---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "Do I need any SEO knowledge to use Stacc?",
    a: "None. Stacc was built for business owners who have never touched an SEO tool. The setup walks you through each step. Once your Google Business Profile is connected and your keywords are set, Stacc runs on autopilot. You don't need to understand how local SEO works — you just need to see your business showing up when customers search.",
  },
  {
    q: "How long does setup take?",
    a: "Most small businesses are fully set up in under 15 minutes. Connect your Google Business Profile via OAuth (3 minutes), set your target keywords and service area (5 minutes), and configure your posting schedule (5 minutes). After that, Stacc handles everything automatically.",
  },
  {
    q: "Why would I use Stacc instead of hiring an SEO agency?",
    a: "A local SEO agency typically charges $1,000–$2,500 per month and requires a 6-month commitment. Stacc is $49/month, no contract, cancel anytime. For most local businesses, Stacc delivers comparable — often better — results because automation is consistent in a way that agency manual work often isn't. You own the data and the results.",
  },
  {
    q: "Will I actually rank higher on Google Maps?",
    a: "89% of Stacc customers see ranking improvements within 30 days. The biggest factors are GBP completeness, posting consistency, citation accuracy, and review velocity — all things Stacc manages automatically. Results vary by market competitiveness, but consistent execution beats sporadic effort every time.",
  },
  {
    q: "What if I only have one location?",
    a: "Stacc works perfectly for single-location businesses. In fact, that's who it was originally built for — the owner-operator who needed agency-level local SEO results without the agency price tag or the learning curve. All features are available from your first location.",
  },
  {
    q: "How does Stacc handle my Google reviews?",
    a: "Stacc monitors your Google reviews in real time. The moment a new review lands, you get an alert with the review text, the star rating, and a suggested response. You can respond directly from Stacc. Review response rates are one of the strongest signals Google uses to rank local businesses — Stacc makes it easy to maintain a strong response record.",
  },
  {
    q: "What happens after my free trial?",
    a: "After your $1 for 3 days, your account continues at $49/month if you choose to stay. No credit card required to start the trial. If you decide Stacc isn't right for you, cancel before the trial ends and you're never charged. There are no contracts and no cancellation fees.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Local SEO for Small Businesses",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Get found on Google Maps and in local search without hiring an SEO agency. theStacc automates the daily work that gets local businesses to the top of local search results.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Solutions", "item": "https://thestacc.com/solutions/" },
        { "@type": "ListItem", "position": 3, "name": "Small Businesses", "item": "https://thestacc.com/solutions/small-businesses/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Local SEO Software for Small Businesses — Rank in Google Maps Without an Agency | theStacc"
  description="Get found on Google Maps and in local search without hiring an SEO agency. theStacc automates the daily work that gets local businesses to the top of local search results."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">For Small Businesses · No SEO Knowledge Required</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Rank on Google Maps.<br />
            <span style="color:#4f39f6;">No agency. No expertise. Just $49/month.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Your competitors showing up above you on Google Maps aren't smarter than you. They're just consistent. Stacc automates the daily local SEO work that gets local businesses found — so you can focus on running your business instead of learning SEO.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start free $1 for 3 days
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No credit card · Set up in 15 minutes · Cancel anytime
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '$49', num: 49, prefix: '$', suffix: '/mo', decimals: 0, from: 0, label: 'vs $1,500/mo for an agency' },
              { value: '15min', num: 15, prefix: '', suffix: 'min', decimals: 0, from: 0, label: 'Average setup time' },
              { value: '89%', num: 89, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'See ranking improvement in 30 days' },
              { value: '0', num: 0, prefix: '', suffix: '', decimals: 0, from: 0, label: 'SEO expertise required' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">If you run a local business</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            You built a great business.<br />The right customers just can't find it.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Customers search "near me" and find your competitor.',
              body: 'Someone within two miles of your business types exactly what you offer into Google. A competitor shows up. You don\'t. That customer never knows you exist. This is happening dozens of times a day, and it costs you more than a bad month of sales — it costs you compounding customer lifetime value.',
            },
            {
              icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'You can\'t afford $1,500 a month for an SEO agency.',
              body: 'Local SEO agencies charge $1,000–$2,500 per month — more than some businesses net in a slow week. The businesses in the top 3 on Google Maps aren\'t all paying agencies. Some of them figured out a cheaper, more consistent way. You can too, without spending a week learning SEO.',
            },
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'You don\'t have time to post, manage reviews, and update listings.',
              body: 'You\'re running a business. The idea of logging into Google Business Profile every week to post content, then checking Yelp for reviews, then auditing your information on 50 directories — that\'s a part-time job you didn\'t sign up for. But ignoring it means staying invisible online.',
            },
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'You don\'t know what\'s actually wrong or what to fix.',
              body: 'Is it your reviews? Your Google Business Profile? Your website? Something called "citations"? Without knowing what to fix, you\'re guessing. And guessing in SEO means months of wasted effort. Most local businesses don\'t have a visibility problem — they have a consistency problem that they don\'t know how to diagnose.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BEFORE/AFTER TABLE ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What changes with Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Agency-level local SEO.<br />Without the agency price tag or learning curve.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]">Task</div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Without Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">With Stacc</div>
          </div>
          {[
            { label: 'Cost', before: '$1,000–$2,500/mo for an agency', after: '$49/month, no contract' },
            { label: 'Setup time', before: 'Weeks to find and onboard an agency', after: '15 minutes to be fully live' },
            { label: 'GBP management', before: 'Manual login, sporadic updates', after: 'Automated posting on a set schedule' },
            { label: 'Review monitoring', before: 'Check manually, respond inconsistently', after: 'Real-time alerts + response templates' },
            { label: 'Citation consistency', before: 'Wrong info across dozens of directories', after: 'Automated audit and correction' },
            { label: 'Ranking visibility', before: 'Guessing based on manual searches', after: 'Daily rank tracking with trend data' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE DEEP DIVES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Built for local business owners</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Everything that gets you ranked.<br />None of the complexity.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Automated GBP Management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated GBP Management</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Your Google Business Profile stays active — without you logging in.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google rewards active, complete Business Profiles with higher local rankings. But posting consistently, keeping hours current, and responding to reviews takes time most business owners don't have. Stacc connects to your GBP and handles all of it — posting on a schedule you set, alerting you the moment a review arrives, and flagging any profile gaps automatically.
              </p>
              <ul class="mt-6 space-y-3">
                {['Posts publish automatically on your schedule — no manual logging in', 'Review alerts arrive instantly with a suggested response ready to send', 'Profile health monitoring flags missing photos, hours, or service descriptions', 'Business hours, phone numbers, and descriptions stay current automatically'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Your GBP · This Month</p>
                <span class="rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">All automated</span>
              </div>
              <div class="space-y-3">
                {[
                  { label: 'Posts published', value: '8', note: 'Scheduled in advance' },
                  { label: 'Reviews responded to', value: '6/6', note: 'Avg response time: 47 min' },
                  { label: 'Profile completeness', value: '97%', note: '+12% vs last month' },
                  { label: 'Local pack ranking', value: '#3', note: '↑4 positions this month' },
                ].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="flex-1">
                      <p class="font-sans text-[12px] font-semibold text-[#374151]">{item.label}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{item.note}</p>
                    </div>
                    <span class="font-mono text-[14px] font-semibold text-[#4f39f6]">{item.value}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Citation Management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Citation Audit · Your Business</p>
              {[
                { dir: 'Google Business Profile', status: 'correct', note: 'All fields match' },
                { dir: 'Yelp', status: 'correct', note: 'Name, address, phone verified' },
                { dir: 'Apple Maps', status: 'fixed', note: 'Phone updated automatically' },
                { dir: 'Bing Places', status: 'fixed', note: 'Hours synced' },
                { dir: 'Facebook Business', status: 'correct', note: 'All fields match' },
              ].map(item => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`h-2 w-2 rounded-full shrink-0 ${item.status === 'correct' ? 'bg-[#059669]' : 'bg-[#d97706]'}`}></div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.dir}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{item.note}</p>
                  </div>
                  <span class={`font-mono text-[10px] font-semibold ${item.status === 'correct' ? 'text-[#059669]' : 'text-[#d97706]'}`}>
                    {item.status === 'correct' ? 'Verified' : 'Auto-fixed'}
                  </span>
                </div>
              ))}
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ directories monitored · Corrections automatic</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Citation Management</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Your business information — consistent everywhere Google looks.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google checks your business information against dozens of directories across the web. Inconsistent names, addresses, or phone numbers send a trust signal that hurts your local ranking. Most businesses have errors in 30–40% of their directory listings — and don't know it. Stacc audits all 50+ major directories continuously and corrects inconsistencies automatically.
              </p>
              <ul class="mt-6 space-y-3">
                {['Audit across 50+ directories — Google, Yelp, Apple Maps, Bing, Facebook, and more', 'Corrections submit automatically — no manual form-filling on 50 different sites', 'NAP consistency score shows you exactly where you stand', 'New inconsistencies flagged and corrected as directories update their data'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What your week looks like</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Local SEO running in the background<br />while you run your business.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: 'Monday 7:00 AM', title: 'Your GBP post published while you were sleeping.', body: 'You scheduled three posts last Sunday. Monday\'s went live at 8AM. Your Google Business Profile looks active to Google — and to customers who scroll your profile. You didn\'t log in. You didn\'t think about it. It just happened.', type: 'automated' },
            { time: 'Tuesday 2:30 PM', title: 'A new review. You responded in 4 minutes.', body: 'A customer left a 5-star review. Stacc sent you an alert with the full review text. You approved the suggested response with one tap. The response went live before the customer closed their phone. That\'s the kind of responsiveness that earns you more reviews and higher rankings.', type: 'alert' },
            { time: 'Thursday 9:00 AM', title: 'Your ranking moved up 2 positions.', body: 'The weekly ranking update shows you moved from position 5 to position 3 for "plumber near me." Stacc shows you what changed — citation consistency improved, GBP activity is up. You didn\'t do anything different. The system did the work.', type: 'outcome' },
            { time: 'Every Friday', title: 'You know exactly where you stand.', body: 'Friday\'s weekly summary: current ranking for each keyword, review score, citation health score, and what Stacc automated this week. One screen. Two minutes. You know your local search health better than most businesses with full-time marketing staff. That\'s what a good system does.', type: 'onboarding' },
          ].map(w => (
            <div class="flex gap-5 rounded-2xl border border-[#e7e5e4] bg-white p-6">
              <div class="shrink-0">
                <div class={`flex h-10 w-10 items-center justify-center rounded-xl ${w.type === 'automated' ? 'bg-[#dcfce7] border border-[#bbf7d0]' : w.type === 'alert' ? 'bg-[#fef3c7] border border-[#fde68a]' : w.type === 'onboarding' ? 'bg-[#f5f3ff] border border-[#c7c0fc]' : 'bg-[#f0f9ff] border border-[#bae6fd]'}`}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={w.type === 'automated' ? '#059669' : w.type === 'alert' ? '#d97706' : w.type === 'onboarding' ? '#4f39f6' : '#0284c7'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    {w.type === 'automated' && <path d="M20 6 9 17l-5-5"/>}
                    {w.type === 'alert' && <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>}
