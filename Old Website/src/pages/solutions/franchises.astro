---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "How does Stacc handle brand control across franchisees?",
    a: "HQ sets the approved content templates, brand guidelines, and mandatory posting cadence in Stacc. Franchisees can publish within those parameters — they can localize content but cannot deviate from brand standards. HQ retains visibility into every franchisee's activity and can override or remove content at any time.",
  },
  {
    q: "What if a franchisee doesn't want to use Stacc?",
    a: "With a 95% adoption rate, most franchisees adopt Stacc quickly because it makes their job easier, not harder. For reluctant franchisees, Stacc's onboarding team can run a direct walkthrough. HQ can also manage a franchisee's local SEO centrally if the franchisee chooses not to engage — either way, the location stays active.",
  },
  {
    q: "Can franchisees see each other's performance data?",
    a: "No. Each franchisee sees only their own location data. HQ and regional managers see the full portfolio. Permissions are role-based — franchisees have no visibility into other franchisees' performance, reviews, or rankings. Competitive benchmarking can be shared by HQ if they choose to do so.",
  },
  {
    q: "Does Stacc integrate with our franchise management software?",
    a: "Stacc connects with common franchise management and CRM platforms via CSV import, Zapier integration, and direct API. Location data — addresses, phone numbers, hours, managers — can sync automatically so your Stacc accounts stay current as your franchise network grows.",
  },
  {
    q: "How does Stacc handle franchisees in different states or countries?",
    a: "Each franchisee location tracks rankings in its specific geographic market. Citation management handles regional directory variations automatically. For international franchise networks, Stacc supports location-specific business information in local formats — hours, phone formatting, and address standards vary by market and Stacc accounts for that.",
  },
  {
    q: "What does HQ see that franchisees don't?",
    a: "HQ sees the complete portfolio — all location rankings, review scores, citation health, GBP activity, and content publishing history across every franchisee. HQ can also see which franchisees are engaging with the platform and which are inactive. Inactivity reports alert HQ when a franchisee location hasn't posted or updated in a set number of days.",
  },
  {
    q: "Can we white-label Stacc for our franchise network?",
    a: "Yes. Franchise networks on Growth and Scale plans can white-label the franchisee-facing dashboard under their brand. Franchisees log in to 'YourBrand Local Hub' — not Stacc. This increases adoption because franchisees see it as your system, not a third-party tool.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Franchise SEO",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Give every franchisee top local rankings without giving up brand control. theStacc lets HQ set the strategy while each location executes locally — automatically.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Solutions", "item": "https://thestacc.com/solutions/" },
        { "@type": "ListItem", "position": 3, "name": "Franchises", "item": "https://thestacc.com/solutions/franchises/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Franchise SEO Software — Local SEO for Every Franchisee, Controlled Centrally | theStacc"
  description="Give every franchisee top local rankings without giving up brand control. theStacc lets HQ set the strategy while each location executes locally — automatically."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">For Franchise Systems · Central Control + Local Execution</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            HQ sets the strategy.<br />
            <span style="color:#4f39f6;">Every franchisee executes it — automatically.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stop choosing between brand consistency and local relevance. Stacc gives franchise HQ full visibility and control while giving each franchisee an automated local SEO system that runs itself — no SEO knowledge required.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Get a franchise demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            200+ franchise systems · 95% franchisee adoption rate · No SEO knowledge required
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '200+', num: 200, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Franchise systems on Stacc' },
              { value: '95%', num: 95, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Franchisee adoption rate' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Brand guidelines enforced automatically' },
              { value: '1', num: 1, prefix: '', suffix: '', decimals: 0, from: 0, label: 'Dashboard for HQ + all franchisees' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">If you run a franchise network</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            The franchise SEO problem<br />no one warned you about.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'Franchisees don\'t know SEO — and don\'t want to.',
              body: 'Your franchisees signed up to run a business, not manage a Google Business Profile. The ones who try do it inconsistently. The ones who don\'t try leave their location invisible in local search. Either way, the customer who could have walked in found a competitor instead.',
            },
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Inconsistent brand representation across locations.',
              body: 'Location 4 is posting off-brand content. Location 19 has the wrong business hours listed. Location 31 hasn\'t posted in two months. HQ has no visibility into any of this — until a customer complaint surfaces, or until your brand audit reveals the damage already done.',
            },
            {
              icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
              title: 'HQ can\'t monitor what they can\'t see.',
              body: 'You don\'t know which franchisees are ranking and which are invisible. You don\'t know which locations have outdated information in 40 directories across the web. You don\'t know which locations are getting bad reviews and not responding. You find out when it becomes a business problem — not before.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Strong locations carry the brand. Weak ones drag it down.',
              body: 'Your best franchisee location ranks #1. Your worst is on page 3. The customer searching "near me" finds the top results — and associates whatever experience they get with your brand. A weak franchisee\'s ranking problem is your brand\'s reputation problem.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BEFORE/AFTER TABLE ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What changes with Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Central control. Local execution.<br />Brand consistency at every location.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]">Area</div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Before Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">With Stacc</div>
          </div>
          {[
            { label: 'Brand enforcement', before: 'Hope franchisees follow guidelines', after: 'Brand templates locked — deviation impossible' },
            { label: 'HQ visibility', before: 'No view across franchise network', after: 'Live portfolio dashboard, every location' },
            { label: 'Franchisee SEO effort', before: 'Manual, inconsistent, or skipped entirely', after: 'Automated — runs without franchisee input' },
            { label: 'Citation consistency', before: 'Different NAP data in every directory', after: 'Automated audit + correction across 50+ directories' },
            { label: 'Review management', before: 'Franchisees don\'t respond, HQ doesn\'t know', after: 'Centralized feed, response templates, full visibility' },
            { label: 'New location launch', before: '2–3 weeks of manual SEO setup', after: 'Configured and live within 24 hours' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE DEEP DIVES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Built for franchise operations</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            HQ controls the rules.<br />Stacc handles the execution at every location.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Brand Control -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Centralized Brand Control</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                HQ sets what's allowed. Franchisees work within it — automatically.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Build your brand content templates in Stacc. Set the approved post formats, imagery guidelines, and messaging frameworks. Franchisees can add location-specific details but cannot publish content outside of those templates. Brand guidelines aren't a document franchisees read once — they're the structural constraint the platform enforces on every post, every day.
              </p>
              <ul class="mt-6 space-y-3">
                {['Pre-approved content templates franchisees customize, not rewrite', 'HQ review queue — approve franchisee content before it publishes', 'Real-time visibility into every franchisee\'s published content', 'Inactivity alerts when a location goes dark for more than X days'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">HQ Content Review Queue</p>
                <span class="rounded-full bg-[#fef3c7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#d97706]">3 pending</span>
              </div>
              <div class="space-y-3">
                {[
                  { loc: 'Dallas — Uptown', content: 'Summer promo post', status: 'approve' },
                  { loc: 'Houston — Midtown', content: 'Holiday hours update', status: 'approve' },
                  { loc: 'Austin — Domain', content: 'Team photo post', status: 'review' },
                ].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="h-8 w-8 rounded-full bg-[#f5f3ff] flex items-center justify-center shrink-0">
                      <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">{item.loc[0]}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{item.loc}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{item.content}</p>
                    </div>
                    <button class={`rounded-lg px-3 py-1.5 font-mono text-[10px] font-semibold ${item.status === 'approve' ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>
                      {item.status === 'approve' ? 'Approve' : 'Review'}
                    </button>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">HQ approves · Franchisee publishes · Brand stays intact</p>
            </div>
          </div>

          <!-- Automated Local SEO -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Franchise Network · Weekly Summary</p>
              {[
                { metric: 'Locations ranking top 3', value: '34/47', change: '+6 this week' },
                { metric: 'Network avg review score', value: '4.6★', change: '+0.2 vs last month' },
                { metric: 'Citation consistency', value: '96%', change: '+8% vs last quarter' },
                { metric: 'GBP posts published', value: '188', change: 'All automated' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.metric}</p>
                    <p class="font-mono text-[10px] text-[#059669]">{r.change}</p>
                  </div>
                  <span class="font-mono text-[14px] font-semibold text-[#4f39f6] shrink-0">{r.value}</span>
                </div>
              ))}
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">HQ dashboard · Updated daily</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated Local SEO for Every Location</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Franchisees don't need to know SEO. Stacc does it for them.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Rank tracking, citation audits, GBP posting, and review monitoring all run automatically for every franchisee location — whether the franchisee engages with the platform or not. The system doesn't require franchisee participation to function. It runs. Results accrue. Rankings improve. Franchisees see their local visibility growing and start engaging more, not less.
              </p>
              <ul class="mt-6 space-y-3">
                {['Automated GBP posting keeps every location active without franchisee effort', 'Citation audits run continuously — inconsistencies corrected automatically', 'Review monitoring sends instant alerts to franchisees with response templates ready', 'HQ sees all of this in a single network-level performance dashboard'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">A week in your franchise network</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            What HQ sees. What franchisees get.<br />What customers experience.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: 'Monday 8:00 AM', title: 'HQ opens the network dashboard.', body: '47 locations, one view. 43 are green — ranking well, reviews responded to, GBP posts running on schedule. 3 are yellow — flagged for review score drops. 1 is red — a franchisee location hasn\'t posted in 11 days. HQ knows exactly where to focus. This review used to take three hours. Now it takes four minutes.', type: 'automated' },
            { time: 'Monday 9:30 AM', title: 'New campaign goes out to the entire network.', body: 'HQ publishes a summer promotion template. 47 franchisee GBPs get the post automatically. Facebook pages follow. Instagram accounts update. Every location is running the same campaign — with their local details auto-personalized. Brand consistent. Locally relevant. Zero franchisee effort required.', type: 'onboarding' },
            { time: 'Wednesday 2:15 PM', title: 'A franchisee location gets a 1-star review.', body: 'Stacc alerts the franchisee instantly with the review text and a pre-approved response template. HQ sees it too. The franchisee responds within the hour. HQ monitors response rates across all locations — and can intervene if a franchisee consistently ignores reviews. The network\'s average review score stays protected.', type: 'alert' },
            { time: 'Friday 5:00 PM', title: 'Network rankings up 14% quarter over quarter.', body: 'The monthly summary arrives. 34 of 47 locations in top 3 for their primary keywords. Citation consistency at 96% across the network. Average review score up 0.2 points. This is what happens when every location gets consistent, automated local SEO execution — regardless of franchisee SEO knowledge.', type: 'outcome' },
          ].map(w => (
            <div class="flex gap-5 rounded-2xl border border-[#e7e5e4] bg-white p-6">
              <div class="shrink-0">
                <div class={`flex h-10 w-10 items-center justify-center rounded-xl ${w.type === 'automated' ? 'bg-[#dcfce7] border border-[#bbf7d0]' : w.type === 'alert' ? 'bg-[#fef3c7] border border-[#fde68a]' : w.type === 'onboarding' ? 'bg-[#f5f3ff] border border-[#c7c0fc]' : 'bg-[#f0f9ff] border border-[#bae6fd]'}`}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={w.type === 'automated' ? '#059669' : w.type === 'alert' ? '#d97706' : w.type === 'onboarding' ? '#4f39f6' : '#0284c7'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
