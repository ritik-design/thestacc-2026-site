---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "Does Stacc include white-label reporting at all plan levels?",
    a: "White-label reporting — your logo, your colors, your domain — is included on Growth and Scale plans. Starter includes Stacc-branded reports. You can upgrade at any time, and existing report schedules carry over automatically.",
  },
  {
    q: "How many client accounts can I manage?",
    a: "All plans support unlimited client accounts. Pricing is based on the number of locations you're tracking and managing, not the number of clients. An agency with 20 clients each with one location pays the same as an agency with 10 clients each with two locations — if total locations are the same.",
  },
  {
    q: "Can I control what clients see in their dashboard?",
    a: "Yes. You decide exactly which data, features, and reports each client can access. You can limit visibility by module, date range, or location. Clients see what's useful to them. You retain full visibility across everything.",
  },
  {
    q: "How long does it take to onboard a new client?",
    a: "Most new clients are fully configured — locations added, keywords set, GBP connected, and automated report schedule live — in under 45 minutes. For multi-location clients with 10+ locations, plan for an hour. After that, Stacc handles everything ongoing.",
  },
  {
    q: "Does Stacc replace my existing SEO tools?",
    a: "For local SEO specifically — rank tracking, citation management, GBP management, review monitoring, and client reporting — yes. Most agencies consolidate 4–6 separate tools into Stacc and cut their tool budget by 60–70%. For advanced link building outreach or technical SEO auditing, Stacc complements those tools rather than replacing them.",
  },
  {
    q: "Can I resell Stacc as a service to my clients?",
    a: "Yes. Many agencies use Stacc as the underlying platform for their local SEO retainers. With white-label reports and client portals, clients interact with your brand throughout — Stacc is invisible. We don't restrict reselling.",
  },
  {
    q: "What integrations are available for client reporting?",
    a: "Reports deliver via email to client inboxes, accessible through white-labeled client portals, and can push data to Google Sheets, Looker Studio, and Slack for agencies with custom reporting workflows.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc for Agencies",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "The local SEO platform built for agencies. Manage every client's GBP, rankings, reviews, and reporting from one white-label dashboard.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Solutions", "item": "https://thestacc.com/solutions/" },
        { "@type": "ListItem", "position": 3, "name": "For Agencies", "item": "https://thestacc.com/solutions/agencies/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO Platform for Agencies — Manage Every Client, Automate Everything | theStacc"
  description="theStacc is the local SEO platform built for agencies. Manage rankings, GBP, reviews, and automated white-label reporting for every client — from one dashboard."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">For SEO Agencies · White-Label Included</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            The SEO platform<br />built for agencies.
            <span style="color:#4f39f6;"> Manage every client. Automate everything.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            One dashboard for every client's local SEO — rank tracking, GBP management, review monitoring, citations, and white-label reporting. All automated. All under your brand.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Get a demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Start free trial
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            400+ agencies · White-label on all growth plans · Setup under 45 minutes
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '400+',  num: 400,  prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Agencies using Stacc' },
              { value: '45min', num: 45,   prefix: '', suffix: 'min', decimals: 0, from: 0, label: 'Avg client onboarding time' },
              { value: '80%',   num: 80,   prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Reduction in manual reporting time' },
              { value: '3×',    num: 3,    prefix: '', suffix: '×', decimals: 0, from: 0, label: 'More clients, same team' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">If you run an SEO agency</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            You already know<br />exactly what this feels like.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'The report tax.',
              body: 'Every Monday morning, someone on your team builds reports instead of doing actual SEO work. 4 hours per client per month. Across 20 clients, that\'s 80 hours a month. That\'s a full-time employee just making PDFs nobody asked to have made by hand.',
            },
            {
              icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
              title: '"Are we ranking?" — on a Friday afternoon.',
              body: 'A client calls. You don\'t have the answer in front of you. You open an incognito tab. You\'re buying time while they\'re losing confidence. You shouldn\'t need 20 minutes to answer a question you should already know the answer to.',
            },
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Six tools. Six logins. One team drowning in tabs.',
              body: 'Rank tracker. Citation tool. GBP management. Review platform. Reporting software. Analytics dashboard. Each client needs all six. Each tool has its own login, its own data format, its own export process. The stack that was supposed to make you efficient is the thing slowing you down.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Growth costs you capacity before it makes you money.',
              body: 'Every new client means more manual work — more reports to build, more dashboards to check, more tabs to open. At some point you stop taking new clients just to stop the bleeding. The business that should be growing is hitting a ceiling made of spreadsheets.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── WHAT CHANGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What changes with Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            One platform. Every client.<br />Nothing manual.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Before Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">With Stacc</div>
          </div>
          {[
            { label: 'Client reporting',      before: '4–6 hrs manual / client / month', after: 'Automated, delivered on schedule' },
            { label: 'Tool stack',            before: '4–6 tools, 4–6 separate bills',   after: 'One platform, one bill' },
            { label: 'Client visibility',     before: 'Client asks → you scramble',       after: 'Dashboard always current' },
            { label: 'New client setup',      before: '3–4 hours minimum',               after: 'Under 45 minutes' },
            { label: 'Rank monitoring',       before: 'Manual check or weekly export',    after: 'Daily automated alerts' },
            { label: 'GBP management',        before: 'Log into each account individually', after: 'All locations in one place' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── AGENCY FEATURES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Built for agencies</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every feature your agency needs.<br />Nothing that gets in your way.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- White Label -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">White-Label Dashboard</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Clients log in to your platform. Not ours.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Every client-facing surface — the dashboard, the reports, the email delivery — carries your logo, your colors, and your domain. Clients interact with your brand throughout. They never see Stacc. They think you built this. You don't have to correct them.
              </p>
              <ul class="mt-6 space-y-3">
                {['Your logo and brand colors throughout the client dashboard', 'Reports delivered from your domain — not a Stacc-branded email', 'Client portal URLs under your agency subdomain', 'Remove all Stacc branding entirely on Growth and Scale plans'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center gap-3">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Your Agency Name</p>
                  <p class="font-mono text-[10px] text-[#79716b]">reports.youragency.com</p>
                </div>
                <span class="ml-auto rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">Fully branded</span>
              </div>
              <div class="space-y-3">
                {['Client login portal', 'Weekly rank report delivery', 'Review monitoring alerts', 'GBP performance dashboard', 'Citation health summary'].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#374151]">{item}</span>
                    <span class="ml-auto font-mono text-[10px] font-semibold text-[#4f39f6]">Your brand</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Automated Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Monday 7:00 AM · Client reports sent</p>
              {[
                { client: 'Smith Plumbing', stat: '+4 ranking positions', type: 'Rank Report' },
                { client: 'Green Valley Dental', stat: '3 new reviews', type: 'Review Report' },
                { client: 'Sunrise HVAC', stat: '28 GBP posts published', type: 'GBP Report' },
                { client: 'City Legal Group', stat: '#1 local pack — 3 keywords', type: 'Local SEO Report' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <div class="h-8 w-8 rounded-full bg-[#f5f3ff] flex items-center justify-center shrink-0">
                    <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">{r.client[0]}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[13px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.type}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669] shrink-0">{r.stat}</span>
                </div>
              ))}
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">All sent automatically · You did nothing</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated Client Reporting</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Reports that build and send themselves. Every client. Every week.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Set your report template once per client. From that day forward, Stacc generates the report, formats it under your brand, and delivers it to the client's inbox on schedule. No one on your team touches it. The 80 hours a month you were spending on reports are now available for actual work.
              </p>
              <ul class="mt-6 space-y-3">
                {['Configure once — delivers forever on your schedule', 'White-label format with your agency branding and commentary', 'Covers rankings, GBP activity, reviews, citations in one report', 'Clients see proof of your work every week without you saying a word'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Monday looks like</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            A week running your agency<br />on Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: '7:00 AM Monday', title: 'Reports already delivered.', body: 'Every client\'s weekly report landed in their inbox at 7AM. You didn\'t touch them. Stacc built and sent 18 reports overnight. Your Monday starts with zero report debt.', type: 'automated' },
            { time: '8:30 AM Monday', title: 'One client had a ranking drop. You already responded.', body: 'Stacc flagged the drop Friday evening. You got the alert, investigated, and had a response plan ready before the client noticed. They think you\'re watching their account 24/7. You are.', type: 'alert' },
            { time: '9:15 AM Monday', title: 'New client onboarded in 40 minutes.', body: 'Locations added. Keywords set. GBP connected. Automated report schedule configured. That client is fully live in Stacc before your second coffee. You didn\'t skip any steps — Stacc just eliminated the manual ones.', type: 'onboarding' },
            { time: '4:00 PM Friday', title: 'You closed the week having done actual SEO.', body: 'Not reports. Not tab-switching. Not copy-pasting data between six tools. You spent the week on strategy, outreach, and the work clients actually pay you for. That\'s not a future plan. That\'s what Stacc makes your default week.', type: 'outcome' },
          ].map(w => (
            <div class="flex gap-5 rounded-2xl border border-[#e7e5e4] bg-white p-6">
              <div class="shrink-0">
                <div class={`flex h-10 w-10 items-center justify-center rounded-xl ${w.type === 'automated' ? 'bg-[#dcfce7] border border-[#bbf7d0]' : w.type === 'alert' ? 'bg-[#fef3c7] border border-[#fde68a]' : w.type === 'onboarding' ? 'bg-[#f5f3ff] border border-[#c7c0fc]' : 'bg-[#f0f9ff] border border-[#bae6fd]'}`}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={w.type === 'automated' ? '#059669' : w.type === 'alert' ? '#d97706' : w.type === 'onboarding' ? '#4f39f6' : '#0284c7'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    {w.type === 'automated' && <path d="M20 6 9 17l-5-5"/>}
                    {w.type === 'alert' && <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>}
                    {w.type === 'onboarding' && <path d="M12 4v16m8-8H4"/>}
                    {w.type === 'outcome' && <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>}
                  </svg>
                </div>
              </div>
              <div>
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">{w.time}</p>
                <p class="mt-1 font-sans text-[15px] font-semibold text-[#111827]">{w.title}</p>
                <p class="mt-1.5 font-sans text-[13px] leading-[1.65] text-[#57534e]">{w.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">ROI for agencies</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            The numbers that matter<br />when you're running an agency.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '80%', num: 80, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Less time on manual reporting', sub: 'recovered per month across your client base' },
            { value: '3×',  num: 3,  prefix: '', suffix: '×', decimals: 0, from: 0, label: 'More clients, same team', sub: 'once reporting and monitoring are automated' },
            { value: '45min', num: 45, prefix: '', suffix: 'min', decimals: 0, from: 0, label: 'Average new client setup', sub: 'from zero to fully configured and live' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIALS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Agency owners</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            What happens when agencies<br />stop doing things manually.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-2">
          {[
            { quote: "We went from 18 to 41 clients in 8 months without hiring a single new person. Stacc automated the reporting and monitoring that was eating all our capacity. The platform essentially hired itself.", name: "Marcus D.", role: "Founder, local SEO agency", result: "18 → 41 clients, same team" },
            { quote: "Client retention went up. I think it's because reports arrive consistently every Monday with real data. Clients used to wonder what they were paying for. Now they get proof every week. Nobody's questioned a retainer in 6 months.", name: "Aisha T.", role: "Agency Director, 23 clients", result: "0 client churn in 6 months" },
          ].map(t => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="flex gap-1 mb-5">
                {[1,2,3,4,5].map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
              </div>
              <blockquote class="font-sans text-[15px] leading-[1.7] text-[#292524]">"{t.quote}"</blockquote>
              <div class="mt-6 flex items-center gap-3">
                <div class="h-10 w-10 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                  <span class="font-mono text-[12px] font-bold text-white">{t.name.split(' ').map(n => n[0]).join('')}</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">{t.name}</p>
                  <p class="font-mono text-[10px] text-[#79716b]">{t.role}</p>
                </div>
                <span class="ml-auto rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">{t.result}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Questions agencies ask before starting
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">One setup away</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            One setup away from never<br />building a client report by hand again.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            The agencies growing fastest aren't smarter. They're not working harder. They're not hiring faster. They're running on better infrastructure — and using the time they get back to actually grow. Join 400+ agencies that made that switch.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Get the agency demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Start free trial
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">No contracts · Cancel anytime</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
