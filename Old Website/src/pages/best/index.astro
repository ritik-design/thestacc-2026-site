---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('best');

const sortedPosts = posts.sort((a, b) => {
  const dateA = new Date(a.data.date);
  const dateB = new Date(b.data.date);
  if (dateB.getTime() !== dateA.getTime()) return dateB.getTime() - dateA.getTime();
  return a.data.title.localeCompare(b.data.title);
});

const visiblePosts = sortedPosts.filter(p => p.data.image);

function readTime(body: string): number {
  const words = (body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const categoryDefs = [
  { id: 'automation', label: 'SEO Automation', filter: (p: any) => ['done-for-you-seo-tools','seo-autopilot-software','seo-automation-software','seo-tools-that-do-the-work','content-autopilot-software','seo-agency-alternatives'].includes(p.data.slug) },
  { id: 'blog', label: 'Blog & Content', filter: (p: any) => ['autoblogging-tools','automated-blog-writing-tools'].includes(p.data.slug) },
  { id: 'local', label: 'Local SEO & GBP', filter: (p: any) => ['gbp-automation-tools','affordable-local-seo-tools','local-seo-tools-under-100','local-seo-automation-tools','all-in-one-local-marketing-tools'].includes(p.data.slug) },
  { id: 'industry', label: 'Industry-Specific', filter: (p: any) => p.data.slug.startsWith('seo-tools-for-') },
  { id: 'ai', label: 'AI Writing', filter: (p: any) => p.data.slug.includes('ai-blog') || p.data.slug.includes('ai-content') || p.data.slug.includes('ai-writer') },
];

const categorizedSlugs = new Set<string>();
const categoryPosts: Record<string, any[]> = {};
categoryDefs.forEach(cat => {
  const cp = visiblePosts.filter(cat.filter);
  if (cp.length > 0) {
    categoryPosts[cat.id] = cp;
    cp.forEach(p => categorizedSlugs.add(p.data.slug));
  }
});
const uncategorized = visiblePosts.filter(p => !categorizedSlugs.has(p.data.slug));
if (uncategorized.length > 0) categoryPosts['other'] = uncategorized;

const methodologyItems = [
  { icon: '🔬', label: 'Tools tested', detail: 'Hands-on + public data' },
  { icon: '💰', label: 'Pricing verified', detail: 'Official pages, March 2026' },
  { icon: '⚡', label: 'ROI focus', detail: 'Features per dollar spent' },
  { icon: '🚫', label: 'Sponsored picks', detail: 'None. Zero. Ever.' },
];
---

<BaseLayout
  title="Best SEO Tools & Software Compared 2026 - theStacc"
  description="We tested and ranked the best SEO tools across every category. Automation, autoblogging, local SEO, GBP tools, and industry picks. Real pricing. Zero fluff."
>
  <Header />
  <main class="flex-1">

    <!-- ░░ DARK HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-12 pb-12">

        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Best Lists</span>
          <span class="h-3 w-px bg-[#e7e5e4]"></span>
          <span class="font-mono text-[10px] text-[#79716b]">{visiblePosts.length} guides</span>
        </div>

        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px]">
          Best SEO Tools &amp; Software
        </h1>
        <p class="mt-3 max-w-[560px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          We tested and ranked the best SEO tools across every category. Automation, autoblogging, local SEO, and industry-specific picks. Real pricing, honest pros and cons, zero fluff.
        </p>

        <!-- Trust pills -->
        <div class="mt-6 flex flex-wrap gap-2">
          {[
            `${visiblePosts.length} guides tested`,
            'Updated March 2026',
            'Pricing verified',
            'No sponsored picks',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>

      </div>
    </section>

    <!-- ░░ METHODOLOGY STRIP ░░ -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x">
        <div class="flex items-center gap-6 overflow-x-auto py-4 scrollbar-none">
          {methodologyItems.map(item => (
            <div class="flex shrink-0 items-center gap-2.5">
              <span class="text-[16px]">{item.icon}</span>
              <div>
                <p class="font-mono text-[11px] font-bold text-[#292524]">{item.label}</p>
                <p class="font-mono text-[10px] text-[#79716b]">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ░░ CATEGORY FILTER TABS ░░ -->
    <div class="sticky top-0 z-20 border-b border-[#e7e5e4] bg-white shadow-[0_1px_0_0_#e7e5e4]">
      <div class="container-x">
        <div class="flex items-center gap-1 overflow-x-auto py-3 scrollbar-none" id="cat-tabs">
          <button data-cat="all" class="cat-tab active shrink-0">All ({visiblePosts.length})</button>
          {categoryDefs.filter(c => categoryPosts[c.id]).map(cat => (
            <button data-cat={cat.id} class="cat-tab shrink-0">
              {cat.label} ({categoryPosts[cat.id]?.length ?? 0})
            </button>
          ))}
          {uncategorized.length > 0 && (
            <button data-cat="other" class="cat-tab shrink-0">More ({uncategorized.length})</button>
          )}
        </div>
      </div>
    </div>

    <!-- ░░ CARD GRID ░░ -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-6xl">

        <!-- All posts panel -->
        <div id="grid-all" class="cat-panel">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {visiblePosts.map((post) => (
              <a href={`/best/${post.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
                <div class="flex flex-1 flex-col p-6">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Best List</span>
                  <h2 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{post.data.title}</h2>
                  <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                  <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                    <span class="font-mono text-[10px] text-[#79716b]">{post.data.date} · {readTime(post.body ?? '')} min</span>
                    <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Per-category panels -->
        {categoryDefs.filter(c => categoryPosts[c.id]).map(cat => (
          <div id={`grid-${cat.id}`} class="cat-panel hidden">
            <div class="mb-6">
              <h2 class="font-sans text-[20px] font-bold text-[#292524]">{cat.label}</h2>
              <p class="mt-1 font-mono text-[11px] text-[#79716b]">{categoryPosts[cat.id]?.length} guides</p>
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {categoryPosts[cat.id].map((post: any) => (
                <a href={`/best/${post.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                  <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
                  <div class="flex flex-1 flex-col p-6">
                    <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">{cat.label}</span>
                    <h3 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{post.data.title}</h3>
                    <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                    <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                      <span class="font-mono text-[10px] text-[#79716b]">{post.data.date} · {readTime(post.body ?? '')} min</span>
                      <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}

        <!-- Other panel -->
        {uncategorized.length > 0 && (
          <div id="grid-other" class="cat-panel hidden">
            <div class="mb-6">
              <h2 class="font-sans text-[20px] font-bold text-[#292524]">More Best Lists</h2>
              <p class="mt-1 font-mono text-[11px] text-[#79716b]">{uncategorized.length} guides</p>
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {uncategorized.map((post: any) => (
                <a href={`/best/${post.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                  <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
                  <div class="flex flex-1 flex-col p-6">
                    <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Best List</span>
                    <h3 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{post.data.title}</h3>
                    <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                    <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                      <span class="font-mono text-[10px] text-[#79716b]">{post.data.date} · {readTime(post.body ?? '')} min</span>
                      <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

      </div>
    </section>

    <!-- ░░ DARK FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#818cf8]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Stop researching. Start ranking.
        </h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          30 SEO blog articles published to your site every month. Automatically. No writers, no workflow, no waiting.
        </p>
        <a
          href="/demo/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Start Your $1 Trial
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">$1 for 3 days · Cancel anytime</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
.cat-tab {
  cursor: pointer;
  padding: 0.4rem 0.875rem;
  font-family: var(--font-geist-mono);
  font-size: 12px;
  font-weight: 600;
  color: #57534e;
  background: transparent;
  border: none;
  white-space: nowrap;
  transition: color 0.1s, background 0.1s;
}
.cat-tab:hover { color: #4f39f6; background: #f5f3ff; }
.cat-tab.active { color: #4f39f6; background: #f5f3ff; }
.scrollbar-none::-webkit-scrollbar { display: none; }
.scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
const tabs = document.querySelectorAll('.cat-tab');
const panels = document.querySelectorAll('.cat-panel');

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    const cat = (tab as HTMLElement).dataset.cat;
    tabs.forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    panels.forEach((panel: any) => {
      const id = panel.id.replace('grid-', '');
      panel.classList.toggle('hidden', id !== cat);
    });
    // Scroll to grid
    document.querySelector('.cat-panel:not(.hidden)')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});
</script>
