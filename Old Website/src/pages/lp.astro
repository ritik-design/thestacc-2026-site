  <style is:global>
    /* ============================================================
       TOKENS: matched to the live thestacc.com (indigo on warm stone)
       ============================================================ */
    :root {
      --bg-outer: #ffffff;
      --bg: #ffffff;
      --surface: #ffffff;
      --surface-2: #f7f6f4;
      --grid: #ecebe8;

      --border: #e7e5e4;
      --border-strong: #d6d3d1;

      --text: #1c1917;
      --text-2: #57534e;
      --text-3: #79716b;

      --accent: #4f39f6;
      --accent-press: #3f2fd0;
      --accent-200: #c7d2fe;
      --accent-100: #e0e7ff;
      --accent-wash: #f5f4ff;

      --dark: #1c1917;
      --dark-2: #262220;
      --dark-card: #211d1b;
      --dark-border: rgba(255,255,255,.10);

      --pos: #059669;
      --pos-wash: #ecfdf5;
      --neg: #e11d48;
      --neg-wash: #fff1f2;
      --amber: #b45309;
      --amber-wash: #fffbeb;

      --r-xs: 8px;
      --r-sm: 12px;
      --r-md: 16px;
      --r-lg: 22px;
      --r-pill: 999px;

      --shadow-sm: 0 1px 2px rgba(28,25,23,.05), 0 1px 1px rgba(28,25,23,.04);
      --shadow-md: 0 4px 16px -4px rgba(28,25,23,.10), 0 2px 6px -2px rgba(28,25,23,.06);
      --shadow-lg: 0 24px 60px -18px rgba(28,25,23,.22), 0 8px 24px -10px rgba(79,57,246,.10);
      --shadow-accent: 0 12px 30px -8px rgba(79,57,246,.45);

      --maxw: 1280px;
      --gutter: clamp(20px, 5vw, 56px);

      --fs-display: clamp(2.5rem, 1.2rem + 5.4vw, 4.2rem);
      --fs-h2: clamp(1.8rem, 1.05rem + 2.8vw, 2.75rem);
      --fs-h3: clamp(1.25rem, 1rem + 0.9vw, 1.55rem);
      --fs-lead: clamp(1.06rem, 1rem + 0.5vw, 1.28rem);
      --fs-body: 1.0625rem;
      --fs-sm: 0.9rem;
      --fs-label: 0.78rem;

      --ease: cubic-bezier(.16,1,.3,1);
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }

    body {
      margin: 0;
      background: var(--bg-outer);
      color: var(--text);
      font-family: "Geist", system-ui, -apple-system, "Segoe UI", sans-serif;
      font-size: var(--fs-body);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      overflow-x: hidden;
    }
    h1, h2, h3, h4 { margin: 0; font-weight: 600; line-height: 1.08; letter-spacing: -0.02em; color: var(--text); overflow-wrap: break-word; }
    h1 { letter-spacing: -0.035em; }
    p { margin: 0; }
    a { color: inherit; text-decoration: none; }
    img, svg, video { display: block; max-width: 100%; }
    ::selection { background: var(--accent); color: #fff; }
    :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

    /* ---------- The framed "lined box" ---------- */
    .frame { width: 100%; max-width: var(--maxw); margin-inline: 0; background: var(--surface); border-inline: 1px solid var(--border); overflow-x: hidden; min-width: 0; }
    body > div:has(> .frame) { background: transparent !important; max-width: var(--maxw) !important; }
    section { padding: clamp(56px, 7vw, 104px) var(--gutter); border-bottom: 1px solid var(--border); text-align: center; position: relative; }
    .band-alt { background: var(--surface-2); }
    .inner { max-width: 1200px; margin-inline: auto; min-width: 0; }
    .narrow { max-width: 720px; margin-inline: auto; min-width: 0; }
    .mono { font-family: "Geist Mono", ui-monospace, monospace; }
    .tabnum { font-variant-numeric: tabular-nums; }

    /* Kicker label (centered) */
    .kicker {
      display: inline-flex; align-items: center; gap: 10px;
      font-family: "Geist Mono", monospace; font-size: var(--fs-label); font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent);
    }
    .kicker::before, .kicker::after { content: ""; width: 18px; height: 1.5px; background: var(--accent); opacity: .5; }

    .section-head { max-width: 760px; margin: 0 auto clamp(40px, 5vw, 60px); }
    .section-head h2 { font-size: var(--fs-h2); margin-top: 18px; }
    .section-head .lead { font-size: var(--fs-lead); color: var(--text-2); margin-top: 18px; line-height: 1.5; }
    .section-head .lead .accent { color: var(--accent); font-weight: 600; }
    .section-head .lead .muted { color: var(--text-3); }
    @media (max-width: 480px) {
      section { padding: clamp(40px, 6vw, 56px) var(--gutter); }
      .section-head { margin-bottom: clamp(24px, 4vw, 40px); }
      .section-head h2 { font-size: clamp(1.45rem, 1rem + 2.2vw, 1.8rem); }
      .section-head .lead { font-size: 1rem; margin-top: 12px; }
      .kicker { gap: 6px; font-size: 0.72rem; }
      .kicker::before, .kicker::after { width: 12px; }
    }

    /* ---------- Buttons ---------- */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 9px;
      font-family: inherit; font-size: var(--fs-body); font-weight: 600;
      padding: 14px 24px; border: 1px solid transparent;
      cursor: pointer; white-space: nowrap; line-height: 1;
      transition: transform .18s var(--ease), background .18s var(--ease), box-shadow .18s var(--ease), border-color .18s var(--ease);
    }
    .btn svg { width: 17px; height: 17px; }
    .btn-primary { background: var(--accent); color: #fff; box-shadow: var(--shadow-accent); }
    .btn-primary:hover { background: var(--accent-press); transform: translateY(-2px); }
    .btn-ghost { background: transparent; color: var(--text); border-color: var(--border-strong); }
    .btn-ghost:hover { background: var(--surface); border-color: var(--text-3); transform: translateY(-2px); box-shadow: var(--shadow-sm); }
    .btn-light { background: #fff; color: var(--accent); }
    .btn-light:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -10px rgba(0,0,0,.35); }
    .btn-on-dark-ghost { background: rgba(255,255,255,.06); color: #fff; border-color: rgba(255,255,255,.28); }
    .btn-on-dark-ghost:hover { background: rgba(255,255,255,.14); border-color: rgba(255,255,255,.5); }
    .btn-lg { padding: 17px 30px; font-size: 1.075rem; }
    .btn-block { width: 100%; }

    .cta-microcopy { font-size: var(--fs-sm); color: var(--text-3); margin-top: 14px; }
    .cta-microcopy.on-dark { color: rgba(255,255,255,.6); }

    /* ============================================================
       NAV (full-bleed, aligned to frame)
       ============================================================ */
    .skip { position: absolute; left: -999px; top: 8px; background: var(--accent); color: #fff; padding: 10px 16px; z-index: 200; }
    .skip:focus { left: 12px; }

    header.nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(250,250,249,.82); backdrop-filter: saturate(180%) blur(14px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner { max-width: var(--maxw); margin-inline: auto; display: flex; align-items: center; justify-content: space-between; gap: 24px; height: 66px; padding-inline: var(--gutter); }
    .brand { display: inline-flex; align-items: center; gap: 9px; flex: 1 1 0; }
    .brand img { height: 28px; width: auto; }
    .nav-links { display: flex; gap: 28px; flex: 0 0 auto; }
    .nav-links a { font-size: var(--fs-sm); font-weight: 500; color: var(--text-2); transition: color .15s; }
    .nav-links a:hover { color: var(--text); }
    .nav-cta { display: flex; gap: 10px; align-items: center; flex: 1 1 0; justify-content: flex-end; }
    .nav-cta .btn { padding: 10px 18px; font-size: var(--fs-sm); box-shadow: none; }
    .nav-cta .btn-primary { box-shadow: 0 6px 16px -6px rgba(79,57,246,.5); }
    @media (max-width: 940px) { .nav-links { display: none; } .nav-cta .demo-nav { display: none; } }
    @media (max-width: 480px) {
      .nav-inner { height: 58px; padding-inline: calc(var(--gutter) * 0.85); }
      .brand img { max-width: 120px; height: 24px; }
      .nav-cta .btn { padding: 8px 14px; font-size: 0.82rem; }
    }

    /* ============================================================
       HERO (homepage layout with LP copy + Safari mockup)
       ============================================================ */

    /* Hero section: kill the global section padding/border so Tailwind
       py-* utilities and a seamless edge with the logo bar take over. */
    section.hero-lp { padding: 0; border-bottom: none; text-align: center; }

    /* Force-correct spacing rhythm in the hero stack. The global resets in
       this file (p { margin: 0 }, h1..h4 { margin: 0 }) use the `margin`
       shorthand which has equal specificity to and lower source-order than
       Tailwind utility margins. We re-assert the rhythm here so it can't
       be silently flattened. */
    .hero-stack > .hero-eyebrow { margin-top: 0; }
    .hero-stack > .hero-title   { margin-top: 28px; }
    .hero-stack > .hero-sub     { margin-top: 20px; }
    .hero-stack > .hero-cta     { margin-top: 36px; }
    .hero-stack > .hero-fine    { margin-top: 16px; }
    @media (min-width: 640px) {
      .hero-stack > .hero-title { margin-top: 32px; }
      .hero-stack > .hero-sub   { margin-top: 24px; }
      .hero-stack > .hero-cta   { margin-top: 40px; }
      .hero-stack > .hero-fine  { margin-top: 20px; }
    }

    /* Safari mockup wrapper handles spacing; .safari handles chrome. */
    .hero-mockup { position: relative; z-index: 1; margin-top: 48px; }
    @media (min-width: 640px) { .hero-mockup { margin-top: 56px; } }
    @media (min-width: 1024px){ .hero-mockup { margin-top: 72px; } }

    /* Safari window mockup */
    .safari { width: 100%; max-width: 100%; margin: 0 auto; overflow: hidden; border: 1px solid var(--border); box-shadow: var(--shadow-lg); background: var(--surface); }
    .safari-bar { display: flex; align-items: center; gap: 14px; padding: 12px 16px; background: var(--surface-2); border-bottom: 1px solid var(--border); }
    .safari-dots { display: flex; gap: 8px; }
    .safari-dots i { width: 12px; height: 12px; display: block; }
    .safari-dots i:nth-child(1) { background: #ff5f57; }
    .safari-dots i:nth-child(2) { background: #febc2e; }
    .safari-dots i:nth-child(3) { background: #28c840; }
    .safari-url { flex: 1; max-width: 340px; margin-inline: auto; background: var(--surface); border: 1px solid var(--border); padding: 6px 14px; font-family: "Geist Mono", monospace; font-size: var(--fs-label); color: var(--text-3); display: inline-flex; align-items: center; gap: 7px; justify-content: center; }
    .safari-url svg { width: 12px; height: 12px; }
    .safari-actions { display: flex; gap: 14px; color: var(--text-3); }
    .safari-actions svg { width: 16px; height: 16px; }
    @media (max-width: 600px) { .safari-actions { display: none; } }
    @media (max-width: 640px) {
      .safari-bar { padding: 10px 12px; }
      .safari-url { max-width: 220px; padding: 5px 10px; font-size: 0.7rem; }
    }
    @media (max-width: 480px) {
      .safari { }
      .safari-bar { padding: 9px 11px; }
      .safari-url { max-width: 170px; font-size: 0.65rem; }
      .safari-dots { gap: 6px; }
      .safari-dots i { width: 10px; height: 10px; }
    }
    @media (max-width: 360px) {
      .safari-url { max-width: 130px; }
      .safari-dots { display: none; }
    }
    .safari-body { background: #000; aspect-ratio: 1920 / 1318; }
    .safari-body video { width: 100%; height: 100%; object-fit: cover; display: block; }

    /* ============================================================
       LOGO BAR
       ============================================================ */
    .logobar { padding-block: clamp(34px, 4vw, 48px); }
    .logobar p { font-size: var(--fs-sm); color: var(--text-3); margin-bottom: 24px; }
    .logos { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 16px 40px; }
    .logos span { font-weight: 600; font-size: 1.05rem; letter-spacing: -0.02em; color: var(--text-3); opacity: .8; transition: color .2s, opacity .2s; }
    .logos span:hover { color: var(--text); opacity: 1; }
    @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    .animate-marquee { animation: marquee 30s linear infinite; width: max-content; }
    .animate-marquee:hover { animation-play-state: paused; }
    @media (max-width: 480px) {
      .logobar .absolute.left-0, .logobar .absolute.right-0 { width: 32px !important; }
      .logobar p { margin-bottom: 16px; }
    }

    /* ============================================================
       PROBLEM (centered, pointer cards with animated icons)
       ============================================================ */
    .prob-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; min-width: 0; }
    @media (max-width: 720px) { .prob-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 480px) { .prob-grid { grid-template-columns: minmax(0, 1fr); } }
    .pcard {
      background: var(--surface); border: 1px solid var(--border);
      padding: 26px 22px; text-align: center; transition: transform .25s var(--ease), box-shadow .25s var(--ease), border-color .25s;
    }
    .pcard:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--accent-200); }
    .picon { width: 52px; height: 52px; margin: 0 auto 16px; background: var(--accent-wash); border: 1px solid var(--accent-100); color: var(--accent); display: grid; place-items: center; }
    .picon svg { width: 26px; height: 26px; transform-box: fill-box; transform-origin: center; }
    .pcard h4 { font-size: 1.08rem; font-weight: 600; }
    .pcard .pain { margin-top: 8px; font-size: var(--fs-sm); color: var(--neg); display: inline-flex; align-items: center; gap: 7px; }
    .pcard .pain svg { width: 15px; height: 15px; flex: none; }
    .pcard .pdesc { margin-top: 10px; font-size: var(--fs-sm); color: var(--text-2); line-height: 1.45; }
    .prob-foot { margin-top: 34px; font-size: 1.18rem; font-weight: 500; color: var(--text); max-width: 50ch; margin-inline: auto; }
    .prob-foot .accent { color: var(--accent); }
    /* hover animations */
    .pcard:hover .pi-cost { animation: picost .85s var(--ease) infinite; }
    @keyframes picost { 0%,100% { transform: translateY(0) rotate(0); } 45% { transform: translateY(-5px) rotate(-7deg); } }
    .pcard:hover .pi-flaky { animation: piflaky 1.3s var(--ease) infinite; }
    @keyframes piflaky { 0% { transform: rotate(0); } 45% { transform: rotate(28deg); } 100% { transform: rotate(28deg); } }
    .pcard:hover .pi-silo { animation: pisilo .7s var(--ease) infinite; }
    @keyframes pisilo { 0%,100% { transform: translateX(0) rotate(0); } 50% { transform: translateX(3px) rotate(9deg); } }
    .pcard:hover .pi-time { animation: pitime 1.5s var(--ease) infinite; }
    @keyframes pitime { 0% { transform: rotate(0); } 55% { transform: rotate(180deg); } 100% { transform: rotate(180deg); } }

    /* ============================================================
       HOW IT WORKS (bento)
       ============================================================ */
    .bento-how { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; text-align: left; min-width: 0; }
    @media (max-width: 720px) { .bento-how { grid-template-columns: minmax(0, 1fr); } }
    .htile { background: var(--surface); border: 1px solid var(--border); padding: 30px; position: relative; transition: transform .25s var(--ease), box-shadow .25s var(--ease), border-color .25s; }
    .htile:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--border-strong); }
    .htile.feature { grid-row: span 2; background: linear-gradient(180deg, var(--accent-wash), var(--surface)); border-color: var(--accent-100); display: flex; flex-direction: column; }
    .htile .n { font-family: "Geist Mono", monospace; font-size: var(--fs-label); color: var(--accent); font-weight: 500; }
    .htile h3 { font-size: var(--fs-h3); margin: 12px 0 10px; }
    .htile p { color: var(--text-2); font-size: var(--fs-body); }
    .htile .ico { position: absolute; top: 28px; right: 26px; color: var(--accent); }
    .htile .ico svg { width: 26px; height: 26px; transform-box: fill-box; transform-origin: center; }
    .htile:hover .ico .spin { animation: spin 6s linear infinite; }
    .runlist { margin-top: auto; padding-top: 22px; display: flex; flex-wrap: wrap; gap: 8px; }
    .runlist span { font-size: var(--fs-label); font-weight: 500; color: var(--accent); background: rgba(255,255,255,.7); border: 1px solid var(--accent-100); padding: 6px 11px; }
    @media (max-width: 480px) {
      .htile { padding: 20px; }
      .htile .ico { top: 18px; right: 18px; }
      .htile .ico svg { width: 22px; height: 22px; }
      .runlist { gap: 6px; padding-top: 16px; }
      .runlist span { font-size: 0.72rem; padding: 4px 8px; }
    }
    .runlist .live { display: inline-flex; align-items: center; gap: 7px; color: var(--pos); background: var(--pos-wash); border-color: transparent; }
    .runlist .live i { width: 7px; height: 7px; background: var(--pos); }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ============================================================
       AEO BAND (under How it works)
       ============================================================ */
    .aeo-band {
      margin-top: clamp(28px, 3.6vw, 44px);
      display: grid;
      grid-template-columns: auto 1fr;
      gap: clamp(20px, 3vw, 32px);
      align-items: start;
      padding: clamp(24px, 3vw, 36px);
      background: linear-gradient(180deg, var(--accent-wash), var(--surface));
      border: 1px solid var(--accent-100);
      text-align: left;
    }
    .aeo-band .aeo-icon {
      width: 56px; height: 56px;
      display: flex; align-items: center; justify-content: center;
      background: #fff;
      border: 1px solid var(--accent-100);
      color: var(--accent);
    }
    .aeo-band .aeo-icon svg { width: 28px; height: 28px; }
    .aeo-band .aeo-tag {
      display: inline-block;
      font-family: "Geist Mono", monospace;
      font-size: var(--fs-label);
      font-weight: 500;
      color: var(--accent);
      background: #fff;
      border: 1px solid var(--accent-100);
      padding: 4px 10px;
    }
    .aeo-band h3 { font-size: var(--fs-h3); margin: 12px 0 10px; }
    .aeo-band p { color: var(--text-2); font-size: var(--fs-body); }
    .aeo-band .aeo-chips { margin-top: 16px; display: flex; flex-wrap: wrap; gap: 8px; }
    .aeo-band .aeo-chips span {
      font-size: var(--fs-label); font-weight: 500;
      color: var(--accent);
      background: rgba(255,255,255,.8);
      border: 1px solid var(--accent-100);
      padding: 6px 11px;
    }
    @media (max-width: 600px) {
      .aeo-band { grid-template-columns: 1fr; }
      .aeo-band .aeo-icon { width: 48px; height: 48px; }
      .aeo-band .aeo-icon svg { width: 24px; height: 24px; }
    }

    /* ============================================================
       PROOF STATS (dark, animated numbers)
       ============================================================ */
    .proof { background: var(--dark); color: #fff; padding-block: clamp(36px, 4.5vw, 60px); }
    .proof::before { content: ""; position: absolute; inset: 0; pointer-events: none; background-image: linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px); background-size: 46px 46px; -webkit-mask: radial-gradient(100% 70% at 50% 0%, #000, transparent 75%); mask: radial-gradient(100% 70% at 50% 0%, #000, transparent 75%); }
    .proof > * { position: relative; }
    .proof h2 { color: #fff; }
    .proof .kicker { color: var(--accent-200); }
    .proof .kicker::before, .proof .kicker::after { background: var(--accent-200); }
    .proof .proof-tag {
      margin-top: 14px;
      max-width: 640px;
      margin-left: auto; margin-right: auto;
      font-size: clamp(1.05rem, 1.6vw, 1.25rem);
      line-height: 1.45;
      color: rgba(255,255,255,.85);
      font-weight: 500;
    }
    .proof .proof-tag .accent { color: var(--accent-200); }
    .stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1px; background: var(--dark-border); border: 1px solid var(--dark-border); overflow: hidden; min-width: 0; }
    @media (max-width: 760px) { .stats { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 440px) { .stats { grid-template-columns: minmax(0, 1fr); } }
    .stats.s4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    @media (max-width: 760px) { .stats.s4 { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 440px) { .stats.s4 { grid-template-columns: minmax(0, 1fr); } }
    .stats.s2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    @media (max-width: 440px) { .stats.s2 { grid-template-columns: minmax(0, 1fr); } }
    .stat { background: var(--dark); padding: clamp(26px, 4vw, 40px) clamp(20px, 3vw, 30px); text-align: center; }
    .stat .num { font-size: clamp(2.2rem, 1.4rem + 3vw, 3.3rem); font-weight: 700; letter-spacing: -0.04em; line-height: 1; color: #fff; }
    .stat .num .u { color: var(--accent-200); }
    .stat .lbl { color: rgba(255,255,255,.6); font-size: var(--fs-sm); margin-top: 12px; }

    /* ============================================================
       MODULES (bento)
       ============================================================ */
    .bento-mod { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr); gap: 16px; text-align: left; align-items: stretch; min-width: 0; }
    .bento-mod > * { min-width: 0; }
    @media (max-width: 720px) { .bento-mod { grid-template-columns: minmax(0, 1fr); } }
    .mtile { background: var(--surface); border: 1px solid var(--border); padding: 28px; transition: transform .25s var(--ease), box-shadow .25s var(--ease), border-color .25s; }
    .mtile:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--accent-200); }
    .mtile.blog { grid-row: span 2; display: flex; flex-direction: column; }
    .mside { display: grid; grid-row: span 2; grid-template-rows: 1fr 1fr; gap: 16px; min-width: 0; }
    .m-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .m-ico { width: 46px; height: 46px; display: grid; place-items: center; flex: none; }
    .m-ico.i-blog { background: var(--accent-wash); color: var(--accent); border: 1px solid var(--accent-100); }
    .m-ico.i-local { background: var(--pos-wash); color: var(--pos); border: 1px solid #bbf7d0; }
    .m-ico.i-social { background: var(--amber-wash); color: var(--amber); border: 1px solid #fde68a; }
    .m-ico svg { width: 24px; height: 24px; }
    .m-price { font-size: var(--fs-sm); color: var(--text-3); }
    .m-price b { font-size: 1.5rem; color: var(--text); font-weight: 700; letter-spacing: -0.02em; }
    .m-tag {
      font-family: "Geist Mono", monospace;
      font-size: var(--fs-label);
      font-weight: 500;
      color: var(--accent);
      background: var(--accent-wash);
      border: 1px solid var(--accent-100);
      padding: 5px 11px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .mtile h3 { font-size: var(--fs-h3); margin: 16px 0 8px; }
    .mtile .m-desc { color: var(--text-2); font-size: var(--fs-sm); }
    .mlist { list-style: none; padding: 0; margin: 18px 0 0; display: grid; gap: 11px; }
    .mlist li { display: flex; gap: 10px; font-size: var(--fs-sm); color: var(--text-2); align-items: flex-start; }
    .mlist svg { width: 18px; height: 18px; color: var(--accent); flex: none; margin-top: 1px; }
    .mlist b { color: var(--text); font-weight: 600; }
    .mlist-compact { margin-top: 14px; gap: 8px; }
    .mlist-compact li { font-size: var(--fs-label); }
    .mlist-compact svg { width: 16px; height: 16px; }
    .blog .m-visual { margin-top: auto; padding-top: 22px; border-top: 1px solid var(--border); }
    .blog .callout { margin-top: auto; padding-top: 20px; font-size: var(--fs-sm); color: var(--text-2); }
    .blog .callout b { color: var(--accent); }
    .mini-feed { display: grid; gap: 8px; }
    .mini-row { display: flex; align-items: center; gap: 10px; padding: 9px 11px; border: 1px solid var(--border); background: var(--bg); }
    .mini-row .cms { width: 24px; height: 24px; flex: none; display: grid; place-items: center; font-family: "Geist Mono", monospace; font-weight: 600; font-size: .64rem; color: #fff; }
    .mini-row .t { font-size: var(--fs-sm); min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    @media (max-width: 480px) { .mini-row .t { white-space: normal; } }
    .mini-row .st { margin-left: auto; font-size: var(--fs-label); font-weight: 600; color: var(--pos); background: var(--pos-wash); padding: 3px 8px; flex: none; }

    /* ============================================================
       INTEGRATIONS (orbiting circles, real logos)
       ============================================================ */
    .orbit { --ro: 188; --ri: 122; position: relative; width: min(500px, 92vw); aspect-ratio: 1; margin: clamp(36px,5vw,52px) auto 0; overflow: visible; }
    .orbit-path { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); border: 1px dashed var(--border-strong); pointer-events: none; }
    .orbit-path.p1 { width: calc(var(--ri) * 2px); height: calc(var(--ri) * 2px); }
    .orbit-path.p2 { width: calc(var(--ro) * 2px); height: calc(var(--ro) * 2px); }
    .orbit-hub { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); z-index: 5; width: 172px; height: 172px; display: grid; place-items: center; }
    .orbit-hub img { width: 168px; height: 168px; object-fit: contain; }
    .orbit-item { position: absolute; top: 50%; left: 50%; width: 50px; height: 50px; margin: -25px; z-index: 3; background: var(--surface); border: 1px solid var(--border); box-shadow: var(--shadow-sm); display: grid; place-items: center; animation: orbit var(--dur, 30s) linear infinite; }
    .orbit-item.rev { animation-direction: reverse; }
    .orbit-item svg { width: 27px; height: 27px; }
    .o-out { --radius: var(--ro); --dur: 36s; }
    .o-in { --radius: var(--ri); --dur: 26s; }
    @keyframes orbit {
      from { transform: rotate(calc(var(--angle) * 1deg)) translateX(calc(var(--radius) * 1px)) rotate(calc(var(--angle) * -1deg)); }
      to   { transform: rotate(calc(var(--angle) * 1deg + 360deg)) translateX(calc(var(--radius) * 1px)) rotate(calc(var(--angle) * -1deg - 360deg)); }
    }
    @media (max-width: 640px) {
      .orbit { --ro: 118; --ri: 74; width: min(340px, 88vw); }
      .orbit-item { width: 36px; height: 36px; margin: -18px; }
      .orbit-item svg { width: 18px; height: 18px; }
      .orbit-hub { width: 92px; height: 92px; }
      .orbit-hub img { width: 88px; height: 88px; }
    }
    @media (max-width: 400px) {
      .orbit { --ro: 100; --ri: 62; width: min(290px, 88vw); }
      .orbit-item { width: 32px; height: 32px; margin: -16px; }
      .orbit-item svg { width: 16px; height: 16px; }
      .orbit-hub { width: 78px; height: 78px; }
      .orbit-hub img { width: 74px; height: 74px; }
    }
    .integ-chips { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin-top: 30px; }
    .integ-chips span { font-size: var(--fs-label); font-weight: 500; color: var(--text-2); background: var(--surface); border: 1px solid var(--border); padding: 6px 12px; }
    .integ-note { display: inline-flex; align-items: center; gap: 9px; margin-top: 22px; font-size: var(--fs-sm); color: var(--text-2); }
    .integ-note svg { width: 18px; height: 18px; color: var(--accent); flex: none; }

    /* ============================================================
       PRICING (live card structure)
       ============================================================ */
    .price-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; align-items: stretch; text-align: left; min-width: 0; }
    @media (max-width: 720px) { .price-grid { grid-template-columns: 1fr; max-width: 440px; margin-inline: auto; } }
    @media (min-width: 721px) and (max-width: 1024px) { .price-grid { gap: 12px; } .pcard2 { padding: 22px 18px; } }
    @media (max-width: 480px) { .pcard2 { padding: 20px 16px; } }
    .pcard2 { background: var(--surface); border: 1px solid var(--border); padding: 28px 26px; display: flex; flex-direction: column; position: relative; transition: transform .25s var(--ease), box-shadow .25s var(--ease); }
    .pcard2:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
    .pcard2.feat { border-color: var(--accent); box-shadow: var(--shadow-lg); }
    .pcard2 .badge { position: absolute; top: 22px; right: 22px; background: var(--accent); color: #fff; font-size: var(--fs-label); font-weight: 600; padding: 4px 11px; }
    .pc-ico { width: 48px; height: 48px; display: grid; place-items: center; margin-bottom: 20px; }
    .pc-ico svg { width: 24px; height: 24px; }
    .pc-ico.i-blog { background: var(--accent-wash); color: var(--accent); }
    .pc-ico.i-local { background: var(--pos-wash); color: var(--pos); }
    .pc-ico.i-bundle { background: var(--accent-100); color: var(--accent-press); }
    .pcard2 h3 { font-size: 1.3rem; }
    .pcard2 .sub { font-size: var(--fs-sm); color: var(--text-3); margin-top: 7px; min-height: 40px; }
    .pcard2 .amt { margin-top: 18px; display: flex; align-items: baseline; gap: 5px; }
    .pcard2 .amt .v { font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; }
    .pcard2 .amt .per { font-size: var(--fs-sm); color: var(--text-3); }
    .pc-more { margin-top: 12px; font-size: var(--fs-sm); color: var(--accent); font-weight: 500; display: inline-flex; align-items: center; gap: 6px; }
    .pc-more svg { width: 15px; height: 15px; }
    .pcard2 hr { border: none; border-top: 1px solid var(--border); margin: 22px 0; }
    .pcard2 ul { list-style: none; padding: 0; margin: 0 0 24px; display: grid; gap: 13px; }
    .pcard2 ul li { display: flex; gap: 11px; font-size: var(--fs-sm); color: var(--text-2); align-items: center; }
    .pcard2 ul .ck { width: 20px; height: 20px; background: var(--accent); display: grid; place-items: center; flex: none; }
    .pcard2 ul .ck svg { width: 12px; height: 12px; color: #fff; }
    .pcard2 .btn { margin-top: auto; }
    .price-note { margin-top: 28px; font-size: var(--fs-sm); color: var(--text-2); }
    .price-note b { color: var(--text); font-weight: 600; }
    .price-note a { color: var(--accent); font-weight: 600; }
    .price-sub { margin-top: 8px; font-size: var(--fs-sm); color: var(--text-3); }

    /* ============================================================
       COMPARISON (optimized)
       ============================================================ */
    .cmp { display: grid; grid-template-columns: 1.2fr 1fr 1fr 1fr; background: var(--surface); border: 1px solid var(--border); overflow: hidden; text-align: left; box-shadow: var(--shadow-sm); }
    .cmp > div { padding: 18px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; }
    .cmp .ch { font-weight: 600; font-size: var(--fs-body); background: var(--surface-2); }
    .cmp .ch.us { background: var(--accent); color: #fff; flex-direction: column; align-items: flex-start; gap: 2px; }
    .cmp .ch.us small { font-weight: 500; font-size: var(--fs-label); color: rgba(255,255,255,.8); }
    .cmp .rl { color: var(--text-3); font-weight: 500; font-size: var(--fs-sm); }
    .cmp .us-col { background: var(--accent-wash); font-weight: 600; color: var(--text); }
    .cmp .big { font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em; }
    .cmp .us-col .big { color: var(--accent); }
    .cmp .muted { color: var(--text-3); }
    .cmp .yes { color: var(--pos); display: inline-flex; align-items: center; gap: 7px; font-weight: 600; }
    .cmp .yes svg, .cmp .no svg { width: 16px; height: 16px; flex: none; }
    .cmp .no { color: var(--text-3); display: inline-flex; align-items: center; gap: 7px; }
    .cmp > div:nth-last-child(-n+4) { border-bottom: none; }
    .cmp-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    @media (max-width: 720px) {
      .cmp { min-width: 580px; }
      .cmp > div { padding: 12px 10px; font-size: 0.9rem; }
      .cmp .big { font-size: 1rem; }
      .cmp > div:nth-child(4n+1) { position: sticky; left: 0; background: var(--surface); z-index: 2; box-shadow: 2px 0 4px rgba(0,0,0,0.05); }
      .cmp .ch { position: sticky; top: 0; z-index: 3; }
      .cmp .ch.us { z-index: 4; }
    }

    /* ============================================================
       TESTIMONIALS / CASE STUDY
       ============================================================ */
    .quotes { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; text-align: left; min-width: 0; }
    @media (max-width: 720px) { .quotes { grid-template-columns: 1fr; } }
    .quote { background: var(--surface); border: 1px solid var(--border); padding: 28px; display: flex; flex-direction: column; }
    .quote.feature { grid-column: span 2; background: var(--accent); color: #fff; }
    @media (max-width: 720px) { .quote.feature { grid-column: span 1; } }
    .quote .stars { color: #f59e0b; letter-spacing: 2px; margin-bottom: 14px; }
    .quote.feature .stars { color: #fde68a; }
    .quote p { font-size: 1.08rem; line-height: 1.5; font-weight: 500; }
    .quote.feature p { font-size: clamp(1.18rem, 1rem + 1vw, 1.5rem); letter-spacing: -0.01em; }
    .quote .who { display: flex; align-items: center; gap: 12px; margin-top: 22px; }
    .quote .who .av { width: 42px; height: 42px; background: var(--accent-100); color: var(--accent); font-weight: 600; display: grid; place-items: center; flex: none; }
    .quote.feature .who .av { background: rgba(255,255,255,.2); color: #fff; }
    .quote .who .nm { font-weight: 600; font-size: var(--fs-sm); }
    .quote .who .ro { font-size: var(--fs-label); color: var(--text-3); }
    .quote.feature .who .ro { color: rgba(255,255,255,.78); }
    .case-stats { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1px; margin-top: 24px; background: rgba(255,255,255,.2); overflow: hidden; min-width: 0; }
    @media (max-width: 520px) { .case-stats { grid-template-columns: repeat(2, 1fr); } }
    .case-stats .cs { background: rgba(255,255,255,.07); padding: 16px 10px; text-align: center; }
    .case-stats .csn { font-size: 1.55rem; font-weight: 700; letter-spacing: -0.02em; color: #fff; line-height: 1; }
    .case-stats .csl { font-size: var(--fs-label); color: rgba(255,255,255,.8); margin-top: 5px; }

    /* ============================================================
       RISK
       ============================================================ */
    .chips { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin-top: 30px; }
    .chip { display: inline-flex; align-items: center; gap: 9px; font-size: var(--fs-sm); font-weight: 500; color: var(--text); background: var(--surface); border: 1px solid var(--border); padding: 11px 17px; }
    .chip svg { width: 17px; height: 17px; color: var(--pos); flex: none; }

    /* ============================================================
       FAQ
       ============================================================ */
    .faq-list { display: grid; gap: 12px; text-align: left; }
    .faq { background: var(--surface); border: 1px solid var(--border); overflow: hidden; }
    .faq summary { list-style: none; cursor: pointer; padding: 20px 22px; display: flex; align-items: center; justify-content: space-between; gap: 18px; font-weight: 600; font-size: 1.05rem; }
    .faq summary::-webkit-details-marker { display: none; }
    .faq .ic { width: 24px; height: 24px; flex: none; position: relative; transition: transform .3s var(--ease); color: var(--accent); }
    .faq[open] .ic { transform: rotate(45deg); }
    .faq .ic::before, .faq .ic::after { content: ""; position: absolute; background: currentColor; }
    .faq .ic::before { left: 4px; right: 4px; top: 11px; height: 2px; }
    .faq .ic::after { top: 4px; bottom: 4px; left: 11px; width: 2px; }
