  <script>
    // Hero: interactive particle canvas + mouse-follow glow
    (function () {
      const canvas = document.getElementById('hero-canvas');
      const section = document.getElementById('hero-section');
      const glow = document.getElementById('hero-mouse-glow');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');

      let W = 0, H = 0;
      const PARTICLE_COUNT = 90;
      const CONNECT_DIST = 130;
      const MOUSE_DIST = 180;
      let particles = [];
      let mouse = { x: -9999, y: -9999 };

      function resize() {
        W = canvas.width = canvas.offsetWidth;
        H = canvas.height = canvas.offsetHeight;
      }

      function mkParticle() {
        return {
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          r: Math.random() * 1.2 + 0.4,
        };
      }

      function init() {
        resize();
        particles = Array.from({ length: PARTICLE_COUNT }, mkParticle);
      }

      function tick() {
        ctx.clearRect(0, 0, W, H);

        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > W) p.vx *= -1;
          if (p.y < 0 || p.y > H) p.vy *= -1;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(79,57,246,0.45)';
          ctx.fill();
        }

        for (let i = 0; i < particles.length; i++) {
          const a = particles[i];
          for (let j = i + 1; j < particles.length; j++) {
            const b = particles[j];
            const d = Math.hypot(a.x - b.x, a.y - b.y);
            if (d < CONNECT_DIST) {
              ctx.beginPath();
              ctx.strokeStyle = `rgba(79,57,246,${0.22 * (1 - d / CONNECT_DIST)})`;
              ctx.lineWidth = 0.6;
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
          const dm = Math.hypot(a.x - mouse.x, a.y - mouse.y);
          if (dm < MOUSE_DIST) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(79,57,246,${0.45 * (1 - dm / MOUSE_DIST)})`;
            ctx.lineWidth = 0.9;
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(mouse.x, mouse.y);
            ctx.stroke();
          }
        }

        requestAnimationFrame(tick);
      }

      section?.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
        if (glow) {
          glow.style.background = `radial-gradient(500px circle at ${mouse.x}px ${mouse.y}px, rgba(79,57,246,0.08) 0%, transparent 70%)`;
        }
      });
      section?.addEventListener('mouseleave', () => {
        mouse.x = -9999;
        mouse.y = -9999;
        if (glow) glow.style.background = '';
      });

      window.addEventListener('resize', init);
      init();
      tick();
    })();

    const nav = document.getElementById('nav');
    // Reveal on scroll
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      document.querySelectorAll('.reveal').forEach(el => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            const sibs = [...e.target.parentElement.querySelectorAll(':scope > .reveal')];
            const idx = Math.max(0, sibs.indexOf(e.target));
            e.target.style.transitionDelay = Math.min(idx * 55, 280) + 'ms';
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    }

    // Count-up numbers
    const fmt = (n, dec) => dec ? n.toFixed(dec) : Math.round(n).toLocaleString('en-US');
    const animateNum = (el) => {
      const target = parseFloat(el.dataset.count);
      const dec = parseInt(el.dataset.dec || '0', 10);
      if (reduce) { el.textContent = fmt(target, dec); return; }
      const dur = 1500, start = performance.now();
      const tick = (now) => {
        const p = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - p, 4);
        el.textContent = fmt(target * eased, dec);
        if (p < 1) requestAnimationFrame(tick); else el.textContent = fmt(target, dec);
      };
      requestAnimationFrame(tick);
    };
    const cio = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { animateNum(e.target); cio.unobserve(e.target); } });
    }, { threshold: 0.5 });
    document.querySelectorAll('[data-count]').forEach(c => cio.observe(c));

    // Sticky mobile CTA after hero
    const sticky = document.getElementById('stickyCta');
    const hero = document.querySelector('.hero');
    if (hero) {
      new IntersectionObserver((entries) => {
        entries.forEach(e => sticky.classList.toggle('show', !e.isIntersecting && e.boundingClientRect.top < 0));
      }, { threshold: 0 }).observe(hero);
    }
  </script>

  <script>
    // Demo form submission → /lp/thankyou/
    (function () {
      const form = document.getElementById('demo-form');
      const submitBtn = document.getElementById('demo-submit');
      if (!form || !submitBtn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const originalHTML = submitBtn.innerHTML;
        submitBtn.textContent = 'Sending...';
        submitBtn.disabled = true;

        try {
          const fd = new FormData(form);
          const data = {
            first_name: (fd.get('first_name') || '').toString().trim(),
            last_name: (fd.get('last_name') || '').toString().trim(),
            email: (fd.get('email') || '').toString().trim(),
            phone: (fd.get('phone') || '').toString().trim(),
            business: (fd.get('business') || '').toString().trim(),
            business_type: (fd.get('business_type') || '').toString().trim(),
            page_url: window.location.href,
          };

          const res = await fetch('/api/demo/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          if (res.ok) {
            const params = new URLSearchParams({
              name: `${data.first_name} ${data.last_name}`.trim(),
              email: data.email,
            });
            if (data.phone) params.set('smsReminderNumber', data.phone);
            window.location.href = `/lp/thankyou/?${params.toString()}`;
          } else {
            const result = await res.json().catch(() => ({}));
            throw new Error(result.error || 'Network error');
          }
        } catch (err) {
          submitBtn.innerHTML = originalHTML;
          submitBtn.disabled = false;
          const msg = err instanceof Error ? err.message : 'Something went wrong.';
          alert(`${msg} Email us directly at sidgangal@gmail.com`);
        }
      });
    })();
  </script>
