---
import BaseLayout from '../layouts/BaseLayout.astro';

const customers = [
  { name: "ReplyDaddy",            logo: "/customer-logos/replydaddy.webp",            showName: true  },
  { name: "NoobBookLM",            logo: "/customer-logos/noobbooklm.webp",            showName: true  },
  { name: "ChartMath",             logo: "/customer-logos/chartmath.webp",             showName: true  },
  { name: "Heaven Designs",        logo: "/customer-logos/heaven-designs.webp",        showName: false },
  { name: "Solar EPC Company",     logo: "/customer-logos/heaven-green-energy.webp",   showName: false },
  { name: "Qbits Energy",          logo: "/customer-logos/qbits.webp",                showName: false },
  { name: "QuickEstimate",         logo: "/customer-logos/quickestimate.webp",        showName: false },
  { name: "Suncart",               logo: "/customer-logos/suncart.svg",               showName: false },
  { name: "Intello",               logo: "/customer-logos/intello.webp",              showName: false },
  { name: "Suryantra Energy",      logo: "/customer-logos/suryantra-energy.webp",      showName: true  },
];
---

<BaseLayout
  title="AI SEO Tool That Replaces Your Content Team | theStacc"
  description="theStacc replaces agencies, freelancers, and in-house content teams with one AI SEO tool. Research, write, optimize, and publish content automatically. Book a demo."
  ogImage="/dashboard-preview.webp"
  noBorders={true}
>
  <a class="skip" href="#main">Skip to content</a>

  <!-- ===================== NAV ===================== -->
  <header class="nav" id="nav">
    <div class="nav-inner">
      <a href="#" class="brand" aria-label="theStacc home"><img src="/lp-assets/theStacc.svg" alt="theStacc"></a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#how">How it works</a>
        <a href="#modules">Modules</a>
        <a href="#pricing">Pricing</a>
        <a href="#reviews">Reviews</a>
      </nav>
      <div class="nav-cta">
        <a href="#book-demo" class="btn btn-primary">Book a Demo</a>
      </div>
    </div>
  </header>

  <div class="frame">
    <main id="main">

      <!-- ===================== HERO (homepage-style, LP copy) ===================== -->
      <section id="hero-section" class="hero-lp relative overflow-hidden" style="background:#ffffff;">
        <!-- Interactive particle canvas -->
        <canvas id="hero-canvas" class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

        <!-- Static grid overlay -->
        <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);" aria-hidden="true"></div>

        <!-- Purple radial glow top-center -->
        <div class="pointer-events-none absolute inset-x-0 top-0 h-[700px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);" aria-hidden="true"></div>

        <!-- Mouse-follow interactive glow -->
        <div id="hero-mouse-glow" class="pointer-events-none absolute inset-0" aria-hidden="true"></div>

        <div class="container-x relative pt-14 pb-12 sm:pt-20 sm:pb-16 md:pt-24 md:pb-20 lg:pt-28 lg:pb-24">

          <!-- Hero content: chip → H1 → subhead → CTA → trust.
               Spacing is controlled by `.hero-stack > .hero-*` rules in the
               global style block (specificity-proof against the file's own
               `p`/`h1..h4` margin resets). -->
          <div class="hero-stack mx-auto flex max-w-[860px] flex-col items-center text-center">

            <!-- Chip badge: 4.9 rating from 127 businesses -->
            <span class="hero-eyebrow inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white/90 px-3 py-1.5 font-mono text-[11px] font-medium text-[#79716b] shadow-sm backdrop-blur-sm sm:text-[12px]">
              <span class="text-[#f59e0b] leading-none tracking-[1px]" aria-hidden="true">★</span>
              <span>4.9 rating from 127 businesses</span>
            </span>

            <!-- H1 -->
            <h1 class="hero-title max-w-[18ch] text-balance font-sans text-[1.875rem] font-semibold leading-[1.08] tracking-[-0.04em] text-[#292524] sm:max-w-[22ch] sm:text-[2.25rem] md:max-w-[26ch] md:text-[2.75rem] lg:text-[3.25rem]">
              AI SEO Tool That Replaces Your Content Team
            </h1>

            <!-- Subhead -->
            <p class="hero-sub mx-auto max-w-[560px] text-center font-sans text-[15px] leading-[1.6] text-[#57534e] sm:max-w-[580px] sm:text-[16px] md:text-[16px] md:leading-[1.65]">
              theStacc is an AI SEO tool, blog writer, SEO content editor, and content optimization system in one. It replaces agencies, freelancers, and in-house writers, so you publish <b class="font-semibold text-[#292524]">30+ SEO-optimized articles every month</b> without managing anyone.
            </p>

            <!-- CTA -->
            <a href="#book-demo" class="hero-cta inline-flex items-center justify-center gap-2.5 rounded-xl bg-[#4f39f6] px-7 py-3.5 font-sans text-[15px] font-semibold !text-white shadow-md transition-all hover:bg-[#615fff] hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 sm:px-8 sm:py-4">
              Book a Demo
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>

            <!-- Trust micro-line -->
            <p class="hero-fine text-center font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
              Book a 30-min demo · See it run on your site · Your content stays yours
            </p>

          </div>

          <!-- Safari mockup with autoplay video -->
          <div class="hero-mockup mx-auto w-full max-w-[960px]">
            <div class="safari reveal">
              <div class="safari-bar">
                <span class="safari-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                <span class="safari-url"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="9" rx="2"></rect><path d="M8 11V8a4 4 0 018 0v3" stroke-linecap="round"></path></svg> thestacc.com</span>
                <span class="safari-actions" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16M14 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"></path></svg>
                </span>
              </div>
              <div class="safari-body">
                <video autoplay muted loop playsinline preload="auto" poster="/lp-assets/hero-poster.jpg" aria-label="theStacc product demo">
                  <source src="/lp-assets/hero-demo.mp4" type="video/mp4">
                </video>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ===================== LOGO BAR ===================== -->
      <section class="logobar reveal">
        <p>Trusted by 127+ businesses across 70+ industries</p>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8" key={i}>
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ===================== PROOF (dark, compact) ===================== -->
      <section class="proof">
        <div class="section-head reveal" style="margin-bottom:clamp(26px,3.2vw,36px)">
          <span class="kicker">By the numbers</span>
          <p class="proof-tag">Built to rank on Google <span class="accent">and</span> get cited by ChatGPT, Gemini, Claude &amp; AI Overviews.</p>
        </div>
        <div class="stats s2 inner reveal">
          <div class="stat"><div class="num tabnum"><span data-count="127">127</span><span class="u">+</span></div><div class="lbl">Businesses served</div></div>
          <div class="stat"><div class="num tabnum">$<span data-count="3500">3,500</span><span class="u">/mo</span></div><div class="lbl">Agency cost replaced</div></div>
        </div>
      </section>

      <!-- ===================== PROBLEM ===================== -->
      <section id="problem">
        <div class="section-head reveal">
          <span class="kicker">The problem</span>
          <h2>Your content team is slowing you down.</h2>
          <p class="lead">You're not losing rankings because your product is worse. You're losing because your content operation is slower.</p>
        </div>
        <div class="prob-grid inner">
          <div class="pcard reveal">
            <div class="picon"><svg class="pi-cost" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2.5" y="6" width="19" height="12" rx="2"></rect><circle cx="12" cy="12" r="2.6"></circle><path d="M6 12h.01M18 12h.01" stroke-linecap="round"></path></svg></div>
            <h4>Agencies are expensive</h4>
            <p class="pdesc">$3,500 a month for a handful of posts and a spreadsheet.</p>
          </div>
          <div class="pcard reveal">
            <div class="picon"><svg class="pi-flaky" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3.5 2" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
            <h4>Freelancers are unreliable</h4>
            <p class="pdesc">4 articles one month, zero the next. SEO needs consistency.</p>
          </div>
          <div class="pcard reveal">
            <div class="picon"><svg class="pi-silo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="8" height="8" rx="1.6"></rect><rect x="13" y="13" width="8" height="8" rx="1.6"></rect><path d="M13.5 6.5h3M6.5 13.5v3" stroke-linecap="round"></path></svg></div>
            <h4>Tools don't talk to each other</h4>
            <p class="pdesc">Research in one app, writing in another, publishing somewhere else.</p>
          </div>
          <div class="pcard reveal">
            <div class="picon"><svg class="pi-time" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M7 4h10M7 20h10M8 4c0 4 4 5 4 8s-4 4-4 8M16 4c0 4-4 5-4 8s4 4 4 8" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
            <h4>Your team has better things to do</h4>
            <p class="pdesc">Chasing content is not the highest-value use of your time.</p>
          </div>
        </div>
        <p class="prob-foot reveal">Meanwhile, your competitor publishes 30+ articles this month. <span class="accent">They show up for the searches you should own.</span></p>
      </section>

      <!-- ===================== HOW IT WORKS (bento) ===================== -->
      <section id="how" class="band-alt">
        <div class="section-head reveal">
          <span class="kicker">How it works</span>
          <h2>Set up in 5 minutes. Run on autopilot forever.</h2>
          <p class="lead"><span class="muted">ChatGPT writes content.</span> <span class="accent">theStacc ranks it.</span></p>
        </div>
        <div class="bento-how inner">
          <div class="htile reveal">
            <span class="n">01</span>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zM2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20" stroke-linecap="round"></path></svg></span>
            <h3>Connect</h3>
            <p>Enter your URL and business details. theStacc analyzes your site and competitors.</p>
          </div>
          <div class="htile feature reveal">
            <span class="n">02</span>
            <span class="ico"><svg class="spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 3v2m0 14v2M5 5l1.5 1.5M17.5 17.5L19 19M3 12h2m14 0h2M5 19l1.5-1.5M17.5 6.5L19 5" stroke-linecap="round"></path><circle cx="12" cy="12" r="3.5"></circle></svg></span>
            <h3>It does the work</h3>
            <p>Keyword research, an AI blog writer in your brand voice, a built-in SEO content editor and checker, a content optimization tool, and auto-publishing. Review the plan and SEO score, then approve what you want or approve it all.</p>
            <div class="runlist">
              <span class="live"><i></i> Running</span>
              <span>Keyword research</span><span>AI writer</span><span>SEO score</span><span>Optimize</span><span>Auto-publish</span><span>Brand voice</span>
            </div>
          </div>
          <div class="htile reveal">
            <span class="n">03</span>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 18l5-5 4 3 6-8" stroke-linecap="round" stroke-linejoin="round"></path><path d="M19 8v4m0-4h-4" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
            <h3>Publish</h3>
            <p>Articles go live on schedule. You get the traffic. Your team gets their time back.</p>
          </div>
        </div>

        <!-- AI Search / Answer Engine Optimization band -->
        <div class="aeo-band inner reveal">
          <div class="aeo-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" stroke-linecap="round"></path></svg>
          </div>
          <div class="aeo-body">
            <span class="aeo-tag">New · Answer Engine Optimization</span>
            <h3>Built to be cited by ChatGPT, Gemini, Claude &amp; AI Overviews.</h3>
            <p>Every article is structured for LLM retrieval — clear answers, scannable headings, schema markup, and entity-rich context. So when buyers ask an AI engine about your category, your brand is the answer it quotes.</p>
            <div class="aeo-chips">
              <span>ChatGPT</span>
              <span>Gemini</span>
              <span>Claude</span>
              <span>Perplexity</span>
              <span>Google AI Overviews</span>
            </div>
          </div>
        </div>

        <div class="reveal" style="margin-top:clamp(36px,4vw,48px)">
          <a href="#book-demo" class="btn btn-primary btn-lg">Book a Demo</a>
          <p class="cta-microcopy">See it research, write, score, and publish in real time.</p>
        </div>
      </section>

      <!-- ===================== MODULES (bento) ===================== -->
      <section id="modules">
        <div class="section-head reveal">
          <span class="kicker">The modules</span>
          <h2>One system. Three modules. Zero headcount.</h2>
          <p class="lead">Start with Blog SEO. Add Local and Social when you're ready. Everything runs from one dashboard.</p>
        </div>
        <div class="bento-mod inner">
          <!-- Blog (large) -->
          <div class="mtile blog reveal">
            <div class="m-top">
              <span class="m-ico i-blog"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 20h16M6 16l9-9 3 3-9 9H6v-3z" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
              <span class="m-tag">Flagship</span>
            </div>
            <h3>Blog SEO</h3>
            <p class="m-desc">The complete AI SEO tool for blog writing and content optimization. Research, write, check, and publish 30+ SEO articles every month.</p>
            <ul class="mlist">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>AI blog writer in your brand voice</span></li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Keyword research and mapping</span></li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Built-in SEO content checker</span></li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Content optimization tool</span></li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Auto-publish to WordPress, Webflow, Ghost</span></li>
            </ul>
            <div class="m-visual">
              <div class="mini-feed">
                <div class="mini-row"><span class="cms" style="background:#21759b">WP</span><span class="t">Cost of a dental implant in 2026</span><span class="st">Live</span></div>
                <div class="mini-row"><span class="cms" style="background:#146ef5">WF</span><span class="t">Do you need a night guard?</span><span class="st">Live</span></div>
                <div class="mini-row"><span class="cms" style="background:#95bf47">SH</span><span class="t">Teeth whitening, what actually works</span><span class="st">Live</span></div>
              </div>
            </div>
          </div>

          <div class="mside">
            <!-- Local -->
            <div class="mtile reveal">
              <div class="m-top">
                <span class="m-ico i-local"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s7-5.5 7-11a7 7 0 10-14 0c0 5.5 7 11 7 11z" stroke-linejoin="round"></path><circle cx="12" cy="10" r="2.5"></circle></svg></span>
                <span class="m-tag">Add-on</span>
              </div>
              <h3>Local SEO</h3>
              <p class="m-desc">Dominate Google Maps and the local pack with daily, on-brand signals.</p>
              <ul class="mlist mlist-compact">
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Daily Google Business Profile posts</span></li>
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>AI-written review responses</span></li>
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Local keyword + map-pack tracking</span></li>
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Multi-location ready</span></li>
              </ul>
            </div>
            <!-- Social -->
            <div class="mtile reveal">
              <div class="m-top">
                <span class="m-ico i-social"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4" stroke-linecap="round"></path></svg></span>
                <span class="m-tag">Add-on</span>
              </div>
              <h3>Social Media</h3>
              <p class="m-desc">Turn every article into posts and carousels — auto-created, scheduled, and published across your channels.</p>
              <ul class="mlist mlist-compact">
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Auto-post to Instagram, LinkedIn, X, Facebook</span></li>
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Brand-voice captions + hashtags</span></li>
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Visual templates from your blog</span></li>
                <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"></path></svg><span>Smart scheduling per channel</span></li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- ===================== INTEGRATIONS (orbit, real logos) ===================== -->
      <section id="integrations" class="band-alt">
        <div class="section-head reveal">
          <span class="kicker">Integrations</span>
          <h2>Connect your stack once. It publishes everywhere.</h2>
          <p class="lead">theStacc plugs into the tools you already use. Link your CMS, your Google Business Profile, and your social accounts one time. After that, everything ships on its own.</p>
        </div>
        <div class="orbit reveal hidden md:block" role="img" aria-label="theStacc connected to WordPress, Webflow, Shopify, Ghost, Google, Instagram, LinkedIn, Facebook, and X.">
          <span class="orbit-path p1" aria-hidden="true"></span>
          <span class="orbit-path p2" aria-hidden="true"></span>
          <span class="orbit-hub"><img src="/lp-assets/thestacc-logo.png" alt="theStacc"></span>
