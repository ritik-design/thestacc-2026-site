---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "What are citations and why do they matter for local SEO?",
    a: "Citations are any online mention of your business name, address, and phone number (NAP). Google uses citations as a trust signal — consistent NAP data across authoritative directories confirms you are a real, stable local business. Inconsistent citations (wrong address, different phone numbers, old business names) dilute that trust and directly hurt your local pack rankings.",
  },
  {
    q: "Why does NAP consistency matter so much?",
    a: "If your address appears as '123 Main St' on Google, '123 Main Street Suite 1' on Yelp, and 'Main St 123' on Apple Maps, Google sees three potentially different businesses. This fragmentation weakens your local authority. Stacc audits every citation against your master NAP data and flags or fixes discrepancies automatically across all 50+ directories.",
  },
  {
    q: "Which directories does Stacc sync citations to?",
    a: "Stacc syncs to 50+ directories including Google Business Profile, Apple Maps, Bing Places, Yelp, Facebook, Foursquare, TripAdvisor, Yellow Pages, Angi, HomeAdvisor, BBB, and dozens of industry-specific and regional directories. The full directory list is available in your dashboard.",
  },
  {
    q: "How long does it take to see results from citation fixes?",
    a: "Most directories accept updates within 1–5 business days. Google typically reflects citation changes within 2–4 weeks. Ranking improvements from corrected citations usually appear in your local pack position within 4–8 weeks, since Google needs time to recrawl, reconcile, and re-evaluate your NAP consistency score.",
  },
  {
    q: "Does Stacc handle duplicate listing removal?",
    a: "Yes. The citation audit automatically detects duplicate listings — same business, same location appearing multiple times in the same directory. Duplicates confuse Google and split your citation authority. Stacc flags them for removal and, where the directory API allows, handles suppression automatically.",
  },
  {
    q: "Can I manage citations for multiple locations?",
    a: "Yes, and this is where Stacc saves the most time. Each location gets its own NAP data set. When you update business hours, move a location, or change a phone number, you update it in Stacc once — and it propagates to all 50+ directories for that location automatically. No directory-by-directory manual updates.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Citation Management Software",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Inconsistent citations hurt your local rankings. theStacc audits, fixes, and builds citations across 50+ directories automatically — so your NAP data is always accurate everywhere.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://thestacc.com/features/" },
        { "@type": "ListItem", "position": 3, "name": "Citation Management", "item": "https://thestacc.com/features/citation-management/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Citation Management Software — Fix, Build & Sync Citations Across 50+ Directories | theStacc"
  description="Inconsistent citations hurt your local rankings. theStacc audits, fixes, and builds citations across 50+ directories automatically — so your NAP data is always accurate everywhere."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Citation Management · Local SEO Module</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Your business is listed differently<br />on every directory.
            <span style="color:#4f39f6;"> Google notices.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc audits your NAP data across 50+ directories, fixes inconsistencies, removes duplicates, and builds new citations automatically. One update in Stacc. Every directory stays in sync.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Fix your citations
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $1 for 3 days · No credit card · Audit runs in minutes
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '50+', num: 50, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Directories synced' },
              { value: '94%', num: 94, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'NAP accuracy rate' },
              { value: '3hrs', num: 3, prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Saved per week per location' },
              { value: '4.9', num: 4.9, prefix: '', suffix: '★', decimals: 1, from: 0, label: 'Average review rating' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up={s.num > 0 ? true : undefined} data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Inconsistent NAP data is silently<br />killing your local rankings.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            A business moves once and suddenly has two addresses in the world. A phone number changes and 12 directories still show the old one. The business name gets abbreviated differently on every platform. To a human this looks trivial. To Google's local ranking algorithm, it's a trust signal problem — one that pushes your listing down the local pack while your competitors with clean, consistent citations move up.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Every wrong listing is a trust signal against you.',
              body: 'Google cross-references your NAP data across the web. Every directory that shows a different address, different phone, or different business name introduces doubt. Enough doubt and your local pack ranking drops — even if your GBP is perfect.',
            },
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Manual updates take hours you don\'t have.',
              body: 'Logging into 50 directories one by one to update business hours or a new address is a full day of work. Most agencies skip it. The result: stale data compounds over months until citation inconsistency is embedded deep enough to need serious cleanup work.',
            },
            {
              icon: 'M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z',
              title: 'Duplicate listings split your citation authority.',
              body: 'When the same business appears twice in the same directory — common after moves, ownership changes, or platform mergers — citation signals get split between two listings. You\'re effectively competing against yourself. Duplicate suppression is non-negotiable.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Audit, fix, and sync — once.<br />Stays accurate automatically.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Enter your master NAP data once. Stacc audits every directory, surfaces errors, fixes them, and monitors for future drift — without you touching another directory login.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Enter your master NAP data', body: 'Input your canonical business name, address, phone, and hours. Stacc uses this as the source of truth to audit against. For multi-location businesses, enter one record per location.' },
            { n: '02', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', title: 'Stacc audits all 50+ directories', body: 'The audit runs automatically across 50+ directories and surfaces every discrepancy: wrong address, wrong phone, missing listings, duplicate entries. You see a consistency score and a prioritized list of what to fix.' },
            { n: '03', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Fixes push automatically, monitoring continues', body: 'Stacc pushes corrections to every directory that supports automated updates. For the rest, you get pre-filled submission forms. After cleanup, monitoring runs monthly so drift never accumulates again.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Everything included</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Complete citation management.<br />Zero directory logins required.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: '50+ Directory Sync', body: 'Citations pushed to Google, Apple Maps, Yelp, Bing, Facebook, Foursquare, YP, BBB, and 40+ more — from one dashboard.', icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9' },
            { title: 'NAP Consistency Audit', body: 'Full audit of every directory against your master NAP. Consistency score, error count, and prioritized fix list.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
            { title: 'Duplicate Detection', body: 'Finds and flags duplicate listings across directories. Suppresses duplicates automatically where APIs allow.', icon: 'M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z' },
            { title: 'Citation Building Automation', body: 'Missing from a directory? Stacc builds the citation for you — correct NAP, correct category, correct hours.', icon: 'M12 4v16m8-8H4' },
            { title: 'Real-Time Monitoring', body: 'Monthly citation health checks. If any directory changes your data (it happens), you\'re alerted and corrections push automatically.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Multi-Location Management', body: 'Manage citation data for every location independently. One change in Stacc, synced to every directory for that location.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DEEP DIVE 1 ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl space-y-16">
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">NAP Consistency Audit</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                See exactly where your citations are wrong and why it's hurting rankings.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Most businesses have no idea their citation data is inconsistent until they wonder why the local pack rankings aren't moving. Stacc's audit surfaces every discrepancy — wrong address format, outdated phone number, missing listings, duplicate entries — and gives you a consistency score so you know how serious the problem is before you fix it.
              </p>
              <ul class="mt-6 space-y-3">
                {['Consistency score across all 50+ directories at a glance', 'Error-by-directory breakdown with exact discrepancy detail', 'Priority ranking: which errors hurt rankings most to fix first', 'Before/after comparison to track citation health over time'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Citation Audit — Austin Plumbing Co</p>
                <span class="rounded-full bg-[#fff1f2] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#ef4444]">14 errors found</span>
              </div>
              {[
                { dir: 'Yelp', issue: 'Wrong phone number', severity: 'High', status: 'Fixing' },
                { dir: 'Apple Maps', issue: 'Old address on file', severity: 'High', status: 'Fixing' },
                { dir: 'Yellow Pages', issue: 'Duplicate listing', severity: 'Medium', status: 'Suppressing' },
                { dir: 'Foursquare', issue: 'Missing listing', severity: 'Medium', status: 'Building' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-[#111827]">{row.dir}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{row.issue}</p>
                  </div>
                  <span class="rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">{row.status}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── DEEP DIVE 2 ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl">
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Citation Sync Status — All Locations</p>
              <div class="space-y-3">
                {[
                  { loc: 'Austin — Main St', score: 98, dirs: '50/50', status: 'Synced' },
                  { loc: 'Austin — Riverside', score: 94, dirs: '47/50', status: 'Synced' },
                  { loc: 'Round Rock', score: 71, dirs: '36/50', status: 'In Progress' },
                  { loc: 'Cedar Park', score: 55, dirs: '28/50', status: 'Needs Attention' },
                ].map(row => (
                  <div class="rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="flex items-center justify-between mb-2">
                      <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.loc}</span>
                      <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">{row.score}% consistent</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="h-1.5 flex-1 rounded-full bg-[#e7e5e4]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${row.score}%`}></div></div>
                      <span class="font-mono text-[10px] text-[#79716b]">{row.dirs} dirs</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Multi-Location Citation Management</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                One update. Every directory. Every location. Done.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                The agencies managing 10, 20, or 50 locations aren't updating each directory one by one. They have Stacc doing it. Change hours for a location in Stacc and it propagates to all 50+ directories for that location automatically. Move a location and one address update syncs everywhere. No spreadsheet. No forgotten directories. No stale data compounding into a ranking problem three months from now.
              </p>
              <ul class="mt-6 space-y-3">
                {['Location-level citation dashboards — see each location\'s health', 'Bulk NAP updates: change hours or address for all locations at once', 'Per-location consistency score updated monthly', 'Citation history log: see every change made and when'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
