---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "How often are rankings updated?",
    a: "Daily by default. Every tracked keyword across every connected location gets a fresh ranking check each morning so your dashboard always reflects what's happening right now — not last week. You can trigger manual updates at any time.",
  },
  {
    q: "Does rank tracking work for multi-location businesses?",
    a: "Yes. Multi-location tracking is a core function, not an add-on. You can track each location's keyword rankings independently, compare them side by side, and see aggregate performance across all locations in one view. Add as many locations as you operate.",
  },
  {
    q: "Does it track local pack and Google Maps rankings, not just organic?",
    a: "Yes. Stacc tracks organic rankings, local 3-pack positions, and Google Maps placement separately. This is critical for local businesses — most of the clicks happen in the local pack, not the organic results below it. You'll see exactly where you stand in both.",
  },
  {
    q: "How is this different from checking rankings in Google Search Console?",
    a: "Google Search Console shows you impressions and clicks aggregated by query. It doesn't show you exact position by keyword and location, it doesn't track competitors, and it doesn't send you alerts when rankings change. Stacc gives you position-level data for every keyword at every location, updated daily, with movement alerts and automated reporting.",
  },
  {
    q: "Can I send white-label rank reports to clients?",
    a: "Yes. All ranking reports can be white-labeled with your agency's logo, brand colors, and custom domain. Clients receive the report under your brand. There's no Stacc branding visible to them.",
  },
  {
    q: "What happens to my data if I cancel?",
    a: "Your complete ranking history exports as CSV before cancellation. Every data point you tracked belongs to you. We don't hold it hostage behind a reactivation wall.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Rank Tracking",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automated daily rank tracking for every keyword, every location. Local pack, organic, and Google Maps rankings in one dashboard.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://thestacc.com/features/" },
        { "@type": "ListItem", "position": 3, "name": "Rank Tracking", "item": "https://thestacc.com/features/rank-tracking/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Rank Tracking Software — Daily Rankings for Every Location | theStacc"
  description="Stop checking rankings manually. theStacc tracks every keyword, every location, every day — local pack, organic, and Google Maps. Automated reports. No spreadsheets."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Rank Tracking · Local SEO Module</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Rankings updated daily.<br />
            <span style="color:#4f39f6;">Every keyword. Every location. Automatically.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc tracks every keyword, every location, every day — organic, local pack, and Google Maps. Rankings update automatically. Reports deliver themselves. You always know exactly where you stand.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start tracking for $1
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No credit card to start · Daily updates · Setup in under 10 minutes
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '1,200+', num: 1200, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'SEO teams using Stacc' },
              { value: 'Daily',  num: 0,    prefix: '', suffix: '',  decimals: 0, from: 0, label: 'Ranking updates' },
              { value: '100%',   num: 100,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Automated — no manual checking' },
              { value: '4.9',    num: 4.9,  prefix: '', suffix: '★', decimals: 1, from: 0, label: 'Average review rating' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up={s.num > 0 ? true : undefined} data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Manual rank checking is a liability<br />dressed up as a workflow.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            You know the routine. A client emails Friday afternoon asking for a ranking update. Suddenly it's a 90-minute fire drill — incognito tabs, copy-pasting numbers, formatting a spreadsheet that looks like it took two minutes but cost you your afternoon. The version where you caught it. The version you don't want to think about is when rankings dropped three weeks ago and nobody noticed.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'You find out about drops when clients tell you.',
              body: 'Rankings can fall 15 positions overnight. Without daily tracking and automatic alerts, you\'re the last to know. Your client\'s traffic drops. Their calls drop. And they\'re wondering why they\'re paying you.',
            },
            {
              icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'Reports take hours you should be billing.',
              body: 'Every hour spent manually building a ranking report is an hour not spent on actual SEO. Across 20 clients, that\'s 40+ hours a month of work that should be automated. It\'s the tax that caps how many clients you can serve.',
            },
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: '"Near me" rankings vary by neighborhood.',
              body: 'Your Maps ranking for "plumber near me" two miles north of your office is completely different from the one two miles south. Without grid-based tracking, you\'re missing most of what\'s actually happening in your service area.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Set it up once. Rankings update<br />themselves every morning.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            No daily logins. No manual checks. No scrambling when a client calls. Connect your locations, add your keywords, and Stacc handles the tracking from that day forward.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Add your locations and keywords', body: 'Connect your locations and paste your keyword list — or let Stacc suggest high-value local keywords based on your business type and city. Takes 10 minutes. You never have to do it again.' },
            { n: '02', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Rankings update every morning', body: 'Organic position, local 3-pack, and Google Maps ranking captured daily for every keyword at every location. Alerts trigger automatically when anything moves significantly — you\'ll know about drops before clients do.' },
            { n: '03', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Reports deliver to clients automatically', body: 'Set your report schedule once. Every client gets a branded ranking report — your logo, your domain — on time every week or month. No manual formatting. No copy-paste from spreadsheets. Reports go out while you sleep.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE DEEP DIVES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What's tracked</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every ranking signal that matters.<br />Nothing you have to babysit.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Feature 1 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Local Pack + Maps Tracking</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Where 80% of local clicks actually happen. Tracked separately.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Most rank trackers only show organic position 1–10. But for local businesses, the local 3-pack and Google Maps listing is where almost all the high-intent clicks land. Stacc tracks both — separately — so you can see your full local search footprint and know exactly what's driving calls.
              </p>
              <ul class="mt-6 space-y-3">
                {['Local 3-pack position tracked per keyword per location', 'Google Maps ranking across your full service area grid', 'Organic ranking tracked in parallel for complete picture', 'Competitive position — see where you rank vs top 3 competitors'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Local Pack Rankings</p>
                <span class="rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">↑ +4 positions this week</span>
              </div>
              {[
                { kw: 'plumber near me', pack: '#1', organic: '#3', change: '+2' },
                { kw: 'emergency plumber [city]', pack: '#2', organic: '#5', change: '+3' },
                { kw: 'drain cleaning near me', pack: '#1', organic: '#2', change: '+1' },
                { kw: 'water heater repair [city]', pack: '#3', organic: '#7', change: '+4' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{row.kw}</span>
                  <div class="flex items-center gap-4">
                    <div class="text-center">
                      <p class="font-mono text-[10px] text-[#79716b]">Pack</p>
                      <p class="font-sans text-[13px] font-semibold text-[#4f39f6]">{row.pack}</p>
                    </div>
                    <div class="text-center">
                      <p class="font-mono text-[10px] text-[#79716b]">Organic</p>
                      <p class="font-sans text-[13px] font-semibold text-[#292524]">{row.organic}</p>
                    </div>
                    <span class="font-mono text-[11px] font-semibold text-[#059669]">{row.change}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Feature 2 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Automated Report — Weekly</p>
              <div class="space-y-4">
                <div class="rounded-xl bg-[#f5f3ff] p-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="font-sans text-[13px] font-semibold text-[#111827]">Keywords improved</span>
                    <span class="font-sans text-[13px] font-semibold text-[#059669]">18 ↑</span>
                  </div>
                  <div class="h-1.5 w-full rounded-full bg-[#e7e5e4]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:72%"></div></div>
                </div>
                <div class="rounded-xl bg-[#fafaf9] p-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="font-sans text-[13px] font-semibold text-[#111827]">Avg position change</span>
                    <span class="font-sans text-[13px] font-semibold text-[#059669]">+3.4</span>
                  </div>
                  <div class="h-1.5 w-full rounded-full bg-[#e7e5e4]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:55%"></div></div>
                </div>
                <div class="rounded-xl bg-[#fafaf9] p-4">
                  <div class="flex items-center justify-between">
                    <span class="font-sans text-[13px] font-semibold text-[#111827]">Top 3 local pack positions</span>
                    <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">9 keywords</span>
                  </div>
                </div>
                <div class="flex items-center justify-between pt-1">
                  <span class="font-mono text-[10px] text-[#79716b]">Delivered to client inbox · Every Monday · Your brand</span>
                  <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">Automated ✓</span>
                </div>
              </div>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated White-Label Reports</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Reports that write and send themselves. Under your brand.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                The moment you stop building reports by hand is the moment you start scaling. Stacc generates branded ranking reports on your schedule — your logo, your domain, your format — and delivers them to client inboxes without you touching a thing. Your clients think you have a custom platform. You just have Stacc.
              </p>
              <ul class="mt-6 space-y-3">
                {['White-label with your agency logo and brand colors', 'Scheduled delivery — weekly or monthly, client by client', 'Rankings, movements, wins, and drops — formatted automatically', 'Client receives from your domain, not a Stacc-branded email'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FULL CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Everything included</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every rank tracking capability you need.<br />Nothing you'll never use.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Daily Rank Updates', body: 'Rankings refresh every morning across all tracked keywords and locations. Always current. Never stale.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
            { title: 'Local Pack Tracking', body: 'Your position in the Google local 3-pack for every keyword. Tracked separately from organic so you see the full picture.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Google Maps Grid Tracking', body: 'See your Maps ranking across a geographic grid of your service area — not just one point. Know where you\'re winning and where you\'re losing.', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7' },
            { title: 'Rank Drop Alerts', body: 'Automated alerts when any tracked keyword drops significantly. You know before your client does, every time.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
