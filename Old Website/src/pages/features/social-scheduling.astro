---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "Which platforms can I schedule posts to?",
    a: "Stacc supports publishing to Google Business Profile, Facebook Business Pages, and Instagram Business accounts. Posts can be published to one platform or all three simultaneously from a single workflow.",
  },
  {
    q: "Can I publish the same post to multiple locations at once?",
    a: "Yes. Bulk publishing is a core feature. Write one post and select multiple locations — Stacc publishes to all selected location profiles simultaneously. For 20 locations, that's one action instead of 20.",
  },
  {
    q: "Can I add location-specific details to bulk posts?",
    a: "Yes. Before bulk-publishing, you can add location-specific overrides — different addresses, different phone numbers in the post body, location-specific hashtags. The core post content stays consistent; the local details get customized per account.",
  },
  {
    q: "Does posting to GBP actually improve my Google Maps ranking?",
    a: "Yes. Google Business Profile activity — including regular posts — is a documented local ranking signal. Businesses that post consistently to GBP see improved local pack visibility compared to inactive profiles. Stacc's GBP posting automation is specifically designed to keep your profile active at a frequency that influences rankings.",
  },
  {
    q: "Can I schedule posts weeks or months in advance?",
    a: "Yes. The content calendar lets you plan and schedule posts as far in advance as you need. You can also set a recurring posting schedule and Stacc will publish on your chosen cadence automatically — daily, weekly, or on a custom schedule.",
  },
  {
    q: "What happens to a scheduled post if an account gets disconnected?",
    a: "Stacc flags the disconnected account immediately and queues the post rather than failing silently. You receive an alert to reconnect the account, and the queued post can be published once the connection is restored.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Social Scheduling",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Schedule social posts to Google Business Profile, Facebook, and Instagram across every location simultaneously. One post, everywhere published, automatically.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://thestacc.com/features/" },
        { "@type": "ListItem", "position": 3, "name": "Social Scheduling", "item": "https://thestacc.com/features/social-scheduling/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Social Media Scheduling for Local Businesses — Post to Every Location Automatically | theStacc"
  description="Schedule social posts across every business location in minutes. theStacc publishes to Google Business Profile, Facebook, and Instagram simultaneously — with location-specific customization."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Social Scheduling · Local SEO Module</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Post to every location<br />
            <span style="color:#4f39f6;">at once. Not one at a time.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc publishes to Google Business Profile, Facebook, and Instagram across all your locations simultaneously. Write once, select all, schedule — every location stays active without copying, pasting, or logging in 20 times.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start scheduling free
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
            {['GBP · Facebook · Instagram', 'Bulk publish to all locations', 'Content calendar included', '$1 for 3 days'].map(c => (
              <span class="flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1 w-1 rounded-full bg-[#4f39f6]"></span>{c}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Manual social posting doesn't scale<br />past one location.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            One location, one social post — fine. Five locations, it's annoying. Twenty locations, it doesn't happen. So your profiles go quiet for weeks, your GBP activity score drops, and your Google Maps ranking slides while competitors who automated this stay active. The posting never catches up. The ranking gap gets wider.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Location profiles go inactive.', body: 'Google treats inactive GBP profiles as a negative ranking signal. When you stop posting — even for 2-3 weeks — your local pack position starts to erode. And it erodes faster when your competitors stay active.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Copy-pasting wastes hours per week.', body: 'Log in, switch accounts, paste, resize image, adjust caption, publish. Repeat 15 times. For a single post cycle across your locations, you\'ve burned an hour that should have taken two minutes.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Some locations always get forgotten.', body: 'When you\'re posting manually across 10+ locations, someone always gets skipped. The quiet locations fall behind. And the ones falling behind on GBP activity are the ones losing ground in local search rankings.' },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Write once. Every location stays<br />active automatically.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Connect your accounts, build your content calendar, set your publishing schedule. Stacc handles the rest — posting on time, to every location, every day.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101', title: 'Connect your platforms and locations', body: 'Connect GBP, Facebook, and Instagram accounts for all your locations via OAuth. No passwords stored. Setup takes 10 minutes regardless of how many locations you have.' },
            { n: '02', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Build your content calendar', body: 'Schedule individual posts or set up a recurring publishing cadence. Daily, weekly, or custom — Stacc publishes on your schedule automatically. Bulk-schedule weeks of content in a single session.' },
            { n: '03', icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', title: 'Posts publish. Locations stay active.', body: 'Every scheduled post goes out on time, to every location, across every connected platform. You see the confirmation in your dashboard. Your GBP activity scores stay high. Your rankings hold.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Everything included</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every social scheduling capability.<br />Built for multi-location.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z', title: 'Bulk publish to all locations', body: 'One post, published everywhere simultaneously. No login switching, no copy-paste, no missed locations.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Content calendar', body: 'Plan your entire posting schedule weeks ahead. Visual calendar view shows what\'s scheduled across all platforms and locations.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Location-specific customization', body: 'Add location-specific overrides per post before bulk-publishing. Same content, different local details — address, hours, phone — per account.' },
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Recurring schedules', body: 'Set a posting cadence — daily, weekly, custom — and Stacc posts automatically. Consistent GBP activity that sustains your local rankings.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Engagement tracking', body: 'Post reach, likes, and engagement across all platforms and locations tracked automatically in one dashboard.' },
            { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'GBP post performance', body: 'See how your GBP posts correlate with Maps ranking changes. Understand which content types drive the most profile engagement.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="relative overflow-hidden py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -20%, rgba(79,57,246,0.12) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Results</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What consistent social posting<br />does to your local rankings.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '8hrs', num: 8, prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Saved per month per location', sub: 'previously spent on manual social posting' },
            { value: '3×', num: 3, prefix: '', suffix: '×', decimals: 0, from: 0, label: 'More consistent posting cadence', sub: 'compared to manual multi-location posting' },
            { value: '89%', num: 89, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Of GBP profiles show ranking lift', sub: 'within 60 days of consistent posting' },
          ].map(m => (
            <div class="px-8 py-10 text-center">
              <div class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-white" style="color:#818cf8;">
                {m.prefix}<span data-count-up data-from={m.from} data-to={m.num} data-suffix={m.suffix} data-decimals={m.decimals}>{m.value}</span>
              </div>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">{m.label}</p>
              <p class="mt-1 font-sans text-[12px]" style="color:#6b7280;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <blockquote class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
            </div>
            <p class="font-sans text-[1rem] leading-relaxed text-[#292524]">"We have 23 franchise locations. Before Stacc, GBP posting was basically a joke — maybe 2-3 locations had recent posts. Now every location posts twice a week automatically. Our average Maps ranking improved almost a full position within 8 weeks."</p>
            <footer class="mt-5 flex items-center gap-3">
              <div class="h-9 w-9 rounded-full bg-[#f5f3ff] flex items-center justify-center">
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">KW</span>
              </div>
              <div>
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Kyle Winters</p>
                <p class="font-sans text-[12px] text-[#79716b]">Marketing Director · 23-location franchise group</p>
              </div>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>


    <!-- ─── RELATED FEATURES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Often used together</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Social scheduling works best<br />with the rest of local SEO.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'GBP Management', desc: 'Manage your full Google Business Profile — posts, hours, photos, and reviews — from one connected workflow.', href: '/modules/local-seo/', label: '$49/month' },
            { title: 'Review Monitoring', desc: 'Monitor and respond to reviews across Google, Facebook, and Yelp from the same dashboard you post from.', href: '/features/review-monitoring/', label: 'Included' },
            { title: 'Rank Tracking', desc: 'See how your GBP posting activity correlates with your Maps and local pack ranking changes over time.', href: '/features/rank-tracking/', label: 'Included' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <div class="flex items-start justify-between gap-4">
                <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
                <span class="shrink-0 rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">{r.label}</span>
              </div>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Questions about social scheduling
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-24" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.4) 0%, transparent 60%);" aria-hidden="true"></div>
