---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "What data is included in automated client reports?",
    a: "Each report includes keyword ranking changes (organic, local pack, and Maps), review counts and average star ratings, citation health status, GBP activity summary (posts published, views, clicks), and a period-over-period trend summary. You can choose which sections appear in each client's report.",
  },
  {
    q: "Can I white-label reports with my agency's branding?",
    a: "Yes. All reports use your agency's logo, brand colors, and custom domain. Clients receive the report from your brand — no Stacc logo or mention visible anywhere in the report. Set your branding once and it applies to all client reports.",
  },
  {
    q: "How does automated report delivery work?",
    a: "You set the schedule (weekly or monthly) and the recipient email addresses. Stacc assembles the report automatically from live data and delivers it by email on your chosen date. If you have 30 clients, 30 reports go out on schedule without you building a single one.",
  },
  {
    q: "Can clients have their own login to view reports?",
    a: "Yes. Client portal access can be granted separately from report delivery. Clients with portal access log in to a branded dashboard and see their own data — rankings, reviews, GBP activity — without accessing any other client's account.",
  },
  {
    q: "Can I customize what each client sees in their report?",
    a: "Yes. The report builder lets you choose which sections to include or exclude per client. Some clients want ranking data only. Others want the full stack. You configure it once per client and Stacc remembers.",
  },
  {
    q: "Are reports available as PDF and shareable links?",
    a: "Yes. Each report generates as both a PDF download and a shareable URL. Send clients a direct link they can bookmark, or attach the PDF to your own email if you prefer to add a personal note before delivery.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Client Reporting",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automated white-label client reports that assemble and deliver themselves. Rankings, reviews, citations, and GBP activity — branded as your agency, sent on schedule.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://thestacc.com/features/" },
        { "@type": "ListItem", "position": 3, "name": "Client Reporting", "item": "https://thestacc.com/features/client-reporting/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Automated Client Reporting — White-Label SEO Reports That Send Themselves | theStacc"
  description="Stop building client reports by hand. theStacc assembles ranking data, review scores, citations, and GBP activity into branded reports that deliver automatically every week or month."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Client Reporting · Agency Module</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Client reports that<br />
            <span style="color:#4f39f6;">build and send themselves.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc assembles ranking data, review scores, citation health, and GBP activity into branded reports — automatically. Set the schedule once. Every client gets a professional report on time, every time, with zero manual work after setup.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Automate your reports free
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
            {['White-label branding', 'Auto-delivery on schedule', 'PDF + shareable link', '$1 for 3 days'].map(c => (
              <span class="flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1 w-1 rounded-full bg-[#4f39f6]"></span>{c}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Manual reporting is the tax<br />that caps how many clients you can serve.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            3 hours per client per month. Across 15 clients, that's 45 hours — more than a full work week — spent every month doing something that should be automated. It's the invisible ceiling on your agency's capacity. You can't take on a 16th client if you're already spending 45 hours on reports for the first 15.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Reports arrive late or not at all.', body: 'The month-end rush hits. Three client reports were supposed to go out Monday. It\'s Thursday. Two are half-finished, one hasn\'t been started. Late reporting erodes client confidence faster than almost anything else.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Data from 5 tools, assembled by hand.', body: 'Rankings from one tool. Reviews from another. Citations from a third. GBP from Google. And then there\'s the formatting, the branding, the PDF export. Every step is manual. Every step is an opportunity for errors.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Your capacity growth is capped.', body: 'You can\'t scale if every new client adds 3 hours of manual reporting. The reporting debt compounds. The one thing that would let you grow — hiring — costs money you\'re spending on time you\'re wasting.' },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Configure once. Reports deliver<br />on their own from that point forward.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Connect your data sources, set your branding, schedule delivery. Stacc pulls the data, assembles the report, and sends it. Zero manual steps after initial setup.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z', title: 'Set up your report template', body: 'Choose which sections each client sees — rankings, reviews, citations, GBP activity. Set your white-label branding: logo, colors, custom domain. Takes 10 minutes per client template.' },
            { n: '02', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Schedule delivery to each client', body: 'Set the day and time reports go out — weekly, bi-weekly, or monthly. Add the client email addresses. Stacc sends reports automatically on your schedule. No calendar reminders needed.' },
            { n: '03', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Reports go out. Clients stay informed.', body: 'Every report period, Stacc pulls fresh data, assembles the report to your template, and delivers it. Clients get a professional PDF and shareable link — under your brand — on time every time.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Everything included</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every reporting capability you need.<br />Zero manual assembly.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Automated assembly', body: 'Rankings, reviews, citations, GBP — all pulled automatically and assembled into a clean report without any manual data collection.' },
            { icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'White-label branding', body: 'Your logo, your colors, your custom domain. Every report looks like it came from your agency. No Stacc branding visible anywhere.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Scheduled delivery', body: 'Reports go out weekly or monthly on your chosen date and time — automatically. No calendar reminders, no last-minute scrambles.' },
            { icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z', title: 'Client portal access', body: 'Clients can log into a branded portal to view their data anytime — rankings, reviews, GBP activity — without accessing any other client\'s account.' },
            { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', title: 'PDF + shareable link', body: 'Each report is available as a downloadable PDF and a unique shareable URL. Clients can bookmark their report link for live data access.' },
            { icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z', title: 'Per-client customization', body: 'Configure which data sections each client sees. Some get ranking-only reports. Others get the full stack. Set it once, Stacc remembers.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="relative overflow-hidden py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -20%, rgba(79,57,246,0.12) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">The numbers</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What automated reporting<br />does for agency capacity.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '3hrs', num: 3, prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Saved per client per month', sub: 'previously spent on manual report building' },
            { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'On-time delivery rate', sub: 'after automated scheduling is configured' },
            { value: '0', num: 0, prefix: '', suffix: '', decimals: 0, from: 0, label: 'Manual steps after setup', sub: 'reports assemble and send automatically' },
          ].map(m => (
            <div class="px-8 py-10 text-center">
              <div class="font-sans text-[3rem] font-semibold tracking-[-0.04em]" style="color:#818cf8;">
                {m.prefix}<span data-count-up data-from={m.from} data-to={m.num} data-suffix={m.suffix} data-decimals={m.decimals}>{m.value}</span>
              </div>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">{m.label}</p>
              <p class="mt-1 font-sans text-[12px]" style="color:#6b7280;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <blockquote class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
            </div>
            <p class="font-sans text-[1rem] leading-relaxed text-[#292524]">"I used to dread the last week of every month. 22 client reports, all manual. Since Stacc, they all go out on the 1st automatically. I gained back an entire week of capacity — which I immediately filled with two new clients."</p>
            <footer class="mt-5 flex items-center gap-3">
              <div class="h-9 w-9 rounded-full bg-[#f5f3ff] flex items-center justify-center">
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">SR</span>
              </div>
              <div>
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Sarah Renner</p>
                <p class="font-sans text-[12px] text-[#79716b]">Agency Owner · 22-client local SEO agency</p>
              </div>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>


    <!-- ─── RELATED FEATURES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Often used together</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Reporting works best when the<br />underlying data is automated too.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Rank Tracking', desc: 'Daily automated rankings feed directly into client reports — no manual data collection or copy-pasting from rank trackers.', href: '/features/rank-tracking/', label: 'Included' },
            { title: 'Review Monitoring', desc: 'Review scores and response rates appear in client reports automatically, pulled from the review monitoring module.', href: '/features/review-monitoring/', label: 'Included' },
            { title: 'White-Label Dashboard', desc: 'Give clients a branded portal to check their data anytime — a complement to automated report delivery.', href: '/features/white-label-dashboard/', label: 'Included' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <div class="flex items-start justify-between gap-4">
                <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
                <span class="shrink-0 rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">{r.label}</span>
              </div>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
