---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "How is this different from Google Keyword Planner?",
    a: "Google Keyword Planner shows broad national search volumes — it's built for paid ads, not local SEO. Stacc surfaces keywords by city, neighborhood, and service area with local search intent scoring. You'll find 'best plumber downtown [city]' before your competitor does. Keyword Planner won't show you that.",
  },
  {
    q: "How does keyword-to-location mapping work?",
    a: "You connect your locations, and Stacc suggests keyword sets for each one based on business type, city, and competitive density. Each keyword is mapped to the locations where it has the highest local search volume. You're not guessing which terms matter where — Stacc tells you.",
  },
  {
    q: "Can I do keyword research across multiple locations at once?",
    a: "Yes. Multi-location keyword research is core functionality. Stacc shows you keyword opportunities per location, surfaces keywords your competitors rank for that you don't, and lets you bulk-assign keyword clusters to location groups. One workflow for 5 locations or 500.",
  },
  {
    q: "What does 'search intent scoring' mean?",
    a: "Not every local keyword has the same intent. 'Plumber near me' is an emergency — high intent, needs fast response. 'How to fix a leaky pipe' is informational. Stacc scores keywords by purchase intent so you know which ones to prioritize for Google Maps and local pack rankings vs. blog content.",
  },
  {
    q: "Can I see what keywords my competitors rank for?",
    a: "Yes. The competitor keyword gap analysis shows you which keywords your top 3 local competitors rank for that you don't appear in at all. These are your fastest-win opportunities — terms with proven local demand where you have no current presence.",
  },
  {
    q: "How often is the keyword data refreshed?",
    a: "Local search volume data is refreshed monthly. Competitor ranking data is checked weekly so you catch new opportunities before they get competitive. When a new keyword appears in the gap analysis, you're alerted immediately.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Local Keyword Research Tool",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Discover the exact keywords your local customers search. theStacc maps high-intent local keywords to every location so you rank in the searches that drive foot traffic.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://thestacc.com/features/" },
        { "@type": "ListItem", "position": 3, "name": "Keyword Research", "item": "https://thestacc.com/features/keyword-research/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Local Keyword Research Tool — Find Keywords That Win Local Pack | theStacc"
  description="Discover the exact keywords your local customers search. theStacc maps high-intent local keywords to every location so you rank in the searches that drive foot traffic."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Keyword Research · Local SEO Module</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            You're targeting keywords<br />your local customers
            <span style="color:#4f39f6;"> never actually search.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc finds the high-intent local keywords tied to each location — the ones with real search volume, clear buyer intent, and room to rank. Stop guessing. Start with data that's specific to your city, your service, your customers.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Find your keywords
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $1 for 3 days · No credit card · Setup in under 10 minutes
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '3×', num: 3, prefix: '', suffix: '×', decimals: 0, from: 0, label: 'More local keyword visibility' },
              { value: '2hrs', num: 2, prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Saved per location per week' },
              { value: '89%', num: 89, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Find keywords they\'d missed' },
              { value: '4.9', num: 4.9, prefix: '', suffix: '★', decimals: 1, from: 0, label: 'Average review rating' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up={s.num > 0 ? true : undefined} data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Targeting the wrong keywords<br />costs you months of effort.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            The standard workflow: open Google Keyword Planner, search a few obvious terms, pick the ones with "medium competition," and start optimizing. Six months later the traffic isn't coming. Because Keyword Planner was built for national ad campaigns — it has no idea that "emergency HVAC repair" gets 10× the local searches in Phoenix in July that it does in December. Local keyword research requires local data. Guessing is costing you rankings your competitor is collecting.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
              title: 'You optimize for terms nobody searches locally.',
              body: 'National keyword tools show you vanity volume. "Best plumber" might have 40,000 monthly searches nationally — but in your metro, it\'s 90 searches, dominated by three established players. You need local data. Not national averages dressed up as local intelligence.',
            },
            {
              icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'Your competitor ranks for keywords you didn\'t know existed.',
              body: 'There are dozens of high-intent local keywords your top competitors rank for that you\'ve never appeared in. "Drain cleaning [neighborhood]," "[service] near [landmark]," "[service] [zip code]." Without a gap analysis, you\'ll never know — and they\'ll keep capturing those clicks.',
            },
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Multi-location keyword strategy is a spreadsheet nightmare.',
              body: 'If you manage 10 locations, each location has a different competitive landscape, different search volume, and different winning keywords. Managing that across a spreadsheet means you\'ll collapse it into one generic keyword list and wonder why results are inconsistent.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Local keywords mapped to every<br />location in three steps.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Connect your locations, get keyword suggestions tailored to each one, and close the gap on competitors — all without opening a spreadsheet.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Connect your locations', body: 'Add your business locations and categories. Stacc pulls local search data from Google to understand what searchers in your specific city and service area are actually typing — not national averages.' },
            { n: '02', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', title: 'Get location-specific keyword suggestions', body: 'Stacc surfaces keyword opportunities ranked by local search volume and search intent score. High-intent keywords — the ones that turn into calls — are prioritized. You see exactly which terms are worth targeting at each location.' },
            { n: '03', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Close competitor keyword gaps', body: 'The gap analysis shows every keyword your top local competitors rank for that you don\'t. Sort by intent score to find the fastest wins. Add them to your tracked keywords and start closing the gap.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Everything included</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every keyword intelligence tool<br />local SEO actually requires.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Location-Specific Suggestions', body: 'Keywords ranked by local search volume at the city and neighborhood level — not national estimates averaged down.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Search Intent Scoring', body: 'Every keyword scored by purchase intent. Know which terms drive calls and which drive clicks so you prioritize correctly.', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
            { title: 'Competitor Gap Analysis', body: 'See every keyword your top competitors rank for that you don\'t. Sorted by intent so you attack the highest-value gaps first.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Keyword-to-Location Mapping', body: 'Assign keyword clusters to specific locations. Each location gets the keywords that actually drive local search traffic there.', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7' },
            { title: 'Local Search Volume Data', body: 'Monthly search volumes at the local level refreshed regularly. Know if a keyword is trending up before your competitors notice.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
            { title: 'Bulk Keyword Assignment', body: 'Apply keyword sets to location groups in one action. Perfect for franchise and multi-location businesses with shared service categories.', icon: 'M4 6h16M4 10h16M4 14h16M4 18h16' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DEEP DIVE 1 ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl space-y-16">
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Location-Specific Keyword Data</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Keywords that actually get searched in your city. Not someone else's.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                National tools average search volume across the entire country. A keyword that gets 5,000 monthly national searches might get 12 local searches in your target city. Stacc pulls local data tied to your specific service area — zip codes, neighborhoods, city modifiers — so you're targeting terms your actual customers type, not theoretical national searchers.
              </p>
              <ul class="mt-6 space-y-3">
                {['City and neighborhood-level search volume breakdown', 'Seasonal demand patterns specific to your market', 'Service-area modifier suggestions ("[service] near [landmark]")', 'Long-tail local variants with lower competition and high intent'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Keyword Suggestions — Austin, TX</p>
                <span class="rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">47 new opportunities</span>
              </div>
              {[
                { kw: 'emergency plumber austin', vol: '1,200/mo', intent: 'High', comp: 'Medium' },
                { kw: 'drain cleaning near me', vol: '880/mo', intent: 'High', comp: 'Low' },
                { kw: 'water heater repair south austin', vol: '320/mo', intent: 'High', comp: 'Low' },
                { kw: 'plumber 78745', vol: '210/mo', intent: 'High', comp: 'Very Low' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{row.kw}</span>
                  <div class="flex items-center gap-3">
                    <div class="text-right">
                      <p class="font-mono text-[10px] text-[#79716b]">Volume</p>
                      <p class="font-sans text-[12px] font-semibold text-[#292524]">{row.vol}</p>
                    </div>
                    <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">{row.intent}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── DEEP DIVE 2 ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl">
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Competitor Keyword Gap — Your Location</p>
              <div class="space-y-3">
                {[
                  { kw: 'ac repair kyle tx', comp: 'AcePro HVAC', intent: 'High', gap: true },
                  { kw: 'hvac maintenance buda', comp: 'CoolBreeze Co', intent: 'Medium', gap: true },
                  { kw: 'furnace repair austin south', comp: '2 competitors', intent: 'High', gap: true },
                  { kw: 'emergency ac near me', comp: 'AcePro HVAC', intent: 'High', gap: true },
                ].map(row => (
                  <div class="flex items-center justify-between rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div>
                      <p class="font-sans text-[13px] font-semibold text-[#111827]">{row.kw}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{row.comp} ranks · you don't</p>
                    </div>
                    <span class="rounded-full bg-[#fff1f2] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#ef4444]">{row.intent} intent gap</span>
                  </div>
                ))}
                <div class="flex items-center justify-between pt-2">
                  <span class="font-mono text-[10px] text-[#79716b]">Updated weekly · Sorted by intent score</span>
                  <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">Add all → Track</span>
                </div>
              </div>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Competitor Keyword Gap Analysis</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                See exactly where your competitors are capturing traffic you're missing.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                The agencies winning local SEO aren't doing better keyword research by hand. They're using tools that surface competitor gaps automatically. Stacc shows you every keyword your top 3 local competitors rank for — sorted by intent score, updated weekly — so you know exactly where to focus next. Stop discovering opportunities six months after your competitor locked them up.
              </p>
              <ul class="mt-6 space-y-3">
                {['Weekly gap report: new competitor rankings you don\'t have', 'Filter by intent score to find highest-value gaps first', 'One-click: add gap keywords to rank tracking', 'Historical gap trends — see if you\'re closing or falling behind'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


