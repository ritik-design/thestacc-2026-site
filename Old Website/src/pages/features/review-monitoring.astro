---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "Which review platforms does Stacc monitor?",
    a: "Stacc monitors Google Business Profile, Facebook, and Yelp — the three platforms that carry the most weight for local SEO and customer decisions. All reviews from these platforms are aggregated into a single dashboard. New reviews trigger instant alerts regardless of which platform they appear on.",
  },
  {
    q: "How fast does Stacc alert me when a new review comes in?",
    a: "Stacc checks for new reviews continuously throughout the day. The moment a new review is detected on any monitored platform, you receive an alert — email, in-app, or both depending on your notification settings. For agencies managing multiple clients, alerts are client-tagged so you know immediately which location and which client needs attention.",
  },
  {
    q: "Does response time really affect local SEO rankings?",
    a: "Yes. Google uses review engagement as a local ranking signal. Businesses that respond to reviews — especially promptly — signal to Google that they're active, engaged, and caring about their customers. Slow or no responses are a missed signal. Additionally, faster responses to negative reviews prevent further damage from customers who amplify complaints after feeling ignored.",
  },
  {
    q: "How do I handle negative reviews?",
    a: "Stacc doesn't remove negative reviews — no tool can do that ethically. What Stacc does is ensure you never miss a negative review (instant alerts), gives you response templates calibrated for damage control, and tracks how your average star rating trends over time so you can see the impact of your review response strategy. Consistent, professional responses to negative reviews often convert skeptical prospects better than a perfect 5-star average.",
  },
  {
    q: "Can I manage reviews for multiple locations from one dashboard?",
    a: "Yes. All locations are aggregated into a single review dashboard. You can filter by location, platform, star rating, or date range. If you manage 20 locations, you're not logging into 20 different GBP accounts — everything comes through Stacc. Agency plans allow you to manage reviews for multiple clients from the same interface.",
  },
  {
    q: "What does the sentiment analysis show?",
    a: "Sentiment analysis reads the text of every review to surface themes — what customers are praising, what they're complaining about, and how sentiment trends over time. If three new 3-star reviews all mention 'slow response times,' that's a pattern Stacc surfaces so you can address it before it becomes a consistent reputation problem.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Review Monitoring Software",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Monitor reviews across Google, Facebook, and Yelp from one dashboard. Get instant alerts for new reviews. Respond faster. Protect your reputation automatically.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://thestacc.com/features/" },
        { "@type": "ListItem", "position": 3, "name": "Review Monitoring", "item": "https://thestacc.com/features/review-monitoring/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Review Monitoring Software — Track & Respond to Every Review in One Dashboard | theStacc"
  description="Monitor reviews across Google, Facebook, and Yelp from one dashboard. Get instant alerts for new reviews. Respond faster. Protect your reputation automatically."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Review Monitoring · Local SEO Module</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            A 1-star review just went up.<br />You won't find out
            <span style="color:#4f39f6;"> for two weeks.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc monitors every review across Google, Facebook, and Yelp from one dashboard. Instant alerts when a new review lands. Response templates ready to go. Your reputation never goes unmanaged again.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Monitor every review
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $1 for 3 days · No credit card · All platforms in one view
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '4.2hrs', num: 4.2, prefix: '', suffix: 'hrs', decimals: 1, from: 0, label: 'Saved per week on review management' },
              { value: '73%', num: 73, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Faster review response time' },
              { value: '0.4★', num: 0.4, prefix: '', suffix: '★', decimals: 1, from: 0, label: 'Star rating improvement average' },
              { value: '4.9', num: 4.9, prefix: '', suffix: '★', decimals: 1, from: 0, label: 'Stacc average rating' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up={s.num > 0 ? true : undefined} data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Logging into six platforms to check<br />reviews is not a reputation strategy.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            The standard approach: remember to check Google, remember to check Yelp, remember to check Facebook, remember to check the location-specific pages for each of your 15 clients. Every week. Without fail. And when a new 1-star review goes up on a Tuesday afternoon while you're in a client call, it sits there unanswered for five days — getting read by every prospect who's researching that business before they decide to call or move on.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'You find out about bad reviews when customers tell you.',
              body: 'A 1-star review can sit unanswered for weeks. Every person who searches your client\'s business during that window sees the unaddressed complaint as the final word. You lose customers you never had a chance to save — because you didn\'t know in time.',
            },
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Manual review checking eats time you can\'t bill.',
              body: 'Across 10 clients on 3 platforms, checking reviews manually takes over 4 hours a week. That\'s 16+ hours a month spent on a task that should take zero minutes. Every hour you spend checking is an hour you\'re not spending on work that actually moves rankings.',
            },
            {
              icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
              title: 'Slow responses signal you don\'t care — to Google and to prospects.',
              body: 'Google rewards active, responsive businesses. A business that responds to reviews within hours outperforms one that responds within weeks on local ranking signals. And the prospect reading your reviews is making a call/no-call decision in 30 seconds — your response speed is part of that judgment.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connect once. Every review<br />comes to you automatically.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Connect your Google Business Profile, Facebook, and Yelp accounts. Stacc aggregates every review, alerts you the moment a new one appears, and surfaces a response template so you can respond in seconds — not days.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1', title: 'Connect your review platforms', body: 'Link your Google Business Profile, Facebook Pages, and Yelp accounts. For multi-location businesses, connect all locations at once. Setup takes under 5 minutes and requires no developer work.' },
            { n: '02', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Get instant alerts for every new review', body: 'The moment a new review appears on any platform, you\'re notified — with the review text, star rating, platform, and location. No more manual checking. No more missed negative reviews sitting unanswered.' },
            { n: '03', icon: 'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z', title: 'Respond from the dashboard — in seconds', body: 'Response templates are ready for every review type — 5-star thank-you, 1-star damage control, 3-star recovery. Select a template, personalize it in 20 seconds, and publish your response without leaving Stacc.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Everything included</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every review management tool<br />without the platform-hopping.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Multi-Platform Aggregation', body: 'Google, Facebook, and Yelp reviews unified in one feed. Filter by platform, location, star rating, or date — one view, everything.', icon: 'M4 6h16M4 10h16M4 14h16M4 18h16' },
            { title: 'Instant New-Review Alerts', body: 'Real-time notification the moment a new review is detected. Email and in-app alerts, tagged by client and location.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Response Templates', body: 'Pre-built response templates for every scenario: 5-star appreciation, 1-star recovery, 3-star follow-up. Personalize in 20 seconds, publish without leaving Stacc.', icon: 'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z' },
            { title: 'Sentiment Analysis', body: 'What are customers praising? What are they complaining about? Stacc reads review text to surface recurring themes — positive and negative.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Star Rating Trends', body: 'Track average star rating over time for each location. See the impact of review response strategy and identify when ratings start drifting.', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
            { title: 'Competitor Review Comparison', body: 'See how your star rating and review volume compares to top local competitors. Know when you\'re falling behind before prospects notice.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DEEP DIVE 1 ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl space-y-16">
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Unified Review Dashboard</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Every review. Every platform. One inbox you actually check.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                The moment you stop logging into separate platforms to check reviews is the moment reviews stop falling through the cracks. Stacc's unified review dashboard shows every review from Google, Facebook, and Yelp in a single chronological feed. Filter by platform, star rating, location, or client. The reviews requiring urgent response surface at the top — you never have to hunt for the problem.
              </p>
              <ul class="mt-6 space-y-3">
                {['All platforms in one feed — chronological, filterable', 'Unanswered reviews flagged and sorted to the top', 'Response status tracking — responded, pending, noted', 'Client-level views for agencies managing multiple businesses'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Review Feed — All Locations</p>
                <span class="rounded-full bg-[#fff1f2] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#ef4444]">2 need response</span>
              </div>
              {[
                { platform: 'Google', stars: 1, text: '"Waited 45 minutes past appointment..."', time: '2 hours ago', responded: false },
                { platform: 'Yelp', stars: 5, text: '"Absolutely excellent service. Will..."', time: '3 hours ago', responded: true },
                { platform: 'Facebook', stars: 3, text: '"Good work but communication could..."', time: '5 hours ago', responded: false },
                { platform: 'Google', stars: 5, text: '"Best plumber in Austin, hands down."', time: 'Yesterday', responded: true },
              ].map(row => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-[#f5f3ff]">
                    <span class="font-mono text-[9px] font-bold text-[#4f39f6]">{row.stars}★</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">{row.platform}</span>
                      <span class="font-mono text-[10px] text-[#79716b]">{row.time}</span>
                    </div>
                    <p class="font-sans text-[12px] text-[#57534e] truncate">{row.text}</p>
                  </div>
                  <span class={`shrink-0 rounded-full px-2 py-0.5 font-mono text-[9px] font-semibold ${row.responded ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#fff1f2] text-[#ef4444]'}`}>{row.responded ? 'Replied' : 'Pending'}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── DEEP DIVE 2 ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl">
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Star Rating Trends — Last 90 Days</p>
              <div class="space-y-4">
                <div class="rounded-xl bg-[#f5f3ff] p-4">
                  <div class="flex items-center justify-between mb-2">
                    <span class="font-sans text-[13px] font-semibold text-[#111827]">Average Star Rating</span>
                    <span class="font-sans text-[13px] font-semibold text-[#059669]">4.6 ↑ from 4.2</span>
                  </div>
                  <div class="h-1.5 w-full rounded-full bg-[#e7e5e4]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:92%"></div></div>
                </div>
                <div class="rounded-xl bg-[#fafaf9] p-4">
                  <div class="flex items-center justify-between mb-2">
