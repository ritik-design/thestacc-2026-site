---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  {
    question: "How do I earn commissions?",
    answer: "Share your unique affiliate link. When someone clicks it and signs up for theStacc, you earn a commission on every payment they make — for up to 3 years. If they sign up directly through your link, you earn 25%. If our sales team helps close the deal, you earn 15%.",
  },
  {
    question: "When and how do I get paid?",
    answer: "Payouts are monthly, net-30. Commissions from March are paid on April 15th. Minimum payout is $50. We pay via PayPal, direct bank transfer (ACH), or Wise for international affiliates.",
  },
  {
    question: "How long does the cookie last?",
    answer: "90 days. If someone clicks your link and signs up within 90 days, you get credit — even if they don't buy immediately. You also get a unique coupon code that works without cookies.",
  },
  {
    question: "Do I need to be a customer to be an affiliate?",
    answer: "No, but it helps. Affiliates who use the product can speak from experience, and their content converts better. We provide a free account to all active affiliates so you can try everything firsthand.",
  },
  {
    question: "What if my referral upgrades their plan later?",
    answer: "You earn more. Your commission is a percentage of whatever your referral pays. If they start at $49/month with one module and upgrade to $199/month or bundle multiple modules, your commission goes up with them.",
  },
  {
    question: "Are there any restrictions on how I can promote?",
    answer: "We ask affiliates not to spam, bid on our branded keywords in paid search, or make misleading claims. Beyond that, you're free to promote through your blog, YouTube, email list, social media, podcast, or any other channel.",
  },
  {
    question: "What marketing materials do you provide?",
    answer: "Banner ads, email templates, social graphics, comparison data sheets, product screenshots, a brand kit, and more. After signup, you get access to our full affiliate resource library.",
  },
  {
    question: "Is there a limit to how much I can earn?",
    answer: "No cap, no limit. Some of our affiliates earn thousands per month. At our $199/month Blog SEO top tier, a single referral earns you $49.75/month — recurring, for up to 3 years. Bundle referrals at $167/month earn you $41.75/month per customer.",
  },
];
---

<BaseLayout
  title="Affiliate Program - Earn 25% Recurring Commission | theStacc"
  description="Join the theStacc affiliate program. Earn 25% recurring commission for 3 years promoting the done-for-you SEO service. 90-day cookie, monthly payouts, dedicated support."
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-16 md:py-24">
      <div class="mx-auto max-w-[680px] text-center">
        <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Affiliate Program</p>
        <h1 class="mt-5 font-sans text-[32px] leading-[40px] md:text-[42px] md:leading-[52px] font-normal text-[#292524]">
          Earn recurring income promoting SEO that runs itself.
        </h1>
        <p class="mt-6 font-sans text-[17px] leading-[28px] text-[#57534e]">
          Recommend theStacc to your audience and earn up to 25% of every payment — for up to 3 years per referral. No cap on how many referrals you make.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#apply"
            class="inline-flex h-[44px] items-center gap-2 rounded-[12px] border border-[#4f39f6] bg-[#615fff] px-6 font-mono text-[14px] font-semibold uppercase text-[#fafaf9] transition-colors hover:bg-[#4f39f6]"
          >
            Become an Affiliate
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a
            href="#how-it-works"
            class="inline-flex items-center gap-1 font-sans text-[14px] font-medium text-[#4f39f6] transition-colors hover:text-[#3b2fc2]"
          >
            See how it works
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Headline Stats -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="grid grid-cols-2 md:grid-cols-4">
        <div class="border-b md:border-b-0 md:border-r border-[#e7e5e4] px-6 py-8 text-center">
          <p class="font-mono text-[32px] md:text-[36px] font-bold text-[#4f39f6]">25%</p>
          <p class="mt-2 font-sans text-[14px] text-[#79716b]">Recurring commission</p>
        </div>
        <div class="border-b md:border-b-0 md:border-r border-[#e7e5e4] px-6 py-8 text-center">
          <p class="font-mono text-[32px] md:text-[36px] font-bold text-[#4f39f6]">90</p>
          <p class="mt-2 font-sans text-[14px] text-[#79716b]">Day cookie window</p>
        </div>
        <div class="border-b md:border-b-0 md:border-r border-[#e7e5e4] px-6 py-8 text-center">
          <p class="font-mono text-[32px] md:text-[36px] font-bold text-[#4f39f6]">3 Years</p>
          <p class="mt-2 font-sans text-[14px] text-[#79716b]">Recurring payouts</p>
        </div>
        <div class="px-6 py-8 text-center">
          <p class="font-mono text-[32px] md:text-[36px] font-bold text-[#4f39f6]">$0</p>
          <p class="mt-2 font-sans text-[14px] text-[#79716b]">To join the program</p>
        </div>
      </div>
    </section>

    <!-- Commission Structure -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-14 md:py-20">
      <div class="mx-auto max-w-[780px]">
        <div class="text-center">
          <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Commission Structure</p>
          <h2 class="mt-4 font-sans text-[28px] leading-[36px] md:text-[32px] md:leading-[42px] font-normal text-[#292524]">
            Two ways to earn. Both pay recurring.
          </h2>
        </div>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-0 rounded-xl border border-[#e7e5e4] overflow-hidden">
          <!-- Direct Sale -->
          <div class="border-b md:border-b-0 md:border-r border-[#e7e5e4] bg-[#fafaf9] p-6 md:p-8">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            </div>
            <p class="mt-5 font-mono text-[40px] font-bold text-[#292524]">25%</p>
            <p class="mt-1 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#4f39f6]">Direct Sale</p>
            <p class="mt-3 font-sans text-[15px] leading-[24px] text-[#79716b]">
              Customer signs up and pays through your affiliate link without any involvement from our sales team. You get the full 25%.
            </p>
            <div class="mt-5 space-y-2">
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Blog SEO ($99/mo)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">$24.75/mo</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Bundle ($167/mo)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">$41.75/mo</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Blog SEO Pro ($199/mo)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">$49.75/mo</span>
              </div>
            </div>
          </div>

          <!-- Sales-Assisted -->
          <div class="bg-[#fafaf9] p-6 md:p-8">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <p class="mt-5 font-mono text-[40px] font-bold text-[#292524]">15%</p>
            <p class="mt-1 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#4f39f6]">Sales-Assisted</p>
            <p class="mt-3 font-sans text-[15px] leading-[24px] text-[#79716b]">
              You generate the lead through your link, but our sales team helps close the deal with a demo or follow-up. You still earn 15%.
            </p>
            <div class="mt-5 space-y-2">
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Blog SEO ($99/mo)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">$14.85/mo</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Bundle ($167/mo)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">$25.05/mo</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Blog SEO Pro ($199/mo)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">$29.85/mo</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Earnings example callout -->
        <div class="mt-6 rounded-xl border border-[#e7e5e4] bg-[#f5f3ff] px-6 py-5">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#4f39f6]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <p class="font-sans text-[15px] leading-[24px] text-[#292524]">
              <strong>Example:</strong> Refer 20 customers on the $99/mo Blog SEO plan and earn <strong class="text-[#4f39f6]">$495/month</strong> — every month, for up to 3 years.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="px-6 pt-8 pb-0 text-center">
        <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">How It Works</p>
        <h2 class="mx-auto mt-4 max-w-[480px] font-sans text-[30px] leading-[38px] font-normal text-[#292524]">
          Start earning in three steps.
        </h2>
      </div>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 border-t border-b border-[#e7e5e4]">
        <div class="px-6 py-5 md:py-8 border-b md:border-b-0 md:border-r border-[#e7e5e4]">
          <div class="flex items-center justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
              </svg>
            </div>
            <span class="font-mono text-[32px] font-bold text-[#e7e5e4]">01</span>
          </div>
          <p class="mt-5 font-mono text-[14px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Apply & Get Your Link</p>
          <p class="mt-2 font-sans text-[14px] leading-[20px] text-[#79716b] hidden md:block">Fill out the form below. We'll review your application and send you a unique affiliate link and coupon code within 24 hours.</p>
        </div>
        <div class="px-6 py-5 md:py-8 border-b md:border-b-0 md:border-r border-[#e7e5e4]">
          <div class="flex items-center justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
              </svg>
            </div>
            <span class="font-mono text-[32px] font-bold text-[#e7e5e4]">02</span>
          </div>
          <p class="mt-5 font-mono text-[14px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Share With Your Audience</p>
          <p class="mt-2 font-sans text-[14px] leading-[20px] text-[#79716b] hidden md:block">Promote theStacc through your blog, YouTube channel, email list, social media, or podcast. We provide banners, templates, and swipe copy.</p>
        </div>
        <div class="px-6 py-5 md:py-8">
          <div class="flex items-center justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <span class="font-mono text-[32px] font-bold text-[#e7e5e4]">03</span>
          </div>
          <p class="mt-5 font-mono text-[14px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Earn Recurring Income</p>
          <p class="mt-2 font-sans text-[14px] leading-[20px] text-[#79716b] hidden md:block">Every time someone signs up through your link, you earn a commission on every payment they make — for up to 3 years. Monthly payouts, no cap.</p>
        </div>
      </div>
    </section>

    <!-- Why Promote theStacc -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-14 md:py-20">
      <div class="mx-auto max-w-[780px]">
        <div class="text-center">
          <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Why Promote theStacc</p>
          <h2 class="mt-4 font-sans text-[28px] leading-[36px] md:text-[32px] md:leading-[42px] font-normal text-[#292524]">
            A product that sells itself.
          </h2>
          <p class="mt-4 font-sans text-[16px] leading-[26px] text-[#57534e]">
            theStacc solves a real problem for real businesses. Your audience doesn't need to learn SEO — they just need to sign up.
          </p>
        </div>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">High Price Points</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">Plans range from $49 to $199/month per module. Bundle multiple modules and your commission scales with the customer.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">3-Year Recurring</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">No one-time payouts. You earn for up to 3 years per referral. Commissions compound over time as your referral base grows.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Low Churn Product</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">theStacc is a done-for-you service, not a tool people forget about. Customers stay because their SEO keeps running automatically.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Easy to Pitch</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">"Sign up and we handle your SEO" is simpler than "here's a tool, learn to use it." The done-for-you angle converts better than software demos.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">90-Day Cookie</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">Longer than Jasper (30 days), Writesonic (30 days), and Surfer SEO (60 days). More time means more conversions from your traffic.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Ready-Made Assets</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">Banners, email templates, social graphics, comparison sheets, and video scripts. Everything you need to start promoting on day one.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Earnings Calculator -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-14 md:py-20">
      <div class="mx-auto max-w-[680px]">
        <div class="text-center">
          <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Earnings Calculator</p>
          <h2 class="mt-4 font-sans text-[28px] leading-[36px] md:text-[32px] md:leading-[42px] font-normal text-[#292524]">
            See what you could earn.
          </h2>
        </div>

        <div class="mt-10 rounded-xl border border-[#e7e5e4] overflow-hidden">
          <!-- Controls -->
          <div class="bg-[#fafaf9] px-6 py-6 space-y-5">
            <div>
