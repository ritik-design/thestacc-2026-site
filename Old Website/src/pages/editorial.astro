---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { SITE_URL, buildBreadcrumbs, organizationSchema } from '../utils/schema';

const editorialSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/editorial/`,
      name: 'Editorial Standards - theStacc',
      url: `${SITE_URL}/editorial/`,
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(`${SITE_URL}/editorial/`, [
      { name: 'Home', url: SITE_URL },
      { name: 'Editorial Standards', url: `${SITE_URL}/editorial/` },
    ]),
    organizationSchema,
  ],
};
---

<BaseLayout
  title="Editorial Standards | theStacc"
  description="How theStacc creates, reviews, and publishes content. Our editorial process, fact-checking methodology, review disclosure policy, and content quality standards."
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(editorialSchema)} />

    <article class="mx-auto max-w-[680px] px-6 py-14 md:py-20">
      <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Our Standards</p>
      <h1 class="mt-4 font-sans text-[32px] leading-[40px] md:text-[38px] md:leading-[48px] font-semibold text-[#292524]">
        Editorial Standards
      </h1>
      <p class="mt-4 font-sans text-[17px] leading-[28px] text-[#57534e]">
        theStacc publishes SEO guides, software reviews, tool comparisons, and industry content. Here is how we create, verify, and maintain that content.
      </p>

      <div class="mt-10 space-y-10">
        <!-- Content Creation -->
        <section>
          <h2 class="font-sans text-[22px] leading-[30px] font-semibold text-[#292524]">How We Create Content</h2>
          <div class="mt-4 space-y-4 font-sans text-[16px] leading-[26px] text-[#57534e]">
            <p>
              Every article on theStacc is planned around keyword research and search intent analysis. We identify topics where businesses need clear, actionable guidance, then create comprehensive content that answers the full scope of the query.
            </p>
            <p>
              Our content uses AI-assisted workflows for research and initial drafting. Every piece is then reviewed, edited, and fact-checked by our editorial team before publication. We use AI as a tool to increase output, not as a replacement for editorial judgment.
            </p>
            <p>
              All content is attributed to <a href="/author/siddharth-gangal/" class="text-[#4f39f6] hover:underline">Siddharth Gangal</a>, founder of theStacc, who oversees editorial direction and final review.
            </p>
          </div>
        </section>

        <!-- Fact-Checking -->
        <section>
          <h2 class="font-sans text-[22px] leading-[30px] font-semibold text-[#292524]">Fact-Checking Process</h2>
          <div class="mt-4 space-y-4 font-sans text-[16px] leading-[26px] text-[#57534e]">
            <p>
              Statistics, pricing data, feature claims, and product information referenced in our content are verified against primary sources before publication. We link directly to the source wherever possible.
            </p>
            <ul class="list-disc pl-6 space-y-2">
              <li>Pricing data is verified against the official pricing pages of each product</li>
              <li>Statistics are sourced from named studies, industry reports, or official company data</li>
              <li>Feature comparisons are based on publicly available documentation and hands-on testing</li>
              <li>Publication and update dates are displayed on every article</li>
            </ul>
            <p>
              If you find an error in any of our content, please <a href="/contact/" class="text-[#4f39f6] hover:underline">contact us</a> and we will correct it promptly.
            </p>
          </div>
        </section>

        <!-- Reviews Disclosure -->
        <section>
          <h2 class="font-sans text-[22px] leading-[30px] font-semibold text-[#292524]">Review &amp; Comparison Disclosure</h2>
          <div class="mt-4 space-y-4 font-sans text-[16px] leading-[26px] text-[#57534e]">
            <p>
              theStacc is a commercial product that competes with several tools we review and compare. We disclose this clearly on every review and alternatives page with the following notice:
            </p>
            <blockquote class="border-l-[3px] border-[#4f39f6] bg-[#fafaf9] px-5 py-4 rounded-r-lg">
              <p class="font-sans text-[15px] leading-[24px] text-[#44403c]">
                "This review was written and published by Stacc, a competing product. We have a commercial interest as an alternative. All pricing and feature data verified against public sources."
              </p>
            </blockquote>
            <p>
              We do not accept payment from any company in exchange for favorable reviews. Our review ratings reflect genuine editorial assessment. We test products firsthand where possible and cross-reference with publicly available user reviews on platforms like G2, Capterra, and TrustRadius.
            </p>
          </div>
        </section>

        <!-- Content Updates -->
        <section>
          <h2 class="font-sans text-[22px] leading-[30px] font-semibold text-[#292524]">Content Freshness &amp; Updates</h2>
          <div class="mt-4 space-y-4 font-sans text-[16px] leading-[26px] text-[#57534e]">
            <p>
              SEO and marketing technology evolve rapidly. We maintain our content through:
            </p>
            <ul class="list-disc pl-6 space-y-2">
              <li>Displaying publication dates and last-updated dates on all articles</li>
              <li>Quarterly reviews of pricing and feature data in software reviews</li>
              <li>Updating statistical content when new data becomes available</li>
              <li>Removing or redirecting content that is no longer accurate or relevant</li>
            </ul>
          </div>
        </section>

        <!-- Glossary -->
        <section>
          <h2 class="font-sans text-[22px] leading-[30px] font-semibold text-[#292524]">Glossary Standards</h2>
          <div class="mt-4 space-y-4 font-sans text-[16px] leading-[26px] text-[#57534e]">
            <p>
              Our <a href="/glossary/" class="text-[#4f39f6] hover:underline">glossary of 690+ terms</a> follows a consistent format: a concise definition, contextual explanation, practical relevance, and related terms. Definitions are written to be accurate, accessible, and useful for both beginners and experienced marketers.
            </p>
          </div>
        </section>

        <!-- Contact -->
        <section>
          <h2 class="font-sans text-[22px] leading-[30px] font-semibold text-[#292524]">Questions or Corrections</h2>
          <div class="mt-4 font-sans text-[16px] leading-[26px] text-[#57534e]">
            <p>
              If you have questions about our editorial process or want to report an error, reach out at <a href="/contact/" class="text-[#4f39f6] hover:underline">thestacc.com/contact</a>.
            </p>
          </div>
        </section>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
