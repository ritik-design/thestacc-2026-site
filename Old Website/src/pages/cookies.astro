---
import LegalLayout from '../layouts/LegalLayout.astro';

const toc = [
  { id: 'what',     label: '1. What Are Cookies' },
  { id: 'types',    label: '2. Types of Cookies We Use' },
  { id: 'managing', label: '3. Managing Cookies' },
  { id: 'contact',  label: '4. Contact' },
];
---

<LegalLayout
  title="Cookie Policy"
  description="How theStacc uses cookies and how you can manage your preferences. Understand our cookie policy and your privacy controls."
  lastUpdated="April 2026"
  badge="Legal · Cookies"
  tocItems={toc}
  currentPath="/cookies/"
>
  <div class="flex flex-col gap-10">

    <section id="what" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">What Are Cookies</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Cookies are small text files placed on your device when you visit a website. They are widely used to make websites work more efficiently, as well as to provide information to site owners. We use cookies to enhance your experience on theStacc and to understand how our services are used.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="types" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Types of Cookies We Use</h2>
      </div>
      <div class="pl-9 flex flex-col gap-6">
        {[
          {
            title: 'Necessary Cookies',
            body: 'These cookies are essential for the website to function properly. They enable core functionality such as security, network management, and account access. The site cannot function correctly without these cookies and they cannot be disabled.',
          },
          {
            title: 'Analytics Cookies',
            body: 'These cookies help us understand how visitors interact with our website by collecting and reporting information anonymously. They help us improve the way our site works, for example, by ensuring that users find what they are looking for easily.',
          },
          {
            title: 'Marketing Cookies',
            body: 'These cookies are used to track visitors across websites to display relevant advertisements based on your interests. They are set by our advertising partners and may be used to build a profile of your interests.',
          },
        ].map(item => (
          <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-5 py-4">
            <p class="font-sans text-[14px] font-semibold text-[#111827] mb-2">{item.title}</p>
            <p class="font-sans text-[14px] leading-[1.7] text-[#57534e]">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="managing" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Managing Cookies</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          You can control and manage cookies in various ways. Most browsers allow you to refuse cookies or to delete cookies that have already been set. Note that disabling cookies may affect the functionality of theStacc. To opt out of analytics tracking, you can also use browser extensions such as uBlock Origin or similar tools.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="contact" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Contact</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          <strong class="font-semibold text-[#111827]">Company:</strong> SOLARTREK VENTURES LLP<br/>
          <strong class="font-semibold text-[#111827]">Address:</strong> Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India<br/>
          <strong class="font-semibold text-[#111827]">Email:</strong> <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>
        </p>
      </div>
    </section>

  </div>
</LegalLayout>
