---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono fondamentali per le imprese di trasloco?",
    a: "Il trasloco è una delle decisioni con più alto livello di fiducia richiesta: i clienti affidano tutti i loro beni a persone sconosciute. L'81% delle persone legge almeno 10 recensioni prima di scegliere un'impresa di trasloco. Un profilo Google con molte recensioni positive riduce drasticamente l'incertezza e aumenta le conversioni da ricerche locali."
  },
  {
    q: "Come theStacc raccoglie le recensioni per i traslochi?",
    a: "Dopo ogni trasloco completato, theStacc invia automaticamente un SMS o email al cliente con un link diretto alla pagina Google della tua impresa. Il messaggio è personalizzato con il nome del cliente e la data del trasloco, aumentando significativamente il tasso di risposta."
  },
  {
    q: "Il settore dei traslochi ha picchi stagionali — theStacc si adatta?",
    a: "Sì. theStacc funziona sempre in automatico, ma puoi intensificare le campagne nei periodi di punta (primavera-estate, fine mese). Il sistema gestisce volumi variabili senza costi aggiuntivi, permettendoti di capitalizzare al massimo i periodi di alta stagione."
  },
  {
    q: "Come gestisce theStacc le recensioni negative nel settore traslochi?",
    a: "Il settore traslochi è soggetto a reclami per oggetti rotti o ritardi. theStacc include un filtro pre-pubblicazione: i clienti insoddisfatti vengono indirizzati a un canale privato dove puoi risolvere il problema. Solo i clienti soddisfatti ricevono la richiesta di recensione pubblica."
  },
  {
    q: "Posso raccogliere recensioni anche per traslochi aziendali?",
    a: "Assolutamente. theStacc permette di configurare messaggi diversi per clienti privati e aziendali. Per i traslochi aziendali, la richiesta può essere indirizzata al responsabile acquisti o al contatto principale dell'azienda cliente."
  },
  {
    q: "theStacc funziona anche per le imprese di trasloco con più città?",
    a: "Sì. Puoi gestire più profili Google Business (uno per ogni sede o zona operativa) dalla stessa dashboard. Le recensioni vengono tracciate separatamente per ogni area geografica, permettendoti di vedere dove sei più forte e dove crescere."
  },
  {
    q: "Quante nuove recensioni posso aspettarmi al mese?",
    a: "La maggior parte delle imprese di trasloco che usano theStacc raccoglie tra 10 e 25 nuove recensioni al mese, a seconda del volume di lavori. Con un tasso di conversione medio del 35%, ogni 30 traslochi puoi aspettarti 10 nuove recensioni."
  },
  {
    q: "Qual è il costo di theStacc per un'impresa di trasloco?",
    a: "theStacc parte da $49 al mese per un'impresa con una sede. Il piano include automazione completa, filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni, nessuna carta di credito richiesta."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Traslochi",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per imprese di trasloco. Automatizza la raccolta di recensioni, aumenta la fiducia dei clienti e migliora il ranking locale.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Traslochi", "item": "https://thestacc.com/it/per/traslochi/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Imprese di Trasloco | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i clienti della tua impresa di trasloco con le recensioni Google automatizzate. theStacc raccoglie recensioni dopo ogni trasloco e ti aiuta a dominare la ricerca locale." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Imprese di Trasloco</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Clienti per la Tua Impresa di Trasloco<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          380.000 italiani cercano servizi di trasloco ogni mese. Chi ispira più fiducia online vince il lavoro. theStacc raccoglie le tue recensioni automaticamente dopo ogni trasloco completato.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">380K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">81%</div>
            <div class="text-gray-400 text-sm">cerca online prima di chiamare</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.6×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Imprese"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Imprese"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          La Sfida delle Imprese di Trasloco Online
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          Il trasloco è una scelta ad alta fiducia. Se il tuo profilo Google non convince, il telefono non squilla.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">La Fiducia si Costruisce Online Prima della Chiamata</h3>
            <p class="text-gray-600">L'81% dei clienti legge le recensioni prima di richiedere un preventivo di trasloco. Se hai poche recensioni, molti potenziali clienti passano al concorrente senza nemmeno contattarti.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Trasloco Finisce — e la Recensione Non Arriva Mai</h3>
            <p class="text-gray-600">Il cliente è soddisfatto, ti stringe la mano, promette una recensione. Ma lo stress del trasloco lo assorbe completamente. Senza un sistema automatico, quella recensione non arriverà mai.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">La Stagione Alta Lascia Zero Tempo</h3>
            <p class="text-gray-600">In primavera e d'estate hai 10 traslochi a settimana. Non c'è tempo per inseguire recensioni manualmente. E proprio nei periodi di punta, non capitalizzi la soddisfazione dei clienti.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Reputazione per le Imprese di Trasloco
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc automatizza ogni aspetto delle tue recensioni online, così puoi concentrarti sui traslochi.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Richieste Automatiche Post-Trasloco",
              desc: "Quando un trasloco si conclude, il cliente riceve automaticamente SMS o email con link diretto a Google. Il momento perfetto — quando la soddisfazione è al massimo."
            },
            {
              title: "Filtro Clienti Insoddisfatti",
              desc: "I reclami per oggetti rotti o ritardi vengono intercettati prima della pubblicazione. Il cliente insoddisfatto viene indirizzato a un canale privato per la risoluzione."
            },
            {
              title: "Dashboard Multi-Area",
              desc: "Gestisci le recensioni per ogni zona operativa o sede dalla stessa interfaccia. Vedi dove sei più forte e dove concentrare gli sforzi."
            },
            {
              title: "Personalizzazione per Tipo di Trasloco",
              desc: "Messaggi diversi per traslochi privati, aziendali, internazionali o di oggetti di valore. La comunicazione giusta per ogni contesto."
            },
            {
              title: "Risposte Professionali",
              desc: "Rispondi a tutte le recensioni direttamente da theStacc. Template per i ringraziamenti e per la gestione professionale delle critiche costruttive."
            },
            {
              title: "Report Stagionali",
              desc: "Analisi delle performance per periodo: primavera, estate, autunno, inverno. Capisci quando le recensioni convertono di più e ottimizza la tua strategia."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Tre Passi per Iniziare
        </h2>
        <p class="text-gray-600 text-center mb-12">Setup rapido, risultati automatici.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Connetti Google Business", desc: "Collega il profilo Google Business della tua impresa in pochi clic. theStacc guida tutto il processo senza bisogno di competenze tecniche." },
            { step: "2", title: "Integra il tuo sistema di gestione traslochi", desc: "Connetti il software che usi per pianificare i traslochi (o importa da Excel/CSV). Ogni trasloco completato innesca automaticamente la richiesta." },
            { step: "3", title: "Le recensioni arrivano in automatico", desc: "Da quel momento, ogni cliente soddisfatto riceve la sua richiesta personalizzata. Tu fai traslochi, la tua reputazione su Google cresce da sola." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Settore Traslochi Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che spiegano perché le recensioni decidono chi vince il lavoro.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "380K", label: "Ricerche mensili per traslochi in Italia" },
            { value: "81%", label: "legge recensioni prima di richiedere preventivo" },
            { value: "4.6×", label: "più richieste con profilo Maps ottimizzato" },
            { value: "93%", label: "chiama solo le prime 3 imprese su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Facevamo 2-3 traslochi a settimana con pochissime recensioni. In 3 mesi con theStacc siamo arrivati a 45 recensioni nuove e siamo passati al primo posto su Google Maps per "traslochi Torino". Ora riceviamo 15-20 richieste di preventivo a settimana solo da Maps.
        </blockquote>
        <div class="font-bold text-gray-900">M. Pellegrino</div>
        <div class="text-gray-600">Pellegrino Traslochi, Torino</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+45 recensioni in 3 mesi · 1° su Google Maps</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per impresa · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "SMS + Email automatici",
              "Filtro recensioni negative",
              "Dashboard analitica completa",
              "Gestione multi-area",
              "Report settimanali",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Idraulici", href: "/it/per/idraulici/" },
            { name: "Elettricisti", href: "/it/per/elettricisti/" },
            { name: "Pulizie", href: "/it/per/pulizie/" },
            { name: "Giardinieri", href: "/it/per/giardinieri/" },
            { name: "Imprenditori Edili", href: "/it/per/imprenditori-edili/" },
            { name: "Climatizzazione", href: "/it/per/climatizzazione/" },
            { name: "Coperture", href: "/it/per/coperture/" },
            { name: "Ispettori Immobiliari", href: "/it/per/ispettori-immobiliari/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia a Ricevere Più Richieste di Preventivo
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
