---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono importanti per i parrucchieri?",
    a: "L'80% delle persone sceglie il proprio parrucchiere basandosi sulle recensioni online. È un settore in cui la fiducia è fondamentale: le persone affidano il proprio aspetto a qualcuno che non conoscono. Un profilo Google con molte recensioni positive riduce questa barriera e trasforma le ricerche locali in nuovi appuntamenti."
  },
  {
    q: "Come funziona la raccolta automatica di recensioni per i parrucchieri?",
    a: "Dopo ogni appuntamento, theStacc invia automaticamente un SMS o email al cliente con un link diretto alla tua pagina Google. Il messaggio viene inviato 1-2 ore dopo il servizio — quando il cliente è ancora entusiasta del risultato e ha avuto il tempo di ammirarlo."
  },
  {
    q: "theStacc funziona anche per i saloni con più parrucchieri?",
    a: "Sì. Puoi collegare il gestionale del salone (Treatwell, Booksy, Fresha e altri) e theStacc invia automaticamente la richiesta dopo ogni appuntamento. Puoi anche tracciare le recensioni per parrucchiere, utile per capire chi genera più feedback positivi."
  },
  {
    q: "Come gestisce theStacc le recensioni negative in un salone?",
    a: "theStacc include un filtro pre-pubblicazione: i clienti insoddisfatti vengono indirizzati a un modulo di feedback privato, permettendoti di gestire la situazione con attenzione prima che diventi una recensione pubblica. Solo i clienti soddisfatti ricevono la richiesta su Google."
  },
  {
    q: "Posso chiedere recensioni anche ai clienti fedeli da anni?",
    a: "Sì. Puoi importare la lista dei tuoi clienti abituali e inviare una campagna di recupero recensioni. Spesso i clienti più fedeli sono i più felici di lasciare una testimonianza — avevano solo bisogno di un piccolo promemoria."
  },
  {
    q: "Le recensioni aiutano ad attirare anche clienti per servizi più costosi (colore, trattamenti)?",
    a: "Assolutamente. Le recensioni che menzionano servizi specifici (colorazione, trattamenti, matrimoni) aiutano i clienti a trovare il tuo salone quando cercano esattamente quel tipo di servizio. Puoi anche chiedere ai clienti di includere dettagli nel loro feedback."
  },
  {
    q: "Quanto tempo ci vuole per vedere più prenotazioni da Google?",
    a: "I saloni che usano theStacc vedono tipicamente un aumento delle prenotazioni da Google entro 60-90 giorni. Con 15-30 nuove recensioni al mese, il ranking su Maps migliora rapidamente e la visibilità nelle ricerche locali aumenta in modo significativo."
  },
  {
    q: "Qual è il costo di theStacc per un salone di parrucchieri?",
    a: "theStacc parte da $49 al mese. Include automazione illimitata, integrazione con i principali gestionali, filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Parrucchieri",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per parrucchieri e saloni. Automatizza la raccolta di recensioni dopo ogni appuntamento e aumenta la visibilità su Google Maps.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Parrucchieri", "item": "https://thestacc.com/it/per/parrucchieri/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Parrucchieri | Più Clienti con le Recensioni Google | theStacc" description="Aumenta le prenotazioni del tuo salone con le recensioni Google automatizzate. theStacc aiuta i parrucchieri a dominare Google Maps e ad attirare nuovi clienti ogni settimana." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Parrucchieri · Saloni · Barberie</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Prenotazioni per il Tuo Salone<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          850.000 italiani cercano un parrucchiere su Google ogni mese. Il salone con più stelle vince il cliente. theStacc raccoglie le tue recensioni automaticamente dopo ogni appuntamento.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">850K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">80%</div>
            <div class="text-gray-400 text-sm">cerca online prima di prenotare</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.4×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Integrazione Gestionali", "Supporto in Italiano", "GDPR Compliant", "Usato da 500+ Saloni"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Integrazione Gestionali", "Supporto in Italiano", "GDPR Compliant", "Usato da 500+ Saloni"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema dei Saloni senza Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          Hai clienti che tornano ogni mese soddisfatti. Ma Google non lo sa — e i nuovi clienti scelgono il concorrente.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Salone con Più Recensioni Prende il Nuovo Cliente</h3>
            <p class="text-gray-600">Chi si trasferisce in una nuova città o cerca un parrucchiere nuovo, guarda Google Maps. Con poche recensioni, passi inosservato — anche se i tuoi clienti abituali ti adorano.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Cliente Esce Felice — ma Non Scrive</h3>
            <p class="text-gray-600">Ama il taglio, ama il colore, dice "tornerò sempre da te". Ma tra la vita quotidiana e lo stress, la recensione viene dimenticata. Senza un sistema automatico, questa voce va persa ogni volta.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Le Giornate Intense Non Lasciano Spazio</h3>
            <p class="text-gray-600">Appuntamento dopo appuntamento, non c'è il momento giusto per pensare al marketing. Le settimane passano, le recensioni rimangono poche, la concorrenza cresce.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Recensioni per il Tuo Salone
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc raccoglie le recensioni automaticamente dopo ogni appuntamento, senza che tu debba pensarci.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Richiesta 1-2 Ore Dopo il Servizio",
              desc: "Il momento perfetto: il cliente è a casa, ammira il risultato, è entusiasta. Un SMS personalizzato con il link a Google arriva esattamente allora."
            },
            {
              title: "Integrazione con Treatwell, Booksy, Fresha",
              desc: "Si connette automaticamente al tuo gestionale appuntamenti. Ogni sessione chiusa innesca la sequenza di richiesta — zero lavoro manuale."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "I clienti insoddisfatti vengono intercettati prima che scrivano su Google. Gestisci il feedback privatamente, solo le esperienze positive diventano pubbliche."
            },
            {
              title: "Recupero Clienti Fedeli",
              desc: "Importa la lista dei clienti abituali e invia una campagna di recupero. I clienti storici sono i più propensi a lasciare recensioni entusiastiche."
            },
            {
              title: "Dashboard per Salone",
              desc: "Monitora le recensioni in tempo reale. Rispondi ai feedback direttamente dalla piattaforma. Tutto in un unico posto, senza aprire Google Business."
            },
            {
              title: "Report Settimanali",
              desc: "Ogni settimana ricevi un riepilogo delle nuove recensioni, del punteggio medio e delle richieste inviate. Dati chiari, decisioni informate."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Setup veloce, risultati immediati.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega Google Business e il gestionale del salone", desc: "Connetti il profilo Google Business e integra il software che usi per gli appuntamenti. La configurazione guidata richiede meno di 30 minuti." },
            { step: "2", title: "Personalizza i messaggi", desc: "Imposta il tono (formale o informale), l'orario di invio e il contenuto del messaggio. Puoi includere il nome del cliente per un tocco personale." },
            { step: "3", title: "Le recensioni arrivano ogni giorno", desc: "Da quel momento, ogni cliente soddisfatto riceve il suo messaggio automaticamente. Tu tagli e colori, le recensioni su Google si accumulano." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Settore Parrucchieri Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che spiegano perché le recensioni riempiono il calendario.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "850K", label: "Ricerche mensili per parrucchieri in Italia" },
            { value: "80%", label: "legge le recensioni prima di prenotare" },
            { value: "4.4×", label: "più prenotazioni con profilo Maps ottimizzato" },
            { value: "88%", label: "sceglie tra i primi 3 saloni su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Avevo 21 recensioni dopo 7 anni di salone. In 4 mesi con theStacc ne ho raccolte 93 nuove. Il calendario di novembre e dicembre è già pieno a ottobre — non era mai successo prima. Ora posso scegliere i clienti, non il contrario.
        </blockquote>
        <div class="font-bold text-gray-900">S. Russo</div>
        <div class="text-gray-600">Salone Russo, Napoli</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+93 recensioni in 4 mesi · calendario prenotato con 2 mesi di anticipo</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per salone · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "SMS + Email automatici",
              "Integrazione gestionali appuntamenti",
              "Filtro recensioni negative",
              "Recupero clienti storici",
              "Dashboard e report settimanali",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Palestre", href: "/it/per/palestre/" },
            { name: "Terapeuti", href: "/it/per/terapeuti/" },
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Servizi Animali", href: "/it/per/servizi-animali/" },
            { name: "Ristoranti", href: "/it/per/ristoranti/" },
            { name: "Fotografi", href: "/it/per/fotografi/" },
            { name: "Matrimoni", href: "/it/per/matrimoni/" },
            { name: "Veterinari", href: "/it/per/veterinari/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Riempi il Calendario di Appuntamenti
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
