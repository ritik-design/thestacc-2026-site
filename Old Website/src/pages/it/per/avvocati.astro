---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Le recensioni Google sono appropriate per uno studio legale?",
    a: "Assolutamente sì. Le recensioni Google sono oggi uno dei principali canali attraverso cui i potenziali clienti valutano uno studio legale. L'86% delle persone che cercano un avvocato online legge le recensioni prima di contattare uno studio. Una presenza solida su Google Business è essenziale per qualsiasi studio che voglia crescere."
  },
  {
    q: "theStacc rispetta le norme deontologiche forensi?",
    a: "Sì. theStacc è progettato per rispettare le linee guida deontologiche: non richiede mai testimonianze su esiti specifici di casi, non promette risultati e non viola le norme sulla pubblicità forense. Le richieste di recensione invitano i clienti a condividere la loro esperienza generale con lo studio, non valutazioni sul merito legale."
  },
  {
    q: "Come posso raccogliere più recensioni rispettando la privacy dei clienti?",
    a: "theStacc invia richieste di recensione solo ai clienti che hanno dato il consenso alla comunicazione. I messaggi sono generici e non contengono dettagli sulla natura del rapporto. Il sistema è GDPR-compliant e include gestione del consenso integrata."
  },
  {
    q: "Per quali aree del diritto theStacc è più utile?",
    a: "theStacc è particolarmente efficace per studi che lavorano con clienti privati: diritto di famiglia, diritto del lavoro, diritto del consumatore, incidenti e responsabilità civile, successioni e diritto immobiliare. In questi settori i clienti cercano attivamente online e le recensioni sono determinanti nella scelta."
  },
  {
    q: "Quanto tempo richiede la gestione della piattaforma?",
    a: "Una volta configurato, theStacc richiede meno di 30 minuti a settimana. La raccolta delle recensioni è completamente automatica. Puoi controllare la dashboard una volta a settimana per rispondere alle nuove recensioni e verificare i dati principali."
  },
  {
    q: "Come gestisce theStacc le recensioni negative?",
    a: "theStacc include un sistema di pre-filtro: i clienti che esprimono insoddisfazione vengono indirizzati a un canale di feedback privato, permettendoti di risolvere la situazione prima che diventi una recensione negativa pubblica. Solo i clienti soddisfatti ricevono la richiesta di recensione su Google."
  },
  {
    q: "Posso usare theStacc per più sedi dello studio?",
    a: "Sì. Se il tuo studio ha più uffici o sedi, puoi gestire tutte le relative pagine Google Business da un'unica dashboard. Le recensioni vengono tracciate per sede, permettendoti di monitorare le performance di ogni ufficio separatamente."
  },
  {
    q: "Qual è il costo di theStacc per uno studio legale?",
    a: "theStacc parte da $49 al mese per una sede. Il piano include automazione completa, dashboard analitica, gestione risposte, report settimanali e supporto dedicato. Puoi iniziare con 14 giorni di prova gratuita senza inserire la carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Avvocati",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per studi legali e avvocati. Aumenta la visibilità online, raccogli recensioni in modo deontologicamente corretto e attira più clienti locali.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Avvocati", "item": "https://thestacc.com/it/per/avvocati/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Avvocati | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i clienti del tuo studio legale con le recensioni Google automatizzate. theStacc aiuta gli avvocati a dominare la ricerca locale nel rispetto della deontologia forense." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Studi Legali &amp; Avvocati</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Clienti per il Tuo Studio Legale<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          96.000 italiani cercano un avvocato online ogni mese. Lo studio con più recensioni viene chiamato per primo. theStacc raccoglie le recensioni automaticamente, nel rispetto della deontologia forense.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">96K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">68%</div>
            <div class="text-gray-400 text-sm">cerca online prima di chiamare</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.3×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "GDPR Compliant", "Conforme Deontologia", "Supporto in Italiano", "Usato da 500+ Professionisti"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "GDPR Compliant", "Conforme Deontologia", "Supporto in Italiano", "Usato da 500+ Professionisti"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema degli Studi Legali Online
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          La reputazione conta da sempre nel diritto. Ma oggi si costruisce anche online — e molti studi sono indietro.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Lo Studio con Più Recensioni Viene Chiamato Prima</h3>
            <p class="text-gray-600">Su Google Maps, il ranking dipende dalle recensioni. Uno studio con 50 recensioni a 4.8 stelle appare sopra il tuo — anche se hai 20 anni di esperienza in più.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">I Clienti Soddisfatti Non Lasciano Recensioni</h3>
            <p class="text-gray-600">Un cliente felice raramente pensa da solo di lasciare una recensione. Chiederlo di persona è scomodo. Senza un sistema automatico, quella voce positiva va persa.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Le Pratiche Consumano Tutto il Tempo</h3>
            <p class="text-gray-600">Udienze, atti, clienti da gestire: non c'è spazio per pensare al marketing. Le recensioni restano zero e i nuovi clienti vanno alla concorrenza.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Costruisci la Tua Reputazione Online in Automatico
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc fa il lavoro di raccolta recensioni al posto tuo, nel rispetto della professione.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Richieste Post-Chiusura Pratica",
              desc: "Quando una pratica si conclude, il cliente riceve automaticamente un messaggio personalizzato con link diretto alla tua pagina Google. Nessun imbarazzo, nessuno sforzo."
            },
            {
              title: "Conforme alle Norme Forensi",
              desc: "Le richieste non citano esiti specifici e rispettano le linee guida deontologiche sull'advertising. Solo esperienza generale, mai valutazioni su risultati."
            },
            {
              title: "Gestione Feedback Negativo",
              desc: "I clienti insoddisfatti vengono intercettati prima che pubblichino. Un canale privato ti permette di risolvere il problema. Solo i soddisfatti arrivano su Google."
            },
            {
              title: "Dashboard per Più Sedi",
              desc: "Se hai più uffici, gestisci tutti i profili Google Business da un unico pannello. Dati separati per sede, un'unica interfaccia."
            },
            {
              title: "Risposte Professionali",
              desc: "Template di risposta pre-approvati per ringraziare i clienti che lasciano recensioni. Ogni risposta è professionale e personalizzabile."
            },
            {
              title: "Report Settimanali",
              desc: "Ogni settimana ricevi un riepilogo: nuove recensioni, punteggio medio, tasso di conversione. Dati utili senza complessità."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Operativo in Meno di un'Ora
        </h2>
        <p class="text-gray-600 text-center mb-12">Tre passi per iniziare a raccogliere recensioni.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega il tuo Google Business", desc: "Connetti il profilo Google Business dello studio in pochi clic. theStacc guida tutto il processo — nessuna competenza tecnica richiesta." },
            { step: "2", title: "Configura i messaggi e i trigger", desc: "Decidi quando inviare le richieste (chiusura pratica, pagamento ricevuto, etc.) e personalizza il messaggio con il nome dello studio." },
            { step: "3", title: "Le recensioni arrivano in automatico", desc: "Da quel momento, ogni cliente soddisfatto riceve la sua richiesta al momento giusto. Tu gestisci le pratiche, la piattaforma costruisce la tua reputazione." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          La Ricerca Legale Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I dati che ogni avvocato dovrebbe conoscere.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "96K", label: "Ricerche mensili per avvocati in Italia" },
            { value: "68%", label: "dei clienti cerca online prima di chiamare" },
            { value: "4.3×", label: "più contatti con profilo Maps ottimizzato" },
            { value: "86%", label: "legge le recensioni prima di scegliere lo studio" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Non pensavo che le recensioni Google potessero fare differenza per uno studio legale. In 5 mesi siamo passati da 8 a 54 recensioni e il traffico al sito è aumentato del 65%. Ora riceviamo mediamente 6 richieste di consulenza a settimana che vengono direttamente da Google Maps.
        </blockquote>
        <div class="font-bold text-gray-900">Avv. S. De Luca</div>
        <div class="text-gray-600">Studio Legale De Luca, Roma</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+46 recensioni in 5 mesi · +65% traffico sito</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per studio · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "SMS + Email automatici",
              "Filtro recensioni negative",
              "Dashboard analitica completa",
              "Gestione multi-sede",
              "Conforme deontologia forense",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Consulenti Finanziari", href: "/it/per/consulenti-finanziari/" },
            { name: "Commercialisti", href: "/it/per/commercialisti/" },
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Medici", href: "/it/per/medici/" },
            { name: "Terapeuti", href: "/it/per/terapeuti/" },
            { name: "Chiropratici", href: "/it/per/chiropratici/" },
            { name: "Assicurazioni", href: "/it/per/assicurazioni/" },
            { name: "Immobiliare", href: "/it/per/immobiliare/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia a Ricevere Più Clienti Oggi
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
