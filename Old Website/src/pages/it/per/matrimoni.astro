---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono importanti per i wedding planner e i fornitori di matrimoni?",
    a: "L'87% delle coppie cerca online i fornitori per il matrimonio, e le recensioni Google sono il principale fattore di fiducia nella scelta. Per un evento così importante e unico nella vita, le coppie leggono molte recensioni prima di prendere qualsiasi decisione. Un profilo con molte recensioni entusiastiche è spesso la differenza tra essere contattati o no."
  },
  {
    q: "Come funziona la raccolta automatica di recensioni nel settore matrimoni?",
    a: "theStacc invia automaticamente un messaggio agli sposi nei giorni successivi al matrimonio — quando l'emozione è ancora alta e vogliono condividere la loro esperienza. Il messaggio è personalizzato con i loro nomi e include un link diretto alla tua pagina Google, rendendo semplicissimo lasciare una recensione."
  },
  {
    q: "Quando è il momento migliore per chiedere una recensione agli sposi?",
    a: "Il momento ideale è 3-7 giorni dopo il matrimonio. Gli sposi sono appena tornati dal viaggio di nozze o stanno ancora rivivendo i ricordi. theStacc ti permette di configurare il timing esatto — abbastanza vicino da mantenere l'emozione, abbastanza lontano da non sembrare precipitosi."
  },
  {
    q: "theStacc funziona per diversi tipi di fornitori matrimoniali (location, fotografi, fioristi, catering)?",
    a: "Sì. theStacc è adatto per qualsiasi fornitore nel settore matrimoniale: location, fotografi, fioristi, catering, wedding planner, musicisti, animatori. Ogni tipo di fornitore può personalizzare i messaggi in base al proprio servizio."
  },
  {
    q: "Come gestisce theStacc le recensioni negative nel settore matrimoni?",
    a: "Un'esperienza negativa il giorno più importante della vita genera recensioni molto forti. theStacc intercetta i clienti insoddisfatti prima della pubblicazione e li indirizza a un canale privato. Puoi affrontare il problema con professionalità prima che diventi pubblica, proteggendo la tua reputazione."
  },
  {
    q: "Le recensioni aiutano anche per i matrimoni fuori stagione o infrasettimanali?",
    a: "Assolutamente. Raccogliere recensioni costantemente tutto l'anno — non solo in alta stagione (giugno-settembre) — mantiene il tuo profilo Google aggiornato e ti aiuta a posizionarti per le ricerche dei mesi fuori stagione, quando i budget sono spesso più elevati."
  },
  {
    q: "Posso raccogliere recensioni anche per i preview e gli engagement?",
    a: "Sì. Per i fotografi e i videografi, puoi inviare richieste dopo il servizio di engagement photography o dopo la consegna delle foto. Per i wedding planner, dopo ogni riunione di pianificazione importante. theStacc si adatta a ogni touchpoint del percorso matrimoniale."
  },
  {
    q: "Qual è il costo di theStacc per i fornitori di matrimoni?",
    a: "theStacc parte da $49 al mese. Include automazione completa, messaggi personalizzati per gli sposi, filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Matrimoni",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per wedding planner, location e fornitori matrimoniali. Automatizza la raccolta di recensioni dopo ogni matrimonio.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Matrimoni", "item": "https://thestacc.com/it/per/matrimoni/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Matrimoni | Più Coppie con le Recensioni Google | theStacc" description="Aumenta le prenotazioni per il tuo servizio matrimoniale con le recensioni Google automatizzate. theStacc aiuta wedding planner, location e fotografi a dominare la ricerca locale." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Wedding Planner · Location · Fotografi · Catering</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Prenotazioni per il Tuo Servizio Matrimoniale<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          290.000 coppie cercano fornitori matrimoniali online ogni mese. Le recensioni decidono chi viene contattato. theStacc raccoglie le tue recensioni automaticamente, catturando il momento di massima emozione degli sposi.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">290K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">87%</div>
            <div class="text-gray-400 text-sm">cerca online prima di scegliere</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.4×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Timing Post-Matrimonio", "Messaggi Personalizzati", "Supporto in Italiano", "GDPR Compliant"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Timing Post-Matrimonio", "Messaggi Personalizzati", "Supporto in Italiano", "GDPR Compliant"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          La Sfida dei Fornitori Matrimoniali Online
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          Un matrimonio straordinario genera entusiasmo enorme. Catturarlo in una recensione richiede un sistema.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Chi ha Più Recensioni Viene Contattato Prima</h3>
            <p class="text-gray-600">Le coppie consultano Google Maps per trovare location, fotografi e wedding planner. Con poche recensioni, sembri meno credibile — indipendentemente dalla qualità del tuo lavoro.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">L'Entusiasmo Post-Matrimonio Dura Poco</h3>
            <p class="text-gray-600">Gli sposi sono euforici il giorno dopo il matrimonio. Ma tra viaggio di nozze, ritorno alla realtà e nuova vita insieme, la recensione promessa non viene mai scritta senza un promemoria al momento giusto.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">La Stagione Alta non Lascia Tempo</h3>
            <p class="text-gray-600">Da maggio a settembre hai matrimoni ogni weekend. Non c'è un secondo per inseguire recensioni manualmente. E proprio quando fai il lavoro migliore, non capitalizzi in visibilità online.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Recensioni per il Settore Matrimoniale
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc cattura l'emozione degli sposi nel momento perfetto — e la trasforma in una recensione su Google.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Timing Ottimale Post-Matrimonio",
              desc: "Configura la richiesta per 3-7 giorni dopo il matrimonio. L'emozione è ancora alta, il viaggio di nozze è appena finito — il momento perfetto per una recensione entusiasta."
            },
            {
              title: "Messaggi Personalizzati per gli Sposi",
              desc: "I messaggi includono i nomi degli sposi e fanno riferimento al giorno del loro matrimonio. Questa personalizzazione emotiva aumenta enormemente il tasso di risposta."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "Le esperienze negative il giorno del matrimonio sono particolarmente delicate. theStacc intercetta il feedback negativo prima della pubblicazione per una gestione professionale."
            },
            {
              title: "Adatto a Tutti i Fornitori",
              desc: "Wedding planner, location, fotografi, videografi, fioristi, catering, musicisti. Ogni fornitore ha il suo template personalizzato."
            },
            {
              title: "Raccolta Fuori Stagione",
              desc: "Mantieni una frequenza di recensioni costante anche fuori dalla stagione matrimoniale. Google premia i profili che ricevono recensioni regolarmente durante l'anno."
            },
            {
              title: "Dashboard e Report",
              desc: "Monitora le recensioni, rispondi ai feedback e traccia la crescita del tuo punteggio su Google nel tempo. Tutto in una piattaforma semplice e intuitiva."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Tre passi per trasformare ogni matrimonio in una recensione su Google.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega Google Business", desc: "Connetti il profilo Google Business del tuo servizio in pochi clic. Il setup guidato richiede meno di 20 minuti." },
            { step: "2", title: "Configura il timing e i messaggi per gli sposi", desc: "Imposta quando inviare la richiesta (3-7 giorni dopo il matrimonio) e personalizza il messaggio con i nomi degli sposi." },
            { step: "3", title: "Le recensioni arrivano automaticamente", desc: "Da quel momento, ogni matrimonio genera automaticamente una richiesta al momento giusto. Tu crei momenti indimenticabili, le recensioni si accumulano su Google." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Settore Matrimoniale Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che ogni fornitore matrimoniale dovrebbe conoscere.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "290K", label: "Ricerche mensili per fornitori matrimoniali" },
            { value: "87%", label: "delle coppie cerca online prima di scegliere" },
            { value: "4.4×", label: "più contatti con profilo Maps ottimizzato" },
            { value: "92%", label: "legge almeno 10 recensioni prima di contattare" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Organizzavo 30 matrimoni all'anno con solo 17 recensioni su Google. Con theStacc in 8 mesi ho raccolto 62 nuove recensioni e sono diventata la prima wedding planner su Google Maps per la mia provincia. Il calendario del prossimo anno è già quasi pieno.
        </blockquote>
        <div class="font-bold text-gray-900">A. Caruso</div>
        <div class="text-gray-600">Caruso Wedding Events, Lecce</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+62 recensioni in 8 mesi · calendario quasi pieno per il prossimo anno</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per fornitore · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "Messaggi personalizzati per gli sposi",
              "Timing ottimale post-matrimonio",
              "Filtro recensioni negative",
              "Raccolta fuori stagione",
              "Dashboard e report",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Fotografi", href: "/it/per/fotografi/" },
            { name: "Ristoranti", href: "/it/per/ristoranti/" },
            { name: "Parrucchieri", href: "/it/per/parrucchieri/" },
            { name: "Terapeuti", href: "/it/per/terapeuti/" },
            { name: "Palestre", href: "/it/per/palestre/" },
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Servizi Animali", href: "/it/per/servizi-animali/" },
            { name: "Ripetizioni", href: "/it/per/ripetizioni/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Riempi il Calendario della Stagione Matrimoniale
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
