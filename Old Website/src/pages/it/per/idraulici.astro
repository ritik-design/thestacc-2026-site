---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono importanti per gli idraulici?",
    a: "Gli idraulici vengono cercati spesso in situazioni di emergenza — una perdita d'acqua, un tubo rotto, un guasto urgente. In quei momenti, il cliente chiama il primo idraulico con buone recensioni che trova su Google Maps. Un profilo ben curato con molte recensioni positive è la differenza tra ricevere la chiamata o perderla."
  },
  {
    q: "Come funziona la raccolta automatica di recensioni per gli idraulici?",
    a: "Dopo ogni intervento completato, theStacc invia automaticamente un SMS al cliente con un link diretto alla tua pagina Google. L'SMS è personalizzato con il nome del cliente e il tipo di intervento, e viene inviato nel momento ottimale — qualche ora dopo la fine del lavoro quando la soddisfazione è ancora alta."
  },
  {
    q: "theStacc funziona anche per gli interventi di emergenza?",
    a: "Sì. Puoi impostare un ritardo personalizzato per le richieste di recensione. Per gli interventi di emergenza, spesso il momento migliore è il giorno successivo — quando il cliente è già tranquillo e vuole esprimere gratitudine per la rapidità dell'intervento."
  },
  {
    q: "Come gestisce theStacc le recensioni negative nel settore idraulico?",
    a: "theStacc include un sistema di pre-filtro: prima di inviare la richiesta pubblica, identifica i clienti insoddisfatti e li indirizza a un canale privato. Puoi gestire il problema prima che diventi una recensione negativa su Google."
  },
  {
    q: "Posso usare theStacc se lavoro sia per privati che per condomini?",
    a: "Sì. Puoi configurare messaggi diversi per clienti privati e amministratori di condominio. Per i condomini, la richiesta può essere indirizzata all'amministratore con un tono più formale e professionale."
  },
  {
    q: "Le recensioni aiutano anche per lavori di manutenzione programmata?",
    a: "Assolutamente. Oltre agli interventi di emergenza, molti idraulici hanno clienti con contratti di manutenzione. Raccogliere recensioni dopo ogni visita di manutenzione costruisce una reputazione solida che attira nuovi clienti sia per emergenze che per lavori programmati."
  },
  {
    q: "Quanto velocemente migliorerà il mio ranking su Google Maps?",
    a: "La maggior parte degli idraulici vede un miglioramento nel ranking Google Maps tra i 45 e i 90 giorni dall'attivazione. Con 10-15 nuove recensioni al mese, il tuo profilo sale rapidamente perché Google premia sia la quantità che la freschezza delle recensioni."
  },
  {
    q: "Quanto costa theStacc per un idraulico?",
    a: "theStacc parte da $49 al mese. Include automazione illimitata, SMS ed email, filtro recensioni negative, dashboard analitica e supporto in italiano. Puoi iniziare con 14 giorni di prova gratuita senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Idraulici",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per idraulici. Automatizza la raccolta di recensioni dopo ogni intervento e aumenta la visibilità nelle ricerche locali di emergenza.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Idraulici", "item": "https://thestacc.com/it/per/idraulici/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Idraulici | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i clienti della tua impresa idraulica con le recensioni Google automatizzate. theStacc raccoglie recensioni dopo ogni intervento e ti porta in cima a Google Maps." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Idraulici &amp; Impianti Idraulici</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Chiamate per il Tuo Servizio Idraulico<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          450.000 italiani cercano un idraulico ogni mese, spesso in emergenza. Chi è in cima a Google Maps riceve la chiamata. theStacc costruisce quella reputazione automaticamente, intervento dopo intervento.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">450K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">72%</div>
            <div class="text-gray-400 text-sm">cerca online prima di chiamare</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.6×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Imprese"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Imprese"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema degli Idraulici senza Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          In emergenza, il cliente chiama chi trova subito e di cui si fida. Senza recensioni, non sei tu.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">In Emergenza Vince Chi è in Cima a Maps</h3>
            <p class="text-gray-600">Con un tubo che perde, nessuno fa lunghe ricerche. Il cliente chiama il primo idraulico con stelle sufficienti. Se non sei in cima, non esisti nel momento che conta di più.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Dopo l'Intervento, il Cliente Dimentica</h3>
            <p class="text-gray-600">Il cliente è grato quando risolvi il problema, ma appena l'urgenza finisce, anche la gratitudine svanisce. Senza un messaggio automatico nelle ore giuste, la recensione non arriverà mai.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Passaparola Non Basta Più</h3>
            <p class="text-gray-600">Una volta bastava essere conosciuti nel quartiere. Oggi il 72% degli italiani cerca l'idraulico online prima di chiamare. Il passaparola rimane importante, ma le recensioni Google moltiplicano la sua portata.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Recensioni per Idraulici
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc lavora in background mentre tu fai interventi. Ogni cliente soddisfatto diventa una recensione.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "SMS Automatico Post-Intervento",
              desc: "Dopo ogni lavoro, il cliente riceve un SMS con link diretto a Google. Timing ottimizzato per emergenze e lavori programmati — sempre al momento giusto."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "I clienti insoddisfatti vengono intercettati prima della pubblicazione. Gestisci il problema privatamente, solo i soddisfatti arrivano su Google."
            },
            {
              title: "Profili per Tipo di Servizio",
              desc: "Messaggi diversi per emergenze, manutenzione, installazioni e ristrutturazioni. La comunicazione contestualizzata aumenta il tasso di risposta."
            },
            {
              title: "Dashboard Centralizzata",
              desc: "Tutte le tue recensioni in un posto. Monitora il punteggio, la frequenza e i trend senza aprire Google Business ogni giorno."
            },
            {
              title: "Gestione Clienti Condominio",
              desc: "Messaggi personalizzati per amministratori di condominio e gestori immobiliari. Costruisci relazioni professionali durature."
            },
            {
              title: "Report Settimanali",
              desc: "Ogni settimana un riepilogo: nuove recensioni, punteggio, richieste inviate. Dati chiari per capire l'andamento della tua reputazione."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Tre passi per iniziare a raccogliere recensioni automaticamente.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega Google Business", desc: "Connetti il tuo profilo Google Business in pochi clic. Nessuna competenza tecnica necessaria — la piattaforma guida ogni passaggio." },
            { step: "2", title: "Importa i clienti o integra il calendario", desc: "Carica la lista dei tuoi interventi o connetti il software di gestione. theStacc sa quando un lavoro si conclude e quando inviare la richiesta." },
            { step: "3", title: "Le recensioni arrivano in automatico", desc: "Da quel momento, ogni cliente soddisfatto riceve la sua richiesta. Tu fai interventi, la tua reputazione su Google cresce giorno dopo giorno." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Mercato degli Idraulici Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che spiegano perché investire nella reputazione online.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "450K", label: "Ricerche mensili per idraulici in Italia" },
            { value: "72%", label: "cerca online prima di chiamare" },
            { value: "4.6×", label: "più chiamate con profilo Maps ottimizzato" },
            { value: "94%", label: "chiama solo il primo idraulico su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Lavoravo solo di passaparola. Poi ho capito che le emergenze idrauliche vanno su Google. Con theStacc ho raccolto 52 recensioni in 4 mesi, sono salito al primo posto su Maps per la mia zona e adesso devo rifiutare lavori perché ho troppo da fare.
        </blockquote>
        <div class="font-bold text-gray-900">A. Ferrara</div>
        <div class="text-gray-600">Ferrara Idraulica, Palermo</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+52 recensioni in 4 mesi · primo su Google Maps</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per impresa · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "SMS automatici post-intervento",
              "Richieste email illimitate",
              "Filtro recensioni negative",
              "Dashboard analitica completa",
              "Profili per tipo di servizio",
              "Report settimanali",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Elettricisti", href: "/it/per/elettricisti/" },
            { name: "Imprenditori Edili", href: "/it/per/imprenditori-edili/" },
            { name: "Giardinieri", href: "/it/per/giardinieri/" },
            { name: "Pulizie", href: "/it/per/pulizie/" },
            { name: "Climatizzazione", href: "/it/per/climatizzazione/" },
            { name: "Traslochi", href: "/it/per/traslochi/" },
            { name: "Coperture", href: "/it/per/coperture/" },
            { name: "Ispettori Immobiliari", href: "/it/per/ispettori-immobiliari/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia a Ricevere Più Chiamate Oggi
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
