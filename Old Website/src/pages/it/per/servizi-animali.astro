---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono importanti per i servizi per animali?",
    a: "I proprietari di animali domestici sono tra i consumatori più attenti e selettivi. L'80% legge le recensioni online prima di scegliere un toelettatore, un addestratore o un pensionato per cani. Una presenza forte su Google Maps è essenziale per qualsiasi attività nel settore pet."
  },
  {
    q: "Come funziona la raccolta automatica di recensioni di theStacc per i servizi pet?",
    a: "Dopo ogni sessione di toelettatura, addestramento, pensione o visita veterinaria, theStacc invia automaticamente un SMS o email al proprietario dell'animale con un link diretto alla tua pagina Google. Il messaggio è personalizzato con il nome del cliente e del suo animale, per un'esperienza più personale."
  },
  {
    q: "theStacc funziona anche per le pensioni per cani e gatti?",
    a: "Sì. Per le pensioni, theStacc invia la richiesta di recensione quando il cliente viene a riprendere il suo animale — il momento di massima soddisfazione. Puoi anche programmare un follow-up 2-3 giorni dopo per catturare i clienti che non rispondono subito."
  },
  {
    q: "Come gestisco le recensioni negative nel settore animali?",
    a: "Il settore animali è emotivamente molto coinvolto — un'esperienza negativa con il proprio pet genera reazioni forti. theStacc intercetta i clienti insoddisfatti prima della pubblicazione e li indirizza a un canale privato, permettendoti di gestire la situazione con attenzione prima che diventi una recensione pubblica."
  },
  {
    q: "Posso usare theStacc se offro più servizi (toelettatura + addestramento + pensione)?",
    a: "Assolutamente. theStacc ti permette di configurare messaggi diversi per ogni tipo di servizio offerto. La richiesta è contestualizzata al servizio fruito, rendendo la comunicazione più rilevante e aumentando il tasso di risposta."
  },
  {
    q: "Le recensioni Google aiutano anche per i servizi locali di dog sitting?",
    a: "Sì. I dog sitter e i servizi di passeggiate cani operano in aree geografiche ristrette, dove il ranking locale su Google Maps è determinante. Con 20-30 recensioni positive, puoi dominare la ricerca nella tua zona e avere sempre clienti in lista d'attesa."
  },
  {
    q: "Quanto tempo ci vuole per vedere i primi risultati?",
    a: "La maggior parte dei servizi per animali che usano theStacc vede le prime nuove recensioni entro la prima settimana di attivazione. Un miglioramento significativo nel ranking Google Maps si osserva tipicamente tra i 60 e i 90 giorni con raccolta costante."
  },
  {
    q: "Qual è il costo di theStacc per un servizio per animali?",
    a: "theStacc parte da $49 al mese. Il piano include automazione illimitata, SMS ed email, filtro recensioni negative, dashboard analitica e supporto in italiano. Puoi iniziare con 14 giorni di prova gratuita senza inserire la carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Servizi per Animali",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per toelettatori, addestratori, pensioni e servizi pet. Automatizza le recensioni e aumenta la visibilità locale.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Servizi per Animali", "item": "https://thestacc.com/it/per/servizi-animali/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Servizi per Animali | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i clienti del tuo servizio per animali con le recensioni Google automatizzate. theStacc aiuta toelettatori, addestratori e pensioni a dominare la ricerca locale." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Toelettatori · Addestratori · Pensioni · Pet Services</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Clienti per il Tuo Servizio per Animali<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          620.000 italiani cercano servizi per animali ogni mese. I proprietari di pet scelgono solo chi si fida. theStacc raccoglie le recensioni automaticamente dopo ogni servizio.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">620K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">80%</div>
            <div class="text-gray-400 text-sm">cerca online prima di scegliere</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.5×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Attività"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Attività"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema dei Servizi Pet senza Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          I proprietari di animali cercano qualcuno di cui fidarsi completamente. Senza recensioni, quella fiducia non si costruisce.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">La Fiducia Vale Tutto nel Settore Pet</h3>
            <p class="text-gray-600">Un proprietario di cane non affida il suo animale a chi non conosce senza prima leggere le recensioni. Con poche recensioni, perdi clienti prima ancora di parlarci.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">I Clienti Felici Non Pensano alle Recensioni</h3>
            <p class="text-gray-600">Il cliente torna a casa con il suo cane bello e pulito. È soddisfattissimo. Ma tra la vita quotidiana, la recensione viene dimenticata. Senza un promemoria automatico, quella voce va persa.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">I Nuovi Pet Store ti Sorpassano</h3>
            <p class="text-gray-600">Un toelettatore aperto da pochi mesi con 60 recensioni appare prima di te su Google Maps — anche se hai anni di esperienza e clienti fidelizzati. L'algoritmo premia chi raccoglie recensioni regolarmente.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          La Soluzione Completa per il Settore Pet
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc automatizza la raccolta delle recensioni per ogni tipo di servizio per animali.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Richieste Personalizzate per Tipo di Servizio",
              desc: "Messaggi diversi per toelettatura, addestramento, pensione e dog sitting. Il nome dell'animale nel messaggio aumenta il tasso di risposta del 40%."
            },
            {
              title: "Timing Perfetto per le Pensioni",
              desc: "Per le pensioni, la richiesta parte quando il cliente ritira il suo animale — il momento di massima soddisfazione e gratitudine."
            },
            {
              title: "Gestione Feedback Sensibile",
              desc: "Nel settore pet le emozioni sono forti. I clienti insoddisfatti vengono intercettati prima della pubblicazione per una gestione privata e attenta."
            },
            {
              title: "Dashboard Centralizzata",
              desc: "Tutte le tue recensioni in un unico posto. Monitora il punteggio, la frequenza e i trend senza dover aprire Google Business ogni giorno."
            },
            {
              title: "Risposte alle Recensioni",
              desc: "Rispondi a ogni recensione direttamente da theStacc. I proprietari apprezzano le risposte personalizzate — e Google le premia nel ranking."
            },
            {
              title: "Report Mensili",
              desc: "Un riepilogo mensile delle performance: nuove recensioni, punteggio medio, confronto con il mese precedente. Dati chiari per decisioni informate."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Tre passi e il tuo sistema di recensioni è attivo.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega il tuo Google Business", desc: "Connetti il profilo della tua attività in pochi clic. theStacc guida tutto il processo — nessuna competenza tecnica necessaria." },
            { step: "2", title: "Configura i tuoi servizi e i messaggi", desc: "Indica i tipi di servizi che offri e personalizza i messaggi per ognuno. Puoi includere il nome dell'animale per un tocco personale." },
            { step: "3", title: "Le recensioni crescono in automatico", desc: "Da quel momento, ogni cliente soddisfatto riceve la sua richiesta personalizzata al momento giusto. Tu curi gli animali, le recensioni si accumulano." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Settore Pet Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che spiegano perché le recensioni sono decisive.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "620K", label: "Ricerche mensili per servizi pet in Italia" },
            { value: "80%", label: "legge le recensioni prima di scegliere" },
            { value: "4.5×", label: "più prenotazioni con profilo Maps ottimizzato" },
            { value: "89%", label: "sceglie tra i primi 3 risultati su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Avevo 18 recensioni dopo 3 anni di attività. Con theStacc in 5 mesi ne ho raccolte 84 nuove. Adesso sono il primo toelettatore su Google Maps per tutta la mia zona e ho sempre una lista d'attesa di 2 settimane.
        </blockquote>
        <div class="font-bold text-gray-900">V. Lombardi</div>
        <div class="text-gray-600">Toelettatura Lombardi, Genova</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+84 recensioni in 5 mesi · lista d'attesa 2 settimane</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per attività · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "SMS + Email automatici",
              "Personalizzazione per tipo servizio",
              "Filtro recensioni negative",
              "Dashboard analitica completa",
              "Risposte semplificate",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Veterinari", href: "/it/per/veterinari/" },
            { name: "Parrucchieri", href: "/it/per/parrucchieri/" },
            { name: "Palestre", href: "/it/per/palestre/" },
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Medici", href: "/it/per/medici/" },
            { name: "Terapeuti", href: "/it/per/terapeuti/" },
            { name: "Ristoranti", href: "/it/per/ristoranti/" },
            { name: "Fotografi", href: "/it/per/fotografi/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia a Ricevere Più Prenotazioni Oggi
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
