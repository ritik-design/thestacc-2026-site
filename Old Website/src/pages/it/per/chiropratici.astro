---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  { q: "Quanto tempo ci vuole prima che il mio studio chiropratico salga su Google Maps?", a: "La maggior parte degli studi chiropratici vede movimenti significativi su Maps entro 60–90 giorni di attività GBP costante. L'algoritmo di Google premia frequenza, rilevanza e coinvolgimento — tutte e tre fornite automaticamente da Stacc ogni mese. Gli studi che non pubblicavano nulla in precedenza tendono a vedere i risultati più rapidamente." },
  { q: "Quali parole chiave usa Stacc per i chiropratici?", a: "Stacc punta alle combinazioni servizio + città — come 'chiropratico vicino a me,' 'chiropratico [città],' 'terapia chiropratica [città],' 'mal di schiena [città],' 'aggiustamento vertebrale [città].' Punta anche a termini basati sull'intento come 'chiropratico per dolore cervicale' e 'trattamento ernia del disco.' Tutte le parole chiave sono calibrate sul tuo tipo di studio e sulla tua posizione." },
  { q: "Il mio studio ha già un Google Business Profile. Devo configurarlo da zero?", a: "Basta collegarlo. Stacc recupera i tuoi dati GBP esistenti — nome, servizi, foto, storico recensioni e posizionamento attuale — e costruisce un piano di contenuti. Il setup richiede meno di cinque minuti. Dopodiché Stacc gestisce tutto automaticamente." },
  { q: "Cosa succede quando ricevo una recensione negativa?", a: "Stacc invia un avviso immediato nel momento in cui compare una nuova recensione. Ricevi il testo, il punteggio e un modello di risposta per rispondere in meno di un minuto. Rispondere rapidamente alle recensioni negative è una delle azioni ad alto ROI più importanti che uno studio chiropratico possa fare — segnala a ogni futuro paziente che prendi sul serio la loro esperienza." },
  { q: "Pubblicare su GBP aiuta davvero uno studio chiropratico a posizionarsi?", a: "Sì. L'algoritmo Maps considera la frequenza di pubblicazione, la reattività alle recensioni e la rilevanza delle parole chiave. Ogni giorno che sei inattivo, un concorrente che pubblica regolarmente guadagna terreno. Stacc pubblica 30 volte al mese affinché il tuo profilo non sia mai silenzioso." },
  { q: "Lavorate con studi chiropratici multi-sede?", a: "Sì. Ogni sede riceve la propria strategia di parole chiave, calendario dei contenuti, calendario GBP e report di posizionamento — tutto da un unico dashboard. Puoi vedere le prestazioni di ogni sede fianco a fianco e identificare quali necessitano più attenzione." },
  { q: "In cosa si distingue Stacc da un'agenzia di marketing per chiropratici?", a: "Un'agenzia di marketing scrive manualmente i tuoi post GBP, addebita 800–2.000$/mese e richiede contratti lunghi. Stacc automatizza ogni parte di quel processo per 49$/mese. La maggior parte degli studi chiropratici che prova Stacc aveva precedentemente pagato un'agenzia 15–40 volte di più per meno volume." },
  { q: "Stacc aiuta con i contenuti del blog o solo con il GBP?", a: "Il modulo Local SEO di Stacc gestisce post GBP, monitoraggio recensioni e rank tracking. Se vuoi contenuti blog chiropratici pubblicati ogni mese — del tipo che si posiziona per 'chiropratico per mal di schiena' e 'quanto dura una seduta chiropratica' — è il modulo Blog SEO a 99$/mese. Molti studi usano entrambi insieme." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc per Chiropratici", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "it", "description": "Stacc pubblica ogni giorno sul GBP del tuo studio chiropratico, gestisce le recensioni e monitora il posizionamento su Maps — automaticamente. Più pazienti da Google a 49$/mese.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" }, { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" }, { "@type": "ListItem", "position": 3, "name": "Chiropratici", "item": "https://thestacc.com/it/per/chiropratici/" } ] },
    { "@type": "FAQPage", "inLanguage": "it", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout title="SEO per Chiropratici | Più Pazienti da Google | theStacc" description="Stacc pubblica ogni giorno sul GBP del tuo studio chiropratico, gestisce le recensioni e monitora il posizionamento su Maps — automaticamente. Più pazienti da Google a 49$/mese." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO per Chiropratici · Powered by Stacc</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Più pazienti da Google.<br /><span style="color:#4f39f6;">Senza pagare per ogni clic.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            720.000 persone cercano "chiropratico vicino a me" ogni mese. Il 74% di loro cerca online prima di chiamare. Stacc fa sì che il tuo studio compaia per primo — pubblicando sul tuo Google Business Profile ogni giorno, gestendo le tue recensioni e monitorando il tuo posizionamento su Maps. Tutto automaticamente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">Inizia per 1$ oggi<svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="#come-funziona" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">Scopri come funziona</a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Rimborso 30 giorni · Nessun contratto · Pubblica sul tuo GBP ogni giorno</p>
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '720K', num: 720, prefix: '', suffix: 'K', decimals: 0, from: 0, label: 'Ricerche mensili "chiropratico vicino a me"' },
              { value: '74%', num: 74, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Pazienti cercano online prima di chiamare' },
              { value: '4.7×', num: 4.7, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Aumento medio del posizionamento Maps' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Recensioni catturate istantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]" data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Studi chiropratici posizionati con Stacc</p>
          <div class="flex items-center gap-1.5"><div class="flex">{[1,2,3,4,5].map(() => (<svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>))}</div><span class="font-mono text-[11px] text-[#6b7280]">4.9 da 127 recensioni</span></div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Centro Chiropratico Rossi — Milano', 'Studio Chiro Bianchi — Roma', 'Chiropratico Verdi — Torino', 'Centro Spinale Ferrari — Bologna', 'Clinica Chiro Marino — Napoli', 'Studio Esposito Chiro — Firenze', 'Chiropratico Romano — Genova', 'Centro Chiropratico Rossi — Milano', 'Studio Chiro Bianchi — Roma', 'Chiropratico Verdi — Torino', 'Centro Spinale Ferrari — Bologna', 'Clinica Chiro Marino — Napoli', 'Studio Esposito Chiro — Firenze', 'Chiropratico Romano — Genova'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8"><div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg></div><span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Pazienti cercano un chiropratico adesso.<br />Stanno prenotando con qualcun altro.</h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Il 74% dei pazienti cerca online prima di chiamare uno studio chiropratico. La posizione su Maps determina quale studio chiamano per primo — e spesso è l'unico che chiamano.</p>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Il tuo GBP non viene aggiornato da mesi — mentre i pazienti scelgono adesso.', body: 'I pazienti valutano gli studi chiropratici in base all\'attività recente del profilo GBP. Un profilo con post settimanali sui servizi, foto aggiornate e risposte attive alle recensioni appare più affidabile. Uno studio silenzioso perde contro uno attivo — anche se la qualità clinica è superiore.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Una recensione negativa senza risposta ti costa nuovi pazienti ogni settimana.', body: 'Il 74% dei pazienti controlla le recensioni prima di scegliere un chiropratico. Una recensione su trattamenti dolorosi o aspettative non soddisfatte senza risposta è visibile a ogni potenziale paziente. Nel settore della salute, la fiducia è tutto — ogni segnale conta.' },
            { icon: 'M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z M12 9v4 M12 17h.01', title: 'Ti posizioni per il nome del tuo studio. Non per "chiropratico vicino a me".', body: 'I nuovi pazienti non cercano il nome del tuo studio — cercano "chiropratico vicino a me," "mal di schiena [città]" e "aggiustamento vertebrale [città]." Se non sei nella Map Pack per queste parole chiave, i tuoi appuntamenti rimangono vuoti mentre il concorrente è al completo.' },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg></div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa fa Stacc per i chiropratici</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Ogni leva che porta nuovi pazienti da Google. Gestita.</h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Pubblicazione Post GBP', body: '30 post al mese — consigli sul mal di schiena, aggiornamenti sui trattamenti, promozioni stagionali e informazioni sulle tecniche chiropratiche. Pubblicati automaticamente ogni mese.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Targeting Parole Chiave Chiropratiche', body: 'Combinazioni servizio + città — chiropratico, aggiustamento vertebrale, mal di schiena, cervicale, ernia del disco, sciatica. Calibrate sul tuo tipo di studio e sulla tua posizione.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
            { title: 'Monitoraggio Recensioni', body: 'Avvisi istantanei per ogni nuova recensione. Punteggio stelle tracciato nel tempo. Modelli di risposta per rispondere professionalmente in meno di un minuto.', icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' },
            { title: 'Rank Tracking Locale', body: 'Report di posizionamento Maps basati su griglia per ogni parola chiave chiropratica nella tua area. Monitoraggio mese su mese per vedere come si muovono i tuoi posizionamenti.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Gestione Multi-Sede', body: 'Più studi? Ciascuno riceve la propria strategia di parole chiave, calendario dei contenuti e report — tutto da un unico dashboard.', icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10' },
            { title: 'Costruzione Citazioni', body: 'Inserimenti nelle directory mediche e della salute, Yelp, Google e oltre 50 altri. I segnali di autorità che superano gli studi concorrenti nel tuo mercato.', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg></div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="come-funziona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Come funziona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Collegati una volta. Stacc gestisce la presenza Maps<br />del tuo studio da quel giorno in poi.</h2>
        </div>
        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            {[
              { num: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Collega il tuo Google Business Profile', body: 'Cerca il tuo studio chiropratico. Stacc recupera i dati GBP attuali e identifica per quali parole chiave chiropratiche non ti stai posizionando nel tuo mercato.' },
              { num: '02', icon: 'M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z', title: "L'AI costruisce il tuo piano di contenuti chiropratici", body: '30 post al mese mirati ai tuoi servizi — aggiustamento vertebrale, mal di schiena, cervicale, sciatica e contenuti stagionali che mantengono il tuo GBP sempre attivo.' },
              { num: '03', icon: 'M20 6 9 17l-5-5', title: 'Post pubblicati. Agenda piena. Studio al completo.', body: 'I contenuti vengono pubblicati secondo programma. Gli avvisi di recensione arrivano istantaneamente. La tua autorità Maps cresce così quando un paziente cerca un chiropratico, sei tra i primi 3.' },
            ].map(s => (
              <div class="bg-white px-8 py-10">
                <div class="mb-6 flex items-center justify-between">
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg></div>
                  <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.num}</span>
                </div>
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
                <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">I numeri</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">Cosa dicono i dati sui pazienti<br />e la ricerca degli studi chiropratici.</h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-2 md:grid-cols-4" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '720K', num: 720, prefix: '', suffix: 'K', decimals: 0, from: 0, label: 'Ricerche mensili "chiropratico vicino a me"', sub: 'solo in Italia' },
            { value: '74%', num: 74, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Pazienti cercano online prima di chiamare', sub: 'il GBP è la prima impressione' },
            { value: '78%', num: 78, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Controllano le recensioni prima di prenotare', sub: 'la fiducia si costruisce online' },
            { value: '4.7×', num: 4.7, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Aumento medio posizionamento Maps con Stacc', sub: 'entro 90 giorni' },
