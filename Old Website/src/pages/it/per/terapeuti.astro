---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Le recensioni Google sono appropriate per i terapeuti e gli psicologi?",
    a: "Sì, nel rispetto della privacy e della deontologia professionale. Le recensioni online sono oggi uno dei principali canali con cui le persone trovano un terapeuta. Il 74% dei potenziali pazienti cerca online prima di contattare uno specialista. theStacc è progettato per rispettare la riservatezza: le richieste non fanno mai riferimento alla natura della terapia."
  },
  {
    q: "Come theStacc tutela la privacy dei pazienti nel settore terapeutico?",
    a: "theStacc non include mai dettagli sulla natura del trattamento nelle comunicazioni. La richiesta di recensione è generica — invita il paziente a condividere la sua esperienza generale con lo studio, senza fare riferimento al tipo di supporto ricevuto. È GDPR-compliant e rispetta le linee guida deontologiche degli ordini professionali italiani."
  },
  {
    q: "Quando è il momento giusto per chiedere una recensione a un paziente?",
    a: "theStacc ti permette di configurare il timing con precisione. Per la terapia, spesso il momento migliore è dopo aver raggiunto un obiettivo importante o al termine di un percorso. Puoi impostare la richiesta manualmente per ogni paziente, garantendo che avvenga nel contesto appropriato."
  },
  {
    q: "Posso scegliere quali pazienti ricevono la richiesta di recensione?",
    a: "Sì. A differenza di altri settori, per la terapia theStacc ti permette di selezionare manualmente i pazienti a cui inviare la richiesta. In questo modo hai pieno controllo e puoi rispettare la sensibilità di ogni singolo caso."
  },
  {
    q: "Come gestisce theStacc le recensioni negative nel settore della salute mentale?",
    a: "theStacc include un sistema di pre-filtro che intercetta i pazienti insoddisfatti prima della pubblicazione. Vengono indirizzati a un canale di feedback privato, permettendoti di gestire la situazione con professionalità. Solo i pazienti soddisfatti ricevono la richiesta di recensione pubblica."
  },
  {
    q: "theStacc funziona anche per le sedute online?",
    a: "Sì. Sempre più terapeuti offrono sessioni via video — theStacc funziona per entrambe le modalità. Puoi configurare richieste diverse per sedute in presenza e online, con messaggi appropriati al contesto."
  },
  {
    q: "Quante nuove recensioni posso aspettarmi per il mio studio terapeutico?",
    a: "Data la natura particolare del settore, il volume di recensioni è tipicamente inferiore ad altri settori. Con theStacc, la maggior parte dei terapisti raccoglie 3-8 nuove recensioni al mese — sufficiente per migliorare significativamente il ranking locale e attrarre nuovi pazienti."
  },
  {
    q: "Qual è il costo di theStacc per un terapista?",
    a: "theStacc parte da $49 al mese. Per i terapisti, il piano include selezione manuale dei destinatari, filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Terapeuti",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per psicologi, terapeuti e counselor. Raccoglie recensioni nel rispetto della privacy e della deontologia professionale.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Terapeuti", "item": "https://thestacc.com/it/per/terapeuti/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Terapeuti e Psicologi | Più Pazienti con le Recensioni Google | theStacc" description="Aumenta i pazienti del tuo studio terapeutico con le recensioni Google. theStacc aiuta psicologi e terapeuti a raccogliere recensioni nel rispetto della privacy e della deontologia." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Psicologi · Terapeuti · Counselor</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Pazienti per il Tuo Studio Terapeutico<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          720.000 italiani cercano un terapeuta online ogni mese. La scelta è influenzata enormemente dalla reputazione online. theStacc raccoglie le tue recensioni nel pieno rispetto della privacy dei pazienti.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">720K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">74%</div>
            <div class="text-gray-400 text-sm">cerca online prima di contattare</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.5×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">privacy rispettata</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "GDPR Compliant", "Privacy Tutelata", "Conforme Deontologia", "Selezione Manuale", "Supporto in Italiano", "Nessuna Carta di Credito"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "GDPR Compliant", "Privacy Tutelata", "Conforme Deontologia", "Selezione Manuale", "Supporto in Italiano", "Nessuna Carta di Credito"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          La Sfida Unica dei Professionisti della Salute Mentale
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          Il tuo lavoro cambia vite — ma le persone che potrebbero beneficiarne non ti trovano online.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">La Visibilità Online Determina la Prima Scelta</h3>
            <p class="text-gray-600">Chi cerca un terapeuta per la prima volta, spesso in un momento di difficoltà, si affida a Google Maps. Con poche recensioni, non trasmetti la fiducia necessaria per quel primo contatto cruciale.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Chiedere Recensioni è Imbarazzante nel Contesto Terapeutico</h3>
            <p class="text-gray-600">Non è come chiedere al cliente del ristorante. La natura della terapia rende la richiesta di recensione delicata. Senza un sistema strutturato e rispettoso, questo compito viene continuamente rimandato.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">I Nuovi Terapeuti ti Superano Online</h3>
            <p class="text-gray-600">Un collega che ha aperto da meno tempo ma ha investito nella reputazione online può avere più visibilità di te su Google Maps. L'anzianità non pesa — le recensioni sì.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          La Soluzione Progettata per i Professionisti della Salute
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc rispetta la delicatezza del tuo lavoro con strumenti pensati per la terapia.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Selezione Manuale dei Pazienti",
              desc: "A differenza di altri settori, puoi scegliere tu quali pazienti ricevono la richiesta. Pieno controllo, rispetto per ogni singolo caso."
            },
            {
              title: "Messaggi Senza Riferimento alla Terapia",
              desc: "Le richieste invitano a condividere l'esperienza generale con lo studio, senza mai fare riferimento al tipo di supporto ricevuto. Privacy garantita."
            },
            {
              title: "Conforme alle Norme Deontologiche",
              desc: "theStacc è progettato nel rispetto delle linee guida degli ordini professionali italiani per psicologi e terapeuti."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "I pazienti insoddisfatti vengono intercettati prima della pubblicazione. Gestione privata e professionale di ogni feedback negativo."
            },
            {
              title: "Supporto per Sedute Online",
              desc: "Funziona sia per sessioni in presenza che per videoterapia. Messaggi personalizzati per ogni modalità di erogazione del servizio."
            },
            {
              title: "Dashboard Riservata",
              desc: "Tutti i dati sono protetti e accessibili solo a te. Dashboard sicura, GDPR-compliant, con report periodici delle performance."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Tre passi rispettosi della tua professione.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega il tuo Google Business", desc: "Connetti il profilo dello studio in pochi clic. La configurazione è semplice e non richiede competenze tecniche." },
            { step: "2", title: "Seleziona i pazienti e configura i messaggi", desc: "Scegli manualmente a chi inviare la richiesta e personalizza il messaggio. Il tono rispettoso è già integrato nei template." },
            { step: "3", title: "Le recensioni arrivano discretamente", desc: "Ogni paziente selezionato riceve il messaggio al momento che hai scelto. Tu fai terapia, la tua visibilità su Google cresce." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          La Salute Mentale Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I dati che ogni terapeuta dovrebbe conoscere.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "720K", label: "Ricerche mensili per terapeuti in Italia" },
            { value: "74%", label: "cerca online prima di contattare uno specialista" },
            { value: "4.5×", label: "più visibilità con profilo Maps ottimizzato" },
            { value: "82%", label: "sceglie tra i primi 3 terapeuti su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Avevo resistito a lungo all'idea di raccogliere recensioni — mi sembrava in contrasto con la riservatezza del mio lavoro. theStacc ha risolto questa tensione: i messaggi sono discreti e rispettosi. In 6 mesi ho 38 nuove recensioni e la lista d'attesa per i nuovi pazienti è di 3 settimane.
        </blockquote>
        <div class="font-bold text-gray-900">Dott.ssa F. Greco</div>
        <div class="text-gray-600">Studio di Psicologia Greco, Roma</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+38 recensioni in 6 mesi · lista d'attesa 3 settimane</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per studio · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Selezione manuale dei pazienti",
              "Messaggi rispettosi della privacy",
              "Conforme deontologia professionale",
              "GDPR compliant",
              "Filtro recensioni negative",
              "Supporto per sedute online",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Chiropratici", href: "/it/per/chiropratici/" },
            { name: "Medici", href: "/it/per/medici/" },
            { name: "Veterinari", href: "/it/per/veterinari/" },
            { name: "Avvocati", href: "/it/per/avvocati/" },
            { name: "Consulenti Finanziari", href: "/it/per/consulenti-finanziari/" },
            { name: "Palestre", href: "/it/per/palestre/" },
            { name: "Ripetizioni", href: "/it/per/ripetizioni/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia ad Aiutare Più Persone Oggi
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Rispettoso della tua professione.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
