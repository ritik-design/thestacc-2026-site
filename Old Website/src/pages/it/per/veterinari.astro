---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono importanti per i veterinari?",
    a: "Gli animali domestici sono considerati parte della famiglia e i proprietari scelgono il veterinario con la stessa cura con cui sceglierebbero un pediatra. Il 78% dei proprietari di animali legge le recensioni Google prima di scegliere una clinica veterinaria. Un profilo con molte recensioni positive trasmette fiducia e competenza."
  },
  {
    q: "Come funziona la raccolta automatica di recensioni per le cliniche veterinarie?",
    a: "Dopo ogni visita o trattamento, theStacc invia automaticamente un SMS o email al proprietario dell'animale con un link diretto alla pagina Google della clinica. Il messaggio è personalizzato con il nome del proprietario e del suo animale, creando un tocco personale che aumenta il tasso di risposta."
  },
  {
    q: "theStacc funziona anche per le emergenze veterinarie notturne?",
    a: "Sì. Per le cliniche con servizio di emergenza h24, theStacc invia la richiesta il giorno successivo — quando il proprietario è tranquillo e vuole esprimere gratitudine per l'assistenza ricevuta in un momento difficile. È proprio dopo un'emergenza gestita bene che i proprietari lasciano le recensioni più entusiastiche."
  },
  {
    q: "Come gestisce theStacc le situazioni difficili come la perdita di un animale?",
    a: "theStacc ti permette di escludere manualmente i clienti che hanno vissuto situazioni particolarmente dolorose. Puoi impostare delle eccezioni per i casi di eutanasia o decesso, garantendo che non vengano contattati in un momento delicato."
  },
  {
    q: "Posso usare theStacc per una clinica veterinaria con più specialisti?",
    a: "Sì. theStacc supporta cliniche con più veterinari e specializzazioni. Puoi tracciare le recensioni per veterinario, capire quale specialista genera più soddisfazione e usare i dati per ottimizzare il team."
  },
  {
    q: "Le recensioni aiutano anche per attirare clienti per servizi aggiuntivi (toelettatura, pensione, etc.)?",
    a: "Assolutamente. Le recensioni che menzionano servizi specifici (toelettatura, pensione, chirurgia) aiutano i proprietari a trovare la clinica quando cercano esattamente quel tipo di servizio. Una presenza ricca di recensioni aumenta la visibilità per tutte le specializzazioni offerte."
  },
  {
    q: "Quante nuove recensioni posso aspettarmi al mese per la mia clinica?",
    a: "Le cliniche veterinarie che usano theStacc raccolgono tipicamente 15-35 nuove recensioni al mese, a seconda del volume di visite. Con un tasso di risposta medio del 30%, ogni 100 visite puoi aspettarti circa 30 nuove recensioni."
  },
  {
    q: "Qual è il costo di theStacc per una clinica veterinaria?",
    a: "theStacc parte da $49 al mese. Include automazione completa, personalizzazione con il nome dell'animale, eccezioni manuali, filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Veterinari",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per cliniche veterinarie e veterinari. Automatizza la raccolta di recensioni dopo ogni visita e aumenta la visibilità locale.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Veterinari", "item": "https://thestacc.com/it/per/veterinari/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Veterinari | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i clienti della tua clinica veterinaria con le recensioni Google automatizzate. theStacc raccoglie recensioni dopo ogni visita e porta la tua clinica in cima a Google Maps." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Cliniche Veterinarie &amp; Veterinari</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Clienti per la Tua Clinica Veterinaria<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          880.000 italiani cercano un veterinario ogni mese. I proprietari di animali scelgono solo chi si fida. theStacc raccoglie le tue recensioni automaticamente dopo ogni visita, con il tocco personale del nome del loro animale.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">880K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">78%</div>
            <div class="text-gray-400 text-sm">cerca online prima di scegliere</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.6×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Nome dell'Animale Incluso", "Eccezioni Manuali", "Supporto in Italiano", "GDPR Compliant"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Nome dell'Animale Incluso", "Eccezioni Manuali", "Supporto in Italiano", "GDPR Compliant"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema delle Cliniche Veterinarie senza Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          I proprietari di animali sono tra i consumatori più attenti. Senza recensioni, non entrano dalla tua porta.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">La Clinica con Più Stelle Prende il Nuovo Proprietario</h3>
            <p class="text-gray-600">Chi si trasferisce, adotta un nuovo animale o cerca un secondo parere va su Google Maps. Con poche recensioni, sembri meno affidabile di una clinica con 100 recensioni — anche se la tua qualità è superiore.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Proprietario Grato Dimentica la Recensione</h3>
            <p class="text-gray-600">La visita è andata bene, il cane sta meglio, il proprietario è sollevato. Ma tra passeggiate, lavoro e la vita di tutti i giorni, la recensione promessa non arriva mai senza un promemoria automatico.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Le Visite Quotidiane Non Lasciano Tempo</h3>
            <p class="text-gray-600">Tra visite, interventi chirurgici e gestione della clinica, non c'è un momento per pensare alle recensioni. Le settimane passano, la reputazione online rimane ferma e i concorrenti crescono.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Recensioni per le Cliniche Veterinarie
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc raccoglie le recensioni con la sensibilità richiesta dal settore veterinario.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Messaggi con il Nome dell'Animale",
              desc: "Includere il nome del cane o gatto nel messaggio crea un tocco personale che i proprietari apprezzano e che aumenta significativamente il tasso di risposta."
            },
            {
              title: "Eccezioni Manuali per Situazioni Difficili",
              desc: "Escludi manualmente i proprietari che hanno vissuto la perdita del loro animale. Rispetto e sensibilità sono parte integrante della piattaforma."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "I proprietari insoddisfatti vengono intercettati prima della pubblicazione e indirizzati a un canale privato per la gestione professionale del feedback."
            },
            {
              title: "Timing per Emergenze",
              desc: "Per le cliniche con servizio di emergenza, la richiesta parte il giorno dopo — quando il proprietario è tranquillo e riconosce la qualità dell'assistenza ricevuta."
            },
            {
              title: "Dashboard Multi-Veterinario",
              desc: "Traccia le recensioni per veterinario e specializzazione. Usa i dati per capire dove sei più forte e dove puoi migliorare."
            },
            {
              title: "Report Mensili",
              desc: "Un riepilogo mensile delle performance: nuove recensioni, punteggio medio, trend nel tempo. Tutto quello che serve per monitorare la crescita."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Setup rapido, risultati costanti.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega Google Business e il gestionale della clinica", desc: "Connetti il profilo Google Business e integra il software della clinica. Il setup guidato richiede meno di 30 minuti." },
            { step: "2", title: "Configura i messaggi e le eccezioni", desc: "Personalizza i messaggi con il nome dell'animale e imposta le eccezioni per i casi sensibili. La clinica mantiene pieno controllo." },
            { step: "3", title: "Le recensioni arrivano in automatico", desc: "Ogni visita completata genera una richiesta automatica. Tu curi gli animali, la tua reputazione su Google cresce." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Settore Veterinario Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che ogni clinica dovrebbe conoscere.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "880K", label: "Ricerche mensili per veterinari in Italia" },
            { value: "78%", label: "legge le recensioni prima di scegliere" },
            { value: "4.6×", label: "più prenotazioni con profilo Maps ottimizzato" },
            { value: "90%", label: "sceglie tra i primi 3 veterinari su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Avevamo 27 recensioni dopo 8 anni di clinica. Con theStacc in 6 mesi ne abbiamo raccolte 94 nuove. Siamo passati al primo posto su Google Maps per la nostra zona e i nuovi pazienti vengono spesso da città vicine perché ci trovano online.
        </blockquote>
        <div class="font-bold text-gray-900">Dott.ssa C. Mancini</div>
        <div class="text-gray-600">Clinica Veterinaria Mancini, Padova</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+94 recensioni in 6 mesi · pazienti da tutta la provincia</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per clinica · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "Messaggi con nome dell'animale",
              "Eccezioni manuali per casi sensibili",
              "Filtro recensioni negative",
              "Dashboard multi-veterinario",
              "Report mensili",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Servizi Animali", href: "/it/per/servizi-animali/" },
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Medici", href: "/it/per/medici/" },
            { name: "Chiropratici", href: "/it/per/chiropratici/" },
            { name: "Terapeuti", href: "/it/per/terapeuti/" },
            { name: "Palestre", href: "/it/per/palestre/" },
            { name: "Sanità", href: "/it/per/sanita/" },
            { name: "Parrucchieri", href: "/it/per/parrucchieri/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia ad Accogliere Più Pazienti Oggi
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
