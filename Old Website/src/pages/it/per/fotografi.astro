---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Le recensioni Google sono importanti per i fotografi?",
    a: "Assolutamente sì. L'84% delle persone che cercano un fotografo per matrimoni, eventi o ritratti legge le recensioni online prima di contattare qualcuno. Un profilo Google con molte recensioni positive comunica affidabilità, professionalità e aumenta significativamente le conversioni da ricerche locali."
  },
  {
    q: "Come theStacc raccoglie le recensioni per i fotografi?",
    a: "Dopo ogni sessione fotografica o consegna del materiale, theStacc invia automaticamente un SMS o email al cliente con un link diretto alla tua pagina Google. Il messaggio è personalizzato con il nome del cliente e il tipo di servizio (matrimonio, ritratto, evento aziendale), aumentando il tasso di risposta."
  },
  {
    q: "Quando è il momento migliore per chiedere una recensione a un cliente fotografico?",
    a: "Il momento di massima soddisfazione è quando il cliente riceve le foto finite — quel momento emotivo in cui rivede i ricordi immortalati. theStacc ti permette di programmare la richiesta esattamente in quel momento, massimizzando le probabilità di ottenere una recensione entusiasta."
  },
  {
    q: "theStacc funziona anche per fotografi di matrimoni che lavorano stagionalmente?",
    a: "Sì. theStacc gestisce automaticamente i volumi variabili della stagione matrimoniale (primavera-autunno). Puoi anche raccogliere recensioni fuori stagione per mantenere una frequenza costante su Google, che è un segnale positivo per l'algoritmo locale."
  },
  {
    q: "Come gestisce theStacc le recensioni negative nel settore fotografico?",
    a: "Le recensioni negative in fotografia spesso riguardano tempi di consegna o aspettative diverse. theStacc intercetta i clienti insoddisfatti con un filtro pre-pubblicazione, indirizzandoli a un canale privato dove puoi risolvere il problema con professionalità prima che diventi pubblica."
  },
  {
    q: "Posso usare theStacc se offro più tipi di fotografia (matrimoni, ritratti, commerciale)?",
    a: "Sì. Puoi configurare messaggi diversi per ogni specializzazione. La comunicazione è contestualizzata al servizio fruito: il cliente di un servizio matrimoniale riceve un messaggio diverso da quello di un ritratto corporate."
  },
  {
    q: "Le recensioni Google aiutano anche per trovare clienti per foto commerciali e aziendali?",
    a: "Sì. Anche le aziende che cercano un fotografo per eventi, prodotti o personal branding guardano le recensioni su Google. Un profilo ben curato con testimonianze di lavori precedenti ti posiziona come scelta affidabile anche per clienti business."
  },
  {
    q: "Qual è il costo di theStacc per un fotografo?",
    a: "theStacc parte da $49 al mese. Il piano include automazione completa, SMS ed email personalizzati, filtro recensioni negative, dashboard analitica e supporto in italiano. Puoi iniziare con 14 giorni di prova gratuita senza inserire la carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Fotografi",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per fotografi professionisti. Automatizza la raccolta di recensioni dopo ogni sessione e aumenta la visibilità nei risultati di ricerca locali.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Fotografi", "item": "https://thestacc.com/it/per/fotografi/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Fotografi | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i clienti del tuo studio fotografico con le recensioni Google automatizzate. theStacc aiuta i fotografi professionisti a dominare la ricerca locale e a ricevere più prenotazioni." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Fotografi Professionisti</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Prenotazioni per il Tuo Studio Fotografico<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          560.000 italiani cercano un fotografo ogni mese. Chi ha più recensioni viene contattato per primo. theStacc raccoglie le tue recensioni automaticamente al momento perfetto — quando il cliente riceve le sue foto.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">560K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">84%</div>
            <div class="text-gray-400 text-sm">cerca online prima di scegliere</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.4×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Fotografi"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Fotografi"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Portfolio Non Basta — Servono le Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          Un portfolio eccellente porta le persone sul tuo sito. Le recensioni le convincono a prenotare.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Chi ha Più Recensioni Appare Prima su Maps</h3>
            <p class="text-gray-600">Google Maps ordina i fotografi locali anche in base alle recensioni. Un collega con uno stile diverso dal tuo ma con 70 recensioni ti batte in visibilità — e riceve le prenotazioni al posto tuo.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">L'Emozione della Consegna Dura Poco</h3>
            <p class="text-gray-600">Quando il cliente riceve le sue foto è emozionato e grato. È il momento perfetto per la recensione — ma se non arriva un promemoria entro 24-48 ore, quell'emozione svanisce e la recensione non arriverà mai.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">La Stagione Matrimoniale è Troppo Intensa</h3>
            <p class="text-gray-600">In estate fotografi 3-4 matrimoni a settimana. Non c'è un secondo per il marketing. Le recensioni rimangono zero nei mesi di punta, e poi fuori stagione non hai richieste.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Recensioni per Fotografi Professionisti
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc cattura ogni recensione al momento giusto — senza che tu debba pensarci.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Trigger sulla Consegna delle Foto",
              desc: "Configura la richiesta per partire esattamente quando invii la galleria al cliente. Il picco emotivo = tasso di risposta massimo."
            },
            {
              title: "Messaggi per Ogni Specializzazione",
              desc: "Messaggi diversi per matrimoni, ritratti, eventi aziendali, newborn. La comunicazione contestualizzata aumenta la percentuale di risposta."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "I clienti insoddisfatti (tempi di consegna, aspettative diverse) vengono intercettati e indirizzati a un canale privato per una gestione professionale."
            },
            {
              title: "Dashboard Fotografo",
              desc: "Monitora le recensioni per tipo di servizio. Scopri quale specializzazione genera più feedback positivi e ottimizza il tuo posizionamento."
            },
            {
              title: "Risposta alle Recensioni",
              desc: "Rispondi a ogni recensione da theStacc. Le risposte personalizzate mostrano professionalità ai futuri clienti che leggono il tuo profilo."
            },
            {
              title: "Report Stagionali",
              desc: "Analisi delle performance per periodo dell'anno. Ottimizza la raccolta nei mesi di bassa stagione per mantenere una frequenza costante su Google."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Setup veloce, risultati immediati.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega il tuo Google Business", desc: "Connetti il profilo della tua attività fotografica in pochi clic. Nessuna competenza tecnica necessaria." },
            { step: "2", title: "Configura i tuoi servizi e i trigger", desc: "Indica quali servizi offri e quando vuoi che partano le richieste (alla consegna, X giorni dopo). Personalizza il messaggio per ogni tipo di shooting." },
            { step: "3", title: "Le recensioni arrivano automaticamente", desc: "Ogni cliente riceve la sua richiesta al momento perfetto. Tu fotografi, la tua reputazione su Google cresce." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          La Fotografia Locale Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I dati che ogni fotografo dovrebbe conoscere.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "560K", label: "Ricerche mensili per fotografi in Italia" },
            { value: "84%", label: "legge le recensioni prima di prenotare" },
            { value: "4.4×", label: "più prenotazioni con profilo Maps ottimizzato" },
            { value: "91%", label: "sceglie tra i primi 3 fotografi su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Fotografo matrimoni da 8 anni ma avevo solo 11 recensioni su Google. Con theStacc ho iniziato a inviare la richiesta quando mando la galleria — in 6 mesi ho 73 nuove recensioni e il calendario estivo è già pieno fino a ottobre.
        </blockquote>
        <div class="font-bold text-gray-900">E. Moretti</div>
        <div class="text-gray-600">Moretti Wedding Photography, Venezia</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+73 recensioni in 6 mesi · calendario pieno fino a ottobre</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per fotografo · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "SMS + Email automatici",
              "Trigger sulla consegna delle foto",
              "Filtro recensioni negative",
              "Dashboard analitica completa",
              "Messaggi per ogni specializzazione",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Matrimoni", href: "/it/per/matrimoni/" },
            { name: "Parrucchieri", href: "/it/per/parrucchieri/" },
            { name: "Ripetizioni", href: "/it/per/ripetizioni/" },
            { name: "Palestre", href: "/it/per/palestre/" },
            { name: "Terapeuti", href: "/it/per/terapeuti/" },
            { name: "Ristoranti", href: "/it/per/ristoranti/" },
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Servizi Animali", href: "/it/per/servizi-animali/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Riempi il Calendario di Prenotazioni
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
