---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono importanti per i centri di ripetizioni?",
    a: "Il 77% dei genitori cerca online prima di scegliere un centro di ripetizioni o un tutor privato per il proprio figlio. Le recensioni Google sono il principale fattore di fiducia: un centro con molte recensioni positive appare affidabile e competente, riducendo la barriera al primo contatto."
  },
  {
    q: "Come theStacc raccoglie le recensioni per i centri di ripetizioni?",
    a: "Dopo ogni sessione o al termine di un ciclo di lezioni, theStacc invia automaticamente un SMS o email al genitore (o allo studente maggiorenne) con un link diretto alla pagina Google del centro. Il messaggio è personalizzato con il nome del cliente e la materia seguita."
  },
  {
    q: "A chi vengono inviate le richieste — allo studente o al genitore?",
    a: "Puoi configurare a chi inviare la richiesta: al genitore per gli studenti minorenni, o direttamente allo studente se maggiorenne. theStacc ti permette di gestire questa distinzione automaticamente in base all'età del cliente."
  },
  {
    q: "Le recensioni aiutano anche per le lezioni private online?",
    a: "Sì. Sempre più lezioni di ripetizioni si svolgono online. theStacc funziona per entrambe le modalità. Puoi configurare messaggi diversi per studenti in presenza e online, con timing adatti a ogni contesto."
  },
  {
    q: "Come gestisce theStacc le recensioni negative per i centri di ripetizioni?",
    a: "theStacc include un filtro pre-pubblicazione: i genitori o studenti insoddisfatti vengono intercettati prima della pubblicazione e indirizzati a un canale privato. Puoi risolvere il problema con professionalità prima che diventi una recensione pubblica."
  },
  {
    q: "Le recensioni aiutano a riempire il calendario in estate?",
    a: "Sì. I corsi estivi, la preparazione agli esami di settembre e i recuperi estivi generano molta domanda. Essere visibili su Google Maps con molte recensioni positive significa intercettare i genitori che cercano ripetizioni durante l'estate, un periodo ad alta domanda."
  },
  {
    q: "Posso usare theStacc per più materie o più insegnanti?",
    a: "Sì. Puoi configurare messaggi diversi per materia o per insegnante. Questo ti permette di capire quali corsi o quali insegnanti generano più soddisfazione e più recensioni, ottimizzando l'offerta del tuo centro."
  },
  {
    q: "Qual è il costo di theStacc per un centro ripetizioni?",
    a: "theStacc parte da $49 al mese. Include automazione completa, gestione genitori e studenti, filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Centri Ripetizioni",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per centri di ripetizioni e tutor privati. Automatizza la raccolta di recensioni e aumenta la visibilità nelle ricerche locali.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Ripetizioni", "item": "https://thestacc.com/it/per/ripetizioni/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Centri Ripetizioni | Più Studenti con le Recensioni Google | theStacc" description="Aumenta gli studenti del tuo centro ripetizioni con le recensioni Google automatizzate. theStacc aiuta i centri di tutoraggio a dominare la ricerca locale e a riempire il calendario." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Centri Ripetizioni · Tutor · Doposcuola</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Studenti per il Tuo Centro Ripetizioni<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          340.000 italiani cercano ripetizioni online ogni mese. I genitori scelgono chi si fida. theStacc raccoglie le tue recensioni automaticamente, sessione dopo sessione.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">340K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">77%</div>
            <div class="text-gray-400 text-sm">cerca online prima di scegliere</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.3×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Gestione Genitori", "Lezioni Online", "Supporto in Italiano", "GDPR Compliant"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Gestione Genitori", "Lezioni Online", "Supporto in Italiano", "GDPR Compliant"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema dei Centri Ripetizioni senza Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          I genitori affidano il futuro dei figli al tuo centro. Senza recensioni, quella fiducia va costruita ogni volta da zero.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">I Nuovi Centri con Recensioni ti Superano</h3>
            <p class="text-gray-600">Un centro aperto da 2 anni con 60 recensioni appare prima di te su Google Maps — anche se hai 10 anni di esperienza e risultati eccellenti. L'algoritmo premia le recensioni, non l'anzianità.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Genitore Soddisfatto Non Lascia Recensioni</h3>
            <p class="text-gray-600">Il figlio ha passato la verifica, il genitore è entusiasta. Ma tra casa, lavoro e altri impegni, la recensione promessa viene dimenticata. Senza un sistema automatico, quell'entusiasmo non si trasforma mai in visibilità.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">La Stagione Estiva è il Momento Critico</h3>
            <p class="text-gray-600">Luglio e agosto sono pieni di studenti che devono recuperare materie. Se non sei visibile su Google Maps con buone recensioni, perdi proprio il periodo di massima domanda.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Recensioni per i Centri Ripetizioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc raccoglie le recensioni automaticamente — con strumenti pensati per la gestione di genitori e studenti.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Richieste ai Genitori o agli Studenti",
              desc: "Configura a chi inviare la richiesta: al genitore per i minorenni, allo studente per i maggiorenni. La piattaforma gestisce la distinzione automaticamente."
            },
            {
              title: "Timing Ottimale per Ogni Ciclo",
              desc: "Imposta la richiesta alla fine del mese, dopo una verifica importante o al completamento di un ciclo. Il momento giusto aumenta il tasso di risposta."
            },
            {
              title: "Messaggi per Materia",
              desc: "Personalizza il messaggio per ogni materia insegnata. Un genitore che parla di matematica è più rilevante di uno generico — e lo sa Google."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "I genitori insoddisfatti vengono intercettati prima della pubblicazione. Risolvi privatamente prima che diventi una recensione negativa pubblica."
            },
            {
              title: "Supporto Lezioni Online",
              desc: "Funziona per lezioni in presenza e online. Il sistema si adatta automaticamente alla modalità di erogazione del servizio."
            },
            {
              title: "Report per Insegnante",
              desc: "Vedi quali insegnanti generano più soddisfazione. Usa i dati per premiare i migliori e formare chi ne ha bisogno."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Tre passi per iniziare.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega Google Business", desc: "Connetti il profilo Google Business del tuo centro in pochi clic. Nessuna competenza tecnica necessaria." },
            { step: "2", title: "Configura gli studenti e i trigger", desc: "Imposta chi riceve la richiesta (genitore o studente), quando e con quale messaggio. Puoi differenziare per materia e insegnante." },
            { step: "3", title: "Le recensioni arrivano in automatico", desc: "Da quel momento, ogni ciclo completato genera una richiesta automatica. Tu insegni, la tua reputazione su Google cresce." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Settore Ripetizioni Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che ogni centro di ripetizioni dovrebbe conoscere.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "340K", label: "Ricerche mensili per ripetizioni in Italia" },
            { value: "77%", label: "dei genitori cerca online prima di scegliere" },
            { value: "4.3×", label: "più iscrizioni con profilo Maps ottimizzato" },
            { value: "85%", label: "sceglie tra i primi 3 centri su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Il nostro centro aveva 14 recensioni dopo 4 anni. Con theStacc in 5 mesi ne abbiamo raccolte 71 nuove. Siamo il primo centro su Google Maps per la nostra zona e per settembre abbiamo già il 70% dei posti occupati — con 3 mesi di anticipo.
        </blockquote>
        <div class="font-bold text-gray-900">M. Fontana</div>
        <div class="text-gray-600">Centro Studio Fontana, Brescia</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+71 recensioni in 5 mesi · 70% posti occupati per settembre</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per centro · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "Gestione genitori e studenti",
              "Messaggi per materia e insegnante",
              "Filtro recensioni negative",
              "Supporto lezioni online",
              "Report per insegnante",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Terapeuti", href: "/it/per/terapeuti/" },
            { name: "Palestre", href: "/it/per/palestre/" },
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Medici", href: "/it/per/medici/" },
            { name: "Parrucchieri", href: "/it/per/parrucchieri/" },
            { name: "Fotografi", href: "/it/per/fotografi/" },
            { name: "Avvocati", href: "/it/per/avvocati/" },
            { name: "Veterinari", href: "/it/per/veterinari/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Riempi i Posti per il Prossimo Anno Scolastico
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
