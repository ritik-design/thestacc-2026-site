---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono importanti per i giardinieri?",
    a: "Le recensioni Google determinano la tua posizione nel Local Pack — i tre risultati che appaiono sopra tutti gli altri nelle ricerche locali. Per i giardinieri, che dipendono da clienti nel raggio di 20-30 km, essere visibili in questa posizione può triplicare il volume di richieste. L'86% dei consumatori legge le recensioni prima di scegliere un servizio di giardinaggio."
  },
  {
    q: "Come funziona la raccolta automatica delle recensioni di theStacc?",
    a: "Dopo ogni servizio completato, theStacc invia automaticamente un SMS o un'email al cliente con un link diretto alla tua pagina Google. Il messaggio è personalizzato con il nome del cliente e il tipo di lavoro svolto, aumentando significativamente il tasso di risposta rispetto alle richieste generiche."
  },
  {
    q: "Posso gestire le recensioni negative con theStacc?",
    a: "Sì. theStacc include un sistema di pre-filtro che identifica i clienti insoddisfatti prima che pubblichino. Quei clienti vengono indirizzati a un modulo di feedback interno, permettendoti di risolvere il problema privatamente. Solo i clienti soddisfatti ricevono la richiesta di recensione pubblica."
  },
  {
    q: "Quanto tempo ci vuole per vedere risultati nel ranking locale?",
    a: "La maggior parte dei giardinieri che usano theStacc vede un miglioramento nella posizione Google Maps entro 60-90 giorni dall'attivazione. Con 10-15 nuove recensioni al mese, il punteggio medio e la frequenza delle recensioni — fattori chiave per l'algoritmo di Google — migliorano rapidamente."
  },
  {
    q: "theStacc funziona anche per le imprese di giardinaggio con più squadre?",
    a: "Assolutamente. La dashboard di theStacc supporta più sedi e operatori. Puoi vedere le performance di recensione per ogni squadra o zona geografica, identificare dove migliorare e premiare i team che generano più feedback positivi."
  },
  {
    q: "Posso rispondere alle recensioni direttamente da theStacc?",
    a: "Sì. Il pannello di theStacc ti permette di rispondere alle recensioni Google senza aprire il tuo account Google Business. Puoi anche impostare risposte automatiche di ringraziamento per le recensioni a 5 stelle, risparmiando tempo mantenendo un'interazione professionale."
  },
  {
    q: "Come si integra theStacc con il mio calendario di lavoro?",
    a: "theStacc si connette ai principali software di gestione lavori usati dai giardinieri (Jobber, ServiceM8, Housecall Pro) e può anche importare da Google Calendar o fogli Excel. Una volta collegato, ogni lavoro completato innesca automaticamente la sequenza di richiesta recensione."
  },
  {
    q: "Qual è il costo di theStacc per un'impresa di giardinaggio?",
    a: "theStacc parte da $49 al mese per le imprese di giardinaggio con una sede. Il piano include automazione illimitata delle recensioni, gestione delle risposte, dashboard analitica e supporto via email. Puoi provarlo gratuitamente per 14 giorni senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Giardinieri",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per giardinieri e imprese di giardinaggio. Automatizza la raccolta di recensioni, migliora il ranking locale e aumenta le richieste di preventivo.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Giardinieri", "item": "https://thestacc.com/it/per/giardinieri/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Giardinieri | Più Clienti con le Recensioni Google | theStacc" description="Aumenta le richieste di preventivo per la tua impresa di giardinaggio con le recensioni Google automatizzate. theStacc aiuta i giardinieri a dominare il Local Pack e attirare più clienti locali." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Giardinieri &amp; Paesaggisti</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Preventivi per la Tua Impresa di Giardinaggio<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          380.000 italiani cercano servizi di giardinaggio ogni mese. Chi ha più recensioni vince. theStacc raccoglie le recensioni automaticamente dopo ogni lavoro — senza che tu debba ricordartelo.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">380K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">73%</div>
            <div class="text-gray-400 text-sm">cerca online prima di chiamare</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.3×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Imprese"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Cancella Quando Vuoi", "Usato da 500+ Imprese"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema dei Giardinieri che Non Chiedono Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          Fai un lavoro eccellente. I clienti sono soddisfatti. Ma se Google non lo sa, quei clienti non arrivano.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Concorrente con Più Recensioni Vince Sempre</h3>
            <p class="text-gray-600">Un giardiniere con 80 recensioni a 4.8 stelle appare prima di te — anche se il tuo lavoro è migliore. Google premia la quantità e la freschezza delle recensioni.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Dimenticano di Lasciare la Recensione</h3>
            <p class="text-gray-600">Il cliente promette di lasciare una recensione, ma la vita va avanti. Senza un sistema automatico di follow-up, il 90% dei clienti soddisfatti non lascia mai niente.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Stagione Alta = Nessun Tempo per il Marketing</h3>
            <p class="text-gray-600">In primavera ed estate sei sommerso di lavoro. Non hai tempo di inviare messaggi a ogni cliente. Così le recensioni non arrivano proprio quando ne hai più bisogno.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Tutto Quello che Serve per Dominare la Ricerca Locale
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc automatizza ogni aspetto della tua reputazione online, così puoi concentrarti sul lavoro.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Richieste Automatiche Post-Servizio",
              desc: "Dopo ogni lavoro completato, il cliente riceve automaticamente un SMS o email con link diretto alla tua pagina Google. Zero sforzo da parte tua."
            },
            {
              title: "Filtro Recensioni Negative",
              desc: "I clienti insoddisfatti vengono identificati prima della pubblicazione e indirizzati a un canale privato. Solo le esperienze positive raggiungono Google."
            },
            {
              title: "Dashboard Centralizzata",
              desc: "Tutte le tue recensioni in un unico posto. Monitora il punteggio, la frequenza e le tendenze senza aprire Google Business ogni giorno."
            },
            {
              title: "Risposte Semplificate",
              desc: "Rispondi alle recensioni direttamente da theStacc. Template pre-approvati per i ringraziamenti, così ogni cliente riceve attenzione."
            },
            {
              title: "Report Settimanali",
              desc: "Ogni lunedì ricevi un riepilogo: nuove recensioni, punteggio medio, richieste inviate e tasso di conversione. Dati chiari, zero complessità."
            },
            {
              title: "Integrazioni Calendario",
              desc: "Si connette a Jobber, ServiceM8, Housecall Pro e Google Calendar. Le richieste partono automaticamente al momento giusto."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Attivo in Meno di un'Ora
        </h2>
        <p class="text-gray-600 text-center mb-12">Tre passi e il tuo sistema di recensioni è operativo.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega il tuo Google Business", desc: "Connetti il tuo profilo Google Business a theStacc in pochi clic. Nessuna configurazione tecnica richiesta — la piattaforma guida tutto il processo." },
            { step: "2", title: "Importa i tuoi clienti o integra il calendario", desc: "Carica la tua lista clienti o connetti il software che usi per gestire gli appuntamenti. theStacc sa automaticamente quando un lavoro è completato." },
            { step: "3", title: "Le recensioni arrivano in automatico", desc: "Da quel momento, ogni cliente soddisfatto riceve una richiesta personalizzata. Tu lavori, le recensioni crescono. Controlla i risultati dalla dashboard settimanale." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          I Numeri del Giardinaggio Locale in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I dati che spiegano perché le recensioni sono la tua priorità numero uno.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "380K", label: "Ricerche mensili per giardinieri in Italia" },
            { value: "73%", label: "dei clienti cerca online prima di chiamare" },
            { value: "4.3×", label: "più richieste con profilo Maps ottimizzato" },
            { value: "86%", label: "legge le recensioni prima di scegliere" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Prima di theStacc avevo 12 recensioni dopo 5 anni di lavoro. In 4 mesi ne ho ricevute 67 nuove. Ora sono il primo risultato su Google per "giardiniere Milano nord" e ricevo 3-4 richieste di preventivo a settimana solo da Maps.
        </blockquote>
        <div class="font-bold text-gray-900">F. Cattaneo</div>
        <div class="text-gray-600">Cattaneo Giardini, Milano</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+67 recensioni in 4 mesi · primo su Google Maps</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per impresa · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "SMS + Email automatici",
              "Filtro recensioni negative",
              "Dashboard analitica completa",
              "Risposte semplificate",
              "Report settimanali",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">
          Domande Frequenti
        </h2>
        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Idraulici", href: "/it/per/idraulici/" },
            { name: "Elettricisti", href: "/it/per/elettricisti/" },
            { name: "Imprenditori Edili", href: "/it/per/imprenditori-edili/" },
            { name: "Pulizie", href: "/it/per/pulizie/" },
            { name: "Climatizzazione", href: "/it/per/climatizzazione/" },
            { name: "Traslochi", href: "/it/per/traslochi/" },
            { name: "Coperture", href: "/it/per/coperture/" },
            { name: "Ispettori Immobiliari", href: "/it/per/ispettori-immobiliari/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia a Ricevere Più Preventivi Oggi
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
