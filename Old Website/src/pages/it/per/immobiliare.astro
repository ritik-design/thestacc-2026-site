---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Le recensioni Google sono importanti per gli agenti immobiliari?",
    a: "Assolutamente sì. Il 76% delle persone che cercano un agente immobiliare online legge le recensioni prima di contattare qualcuno. Nel settore immobiliare, dove la fiducia è fondamentale per una delle decisioni più importanti della vita, avere molte recensioni positive su Google è un vantaggio competitivo determinante."
  },
  {
    q: "Quando è il momento migliore per chiedere una recensione nel settore immobiliare?",
    a: "Il momento ideale è subito dopo la firma del contratto o il rogito — quando l'emozione è al massimo e il cliente è grato per il lavoro svolto. theStacc ti permette di programmare la richiesta esattamente in quel momento, con un messaggio personalizzato che rispecchia la soddisfazione del cliente."
  },
  {
    q: "Come funziona theStacc per le agenzie immobiliari con più agenti?",
    a: "theStacc supporta agenzie con più agenti. Ogni agente può avere il suo profilo nella dashboard, con le richieste inviate ai propri clienti. Le recensioni vengono tracciate per agente, permettendo al direttore dell'agenzia di monitorare le performance individuali."
  },
  {
    q: "theStacc funziona anche per gli affitti, non solo per le compravendite?",
    a: "Sì. Puoi configurare richieste separate per compravendite e affitti. Per gli affitti, il momento ottimale è la consegna delle chiavi o il completamento della ricerca dell'immobile. Per le compravendite, il rogito o la firma del compromesso."
  },
  {
    q: "Come gestisce theStacc le recensioni negative nel settore immobiliare?",
    a: "Le trattative immobiliari sono complesse e a volte non vanno come sperato. theStacc identifica i clienti insoddisfatti prima della pubblicazione e li indirizza a un canale privato, permettendoti di affrontare il problema professionalmente prima che diventi una recensione negativa su Google."
  },
  {
    q: "Le recensioni aiutano anche per attirare venditori (non solo acquirenti)?",
    a: "Sì. Quando un proprietario cerca un agente a cui affidare la vendita del suo immobile, consulta le recensioni Google per valutare la serietà e l'efficienza dell'agenzia. Avere molte recensioni positive attira sia acquirenti che nuovi mandati di vendita."
  },
  {
    q: "Quanto tempo ci vuole per vedere miglioramenti nel ranking locale?",
    a: "Nel settore immobiliare, i cicli di vendita sono più lunghi, quindi il volume mensile di recensioni può essere inferiore ad altri settori. Con 5-8 nuove recensioni al mese, tuttavia, si osserva un miglioramento nel ranking Google Maps entro 90-120 giorni."
  },
  {
    q: "Qual è il costo di theStacc per un'agenzia immobiliare?",
    a: "theStacc parte da $49 al mese per la sede principale. Se hai più filiali, ci sono piani multi-sede. Il piano base include automazione completa, filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni senza carta."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Agenzie Immobiliari",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per agenti e agenzie immobiliari. Automatizza la raccolta di recensioni dopo ogni transazione e aumenta la visibilità locale.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Immobiliare", "item": "https://thestacc.com/it/per/immobiliare/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Agenzie Immobiliari | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i clienti della tua agenzia immobiliare con le recensioni Google automatizzate. theStacc raccoglie recensioni dopo ogni transazione e migliora il tuo ranking locale." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Agenti &amp; Agenzie Immobiliari</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Clienti per la Tua Agenzia Immobiliare<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          246.000 italiani cercano un agente immobiliare online ogni mese. La fiducia si costruisce prima ancora del primo contatto. theStacc raccoglie le tue recensioni automaticamente dopo ogni transazione.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">246K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">76%</div>
            <div class="text-gray-400 text-sm">cerca online prima di scegliere</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.5×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Multi-agente", "Usato da 500+ Agenzie"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Multi-agente", "Usato da 500+ Agenzie"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema delle Agenzie Immobiliari senza Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          Comprare o vendere casa è la decisione più grande nella vita di una persona. Scelgono solo chi si fidano.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Le Grandi Agenzie Dominano Google</h3>
            <p class="text-gray-600">I franchising nazionali hanno budget marketing enormi. Ma sul Local Pack di Google Maps, ciò che conta sono le recensioni — e un'agenzia locale con 80 recensioni può battere una multinazionale.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Dopo il Rogito, il Cliente Sparisce</h3>
            <p class="text-gray-600">La transazione si chiude, il cliente è felice — ma tra trasloco, pratiche burocratiche e vita quotidiana, la recensione non viene mai scritta. Senza un promemoria automatico, quella voce va persa per sempre.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Le Trattative Lunghe Prosciugano il Tempo</h3>
            <p class="text-gray-600">Ogni compravendita richiede mesi di lavoro. Non c'è spazio per pensare al marketing mentre gestisci trattative, visite e pratiche. Le recensioni rimangono ferme mentre la concorrenza cresce.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          La Piattaforma di Reputazione per il Settore Immobiliare
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc raccoglie le recensioni al momento giusto — senza che tu debba ricordartelo.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Trigger sul Rogito o Contratto",
              desc: "Configura la richiesta per partire esattamente alla chiusura della transazione — il momento di massima soddisfazione per il cliente."
            },
            {
              title: "Dashboard Multi-Agente",
              desc: "Ogni agente ha il suo profilo. Monitora le performance individuali e quella complessiva dell'agenzia da un'unica interfaccia."
            },
            {
              title: "Messaggi per Compravendite e Affitti",
              desc: "Comunicazioni diverse per acquirenti, venditori e inquilini. La contestualizzazione aumenta il tasso di risposta."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "Le trattative possono generare frustrazioni. theStacc intercetta i clienti insoddisfatti prima che pubblichino, permettendo una gestione privata e professionale."
            },
            {
              title: "Report per Agente",
              desc: "Vedi quali agenti generano più recensioni positive. Usa i dati per formazione, incentivi e ottimizzazione del team."
            },
            {
              title: "Risposte Professionali",
              desc: "Rispondi a ogni recensione direttamente da theStacc. Le risposte dell'agenzia mostrano professionalità a chi legge prima di contattarti."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Tre passi per iniziare a raccogliere recensioni.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega il Google Business dell'agenzia", desc: "Connetti il profilo della tua agenzia (o i profili delle sedi multiple) in pochi clic. Nessuna competenza tecnica necessaria." },
            { step: "2", title: "Configura gli agenti e i trigger", desc: "Aggiungi i tuoi agenti alla dashboard e imposta quando partono le richieste (rogito, firma contratto, consegna chiavi). Personalizza il messaggio per ogni tipo di transazione." },
            { step: "3", title: "Le recensioni arrivano in automatico", desc: "Da quel momento, ogni cliente soddisfatto riceve la sua richiesta al momento giusto. Tu chiudi trattative, la tua reputazione su Google cresce." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Mercato Immobiliare Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che spiegano perché le recensioni contano nel real estate.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "246K", label: "Ricerche mensili per agenzie immobiliari" },
            { value: "76%", label: "legge le recensioni prima di contattare" },
            { value: "4.5×", label: "più contatti con profilo Maps ottimizzato" },
            { value: "88%", label: "sceglie tra le prime 3 agenzie su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Avevamo 23 recensioni dopo 12 anni di attività. Con theStacc in 8 mesi ne abbiamo raccolte 91 nuove. Siamo passati dal 4° al 1° posto su Google Maps per la nostra zona e il numero di richieste di valutazione da Google è triplicato.
        </blockquote>
        <div class="font-bold text-gray-900">D. Romano</div>
        <div class="text-gray-600">Romano Immobiliare, Bari</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+91 recensioni in 8 mesi · richieste di valutazione ×3</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per agenzia · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "Dashboard multi-agente",
              "Trigger su rogito e contratti",
              "Filtro recensioni negative",
              "Report per agente",
              "Risposte professionali",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Avvocati", href: "/it/per/avvocati/" },
            { name: "Consulenti Finanziari", href: "/it/per/consulenti-finanziari/" },
            { name: "Commercialisti", href: "/it/per/commercialisti/" },
            { name: "Ispettori Immobiliari", href: "/it/per/ispettori-immobiliari/" },
            { name: "Imprenditori Edili", href: "/it/per/imprenditori-edili/" },
            { name: "Coperture", href: "/it/per/coperture/" },
            { name: "Assicurazioni", href: "/it/per/assicurazioni/" },
            { name: "Idraulici", href: "/it/per/idraulici/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia a Ricevere Più Richieste di Valutazione
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
