---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono fondamentali per un ristorante?",
    a: "L'86% delle persone controlla le recensioni Google prima di scegliere dove mangiare. Per i ristoranti, le recensioni sono il principale fattore che determina la scelta — più delle guide gastronomiche, dei social media o del passaparola. Un ristorante con 200 recensioni a 4.7 stelle riceve il 70% in più di prenotazioni rispetto a uno con 40 recensioni."
  },
  {
    q: "Come funziona la raccolta automatica di recensioni per i ristoranti?",
    a: "theStacc invia automaticamente un SMS o email al cliente dopo ogni visita. Per i ristoranti, puoi integrare il sistema con il tuo POS o sistema di prenotazione. Il messaggio viene inviato 1-2 ore dopo il pasto — quando il cliente è ancora soddisfatto ma ha già avuto il tempo di assaporare l'esperienza."
  },
  {
    q: "theStacc funziona anche per i ristoranti con delivery e asporto?",
    a: "Sì. Puoi configurare sequenze diverse per clienti del ristorante, delivery e asporto. Per il delivery, la richiesta parte quando l'ordine viene consegnato. Ogni canale ha il suo messaggio personalizzato per massimizzare il tasso di risposta."
  },
  {
    q: "Come gestisce theStacc le recensioni negative per un ristorante?",
    a: "theStacc include un filtro pre-pubblicazione: i clienti che esprimono insoddisfazione vengono indirizzati a un canale privato, permettendoti di rispondere e risolvere prima che la recensione diventi pubblica. Questo riduce significativamente le recensioni negative su Google."
  },
  {
    q: "Posso usare theStacc se ho più ristoranti o punti vendita?",
    a: "Sì. theStacc supporta la gestione di più location dalla stessa dashboard. Le recensioni vengono tracciate per sede, permettendoti di monitorare le performance di ogni locale separatamente e identificare dove intervenire."
  },
  {
    q: "theStacc si integra con i sistemi di prenotazione come TheFork o OpenTable?",
    a: "theStacc si integra con i principali sistemi di prenotazione e POS. Per i sistemi non ancora integrati nativamente, puoi importare i dati dei clienti tramite CSV o webhook. Il team di supporto ti aiuta a configurare l'integrazione più adatta al tuo setup."
  },
  {
    q: "Quante nuove recensioni posso aspettarmi al mese per il mio ristorante?",
    a: "I ristoranti che usano theStacc raccolgono tipicamente 20-50 nuove recensioni al mese, a seconda del volume di coperti. Con un tasso di conversione medio del 25-30%, ogni 100 clienti puoi aspettarti 25-30 nuove recensioni — una crescita molto rapida della tua reputazione online."
  },
  {
    q: "Qual è il costo di theStacc per un ristorante?",
    a: "theStacc parte da $49 al mese per un locale. Il piano include automazione illimitata per tutti i canali (sala, delivery, asporto), filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Ristoranti",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per ristoranti e locali. Automatizza la raccolta di recensioni dopo ogni pasto e aumenta la visibilità su Google Maps e nelle ricerche locali.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Ristoranti", "item": "https://thestacc.com/it/per/ristoranti/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Ristoranti | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i coperti del tuo ristorante con le recensioni Google automatizzate. theStacc raccoglie recensioni dopo ogni pasto e porta il tuo locale in cima a Google Maps." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Ristoranti · Pizzerie · Trattorie · Bar</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Coperti per il Tuo Ristorante<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          1,8 milioni di italiani cercano dove mangiare su Google ogni mese. Chi ha più recensioni vince la serata. theStacc raccoglie le tue recensioni automaticamente dopo ogni pasto, ogni giorno.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">1.8M</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">86%</div>
            <div class="text-gray-400 text-sm">controlla le recensioni prima di scegliere</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.4×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Integrazione POS", "Multi-locale", "Supporto in Italiano", "GDPR Compliant"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Integrazione POS", "Multi-locale", "Supporto in Italiano", "GDPR Compliant"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema dei Ristoranti senza Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          La cucina eccellente non basta. Se Google non ti conosce, i tavoli restano vuoti.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Chi ha Più Stelle Riempie Prima</h3>
            <p class="text-gray-600">Quando qualcuno cerca "ristorante italiano vicino a me", Google mostra prima chi ha più recensioni aggiornate. Un concorrente con 150 recensioni ti batte — anche se il tuo cibo è migliore.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">I Clienti Felici Non Tornano a Scrivere</h3>
            <p class="text-gray-600">Il cliente ha mangiato bene, è uscito soddisfatto. Ma tra casa, lavoro e tutto il resto, la recensione viene dimenticata. Solo chi insoddisfatto ha la motivazione di farlo spontaneamente.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Servizio Serale Non Lascia Tempo</h3>
            <p class="text-gray-600">Il personale è impegnato con i tavoli, la cucina, le ordinazioni. Non c'è un secondo per pensare a chiedere recensioni. E così la reputazione online non cresce mai quanto quella fisica.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Recensioni per la Ristorazione
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc lavora automaticamente mentre tu servi i tuoi clienti.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Richieste Post-Pasto Automatiche",
              desc: "Il cliente riceve un SMS 1-2 ore dopo la cena con link diretto a Google. Timing perfetto: soddisfazione alta, distanza dalla coda sufficiente."
            },
            {
              title: "Canali Multipli: Sala, Delivery, Asporto",
              desc: "Messaggi diversi per ogni canale di servizio. Il cliente del delivery riceve la richiesta quando l'ordine è consegnato."
            },
            {
              title: "Filtro Esperienze Negative",
              desc: "I clienti insoddisfatti vengono intercettati prima della pubblicazione. Gestisci il problema privatamente — solo le esperienze positive arrivano su Google."
            },
            {
              title: "Dashboard Multi-Locale",
              desc: "Gestisci tutti i tuoi locali da un unico pannello. Confronta le performance tra sedi e identifica le aree di miglioramento."
            },
            {
              title: "Risposta alle Recensioni",
              desc: "Rispondi a tutte le recensioni da theStacc. Una risposta personalizzata del ristoratore mostra cura ai futuri clienti che leggono prima di prenotare."
            },
            {
              title: "Integrazione POS e Prenotazioni",
              desc: "Si integra con i principali sistemi POS e di prenotazione. Ogni tavolo chiuso innesca automaticamente la sequenza di richiesta."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Setup in un pomeriggio, poi tutto gira in automatico.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega Google Business e il tuo sistema di cassa", desc: "Connetti il profilo Google Business del ristorante e integra il tuo POS o sistema di prenotazione. Nessuna competenza tecnica necessaria." },
            { step: "2", title: "Configura i canali e i messaggi", desc: "Imposta i messaggi per sala, delivery e asporto. Personalizza il timing e il tono — formale per il fine dining, informale per la pizzeria." },
            { step: "3", title: "Le recensioni arrivano ogni giorno", desc: "Da quel momento, ogni cliente riceve la sua richiesta al momento giusto. Tu cucini, le recensioni si accumulano su Google Maps automaticamente." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          La Ristorazione Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che dimostrano perché le recensioni riempiono i ristoranti.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "1.8M", label: "Ricerche mensili per ristoranti in Italia" },
            { value: "86%", label: "controlla le recensioni prima di scegliere" },
            { value: "4.4×", label: "più prenotazioni con profilo Maps ottimizzato" },
            { value: "70%", label: "più prenotazioni con 200+ recensioni vs 40" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Avevamo 34 recensioni in 6 anni. Con theStacc ne raccogliamo in media 35 al mese. In 5 mesi siamo saliti al primo posto su Google Maps per la nostra zona e il sabato sera siamo pieni fino alle 23. I tavoli del venerdì si prenotano con una settimana di anticipo.
        </blockquote>
        <div class="font-bold text-gray-900">G. Marchetti</div>
        <div class="text-gray-600">Ristorante Marchetti, Firenze</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+35 recensioni/mese · sabato sempre pieno</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per locale · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "Sala + Delivery + Asporto",
              "Integrazione POS e prenotazioni",
              "Filtro recensioni negative",
              "Dashboard multi-locale",
              "Risposte alle recensioni",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Parrucchieri", href: "/it/per/parrucchieri/" },
            { name: "Palestre", href: "/it/per/palestre/" },
            { name: "Servizi Animali", href: "/it/per/servizi-animali/" },
            { name: "Dentisti", href: "/it/per/dentisti/" },
            { name: "Fotografi", href: "/it/per/fotografi/" },
            { name: "Matrimoni", href: "/it/per/matrimoni/" },
            { name: "Terapeuti", href: "/it/per/terapeuti/" },
            { name: "Veterinari", href: "/it/per/veterinari/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia a Riempire i Tavoli con Google
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
