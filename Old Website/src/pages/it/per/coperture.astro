---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Perché le recensioni Google sono importanti per le imprese di coperture?",
    a: "La sostituzione o riparazione di un tetto è un investimento significativo — spesso tra 5.000 e 30.000 euro. I clienti si affidano quasi esclusivamente alle recensioni online per scegliere un'impresa affidabile. Il 76% legge almeno 8 recensioni prima di richiedere un preventivo. Con molte recensioni positive, la tua impresa viene percepita come scelta sicura."
  },
  {
    q: "Come funziona la raccolta automatica di recensioni per le imprese di coperture?",
    a: "Dopo ogni lavoro completato, theStacc invia automaticamente un SMS o email al cliente con un link diretto alla tua pagina Google. Il messaggio è personalizzato con il nome del cliente e il tipo di intervento svolto, e viene inviato nel momento ottimale dopo il completamento del cantiere."
  },
  {
    q: "Il settore delle coperture ha lavori lunghi — quando si chiede la recensione?",
    a: "Per i lavori lunghi (rifacimento completo, più settimane), theStacc ti permette di scegliere il trigger: puoi inviare la richiesta alla fine del cantiere, al saldo finale, oppure qualche giorno dopo per dare al cliente il tempo di apprezzare il risultato. La flessibilità del timing è fondamentale in questo settore."
  },
  {
    q: "Come gestisce theStacc le recensioni negative nel settore coperture?",
    a: "Le controversie sui tetti (infiltrazioni post-lavoro, ritardi) possono generare recensioni molto negative. theStacc include un filtro pre-pubblicazione: i clienti insoddisfatti vengono intercettati e indirizzati a un canale privato per la risoluzione. Solo i clienti soddisfatti ricevono la richiesta di recensione pubblica."
  },
  {
    q: "theStacc funziona anche per i lavori di manutenzione ordinaria dei tetti?",
    a: "Sì. Puoi configurare richieste diverse per interventi di manutenzione, riparazioni d'emergenza e rifacimenti completi. Ogni tipo di intervento ha il suo messaggio personalizzato e il timing ottimale per massimizzare il tasso di risposta."
  },
  {
    q: "Le recensioni aiutano in caso di danni da grandine o eventi atmosferici?",
    a: "Assolutamente. Dopo eventi atmosferici importanti, molti proprietari cercano urgentemente un'impresa di coperture. Essere il primo risultato su Google Maps con molte recensioni positive significa ricevere decine di chiamate quando la domanda è al massimo."
  },
  {
    q: "Posso gestire più cantieri attivi contemporaneamente con theStacc?",
    a: "Sì. theStacc gestisce automaticamente più clienti contemporaneamente. Puoi importare l'elenco dei cantieri attivi e il sistema si occupa di inviare le richieste a ciascun cliente al momento giusto, senza che tu debba gestire nulla manualmente."
  },
  {
    q: "Qual è il costo di theStacc per un'impresa di coperture?",
    a: "theStacc parte da $49 al mese. Include automazione illimitata, SMS ed email, filtro recensioni negative, dashboard analitica e supporto in italiano. Prova gratuita 14 giorni senza carta di credito."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Imprese di Coperture",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di gestione recensioni Google per imprese di coperture e tetti. Automatizza la raccolta di recensioni dopo ogni cantiere e aumenta la visibilità locale.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Settori", "item": "https://thestacc.com/it/per/" },
        { "@type": "ListItem", "position": 3, "name": "Coperture", "item": "https://thestacc.com/it/per/coperture/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---
<BaseLayout title="SEO per Imprese di Coperture | Più Clienti con le Recensioni Google | theStacc" description="Aumenta i cantieri della tua impresa di coperture con le recensioni Google automatizzate. theStacc raccoglie recensioni dopo ogni lavoro e ti posiziona in cima a Google Maps." lang="it">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-[#0d1117] pt-24 pb-20 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[#4f39f6]/20 via-transparent to-transparent pointer-events-none"></div>
      <div class="max-w-6xl mx-auto px-6 relative">
        <div class="inline-flex items-center gap-2 bg-[#4f39f6]/10 border border-[#4f39f6]/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-[#4f39f6] inline-block"></span>
          <span class="text-[#a78bfa] text-sm font-medium">Coperture · Tetti · Impermeabilizzazioni</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight max-w-4xl">
          Più Cantieri per la Tua Impresa di Coperture<br />
          <span class="text-[#4f39f6]">con le Recensioni Google</span>
        </h1>
        <p class="text-xl text-gray-300 mb-10 max-w-2xl">
          390.000 italiani cercano un'impresa di coperture ogni mese. Per un lavoro così importante, la fiducia è tutto. theStacc raccoglie le tue recensioni automaticamente dopo ogni cantiere completato.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a href="/it/inizia/" class="bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Inizia Gratis — 14 Giorni
          </a>
          <a href="/it/demo/" class="border border-gray-600 hover:border-gray-400 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors text-center">
            Guarda la Demo
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">390K</div>
            <div class="text-gray-400 text-sm">ricerche/mese in Italia</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">76%</div>
            <div class="text-gray-400 text-sm">cerca online prima di chiamare</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">4.7×</div>
            <div class="text-gray-400 text-sm">più visibilità su Maps</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-gray-400 text-sm">recensioni catturate</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Social Proof Strip -->
    <section class="bg-white border-y border-gray-100 py-6 overflow-hidden">
      <div class="flex gap-12 animate-marquee whitespace-nowrap">
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Timing Flessibile", "Usato da 500+ Imprese"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
        {["Google Business", "4.9★ Media Recensioni", "Setup in 5 Minuti", "Nessuna Carta di Credito", "Supporto in Italiano", "GDPR Compliant", "Timing Flessibile", "Usato da 500+ Imprese"].map(item => (
          <span class="text-gray-500 font-medium text-sm flex-shrink-0">✦ {item}</span>
        ))}
      </div>
    </section>

    <!-- Pain Agitation -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Problema delle Imprese di Coperture senza Recensioni
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          Per un lavoro da decine di migliaia di euro, i clienti cercano certezze. Senza recensioni, non le trovano da te.
        </p>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Chi ha Più Recensioni Vince il Preventivo</h3>
            <p class="text-gray-600">Quando un proprietario chiede tre preventivi, spesso scegli anche in base alla reputazione online. Un'impresa con 60 recensioni a 4.9 stelle viene preferita — anche con un prezzo leggermente più alto.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Il Cliente Ringrazia — ma Non Scrive</h3>
            <p class="text-gray-600">Il cantiere finisce, il cliente è contento del tetto nuovo. Ma tra pensieri quotidiani e la vita che va avanti, la recensione promessa non arriva mai. Senza un follow-up automatico, quella soddisfazione rimane muta.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
            <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Dopo Grandine e Tempeste, Chi Non è su Maps Perde</h3>
            <p class="text-gray-600">Dopo eventi atmosferici intensi, centinaia di persone cercano "rifacimento tetto" su Google. Se non sei in cima con buone recensioni, tutta quella domanda improvvisa va ai concorrenti.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">
          Il Sistema di Reputazione per le Coperture
        </h2>
        <p class="text-gray-600 text-center mb-12 max-w-2xl mx-auto">
          theStacc raccoglie le recensioni al momento giusto per ogni tipo di intervento.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: "Timing Flessibile per Cantieri Lunghi",
              desc: "Configura il trigger per partire alla fine del cantiere, al saldo o qualche giorno dopo. Il momento giusto dipende dal tipo di lavoro — theStacc si adatta."
            },
            {
              title: "Filtro Pre-Pubblicazione",
              desc: "I clienti insoddisfatti vengono intercettati prima della pubblicazione. Gestisci il problema privatamente con professionalità."
            },
            {
              title: "Messaggi per Tipo di Intervento",
              desc: "Rifacimento completo, manutenzione, emergenza post-tempesta — messaggi personalizzati per ogni scenario aumentano il tasso di risposta."
            },
            {
              title: "Dashboard Cantieri",
              desc: "Visualizza lo stato delle richieste per ogni cantiere. Vedi chi ha risposto, chi ha lasciato la recensione e chi ha bisogno di un follow-up."
            },
            {
              title: "Risposta alle Recensioni",
              desc: "Rispondi a tutte le recensioni direttamente da theStacc. Ogni risposta professionale rafforza la tua immagine agli occhi dei futuri clienti."
            },
            {
              title: "Report Settimanali",
              desc: "Ogni settimana ricevi un riepilogo: nuove recensioni, punteggio medio, cantieri in attesa. Tieni tutto sotto controllo senza aprire Google Business."
            }
          ].map(feature => (
            <div class="p-6 rounded-2xl border border-gray-100 hover:border-[#4f39f6]/30 hover:shadow-md transition-all">
              <div class="w-10 h-10 bg-[#4f39f6]/10 rounded-lg flex items-center justify-center mb-4">
                <svg class="w-5 h-5 text-[#4f39f6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-4">Come Funziona</h2>
        <p class="text-gray-600 text-center mb-12">Tre passi per iniziare a raccogliere recensioni.</p>
        <div class="space-y-8">
          {[
            { step: "1", title: "Collega Google Business", desc: "Connetti il profilo Google Business della tua impresa in pochi clic. Il processo guidato richiede meno di 10 minuti." },
            { step: "2", title: "Configura il timing e i messaggi per ogni tipo di intervento", desc: "Imposta quando partono le richieste e personalizza i messaggi. Rifacimento completo, manutenzione, emergenza — ognuno ha il suo template." },
            { step: "3", title: "Le recensioni arrivano automaticamente", desc: "Da quel momento, ogni cantiere completato genera una richiesta automatica. Tu lavori sui tetti, le recensioni su Google si accumulano." }
          ].map(item => (
            <div class="flex gap-6 items-start">
              <div class="w-12 h-12 bg-[#4f39f6] rounded-full flex items-center justify-center flex-shrink-0 text-white font-bold text-lg">
                {item.step}
              </div>
              <div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Dark Metrics -->
    <section class="py-20 bg-[#0d1117]">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4">
          Il Settore Coperture Online in Italia
        </h2>
        <p class="text-gray-400 text-center mb-12">I numeri che spiegano perché la reputazione online vale ogni euro investito.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: "390K", label: "Ricerche mensili per coperture in Italia" },
            { value: "76%", label: "legge le recensioni prima di chiamare" },
            { value: "4.7×", label: "più richieste di preventivo con Maps ottimizzato" },
            { value: "89%", label: "sceglie tra i primi 3 risultati su Maps" }
          ].map(stat => (
            <div class="text-center">
              <div class="text-4xl font-bold text-[#4f39f6] mb-2">{stat.value}</div>
              <div class="text-gray-400 text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-20 bg-[#f5f3ff]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="text-5xl text-[#4f39f6] mb-6">"</div>
        <blockquote class="text-2xl font-medium text-gray-900 mb-8 leading-relaxed">
          Lavoravamo solo di passaparola e avevamo 8 recensioni. Con theStacc dopo 6 mesi ne abbiamo 58 nuove. Siamo il primo risultato su Google Maps per la nostra provincia e riceviamo richieste di preventivo da tutta la zona. Il fatturato è aumentato del 40%.
        </blockquote>
        <div class="font-bold text-gray-900">L. Amato</div>
        <div class="text-gray-600">Amato Coperture e Impermeabilizzazioni, Catania</div>
        <div class="text-[#4f39f6] font-semibold mt-1">+58 recensioni in 6 mesi · +40% fatturato</div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 bg-white">
      <div class="max-w-lg mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Un Prezzo Semplice</h2>
        <p class="text-gray-600 mb-10">Nessun contratto. Nessuna sorpresa. Cancella quando vuoi.</p>
        <div class="border-2 border-[#4f39f6] rounded-2xl p-8 shadow-lg">
          <div class="text-5xl font-bold text-gray-900 mb-2">$49<span class="text-2xl font-normal text-gray-500">/mese</span></div>
          <div class="text-gray-600 mb-8">Per impresa · Tutto incluso</div>
          <ul class="text-left space-y-3 mb-8">
            {[
              "Richieste recensioni illimitate",
              "SMS + Email automatici",
              "Timing flessibile per cantieri",
              "Filtro recensioni negative",
              "Dashboard cantieri",
              "Report settimanali",
              "Supporto in italiano",
              "14 giorni gratis, no carta"
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-700">
                <svg class="w-5 h-5 text-[#4f39f6] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/it/inizia/" class="block w-full bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold py-4 rounded-xl text-lg transition-colors">
            Inizia la Prova Gratuita
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-12">Domande Frequenti</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <button class="faq-btn w-full text-left px-6 py-5 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                <span class="font-semibold text-gray-900">{faq.q}</span>
                <svg class="faq-icon-plus w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                <svg class="faq-icon-minus w-5 h-5 text-gray-400 flex-shrink-0 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="text-gray-600 leading-relaxed">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Other Industries -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">theStacc per Altri Settori</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: "Imprenditori Edili", href: "/it/per/imprenditori-edili/" },
            { name: "Idraulici", href: "/it/per/idraulici/" },
            { name: "Elettricisti", href: "/it/per/elettricisti/" },
            { name: "Climatizzazione", href: "/it/per/climatizzazione/" },
            { name: "Giardinieri", href: "/it/per/giardinieri/" },
            { name: "Pulizie", href: "/it/per/pulizie/" },
            { name: "Traslochi", href: "/it/per/traslochi/" },
            { name: "Ispettori Immobiliari", href: "/it/per/ispettori-immobiliari/" }
          ].map(industry => (
            <a href={industry.href} class="text-center py-4 px-4 rounded-xl border border-gray-200 hover:border-[#4f39f6] hover:text-[#4f39f6] text-gray-700 font-medium transition-colors text-sm">
              {industry.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-[#0d1117] relative overflow-hidden">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, #4f39f6/20 0%, transparent 70%);"></div>
      <div class="max-w-3xl mx-auto px-6 text-center relative">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Inizia a Ricevere Più Richieste di Preventivo
        </h2>
        <p class="text-gray-300 text-xl mb-10">
          14 giorni gratis. Nessuna carta di credito. Setup in meno di un'ora.
        </p>
        <a href="/it/inizia/" class="inline-block bg-[#4f39f6] hover:bg-[#4338ca] text-white font-semibold px-10 py-5 rounded-xl text-xl transition-colors">
          Prova theStacc Gratis
        </a>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
