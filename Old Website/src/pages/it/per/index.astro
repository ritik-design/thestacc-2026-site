---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const localSEO = [
  { label: 'Commercialisti',        href: '/it/per/commercialisti/'        },
  { label: 'Concessionarie Auto',   href: '/it/per/concessionarie-auto/'   },
  { label: 'Chiropratici',          href: '/it/per/chiropratici/'          },
  { label: 'Pulizie',               href: '/it/per/pulizie/'               },
  { label: 'Imprenditori Edili',    href: '/it/per/imprenditori-edili/'    },
  { label: 'Dentisti',              href: '/it/per/dentisti/'              },
  { label: 'Elettricisti',          href: '/it/per/elettricisti/'          },
  { label: 'Consulenti Finanziari', href: '/it/per/consulenti-finanziari/' },
  { label: 'Palestre',              href: '/it/per/palestre/'              },
  { label: 'Sanità',                href: '/it/per/sanita/'                },
  { label: 'Ispettori Immobiliari', href: '/it/per/ispettori-immobiliari/' },
  { label: 'Climatizzazione',       href: '/it/per/climatizzazione/'       },
  { label: 'Assicurazioni',         href: '/it/per/assicurazioni/'         },
  { label: 'Giardinieri',           href: '/it/per/giardinieri/'           },
  { label: 'Avvocati',              href: '/it/per/avvocati/'              },
  { label: 'Traslochi',             href: '/it/per/traslochi/'             },
  { label: 'Servizi Animali',       href: '/it/per/servizi-animali/'       },
  { label: 'Fotografi',             href: '/it/per/fotografi/'             },
  { label: 'Idraulici',             href: '/it/per/idraulici/'             },
  { label: 'Immobiliare',           href: '/it/per/immobiliare/'           },
  { label: 'Ristoranti',            href: '/it/per/ristoranti/'            },
  { label: 'Coperture',             href: '/it/per/coperture/'             },
  { label: 'Parrucchieri',          href: '/it/per/parrucchieri/'          },
  { label: 'Terapeuti',             href: '/it/per/terapeuti/'             },
  { label: 'Ripetizioni',           href: '/it/per/ripetizioni/'           },
  { label: 'Veterinari',            href: '/it/per/veterinari/'            },
  { label: 'Matrimoni',             href: '/it/per/matrimoni/'             },
];

const blogSEO = [
  { label: 'Studi di Consulenza',   href: '/it/per/consulenza/'            },
  { label: 'Ecommerce',             href: '/it/per/ecommerce/'             },
  { label: 'SaaS',                  href: '/it/per/saas/'                  },
];
---

<BaseLayout
  title="theStacc per Ogni Settore — Automazione SEO per Tipo di Business | theStacc"
  description="theStacc automatizza la SEO per 30+ settori — dalle attività locali alle aziende SaaS. Trova il tuo settore e scopri come theStacc aumenta il tuo traffico organico."
  lang="it"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
        <div class="mx-auto max-w-[680px] text-center">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">30 Settori · SEO Locale & Blog SEO</span>
          </div>
          <h1 class="font-sans text-[2.2rem] font-semibold leading-[1.15] tracking-[-0.035em] text-[#111827] md:text-[3rem]">
            SEO costruita per il tuo settore.
          </h1>
          <p class="mx-auto mt-5 max-w-[540px] font-sans text-[1.05rem] leading-[1.7] text-[#57534e]">
            Ogni settore ha parole chiave diverse, acquirenti diversi e segnali di ranking diversi. theStacc è addestrato sulla tua categoria — così i post, gli articoli e le ottimizzazioni che escono ogni mese sono specifici per come i tuoi clienti cercano davvero.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia a $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#292524] transition-colors hover:bg-[#fafaf9]">
              Vedi i prezzi
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- MODULE EXPLAINER -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="mx-auto max-w-6xl px-6 py-10">
        <div class="mx-auto grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-2">
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">SEO Locale</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$49/mese</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">Per le attività che dipendono dalla ricerca locale — post GBP, monitoraggio recensioni e rank tracking su Maps. Ideale per attività di servizi locali, esercizi fisici e chiunque voglia posizionarsi nel Map Pack.</p>
            </div>
          </div>
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">Blog SEO</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$99/mese</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">Per le aziende che crescono tramite contenuti organici — 30 articoli SEO pubblicati sul tuo sito ogni mese. Ideale per SaaS, ecommerce e servizi professionali in competizione a livello nazionale.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LOCAL SEO INDUSTRIES -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Modulo SEO Locale</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$49/mese · {localSEO.length} settori</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Attività di servizi locali
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            Post GBP, gestione recensioni e rank tracking nel Map Pack — tutto automatizzato.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {localSEO.map(item => (
            <a href={item.href} class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]">
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- BLOG SEO INDUSTRIES -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Modulo Blog SEO</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$99/mese · {blogSEO.length} settori</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Aziende guidate dai contenuti
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            30 articoli SEO pubblicati sul tuo sito ogni mese — ricercati, scritti e pubblicati.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3">
          {blogSEO.map(item => (
            <a href={item.href} class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]">
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- DARK CTA -->
    <section class="relative overflow-hidden py-16 md:py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.18) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.03) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="mx-auto max-w-6xl px-6 relative">
        <div class="mx-auto max-w-xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Non vedi il tuo settore?</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.03em] text-[#292524] md:text-[2.4rem]">
            theStacc funziona per qualsiasi<br />attività che ha bisogno di traffico organico.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Se i tuoi clienti ti cercano su Google, theStacc può automatizzare la SEO che ti fa trovare. Prenota una demo e ti mostreremo come funziona per la tua attività specifica.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Prenota una demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff] bg-white">
              Vedi i prezzi
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
