---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il franchising SEO?", a: "Il franchising SEO è l'ottimizzazione della visibilità nelle ricerche locali per i business in franchising su più sedi. Ogni punto franchising ha bisogno del proprio profilo Google Business gestito, delle citazioni locali mantenute e dei ranking tracciati — mantenendo la coerenza del brand su tutta la rete." },
  { q: "Qual è la sfida SEO principale per i franchising?", a: "La coerenza a scala. Ogni sede ha bisogno dello stesso lavoro SEO di base eseguito correttamente — citazioni accurate, GBP attivo, profilo recensioni forte. Con 50 o 500 sedi, non è possibile farlo manualmente. Le sedi che ricevono attenzione si posizionano. Quelle trascurate no. L'automazione è l'unico modo per applicare un impegno SEO costante su tutta la rete." },
  { q: "Come gestisce Stacc il rapporto franchisor/franchisee?", a: "Stacc supporta l'accesso a più livelli. I franchisor hanno una vista portfolio di tutte le sedi con confronto delle performance. I franchisee possono accedere alla dashboard della propria sede. Gestione centralizzata e visibilità individuale possono coesistere nella stessa piattaforma." },
  { q: "Stacc può gestire GBP per 200 sedi in franchising?", a: "Sì. Stacc pubblica post GBP su tutte le sedi simultaneamente. Gli aggiornamenti in blocco di orari, descrizioni e attributi si applicano a tutta la rete in una singola azione. Non c'è un limite pratico al numero di sedi." },
  { q: "Come si mantiene la coerenza del brand nei post GBP su più sedi?", a: "La pubblicazione in blocco di Stacc permette di scrivere un post una volta e pubblicarlo su tutte le sedi simultaneamente. Puoi aggiungere personalizzazioni locali (indirizzo, telefono locale, hashtag locali) prima della pubblicazione in blocco. Il brand rimane coerente; i dettagli vengono localizzati." },
  { q: "Quanto velocemente posso aggiungere una nuova sede?", a: "Circa 2 minuti. Inserisci i dati aziendali di base, connetti il profilo GBP e Stacc propaga automaticamente la configurazione su tutta la rete di citazioni. Nessuna registrazione manuale directory per directory." },
  { q: "Quanto costa il software SEO per franchising?", a: "Il modulo SEO locale di Stacc parte da $49/mese e include tutte le funzionalità di gestione franchising e multi-sede." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Franchising SEO",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automazione SEO per franchising: GBP, citazioni, ranking e report su ogni sede della rete simultaneamente. Gestione centralizzata con accesso franchisee individuale.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Franchising SEO", "item": "https://thestacc.com/it/franchising-seo/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Franchising SEO — Automatizza il SEO Locale su Tutta la Rete | theStacc"
  description="SEO franchising a scala richiede automazione. theStacc gestisce GBP, citazioni, rank tracking e report per ogni sede della rete simultaneamente — brand coerente, performance locale."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Franchising SEO · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO franchising che funziona<br />
            <span style="color:#4f39f6;">su tutta la rete.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Ogni sede franchising ha bisogno di lavoro SEO locale costante e quotidiano per posizionarsi nel suo mercato. Stacc automatizza quel lavoro su tutta la rete — così ogni sede compete al massimo, non solo quelle che qualcuno si è ricordato di aggiornare.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Scopri le funzionalità
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- IL PROBLEMA DEL FRANCHISING SEO -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema del franchising SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alcune sedi si posizionano. La maggior parte no.<br />La differenza è l'esecuzione SEO costante.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              In ogni rete franchising c'è un pattern ricorrente: un gruppo di sedi top performer che si posizionano costantemente e una lunga coda di underperformer invisibili nelle ricerche locali. La differenza quasi mai è la qualità del servizio — è la qualità dell'esecuzione SEO locale. Le sedi che si posizionano hanno profili GBP attivi, citazioni coerenti e recensioni recenti. Quelle invisibili hanno schede GBP non aggiornate, dati NAP inconsistenti e profili abbandonati.
            </p>
            <p>
              Il motivo non è la negligenza — è la capacità. Non c'è modo di mantenere manualmente un SEO locale adeguato su 50 o 500 sedi. Qualcosa viene sempre saltato. Stacc garantisce che niente venga saltato automatizzando ogni attività SEO ricorrente per ogni sede ogni giorno.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Funzionalità SEO franchising</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni sede. Ogni attività.<br />Tutto automatizzato.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Gestione GBP in blocco', body: 'Pubblica post su tutte le sedi franchising simultaneamente. Aggiorna orari, descrizioni e attributi per l\'intera rete in una singola azione.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rank tracking per sede', body: 'Ranking giornalieri per ogni sede in local pack, Maps e organico. Confronta tutte le sedi fianco a fianco per identificare i mercati da rafforzare.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoraggio coerenza NAP', body: 'Rileva e correggi inconsistenze NAP su 50+ directory per ogni sede. La coerenza delle citazioni è un fattore di ranking fondamentale per il local SEO.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitoraggio recensioni per sede', body: 'Avvisi recensioni in tempo reale per ogni sede. Rispondi da una dashboard centralizzata. Traccia il punteggio medio e il volume per sede.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Report performance rete', body: 'Dashboard portfolio confronta tutte le sedi. Identifica top e bottom performer istantaneamente. Report automatici per l\'intera rete o sedi singole.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Accesso franchisor e franchisee', body: 'I franchisor vedono l\'intera rete. I franchisee vedono le proprie sedi. Gestione centralizzata con responsabilità individuale.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- METRICHE DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '500+', label: 'Sedi in un account franchising', sub: 'Nessun personale per sede necessario' },
            { value: '2 min', label: 'Per aggiungere una nuova sede', sub: 'Da zero a gestione completa' },
            { value: '89%', label: 'Miglioramento ranking GBP in 90 giorni', sub: 'Attività costante vs profilo inattivo' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── PANORAMICA PIATTAFORMA ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">L'approccio Stacc al franchising SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tre livelli di lavoro SEO,<br />uno per ogni canale di acquisizione locale.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['GBP attivo per ogni sede della rete', 'Citazioni coerenti su 50+ directory', 'Recensioni monitorate per sede', 'Rank tracking giornaliero per sede'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['Hub di contenuti centrale del franchisor', 'Articoli sui temi cercati dai clienti', 'Link verso le pagine sede locale', 'Posizionamento sui topic di categoria'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post per sede su Facebook e Instagram', 'Pubblicazione in blocco multi-sede', 'Brand di rete coerente', 'Personalizzazione locale automatica'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">La metodologia franchising SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tre pilastri che separano le sedi visibili<br />dalle sedi invisibili.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP attivo -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pilastro 1 · Attività GBP costante</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Google premia le sedi che pubblicano. Penalizza quelle silenziose.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                L'algoritmo di Maps usa la frequenza di pubblicazione GBP come segnale di vitalità della sede. Una sede che pubblica almeno due volte a settimana per 90 giorni consecutivi ottiene mediamente un boost significativo nel local pack rispetto a una sede inattiva. In un sistema franchising, l'unico modo per garantire questa frequenza su 50, 100 o 500 sedi è automatizzare la pubblicazione dal centro — con personalizzazione locale per non finire nella zona del contenuto duplicato.
              </p>
              <a href="/it/software-google-business-profile/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri la gestione GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posizione local pack vs frequenza GBP</p>
              {[
                { label: 'Sede con 0 post/mese', val: 'Posizione media #11', class: 'text-[#b91c1c]' },
                { label: 'Sede con 4 post/mese', val: 'Posizione media #6', class: 'text-[#a16207]' },
                { label: 'Sede con 12 post/mese', val: 'Posizione media #3', class: 'text-[#059669]' },
                { label: 'Sede con 30 post/mese', val: 'Posizione media #1.8', class: 'text-[#059669]' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class={`font-sans text-[13px] font-semibold ${row.class}`}>{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Dati medi · 90 giorni · Reti franchising su Stacc</p>
            </div>
          </div>

          <!-- Coerenza NAP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Coerenza NAP · Distribuzione tipica</p>
              {[
                { label: 'Sede con NAP coerente al 95%+', val: 'Trust score alto', icon: 'check' },
                { label: 'Sede con NAP coerente al 70–95%', val: 'Trust score medio', icon: 'warn' },
                { label: 'Sede con NAP coerente <70%', val: 'Trust score basso', icon: 'x' },
                { label: 'Stacc target di rete', val: '99% coerenza media', icon: 'check' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class={`font-mono text-[11px] font-semibold ${row.icon === 'check' ? 'text-[#059669]' : row.icon === 'warn' ? 'text-[#a16207]' : 'text-[#b91c1c]'}`}>{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ directory monitorate · Auto-correzione in blocco</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pilastro 2 · Coerenza NAP nelle citazioni</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Nome, indirizzo, telefono — identici ovunque o l'autorità della sede crolla.
