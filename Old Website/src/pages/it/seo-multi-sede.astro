---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il SEO multi-sede?", a: "Il SEO multi-sede è l'ottimizzazione della presenza locale nelle ricerche per un'azienda con più sedi fisiche. Comprende la gestione dei profili Google Business, la creazione di citazioni coerenti, il monitoraggio dei ranking per keyword per ogni sede, il monitoraggio delle recensioni e la pubblicazione di contenuti che targetizzano l'intento di ricerca locale per il mercato di ogni sede." },
  { q: "Perché il SEO multi-sede è più difficile del SEO per sede singola?", a: "Perché ogni attività si moltiplica per il numero di sedi. Rank tracking, gestione GBP, costruzione citazioni, monitoraggio recensioni e reportistica devono avvenire indipendentemente per ogni sede. Con 20+ sedi, la gestione manuale diventa un lavoro a tempo pieno per un intero team — ed è per questo che l'automazione è l'unico approccio scalabile." },
  { q: "Qual è il fattore più importante per posizionare più sedi su Google Maps?", a: "Dati NAP (Nome, Indirizzo, Telefono) coerenti su tutte le directory, gestione attiva del profilo Google Business con post e risposte alle domande regolari, e buon volume di recensioni con attività recente sono i tre fattori ad impatto più alto per i ranking su Maps a scala." },
  { q: "Come aiuta Stacc con il SEO multi-sede?", a: "Stacc automatizza la pubblicazione post GBP, il monitoraggio e la correzione delle citazioni, il rank tracking giornaliero e gli avvisi recensioni per ogni sede simultaneamente. Configuri ogni sede una volta e la piattaforma esegue le attività SEO automaticamente — così la manutenzione del ranking non richiede lavoro manuale quotidiano per sede." },
  { q: "Una persona può gestire il SEO per 50+ sedi?", a: "Con la giusta automazione, sì. I clienti di Stacc gestiscono portfolio di 500+ sedi senza personale SEO dedicato per sede. La chiave è automatizzare il lavoro quotidiano ripetitivo — attività GBP, monitoraggio citazioni, rank tracking, reportistica — così l'attenzione umana va alla strategia, non all'esecuzione." },
  { q: "Quanto tempo prima di vedere miglioramenti nei ranking?", a: "Le correzioni delle citazioni e i miglioramenti all'attività GBP mostrano tipicamente movimenti di ranking entro 4-8 settimane. La pubblicazione costante su GBP produce effetti composti in 3-6 mesi. Il timeline esatto dipende dalla baseline attuale, dalla competitività del mercato e dalla coerenza dell'attività." },
  { q: "Quanto costa Stacc per il SEO multi-sede?", a: "Il modulo SEO locale parte da $49/mese e copre tutte le funzionalità multi-sede tra cui gestione in blocco, reportistica portfolio e automazione a scala." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO Multi-Sede",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automatizza il SEO multi-sede per ogni sede. Rank tracking, gestione GBP, monitoraggio citazioni e reportistica — tutti in esecuzione simultanea per l\'intero portfolio.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "SEO Multi-Sede", "item": "https://thestacc.com/it/seo-multi-sede/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="SEO Multi-Sede — Automatizza il SEO Locale per Ogni Sede | theStacc"
  description="SEO multi-sede a scala richiede automazione. theStacc gestisce GBP, rank tracking, citazioni e report per ogni sede simultaneamente — senza aumentare il team."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Multi-Sede · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO multi-sede che scala<br />
            <span style="color:#4f39f6;">senza scalare il team.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Il SEO locale per 50 sedi richiede lo stesso lavoro quotidiano di quello per 1 — moltiplicato per 50. Stacc automatizza ogni attività per ogni sede in modo che il lavoro non si moltiplichi con il numero di sedi.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/software-seo-locale/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Scopri la piattaforma
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Portfolio di 500+ sedi gestiti</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Setup in meno di 5 minuti</span>
          </div>
        </div>
      </div>
    </section>


    <!-- IL PROBLEMA -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">La matematica che spezza il SEO multi-sede</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni sede richiede lo stesso lavoro.<br />La maggior parte dei team ne gestisce solo alcune.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Per una singola sede, il SEO locale è gestibile: aggiorna la scheda GBP, correggi le citazioni quando si deteriorano, rispondi alle recensioni, monitora qualche keyword. Forse 3-4 ore a settimana. Va bene per una sede.</p>
            <p>Moltiplicalo per 20 sedi. Il lavoro è lo stesso per sede — si ripete 20 volte. In pratica, alcune sedi ricevono attenzione e la maggior parte no. Le sedi curate si posizionano. Quelle trascurate no. Le performance del tuo portfolio sono limitate da quante sedi il tuo team può gestire manualmente.</p>
            <p class="font-semibold text-[#111827]">Stacc rompe questo vincolo. L'automazione gestisce il lavoro quotidiano ripetitivo per ogni sede contemporaneamente — attività GBP, monitoraggio citazioni, rank tracking, avvisi recensioni — così il tuo sforzo umano va alla strategia, non all'esecuzione. Il tuo portfolio di 50 sedi riceve la stessa cura costante che il tuo concorrente con una sede dà al suo unico listing.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa automatizza Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni attività SEO multi-sede.<br />In esecuzione automatica.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automazione post GBP', body: '30 post al mese per sede — pubblicati automaticamente per mantenere ogni profilo attivo e segnalare rilevanza all\'algoritmo Maps di Google.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rank tracking giornaliero', body: 'Ogni keyword, ogni sede, monitorato quotidianamente in local pack, Maps e organico. Vedi i trend di ranking per sede e individua gli underperformer prima che scendano ulteriormente.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Gestione citazioni', body: 'Monitora e correggi inconsistenze citazioni su 50+ directory per ogni sede. La coerenza NAP è uno dei fattori di ranking locali ad impatto più alto.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitoraggio recensioni', body: 'Avvisi in tempo reale per nuove recensioni su ogni sede. Rispondi direttamente dalla dashboard. Traccia velocità e punteggio medio per sede.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Gestione in blocco', body: 'Aggiorna orari, indirizzi, descrizioni e categorie per ogni sede simultaneamente. Aggiunta nuova sede in 2 minuti.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Reportistica portfolio', body: 'Report automatici per ogni sede, consegnati secondo calendario. Confronta tutte le sedi in una vista portfolio unificata. White-label per consegna clienti.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- METRICHE DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Cosa consegna l'automazione SEO multi-sede costante</span>
        </div>
        <div class="mx-auto mt-14 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '500+', label: 'Sedi in un portfolio', sub: 'Nessun personale per sede necessario' },
            { value: '89%', label: 'Miglioramento ranking GBP in 90 giorni', sub: 'Attività costante vs baseline inattiva' },
            { value: '45 min', label: 'Tempo di onboarding medio', sub: 'Da zero al primo report automatico' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Una piattaforma. Ogni sede.</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tre moduli che lavorano in parallelo<br />su tutto il tuo portfolio.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['30 post GBP per sede al mese', 'Rank tracking giornaliero', 'Citazioni 50+ directory', 'Recensioni multi-piattaforma'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli al mese', 'Pagine "servizio + città"', 'Pubblicazione automatica', 'Internal linking ottimizzato'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri per sede', 'Instagram, Facebook, GBP', 'Programmati automaticamente', 'Coerenti con il brand'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Approccio multi-sede.<br />Esecuzione simultanea su tutte.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Block 1: Portfolio Dashboard -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Vista portfolio unificata</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Vedi tutte le sedi in un colpo d'occhio. Identifica chi cresce e chi cala in tre secondi.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Una dashboard portfolio mostra ogni sede con ranking medio, nuove recensioni, stato delle citazioni e attività GBP. Le sedi con cali significativi salgono in cima alla lista. Le sedi senza problemi restano in fondo. Smetti di passare ore a confrontare report sede per sede — l'attenzione va dove serve in automatico.
              </p>
              <a href="/it/software-seo-multi-sede/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il software multi-sede
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Portfolio · Top sedi questa settimana</p>
              {[
                { sede: 'Milano Centro', rank: '#2', delta: '+1', trend: 'up' },
                { sede: 'Roma Prati', rank: '#3', delta: '+2', trend: 'up' },
                { sede: 'Torino Crocetta', rank: '#5', delta: '0', trend: 'flat' },
                { sede: 'Bologna Centro', rank: '#7', delta: '-1', trend: 'down' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.sede}</span>
                  <div class={`flex h-7 w-12 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${parseInt(r.rank.replace('#','')) <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>{r.rank}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : r.trend === 'down' ? 'text-[#dc2626]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : r.trend === 'down' ? '↓' : '→'} {r.delta}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Aggiornato giornalmente · Tutte le sedi · Una vista</p>
            </div>
          </div>

          <!-- Block 2: Bulk Actions -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Aggiornamento in blocco · 27 sedi</p>
              <div class="space-y-3">
                {[
                  { campo: 'Orario apertura domenica', stato: 'Aggiornato' },
                  { campo: 'Foto profilo GBP', stato: 'Pubblicato' },
                  { campo: 'Descrizione attività', stato: 'Pubblicato' },
                  { campo: 'Categoria secondaria', stato: 'Aggiornato' },
                ].map(r => (
