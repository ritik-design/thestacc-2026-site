---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "Cos'è l'automazione SEO locale?",
    a: "L'automazione SEO locale consiste nell'usare software per gestire le attività ripetitive e ad alto dispendio di tempo che guidano il posizionamento locale — pubblicazione di post su GBP, monitoraggio citazioni, avvisi recensioni, rank tracking e generazione di report — senza richiedere intervento manuale ogni volta. Invece di accedere ogni giorno per controllare e aggiornare, configuri le regole una volta e il software le esegue continuativamente.",
  },
  {
    q: "Quali attività SEO locali automatizza Stacc?",
    a: "Stacc automatizza la pubblicazione di post su GBP (30 post al mese per sede), il rank tracking giornaliero su local pack e organico, il monitoraggio delle recensioni in tempo reale con avvisi, il monitoraggio dell'accuratezza delle citazioni su 50+ directory e la generazione e consegna di report clienti white-label. Queste sono le cinque attività manuali a più alto volume nel SEO locale — e Stacc le gestisce tutte in automatico.",
  },
  {
    q: "Quante ore risparmia l'automazione SEO locale?",
    a: "Le attività e le agenzie che usano Stacc riportano un risparmio medio di 8 ore per cliente al mese rispetto alla gestione manuale dello stesso lavoro. Per un'agenzia con 20 clienti, sono 160 ore al mese — circa un dipendente a tempo pieno — recuperate senza ridurre la qualità.",
  },
  {
    q: "L'automazione SEO locale migliora davvero il posizionamento?",
    a: "Sì, quando eseguita con costanza. L'algoritmo di Google Maps premia i profili GBP attivi e coerenti con dati di citazioni accurati. Il problema con il SEO locale manuale è l'inconsistenza — passano settimane senza post su GBP, le citazioni si discostano e le risposte alle recensioni rallentano. L'automazione garantisce che i segnali che Google cerca vengano inviati costantemente, ogni giorno, per ogni sede.",
  },
  {
    q: "Stacc può automatizzare il SEO locale per più sedi contemporaneamente?",
    a: "Sì. Stacc è progettato per la gestione multi-sede. Puoi pubblicare post su GBP per tutte le sedi simultaneamente (o pianificare contenuti specifici per sede), tracciare il ranking per ogni sede indipendentemente, monitorare le recensioni su tutti i GBP in un unico feed e generare report separati o aggregati per sede.",
  },
  {
    q: "L'automazione SEO locale è adatta alle agenzie?",
    a: "L'automazione SEO locale è particolarmente potente per le agenzie perché il risparmio di tempo si moltiplica per ogni cliente. Stacc offre alle agenzie reportistica white-label (consegnata con il tuo brand), gestione account multi-cliente e la capacità di gestire decine di clienti allo stesso livello di qualità che prima richiedeva un dipendente dedicato ogni 5–10 clienti.",
  },
  {
    q: "L'automazione sostituisce la necessità di una strategia SEO?",
    a: "No — l'automazione gestisce l'esecuzione, non la strategia. Sei tu a decidere quali keyword targettare, quali servizi promuovere e come posizionare ogni sede. Stacc poi esegue quella strategia in modo coerente — pubblicando il contenuto giusto, tracciando le keyword giuste, monitorando i segnali giusti — così la strategia viene effettivamente implementata invece di restare in un documento.",
  },
  {
    q: "Quanto tempo ci vuole per vedere risultati dall'automazione SEO locale?",
    a: "La maggior parte delle attività registra i primi movimenti di ranking entro 30–60 giorni dalla pubblicazione coerente su GBP e dalla pulizia delle citazioni. L'impatto completo si manifesta tipicamente entro 90 giorni. Il fattore chiave è la costanza: Stacc pubblica ogni giorno, monitora ogni giorno e corregge i problemi ogni giorno — qualcosa che la gestione manuale non riesce quasi mai a raggiungere su scala.",
  },
  {
    q: "Quanto costa Stacc?",
    a: "Il modulo SEO Locale parte da $49/mese. Include pubblicazione di post su GBP, rank tracking giornaliero, monitoraggio recensioni, gestione citazioni e reportistica automatica. È disponibile una prova gratuita di 14 giorni senza carta di credito.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Automazione SEO Locale",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Piattaforma di automazione SEO locale che gestisce rank tracking, sincronizzazione citazioni, monitoraggio recensioni e pubblicazione GBP in automatico — risparmiando 8 ore per cliente al mese.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Modulo SEO Locale — prova gratuita 14 giorni"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Automazione SEO Locale", "item": "https://thestacc.com/it/automazione-seo-locale/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Automazione SEO Locale — Automatizza Ranking, Citazioni e Recensioni | theStacc"
  description="Automatizza il lavoro quotidiano del SEO locale. theStacc gestisce rank tracking, sincronizzazione citazioni, monitoraggio recensioni e pubblicazione GBP in automatico — 8 ore risparmiate a settimana."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex flex-wrap items-center justify-center gap-3">
            {['Completamente automatizzato', '8 ore risparmiate/mese', 'GBP + citazioni + recensioni', 'Nessuna carta di credito', '$49/mese'].map(chip => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>{chip}
              </span>
            ))}
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Automazione SEO locale che<br />funziona senza di te.
            <span style="color:#4f39f6;"> Ogni giorno. Ogni sede.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Il SEO locale manuale è un lavoro a tempo pieno che stai facendo part-time. Stacc automatizza il lavoro di esecuzione quotidiano — pubblicazione GBP, monitoraggio ranking, sincronizzazione citazioni, avvisi recensioni e report clienti — così puoi concentrarti sulla strategia, non sui fogli di calcolo.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi cosa viene automatizzato
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito per iniziare · Disdici quando vuoi
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ agenzie che usano Stacc</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Setup in meno di 5 minuti</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN NARRATIVE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perché il SEO locale manuale non scala</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Il SEO locale è un lavoro quotidiano.<br />Tu lo fai mensilmente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              L'algoritmo locale di Google non ti giudica ogni mese. Ti osserva ogni giorno. Il tuo GBP pubblica con costanza? Le tue citazioni corrispondono su tutte le directory? Stai rispondendo alle recensioni rapidamente? Il tuo ranking tiene nel local pack? Non sono domande per audit mensili — sono condizioni operative quotidiane. E se le gestisci manualmente, ne stai mancando la maggior parte quasi sempre.
            </p>
            <p>
              Le agenzie e le attività che si posizionano in cima a Google Maps non accedono ogni mattina per controllare il loro GBP e pubblicare manualmente. <strong class="text-[#111827]">Lo hanno automatizzato.</strong> Hanno costruito un sistema che esegue il lavoro SEO quotidiano senza che nessuno debba farlo. La costanza — non il genio — è ciò che guida i ranking locali. E la costanza su scala è possibile solo con l'automazione.
            </p>
            <p>
              Pensa a cosa stai davvero spendendo in termini di tempo: controllare ranking che potrebbero avvisarti automaticamente, scrivere post GBP che il software può generare, costruire report che dovrebbero consegnarsi da soli, monitorare piattaforme di recensioni una scheda alla volta. Sommalo su 10 clienti e stai guardando 80+ ore di lavoro manuale al mese che non dovrebbe essere manuale per niente.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc è stato costruito per sostituire quelle 80 ore con un unico sistema automatizzato. Tu imposti la strategia. Stacc si occupa dell'esecuzione — ogni giorno, per ogni sede, senza che nessuno nel tuo team la tocchi.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa automatizza Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni attività SEO locale che ha divorato<br />il tempo del tuo team.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Pubblicazione post GBP — 30/mese', 'Rank tracking giornaliero — local pack + organico', 'Monitoraggio recensioni — avvisi in tempo reale', 'Gestione citazioni — 50+ directory'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Pubblicati direttamente sul tuo sito', 'Ricerca keyword inclusa', 'Link interni ottimizzati'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri con immagini', 'Instagram, LinkedIn, Facebook, X', 'Scritti e programmati automaticamente', 'Contenuto coerente al brand'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">L'automazione nel dettaglio</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cosa fa Stacc<br />mentre sei concentrato altrove.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Automazione GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automazione Post GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 post su Google Business Profile al mese. Scritti e pubblicati automaticamente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                L'algoritmo locale di Google assegna posizioni più alte nel local pack alle attività che pubblicano con costanza. Stacc genera 30 post ottimizzati per sede al mese targetando le combinazioni servizio + città, argomenti stagionali e ricerche ad alta intenzione. Vengono pubblicati secondo programma. Il tuo profilo rimane attivo ogni singolo giorno senza che nessuno nel tuo team acceda.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri l'automazione GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Log attività automazione</p>
              {[
                { time: '07:02', action: 'Post GBP pubblicato', loc: 'Sede Milano', ok: true },
                { time: '07:02', action: 'Post GBP pubblicato', loc: 'Sede Roma', ok: true },
                { time: '06:45', action: 'Controllo ranking completato', loc: '14 keyword tracciate', ok: true },
                { time: '06:30', action: 'Audit citazioni eseguito', loc: '50 directory controllate', ok: true },
                { time: '02:14', action: 'Avviso nuova recensione', loc: 'Recensione 5 stelle ricevuta', ok: true },
              ].map(log => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <span class="font-mono text-[10px] text-[#79716b] shrink-0 mt-0.5">{log.time}</span>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{log.action}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{log.loc}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tutto automatizzato · Zero interventi manuali</p>
            </div>
          </div>

          <!-- Monitoraggio Recensioni -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Monitoraggio recensioni — tutte le sedi</p>
              {[
                { stars: 5, text: '"Servizio incredibile. Il miglior idraulico a Milano."', platform: 'Google', time: '2h fa', alerted: true },
                { stars: 5, text: '"Risposta rapida, prezzo onesto. Consigliato."', platform: 'Google', time: '1g fa', alerted: true },
                { stars: 3, text: '"Discreto ma ci ha messo più del previsto."', platform: 'Yelp', time: '2g fa', alerted: true },
                { stars: 5, text: '"La migliore azienda HVAC della città."', platform: 'Google', time: '3g fa', alerted: true },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center gap-2 mb-1">
                    <div class="flex gap-0.5">
                      {Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
                    </div>
                    <span class="font-mono text-[10px] text-[#79716b]">{r.platform} · {r.time}</span>
                    {r.alerted && <span class="ml-auto font-mono text-[10px] text-[#059669]">✓ Avvisato</span>}
                  </div>
                  <p class="font-sans text-[12px] text-[#57534e] italic">{r.text}</p>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automazione Monitoraggio Recensioni</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sappi di ogni recensione nel momento in cui arriva. Rispondi prima che ti penalizzi.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Una recensione negativa lasciata senza risposta per 48 ore fa più danni della recensione stessa. Stacc monitora ogni piattaforma di recensioni su tutte le tue sedi in tempo reale e invia avvisi nel momento in cui appare una nuova recensione — così puoi rispondere mentre è ancora fresca. Per le agenzie, il feed unificato delle recensioni significa vedere ogni recensione dei clienti senza accedere a 20 account Google diversi.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il monitoraggio recensioni
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reportistica Automatica -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reportistica Automatica</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Report che si generano, brandizzano e consegnano da soli. Ogni cliente. Ogni settimana.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
