---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Come funziona il posizionamento su Google Maps?", a: "L'algoritmo di Google Maps valuta tre fattori principali: pertinenza (quanto il tuo profilo corrisponde alla ricerca), distanza (quanto sei vicino al ricercatore) e prominenza (quanto la tua azienda è conosciuta e attiva online). La pertinenza e la prominenza sono quelle su cui puoi lavorare concretamente — con post GBP regolari, citazioni coerenti e recensioni attive." },
  { q: "Quali segnali migliorano il ranking su Google Maps?", a: "I segnali principali sono: attività costante del profilo GBP (post regolari, aggiornamento attributi), coerenza NAP (Nome, Indirizzo, Telefono) su tutte le directory, volume e qualità delle recensioni con risposta attiva, accuratezza delle categorie e descrizioni del profilo. Stacc automatizza tutti questi segnali continui." },
  { q: "Il posting GBP migliora davvero il ranking su Maps?", a: "Sì. Google GBP Post è uno dei segnali di attività più diretti per l'algoritmo Maps. Le aziende che pubblicano regolarmente mostrano a Google che il profilo è attivo e gestito attivamente. Stacc pubblica 30 post al mese per sede — circa uno al giorno — ottimizzati per le combinazioni servizio + città. L'effetto è cumulativo nel tempo." },
  { q: "Quanto tempo ci vuole per vedere miglioramenti nel ranking?", a: "La maggior parte delle aziende vede i primi movimenti di ranking entro 30-60 giorni dall'inizio dell'attività costante su GBP e dalla correzione delle citazioni. L'impatto completo si vede tipicamente entro 90 giorni. La chiave è la coerenza quotidiana — che è esattamente ciò che l'automazione garantisce." },
  { q: "Le citazioni influenzano il ranking su Maps?", a: "Significativamente. Citazioni incoerenti (NAP diverso su directory diverse) inviano segnali contraddittori a Google sulle informazioni aziendali. Questo abbassa il punteggio di prominenza e la fiducia nel profilo. Stacc monitora la coerenza NAP su 50+ directory e segnala o corregge automaticamente le incongruenze." },
  { q: "Stacc può migliorare il ranking per più sedi contemporaneamente?", a: "Sì. Stacc automatizza i segnali di ranking per ogni sede indipendentemente — post GBP, monitoring citazioni, avvisi recensioni — tutte in esecuzione simultanea. Puoi gestire 1 o 500 sedi con lo stesso sforzo: configuri una volta e Stacc esegue per tutte." },
  { q: "Quanto costa?", a: "Il modulo SEO locale di Stacc, che include tutte le funzionalità di ottimizzazione per Google Maps, parte da $49/mese per sede." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Posizionamento Google Maps",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automatizza i segnali che migliorano il tuo posizionamento su Google Maps. GBP automation, citazioni, recensioni e rank tracking — tutti i segnali che contano, eseguiti ogni giorno.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Posizionamento Google Maps", "item": "https://thestacc.com/it/posizionamento-google-maps/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Posizionamento Google Maps — Automatizza i Segnali che Migliorano il Tuo Ranking | theStacc"
  description="Automatizza i segnali che migliorano il tuo posizionamento su Google Maps. theStacc gestisce GBP, citazioni, recensioni e rank tracking per aumentare la tua visibilità locale."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Posizionamento Google Maps · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Automatizza i segnali che migliorano<br />
            <span style="color:#4f39f6;">il tuo ranking su Google Maps.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Google Maps premia la pertinenza e la prominenza. Stacc automatizza i segnali che le migliorano — post GBP giornalieri, citazioni coerenti, monitoraggio recensioni e rank tracking — in modo che ogni sede invii i segnali giusti ogni giorno.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Come funziona
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- NARRATIVA: COME FUNZIONA MAPS -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Come funziona il ranking su Google Maps</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tre fattori determinano dove<br />appari su Maps. Due sono automatizzabili.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Google valuta tre fattori per il local pack e Maps: <strong class="text-[#111827]">pertinenza</strong> (quanto il tuo profilo corrisponde alla ricerca), <strong class="text-[#111827]">distanza</strong> (quanto sei vicino al ricercatore) e <strong class="text-[#111827]">prominenza</strong> (quanto sei conosciuto e attivo online). La distanza non è controllabile. Pertinenza e prominenza lo sono completamente.
            </p>
            <p>
              La pertinenza migliora con categorie GBP accurate, keyword nei post e nelle descrizioni, e post che coprono i servizi e le aree geografiche rilevanti. La prominenza migliora con l'attività costante del profilo, le recensioni, le citazioni coerenti e i backlink. Nessuno di questi è un intervento una-tantum — tutti richiedono lavoro continuativo ogni giorno.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc automatizza esattamente questo lavoro continuativo. 30 post al mese ottimizzati per pertinenza, monitoraggio citazioni su 50+ directory per la prominenza, avvisi recensioni per mantenere un profilo attivo. Ogni segnale inviato ogni giorno senza intervento manuale.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Segnali automatizzati per Maps</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni segnale di ranking su Maps<br />automatizzato ogni giorno.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: '30 post GBP al mese', body: 'Post ottimizzati per servizio + città, pubblicati automaticamente ogni giorno. Profilo sempre attivo = segnale positivo per l\'algoritmo Maps.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoraggio citazioni', body: 'Citazioni NAP coerenti su 50+ directory rafforzano la prominenza su Maps. Stacc monitora e segnala inconsistenze automaticamente.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitoraggio recensioni', body: 'Le recensioni frequenti con risposta rapida sono un segnale di prominenza. Avvisi in tempo reale per ogni nuova recensione su ogni piattaforma.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rank tracking giornaliero', body: 'Monitora la tua posizione nel local pack e su Maps ogni giorno. Vedi come si muovono i ranking nel tempo e identifica immediatamente cali o miglioramenti.' },
            { icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', title: 'Protezione modifiche non autorizzate', body: 'Chiunque può suggerire modifiche al tuo profilo GBP. Stacc rileva immediatamente modifiche non autorizzate a indirizzo, orario o categoria.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Analisi trend', body: 'Grafici storici del posizionamento su Maps nel tempo. Identifica l\'impatto delle attività SEO e i pattern stagionali del ranking locale.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- METRICHE DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '89%', label: 'Miglioramento medio ranking Maps', sub: 'In 90 giorni di attività GBP costante' },
            { value: '30', label: 'Post GBP pubblicati al mese per sede', sub: 'Ottimizzati per pertinenza locale' },
            { value: '50+', label: 'Directory monitorate per citazioni', sub: 'NAP coerente su tutto il web' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Una piattaforma. Ogni segnale che conta.</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutti i segnali di Google Maps<br />gestiti da un'unica piattaforma.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['30 post GBP al mese per sede', 'Rank tracking giornaliero su Maps', 'Monitoraggio recensioni in tempo reale', 'Citazioni NAP su 50+ directory'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Pagine servizio + città', 'Internal linking ottimizzato', 'Pubblicazione automatica'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri con immagini', 'Instagram, Facebook, GBP', 'Pianificati automaticamente', 'Coerenti con il brand'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Pertinenza, prominenza, visibilità.<br />Ogni leva di Maps automatizzata.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Block 1: Post GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pubblicazione GBP automatica</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 post al mese che dicono a Maps che il tuo profilo è vivo, attivo e affidabile.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google Maps premia i profili che pubblicano contenuti rilevanti con costanza. Stacc scrive 30 post al mese per sede — combinazioni servizio + città, intento "vicino a me", eventi stagionali, promozioni — e li pubblica secondo calendario. Ogni post invia un segnale di attività e pertinenza all'algoritmo Maps. Tu non tocchi nulla.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario GBP del mese</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 22 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Post pubblicati</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">22 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:73%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Profilo attivo ogni giorno · Segnale di prominenza costante</p>
            </div>
          </div>

          <!-- Block 2: Local Pack -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posizione nel local pack — oggi</p>
              {[
                { kw: 'idraulico vicino a me', pack: 1, change: '+3', trend: 'up' },
                { kw: 'idraulico urgente Milano', pack: 2, change: '+1', trend: 'up' },
                { kw: 'riparazione caldaia Milano', pack: 3, change: '+2', trend: 'up' },
                { kw: 'pronto intervento idraulico', pack: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
