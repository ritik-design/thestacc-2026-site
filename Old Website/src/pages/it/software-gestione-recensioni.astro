---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "Cos'è un software di gestione delle recensioni?",
    a: "Un software di gestione delle recensioni monitora le recensioni della tua attività su piattaforme come Google, Facebook e Yelp — avvisandoti istantaneamente ogni volta che arriva una nuova recensione, monitorando i trend del tuo rating nel tempo e aiutandoti a rispondere più velocemente. Stacc centralizza tutte le recensioni in un'unica dashboard così non ne perdi mai una.",
  },
  {
    q: "Come monitora le recensioni Stacc?",
    a: "Stacc si collega direttamente al tuo Google Business Profile, alla tua pagina Facebook e al tuo profilo Yelp. Quando viene pubblicata una nuova recensione su qualsiasi piattaforma, Stacc la rileva nel giro di minuti e ti invia un avviso immediato. Vedi la recensione nella tua dashboard centrale senza dover accedere separatamente a ogni piattaforma.",
  },
  {
    q: "Stacc può aiutarmi a ottenere più recensioni?",
    a: "Sì. Stacc include l'automazione delle richieste di recensione — puoi impostare sequenze di follow-up automatizzate che chiedono ai clienti soddisfatti di lasciare una recensione. Tempi e messaggi sono personalizzabili. Le attività che usano la funzione di richiesta recensioni di Stacc ottengono in media un rating più alto di 0,4 stelle in 90 giorni.",
  },
  {
    q: "Quanto sono importanti le recensioni per il posizionamento SEO locale?",
    a: "Le recensioni sono il 2° fattore di ranking per il local pack di Google — secondo solo alla rilevanza del GBP. Quantità, recenza e rating medio delle recensioni influenzano direttamente dove appari su Maps e nei risultati di ricerca locali. Un'attività con 200 recensioni recenti a 4,8 stelle supera costantemente chi ne ha 20 più vecchie.",
  },
  {
    q: "Stacc funziona per attività con più sedi?",
    a: "Sì. Ogni sede ha la propria dashboard di monitoraggio recensioni. Puoi vedere le recensioni per sede, confrontare i rating tra le sedi e ricevere avvisi specifici per ciascuna. Per franchising e attività multi-sede, questo è essenziale — sai cosa succede in ogni sede senza dover effettuare accessi separati.",
  },
  {
    q: "Quanto velocemente Stacc mi avvisa di una recensione negativa?",
    a: "Stacc rileva le nuove recensioni entro pochi minuti dalla pubblicazione e invia un avviso immediato. Per le recensioni negative (sotto la soglia di rating che hai impostato), puoi configurare avvisi prioritari via email o SMS così sei sempre il primo a saperlo — non l'ultimo.",
  },
  {
    q: "Le agenzie possono usare Stacc per gestire le recensioni dei clienti?",
    a: "Sì. Le agenzie gestiscono tutti i profili recensioni dei clienti da un'unica dashboard. I dati delle recensioni sono inclusi nei report mensili white-label di Stacc — consegnati sotto il tuo brand in automatico. I tuoi clienti ricevono un report professionale sulle recensioni. Tu non spendi un minuto a costruirlo.",
  },
  {
    q: "Stacc traccia i trend delle recensioni nel tempo?",
    a: "Sì. Stacc traccia la cronologia del tuo rating, la velocità delle recensioni e il tasso di risposta nel tempo. Puoi vedere se la tua reputazione sta migliorando o peggiorando, quanto velocemente stai rispondendo alle recensioni e come il volume delle recensioni si confronta con i periodi precedenti — tutto in un'unica dashboard.",
  },
  {
    q: "Su quali piattaforme monitora le recensioni Stacc?",
    a: "Stacc monitora Google Business Profile, Facebook e Yelp — coprendo la grande maggioranza delle recensioni locali che influenzano il posizionamento nella ricerca locale. Sono supportate anche le directory di settore per le categorie di attività rilevanti.",
  },
  {
    q: "Quanto costa la gestione delle recensioni con Stacc?",
    a: "Il monitoraggio delle recensioni è incluso nel modulo SEO Locale a $49/mese. Ottieni anche rank tracking, gestione citazioni, pubblicazione su GBP e reportistica automatica — tutto allo stesso prezzo di $49. Nessuna tariffa per piattaforma, nessun sovrapprezzo per sede.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software Gestione Recensioni",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Monitora le recensioni su Google, Facebook e Yelp in un'unica dashboard. Ricevi avvisi istantanei, rispondi più velocemente e traccia i trend della tua reputazione in automatico.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Modulo SEO Locale con gestione recensioni — prova 14 giorni"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software Gestione Recensioni", "item": "https://thestacc.com/it/software-gestione-recensioni/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Software Gestione Recensioni — Monitora, Rispondi e Migliora il Rating | theStacc"
  description="Monitora le recensioni su Google, Facebook e Yelp in un'unica dashboard. Avvisi istantanei, risposte più veloci e trend della reputazione tracciati in automatico."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software Gestione Recensioni · Da $49/mese</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Smettila di scoprire le recensioni negative<br />
            <span style="color:#4f39f6;">dal cliente che se n'è già andato.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Le recensioni sono il 2° fattore di ranking locale. La maggior parte delle attività scopre quelle negative con giorni di ritardo. Stacc monitora Google, Facebook e Yelp in tempo reale — una dashboard, avvisi istantanei, zero controlli manuali.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia a monitorare le recensioni gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi i prezzi
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Prova gratuita 14 giorni · Nessuna carta di credito · Disdici quando vuoi
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Google, Facebook, Yelp monitorati</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Avvisi in pochi minuti</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN NARRATIVE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema delle recensioni che la maggior parte ignora</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Non stai rispondendo alle recensioni.<br />Stai reagendo — con giorni di ritardo.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Sei quella persona che accede a Google Business Profile una volta a settimana — forse una volta al mese — e scopre una recensione a 2 stelle di tre giorni fa di cui non sapeva nulla. Per quando rispondi, il cliente è andato avanti. Il danno è fatto. Le prossime 20 persone che hanno cercato la tua attività hanno visto quella recensione lì, senza risposta, che segnalava loro che non ti importa.
            </p>
            <p>
              Le recensioni sono il 2° fattore di ranking per il local pack. Quantità, recenza, velocità e tasso di risposta alimentano direttamente il posizionamento su Maps. Le attività che dominano la ricerca locale non si limitano a raccogliere più recensioni — rispondono entro poche ore, il che segnala a Google coinvolgimento e ai potenziali clienti affidabilità.
            </p>
            <p>
              La matematica è semplice. Un'attività che risponde alle recensioni entro 2 ore sembra un'attività attenta. Una che risponde in 3 giorni — se risponde — sembra una che non lo è. La tua reputazione si decide in questo momento in recensioni che non hai ancora letto. Stacc fa in modo che tu sia sempre il primo a saperlo.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa fa Stacc per le recensioni</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Monitora. Avvisa. Traccia. Reporta.<br />Un'unica dashboard per ogni piattaforma.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            {
              title: 'Monitoraggio in Tempo Reale',
              icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
              features: ['Google, Facebook, Yelp monitorati', 'Avvisi in minuti dalla pubblicazione', 'Avvisi prioritari per recensioni negative', 'Monitoraggio multi-sede in un\'unica vista'],
              href: '/it/moduli/seo-locale/',
            },
            {
              title: 'Tracciamento Reputazione',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              features: ['Cronologia andamento rating', 'Tracciamento velocità recensioni', 'Misurazione tasso di risposta', 'Benchmark rating vs. competitor'],
              href: '/it/software-monitoraggio-posizioni/',
            },
            {
              title: 'Reportistica Automatica',
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              features: ['Report mensile recensioni incluso', 'Consegna white-label per agenzie', 'Trend rating nei report clienti', 'Zero costruzione manuale di report'],
              href: '/it/reportistica-white-label/',
            },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Come Stacc gestisce le recensioni</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni recensione vista. Ogni trend tracciato.<br />Ogni report clienti automatizzato.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Avvisi -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Avvisi Recensioni Istantanei</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sappi di ogni recensione in pochi minuti — non in giorni.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc monitora continuamente i tuoi profili Google, Facebook e Yelp. Nel momento in cui appare una nuova recensione, ricevi un avviso. Per le recensioni negative sotto la soglia di rating impostata, ricevi un avviso prioritario — email o SMS — così puoi rispondere prima che la situazione si aggravi. Le attività che usano Stacc rispondono in media il 73% più velocemente rispetto a chi controlla manualmente.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Avvisi recensioni recenti</p>
              {[
                { platform: 'Google', rating: '⭐⭐⭐⭐⭐', preview: '"Servizio eccellente, lo consiglio vivamente"', time: '12 min fa', type: 'positive' },
                { platform: 'Yelp', rating: '⭐⭐', preview: '"Tempi di attesa troppo lunghi"', time: '2 ore fa', type: 'negative' },
                { platform: 'Facebook', rating: '⭐⭐⭐⭐⭐', preview: '"Il migliore in città, tornerò"', time: '5 ore fa', type: 'positive' },
              ].map(r => (
                <div class={`rounded-xl p-3 mb-3 border ${r.type === 'negative' ? 'border-[#fecaca] bg-[#fef2f2]' : 'border-[#e7e5e4] bg-[#fafaf9]'}`}>
                  <div class="flex items-center justify-between mb-1">
                    <span class="font-mono text-[11px] font-semibold text-[#374151]">{r.platform}</span>
                    <span class="font-mono text-[10px] text-[#79716b]">{r.time}</span>
                  </div>
                  <p class="font-sans text-[11px] text-[#57534e]">{r.rating} {r.preview}</p>
                  {r.type === 'negative' && <p class="mt-1 font-mono text-[10px] font-semibold text-[#dc2626]">⚠ Avviso prioritario inviato</p>}
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tutte le piattaforme · Monitoraggio in tempo reale</p>
            </div>
          </div>

          <!-- Tracciamento -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Punteggio reputazione — 90 giorni</p>
              <div class="flex items-end gap-1 h-24 mb-4">
                {[3.8, 3.9, 4.0, 4.1, 4.0, 4.1, 4.2, 4.3, 4.4, 4.4, 4.5, 4.6].map((v, i) => (
                  <div class="flex-1 rounded-t" style={`height:${((v-3.5)/1.5)*100}%;background:${i >= 9 ? '#4f39f6' : '#e7e5e4'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">90 giorni fa: 3.8 ★</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">Oggi: 4.6 ★</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">+0.8 stelle in 90 giorni · Google Business Profile</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tracciamento Andamento Rating</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Vedi se la tua reputazione sta migliorando o peggiorando — in automatico.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc traccia il tuo rating, il numero di recensioni e il tasso di risposta nel tempo su ogni piattaforma. Puoi vedere a colpo d'occhio se sei in crescita o in calo, quali piattaforme richiedono attenzione e quanto velocemente il tuo team risponde. Per le agenzie, questi dati si aggregano automaticamente nei report clienti — mostrando il valore che stai generando senza costruire una singola slide.
              </p>
              <a href="/it/software-monitoraggio-posizioni/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Vedi tutte le funzionalità di tracciamento
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reportistica -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reportistica Recensioni per Agenzie</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Dati recensioni nei report clienti. Consegnati automaticamente. Con il tuo brand.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                I report mensili white-label di Stacc includono automaticamente i dati delle recensioni — nuove recensioni ricevute, trend del rating, tasso di risposta e ripartizione per piattaforma. I tuoi clienti vedono esattamente come sta andando la loro reputazione senza che tu ci spenda tempo. Imposta il template una volta. I report si consegnano da soli ogni mese, brandizzati come tuoi.
              </p>
              <a href="/it/reportistica-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri Stacc per agenzie
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
