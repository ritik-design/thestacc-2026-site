---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il SEO locale white-label?", a: "Il SEO locale white-label significa erogare servizi di SEO locale ai tuoi clienti con il tuo marchio. Con Stacc, tutta la piattaforma — dashboard, report, accesso clienti, email — appare con il logo e i colori della tua agenzia. I clienti non vedono mai Stacc." },
  { q: "Cosa viene incluso nel modulo SEO locale?", a: "Il modulo SEO locale di Stacc include: gestione automatizzata del profilo Google Business, monitoraggio posizioni giornaliero, monitoraggio recensioni in tempo reale, gestione citazioni su 50+ directory e report automatizzati in white-label per i clienti." },
  { q: "Come funziona il setup?", a: "La configurazione richiede circa 2 ore: carica il logo della tua agenzia, imposta i colori del brand, configura il dominio personalizzato per il portale clienti. Dopo, l'onboarding di ogni nuovo cliente richiede pochi minuti. Nessuna competenza tecnica necessaria." },
  { q: "I clienti possono accedere alla loro dashboard?", a: "Sì. Ogni cliente riceve credenziali di accesso a una dashboard brandizzata con il tuo marchio. Possono consultare le proprie metriche di posizionamento, citazioni e recensioni in autonomia, riducendo le richieste di reportistica all'agenzia." },
  { q: "Come vengono gestiti più clienti?", a: "Tutti i clienti sono visibili da un'unica dashboard di gestione multi-cliente. Puoi monitorare le performance di ogni account, vedere avvisi e aggiornamenti in un feed unificato, e gestire le attività senza dover accedere a decine di account separati." },
  { q: "Quanto costa?", a: "Il modulo SEO locale parte da $49/mese e include tutte le funzionalità white-label. Nessun costo per cliente aggiuntivo, nessuna quota di configurazione." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO Locale White-Label",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Software SEO locale white-label per agenzie. Automazione GBP, rank tracking, citazioni e report — tutto brandizzato con il marchio della tua agenzia.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "SEO Locale White-Label", "item": "https://thestacc.com/it/seo-locale-white-label/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="SEO Locale White-Label — Automazione SEO Locale Sotto il Tuo Marchio | theStacc"
  description="Software SEO locale white-label per agenzie. theStacc automatizza GBP, rank tracking, citazioni e report per i tuoi clienti — tutto brandizzato con il tuo logo e dominio."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Locale White-Label · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO locale white-label per la<br />
            <span style="color:#4f39f6;">tua agenzia. Al tuo marchio.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc automatizza GBP, rank tracking, citazioni, monitoraggio recensioni e report per i tuoi clienti. Tutto appare con il tuo logo. I clienti vedono solo la tua agenzia.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Scopri le funzionalità
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- ─── NARRATIVA (PAIN) ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perché il SEO locale white-label è diverso</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            I clienti locali hanno bisogno di un SEO<br />che si esegue ogni giorno, non ogni mese.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Il SEO locale non è un'attività mensile. L'algoritmo di Google Maps valuta ogni giorno se il profilo GBP è attivo, se le citazioni sono coerenti e se le recensioni ricevono risposta. Le agenzie che gestiscono questo manualmente — per 10, 20 o 50 clienti — perdono la maggior parte di queste opportunità semplicemente per mancanza di tempo.
            </p>
            <p>
              Stacc risolve il problema alla radice automatizzando l'esecuzione quotidiana: 30 post GBP al mese per ogni cliente, monitoraggio posizioni giornaliero, avvisi review in tempo reale, controllo citazioni su oltre 50 directory. Tutto avviene automaticamente, senza che nessuno del tuo team debba accedere manualmente.
            </p>
            <p class="font-semibold text-[#111827]">
              E tutto questo — ogni dashboard, ogni report, ogni email inviata ai clienti — porta il tuo logo e il tuo marchio. I tuoi clienti vedono un'agenzia professionale che consegna risultati, non una piattaforma SaaS che hanno imparato a usare da soli.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW (FUNZIONALITÀ) ─── -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa include il modulo</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutto il SEO locale dei tuoi clienti<br />gestito in automatico.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automazione GBP', body: 'Pubblicazione automatica di 30 post al mese per ogni cliente sul Google Business Profile. Attività costante = segnali di ranking costanti.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rank tracking giornaliero', body: 'Monitoraggio delle posizioni ogni giorno per ogni cliente — local pack, Maps e organico. Avvisi automatici su variazioni significative.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoraggio citazioni', body: 'Controllo della coerenza NAP su 50+ directory per ogni cliente. Inconsistenze identificate e corrette in automatico.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestione recensioni', body: 'Avvisi in tempo reale per ogni nuova recensione su tutti i profili dei clienti. Feed centralizzato per rispondere senza accedere a più account.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Report brandizzati automatici', body: 'Report generati, brandizzati con il tuo logo e inviati ai clienti automaticamente ogni mese. Zero lavoro manuale di reportistica.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Dominio personalizzato', body: 'Il portale clienti può essere ospitato su un sottodominio della tua agenzia. Esperienza completamente white-label dall\'URL alla schermata di login.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità del white-label SEO locale</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutto sotto il tuo brand.<br />Tutto eseguito da Stacc.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP brandizzato -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automazione GBP brandizzata</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 post GBP al mese per ogni cliente. Profili sempre attivi. Niente da fare manualmente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Per ogni cliente che gestisci, Stacc scrive e pubblica 30 post Google Business al mese — ottimizzati per le keyword di servizio locali, l'intento "vicino a me" e gli argomenti stagionali pertinenti. Il cliente vede attività costante sul proprio profilo. La tua agenzia non tocca mai un post. E quando un cliente ti chiede prove di lavoro, esporti il calendario di pubblicazione brandizzato con il tuo logo in due click.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario post di questo mese</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 22 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Post pubblicati</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">22 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:73%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">8 programmati · Brandizzati con il logo della tua agenzia</p>
            </div>
          </div>

          <!-- Dashboard cliente brandizzata -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5 border-b border-[#f5f3ff] pb-4">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Portale Cliente · La Tua Agenzia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">app.tuaagenzia.it</p>
                </div>
              </div>
              {[
                { kw: 'idraulico Milano centro', pack: 1, change: '+3' },
                { kw: 'pronto intervento Milano', pack: 2, change: '+1' },
                { kw: 'caldaia rotta vicino a me', pack: 3, change: '+2' },
                { kw: 'sturatura tubi Milano', pack: 4, change: '0' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.change.startsWith('+') ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.change.startsWith('+') ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Dashboard accessibile dal cliente · Logo e dominio della tua agenzia</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dashboard cliente brandizzata</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Ogni cliente accede a una dashboard sotto il tuo dominio. Con il tuo logo. Niente Stacc.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Le agenzie più professionali danno ai clienti un portale dove possono vedere ranking, recensioni e attività in tempo reale. Stacc ti dà esattamente questo — ma sotto il tuo dominio (app.tuaagenzia.it), con il tuo logo nell'intestazione e i tuoi colori. Il cliente apre il browser, va su un URL del tuo brand e vede una dashboard professionale. Non sa né vede che dietro c'è Stacc.
              </p>
              <a href="/it/software-monitoraggio-posizioni/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il rank tracking
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reportistica white-label automatica -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reportistica automatica brandizzata</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Report mensili con il tuo logo. Inviati dal tuo dominio email. Zero lavoro manuale.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configura una volta il template — logo, colori, struttura, frequenza — e Stacc genera il report mensile per ogni cliente, lo brandizza completamente e lo invia all'inbox del cliente dal mittente del tuo dominio. Il PDF arriva con la tua intestazione, le tue conclusioni precompilate e zero menzione del software che lo ha generato. Per il cliente, è la tua agenzia che ha costruito un sistema interno.
              </p>
              <a href="/it/reportistica-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri la reportistica white-label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Report mensile · La Tua Agenzia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Da: report@tuaagenzia.it</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Inviato</span>
              </div>
              {[
                { label: 'Posizioni in top 3 GBP', val: '+4 keyword' },
                { label: 'Post pubblicati', val: '30 / 30' },
                { label: 'Recensioni nuove', val: '6 (media 4.8)' },
                { label: 'Visite stimate', val: '+38% vs mese scorso' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generato e consegnato il 1° del mese · Zero ore del tuo team</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICHE DARK ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '3×', label: 'Più clienti per dipendente', sub: 'Rispetto alla gestione manuale' },
            { value: '400+', label: 'Agenzie usano Stacc', sub: 'Con clienti SEO locale attivi' },
            { value: '100%', label: 'Brand replacement', sub: 'Nessun riferimento a Stacc visibile ai clienti' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


