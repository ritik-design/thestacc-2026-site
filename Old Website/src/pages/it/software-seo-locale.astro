---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "Cos'è un software SEO locale?",
    a: "Un software SEO locale aiuta le attività a gestire i segnali che determinano come si posizionano nella ricerca locale — incluse l'attività su Google Business Profile, i ranking delle keyword nel local pack e su Google Maps, la coerenza delle citazioni nelle directory e le recensioni dei clienti. Stacc automatizza tutti questi compiti in un'unica piattaforma così le attività locali e le agenzie non devono gestirli manualmente.",
  },
  {
    q: "Cosa fa Stacc che un rank tracker di base non fa?",
    a: "La maggior parte dei rank tracker traccia solo il ranking. Stacc pubblica anche sul tuo Google Business Profile ogni giorno, monitora e avvisa sulle recensioni in tempo reale, gestisce le citazioni su 50+ directory e genera report clienti white-label che si consegnano da soli. È un sistema operativo SEO locale completo — non solo un dashboard di dati.",
  },
  {
    q: "Stacc funziona per attività con più sedi?",
    a: "Sì — la gestione multi-sede è una delle capacità fondamentali di Stacc. Gestisci tutte le sedi da una dashboard, pubblica post su tutte contemporaneamente e genera report individuali o aggregati per ogni sede. Non c'è un limite pratico al numero di sedi che puoi aggiungere.",
  },
  {
    q: "Stacc è pensato per agenzie o team marketing interni?",
    a: "Entrambi. Le agenzie ottengono reportistica white-label, gestione account multi-cliente e portali clienti brandizzati. I team interni di attività multi-sede ottengono strumenti di gestione in blocco e reportistica automatica per gli stakeholder interni. La stessa piattaforma serve entrambi i flussi di lavoro.",
  },
  {
    q: "In cosa differisce Stacc dalla gestione manuale del SEO locale?",
    a: "Il SEO locale manuale significa accedere a strumenti separati per ranking, GBP, citazioni e recensioni — poi costruire report a mano ogni mese. Stacc collega tutto in un unico sistema automatizzato. I dati fluiscono automaticamente. I report si generano e si inviano automaticamente. Tu ti concentri sulla strategia. Stacc gestisce l'esecuzione.",
  },
  {
    q: "Quanto tempo ci vuole per configurare Stacc per una nuova sede o cliente?",
    a: "La maggior parte delle configurazioni si completa in meno di 5 minuti — sedi aggiunte, keyword configurate, GBP connesso e reportistica automatica programmata. Per clienti con 10+ sedi, calcola un'ora. Dopo la configurazione, Stacc gestisce tutto in modo continuativo senza ulteriore tempo dal tuo team.",
  },
  {
    q: "Stacc include la reportistica white-label per agenzie?",
    a: "Sì. I report white-label — con il tuo logo, colori del brand e dominio personalizzato — sono disponibili sui piani Growth e Scale. I report vengono consegnati con il tuo brand. I tuoi clienti non vedono alcun branding Stacc.",
  },
  {
    q: "Quali integrazioni supporta Stacc?",
    a: "Stacc si integra con Google Business Profile, Google Search Console, Google Analytics, Facebook, Instagram, WordPress, Webflow, Ghost e Wix. Tutte le integrazioni sono incluse — senza tariffe per singola integrazione.",
  },
  {
    q: "Posso disdire in qualsiasi momento?",
    a: "Sì. Nessun contratto. Nessuna penale di cancellazione. Esporta l'intera cronologia dei tuoi dati in qualsiasi momento prima di cancellare. I tuoi dati appartengono a te.",
  },
  {
    q: "Quanto costa Stacc?",
    a: "I piani partono da $49/mese per il modulo SEO Locale. Il modulo Blog SEO è $99/mese. Il modulo Social Media è $49/mese. Tutti i moduli includono una prova gratuita di 14 giorni a partire da $1.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software SEO Locale",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Software SEO locale che automatizza gestione GBP, rank tracking, monitoraggio citazioni, gestione recensioni e reportistica clienti per attività locali e agenzie.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Modulo SEO Locale — prova 14 giorni da $1"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software SEO Locale", "item": "https://thestacc.com/it/software-seo-locale/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Software SEO Locale — Automatizza il SEO Locale su Ogni Sede | theStacc"
  description="theStacc è il software SEO locale che fa il lavoro — non solo lo traccia. Gestione GBP, rank tracking, monitoraggio citazioni e reportistica automatica in pilota automatico."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software SEO Locale · Da $49/mese</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO locale che<br />fa il lavoro per te.
            <span style="color:#4f39f6;"> Non solo lo traccia.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            La maggior parte degli strumenti SEO locali ti dà dashboard. Stacc ti dà automazione. Google Business Profile, rank tracking, gestione citazioni, monitoraggio recensioni e reportistica white-label — tutto in funzione da solo, su ogni sede.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi cosa è incluso
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito per iniziare · Disdici quando vuoi
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ sedi gestite</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Setup in meno di 5 minuti</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema con la maggior parte degli strumenti SEO locali</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Hai provato gli strumenti.<br />Stai ancora facendo il lavoro.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Forse hai un rank tracker. Forse hai uno strumento per le citazioni. Forse hai qualcosa per le recensioni. E forse li hai messi insieme con fogli di calcolo e messaggi su Slack e un rituale settimanale di accesso a cinque piattaforme diverse per costruire un report che richiede tre ore e sembra fatto in quindici minuti.
            </p>
            <p>
              Questo è il dirty secret della maggior parte del software SEO locale: <strong class="text-[#111827]">traccia le cose. Non le fa.</strong> Le fai ancora tu. Il software ti dà solo una vista più elegante di quanto lavoro hai da fare.
            </p>
            <p>
              Ecco cosa costa. Ogni controllo manuale del ranking è 45 minuti che non stai fatturando. Ogni audit delle citazioni sono due ore della giornata di qualcuno. Ogni report clienti è una tassa sul tuo venerdì pomeriggio. Moltiplica per 20 clienti, 50 sedi, 12 mesi — e hai passato un anno a fare lavoro che dovrebbe essere automatizzato.
            </p>
            <p class="font-semibold text-[#111827]">
              I tuoi competitor lo stanno automatizzando. Servono più clienti, scalano più velocemente e appaiono più professionali — non perché siano più bravi, ma perché hanno smesso di fare manualmente quello che il software dovrebbe fare in automatico.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa fa Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una piattaforma. Ogni leva SEO locale.<br />Tutto automatizzato.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Pubblicazione post GBP — 30/mese', 'Rank tracking giornaliero — local pack + organico', 'Monitoraggio recensioni — avvisi in tempo reale', 'Gestione citazioni — 50+ directory'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Pubblicati direttamente sul tuo sito', 'Ricerca keyword inclusa', 'Link interni ottimizzati'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri con immagini', 'Instagram, LinkedIn, Facebook, X', 'Scritti e programmati automaticamente', 'Contenuto coerente al brand'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni attività SEO locale automatizzata.<br />Ogni risultato visibile.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automazione Post GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 post GBP al mese. Pubblicati automaticamente. Che targetano le ricerche che generano chiamate.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                L'algoritmo di Maps di Google premia le attività che pubblicano con costanza con una maggiore visibilità nel local pack. Stacc scrive 30 post ottimizzati per sede al mese — targetando le combinazioni servizio + città, l'intento "vicino a me", le ricerche di emergenza e gli argomenti stagionali — poi li pubblica secondo programma. Il tuo profilo rimane attivo ogni giorno. Non lo tocchi.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Post GBP di questo mese</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 20 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Post pubblicati finora</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">20 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:66%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Altri 10 programmati · Tutto automatizzato · Zero lavoro manuale</p>
            </div>
          </div>

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Aggiornamento ranking di oggi</p>
              {[
                { kw: 'dentista vicino a me', pack: 1, change: '+2', trend: 'up' },
                { kw: 'dentista urgente [città]', pack: 2, change: '+1', trend: 'up' },
                { kw: 'sbiancamento denti vicino a me', pack: 3, change: '+4', trend: 'up' },
                { kw: 'impianti dentali [città]', pack: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Aggiornato giornalmente · Local pack + organico + Maps</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rank Tracking Giornaliero</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sappi dove ti posizioni — nel local pack, su Maps e nell'organico — ogni mattina.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                I ranking si aggiornano ogni giorno su ogni keyword tracciata per ogni sede. Vedi la tua posizione nei risultati organici e nel local pack separatamente — perché per le attività locali, il pack da 3 è dove atterrano quasi tutti i click ad alta intenzione. Gli avvisi scattano automaticamente quando i ranking cambiano significativamente, così sei sempre informato prima del cliente.
              </p>
              <a href="/it/software-monitoraggio-posizioni/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il rank tracking nel dettaglio
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reportistica -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reportistica White-Label Automatica</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Report che si costruiscono e si inviano da soli. Ogni cliente. Ogni settimana. Con il tuo brand.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Il momento in cui smetti di costruire report a mano è il momento in cui inizi a scalare. Imposta il template una volta per cliente. Stacc genera il report, lo formatta con il branding della tua agenzia e lo consegna all'inbox del cliente secondo programma. Nessuno nel tuo team lo tocca. Questo non è solo un risparmio di tempo — è la cosa che ti permette di raddoppiare la base clienti senza raddoppiare il personale.
              </p>
              <a href="/it/reportistica-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri Stacc per agenzie
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">La Tua Agenzia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Report SEO Locale Settimanale</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Inviato</span>
              </div>
              {[
                { label: 'Miglioramenti di ranking', val: '+6 keyword in top 3' },
                { label: 'Post GBP pubblicati', val: '8 questa settimana' },
