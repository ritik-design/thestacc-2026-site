---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const changelog = [
  {
    date: "Aprile 2026",
    tag: "Ultimo",
    entries: [
      { title: "Sincronizzazione del piano in tempo reale", body: "Il tuo piano di contenuti ora rimane sincronizzato con la tua attività. Hai cambiato il pubblico target o aggiunto una nuova sede? Stacc rileva cosa è obsoleto e ti permette di aggiornare i singoli piani o l'intero mese con un clic." },
      { title: "Pubblicazione del mese successivo", body: "Pianifica in anticipo. Ora puoi generare il piano di contenuti del mese successivo mentre i post di questo mese sono ancora in pubblicazione. Rimani sempre un mese avanti." },
      { title: "Editor immagini in evidenza", body: "Immagini in evidenza, gestite. Seleziona, scambia o rimuovi le immagini hero direttamente nell'editor del blog. Si sincronizzano automaticamente con WordPress e Webflow." },
      { title: "Pagina dettaglio blog più pulita", body: "Genera, modifica o rigenera un piano da un unico posto. Niente più ricerca nella barra laterale per trovare il pulsante giusto." },
      { title: "Modifica slug in tempo reale", body: "Modifica gli slug del tuo blog direttamente dalla barra laterale. Le modifiche vengono pubblicate in tempo reale su WordPress, Webflow e WordPress.com all'istante." },
      { title: "Integrazione Ghost CMS", body: "Pubblica direttamente su Ghost CMS con verifica automatica delle credenziali." },
      { title: "Impostazioni moduli indipendenti", body: "Gestisci più progetti? Ognuno ora ha impostazioni di modulo completamente indipendenti. Attivare il Blog SEO per un sito non tocca gli altri." },
      { title: "Rigenerazione massiva 5 volte più veloce", body: "La rigenerazione massiva dei piani è ora 5 volte più veloce. Quello che prima richiedeva 90 secondi ora finisce in meno di 18." },
    ],
  },
  {
    date: "Marzo 2026",
    tag: null,
    entries: [
      { title: "Modulo Social Media lanciato", body: "Stacc ora scrive, progetta e pianifica post su Instagram, LinkedIn, X e Facebook. Imposta il tono del tuo brand una volta e lascialo andare in automatico." },
      { title: "Redesign completo dell'interfaccia", body: "Abbiamo ricostruito l'intera interfaccia da zero. Nuovo sistema di design, nuove icone, navigazione più rapida. Tutto appare più nitido e intenzionale." },
      { title: "Revisione del piano di contenuti", body: "Rivedi il piano di contenuti prima che venga scritto qualcosa. Modifica i titoli, cambia le parole chiave, cambia i tipi di blog. Tutto inline, prima che venga generato un singolo articolo." },
      { title: "API Blog pubblica", body: "Per gli sviluppatori: ottieni una chiave API, configura i webhook di deploy e importa i contenuti pubblicati in qualsiasi frontend o sito statico." },
      { title: "Migliore collaborazione in team", body: "Reinvia gli inviti, monitora la scadenza e controlla esattamente a cosa possono accedere i visualizzatori nei progetti condivisi." },
      { title: "Integrazione Shopify", body: "I contenuti del tuo blog SEO ora vengono pubblicati direttamente nel tuo negozio Shopify." },
    ],
  },
  {
    date: "Febbraio 2026",
    tag: null,
    entries: [
      { title: "Integrazione Webflow", body: "Collega il tuo sito Webflow tramite OAuth e ogni post del blog viene pubblicato direttamente nel tuo CMS con sincronizzazione in tempo reale." },
      { title: "Abbonamenti modulari", body: "Abbonati esattamente a ciò di cui hai bisogno. Scegli Blog SEO, SEO Locale o Social Media singolarmente. Ogni modulo ha il proprio piano e fatturazione." },
      { title: "Controlli di stile e tono del brand", body: "Imposta le preferenze di stile di scrittura, le linee guida per le immagini e le regole di collegamento che si applicano a ogni articolo generato da Stacc." },
      { title: "Onboarding più intelligente", body: "Stacc ora legge la tua sitemap e comprende i tuoi contenuti esistenti prima di costruire la tua strategia di parole chiave." },
    ],
  },
  {
    date: "Gennaio 2026",
    tag: null,
    entries: [
      { title: "Modulo SEO Locale lanciato", body: "Automatizza i post su Google Business Profile, monitora le recensioni con risposte scritte dall'IA, traccia le parole chiave locali e gestisci più sedi da un unico dashboard." },
      { title: "Integrazione WordPress", body: "Pubblicazione con un clic tramite OAuth o App Password. Categorie, tag e immagini in evidenza vengono gestiti automaticamente." },
      { title: "Supporto multi-progetto", body: "Gestisci più siti web da un singolo account. Ogni progetto ha le proprie impostazioni, membri del team e pipeline di contenuti." },
      { title: "Punteggio SEO in tempo reale", body: "Ogni blog ottiene un punteggio di ottimizzazione in tempo reale con suggerimenti pratici per migliorare la densità delle parole chiave, la struttura e la leggibilità." },
      { title: "Targeting per posizione", body: "Targhetizza qualsiasi posizione geografica. Cerca la tua città e Stacc scopre le aree vicine per espandere la tua portata con le parole chiave." },
    ],
  },
  {
    date: "Dicembre 2025",
    tag: "Lancio",
    entries: [
      { title: "theStacc è stato lanciato", body: "Piani di contenuto con IA, ricerca di parole chiave, scrittura di blog e pubblicazione automatica. Tutto da un'unica piattaforma." },
      { title: "Onboarding intelligente", body: "Inserisci il tuo URL e Stacc estrae i tuoi servizi, trova i tuoi concorrenti e mappa i tuoi primi 30 argomenti del blog." },
      { title: "Calendario visuale dei contenuti", body: "Visualizza l'intero mese a colpo d'occhio. Tieni traccia di ciò che è pianificato, in generazione, pubblicato o richiede attenzione." },
      { title: "Tono del brand e targeting del pubblico", body: "Definisci il tuo tono e fino a 6 profili di cliente ideale affinché ogni articolo parli alle persone giuste." },
    ],
  },
];
---

<BaseLayout
  title="Changelog | theStacc"
  description="Novità di theStacc. Aggiornamenti del prodotto, nuove funzionalità e miglioramenti della piattaforma. Aggiornato mensilmente."
  lang="it"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- DARK HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="max-w-6xl mx-auto px-6 relative z-10 py-16 text-center">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Changelog</p>
        <h1 class="mx-auto mt-4 max-w-[560px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[44px]">
          Novità di theStacc
        </h1>
        <p class="mx-auto mt-4 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          Aggiornamenti del prodotto, nuove integrazioni e miglioramenti della piattaforma. Aggiornato ogni mese.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {[
            'Aggiornato mensilmente',
            `${changelog.reduce((n, m) => n + m.entries.length, 0)} aggiornamenti rilasciati`,
            'Da dicembre 2025 ad oggi',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- TIMELINE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="mx-auto max-w-[760px]">
          <div class="space-y-14">
            {changelog.map((month) => (
              <div>
                <div class="flex items-center gap-3 mb-6">
                  <div class="h-2.5 w-2.5 shrink-0 rounded-full bg-[#4f39f6]"></div>
                  <h2 class="font-mono text-[13px] font-bold uppercase tracking-[0.12em] text-[#292524]">{month.date}</h2>
                  {month.tag && (
                    <span class={`rounded-full px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.1em] ${month.tag === 'Lancio' ? 'bg-[#fef3c7] text-[#92400e]' : 'bg-[#f0fdf4] text-[#166534]'}`}>{month.tag}</span>
                  )}
                  <div class="flex-1 border-t border-[#e7e5e4]"></div>
                </div>

                <div class="ml-5 space-y-3">
                  {month.entries.map(entry => (
                    <div class="rounded-xl border border-[#e7e5e4] bg-white px-5 py-4 transition-colors hover:border-[#c4b5fd]">
                      <p class="font-sans text-[14px] font-semibold text-[#292524]">{entry.title}</p>
                      <p class="mt-1 font-sans text-[13px] leading-[1.65] text-[#79716b]">{entry.body}</p>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- DARK CTA -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="max-w-6xl mx-auto px-6 relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Prova quello che stiamo costruendo.
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Ogni aggiornamento sopra è disponibile nel tuo account dal primo giorno. Inizia con $1 e vedi tutto in azione.
        </p>
        <a href="/it/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Inizia la prova a $1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">$1 per 30 giorni · Cancella quando vuoi</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
