---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il rank tracking per il SEO locale?", a: "Il rank tracking locale è il monitoraggio della posizione della tua attività nelle ricerche Google rilevanti per la tua zona — il local pack (le 3 aziende mostrate con la mappa), Google Maps e i risultati organici. A differenza del SEO tradizionale che traccia solo le posizioni organiche, il rank tracking locale misura dove appari quando qualcuno cerca 'idraulico Milano' o 'dentista vicino a me'." },
  { q: "Con quale frequenza Stacc controlla le posizioni?", a: "Stacc esegue aggiornamenti giornalieri delle posizioni per ogni keyword tracciato. Ricevi un report giornaliero e avvisi immediati quando una posizione cambia significativamente — sia in miglioramento che in peggioramento. Non aspetti più una settimana per accorgerti di un calo." },
  { q: "Su quali piattaforme viene tracciato il posizionamento?", a: "Stacc traccia il posizionamento su tre superfici distinte: local pack di Google (le schede con mappa), Google Maps e risultati organici. Per le attività locali, il local pack è spesso la fonte di traffico più importante — quindi è fondamentale monitorarlo separatamente dall'organico." },
  { q: "Posso monitorare le posizioni per più sedi?", a: "Sì. Stacc è progettato per la gestione multi-sede. Ogni sede ha il suo set di keyword tracciati in modo indipendente. Puoi confrontare le performance di tutte le sedi in una vista portfolio unificata e identificare rapidamente quali mercati necessitano di attenzione." },
  { q: "Cosa succede quando cambia una posizione?", a: "Stacc invia avvisi immediati in caso di variazioni significative di ranking — sia miglioramenti che cali. Puoi configurare le soglie di avviso: ad esempio, ricevere una notifica solo quando una posizione cambia di 5 o più posti. Gli avvisi arrivano via email o notifica in-app." },
  { q: "Il rank tracking è incluso nel modulo SEO locale?", a: "Sì. Il monitoraggio giornaliero delle posizioni — local pack, Maps e organico — è incluso nel modulo SEO locale da $49/mese. Non è necessario un modulo separato." },
  { q: "Quanto costa?", a: "Il rank tracking è incluso nel modulo SEO locale di Stacc da $49/mese. Questo comprende aggiornamenti giornalieri, avvisi su variazioni, monitoraggio multi-sede e integrazione con i report white-label automatici." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software Monitoraggio Posizioni",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Software di monitoraggio posizioni locale con aggiornamenti giornalieri su local pack, Maps e organico. Avvisi automatici su variazioni di ranking.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software Monitoraggio Posizioni", "item": "https://thestacc.com/it/software-monitoraggio-posizioni/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Software Monitoraggio Posizioni — Rank Tracking Locale Giornaliero | theStacc"
  description="Monitora le tue posizioni ogni giorno su local pack, Maps e organico. theStacc traccia i ranking locali automaticamente e ti avvisa in tempo reale su ogni variazione."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software Monitoraggio Posizioni · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Posizionamento locale monitorato<br />
            <span style="color:#4f39f6;">ogni giorno. Su tutte le superfici.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Aggiornamenti giornalieri delle posizioni su local pack, Google Maps e organico. Avvisi immediati su ogni variazione di ranking. Per ogni sede, ogni giorno, automaticamente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Come funziona
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- NARRATIVA -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perché il rank tracking giornaliero è fondamentale</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Google aggiorna i ranking ogni giorno.<br />I controlli settimanali sono troppo lenti.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              L'algoritmo di Google per il local pack si aggiorna continuamente. Un nuovo concorrente ottimizza il suo profilo GBP il lunedì e potrebbe superarti entro il giovedì. Una citation inconsistente scoperta da Google può abbassarti di 3 posizioni nel giro di giorni. Se stai controllando le posizioni settimanalmente o mensilmente, stai vedendo i danni dopo che si sono già verificati.
            </p>
            <p>
              Il monitoraggio giornaliero cambia la dinamica. Quando una posizione cala il martedì, ricevi l'avviso il martedì — non la settimana successiva. Puoi identificare la causa, correggere il problema e fermarne l'impatto prima che si consolidi. La velocità di risposta è il vantaggio competitivo nel SEO locale.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc monitora le tue posizioni su tre superfici — local pack, Maps e organico — ogni singolo giorno, per ogni sede. Ricevi avvisi immediati su variazioni rilevanti e una vista storica di come le posizioni si muovono nel tempo, senza dover accedere a nessuno strumento manualmente.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa fa Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una piattaforma. Ogni superficie di ranking.<br />Monitorata ogni giorno.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Rank tracking giornaliero — local pack + organico', 'Posizioni Google Maps per area di servizio', 'Avvisi su variazioni di ranking in tempo reale', 'Comparazione multi-sede e analisi trend'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Pubblicati direttamente sul tuo sito', 'Ricerca keyword inclusa', 'Link interni ottimizzati'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri con immagini', 'Instagram, LinkedIn, Facebook, X', 'Scritti e programmati automaticamente', 'Contenuto coerente al brand'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni keyword tracciato.<br />Ogni superficie monitorata. Ogni giorno.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Local Pack -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tracking Local Pack</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sappi esattamente dove ti posizioni nelle 3 schede del local pack — la fonte di traffico più importante per il SEO locale.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Per le ricerche locali ad alto intento, il pack da 3 cattura la maggior parte dei click. Stacc traccia separatamente la tua posizione nel local pack — non mescolata con i risultati organici — così puoi vedere immediatamente se sei nelle 3 posizioni che generano chiamate o se sei finito sulla seconda pagina di Maps. Le keyword vengono controllate ogni giorno e i cambiamenti vengono segnalati in tempo reale.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posizioni local pack — oggi</p>
              {[
                { kw: 'idraulico vicino a me', pack: 1, change: '+2', trend: 'up' },
                { kw: 'idraulico urgente Milano', pack: 2, change: '+1', trend: 'up' },
                { kw: 'riparazione caldaie Milano', pack: 3, change: '+4', trend: 'up' },
                { kw: 'idraulico 24 ore Milano', pack: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Aggiornato giornalmente · Local pack isolato</p>
            </div>
          </div>

          <!-- Avvisi -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Avviso ranking — questa mattina</p>
              <div class="rounded-xl border border-[#fee2e2] bg-[#fef2f2] p-4 mb-3">
                <div class="flex items-center justify-between mb-2">
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#dc2626]">↓ Calo rilevato</span>
                  <span class="font-mono text-[10px] text-[#79716b]">06:42</span>
                </div>
                <p class="font-sans text-[13px] text-[#374151]">"dentista urgente Roma" — passato da #2 a #6 nel local pack.</p>
              </div>
              <div class="rounded-xl border border-[#dcfce7] bg-[#f0fdf4] p-4 mb-3">
                <div class="flex items-center justify-between mb-2">
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#059669]">↑ Miglioramento</span>
                  <span class="font-mono text-[10px] text-[#79716b]">06:42</span>
                </div>
                <p class="font-sans text-[13px] text-[#374151]">"sbiancamento denti Roma" — passato da #5 a #2 nel local pack.</p>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Avvisi configurabili per soglia · Email + dashboard</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Avvisi Variazioni Ranking</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Scopri i cali in tempo reale, non quando il cliente ti chiama.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc invia avvisi automatici quando una posizione si muove di più della soglia che imposti — sia in caduta che in miglioramento. Configuri una sola volta i parametri (es. avviso quando una keyword cambia di 3 posizioni o più) e ricevi notifiche via email e in dashboard. Reagisci alle variazioni il giorno stesso, non la settimana dopo, quando il danno è già consolidato.
              </p>
              <a href="/it/software-seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il software SEO locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Multi-sede -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tracking Multi-Sede</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Confronta tutte le sedi in una vista unica. Identifica subito chi ha bisogno di attenzione.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Per franchising, gruppi multi-sede e agenzie con portfolio clienti ampi, il rank tracking deve scalare. Stacc traccia ogni sede in modo indipendente — keyword separate, posizioni separate, trend separati — ma li mostra tutti in una dashboard unificata. Vedi a colpo d'occhio quale sede sta crescendo, quale sta arretrando e dove concentrare le risorse.
              </p>
              <a href="/it/software-seo-multi-sede/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri Stacc per multi-sede
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Portfolio sedi — questa settimana</p>
              {[
                { name: 'Milano Centro', avg: 2.3, change: '+0.4', trend: 'up' },
                { name: 'Roma Eur', avg: 3.1, change: '+0.8', trend: 'up' },
                { name: 'Torino Sud', avg: 4.7, change: '-0.6', trend: 'down' },
                { name: 'Napoli Vomero', avg: 2.9, change: '+0.2', trend: 'up' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] font-medium text-[#374151] truncate">{r.name}</span>
                  <span class="font-mono text-[12px] font-semibold text-[#111827]">Pos. media #{r.avg}</span>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#dc2626]'}`}>{r.trend === 'up' ? '↑' : '↓'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Confronta sedi · Identifica priorità · 1 dashboard</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Funzionalità di monitoraggio</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Rank tracking progettato<br />per il SEO locale a scale.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
