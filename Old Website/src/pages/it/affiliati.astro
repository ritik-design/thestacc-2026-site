              <ul id="aff-dropdown-menu" class="absolute left-0 right-0 top-full z-10 mt-1 hidden overflow-hidden rounded-xl border border-[#e7e5e4] bg-white shadow-lg">
                <li data-value="Blog / Sito web" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Blog / Sito web</li>
                <li data-value="YouTube" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">YouTube</li>
                <li data-value="Newsletter email" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Newsletter email</li>
                <li data-value="Social media" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Social media</li>
                <li data-value="Podcast" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Podcast</li>
                <li data-value="Agenzia / Consulenza" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Agenzia / Consulenza</li>
                <li data-value="Altro" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Altro</li>
              </ul>
            </div>
