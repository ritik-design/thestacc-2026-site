---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const legalPages = [
  { label: 'Privacy Policy', href: '/it/privacy/' },
  { label: 'Termini di Servizio', href: '/it/termini/' },
  { label: 'Cookie Policy', href: '/it/cookie/' },
  { label: 'Trattamento Dati', href: '/it/trattamento-dati/' },
  { label: 'Licenze', href: '/it/licenze/' },
];

const frontendLibraries = [
  { name: 'Astro',        licence: 'MIT License',           url: 'https://astro.build' },
  { name: 'Tailwind CSS', licence: 'MIT License',           url: 'https://tailwindcss.com' },
  { name: 'Three.js',     licence: 'MIT License',           url: 'https://threejs.org' },
];

const fonts = [
  { name: 'Geist Sans', licence: 'SIL Open Font License', url: 'https://fonts.google.com/specimen/Geist' },
  { name: 'Geist Mono', licence: 'SIL Open Font License', url: 'https://fonts.google.com/specimen/Geist+Mono' },
];

const devTools = [
  { name: 'TypeScript', licence: 'Apache License 2.0', url: 'https://typescriptlang.org' },
];
---

<BaseLayout
  title="Licenze Open Source | theStacc"
  description="Licenze software open source e dei font utilizzati in theStacc. Attribuzioni complete e dettagli di licenza per tutti i componenti di terze parti."
  lang="it"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="min-h-screen bg-[#fafaf9]">
    <div class="relative overflow-hidden border-b border-white/10" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.5) 0%, transparent 62%);" aria-hidden="true"></div>
      <div class="max-w-6xl mx-auto px-6 relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#818cf8]">Legale</span>
        <h1 class="mt-2 text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.5rem]">Licenze Open Source</h1>
        <p class="mt-2 font-mono text-[12px] text-white/40">Ultimo aggiornamento: Aprile 2026</p>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <div class="mx-auto max-w-5xl lg:grid lg:grid-cols-[220px_1fr] lg:gap-12">

        <aside class="mb-10 lg:mb-0">
          <div class="lg:sticky lg:top-8 flex flex-col gap-6">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#79716b]">In questa pagina</p>
              <nav class="flex flex-col gap-0.5">
                {[
                  { id: 'intro',      label: 'Informazioni' },
                  { id: 'frontend',   label: 'Tecnologie frontend' },
                  { id: 'fonts',      label: 'Font' },
                  { id: 'devtools',   label: 'Strumenti di sviluppo' },
                ].map(item => (
                  <a href={`#${item.id}`} class="rounded-lg px-3 py-2 text-[13px] text-[#79716b] transition-colors hover:bg-[#f5f3ff] hover:text-[#4f39f6]">
                    {item.label}
                  </a>
                ))}
              </nav>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#79716b]">Documenti legali</p>
              <nav class="flex flex-col gap-0.5">
                {legalPages.map(page => (
                  <a href={page.href} class={`rounded-lg px-3 py-2 text-[13px] transition-colors ${page.href === '/it/licenze/' ? 'bg-[#f5f3ff] font-semibold text-[#4f39f6]' : 'text-[#79716b] hover:bg-[#fafaf9] hover:text-[#374151]'}`}>
                    {page.label}
                  </a>
                ))}
              </nav>
            </div>
          </div>
        </aside>

        <article class="max-w-none text-[#292524]">

          <section id="intro" class="mb-10">
            <p class="text-[#57534e] leading-relaxed">
              theStacc è realizzato utilizzando software open source e font di terze parti. Ringraziamo gli sviluppatori e le comunità che hanno reso disponibile il loro lavoro. Di seguito è riportato un elenco delle principali librerie open source e asset utilizzati, con le rispettive licenze.
            </p>
          </section>

          <div class="border-t border-[#e7e5e4] mb-10"></div>

          <section id="frontend" class="mb-10">
            <h2 class="text-[1.375rem] font-semibold text-[#292524] mb-5">Tecnologie frontend</h2>
            <div class="overflow-hidden rounded-xl border border-[#e7e5e4] bg-white">
              <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#f5f3ff] px-5 py-3">
                <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Libreria</span>
                <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Licenza</span>
              </div>
              {frontendLibraries.map((item, i) => (
                <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < frontendLibraries.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-[15px] font-medium text-[#292524] transition-colors hover:text-[#4f39f6]"
                  >
                    {item.name}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                  <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
                </div>
              ))}
            </div>
          </section>

          <div class="border-t border-[#e7e5e4] mb-10"></div>

          <section id="fonts" class="mb-10">
            <h2 class="text-[1.375rem] font-semibold text-[#292524] mb-5">Font</h2>
            <div class="overflow-hidden rounded-xl border border-[#e7e5e4] bg-white">
              <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#f5f3ff] px-5 py-3">
                <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Font</span>
                <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Licenza</span>
              </div>
              {fonts.map((item, i) => (
                <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < fonts.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-[15px] font-medium text-[#292524] transition-colors hover:text-[#4f39f6]"
                  >
                    {item.name}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                  <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
                </div>
              ))}
            </div>
          </section>

          <div class="border-t border-[#e7e5e4] mb-10"></div>

          <section id="devtools" class="mb-10">
            <h2 class="text-[1.375rem] font-semibold text-[#292524] mb-5">Strumenti di sviluppo</h2>
            <div class="overflow-hidden rounded-xl border border-[#e7e5e4] bg-white">
              <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#f5f3ff] px-5 py-3">
                <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Strumento</span>
                <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Licenza</span>
              </div>
              {devTools.map((item, i) => (
                <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < devTools.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-[15px] font-medium text-[#292524] transition-colors hover:text-[#4f39f6]"
                  >
                    {item.name}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                  <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
                </div>
              ))}
            </div>
            <p class="mt-5 text-[13px] text-[#79716b]">
              Per l'elenco completo delle dipendenze e delle relative licenze, consulta il nostro <code class="rounded bg-[#f5f3ff] px-1.5 py-0.5 font-mono text-[12px] text-[#4f39f6]">package.json</code> o contattaci all'indirizzo <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
            </p>
          </section>

        </article>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
