---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { SITE_URL, LOGO_URL, buildBreadcrumbs } from '../../utils/schema';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const blogTiers = [
  { label: '30 articoli', count: 30, price: 99 },
  { label: '50 articoli', count: 50, price: 149 },
  { label: '80 articoli', count: 80, price: 199, best: true },
];
const localTiers = [
  { label: '30 post', count: 30, price: 49 },
  { label: '60 post', count: 60, price: 79 },
  { label: '80 post', count: 80, price: 99, best: true },
];
const socialTiers = [
  { label: '30 post', count: 30, price: 49 },
  { label: '60 post', count: 60, price: 79 },
  { label: '120 post', count: 120, price: 129, best: true },
];

const blogFeatures = [
  'Ricerca parole chiave e analisi della concorrenza',
  'Pubblicazione automatica sul tuo sito',
  'WordPress, Webflow, Ghost e altro',
  'Ottimizzato per SEO nella tua voce di brand',
];
const localFeatures = [
  'Post automatici su Google Business Profile',
  'Risposte alle recensioni con IA',
  'Monitoraggio parole chiave locali',
  'Supporto multi-sede',
];
const socialFeatures = [
  'Pubblicazione automatica e programmazione',
  'Analytics multi-piattaforma',
  'Contenuto con voce di brand',
  '4 piattaforme incluse',
];

const managedPlans = [
  {
    name: 'Crescita Locale',
    tagline: 'Contenuto + SEO Locale, completamente gestito.',
    price: 749,
    annualPrice: 625,
    features: [
      '30 articoli blog pubblicati/mese',
      '30 post GBP/mese',
      'Monitoraggio e risposte recensioni giornalieri',
      'Report performance settimanali',
      'Videocall strategica mensile',
      '1 sede inclusa (+$150 per sede extra)',
    ],
    popular: false,
    comparison: null as string | null,
  },
  {
    name: 'Crescita Pro',
    tagline: 'Contenuto + SEO Locale + Social Media.',
    price: 999,
    annualPrice: 835,
    features: [
      'Tutto di Crescita Locale',
      '60 post social su 6 piattaforme/mese',
      'Contenuto e hashtag specifici per piattaforma',
      'Orario di pubblicazione ottimizzato',
      'Monitoraggio interazioni giornaliero',
      'Analytics mensile + call strategica',
    ],
    popular: true,
    comparison: null as string | null,
  },
  {
    name: 'Crescita Completa',
    tagline: 'Tutto. Blog, locale, social e sito web.',
    price: 1299,
    annualPrice: 999,
    features: [
      'Tutto di Crescita Pro',
      'Sito web AI, ospitato e gestito',
      'Aggiornamenti mensili del sito e ottimizzazione SEO',
      'Monitoraggio velocità e patch di sicurezza',
      'Report settimanali + call strategica mensile',
      'Team operativo con sede negli USA',
    ],
    popular: false,
    comparison: 'Confronto: un dipendente marketing part-time costa <strong>$2.500–$4.000/mese</strong>. Un\'agenzia fattura <strong>$3.000–$10.000/mese</strong> di retainer.',
  },
];

const tabs = [
  {
    id: 'blog',
    label: 'SEO Blog',
    icon: '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>',
    title: 'SEO Blog',
    replaces: ['Piattaforma SEO ($99–$399/mese)', 'copywriter freelance ($2.000–$5.000/mese)', 'strumento calendario contenuti'],
    narrative: "Le attività che appaiono in prima pagina pubblicano 20–30 articoli al mese. L'attività media ne pubblica 2. Stacc scrive, ottimizza e pubblica sul tuo sito ogni giorno. Anche se non hai mai posizionato una parola chiave in vita tua. Senza brief. Senza editor. Senza scadenze mancate.",
    stats: [
      { label: 'Velocità contenuto vs. attività media', value: '15× di più', percent: 88, color: 'purple' },
      { label: 'Costo vs. copywriter freelance', value: '95% meno', percent: 95, color: 'green' },
      { label: 'Tempo al primo movimento di ranking', value: '60–90 giorni', percent: 65, color: 'amber' },
    ],
  },
  {
    id: 'local',
    label: 'SEO Locale',
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
    title: 'SEO Locale',
    replaces: ['Agenzia SEO locale ($800–$2.000/mese)', 'strumento di gestione recensioni', 'tracker di posizionamento locale'],
    narrative: "Il tuo Google Business Profile è lo spazio più prezioso nella ricerca locale. Un profilo inattivo è invisibile. Stacc pubblica 30 volte al mese, risponde alle recensioni all'istante e traccia ogni parola chiave nella tua città. Anche se non hai aperto il tuo GBP da mesi.",
    stats: [
      { label: 'Post GBP vs. attività tipica', value: '10× di più', percent: 80, color: 'purple' },
      { label: 'Tempo di risposta alle recensioni', value: 'Meno di 1 ora', percent: 95, color: 'green' },
      { label: 'Miglioramento posizione Maps a 90 giorni', value: '4.7×', percent: 70, color: 'amber' },
    ],
  },
  {
    id: 'social',
    label: 'Social Media',
    icon: '<path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>',
    title: 'Social Media',
    replaces: ['Social media manager ($2.500–$5.000/mese)', 'strumento di programmazione', 'strumento di design'],
    narrative: "L'algoritmo premia la costanza. Le attività che pubblicano ogni giorno ottengono più portata, più follower, più clienti. Stacc genera contenuto nativo per Instagram, LinkedIn, X e Facebook. Anche se hai già provato strumenti di programmazione e li hai abbandonati dopo due settimane.",
    stats: [
      { label: 'Post/mese vs. attività tipica', value: '10× di più', percent: 80, color: 'purple' },
      { label: 'Costo vs. social media manager', value: '98% meno', percent: 98, color: 'green' },
      { label: 'Tempo risparmiato a settimana', value: '5+ ore', percent: 85, color: 'amber' },
    ],
  },
];

const milestones = [
  { month: 'Mese 3', stat: '+47%', desc: 'Pagine indicizzate' },
  { month: 'Mese 6', stat: '+180%', desc: 'Traffico organico' },
  { month: 'Mese 12', stat: '+320%', desc: 'Lead qualificati' },
];

const testimonials = [
  {
    quote: "Siamo passati da 0 a 47 contatti mensili in 4 mesi. Stacc ha sostituito la nostra agenzia da $3.000/mese e i risultati sono migliori.",
    name: "Titolare",
    role: "Studio Dentistico · Milano",
    metric: "47 contatti/mese",
    init: "GR",
  },
  {
    quote: "Ero scettico sui contenuti IA. Ma i nostri articoli appaiono in prima pagina e i clienti li citano durante le consulenze. È il marketing più credibile che abbiamo mai fatto.",
    name: "Socio",
    role: "Studio Legale · Torino",
    metric: "3× traffico organico",
    init: "AS",
  },
  {
    quote: "Top 3 su Maps per 'installazione impianti termici vicino a me' in 90 giorni. I post GBP escono ogni giorno senza che tocchi nulla. La valutazione è passata da 4.1 a 4.8. Per $49 al mese, nulla si avvicina.",
    name: "Luca B.",
    role: "Azienda Impianti · Roma",
    metric: "↑ Top 3 su Maps in 90 giorni",
    init: "LB",
  },
  {
    quote: "Visibilità su Google Maps aumentata del 200% nel primo trimestre. Riceviamo chiamate da zone dove non eravamo mai stati presenti. La configurazione ha richiesto 10 minuti.",
    name: "Agente",
    role: "Agenzia Immobiliare · Bologna",
    metric: "200% visualizzazioni in più su Maps",
    init: "FI",
  },
];

const faqs = [
  {
    q: "Ho già provato il content marketing e non ha funzionato.",
    a: "Il motivo per cui la maggior parte del content marketing fallisce non è il contenuto. È l'inconsistenza. Pubblichi 4 articoli, ti fermi per 6 settimane, ne pubblichi altri 2 e poi molli perché non vedi risultati. L'algoritmo di Google premia la pubblicazione sostenuta e regolare. Stacc pubblica ogni giorno, ogni mese, senza interruzioni. Le attività che usano Stacc e che 'hanno già provato i contenuti' sono quelle che vedono i risultati migliori. Perché questa volta la pubblicazione non si ferma.",
  },
  {
    q: "Quanto tempo prima di vedere risultati?",
    a: "La maggior parte delle attività vede un movimento significativo nel posizionamento entro 60–90 giorni di pubblicazione costante. Il primo mese, Google indicizza il nuovo contenuto. Il secondo mese, i ranking iniziano a muoversi. Tra il mese 3 e il mese 6, il traffico cresce in modo notevole. La SEO non è un gioco di un mese. È un investimento a 6 mesi che produce dividendi per anni. Ogni articolo pubblicato da Stacc continua a lavorare per te, che tu sia abbonato o meno.",
  },
  {
    q: "Vale la pena $99/mese? Sono $1.200 all'anno.",
    a: "Un copywriter freelance chiede tra $150 e $500 per articolo. Con 30 articoli al mese, sono $4.500–$15.000/mese. O $54.000–$180.000/anno. Una piattaforma SEO (Ahrefs, Semrush) costa $99–$399/mese solo per i dati, senza scrittura inclusa. Un solo nuovo cliente dalla ricerca organica paga l'intero costo annuale di Stacc prima di pranzo. I numeri funzionano in un unico modo.",
  },
  {
    q: "Devo scrivere qualcosa o essere molto coinvolto?",
    a: "Nemmeno una parola. Stacc gestisce la ricerca di parole chiave, l'analisi della concorrenza, la creazione dei contenuti, l'ottimizzazione SEO e la pubblicazione sul tuo sito. Completamente automatizzato. Puoi revisionare gli articoli prima della pubblicazione se vuoi, oppure attivare la pubblicazione automatica e controllare mensilmente. La maggior parte dei clienti dedica circa 1–2 ore al mese alla revisione. Il resto del tempo è tuo.",
  },
  {
    q: "Posso cancellare in qualsiasi momento? Ho paura di essere bloccato.",
    a: "Cancella quando vuoi. Senza contratti, senza penali, senza costi di cancellazione. Il contenuto pubblicato da Stacc rimane sul tuo sito per sempre e continua a posizionarsi. Non perdi l'accesso al lavoro passato quando cancelli. Ti fermi solo sulla pubblicazione futura. La maggior parte di chi cancella torna entro 60 giorni quando vede che il traffico si blocca.",
  },
  {
    q: "In cosa si differenzia da ChatGPT o dall'assumere un assistente virtuale?",
    a: "ChatGPT scrive quando lo attivi. Stacc pubblica secondo un calendario, automaticamente, ogni giorno. Un assistente virtuale scrive quando è disponibile, manca le scadenze, ha bisogno di formazione, va in vacanza. Stacc no. La differenza reale sta nel sistema: ricerca parole chiave → ottimizzazione SEO → pubblicazione nel CMS → monitoraggio posizionamento, tutto automatizzato e connesso. ChatGPT è uno strumento. Stacc è il flusso di lavoro completo.",
  },
  {
    q: "Quali piattaforme CMS sono supportate?",
    a: "WordPress, Webflow, Ghost, Shopify e qualsiasi piattaforma che supporta la pubblicazione tramite API o webhook. Se il tuo CMS non è nell'elenco, contattaci. Supportiamo la maggior parte delle piattaforme con un'integrazione personalizzata. La configurazione richiede meno di 10 minuti.",
  },
  {
    q: "Come funziona lo sconto del 15% sul bundle?",
    a: "Seleziona due o più moduli e lo sconto viene applicato automaticamente nella barra di riepilogo in basso sullo schermo. Senza codici coupon. Senza calcoli manuali. Il risparmio appare istantaneamente mentre costruisci il tuo piano.",
  },
];

const pricingSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE_URL}/#software`,
      name: 'theStacc',
      description: 'Piattaforma di automazione SEO con IA che scrive e pubblica contenuti blog, gestisce profili Google Business e automatizza i social media per le PMI italiane.',
      url: SITE_URL,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      inLanguage: 'it',
      offers: [
        { '@type': 'Offer', name: 'SEO Blog', description: '30 articoli SEO scritti con IA pubblicati sul tuo sito ogni mese', price: '99.00', priceCurrency: 'USD', url: `${SITE_URL}/it/prezzi/` },
        { '@type': 'Offer', name: 'SEO Locale', description: 'Ottimizzazione e gestione del Google Business Profile', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/it/prezzi/` },
        { '@type': 'Offer', name: 'Social Media', description: 'Pubblicazione e distribuzione automatizzata sui social media', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/it/prezzi/` },
        { '@type': 'Offer', name: 'Bundle (Tutti i Moduli)', description: 'SEO Blog + SEO Locale + Social Media', price: '167.00', priceCurrency: 'USD', url: `${SITE_URL}/it/prezzi/` },
      ],
      provider: { '@id': `${SITE_URL}/#organization` },
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/it/prezzi/`,
      name: 'Prezzi theStacc — SEO Blog, SEO Locale e Social Media da $99/mese',
      description: 'Scegli il modulo Stacc di cui hai bisogno. SEO Blog da $99/mese, SEO Locale da $49/mese, Social Media da $49/mese. Senza contratti. Cancella quando vuoi.',
      url: `${SITE_URL}/it/prezzi/`,
      inLanguage: 'it',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(`${SITE_URL}/it/prezzi/`, [
      { name: 'Inizio', url: `${SITE_URL}/it/` },
      { name: 'Prezzi', url: `${SITE_URL}/it/prezzi/` },
    ]),
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL },
    },
  ],
};
---

<BaseLayout
  title="Prezzi theStacc — SEO Blog, SEO Locale e Social Media da $99/mese"
  description="Scegli il modulo Stacc di cui hai bisogno. SEO Blog da $99/mese, SEO Locale da $49/mese, Social Media da $49/mese. Senza contratti. Cancella quando vuoi."
  lang="it"
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[820px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">3 moduli · 1 piattaforma · Inizia per $1</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Loro pubblicano ogni giorno.
            <span style="color:#4f39f6;"> Tu no. Questa è la differenza.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc ricerca, scrive e pubblica contenuti SEO, aggiornamenti su Google Business Profile e post social ogni giorno. Automaticamente. Scegli i tuoi moduli e inizia per $1.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="#pricing"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Costruisci il mio piano
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#compare"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Guarda cosa sostituisci
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Garanzia 30 giorni · Senza carta di credito · Cancella quando vuoi
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '300k', num: 300000, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Articoli pubblicati' },
              { value: '340+', num: 340,     prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Attività in crescita' },
              { value: '4.9★', num: 4.9,     prefix: '',  suffix: '★', decimals: 1, from: 0, label: 'Valutazione clienti' },
              { value: '0',    num: 0,       prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Penalizzazioni Google' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Attività in crescita con Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 su 127 recensioni</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PRICING MODULES ─── -->
    <section class="bg-white" id="pricing">

      <!-- ── Controls bar ── -->
      <div class="border-b border-[#e7e5e4]">
        <div class="container-x py-4">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-3">
              <div class="flex items-center gap-1.5">
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Scegli il tuo percorso</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </div>
              <div class="inline-flex overflow-hidden rounded-full border border-[#e7e5e4] bg-[#fafaf9] p-1" role="group" aria-label="Opzione prezzi">
                <a href="#software-pricing" class="rounded-full px-5 py-2 font-sans text-[13px] font-semibold bg-[#111827] text-white shadow-sm">Software</a>
                <a href="#managed-pricing" class="rounded-full px-5 py-2 font-sans text-[13px] font-semibold text-[#9ca3af] hover:text-[#374151] transition-colors">Servizi</a>
              </div>
            </div>
            <div id="billing-controls" class="flex items-center gap-3">
              <span id="mod-billing-label" class="cursor-pointer font-sans text-[13px] font-semibold text-[#374151]">Fatturazione annuale</span>
              <button id="mod-billing-toggle" class="relative h-[24px] w-[44px] shrink-0 cursor-pointer rounded-full bg-[#4f39f6] transition-colors" aria-label="Cambia fatturazione annuale" type="button">
                <div id="mod-billing-dot" class="absolute top-[3px] left-[3px] h-[18px] w-[18px] rounded-full bg-white shadow-sm transition-transform" style="transform:translateX(20px)"></div>
              </button>
              <span id="mod-save-badge" class="rounded-md bg-[#4f39f6]/10 px-2 py-0.5 font-mono text-[11px] font-semibold text-[#4f39f6]">Risparmia 17%</span>
            </div>
          </div>
        </div>
      </div>

