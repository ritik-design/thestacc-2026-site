---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il rivenditore SEO?", a: "Diventare un rivenditore SEO significa erogare servizi SEO ai tuoi clienti usando la piattaforma di Stacc — a un costo di $49/mese — e fatturare ai clienti il prezzo di mercato (tipicamente €300-1.500/mese). Il margine tra il tuo costo e il prezzo che applichi è il profitto della tua agenzia." },
  { q: "Come funziona il modello di rivendita?", a: "Paghi $49/mese per cliente per la piattaforma Stacc. Tu gestisci la relazione con il cliente, imposti la strategia e stabilisci il prezzo che vuoi. Stacc esegue il lavoro — GBP automation, rank tracking, citazioni, report — con il tuo marchio. I clienti non vedono Stacc." },
  { q: "Che margini posso ottenere?", a: "Con un costo di $49/mese per cliente e prezzi di mercato tra €300 e €1.500/mese per i servizi SEO locale, il margine lordo per cliente è tipicamente tra l'85% e il 97%. Un'agenzia con 20 clienti a €500/mese genera €10.000/mese di ricavi con un costo Stacc di circa €1.000/mese." },
  { q: "I clienti scopriranno che uso Stacc?", a: "No. Tutta la piattaforma è completamente white-label: dashboard, report, email e portale clienti portano il tuo marchio. Nessun cliente vede mai Stacc nel suo flusso di lavoro." },
  { q: "Come gestisco più clienti contemporaneamente?", a: "Stacc include una dashboard di gestione multi-cliente. Puoi vedere tutti i tuoi clienti in un unico pannello, monitorare le performance, ricevere avvisi e gestire le attività senza accedere a decine di account separati." },
  { q: "Quanto lavoro continuo richiede ogni cliente?", a: "Con Stacc, il lavoro operativo continuo per cliente è minimo. GBP posting, rank tracking, gestione citazioni e invio report sono tutti automatizzati. Il tuo team si concentra sulla strategia e sulla relazione con il cliente, non sull'esecuzione manuale quotidiana." },
  { q: "Ho bisogno di esperti SEO nel mio team?", a: "Non è necessario un team SEO dedicato. Stacc gestisce l'esecuzione tecnica. È utile avere qualcuno che comprenda la strategia SEO locale per impostare correttamente obiettivi e keyword per ogni cliente — ma il lavoro operativo giornaliero è automatizzato." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Rivenditore SEO",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Programma rivenditore SEO per agenzie. Costo $49/mese per cliente, prezzi di mercato €300-1.500/mese. Piattaforma completamente white-label.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Rivenditore SEO", "item": "https://thestacc.com/it/rivenditore-seo/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Rivenditore SEO — Eroga Servizi SEO con il Tuo Marchio a Margini Elevati | theStacc"
  description="Diventa rivenditore SEO con theStacc. Costo da $49/mese per cliente, prezzi di mercato €300-1.500. Piattaforma completamente white-label, automazione inclusa."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Rivenditore SEO · Da $49/mese per cliente</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Eroga SEO locale con il tuo brand.<br />
            <span style="color:#4f39f6;">Margini fino al 97%.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Costo $49/mese. Prezzo di mercato €300-1.500/mese. Stacc esegue il lavoro SEO — GBP automation, rank tracking, citazioni, report — con il tuo marchio. I clienti vedono solo la tua agenzia.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Come funziona la rivendita
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- ─── L'ECONOMIA DEL RIVENDITORE (PAIN) ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">L'economia del rivenditore SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            $49 di costo. €300-1.500<br />di prezzo di vendita. Il differenziale è tuo.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Il modello di rivendita SEO funziona perché c'è un divario strutturale tra il costo della tecnologia e il valore percepito dai clienti finali. Un'agenzia paga $49/mese per cliente a Stacc. Lo stesso cliente paga tipicamente tra €300 e €1.500/mese per i servizi SEO locale nel mercato italiano. Il margine — tra l'85% e il 97% — va all'agenzia.
            </p>
            <p>
              Ma il vantaggio non è solo economico. È operativo. Invece di assumere specialisti SEO per ogni 5-10 clienti, un'agenzia con Stacc può gestire 30-40 clienti con un team molto ridotto — perché l'automazione fa il lavoro che normalmente richiederebbe ore di esecuzione manuale ogni settimana.
            </p>
            <p class="font-semibold text-[#111827]">
              Il risultato: puoi acquisire più clienti, servirli meglio e farlo con una struttura di costi che scala senza assumere. Questo è il vantaggio competitivo del rivenditore SEO moderno.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW (FUNZIONALITÀ) ─── -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa include il programma rivenditore</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutto il necessario per gestire<br />clienti SEO in modo scalabile.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'White-label completo', body: 'Dashboard, report, email e portale clienti completamente brandizzati con il tuo marchio. Nessun cliente vede Stacc.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automazione GBP', body: '30 post GBP al mese per ogni cliente — scritti e pubblicati automaticamente. Profili sempre attivi, nessun lavoro manuale.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rank tracking', body: 'Monitoraggio posizioni giornaliero per ogni cliente in local pack, Maps e organico. Avvisi su variazioni rilevanti.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Report automatici', body: 'Report clienti generati, brandizzati e inviati automaticamente. Il tuo team non prepara più report manuali.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Gestione citazioni', body: 'Monitoraggio e correzione citazioni su 50+ directory per ogni cliente. NAP coerente = ranking più alto.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Gestione multi-cliente', body: 'Dashboard unificata per tutti i tuoi clienti. Vedi performance, avvisi e attività di ogni account in un unico pannello.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave del programma rivenditore</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Esegui il SEO dei clienti.<br />Senza eseguirlo manualmente.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP per clienti -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pubblicazione GBP per ogni cliente</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 post GBP al mese, per cliente. Pubblicati con il tuo brand. Zero ore del tuo team.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Quando rivendi SEO locale, il problema più grande è la scala dell'esecuzione: pubblicare manualmente 30 post al mese su 20 profili Google Business significa 600 post da scrivere e programmare. Stacc lo fa in automatico per ogni cliente. Tu importi il cliente, configuri città e categoria, e i post iniziano a girare entro 24 ore — con riferimenti al brand del cliente, mai al tuo software fornitore.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Volume mensile rivenditore</p>
              {[
                { label: 'Cliente A — Studio dentistico Milano', val: '30 / 30 post' },
                { label: 'Cliente B — Officina Roma', val: '28 / 30 post' },
                { label: 'Cliente C — Boutique Torino', val: '30 / 30 post' },
                { label: 'Cliente D — HVAC Bologna', val: '26 / 30 post' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e] truncate pr-3">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#4f39f6] shrink-0">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">114 post pubblicati questo mese · Su 4 clienti · Zero lavoro manuale</p>
            </div>
          </div>

          <!-- Rank Tracking multi-cliente -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Vista multi-cliente · Ranking di oggi</p>
              {[
                { client: 'Cliente A', kw: 'dentista vicino a me', pack: 1, change: '+2' },
                { client: 'Cliente B', kw: 'meccanico Roma', pack: 3, change: '+1' },
                { client: 'Cliente C', kw: 'boutique Torino', pack: 2, change: '+3' },
                { client: 'Cliente D', kw: 'climatizzatori Bologna', pack: 4, change: '0' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <span class="w-20 shrink-0 font-mono text-[10px] uppercase tracking-[0.1em] text-[#79716b]">{r.client}</span>
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.change.startsWith('+') ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.change.startsWith('+') ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Aggiornato giornalmente · Tutti i clienti · Una dashboard</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dashboard multi-cliente</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Tutti i tuoi clienti. Un'unica vista. Aggiornata ogni mattina.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Il rivenditore SEO che scala è quello che riesce a controllare 30 clienti in 30 minuti, non in 30 ore. Stacc consolida i ranking di ogni cliente in una dashboard unica — vedi cosa è migliorato, cosa è peggiorato e dove serve attenzione, senza accedere a 30 profili separati. Quando un account inizia a perdere posizioni, ricevi un avviso automatico prima del cliente.
              </p>
              <a href="/it/software-monitoraggio-posizioni/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il rank tracking nel dettaglio
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reportistica white-label -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reportistica brandizzata automatica</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Report che arrivano dal dominio della tua agenzia. Non dal nostro.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Il momento del report è il momento in cui un cliente capisce se la tua agenzia è seria. Stacc genera report mensili e settimanali per ogni cliente — con il tuo logo, i tuoi colori, dal mittente del tuo dominio. Ogni cliente li riceve puntuale lo stesso giorno del mese. Per il cliente, è la tua agenzia che ha costruito un sistema di reportistica enterprise. Per te, è zero lavoro.
              </p>
              <a href="/it/reportistica-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri la reportistica white-label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">La Tua Agenzia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Da: report@tuaagenzia.it</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Inviato</span>
              </div>
              {[
                { label: 'Keyword in top 3', val: '+5 questa settimana' },
                { label: 'Post GBP pubblicati', val: '8 pubblicati' },
                { label: 'Recensioni nuove', val: '4 (media 4.9)' },
                { label: 'Citazioni controllate', val: '50/50 coerenti' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generato e consegnato automaticamente · Nessun branding Stacc visibile</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICHE DARK ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '3×', label: 'Più clienti per dipendente', sub: 'L\'automazione moltiplica la capacità' },
            { value: '400+', label: 'Agenzie già rivendono con Stacc', sub: 'Con clienti attivi in tutto il mondo' },
            { value: '$49', label: 'Costo per cliente al mese', sub: 'Versus €300-1.500 di prezzo di vendita' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa dicono le agenzie</span>
