                  <p class="font-mono text-[9px] uppercase tracking-[0.1em] text-[#79716b]">Mancanti</p>
                </div>
              </div>
              {[
                { dir: 'Google Business Profile', stato: 'Corretto', col: 'text-[#059669]' },
                { dir: 'Apple Maps', stato: 'Inconsistente', col: 'text-[#d97706]' },
                { dir: 'Yelp', stato: 'Corretto', col: 'text-[#059669]' },
