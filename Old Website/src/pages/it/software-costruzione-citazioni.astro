---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il software di gestione citazioni?", a: "Il software di gestione citazioni monitora e mantiene le menzioni della tua attività (Nome, Indirizzo, Telefono — NAP) su directory online, siti di recensioni e piattaforme locali. Trova inconsistenze, le corregge e monitora il profilo citazioni in modo continuativo per garantire che Google veda dati aziendali accurati e coerenti ovunque." },
  { q: "Perché la coerenza NAP è importante per il SEO locale?", a: "Google usa i dati delle citazioni per verificare la legittimità e le informazioni di un'azienda. Quando NAP è inconsistente tra directory diverse, Google riceve segnali contraddittori — questo abbassa la fiducia e il ranking. La coerenza NAP su 50+ directory è uno dei fattori di ranking locali ad impatto più alto, specialmente per il local pack e Maps." },
  { q: "Come trova Stacc le citazioni errate?", a: "Stacc esegue audit automatici su 50+ directory principali — Google, Yelp, Facebook, Apple Maps, Bing, Foursquare e molte altre. Confronta il NAP della tua attività con quanto è elencato su ogni piattaforma e segnala qualsiasi discrepanza: nomi leggermente diversi, vecchi indirizzi, numeri di telefono scaduti o formati diversi." },
  { q: "Stacc può correggere automaticamente le citazioni errate?", a: "Sì, per molte directory. Stacc può inviare aggiornamenti direttamente alle principali directory e aggregatori attraverso le loro API. Per le directory che non supportano aggiornamenti automatici, Stacc fornisce un elenco prioritizzato con le istruzioni di correzione esatte." },
  { q: "Con quale frequenza vengono monitorate le citazioni?", a: "Stacc esegue scansioni delle citazioni in modo continuativo, non solo una volta. Nuove inconsistenze vengono rilevate e segnalate man mano che si sviluppano — ad esempio quando una directory crea automaticamente un nuovo listing con dati errati o quando un aggiornamento su una piattaforma sovrascrive informazioni accurate." },
  { q: "Quante directory monitora Stacc?", a: "Stacc monitora 50+ directory tra le più importanti per il SEO locale, tra cui Google Business Profile, Yelp, Facebook, Apple Maps, Bing Places, Foursquare/Swarm, TripAdvisor, Yellow Pages e molte altre specifiche per settore e zona geografica." },
  { q: "Il software di gestione citazioni funziona per più sedi?", a: "Sì. Stacc monitora e gestisce le citazioni per ogni sede indipendentemente. Con più sedi, le inconsistenze vengono rilevate per ciascuna e le correzioni vengono applicate sede per sede o in blocco dove possibile." },
  { q: "Quanto costa?", a: "La gestione citazioni è inclusa nel modulo SEO locale di Stacc da $49/mese. Include audit continuo, rilevamento inconsistenze, correzione assistita e monitoraggio della rete citazioni per tutte le sedi." },
  { q: "Quanto tempo risparmia il software di gestione citazioni?", a: "Tipicamente 3+ ore a settimana per sede rispetto all'audit manuale. Il risparmio maggiore è nella ricerca — trovare manualmente ogni directory dove l'azienda è elencata e controllare i dati uno a uno richiederebbe ore che il software compie in pochi secondi." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software Gestione Citazioni",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Software per l'audit, la correzione e il monitoraggio delle citazioni locali su 50+ directory. Coerenza NAP garantita per migliorare il ranking su Google Maps e local pack.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software Gestione Citazioni", "item": "https://thestacc.com/it/software-costruzione-citazioni/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Software Gestione Citazioni — Audit e Correzione NAP su 50+ Directory | theStacc"
  description="Software per la gestione delle citazioni locali. theStacc trova inconsistenze NAP su 50+ directory, le corregge e monitora in modo continuativo per migliorare il ranking locale."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Gestione Citazioni · 50+ Directory · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Le tue citazioni NAP accurate<br />
            <span style="color:#4f39f6;">su ogni directory. Automaticamente.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Inconsistenze NAP su directory diverse confondono Google e abbassano il ranking. Stacc trova ogni discrepanza, la corregge e monitora le tue citazioni in modo continuativo — su 50+ directory, per ogni sede.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Come funziona
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- NARRATIVA -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema delle citazioni inconsistenti</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Google vede versioni diverse della tua azienda<br />su diverse directory. Questo ti penalizza.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              La maggior parte delle aziende ha il proprio NAP elencato in modi leggermente diversi su directory diverse — "Via Roma 1" su Google, "V.le Roma, 1" su Yelp, "Via Roma, 1" su Facebook. Questi non sono errori gravi da un punto di vista umano, ma per l'algoritmo di Google sono segnali contraddittori su dove si trova l'azienda e se le informazioni sono affidabili.
            </p>
            <p>
              Le citazioni inconsistenti abbassano direttamente il punteggio di prominenza — uno dei tre fattori principali del ranking Maps di Google. E il problema si aggrava nel tempo: nuove directory vengono create automaticamente con dati vecchi, le informazioni vengono sovrascritte da aggregatori, i numeri di telefono cambiano ma non su tutte le piattaforme.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc elimina questo problema eseguendo audit continui su 50+ directory, identificando ogni inconsistenza NAP e correggendola — sia automaticamente dove possibile, sia con istruzioni precise per le directory che lo richiedono manualmente. Il risultato è un profilo citazioni coerente che rafforza il ranking su Google Maps.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PANORAMICA PIATTAFORMA 3 CARD -->
    <section class="border-b border-[#e7e5e4] bg-white">
