---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Il dashboard white-label è disponibile in tutti i piani?",
    a: "I report white-label — logo, colori e dominio tuoi — sono disponibili nei piani Growth e Scale. Il piano Starter include report con il brand Stacc. Puoi fare upgrade in qualsiasi momento e i calendari di report esistenti vengono trasferiti automaticamente.",
  },
  {
    q: "Quanti account cliente posso gestire?",
    a: "Tutti i piani supportano account cliente illimitati. Il pricing è basato sul numero di sedi che gestisci, non sul numero di clienti. Un'agenzia con 20 clienti con una sede paga lo stesso di un'agenzia con 10 clienti con due sedi — se il totale delle sedi è uguale.",
  },
  {
    q: "Posso controllare cosa vedono i clienti nel loro dashboard?",
    a: "Sì. Decidi esattamente quali dati, funzionalità e report ogni cliente può vedere. Puoi limitare la visibilità per modulo, intervallo di date o sede. I clienti vedono ciò che è utile per loro. Tu mantieni visibilità completa su tutto.",
  },
  {
    q: "Quanto tempo ci vuole per onboardare un nuovo cliente?",
    a: "La maggior parte dei nuovi clienti è completamente configurata — sedi aggiunte, parole chiave impostate, GBP collegato e calendario report attivo — in meno di 45 minuti. Per clienti multi-sede con più di 10 sedi, pianifica un'ora. Dopodiché Stacc gestisce tutto automaticamente.",
  },
  {
    q: "Stacc sostituisce i miei strumenti SEO attuali?",
    a: "Per il SEO locale — rank tracking, gestione citazioni, gestione GBP, monitoraggio recensioni e report clienti — sì. La maggior parte delle agenzie consolida 4–6 strumenti separati in Stacc e riduce il budget strumenti del 60–70%.",
  },
  {
    q: "Posso rivendere Stacc come servizio ai miei clienti?",
    a: "Sì. Molte agenzie usano Stacc come piattaforma base per i loro mandati SEO locali. Con report white-label e portali clienti, i clienti interagiscono sempre con il tuo brand — Stacc è invisibile.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Agenzie",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "La piattaforma SEO locale per agenzie. Gestisci posizionamenti, GBP, recensioni e report white-label automatizzati per ogni cliente da un unico dashboard.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Soluzioni", "item": "https://thestacc.com/it/soluzioni/" },
        { "@type": "ListItem", "position": 3, "name": "Per Agenzie", "item": "https://thestacc.com/it/soluzioni/agenzie/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO Tool per Agenzie — Gestisci Ogni Cliente, Automatizza Tutto | theStacc"
  description="theStacc è la piattaforma SEO locale per agenzie. Gestisci posizionamenti, GBP, recensioni e report white-label automatizzati per ogni cliente da un unico dashboard."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Per Agenzie SEO · White-Label Incluso</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Il tool SEO costruito per le agenzie.<br />
            <span style="color:#4f39f6;">Ogni cliente gestito. Tutto automatizzato.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Un dashboard per il SEO locale di ogni cliente — rank tracking, gestione GBP, monitoraggio recensioni, citazioni e report white-label automatizzati. Tutto automatizzato. Tutto sotto il tuo brand.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Richiedi demo per agenzie
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi i prezzi
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            400+ agenzie · White-Label in tutti i piani Growth · Setup in meno di 5 minuti
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '400+', label: 'Agenzie usano Stacc' },
              { value: '45min', label: 'Tempo medio di onboarding' },
              { value: '80%', label: 'Meno tempo per i report manuali' },
              { value: '3×', label: 'Più clienti, stesso team' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Se gestisci un'agenzia SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conosci esattamente questa sensazione.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'La tassa dei report.',
              body: 'Ogni lunedì mattina qualcuno del tuo team costruisce report invece di fare vero SEO. 4 ore per cliente al mese. Con 20 clienti sono 80 ore al mese — un lavoro a tempo pieno che produce solo PDF che nessuno vuole creare.',
            },
            {
              icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
              title: '"Ci stiamo posizionando?" — il venerdì sera.',
              body: 'Un cliente chiama. Non hai la risposta davanti a te. Apri una scheda incognito. Guadagni tempo mentre il cliente perde fiducia. Non dovresti impiegare 20 minuti per rispondere a una domanda che dovresti già conoscere.',
            },
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Sei strumenti. Sei login. Il team annega nei tab.',
              body: 'Rank tracker. Strumento citazioni. Gestione GBP. Piattaforma recensioni. Software di reportistica. Dashboard analytics. Ogni cliente ha bisogno di tutti e sei. Ogni strumento ha il suo login, il suo formato dati, il suo processo di export.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'La crescita ti costa capacità prima di portarti denaro.',
              body: 'Ogni nuovo cliente significa più lavoro manuale. A un certo punto smetti di accettare nuovi clienti per fermare il sanguinamento. L\'azienda che doveva crescere si scontra con un soffitto di fogli di calcolo.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── COMPARISON TABLE ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa cambia con Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una piattaforma. Ogni cliente.<br />Niente manuale.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Senza Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Con Stacc</div>
          </div>
          {[
            { label: 'Report clienti',              before: '4–6 ore manuale / cliente / mese',    after: 'Automatizzati, consegnati puntualmente' },
            { label: 'Stack strumenti',              before: '4–6 strumenti, 4–6 fatture',          after: 'Una piattaforma, una fattura' },
            { label: 'Trasparenza clienti',          before: 'Il cliente chiede → tu corri',        after: 'Dashboard sempre aggiornato' },
            { label: 'Onboarding nuovo cliente',     before: 'Minimo 3–4 ore',                      after: 'Meno di 45 minuti' },
            { label: 'Monitoraggio posizionamenti',  before: 'Controllo manuale settimanale',        after: 'Avvisi automatici giornalieri' },
            { label: 'Gestione GBP',                 before: 'Login separato per ogni account',     after: 'Tutte le sedi in un unico posto' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">ROI per Agenzie</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            I numeri che contano<br />quando gestisci un'agenzia.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '80%', label: 'Meno tempo per report manuali', sub: 'recuperato ogni mese sulla base clienti completa' },
            { value: '3×', label: 'Più clienti, stesso team', sub: 'quando report e monitoraggio sono automatizzati' },
            { value: '45min', label: 'Tempo di setup per nuovo cliente', sub: 'da zero a completamente configurato e attivo' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIALS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Titolari di agenzie</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cosa succede quando le agenzie smettono<br />di fare tutto manualmente.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-2">
          {[
            { quote: "Siamo passati da 18 a 41 clienti in 8 mesi senza assumere nessuno. Stacc ha automatizzato i report e il monitoraggio che consumavano tutta la nostra capacità. La piattaforma si è ripagata da sola.", name: "Marco D.", role: "Fondatore, Agenzia SEO Locale", result: "18 → 41 clienti, stesso team" },
            { quote: "La fidelizzazione dei clienti è migliorata. I report arrivano ogni lunedì puntualmente con dati reali. I clienti prima si chiedevano perché pagavano. Ora ricevono le prove ogni settimana. In 6 mesi nessun cliente ha messo in discussione il mandato.", name: "Alessia T.", role: "Direttrice Agenzia, 23 clienti", result: "0 churn in 6 mesi" },
          ].map(t => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="flex gap-1 mb-5">
                {[1,2,3,4,5].map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
              </div>
              <blockquote class="font-sans text-[15px] leading-[1.7] text-[#292524]">"{t.quote}"</blockquote>
              <div class="mt-6 flex items-center gap-3">
                <div class="h-10 w-10 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                  <span class="font-mono text-[12px] font-bold text-white">{t.name.split(' ').map((n: string) => n[0]).join('')}</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">{t.name}</p>
                  <p class="font-mono text-[10px] text-[#79716b]">{t.role}</p>
                </div>
                <span class="ml-auto rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">{t.result}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Domande frequenti</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Domande che le agenzie fanno prima di iniziare
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">A un setup dalla fine dei report manuali</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Non dovrai mai più creare manualmente<br />un report per un cliente.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Le agenzie che crescono più velocemente non sono più intelligenti. Non lavorano più duramente. Non assumono più velocemente. Lavorano con un'infrastruttura migliore — e usano il tempo recuperato per crescere davvero. Unisciti alle 400+ agenzie che hanno fatto questo passo.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Richiedi demo per agenzie
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Vedi i prezzi
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Garanzia 30 giorni · Nessun contratto · Cancella quando vuoi</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
