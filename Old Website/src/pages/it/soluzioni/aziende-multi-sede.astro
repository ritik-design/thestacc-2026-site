---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Per quante sedi è progettato Stacc?",
    a: "Stacc supporta da una singola sede fino a 500+ sedi in un unico account. Il pricing scala con il numero di sedi — paghi solo per quello che gestisci.",
  },
  {
    q: "Posso assegnare team diversi a sedi diverse?",
    a: "Sì. Puoi configurare permessi di accesso specifici per sede per utenti diversi. I manager regionali vedono solo le loro sedi, mentre gli amministratori hanno visibilità su tutte le sedi.",
  },
  {
    q: "Quanto tempo richiede la configurazione di più sedi?",
    a: "La maggior parte degli account multi-sede viene completamente configurata in un'unica sessione. Con la funzione di importazione massiva puoi caricare tutte le informazioni delle sedi in una volta. La personalizzazione per singola sede (keyword specifiche, connessione GBP) richiede 10–15 minuti per sede.",
  },
  {
    q: "Stacc traccia il ranking per ogni sede separatamente?",
    a: "Sì. Ogni sede ha la propria lista di keyword e traccia i ranking per il suo specifico mercato geografico. Una sede a Milano monitora keyword locali diverse rispetto a una sede a Napoli — anche se si tratta dello stesso tipo di attività.",
  },
  {
    q: "Posso ricevere report aggregati per tutte le sedi e report individuali per singola sede?",
    a: "Sì. Stacc può generare sia report di portfolio aggregati (riepilogo di tutte le sedi) che report individuali per sede — con cadenze diverse e a destinatari diversi.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Aziende Multi-Sede",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Gestisci ranking, recensioni, GBP e citazioni per tutte le tue sedi da un'unica piattaforma. Scala la tua presenza SEO locale senza investire proporzionalmente più tempo.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Soluzioni", "item": "https://thestacc.com/it/soluzioni/" },
        { "@type": "ListItem", "position": 3, "name": "Aziende Multi-Sede", "item": "https://thestacc.com/it/soluzioni/aziende-multi-sede/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO Locale per Aziende Multi-Sede — Tutte le Sedi in un Dashboard | theStacc"
  description="Gestisci ranking, recensioni, GBP e citazioni per tutte le tue sedi da un'unica piattaforma. Scala la tua presenza SEO locale senza investire proporzionalmente più tempo."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Per Aziende Multi-Sede</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Gestire il SEO di 10 sedi<br />non dovrebbe costare 10× più tempo.<br /><span style="color:#4f39f6;">Con Stacc non è così.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Gestisci ranking, recensioni, profili GBP e citazioni per tutte le tue sedi da un unico dashboard. Scala la tua presenza SEO locale senza investire proporzionalmente più tempo e risorse.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Richiedi una demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi i prezzi
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Scala da 2 a 500+ sedi · Ranking aggiornati ogni giorno · GDPR-compliant
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '500+',    label: 'Sedi in un unico dashboard' },
              { value: 'Ogni giorno', label: 'Aggiornamenti ranking per ogni sede' },
              { value: 'Centrale', label: 'Tutte le sedi in un\'unica piattaforma' },
              { value: '4.9★',   label: 'Valutazione clienti' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Per le Aziende Multi-Sede</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Le sfide che ogni azienda<br />multi-sede conosce bene.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Strumenti separati per ogni sede rendono la supervisione impossibile.',
              body: 'Quando ogni sede ha il suo strumento, il suo accesso e il suo formato di reportistica, si passa più tempo a navigare tra sistemi che a ottimizzare realmente. I problemi rimangono nascosti perché controllarli richiede troppo sforzo manuale.',
            },
            {
              icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
              title: 'Un problema di ranking in una sede danneggia l\'intera reputazione del network.',
              body: 'Una sede con ranking in calo o recensioni negative che non tieni d\'occhio ti costa clienti ogni giorno. Con più sedi il rischio è proporzionalmente più alto — ma la capacità di monitoraggio manuale rimane la stessa.',
            },
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Dati aziendali incoerenti tra le sedi penalizzano l\'intero network.',
              body: 'Se le citazioni per la sede A sono corrette ma per la sede C sono errate, l\'intera azienda perde potere di ranking locale. La coerenza NAP va mantenuta per tutte le sedi contemporaneamente — praticamente impossibile a mano.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'La crescita genera complessità operativa prima di generare fatturato.',
              body: 'Ogni nuova sede non raddoppia il carico gestionale — lo moltiplica. Senza l\'infrastruttura giusta, ogni nuova apertura diventa un freno invece che un motore di crescita.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── WHAT CHANGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa cambia con Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutte le sedi. Una piattaforma.<br />Scalabile.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Senza Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Con Stacc</div>
          </div>
          {[
            { label: 'Monitoraggio ranking',        before: 'Ogni sede controllata separatamente',          after: 'Tutte le sedi in un unico dashboard' },
            { label: 'Monitoraggio recensioni',     before: 'Controllo manuale per piattaforma per sede',   after: 'Alert in tempo reale per tutte le sedi' },
            { label: 'Gestione profili GBP',        before: 'Login separato per ogni sede',                 after: 'Tutti i profili GBP gestiti centralmente' },
            { label: 'Coerenza citazioni',          before: 'Audit manuali periodici',                      after: 'Monitoraggio automatico continuo' },
            { label: 'Confronto performance',       before: 'Assemblato manualmente da report singoli',     after: 'Confronto immediato tra sedi nel dashboard' },
            { label: 'Configurazione nuove sedi',   before: 'Ore per ogni sede',                            after: 'Minuti con configurazione guidata' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE HIGHLIGHTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Progettato per il multi-sede</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni funzionalità di cui hai bisogno<br />per gestire tutte le sedi.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Portfolio Overview -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Panoramica portfolio</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Vedi tutte le sedi a colpo d'occhio. Approfondisci quando serve.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Il dashboard portfolio mostra metriche aggregate su tutte le sedi — e accanto le performance individuali. Identifica immediatamente gli outlier: quale sede è sotto media, dove calano le recensioni, dove scendono i ranking.
              </p>
              <ul class="mt-6 space-y-3">
                {['Metriche aggregate del portfolio su tutte le sedi', 'Confronto tra sedi per ranking, recensioni e attività GBP', 'Segnalazione automatica delle sedi sotto la media', 'Click su una sede per analisi approfondita completa'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Panoramica portfolio</p>
                <span class="rounded-full bg-[#f5f3ff] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#4f39f6]">4 sedi</span>
              </div>
              <div class="space-y-3">
                {[
                  { name: 'Milano Centro', rank: '#2 locale', reviews: '4.8★', status: 'ok' },
                  { name: 'Napoli Chiaia', rank: '#5 locale', reviews: '4.2★', status: 'attenzione' },
                  { name: 'Roma Prati', rank: '#1 locale', reviews: '4.9★', status: 'ok' },
                  { name: 'Torino Crocetta', rank: '#3 locale', reviews: '4.6★', status: 'ok' },
                ].map(loc => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="h-7 w-7 rounded-lg bg-[#4f39f6] flex items-center justify-center shrink-0">
                      <span class="font-mono text-[9px] font-bold text-white">{loc.name[0]}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{loc.name}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{loc.rank} · {loc.reviews}</p>
                    </div>
                    <span class={`font-mono text-[10px] font-semibold shrink-0 ${loc.status === 'ok' ? 'text-[#059669]' : 'text-[#d97706]'}`}>{loc.status === 'ok' ? 'Ottimo' : 'Controlla'}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Centralized GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Gestione GBP · Tutte le sedi</p>
              <div class="space-y-3">
                {[
                  { action: 'Orari festivi', scope: 'Tutte le 4 sedi', status: 'Pubblicato' },
                  { action: 'Nuova foto prodotto', scope: 'Milano, Napoli', status: 'Programmato' },
                  { action: 'Offerta di gennaio', scope: 'Tutte le 4 sedi', status: 'Bozza' },
                  { action: 'Aggiornamento profilo GBP', scope: 'Roma', status: 'Pubblicato' },
                ].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{item.action}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{item.scope}</p>
                    </div>
                    <span class={`font-mono text-[10px] font-semibold shrink-0 ${item.status === 'Pubblicato' ? 'text-[#059669]' : item.status === 'Programmato' ? 'text-[#4f39f6]' : 'text-[#79716b]'}`}>{item.status}</span>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Crea una volta — pubblica su tutte le sedi</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestione GBP centralizzata</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Tutti i profili Google Business da un'unica interfaccia.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Invece di accedere separatamente a ogni account GBP, gestisci tutti i profili — post, foto, orari, offerte — direttamente in Stacc. Le modifiche che si applicano a tutte le sedi si applicano con un'unica azione.
              </p>
              <ul class="mt-6 space-y-3">
                {['Post GBP pubblicati su tutte o su sedi selezionate contemporaneamente', 'Aggiornamenti orari applicati a tutte le sedi in un\'unica operazione', 'Tutte le visualizzazioni e azioni GBP in un unico report', 'Alert automatico per problemi al profilo GBP su qualsiasi sede'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Una settimana con Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Come gestisci 10 sedi<br />in una settimana con Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: 'Lunedì ore 8:00', title: 'Panoramica portfolio in 2 minuti.', body: 'Apri Stacc e vedi subito: ranking di tutte le sedi, nuove recensioni del weekend, attività GBP della settimana. Quello che prima richiedeva 2 ore di controlli manuali ora richiede 2 minuti.', type: 'automated' },
            { time: 'Mercoledì ore 9:00', title: 'La sede di Napoli ha un problema con le recensioni.', body: 'Stacc ha segnalato una recensione da 2 stelle martedì. Hai ricevuto l\'alert immediatamente, letto il contesto e lasciato una risposta ponderata entro mercoledì mattina. Un altro operatore locale l\'avrebbe scoperta una settimana dopo.', type: 'alert' },
            { time: 'Giovedì ore 14:00', title: 'Nuova sede configurata in 30 minuti.', body: 'Nuova apertura? Keyword aggiunte, GBP collegato, baseline citazioni registrata, piano di reportistica configurato. La nuova sede è completamente attiva in Stacc prima della pausa caffè.', type: 'onboarding' },
            { time: 'Venerdì ore 17:00', title: 'Tutte le sedi monitorate. Nessuno sforzo manuale.', body: 'Per tutta la settimana i ranking sono stati tracciati, le recensioni monitorate, le citazioni verificate e l\'attività GBP pianificata — in automatico. Ti sei concentrato sulle ottimizzazioni, non sulla sorveglianza.', type: 'outcome' },
          ].map(w => (
            <div class="flex gap-5 rounded-2xl border border-[#e7e5e4] bg-white p-6">
              <div class="shrink-0">
