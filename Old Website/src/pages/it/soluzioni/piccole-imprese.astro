---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Ho bisogno di conoscenze SEO per usare Stacc?",
    a: "No. Stacc è progettato per imprenditori locali senza competenze tecniche. La piattaforma spiega cosa significano i dati e fornisce raccomandazioni chiare su cosa fare — in un linguaggio comprensibile.",
  },
  {
    q: "Quanto tempo devo dedicare ogni settimana al SEO locale?",
    a: "La maggior parte delle piccole imprese trascorre 20–30 minuti a settimana con Stacc — guardare il riepilogo settimanale, rispondere alle nuove recensioni e magari pubblicare un post GBP. Il monitoraggio e la raccolta dati avvengono in automatico.",
  },
  {
    q: "Cosa è incluso nel piano Starter?",
    a: "Il piano Starter include il rank tracking per un massimo di 5 keyword per sede, il monitoraggio delle recensioni su Google Business Profile, l'audit delle citazioni e il monitoraggio del profilo GBP. Per la maggior parte delle piccole imprese con una singola sede è un sistema SEO locale completo.",
  },
  {
    q: "Stacc funziona per qualsiasi tipo di attività locale?",
    a: "Sì. Stacc funziona per qualsiasi attività che voglia apparire nelle ricerche locali di Google — artigiani, ristoranti, studi medici, centri estetici, negozi al dettaglio, professionisti. Se i tuoi clienti cercano localmente, Stacc ti aiuta a farti trovare.",
  },
  {
    q: "Cosa succede dopo i 14 giorni di prova?",
    a: "Dopo il periodo di prova puoi scegliere il piano più adatto alla tua attività. Se Stacc non fa per te, il periodo di prova si conclude senza costi — nessun rinnovo automatico, nessuna clausola nascosta.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc per Piccole Imprese",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Stacc mette a disposizione delle piccole imprese locali gli strumenti SEO che usano le grandi aziende — senza conoscenze tecniche, senza budget elevato, senza impegno quotidiano.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Soluzioni", "item": "https://thestacc.com/it/soluzioni/" },
        { "@type": "ListItem", "position": 3, "name": "Piccole Imprese", "item": "https://thestacc.com/it/soluzioni/piccole-imprese/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO Locale per Piccole Imprese — Farsi Trovare su Google senza Essere un Esperto SEO | theStacc"
  description="Stacc mette a disposizione delle piccole imprese locali gli strumenti SEO che usano le grandi aziende — senza conoscenze tecniche, senza budget elevato, senza impegno quotidiano."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Per Piccole e Medie Imprese</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            I clienti locali cercano ogni giorno<br />i tuoi servizi.<br /><span style="color:#4f39f6;">E trovano i tuoi concorrenti.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc mette a disposizione delle piccole imprese locali gli strumenti SEO che prima erano riservati alle grandi aziende con team di marketing. Monitora il tuo posizionamento su Google Maps, gestisci le recensioni e mantieni aggiornato il profilo GBP — senza essere un esperto SEO.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Prova gratis 14 giorni
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi i prezzi
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Da €49/mese · 14 giorni gratis · Nessuna carta di credito · GDPR-compliant
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'Ogni giorno', label: 'Aggiornamenti ranking per la tua sede' },
              { value: '30 min',     label: 'Impegno settimanale per il SEO locale' },
              { value: 'Top 3',      label: 'Obiettivo Google Maps per la visibilità locale' },
              { value: '4.9★',      label: 'Valutazione clienti' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Per i piccoli imprenditori locali</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Quello che vivono ogni giorno<br />i piccoli imprenditori locali.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'I clienti locali cercano i tuoi servizi — e trovano i tuoi concorrenti.',
              body: 'Ogni giorno persone nella tua città cercano quello che offri. Se non appari nei primi tre risultati di Google Maps, scelgono chi c\'è — senza mai sapere che la tua attività esiste.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Senza dati non sai cosa funziona e cosa no.',
              body: 'Hai creato il profilo GBP, ma non sai quante persone lo vedono. Hai aggiornato gli orari, ma non sai se il tuo ranking ne ha beneficiato. Senza dati ottimizzi al buio.',
            },
            {
              icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
              title: 'Recensioni negative scoperte tardi danneggiano durevolmente la reputazione.',
              body: 'Un cliente lascia una recensione da 2 stelle. La scopri una settimana dopo — quando 50 potenziali clienti l\'hanno già letta senza che nessuno abbia risposto. Per una piccola impresa, una recensione negativa senza risposta può costare settimane di nuovi clienti.',
            },
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Gli strumenti SEO sono troppo complessi o troppo costosi per le piccole imprese.',
              body: 'La maggior parte delle piattaforme SEO è stata costruita per agenzie o grandi aziende. Sono piene di funzionalità che non userai mai e costano centinaia di euro al mese. Quello di cui hai bisogno: strumenti semplici e chiari per la visibilità locale — a un prezzo che abbia senso per una piccola impresa.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── WHAT CHANGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa cambia con Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            SEO locale costruito per<br />le piccole imprese.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Senza Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Con Stacc</div>
          </div>
          {[
            { label: 'Ranking su Google Maps',       before: 'Sconosciuto — ricerca manuale necessaria',      after: 'Tracciato e comunicato ogni giorno' },
            { label: 'Nuove recensioni',             before: 'Scoperte per caso',                             after: 'Alert immediato per ogni nuova recensione' },
            { label: 'Stato profilo GBP',            before: 'Controllato raramente',                         after: 'Monitorato e ottimizzato continuamente' },
            { label: 'Coerenza citazioni',           before: 'Mai verificata sistematicamente',               after: 'Monitorata automaticamente in 50+ directory' },
            { label: 'Tempo dedicato al SEO',        before: '2–4 ore/settimana di controlli manuali',       after: '30 minuti/settimana nel dashboard' },
            { label: 'Conoscenze SEO richieste',     before: 'Competenze tecniche necessarie',               after: 'Nessuna conoscenza preliminare richiesta' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE HIGHLIGHTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Sviluppato per le piccole imprese</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutto quello che ti serve per la visibilità locale.<br />Niente di più.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Easy to understand -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Semplice da capire</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Stacc ti dice cosa è importante — e cosa fare.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Non devi essere un esperto SEO. Stacc traduce i dati tecnici sui ranking in informazioni comprensibili: il tuo ranking è sceso di 3 posizioni questa settimana perché il tuo profilo GBP ha avuto poca attività di recente. Ecco due passi che possono aiutare.
              </p>
              <ul class="mt-6 space-y-3">
                {['Spiegazioni chiare invece di termini tecnici', 'Raccomandazioni prioritizzate su cosa fare subito', 'Report di riepilogo settimanale per la tua sede', 'Nessuna interpretazione dei dati richiesta — ci pensa Stacc'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Il tuo riepilogo settimanale</p>
                <span class="rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">Questa settimana</span>
              </div>
              <div class="space-y-3">
                {[
                  { label: 'Idraulico Milano', rank: '#2 su Google Maps', change: '+3', good: true },
                  { label: 'Pronto intervento idraulico', rank: '#4 su Google Maps', change: '0', good: true },
                  { label: 'Sblocco scarichi Milano', rank: '#6 su Google Maps', change: '-1', good: false },
                ].map(kw => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{kw.label}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{kw.rank}</p>
                    </div>
                    <span class={`font-mono text-[11px] font-semibold shrink-0 ${kw.good ? 'text-[#059669]' : 'text-[#ef4444]'}`}>{kw.change !== '0' ? kw.change : '—'}</span>
                  </div>
                ))}
                <div class="mt-3 rounded-xl bg-[#fef3c7] border border-[#fde68a] px-4 py-3">
                  <p class="font-sans text-[12px] font-semibold text-[#92400e]">Raccomandazione per questa settimana</p>
                  <p class="font-sans text-[11px] text-[#78350f] mt-1">Aggiungi un post GBP per aumentare l'attività. Il tuo profilo non ha aggiornamenti da 10 giorni.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- All-in-one -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Il tuo dashboard SEO locale</p>
              <div class="space-y-3">
                {[
                  { module: 'Rank Tracking', detail: '3 keyword monitorate · Aggiornato ogni giorno', status: 'Attivo' },
                  { module: 'Monitoraggio recensioni', detail: '4.7★ media · 2 nuove questa settimana', status: 'Attivo' },
                  { module: 'Gestione GBP', detail: 'Profilo completo · Ultimo post: 3 giorni fa', status: 'Ottimo' },
                  { module: 'Monitoraggio citazioni', detail: '47/50 directory corrette', status: 'Controlla' },
                ].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{item.module}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{item.detail}</p>
                    </div>
                    <span class={`font-mono text-[10px] font-semibold shrink-0 ${item.status === 'Attivo' || item.status === 'Ottimo' ? 'text-[#059669]' : 'text-[#d97706]'}`}>{item.status}</span>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tutto in un unico strumento · Nessun accesso doppio</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tutto quello che serve a un'attività locale</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Ranking, recensioni, GBP e citazioni — in un unico strumento.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Invece di gestire più strumenti con più accessi, hai tutto in un'unica piattaforma: il rank tracking ti dice dove sei posizionato. Il monitoraggio recensioni ti assicura di poter rispondere subito. La gestione GBP mantiene aggiornato il tuo profilo. Il monitoraggio citazioni garantisce che i tuoi dati siano corretti ovunque.
              </p>
              <ul class="mt-6 space-y-3">
                {['Rank tracking quotidiano per le tue keyword locali', 'Alert immediati per le recensioni su tutte le piattaforme', 'Monitoraggio profilo GBP e raccomandazioni di ottimizzazione', 'Audit citazioni e monitoraggio continuo della coerenza'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Una settimana con Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Come si presenta la settimana<br />di una piccola impresa con Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: 'Lunedì mattina, 10 minuti', title: 'Riepilogo settimanale letto.', body: 'Ranking questa settimana: +2 posizioni per "idraulico [città]", stabili per le altre keyword. Due nuove recensioni dal weekend — entrambe 5 stelle, entrambe ancora senza risposta. Te ne occupi nei prossimi 10 minuti.', type: 'automated' },
            { time: 'Martedì, alert immediato', title: 'Nuova recensione da 3 stelle — risposta in un\'ora.', body: 'Stacc invia un alert. Leggi la recensione, capisci il problema e rispondi professionalmente entro un\'ora. Non la settimana prossima — entro un\'ora.', type: 'alert' },
            { time: 'Mercoledì, 15 minuti', title: 'Raccomandazione GBP messa in pratica.', body: 'Stacc suggerisce di aggiungere una foto recente della tua attività. La carichi, aggiungi un post GBP aggiornato — 15 minuti di lavoro che aiutano la tua visibilità locale.', type: 'onboarding' },
            { time: 'Venerdì', title: 'SEO locale attivo. Senza conoscenze tecniche.', body: 'Questa settimana hai dedicato meno di 30 minuti al SEO locale. Ranking monitorati. Recensioni con risposta. GBP aggiornato. Citazioni sotto controllo. Tutto quello che serve a una piccola impresa.', type: 'outcome' },
