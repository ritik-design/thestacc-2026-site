---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const standards = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: 'Come creiamo i contenuti',
    body: 'Ogni articolo su theStacc è pianificato sulla base di ricerche di parole chiave e analisi dell\'intento di ricerca. Identifichiamo gli argomenti su cui le aziende necessitano di una guida chiara e pratica, quindi creiamo contenuti esaustivi che rispondono all\'intera portata della query.',
    detail: 'I nostri contenuti utilizzano flussi di lavoro assistiti dall\'IA per la ricerca e la stesura iniziale. Ogni articolo viene poi revisionato, modificato e verificato dal nostro team editoriale prima della pubblicazione. Usiamo l\'IA come strumento per aumentare la produzione, non come sostituto del giudizio editoriale.',
    note: `Tutti i contenuti sono attribuiti a <a href="/it/autore/siddharth-gangal/" class="text-[#4f39f6] hover:underline">Siddharth Gangal</a>, fondatore di theStacc, che supervisiona la direzione editoriale e la revisione finale.`,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
    title: 'Processo di verifica dei fatti',
    body: 'Statistiche, dati sui prezzi, affermazioni sulle funzionalità e informazioni sui prodotti citati nei nostri contenuti vengono verificati rispetto alle fonti primarie prima della pubblicazione. Colleghiamo direttamente alla fonte ove possibile.',
    checks: [
      'Dati sui prezzi verificati nelle pagine ufficiali dei prezzi di ciascun prodotto',
      'Statistiche provenienti da studi nominati, report di settore o dati ufficiali aziendali',
      'Confronti sulle funzionalità basati sulla documentazione pubblica e su test pratici',
      'Date di pubblicazione e aggiornamento visualizzate su ogni articolo',
    ],
    note: `Se trovi un errore in uno qualsiasi dei nostri contenuti, <a href="/it/contatti/" class="text-[#4f39f6] hover:underline">contattaci</a> e lo correggeremo tempestivamente.`,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: 'Informativa su recensioni e confronti',
    body: 'theStacc è un prodotto commerciale che compete con diversi strumenti che recensiamo e compariamo. Lo riveliamo chiaramente su ogni pagina di recensione e alternative.',
    quote: 'Questa recensione è stata scritta e pubblicata da Stacc, un prodotto concorrente. Abbiamo un interesse commerciale come alternativa. Tutti i dati sui prezzi e le funzionalità sono verificati rispetto a fonti pubbliche.',
    detail: 'Non accettiamo pagamenti da nessuna azienda in cambio di recensioni favorevoli. Le nostre valutazioni riflettono una valutazione editoriale genuina. Testiamo i prodotti direttamente ove possibile e incrociamo con le recensioni degli utenti disponibili pubblicamente su piattaforme come G2, Capterra e TrustRadius.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: 'Aggiornamento dei contenuti',
    body: 'La SEO e le tecnologie di marketing si evolvono rapidamente. Manteniamo i nostri contenuti attraverso un processo di aggiornamento sistematico.',
    checks: [
      'Date di pubblicazione e ultimo aggiornamento visualizzate su tutti gli articoli',
      'Revisione trimestrale dei dati su prezzi e funzionalità nelle recensioni software',
      'Contenuti statistici aggiornati quando diventano disponibili nuovi dati',
      'Contenuti obsoleti rimossi o reindirizzati quando non più accurati o pertinenti',
    ],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    title: 'Standard del glossario',
    body: `Il nostro <a href="/it/glossario/" class="text-[#4f39f6] hover:underline">glossario di oltre 690 termini</a> segue un formato coerente: una definizione concisa, una spiegazione contestuale, la rilevanza pratica e i termini correlati. Le definizioni sono scritte per essere accurate, accessibili e utili sia per i principianti che per i marketer esperti.`,
  },
];
---

<BaseLayout
  title="Standard Editoriali | theStacc"
  description="Come theStacc crea, verifica e pubblica i contenuti. Il nostro processo editoriale, la metodologia di fact-checking, la politica di divulgazione delle recensioni e gli standard di qualità."
  lang="it"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- DARK HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="max-w-6xl mx-auto px-6 relative z-10 py-16 text-center">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Standard Editoriali</p>
        <h1 class="mx-auto mt-4 max-w-[600px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[44px]">
          Come creiamo e garantiamo i nostri contenuti.
        </h1>
        <p class="mx-auto mt-4 max-w-[500px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          theStacc pubblica guide SEO, recensioni software, confronti tra strumenti e contenuti di settore. Ecco come creiamo, verifichiamo e manteniamo quei contenuti.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {[
            'Nessun posizionamento a pagamento',
            'Prezzi verificati trimestralmente',
            'Informativa su ogni recensione',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- STANDARDS SECTIONS -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="mx-auto max-w-[760px] space-y-5">

          {standards.map(s => (
            <div class="overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
              <div class="flex items-center gap-3 border-b border-[#f5f5f4] px-6 py-4">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#f5f3ff]" set:html={s.icon}></div>
                <h2 class="font-sans text-[16px] font-bold text-[#292524]">{s.title}</h2>
              </div>
              <div class="px-6 py-5 space-y-4">
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]" set:html={s.body}></p>
                {s.detail && <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{s.detail}</p>}
                {s.quote && (
                  <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-5 py-4" style="border-left: 3px solid #4f39f6;">
                    <p class="font-sans text-[13px] leading-[1.7] text-[#57534e] italic">"{s.quote}"</p>
                  </div>
                )}
                {s.checks && (
                  <ul class="space-y-2">
                    {s.checks.map(c => (
                      <li class="flex items-start gap-2.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">
                        <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        {c}
                      </li>
                    ))}
                  </ul>
                )}
                {s.note && <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]" set:html={s.note}></p>}
              </div>
            </div>
          ))}

          <div class="rounded-2xl border border-[#4f39f6] p-6 text-center" style="background:linear-gradient(135deg,#f5f3ff 0%,#fafaf9 100%);">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Domande o correzioni</p>
            <p class="mt-2 font-sans text-[15px] font-semibold text-[#292524]">Trovato un errore? Vogliamo saperlo.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.7] text-[#57534e]">
              Se noti un prezzo non aggiornato, un'affermazione errata su una funzionalità o qualcosa che non torna, scrivici a <a href="/it/contatti/" class="text-[#4f39f6] hover:underline">thestacc.com/it/contatti</a>. Correggiamo i problemi entro 48 ore.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- DARK CTA -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="max-w-6xl mx-auto px-6 relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Contenuti pensati per guadagnare fiducia.
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Gli stessi standard a cui ci atteniamo sono integrati in ogni articolo che theStacc pubblica per la tua attività.
        </p>
        <a href="/it/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Inizia la prova a $1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">$1 per 30 giorni · Cancella quando vuoi</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
