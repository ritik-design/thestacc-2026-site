---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cosa deve fare un software SEO per franchising?", a: "Un software SEO per franchising deve automatizzare le attività SEO locali ripetitive che devono avvenire in modo costante per ogni sede: pubblicazione post GBP, monitoraggio citazioni, rank tracking, avvisi recensioni e reportistica. Se si limita a monitorare queste attività richiedendo poi esecuzione manuale, non risolve il problema di scalabilità." },
  { q: "Qual è la differenza tra software SEO tradizionale e software per franchising?", a: "Gli strumenti SEO tradizionali sono costruiti per singole sedi o piccoli gruppi. Il software SEO per franchising è costruito per portfolio — modifica in blocco, reportistica di rete, accesso a più livelli per franchisee e franchisor, e automazione che esegue le stesse attività per ogni sede senza ripetizione manuale per sede." },
  { q: "Stacc può gestire sedi di proprietà aziendale e franchisee contemporaneamente?", a: "Sì. Puoi segmentare le sedi per tipo di proprietà o regione e applicare impostazioni, calendario report o livelli di accesso diversi a ciascun gruppo. Le sedi aziendali e quelle franchisee convivono nella stessa dashboard con livelli di permesso configurabili." },
  { q: "Stacc supporta la reportistica white-label per le reti franchising?", a: "Sì. I report white-label possono portare il brand del franchisor o del franchisee in base alla struttura di reporting. I report vengono generati e consegnati automaticamente secondo il calendario configurato." },
  { q: "Come gestisce Stacc la coerenza NAP su più sedi franchising?", a: "Stacc monitora i dati delle citazioni su 50+ directory per ogni sede e segnala inconsistenze in tempo reale. Le correzioni possono essere applicate in blocco a tutte le sedi interessate. La coerenza NAP è uno dei fattori di ranking locali ad impatto più alto per i business in franchising." },
  { q: "C'è una quota di configurazione per account franchising?", a: "No. Nessuna quota di configurazione. I piani partono da $49/mese per il modulo SEO locale, che include tutte le funzionalità per franchising e multi-sede." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software SEO Franchising",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Software SEO per franchising che automatizza la gestione locale dell'intera rete. GBP, citazioni, ranking e report per ogni sede, simultaneamente.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software SEO Franchising", "item": "https://thestacc.com/it/software-seo-franchising/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Software SEO Franchising — Automatizza il SEO Locale su Tutta la Rete | theStacc"
  description="Software SEO per franchising a scala. theStacc automatizza gestione GBP, monitoraggio citazioni, rank tracking e reportistica per ogni sede della rete — zero lavoro manuale per sede."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software SEO Franchising · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Software SEO per franchising che<br />
            <span style="color:#4f39f6;">gestisce tutta la rete.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Progettato per la scala franchising: gestione GBP in blocco, monitoraggio citazioni su tutta la rete, dashboard ranking portfolio e report automatici per ogni sede simultaneamente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Funzionalità franchising
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- NARRATIVA -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa deve fare il software SEO per franchising</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La maggior parte degli strumenti monitora a scala.<br />Stacc esegue a scala.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>La maggior parte degli strumenti SEO locali è costruita per una sede o per un piccolo gruppo. Ti mostrano le dashboard. Ti dicono cosa deve essere fatto. Poi qualcuno del tuo team deve aprire ogni sede e farlo. Funziona per cinque sedi. Non funziona per cinquanta.</p>
            <p>Il software SEO per franchising ha un compito diverso: automatizzare l'esecuzione a scala. Non solo monitorare ciò che accade — farlo davvero. Pubblicare i post GBP. Monitorare le citazioni. Inviare i report. Per ogni sede, ogni giorno, senza che qualcuno lo pianifichi manualmente per sede.</p>
            <p class="font-semibold text-[#111827]">Questo è Stacc. Costruito dall'inizio per l'esecuzione multi-sede — non adattato alla scala in un secondo momento.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Funzionalità della piattaforma</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutto ciò di cui le reti franchising hanno bisogno<br />in una sola piattaforma.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Gestione GBP su tutta la rete', body: 'Pubblica post, aggiorna orari e gestisci attributi per ogni sede franchising in blocco. Un\'azione. Ogni sede. Propagazione istantanea.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoraggio coerenza citazioni', body: 'Monitora la correttezza NAP su 50+ directory per ogni sede. Correggi inconsistenze in blocco prima che influenzino i ranking.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Dashboard ranking per sede', body: 'Aggiornamenti ranking giornalieri per ogni sede in local pack, Maps e organico. Vista portfolio con tutte le sedi fianco a fianco e trend di performance.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestione recensioni per sede', body: 'Inbox recensioni centralizzato per tutte le sedi. Avvisi in tempo reale, gestione risposte e tracking punteggio per sede.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Accesso franchisor e franchisee', body: 'Accesso a più livelli: i franchisor vedono l\'intera rete, i franchisee vedono i propri dati. Gestione centralizzata con visibilità individuale.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Report automatici per la rete', body: 'Report di sintesi rete, report per sede e report per gruppi personalizzati — generati e consegnati automaticamente secondo il calendario.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- METRICHE DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '500+', label: 'Sedi franchising gestite', sub: 'Unica piattaforma, zero personale per sede' },
            { value: '95%', label: 'Meno tempo per aggiornamenti di rete', sub: 'Modifica in blocco vs sede per sede' },
            { value: '3×', label: 'Più sedi per dipendente', sub: 'L\'automazione si moltiplica a scala' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── PANORAMICA PIATTAFORMA ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa fa Stacc per il franchising</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una piattaforma. Tutta la rete franchising.<br />Tutto automatizzato.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Pubblicazione GBP per ogni sede — 30/mese', 'Rank tracking per sede — local pack + Maps', 'Monitoraggio recensioni in rete — avvisi in tempo reale', 'Coerenza citazioni — 50+ directory per sede'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['Articoli SEO scritti ogni mese', 'Pubblicati direttamente sul sito del franchisor', 'Ricerca keyword inclusa', 'Hub di contenuti per la rete'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri per ogni sede', 'Instagram, LinkedIn, Facebook, X', 'Programmati automaticamente', 'Brand di rete coerente'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità per la rete</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Il lavoro SEO ripetitivo,<br />moltiplicato per ogni sede.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP in blocco -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pubblicazione GBP in blocco</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Un post. 200 sedi. Pubblicato simultaneamente con personalizzazione locale.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Scrivi un post una volta sola. Selezioni le sedi target — possono essere 5, 50 o 500. Stacc lo pubblica su tutti i Google Business Profile contemporaneamente, con la possibilità di iniettare automaticamente i dettagli locali per ogni sede: indirizzo, numero di telefono, nome del responsabile, hashtag della città. Il brand della rete rimane coerente. I dettagli si adattano alla sede. La frequenza di pubblicazione richiesta dall'algoritmo di Google viene mantenuta su tutta la rete senza che nessuno apra mai un singolo profilo manualmente.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Pubblicazione di rete · Oggi</p>
              <div class="grid grid-cols-10 gap-1 mb-4">
                {Array.from({length: 50}).map((_, i) => (
                  <div class={`h-4 w-full rounded ${i < 47 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Sedi pubblicate con successo</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">47 / 50</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:94%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">3 sedi in retry · Avvisi inviati al franchisor</p>
            </div>
          </div>

          <!-- Dashboard portfolio -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Performance di rete · Top 4</p>
              {[
                { sede: 'Milano Centro', pack: 1, change: '+3', trend: 'up' },
                { sede: 'Roma Trastevere', pack: 2, change: '+1', trend: 'up' },
                { sede: 'Torino Lingotto', pack: 3, change: '+2', trend: 'up' },
                { sede: 'Napoli Vomero', pack: 6, change: '-1', trend: 'down' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.sede}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#b91c1c]'}`}>{r.trend === 'up' ? '↑' : '↓'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Confronto sede per sede · Aggiornato giornalmente</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dashboard ranking portfolio</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Vedi tutta la rete fianco a fianco — e individua subito le sedi che perdono terreno.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                In un sistema franchising, una sede in calo per due settimane perde mesi di slancio nei ranking locali. La dashboard portfolio di Stacc mostra tutte le sedi nello stesso schermo — ranking medi, trend, sedi top performer e quelle che richiedono attenzione. Non devi più chiedere "come sta andando il franchisee di Bologna?" durante la riunione operativa: lo vedi prima che la riunione cominci. Le sedi sotto soglia attivano avvisi automatici al franchisor e al franchisee responsabile.
              </p>
