---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il software di automazione SEO?", a: "Il software di automazione SEO gestisce le attività SEO ripetitive e ad alto volume — pubblicazione post GBP, monitoraggio citazioni, monitoraggio recensioni, rank tracking e reportistica — senza richiedere intervento manuale ogni volta. Invece di eseguire ogni operazione manualmente, configuri le regole una volta e il software le esegue in modo continuativo." },
  { q: "Cosa automatizza esattamente Stacc?", a: "Stacc automatizza: pubblicazione post GBP (30/mese per sede), rank tracking giornaliero su local pack e organico, monitoraggio recensioni in tempo reale con avvisi, monitoraggio citazioni su 50+ directory, consegna automatica report clienti in white-label e sincronizzazione keyword e citazioni. Queste sono le cinque attività manuali ad alto volume nel SEO locale — Stacc le gestisce tutte automaticamente." },
  { q: "Quante ore di lavoro risparmia l'automazione SEO?", a: "Le aziende e le agenzie che usano Stacc riferiscono di risparmiare in media 8 ore per cliente ogni mese rispetto alla gestione manuale. Per un'agenzia con 20 clienti, sono 160 ore al mese — circa un dipendente a tempo pieno — recuperate senza ridurre la qualità del servizio." },
  { q: "L'automazione SEO migliora davvero il posizionamento?", a: "Sì, quando eseguita in modo costante. L'algoritmo di Maps di Google premia i profili GBP attivi e i dati di citazione accurati. Il problema con il SEO locale manuale è l'inconsistenza — passano settimane senza post GBP, le citazioni si deteriorano. L'automazione garantisce che i segnali che Google cerca vengano inviati in modo costante ogni giorno per ogni sede." },
  { q: "Stacc può automatizzare il SEO per più sedi contemporaneamente?", a: "Sì. Stacc è progettato per la gestione multi-sede. Puoi pubblicare post GBP in tutte le sedi simultaneamente, tracciare le posizioni per ogni sede in modo indipendente, monitorare le recensioni su tutti i GBP in un unico feed e generare report separati o aggregati per sede." },
  { q: "L'automazione sostituisce la strategia SEO?", a: "No — l'automazione gestisce l'esecuzione, non la strategia. Tu decidi quali keyword targetizzare, quali servizi promuovere e come posizionare ogni sede. Stacc esegue poi quella strategia in modo costante — pubblicando il contenuto giusto, monitorando i keyword giusti, tracciando i segnali giusti — così la strategia viene effettivamente implementata ogni giorno." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software Automazione SEO",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Software di automazione SEO locale che gestisce rank tracking, sincronizzazione citazioni, monitoraggio recensioni e pubblicazione GBP automaticamente.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software Automazione SEO", "item": "https://thestacc.com/it/software-automazione-seo/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Software Automazione SEO — La Maggior Parte degli Strumenti SEO ti Dice Cosa Fare. Stacc lo Fa | theStacc"
  description="Software automazione SEO locale. theStacc gestisce GBP, rank tracking, citazioni, recensioni e report automaticamente — 8 ore risparmiate per cliente ogni mese."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software Automazione SEO · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            La maggior parte degli strumenti SEO<br />
            <span style="color:#4f39f6;">ti dice cosa fare. Stacc lo fa.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            GBP automation, rank tracking, monitoraggio citazioni, avvisi recensioni e consegna report — tutto automatizzato. Tu imposti la strategia. Stacc esegue ogni giorno senza che nessuno debba farlo manualmente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Scopri l'automazione
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- NARRATIVA -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema degli strumenti SEO tradizionali</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sapere cosa fare non<br />è la stessa cosa di farlo.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              La maggior parte degli strumenti SEO è costruita per l'analisi, non per l'esecuzione. Ti mostrano dove sei posizionato. Ti mostrano quali citazioni sono errate. Ti mostrano quante recensioni hai ricevuto. Poi ti lasciano fare il lavoro manualmente — aggiornare il GBP, correggere le citazioni, rispondere alle recensioni, preparare il report. Gli strumenti diagnosticano. Tu esegui.
            </p>
            <p>
              Questo funziona con 2-3 clienti o sedi. Non funziona con 10, 20 o 50. A quella scala, il collo di bottiglia non è la conoscenza — è la capacità di esecuzione. Hai già saputo cosa fare. Non hai avuto il tempo di farlo in modo costante per ogni sede ogni giorno.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc è costruito diversamente. Non ti mostra solo cosa fare — lo esegue. Pubblica i post GBP. Monitora le citazioni. Invia avvisi per le recensioni. Genera e consegna i report. L'automazione fa il lavoro operativo in modo che il tuo team possa concentrarsi sulla strategia.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa automatizza Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tre moduli. Ogni leva SEO.<br />Tutta l'esecuzione in pilota automatico.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['30 post GBP/mese pubblicati automaticamente', 'Rank tracking giornaliero su 3 superfici', 'Monitoraggio recensioni e citazioni', 'Reportistica white-label automatica'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Keyword research automatica', 'Pubblicati direttamente sul sito', 'Link interni ottimizzati'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri scritti automaticamente', 'Programmati su 4 piattaforme social', 'Immagini generate sul brand', 'Calendario editoriale automatico'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Esecuzione automatica.<br />Coerenza ogni giorno. Zero lavoro manuale.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Pubblicazione automatica -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pubblicazione GBP Automatica</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 post GBP scritti, ottimizzati e pubblicati automaticamente — per ogni sede, ogni mese.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                L'algoritmo di Maps premia i profili attivi. Il problema è la coerenza: pochi team riescono a pubblicare un post GBP al giorno per ogni sede senza che qualcosa salti. Stacc gestisce l'intero ciclo — generazione contenuto basata su servizio + città, programmazione, pubblicazione e monitoraggio dell'engagement — senza che nessuno acceda manualmente al profilo. Tu ricevi il report mensile, Google riceve i segnali ogni giorno.
              </p>
              <a href="/it/software-google-business-profile/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il software GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario pubblicazioni — questo mese</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 22 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Post pubblicati finora</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">22 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:73%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Altri 8 programmati · Tutto in pilota automatico</p>
            </div>
          </div>

          <!-- Sincronizzazione -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Sincronizzazione moduli — oggi</p>
              {[
                { module: 'GBP → Recensioni', last: '2 min fa', status: 'OK' },
                { module: 'Citazioni → NAP', last: '14 min fa', status: 'OK' },
                { module: 'Keyword → Rank tracker', last: '37 min fa', status: 'OK' },
                { module: 'Report → Email cliente', last: '1 ora fa', status: 'OK' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] font-medium text-[#374151] truncate">{r.module}</span>
                  <span class="font-mono text-[11px] text-[#79716b]">{r.last}</span>
                  <span class="font-mono text-[10px] font-semibold text-[#059669]">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Sincronizzazione continua · 1 sistema, 1 fonte di verità</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Sincronizzazione Tra Moduli</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Aggiorni una volta. Il dato si propaga ovunque. Niente più copia-incolla tra strumenti.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc è un sistema unico, non quattro strumenti incollati insieme. Quando aggiungi una keyword, viene tracciata automaticamente sul rank tracker. Quando aggiorni l'orario su GBP, le citazioni si sincronizzano. Quando arriva una recensione, il dato compare nel report. Una sola fonte di verità — e tutta l'esecuzione che ne deriva si propaga automaticamente in tutto il sistema.
              </p>
              <a href="/it/software-seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il software SEO locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reportistica auto -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reportistica Auto-Consegnata</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Report mensili che si scrivono e si inviano da soli. Il tuo team smette di costruirli a mano.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Imposta una volta il template per ogni cliente o sede. Stacc estrae i dati da GBP, rank tracker, citazioni e recensioni, li formatta nel report brandizzato, lo allega all'email programmata e lo consegna. Il primo del mese parte per tutti i clienti contemporaneamente, senza che nessuno apra Excel. Questa è la cosa che permette a un'agenzia di passare da 10 a 50 clienti senza assumere.
              </p>
              <a href="/it/reportistica-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri la reportistica white-label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">La Tua Agenzia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Report SEO Mensile · Marzo</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Inviato</span>
              </div>
              {[
                { label: 'Post GBP pubblicati', val: '30 / 30 nel mese' },
                { label: 'Keyword in top 3', val: '+8 nuove' },
                { label: 'Recensioni ricevute', val: '12 (media 4.7)' },
                { label: 'Citazioni corrette', val: '6 inconsistenze' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generato e consegnato automaticamente</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa automatizza Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Le cinque attività SEO locali<br />più ad alto volume. Tutte automatizzate.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
