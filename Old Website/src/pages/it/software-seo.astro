---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "Cos'è un software SEO?",
    a: "Un software SEO aiuta le attività a gestire i segnali che determinano come si posizionano sui motori di ricerca — inclusi ranking delle keyword, ottimizzazione on-page, citazioni, attività su Google Business Profile e generazione di recensioni. Il software SEO moderno va oltre i dashboard per automatizzare il lavoro di esecuzione effettivo: pubblicare contenuti, aggiornare schede, monitorare recensioni e consegnare report automaticamente.",
  },
  {
    q: "In cosa differisce theStacc dagli altri software SEO?",
    a: "La maggior parte degli strumenti SEO sono strumenti di dati. Tracciano cosa sta succedendo ma lasciano tutto il fare a te. Stacc fa davvero il lavoro — pubblica post GBP, sincronizza le citazioni, monitora le recensioni in tempo reale e consegna report white-label secondo programma. È una piattaforma di esecuzione, non solo un dashboard di reportistica.",
  },
  {
    q: "Ho bisogno di più strumenti SEO se uso Stacc?",
    a: "Per il SEO locale, no. Stacc sostituisce rank tracker standalone, strumenti di gestione GBP, servizi di citazioni, strumenti di monitoraggio recensioni e software di reportistica. Gestisci tutto da una piattaforma. Le agenzie eliminano tipicamente 4–5 abbonamenti separati quando passano a Stacc.",
  },
  {
    q: "Stacc funziona per attività con più sedi?",
    a: "Sì — la gestione multi-sede è una capacità fondamentale. Gestisci ogni sede da una dashboard, pubblica post GBP su tutte le sedi simultaneamente e genera report di performance individuali o aggregati per sede. Non c'è un limite pratico al numero di sedi che puoi aggiungere.",
  },
  {
    q: "Stacc è pensato per agenzie o team interni?",
    a: "Entrambi. Le agenzie ottengono reportistica white-label, gestione account multi-cliente e portali clienti brandizzati. I team interni di attività multi-sede ottengono strumenti di gestione in blocco e reportistica automatica per gli stakeholder interni. La stessa piattaforma serve entrambi i flussi di lavoro senza compromessi.",
  },
  {
    q: "Come si presenta il setup?",
    a: "La maggior parte delle configurazioni si completa in meno di 5 minuti — sedi aggiunte, keyword configurate, GBP connesso e reportistica automatica programmata. Dopo il setup, Stacc gestisce tutto in modo continuativo senza ulteriore tempo dal tuo team. Non è richiesto un lungo onboarding o un'integrazione tecnica.",
  },
  {
    q: "Stacc include la reportistica white-label?",
    a: "Sì. I report white-label — con il tuo logo, colori del brand e dominio personalizzato — sono disponibili sui piani Growth e Scale. I report si generano e si consegnano con il tuo brand. I tuoi clienti non vedono alcun branding Stacc.",
  },
  {
    q: "Quali integrazioni supporta Stacc?",
    a: "Stacc si integra con Google Business Profile, Google Search Console, Google Analytics, Facebook, Instagram, WordPress, Webflow, Ghost e Wix. Tutte le integrazioni sono incluse nel tuo piano — senza tariffe per singola integrazione.",
  },
  {
    q: "Quanto costa Stacc?",
    a: "I piani partono da $49/mese per il modulo SEO Locale, che include pubblicazione di post GBP, rank tracking giornaliero, monitoraggio recensioni e gestione citazioni. Il modulo Blog SEO è $99/mese. Il modulo Social Media è $49/mese. Tutti i moduli includono una prova gratuita di 14 giorni.",
  },
  {
    q: "Posso disdire in qualsiasi momento?",
    a: "Sì. Nessun contratto. Nessuna penale di cancellazione. Esporta l'intera cronologia dei tuoi dati in qualsiasi momento prima di cancellare. I tuoi dati appartengono a te.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software SEO",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Software SEO all-in-one che automatizza ranking locali, citazioni, recensioni, gestione GBP e reportistica per attività e agenzie.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Modulo SEO Locale — parte da $49/mese"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software SEO", "item": "https://thestacc.com/it/software-seo/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Software SEO — Automazione SEO Locale All-in-One a $49/Mese | theStacc"
  description="Smetti di gestire 5 strumenti SEO. theStacc è il software SEO all-in-one che automatizza ranking locali, citazioni, recensioni e reportistica per attività e agenzie."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex flex-wrap items-center justify-center gap-3">
            {['Piattaforma all-in-one', '$49/mese', '400+ agenzie', 'Nessuna carta di credito', 'Prova 14 giorni'].map(chip => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>{chip}
              </span>
            ))}
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Software SEO che<br />fa il lavoro.
            <span style="color:#4f39f6;"> Non solo il tracking.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Hai cercato software SEO perché sei stanco di pagare strumenti che ti danno dati ma ti lasciano tutto il lavoro. Stacc è diverso — automatizza post GBP, rank tracking, gestione citazioni, monitoraggio recensioni e reportistica white-label. Una piattaforma. Tutto automatizzato.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi i prezzi
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito per iniziare · Disdici quando vuoi
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ attività e agenzie</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ sedi gestite</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN NARRATIVE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema con la maggior parte dei software SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Stai pagando cinque strumenti<br />e stai ancora facendo tutto il lavoro.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Di solito va così. Ti iscrivi a un rank tracker. Poi aggiungi uno strumento per le citazioni perché il rank tracker non lo fa. Poi compri uno strumento di gestione GBP perché lo strumento delle citazioni non pubblica. Poi aggiungi una piattaforma per le recensioni. Poi costruisci i tuoi report mensili in un foglio di calcolo perché nessuno di questi strumenti parla con gli altri e nessuno genera il tipo di report che un cliente reale vuole vedere.
            </p>
            <p>
              Ora hai cinque abbonamenti, cinque login, e stai passando più tempo a gestire il tuo toolstack SEO che a gestire davvero il SEO. <strong class="text-[#111827]">Gli strumenti sono diventati il lavoro.</strong> Il lavoro reale — strategia, relazioni con i clienti, crescita — è stato spostato a quello che resta del venerdì.
            </p>
            <p>
              Questo è il problema del software SEO frammentato: ogni strumento si ottimizza per la sua nicchia e nessuno risolve l'intero flusso di lavoro. Colmi le lacune con il tuo tempo. E il tuo tempo è la risorsa più costosa nell'attività.
            </p>
            <p class="font-semibold text-[#111827]">
              Le agenzie che vincono sul SEO locale adesso non stanno lavorando di più. Hanno consolidato tutto in un'unica piattaforma automatizzata e lasciato che il software gestisca l'esecuzione. Questo è Stacc.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa include Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una piattaforma. Ogni leva SEO.<br />Tutto automatizzato.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Pubblicazione post GBP — 30/mese', 'Rank tracking giornaliero — local pack + organico', 'Monitoraggio recensioni — avvisi in tempo reale', 'Gestione citazioni — 50+ directory'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Pubblicati direttamente sul tuo sito', 'Ricerca keyword inclusa', 'Link interni ottimizzati'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri con immagini', 'Instagram, LinkedIn, Facebook, X', 'Scritti e programmati automaticamente', 'Contenuto coerente al brand'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sostituisci cinque strumenti con uno.<br />Dimezza il costo in termini di tempo.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rank Tracking Automatizzato</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Ogni keyword, ogni sede, ogni mattina — senza accedere a nulla.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc traccia i tuoi ranking nel local pack da 3, su Google Maps e nei risultati organici ogni giorno su ogni keyword che ti interessa. Gli avvisi scattano automaticamente quando le posizioni cambiano significativamente. Ti svegli sapendo dove sei — senza aprire un singolo dashboard. Per le agenzie che gestiscono 20 clienti, questa è la differenza tra passare il martedì sui controlli ranking o passarlo sulla strategia.
              </p>
              <a href="/it/software-monitoraggio-posizioni/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il rank tracking nel dettaglio
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Aggiornamento ranking di oggi — tutti i clienti</p>
              {[
                { client: 'Idraulica Rossi', kw: 'idraulico vicino a me', pos: 1, change: '+3', trend: 'up' },
                { client: 'Studio Dentistico Bianchi', kw: 'dentista [città]', pos: 2, change: '+2', trend: 'up' },
                { client: 'HVAC Elite', kw: 'riparazione HVAC vicino a me', pos: 2, change: '+5', trend: 'up' },
                { client: 'Studio Legale Metro', kw: 'avvocato vicino a me', pos: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Aggiornato giornalmente · Local pack + organico + Maps</p>
            </div>
          </div>

          <!-- Citation Management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Stato citazioni — tutte le directory</p>
              {[
                { dir: 'Google Business Profile', status: 'Accurato', ok: true },
                { dir: 'Yelp', status: 'Accurato', ok: true },
                { dir: 'Apple Maps', status: 'Accurato', ok: true },
                { dir: 'Pagine Gialle', status: 'Discrepanza corretta', ok: true },
                { dir: 'Foursquare', status: 'Auto-corretto', ok: true },
              ].map(c => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{c.dir}</span>
                  <span class={`flex items-center gap-1.5 font-mono text-[11px] font-semibold ${c.ok ? 'text-[#059669]' : 'text-[#dc2626]'}`}>
                    {c.ok ? '✓' : '✗'} {c.status}
                  </span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ directory monitorate · Correzioni automatizzate</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestione Citazioni</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Le citazioni incoerenti penalizzano il tuo ranking. Stacc le trova e le corregge automaticamente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google incrocia i dati della tua attività su 50+ directory per verificare che tu sia chi dici di essere. Quando il nome, l'indirizzo o il numero di telefono non corrispondono, i tuoi ranking locali ne soffrono. Stacc monitora ogni directory principale in modo continuativo — e quando trova una discrepanza, la corregge automaticamente. Niente più audit trimestrali delle citazioni. Niente più strumenti di submission manuale.
              </p>
              <a href="/it/software-costruzione-citazioni/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri la gestione citazioni
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reportistica Clienti Automatizzata</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Report che si costruiscono e si inviano da soli. Con il tuo brand. Ogni settimana.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Per la maggior parte delle agenzie, la reportistica clienti è la tassa che non scompare mai — ore ogni mese che non puoi fatturare e non puoi eliminare. Stacc le elimina. Imposta il template una volta per cliente. Stacc genera il report, lo formatta con il tuo branding e lo consegna all'inbox del cliente secondo programma. Il momento in cui la reportistica diventa automatica è il momento in cui puoi scalare oltre il tuo attuale limite di personale.
              </p>
              <a href="/it/reportistica-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri Stacc per agenzie
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
