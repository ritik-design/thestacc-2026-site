---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Perché è necessario un software per gestire Google Business Profile?", a: "La gestione manuale di GBP non è scalabile. Pubblicare post costantemente, rispondere alle recensioni in tempo reale, monitorare le modifiche non autorizzate, aggiornare le informazioni su più sedi e produrre report regolari richiedono ore ogni settimana. Un software automatizza queste attività in modo che i profili restino attivi e ottimizzati senza richiedere lavoro manuale continuo." },
  { q: "Quanti post GBP pubblica Stacc ogni mese?", a: "Stacc pubblica 30 post per sede al mese — circa uno al giorno. I post sono ottimizzati per le combinazioni servizio + città della sede, argomenti stagionali e ricerche ad alto intento. Vengono pubblicati in automatico secondo un calendario senza che nessuno debba accedere manualmente al profilo." },
  { q: "Stacc monitora le modifiche non autorizzate al GBP?", a: "Sì. Stacc monitora continuamente il tuo GBP per rilevare modifiche non autorizzate — chiunque (inclusi utenti Google) può suggerire modifiche a un profilo GBP. Quando viene rilevata una modifica non autorizzata all'indirizzo, al nome, all'orario o alla categoria, ricevi un avviso immediato." },
  { q: "Posso gestire GBP per più sedi contemporaneamente?", a: "Sì. Stacc è progettato per la gestione multi-sede. Puoi pubblicare post in tutte le sedi simultaneamente, aggiornare orari e attributi in blocco e visualizzare le performance di tutte le sedi in una dashboard unificata." },
  { q: "Come viene gestito il monitoraggio delle recensioni?", a: "Stacc monitora il tuo profilo GBP in tempo reale e invia avvisi immediati quando arriva una nuova recensione. Puoi rispondere direttamente dalla dashboard di Stacc senza dover accedere a Google. Per le agenzie, il feed centralizzato mostra le recensioni di tutti i clienti in un unico luogo." },
  { q: "Il software GBP è incluso nel prezzo base?", a: "Sì. Tutta la gestione GBP — 30 post al mese, monitoraggio recensioni, rilevamento modifiche non autorizzate, aggiornamenti in blocco e tracking performance — è inclusa nel modulo SEO locale da $49/mese." },
  { q: "Quanto costa?", a: "Il modulo SEO locale di Stacc, che include la gestione completa di GBP, parte da $49/mese. Include automazione GBP per ogni sede, monitoraggio recensioni, rank tracking e reportistica automatica." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software Google Business Profile",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Software per la gestione automatizzata di Google Business Profile. 30 post al mese, monitoraggio recensioni, rilevamento modifiche non autorizzate e aggiornamenti in blocco.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software Google Business Profile", "item": "https://thestacc.com/it/software-google-business-profile/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Software Google Business Profile — GBP Gestito Automaticamente | theStacc"
  description="Software per la gestione automatizzata di Google Business Profile. theStacc pubblica 30 post al mese, monitora le recensioni e rileva modifiche non autorizzate in automatico."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Google Business Profile · Gestione Automatica</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            GBP gestito automaticamente.<br />
            <span style="color:#4f39f6;">Ogni giorno. Zero intervento manuale.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            30 post al mese pubblicati in automatico, monitoraggio recensioni in tempo reale, rilevamento modifiche non autorizzate, aggiornamenti in blocco su più sedi — tutto senza che nessuno acceda manualmente al profilo.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Scopri le funzionalità GBP
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- NARRATIVA -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perché il GBP ha bisogno di un software</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Google premia i profili attivi.<br />La coerenza non è possibile senza automazione.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              L'algoritmo di Google Maps valuta il grado di attività e coerenza di un profilo GBP. Le aziende che pubblicano regolarmente, rispondono velocemente alle recensioni e mantengono informazioni aggiornate ottengono posizioni migliori. Il problema è che questo richiede lavoro quotidiano — e la maggior parte delle aziende non ha il tempo o le risorse per farlo in modo costante, specialmente su più sedi.
            </p>
            <p>
              Il risultato tipico: un profilo GBP ben ottimizzato al momento del lancio che poi si deteriora nel tempo. Il posting si interrompe. Le recensioni rimangono senza risposta per giorni. Le informazioni di orario non vengono aggiornate per le festività. Ogni omissione è un segnale negativo per Google.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc risolve questo problema automatizzando ogni attività GBP ricorrente. Il profilo rimane attivo ogni singolo giorno — anche quando il tuo team è concentrato su altre priorità. Google vede coerenza; i clienti vedono un'azienda professionale e presente.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa fa Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una piattaforma. Ogni leva GBP.<br />Tutto in pilota automatico.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['30 post GBP/mese pubblicati automaticamente', 'Monitoraggio recensioni in tempo reale', 'Rilevamento modifiche non autorizzate', 'Aggiornamenti in blocco multi-sede'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Pubblicati direttamente sul tuo sito', 'Keyword research inclusa', 'Link interni ottimizzati'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri con immagini', 'Instagram, LinkedIn, Facebook, X', 'Programmati automaticamente', 'Coerenti al brand'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            GBP attivo ogni giorno.<br />Senza accessi manuali.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Pubblicazione post -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pubblicazione Post Automatica</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 post al mese — scritti, ottimizzati e pubblicati automaticamente per ogni sede.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google Maps premia i profili attivi con maggiore visibilità nel local pack. Stacc genera 30 post ottimizzati al mese per ogni sede — combinando servizi, città, intento "vicino a me", argomenti stagionali e ricerche di emergenza — e li pubblica secondo programma. Il profilo riceve il segnale di attività che Google cerca, ogni giorno, senza che nessuno apra il GBP Manager.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario post — questo mese</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 24 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Pubblicati finora</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">24 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:80%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Altri 6 programmati · Tutto in pilota automatico</p>
            </div>
          </div>

          <!-- Recensioni -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Recensioni — feed centralizzato</p>
              {[
                { stars: 5, name: 'Giulia M.', minutes: '8 min fa', preview: 'Servizio impeccabile, super veloci...' },
                { stars: 5, name: 'Luca R.', minutes: '42 min fa', preview: 'Personale gentilissimo e prezzi onesti...' },
                { stars: 4, name: 'Marco T.', minutes: '2 ore fa', preview: 'Tutto bene ma attesa un po\' lunga...' },
                { stars: 5, name: 'Anna B.', minutes: '5 ore fa', preview: 'Tornerò sicuramente, consiglio...' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex gap-0.5 shrink-0">
                    {Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
                  </div>
                  <span class="font-sans text-[12px] font-semibold text-[#374151] shrink-0">{r.name}</span>
                  <span class="font-sans text-[12px] text-[#79716b] truncate">{r.preview}</span>
                  <span class="font-mono text-[10px] text-[#79716b] shrink-0 ml-auto">{r.minutes}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Avvisi in tempo reale · Rispondi dalla dashboard</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Monitoraggio Recensioni</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Avviso al minuto per ogni recensione. Rispondi quando è ancora caldo.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc monitora il tuo profilo GBP in tempo reale e ti notifica al minuto quando arriva una nuova recensione. Rispondi direttamente dalla dashboard di Stacc — non serve aprire Google Business Manager. Per le agenzie, il feed centralizzato mostra le recensioni di tutti i clienti in un unico flusso, con filtri per cliente, sentimento e priorità di risposta.
              </p>
              <a href="/it/software-gestione-recensioni/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri la gestione recensioni
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Multi-sede e modifiche -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Multi-Sede + Sicurezza Profilo</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Aggiorna 50 sedi in un click. Rileva modifiche non autorizzate al volo.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Aggiornare orari festivi, descrizioni o categorie su 50 GBP a mano è un giorno di lavoro. Con Stacc è un'azione singola che si propaga su tutte le sedi simultaneamente. In più, Stacc monitora continuamente il tuo profilo per rilevare modifiche non autorizzate — chiunque (inclusi utenti Google) può suggerire cambiamenti. Quando viene rilevata una modifica all'indirizzo, al nome, all'orario o alla categoria, ricevi un avviso immediato e puoi annullarla prima che danneggi il ranking.
              </p>
              <a href="/it/software-seo-multi-sede/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri Stacc per multi-sede
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Modifiche rilevate — ultime 24 ore</p>
              <div class="rounded-xl border border-[#fee2e2] bg-[#fef2f2] p-4 mb-3">
                <div class="flex items-center justify-between mb-2">
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#dc2626]">⚠ Non autorizzata</span>
                  <span class="font-mono text-[10px] text-[#79716b]">14:22</span>
                </div>
                <p class="font-sans text-[13px] text-[#374151]">Sede Milano — orario di chiusura modificato da 19:00 a 18:00.</p>
              </div>
              <div class="rounded-xl border border-[#dcfce7] bg-[#f0fdf4] p-4 mb-3">
                <div class="flex items-center justify-between mb-2">
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#059669]">✓ Aggiornamento bulk</span>
                  <span class="font-mono text-[10px] text-[#79716b]">09:15</span>
                </div>
                <p class="font-sans text-[13px] text-[#374151]">Orari festività propagati su 14 sedi simultaneamente.</p>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Monitoraggio continuo · Avvisi immediati</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Funzionalità di gestione GBP</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutto ciò che serve per mantenere<br />il GBP al massimo ogni giorno.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
