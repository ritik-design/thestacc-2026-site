---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Quali piattaforme social supporta Stacc?", a: "Stacc pubblica automaticamente su Google Business Profile, Facebook e Instagram. Per le aziende con più sedi, i post possono essere pubblicati simultaneamente su tutti i profili di tutte le sedi in una sola azione." },
  { q: "Perché la gestione manuale dei social non funziona per più sedi?", a: "Con una sede singola è gestibile. Con 5, 10 o 20 sedi, la gestione manuale dei social significa accedere a decine di account diversi, creare contenuti personalizzati per ogni sede e pubblicare manualmente più volte alla settimana su ogni profilo. Il risultato è che alcune sedi ricevono attenzione e altre vengono trascurate per settimane." },
  { q: "Come funziona la pubblicazione in blocco su più sedi?", a: "Scrivi un post una volta sola — testo, immagine, CTA — e seleziona le sedi a cui pubblicarlo. Stacc pubblica il post su GBP, Facebook e Instagram di ogni sede selezionata simultaneamente. Puoi aggiungere personalizzazioni locali (indirizzo, telefono locale) prima di pubblicare se necessario." },
  { q: "I contenuti vengono creati automaticamente?", a: "Sì. Stacc genera il testo dei post automaticamente basandosi sui servizi, la posizione e gli argomenti di ogni sede. I post sono ottimizzati per le ricerche locali e per il tipo di piattaforma. Puoi revisionare e approvare prima della pubblicazione o lasciare che vengano pubblicati automaticamente secondo il calendario configurato." },
  { q: "Come vengono gestite le sedi che non riescono a pubblicare?", a: "Stacc monitora lo stato di ogni pubblicazione e invia avvisi immediati se un post non riesce a pubblicarsi su una sede specifica (es. per problemi di autorizzazione o di connessione). Non rimane nessun post mancato inosservato." },
  { q: "Quanto costa?", a: "Il modulo social media di Stacc parte da $49/mese e include la pubblicazione automatica su GBP, Facebook e Instagram per tutte le sedi, con calendario dei contenuti e report performance." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Strumento Automazione Social",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Pubblica su GBP, Facebook e Instagram per ogni sede simultaneamente. Automazione social media per aziende multi-sede con contenuto automatico e calendario programmato.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Strumento Automazione Social", "item": "https://thestacc.com/it/strumento-automazione-social/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Strumento Automazione Social — Pubblica su Ogni Sede in Automatico | theStacc"
  description="Pubblica su GBP, Facebook e Instagram per tutte le tue sedi simultaneamente. theStacc automatizza la creazione e la pubblicazione dei contenuti social per aziende multi-sede."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Automazione Social · GBP + Facebook + Instagram</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Pubblica su ogni sede in automatico.<br />
            <span style="color:#4f39f6;">GBP, Facebook, Instagram. Simultaneamente.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Gestire i social per più sedi manualmente significa decine di account, ore di lavoro ripetitivo e inevitabilmente alcune sedi che rimangono indietro. Stacc pubblica su tutte le sedi in automatico — stessa qualità per ogni sede, zero lavoro manuale.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Come funziona
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- NARRATIVA -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema della gestione social a scala</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La gestione manuale dei social<br />non scala oltre 2-3 sedi.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Con una sede puoi pubblicare manualmente 3-4 volte alla settimana su GBP, Facebook e Instagram — forse. Con 10 sedi questo si trasforma in 30-40 post a settimana su decine di account diversi. Con 50 sedi è fisicamente impossibile senza un team dedicato. Il risultato è sempre lo stesso: alcune sedi ricevono attenzione costante e le altre scompaiono dai radar.
            </p>
            <p>
              Le sedi che pubblicano regolarmente su GBP ottengono ranking migliori su Google Maps. Le sedi che rimangono inattive scendono. Quando la gestione è manuale, le performance diventano una lotteria dipendente da chi ha più tempo quella settimana, non da chi ha la migliore strategia.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc elimina questo divario. Configuri una strategia di contenuto una volta, imposti le sedi e il calendario, e Stacc pubblica automaticamente su GBP, Facebook e Instagram di ogni sede ogni giorno — con la stessa qualità e coerenza per tutte le sedi, indipendentemente da quante sono.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Funzionalità di automazione social</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Pubblicazione social automatica<br />per ogni sede, ogni giorno.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', title: 'GBP, Facebook e Instagram', body: 'Pubblicazione simultanea su tutte e tre le piattaforme per ogni sede. Un\'unica azione copre tutti i canali di tutte le sedi.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Pubblicazione in blocco multi-sede', body: 'Scrivi un post una volta e pubblicalo su 10, 50 o 200 sedi contemporaneamente. Con personalizzazioni locali opzionali per ogni sede.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Calendario contenuti', body: 'Pianifica i contenuti settimane in anticipo. Il calendario automatico gestisce la frequenza e i tempi di pubblicazione per ogni sede.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Personalizzazione locale', body: 'Aggiungi dettagli specifici per sede — indirizzo locale, numero di telefono, hashtag locali — prima della pubblicazione in blocco. Brand coerente, dettagli localizzati.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Avvisi su post falliti', body: 'Notifica immediata se un post non riesce a pubblicarsi su una sede specifica. Nessuna sede rimane senza contenuto senza che tu lo sappia.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Report performance', body: 'Metriche di engagement per ogni post e per ogni sede. Vedi cosa funziona, dove e quando — tutto incluso nel report mensile automatico.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- METRICHE DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '8 ore', label: 'Risparmiate ogni settimana per sede', sub: 'Rispetto alla gestione social manuale' },
            { value: '3×', label: 'Più coerenza di pubblicazione', sub: 'Automazione vs gestione manuale' },
            { value: '89%', label: 'Miglioramento ranking GBP', sub: 'Con attività costante nei primi 90 giorni' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── PANORAMICA PIATTAFORMA ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa fa Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una piattaforma. Ogni profilo social.<br />Tutto pubblicato per te.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri su GBP, Facebook, Instagram', 'Pubblicazione in blocco multi-sede', 'Calendario contenuti automatico', 'Avvisi su pubblicazioni fallite'], href: '/it/moduli/social-media/' },
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['30 post GBP/mese per sede', 'Rank tracking giornaliero', 'Monitoraggio recensioni', 'Coerenza citazioni 50+ directory'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['Articoli SEO scritti ogni mese', 'Pubblicati direttamente sul tuo sito', 'Ricerca keyword inclusa', 'Link interni ottimizzati'], href: '/it/moduli/seo-blog/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Programmazione, contenuti e multi-account<br />in un unico flusso automatico.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Calendario contenuti -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Calendario di programmazione</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Pianifica un mese di contenuti in 30 minuti. Stacc pubblica per le successive quattro settimane.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Imposti il calendario una volta — frequenza per piattaforma, fasce orarie ottimali, tipologie di post da alternare. Stacc pesca dal piano editoriale e pubblica nei momenti che generano più engagement per ogni canale: la mattina presto su GBP, l'ora di pranzo su Instagram, il tardo pomeriggio su Facebook. Le pubblicazioni si distribuiscono automaticamente per evitare picchi e silenzi sospetti agli algoritmi delle piattaforme.
              </p>
              <a href="/it/moduli/social-media/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo Social Media
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario settimanale</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {['L','M','M','G','V','S','D'].map(d => (
                  <div class="font-mono text-[10px] text-center text-[#79716b]">{d}</div>
                ))}
                {Array.from({length: 28}).map((_, i) => {
                  const filled = [0,1,2,3,4,7,8,9,10,11,14,15,16,17,18,21,22,23,24,25].includes(i);
                  return <div class={`h-5 w-full rounded ${filled ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>;
                })}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Post programmati</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">20 / 28 giorni</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Distribuzione automatica · Nessun picco · Nessun silenzio</p>
            </div>
          </div>

          <!-- Multi-account -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Pubblicazione multi-account · Oggi</p>
              {[
                { label: 'Profili GBP', val: '12 / 12 pubblicati' },
                { label: 'Pagine Facebook', val: '12 / 12 pubblicate' },
                { label: 'Account Instagram', val: '11 / 12 pubblicati' },
                { label: 'Tempo di esecuzione', val: '34 secondi' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">1 retry inviato per Instagram · Avviso al team</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pubblicazione multi-account</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Decine di account collegati. Una sola interfaccia. Pubblicazioni in pochi secondi.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Connetti tutti i profili una volta — GBP, Facebook, Instagram per ogni sede o cliente — e Stacc gestisce le credenziali, i token e le retry automaticamente. Quando una pubblicazione fallisce per un problema temporaneo del social, il sistema ritenta entro pochi minuti senza intervento umano. Quando un token scade, ricevi una notifica chiara con il link diretto per riconnettere — niente percorsi a ostacoli per riautorizzare l'app.
              </p>
              <a href="/it/software-google-business-profile/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri la gestione GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
