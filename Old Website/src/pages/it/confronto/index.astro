---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const compareCategories = [
  { label: 'Piattaforme SEO complete', desc: 'theStacc vs Semrush, Ahrefs, Moz e altre suite SEO. Confronto funzionalità, prezzi e casi d\'uso.' },
  { label: 'Strumenti di content marketing', desc: 'Confronto tra generatori di blog AI, strumenti di autopubblicazione e piattaforme di content scaling.' },
  { label: 'SEO locale e GBP', desc: 'Strumenti per ottimizzare Google Business Profile, gestire recensioni e dominare le ricerche locali.' },
  { label: 'theStacc vs concorrenti', desc: 'Confronti onesti tra theStacc e i suoi alternative più simili: Outrank, WriterZen, e altri.' },
];
---

<BaseLayout
  title="Confronto Strumenti SEO 2026 — Comparazioni Oneste | theStacc"
  description="Confronti approfonditi tra i principali strumenti SEO e di content marketing. Prezzi reali, funzionalità verificate, verdetti chiari. Scritti da chi pubblica 30+ articoli al mese."
  lang="it"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>

    <!-- DARK HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="max-w-6xl mx-auto px-6 relative z-10 py-16">
        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Confronto</span>
        </div>
        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px] max-w-[600px]">
          Confronto strumenti SEO
        </h1>
        <p class="mt-3 max-w-[520px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Confronti onesti e approfonditi tra i principali strumenti SEO e di content marketing. Prezzi reali, funzionalità verificate, verdetti chiari. Scritti da chi pubblica 30+ articoli al mese.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {['Prezzi verificati', 'Funzionalità reali', 'Verdetti chiari', 'Nessuna pubblicità pagata'].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- METHODOLOGY -->
    <section class="border-b border-[#e7e5e4] bg-white py-12 px-6">
      <div class="mx-auto max-w-[860px]">
        <h2 class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#79716b] mb-6">Come confrontiamo</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { icon: '💰', label: 'Prezzi reali', detail: 'Verificati sulle pagine ufficiali' },
            { icon: '⚖️', label: 'Confronto onesto', detail: 'Anche dove perdiamo il confronto' },
            { icon: '🏁', label: 'Verdetto chiaro', detail: 'Per chi è adatto, chi dovrebbe evitarlo' },
            { icon: '📊', label: 'Tabelle complete', detail: 'Funzionalità comparate riga per riga' },
          ].map(item => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4 text-center">
              <span class="text-2xl">{item.icon}</span>
              <p class="mt-2 font-mono text-[11px] font-bold uppercase tracking-[0.08em] text-[#292524]">{item.label}</p>
              <p class="mt-1 font-sans text-[12px] text-[#79716b]">{item.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FEATURED COMPARISON -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] py-14 px-6">
      <div class="mx-auto max-w-[860px]">
        <h2 class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#79716b] mb-8">Confronto in evidenza</h2>
        <a
          href="/it/confronto/outrank/"
          class="group flex flex-col sm:flex-row items-start gap-5 rounded-2xl border border-[#e7e5e4] bg-white p-6 transition-all hover:border-[#c4b5fd] hover:shadow-sm"
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-[#f5f3ff]">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Confronto VS</span>
            <h3 class="mt-1 font-sans text-[18px] font-bold text-[#292524] transition-colors group-hover:text-[#4f39f6]">theStacc vs Outrank.so</h3>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Confronto completo di funzionalità, prezzi, SEO locale, qualità dei contenuti e supporto. Chi conviene scegliere e perché.</p>
            <div class="mt-4 inline-flex items-center gap-1.5 font-mono text-[12px] font-semibold text-[#4f39f6]">
              Leggi il confronto
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- CATEGORIES -->
    <section class="border-b border-[#e7e5e4] bg-white py-14 px-6">
      <div class="mx-auto max-w-[860px]">
        <h2 class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#79716b] mb-8">Categorie di confronto</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {compareCategories.map(cat => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-5">
              <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#4f39f6]">{cat.label}</p>
              <p class="mt-2 font-sans text-[14px] leading-[20px] text-[#57534e]">{cat.desc}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-6 text-center">
          <p class="font-sans text-[15px] font-semibold text-[#292524]">Altri confronti in italiano in arrivo</p>
          <p class="mt-2 font-sans text-[14px] leading-[1.7] text-[#57534e]">
            Nuovi confronti vengono aggiunti ogni settimana. Nel frattempo, consulta i nostri <a href="/compare/" class="text-[#4f39f6] hover:underline">confronti in inglese</a> o scopri perché migliaia di aziende scelgono theStacc.
          </p>
          <div class="mt-5 flex flex-wrap gap-3 justify-center">
            <a href="/it/demo/" class="inline-flex h-10 items-center gap-2 rounded-xl bg-[#4f39f6] px-5 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Prova theStacc
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/compare/" class="inline-flex h-10 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-5 font-sans text-[14px] font-semibold text-[#292524] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              Confronti in inglese
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- DARK CTA -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="max-w-6xl mx-auto px-6 relative z-10 py-16 text-center">
        <h3 class="font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Smetti di confrontare. Inizia a crescere.
        </h3>
        <p class="mx-auto mt-3 max-w-[400px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          theStacc gestisce la tua SEO in automatico, senza bisogno di imparare decine di strumenti.
        </p>
        <a href="/it/demo/" class="mt-6 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Inizia la prova a $1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">$1 per 30 giorni · Cancella quando vuoi</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
