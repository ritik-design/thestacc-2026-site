---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import { SITE_URL, organizationSchema, publisherRef, authorRef, websiteSchema, buildBreadcrumbs } from '../../../utils/schema';

const pageUrl = `${SITE_URL}/it/confronto/outrank/`;
const enUrl = `${SITE_URL}/compare/outrank/`;

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${pageUrl}#article`,
      headline: 'theStacc vs Outrank.so — Confronto Completo 2026',
      description: 'Confronto approfondito tra theStacc e Outrank.so: funzionalità, prezzi, SEO locale, qualità dei contenuti e supporto. Chi conviene scegliere e perché.',
      url: pageUrl,
      author: authorRef,
      publisher: publisherRef,
      mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
      articleSection: 'Confronto Software',
      inLanguage: 'it',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(pageUrl, [
      { name: 'Home', url: SITE_URL },
      { name: 'Confronto', url: `${SITE_URL}/it/confronto/` },
      { name: 'theStacc vs Outrank', url: pageUrl },
    ]),
    organizationSchema,
    websiteSchema,
  ],
};

const comparisonSections = [
  {
    title: 'Contenuto e Pubblicazione',
    rows: [
      { label: 'Generazione articoli blog AI', stacc: true, outrank: true },
      { label: 'Ricerca keyword SEO', stacc: true, outrank: true },
      { label: 'Pubblicazione automatica su CMS', stacc: true, outrank: true },
      { label: 'Integrazione WordPress', stacc: true, outrank: true },
      { label: 'Integrazione Webflow', stacc: true, outrank: true },
      { label: 'Integrazione Shopify', stacc: false, outrank: true },
      { label: 'Pubblicazione a rilascio giornaliero', stacc: true, outrank: true },
      { label: 'Calendario dei contenuti', stacc: true, outrank: true },
      { label: 'Punteggio SEO per articolo', stacc: '92 medio', outrank: 'Non mostrato' },
      { label: 'Voce e tono del brand personalizzati', stacc: true, outrank: false },
      { label: 'Analisi contenuti concorrenti', stacc: true, outrank: true },
      { label: 'Infografiche generate dall\'AI', stacc: true, outrank: 'Bassa qualità' },
    ],
  },
  {
    title: 'SEO Locale',
    rows: [
      { label: 'Ottimizzazione Google Business Profile', stacc: true, outrank: false },
      { label: 'Post GBP giornalieri', stacc: true, outrank: false },
      { label: 'Monitoraggio recensioni e risposte AI', stacc: true, outrank: false },
      { label: 'Tracciamento keyword locali', stacc: true, outrank: false },
      { label: 'Landing page per città', stacc: true, outrank: false },
      { label: 'Supporto multi-sede', stacc: true, outrank: false },
      { label: 'Costruzione citazioni locali', stacc: true, outrank: false },
    ],
  },
  {
    title: 'Piattaforma e Prezzi',
    rows: [
      { label: 'Prezzo di partenza (blog)', stacc: '$99/mese', outrank: '$99/mese' },
      { label: 'Modulo SEO locale', stacc: 'Da $49/mese', outrank: 'Non disponibile' },
      { label: 'Sconto bundle', stacc: '10% off', outrank: 'N/D' },
      { label: 'Sconto annuale', stacc: '17%', outrank: 'Non specificato' },
      { label: 'Prova gratuita', stacc: '$1 per 30 giorni', outrank: '7 giorni gratuiti' },
      { label: 'Flusso di approvazione contenuti', stacc: true, outrank: false },
      { label: 'Rete di scambio backlink', stacc: false, outrank: true },
      { label: 'Multi-lingua (150+)', stacc: false, outrank: true },
      { label: 'Supporto prioritario', stacc: true, outrank: 'Lento (4-5 giorni)' },
    ],
  },
];

const faqs = [
  {
    q: 'Qual è la differenza principale tra theStacc e Outrank.so?',
    a: 'Entrambe le piattaforme generano contenuti blog AI e li pubblicano automaticamente sul tuo CMS. La differenza fondamentale è che theStacc include un modulo SEO locale completo: ottimizzazione Google Business Profile, monitoraggio recensioni, risposte AI alle recensioni, tracciamento keyword locali e landing page per città. Outrank si concentra solo sul blog. Se la tua attività dipende dai clienti locali, theStacc copre entrambi i canali.',
  },
  {
    q: 'theStacc è un sostituto di Outrank.so?',
    a: 'Sì. theStacc fa tutto ciò che fa Outrank per il blog SEO — ricerca keyword, generazione contenuti AI, punteggio SEO e pubblicazione automatica — più un intero modulo SEO locale che Outrank non offre. L\'unica funzionalità che Outrank ha e theStacc non ha è una rete di scambio backlink.',
  },
  {
    q: 'Come si confrontano i prezzi?',
    a: 'Entrambi partono da $99/mese per 30 articoli blog. theStacc offre anche il modulo SEO locale da $49/mese, uno sconto del 10% quando combini entrambi i moduli, e uno sconto del 17% per il piano annuale. Outrank offre sconti multi-sito per agenzie che gestiscono più domini.',
  },
  {
    q: 'Chi dovrebbe scegliere Outrank invece di theStacc?',
    a: 'Outrank è la scelta migliore se hai bisogno di una rete di scambio backlink, supporti più di 150 lingue, o gestisci molti siti e-commerce su Shopify. Se il tuo focus è il blog SEO senza bisogno di SEO locale, la prova gratuita di 7 giorni di Outrank ha un punto di ingresso più basso.',
  },
  {
    q: 'theStacc funziona bene per la SEO locale in Italia?',
    a: 'Sì. Il modulo SEO locale di theStacc è progettato per attività locali: gestisce i post su Google Business Profile in italiano, risponde alle recensioni con tono appropriato al settore, e genera landing page ottimizzate per keyword locali come "avvocato Milano" o "dentista Roma".',
  },
];
---

<BaseLayout
  title="theStacc vs Outrank.so — Confronto Completo 2026 | theStacc"
  description="Confronto approfondito tra theStacc e Outrank.so: funzionalità, prezzi, SEO locale, qualità contenuti e supporto. Chi conviene scegliere e perché."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>

  <Header />
  <main>

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="mx-auto max-w-6xl px-6 relative z-10 py-16">
        <nav class="flex items-center gap-1.5 mb-4" aria-label="Breadcrumb">
          <a href="/it/confronto/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#6b7280] hover:text-[#4f39f6]">Confronto</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#374151" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6]">VS Outrank</span>
        </nav>
        <div class="flex flex-wrap items-center gap-3 mb-5">
          <span class="rounded-md px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.1em] text-[#4f39f6]" style="background:rgba(79,57,246,0.06);">Confronto VS</span>
          <span class="font-mono text-[11px] text-[#6b7280]">Aggiornato gennaio 2026</span>
        </div>
        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px] max-w-[680px]">
          theStacc vs Outrank.so — Confronto Completo
        </h1>
        <p class="mt-4 max-w-[540px] font-sans text-[16px] leading-[1.7] text-[#57534e]">
          Confronto approfondito di funzionalità, prezzi, SEO locale, qualità dei contenuti e supporto. Chi conviene scegliere e perché.
        </p>

        <!-- Ragioni principali -->
        <div class="mt-8 grid gap-4 sm:grid-cols-3 max-w-[760px]">
          {[
            { title: 'SEO locale inclusa', body: 'Outrank fa solo blog. theStacc gestisce anche Google Business Profile, recensioni e pagine per città.' },
            { title: 'Più valore', body: 'Prezzi blog equivalenti, più un modulo SEO locale da $49/mese. Combina i due e risparmia il 10%.' },
            { title: 'Supporto affidabile', body: 'Supporto reale dal team di prodotto. Niente attese di 5 giorni via email.' },
          ].map(r => (
            <div class="rounded-xl border p-4" style="border-color:rgba(79,57,246,0.10);background:rgba(79,57,246,0.08);">
              <p class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#57534e]">{r.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ AVVISO INGLESE ░░ -->
    <div class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="mx-auto max-w-6xl px-6 py-3">
        <div class="flex flex-wrap items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
          <span class="font-mono text-[11px] text-[#57534e]">Stai leggendo la versione italiana di questo confronto.</span>
          <a href={enUrl} class="font-mono text-[11px] font-semibold text-[#4f39f6] underline-offset-2 hover:underline">Leggi in inglese →</a>
        </div>
      </div>
    </div>

    <!-- ░░ TABELLE CONFRONTO ░░ -->
    <section class="border-b border-[#e7e5e4] bg-white py-14 px-6">
      <div class="mx-auto max-w-[860px]">
        <h2 class="font-sans text-[22px] font-bold tracking-[-0.02em] text-[#111827] mb-8">Confronto funzionalità</h2>

        <div class="space-y-10">
          {comparisonSections.map(section => (
            <div>
              <h3 class="mb-3 font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">{section.title}</h3>
              <div class="overflow-hidden rounded-2xl border border-[#e7e5e4]">
                <!-- Header -->
                <div class="grid grid-cols-3 border-b border-[#f5f5f4] bg-[#fafaf9] px-5 py-3">
                  <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">Funzionalità</span>
                  <span class="text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#4f39f6]">theStacc</span>
                  <span class="text-center font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">Outrank</span>
                </div>
                {section.rows.map((row, i) => (
                  <div class={`grid grid-cols-3 items-center px-5 py-3.5 ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
                    <span class="font-sans text-[13px] text-[#292524]">{row.label}</span>
                    <span class="text-center">
                      {row.stacc === true ? (
                        <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      ) : row.stacc === false ? (
                        <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      ) : (
                        <span class="font-mono text-[11px] text-[#4f39f6]">{row.stacc}</span>
                      )}
                    </span>
                    <span class="text-center">
                      {row.outrank === true ? (
                        <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                      ) : row.outrank === false ? (
                        <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      ) : (
                        <span class="font-mono text-[11px] text-[#79716b]">{row.outrank}</span>
                      )}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ VERDICT ░░ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] py-14 px-6">
      <div class="mx-auto max-w-[860px]">
        <h2 class="font-sans text-[22px] font-bold tracking-[-0.02em] text-[#111827] mb-6">Verdetto</h2>
        <div class="grid gap-5 sm:grid-cols-2">
          <div class="rounded-2xl border border-[#4f39f6] bg-white p-6" style="border-width:2px;">
            <p class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6] mb-3">Scegli theStacc se...</p>
            <ul class="space-y-2.5">
              {[
                'Hai un\'attività locale che dipende dai clienti di zona',
                'Vuoi gestire blog SEO e Google Business Profile in un\'unica piattaforma',
                'Hai bisogno di rispondere alle recensioni automaticamente',
                'Gestisci più sedi o franchising',
                'Preferisci un supporto reattivo dal team di prodotto',
              ].map(item => (
                <li class="flex items-start gap-2.5 font-sans text-[13px] text-[#57534e]">
                  <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
            <p class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#79716b] mb-3">Valuta Outrank se...</p>
            <ul class="space-y-2.5">
              {[
                'Hai bisogno di una rete di scambio backlink integrata',
                'Pubblichi contenuti in più di 150 lingue diverse',
                'Gestisci molti siti e-commerce su Shopify',
                'La SEO locale non è una priorità per la tua attività',
                'Vuoi una prova gratuita senza carta di credito (7 giorni)',
              ].map(item => (
                <li class="flex items-start gap-2.5 font-sans text-[13px] text-[#57534e]">
                  <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#a8a29e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ░░ FAQ ░░ -->
    <section class="border-b border-[#e7e5e4] bg-white py-14 px-6">
      <div class="mx-auto max-w-[720px]">
        <h2 class="font-sans text-[22px] font-bold tracking-[-0.02em] text-[#111827] mb-6">Domande Frequenti</h2>
        <div class="divide-y divide-[#f3f4f6] overflow-hidden rounded-2xl border border-[#e5e7eb] bg-white shadow-sm">
          {faqs.map((faq, i, arr) => (
            <div class={i < arr.length - 1 ? 'border-b border-[#f3f4f6]' : ''}>
              <button class="compare-faq-btn flex w-full cursor-pointer items-start justify-between gap-4 px-6 py-5 text-left transition-colors hover:bg-[#fafafa]" aria-expanded="false">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="compare-faq-plus mt-0.5 shrink-0 text-[#9ca3af]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                <svg class="compare-faq-minus hidden mt-0.5 shrink-0 text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <div class="compare-faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-[1.7] text-[#4b5563]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ DARK CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#818cf8]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Hai finito di confrontare. È ora di pubblicare.
        </h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          theStacc scrive, ottimizza e pubblica 30 articoli SEO sul tuo sito ogni mese. Automaticamente.
        </p>
        <a href="/it/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Inizia la prova a $1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">$1 per 30 giorni · Cancella quando vuoi</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.compare-faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      btn.querySelector('.compare-faq-plus')?.classList.toggle('hidden', !expanded);
      btn.querySelector('.compare-faq-minus')?.classList.toggle('hidden', expanded);
      if (expanded) { answer?.classList.add('hidden'); } else { answer?.classList.remove('hidden'); }
    });
  });
</script>
