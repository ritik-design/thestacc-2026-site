---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il software SEO multi-sede?", a: "Il software SEO multi-sede è progettato per gestire il posizionamento locale di un'azienda con più punti vendita o sedi operative. Invece di gestire ogni sede manualmente, il software consente di pubblicare post GBP, monitorare le posizioni, gestire le citazioni e generare report per tutte le sedi contemporaneamente, da un'unica dashboard." },
  { q: "Qual è la differenza rispetto al SEO per sede singola?", a: "Con una sola sede, il lavoro è gestibile manualmente. Con 10, 20 o 50 sedi, ogni attività si moltiplica per il numero di sedi. Il software SEO multi-sede automatizza l'esecuzione a scala — così il lavoro non aumenta proporzionalmente al numero di sedi gestite." },
  { q: "Come gestisce Stacc le sedi con performance diverse?", a: "Stacc fornisce una dashboard portfolio che mostra le performance di tutte le sedi fianco a fianco. Puoi identificare immediatamente quali sedi stanno crescendo, quali stanno calando e dove intervenire. I report per sede mostrano ranking, citazioni e recensioni in dettaglio per ogni posizione." },
  { q: "Posso aggiornare tutte le sedi contemporaneamente?", a: "Sì. La funzione di aggiornamento in blocco di Stacc permette di modificare orari, descrizioni, categorie e attributi GBP su tutte le sedi in una singola azione. Non è necessario accedere a ogni profilo separatamente." },
  { q: "Come funziona la reportistica multi-sede?", a: "Stacc genera report automatici per ogni sede e report portfolio aggregati che mostrano le performance dell'intera rete. I report vengono consegnati automaticamente secondo il calendario configurato — settimanalmennte o mensilmente — senza che il tuo team debba prepararli manualmente." },
  { q: "Quante sedi può gestire Stacc?", a: "Non c'è un limite pratico. Stacc gestisce portfolio da 1 a 500+ sedi. La piattaforma è progettata per scalare senza richiedere personale aggiuntivo per ogni sede aggiunta — l'automazione gestisce il volume." },
  { q: "Quanto costa per le aziende multi-sede?", a: "Il modulo SEO locale parte da $49/mese e include tutte le funzionalità multi-sede — dashboard portfolio, gestione in blocco, report aggregati e automazione per ogni sede." },
  { q: "Quanto tempo richiede l'onboarding di una nuova sede?", a: "Circa 2 minuti. Inserisci i dati della sede (nome, indirizzo, telefono, categorie), connetti il profilo GBP e Stacc propaga automaticamente la configurazione su tutta la rete di citazioni." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software SEO Multi-Sede",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Software SEO multi-sede per gestire rank tracking, GBP, citazioni e reportistica per ogni sede contemporaneamente da una dashboard portfolio unificata.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Software SEO Multi-Sede", "item": "https://thestacc.com/it/software-seo-multi-sede/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Software SEO Multi-Sede — Gestisci Tutte le Sedi da Una Dashboard | theStacc"
  description="Software SEO multi-sede per aziende e agenzie. theStacc automatizza GBP, rank tracking, citazioni e report per ogni sede contemporaneamente — portfolio dashboard inclusa."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software SEO Multi-Sede · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Tutte le sedi gestite<br />
            <span style="color:#4f39f6;">da una dashboard. In automatico.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Con 10 sedi il lavoro SEO si moltiplica per 10. Con Stacc, no. Portfolio dashboard, gestione in blocco, automazione GBP, rank tracking per sede e report automatici — tutto scalato senza aggiungere personale.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Scopri le funzionalità
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- NARRATIVA -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema della gestione SEO multi-sede</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni sede ha bisogno dello stesso lavoro.<br />I team umani possono gestirne solo alcune.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Per una singola sede, il SEO locale è gestibile: aggiorna il GBP, monitora le citazioni, rispondi alle recensioni, traccia i ranking. Forse 3-4 ore a settimana. Va bene per una sede.
            </p>
            <p>
              Moltiplica per 20 sedi. Il lavoro è lo stesso per sede — succede solo 20 volte. In pratica, alcune sedi ricevono attenzione e la maggior parte no. Le sedi curate salgono in classifica. Quelle trascurate no. Le performance del tuo portfolio sono limitate da quante sedi il tuo team riesce a gestire manualmente.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc rompe questo vincolo. L'automazione gestisce il lavoro quotidiano ripetitivo per ogni sede simultaneamente — attività GBP, monitoraggio citazioni, rank tracking, avvisi recensioni — così il tuo sforzo umano va alla strategia, non all'esecuzione.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PANORAMICA PIATTAFORMA -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Moduli disponibili</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una piattaforma completa<br />per ogni sede della tua rete.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Post GBP — 30/mese', 'Rank tracking giornaliero', 'Monitoraggio recensioni', 'Gestione citazioni — 50+ directory'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Pubblicati direttamente sul sito', 'Ricerca keyword inclusa', 'Internal linking ottimizzato'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri con immagini', 'Instagram, Facebook, GBP', 'Scritti e programmati in automatico', 'Contenuto coerente con il brand'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ MULTI-SEDE -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Funzionalità multi-sede</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Progettato per gestire<br />portfolio di qualsiasi dimensione.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Dashboard portfolio', body: 'Vedi tutte le sedi in un unico pannello con ranking, performance recensioni e stato citazioni. Identifica immediatamente chi ha bisogno di attenzione.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Gestione in blocco', body: 'Aggiorna orari, descrizioni, categorie e attributi GBP su tutte le sedi con una singola azione. Nessuna modifica ripetuta sede per sede.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Report portfolio aggregati', body: 'Report automatici per ogni sede + vista aggregata dell\'intera rete. Consegnati in white-label su calendario configurato.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- METRICHE DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '500+', label: 'Sedi gestite in un portfolio', sub: 'Senza personale dedicato per sede' },
            { value: '90%', label: 'Tempo risparmiato per aggiornamenti', sub: 'Modifica in blocco vs sede per sede' },
            { value: '3×', label: 'Più sedi per dipendente', sub: 'L\'automazione moltiplica la capacità' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE (3 in-depth blocks) ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Costruito specificamente<br />per gestire portfolio multi-sede.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Block 1: Dashboard portfolio -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dashboard portfolio multi-sede</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Una vista. Tutte le sedi. Le performance critiche in evidenza ogni mattina.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                La dashboard portfolio ordina automaticamente le sedi per priorità: cali di ranking in cima, sedi in crescita più in basso, anomalie segnalate. Filtra per regione, brand, manager o stato delle citazioni. Clicchi su una sede e vedi rank, recensioni, citazioni e attività GBP — tutto senza saltare tra strumenti diversi.
              </p>
              <a href="/it/seo-multi-sede/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri l'approccio multi-sede
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Portfolio · 27 sedi attive</p>
              <div class="grid grid-cols-3 gap-3 mb-4">
                <div class="rounded-lg bg-[#f5f3ff] p-3 text-center">
                  <p class="font-sans text-[20px] font-bold text-[#4f39f6]">14</p>
                  <p class="font-mono text-[9px] uppercase tracking-[0.1em] text-[#79716b]">In top 3</p>
                </div>
                <div class="rounded-lg bg-[#f5f3ff] p-3 text-center">
                  <p class="font-sans text-[20px] font-bold text-[#4f39f6]">9</p>
                  <p class="font-mono text-[9px] uppercase tracking-[0.1em] text-[#79716b]">In crescita</p>
                </div>
                <div class="rounded-lg bg-[#fef3c7] p-3 text-center">
                  <p class="font-sans text-[20px] font-bold text-[#d97706]">3</p>
                  <p class="font-mono text-[9px] uppercase tracking-[0.1em] text-[#79716b]">Da rivedere</p>
                </div>
              </div>
              {[
                { sede: 'Milano · Centro', rank: '#2', delta: '↑1' },
                { sede: 'Roma · Prati', rank: '#3', delta: '↑2' },
                { sede: 'Torino · Crocetta', rank: '#5', delta: '→' },
                { sede: 'Bologna · Centro', rank: '#7', delta: '↓1' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-2.5">
                  <span class="flex-1 font-sans text-[12px] text-[#374151] truncate">{r.sede}</span>
                  <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">{r.rank}</span>
                  <span class="font-mono text-[10px] text-[#79716b] w-8 text-right">{r.delta}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Block 2: Bulk operations -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Operazione in blocco · 47 sedi selezionate</p>
              <div class="rounded-lg bg-[#f5f3ff] p-4 mb-4">
                <p class="font-sans text-[12px] text-[#4f39f6] font-semibold">Aggiornamento orari festivi</p>
                <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-[#79716b] mt-1">Applicato in parallelo a tutte le sedi</p>
              </div>
              <div class="space-y-2.5">
                <div class="flex items-center justify-between">
                  <span class="font-sans text-[12px] text-[#374151]">Sedi processate</span>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">47 / 47</span>
                </div>
                <div class="h-1.5 w-full rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:100%"></div></div>
                <div class="flex items-center justify-between">
                  <span class="font-sans text-[12px] text-[#374151]">Tempo totale</span>
                  <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">3 min 42 sec</span>
                </div>
              </div>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Operazioni in blocco</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Aggiornamenti che richiederebbero giorni — eseguiti in pochi minuti.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Modifiche di orari, descrizioni, attributi GBP, categorie, foto: applicate simultaneamente a tutte le sedi selezionate. Il software gestisce i rate limit delle API, riprova in caso di fallimento e tiene un log completo delle modifiche. Ogni operazione è annullabile e tracciata, così il tuo team mantiene il controllo anche su grandi network.
              </p>
              <a href="/it/automazione-seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri l'automazione SEO locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Block 3: Aggregated reporting -->
