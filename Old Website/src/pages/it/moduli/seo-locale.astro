---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const faqs = [
  {
    q: "Google penalizza i post automatici su GBP?",
    a: "No. Le stesse linee guida di Google incoraggiano l'attività regolare su Google Business Profile: post, aggiornamenti, foto e risposte. Stacc pubblica contenuti che seguono le best practice di GBP: pertinenti, locali e vari. I nostri clienti pubblicano 30 volte al mese senza una sola sospensione del profilo né penalizzazioni nel posizionamento.",
  },
  {
    q: "Quanto tempo ci vuole per salire su Maps?",
    a: "La maggior parte dei clienti vede movimenti significativi su Maps entro 60–90 giorni di attività costante su GBP. L'algoritmo locale di Google premia frequenza, pertinenza e coinvolgimento. Tutti e tre li fornisce Stacc automaticamente ogni mese. Le attività che vedono i risultati più rapidi sono quelle che prima non pubblicavano quasi nulla.",
  },
  {
    q: "Cosa succede se ho più sedi?",
    a: "Ogni sede riceve il proprio contenuto personalizzato: post mirati alla città, ai servizi e alle parole chiave specifiche di quella sede. Tutto gestito da un unico pannello. Aggiungi tutte le sedi che hai e Stacc tratta ciascuna come un'entità locale indipendente.",
  },
  {
    q: "Posso revisionare i post prima che vengano pubblicati?",
    a: "Sì. Ogni post è disponibile in una coda di revisione prima della pubblicazione. Approva, modifica o attiva la pubblicazione automatica. La maggior parte dei clienti revisiona i primi batch e poi passa alla pubblicazione automatica una volta verificata la qualità del contenuto. Dopodichè i post appaiono semplicemente nel tuo profilo GBP secondo il calendario.",
  },
  {
    q: "Cosa include il monitoraggio delle recensioni?",
    a: "Avvisi istantanei nel momento in cui appare una nuova recensione sul tuo Google Business Profile. Positiva o negativa. Monitoraggio del trend di valutazione settimana dopo settimana. Modelli di risposta per i tipi più comuni di recensioni, così puoi rispondere in meno di un minuto. Tutte le recensioni visibili in un unico pannello per tutte le tue sedi.",
  },
  {
    q: "In cosa si differenzia da Birdeye o Yext?",
    a: "Birdeye e Yext sono strumenti enterprise creati per grandi catene. Partono da €300–€500/mese e richiedono chiamate di onboarding e contratti lunghi. Stacc è costruito per le attività locali: $49/mese, configurazione in pochi minuti, nessun contratto. Inoltre generiamo i tuoi contenuti GBP automaticamente. Birdeye e Yext richiedono che tu scriva i tuoi post.",
  },
];
---

<BaseLayout
  title="Modulo SEO Locale | theStacc | Domina Google Maps per $49/mese"
  description="Stacc pubblica sul tuo Google Business Profile ogni giorno, gestisce le tue recensioni e monitora la tua posizione su Maps. Tutto automaticamente. Inizia per $1."
  lang="it"
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Modulo SEO Locale · $49/mese</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Qualcuno ha appena cercato "[servizio] vicino a me".<br />
            <span style="color:#4f39f6;">Il tuo concorrente è apparso.<br />Tu no.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc pubblica sul tuo Google Business Profile ogni giorno, monitora le tue recensioni e segue la tua posizione su Maps. Tutto automaticamente. Più attività significa maggiore visibilità. Maggiore visibilità significa più chiamate.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/it/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#come-funziona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Scopri come funziona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Garanzia 30 giorni · Senza carta di credito · Post sul tuo GBP per sempre
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '2.800+', num: 2800, prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Post GBP al mese' },
              { value: '340+',   num: 340,  prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Attività locali' },
              { value: '4.7×',   num: 4.7,  prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Miglioramento medio posizione Maps' },
              { value: '0',      num: 0,    prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Recensioni perse' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Attività locali posizionate con Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 su 127 recensioni</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            "Vicino a me" è la ricerca locale più preziosa.<br />Sei invisibile per essa.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Google premia i profili attivi. Tu hai pubblicato due volte il mese scorso.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">L'algoritmo di Maps favorisce le attività che pubblicano costantemente, rispondono alle recensioni e rimangono attive. Ogni settimana che scompari, un concorrente che posta ogni giorno guadagna terreno che ti costerà mesi recuperare.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Una recensione negativa senza risposta può costarti clienti per mesi.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">L'88% dei clienti locali legge le recensioni prima di chiamare. Una recensione da 1 stella senza risposta per una settimana dice a tutti gli altri che non ti importa. La tua valutazione è la tua reputazione. Merita attenzione quotidiana.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Non sai dove appari nelle ricerche "vicino a me".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">La tua posizione su Maps per "idraulico vicino a me" in un quartiere è completamente diversa da un altro a due chilometri. Senza monitoraggio, operi alla cieca. E probabilmente stai perdendo chiamate che non sai nemmeno di perdere.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="come-funziona" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Come funziona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connetti una volta. Stacc gestisce la tua presenza<br />su Maps da quel giorno in poi.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Nessun accesso a GBP. Nessun post da scrivere. Nessuna recensione da controllare manualmente. Configuralo una volta e il tuo Google Business Profile si gestisce da solo. Ogni giorno.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connetti il tuo Google Business Profile</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Cerca la tua attività per nome e sede. Stacc acquisisce i tuoi dati GBP attuali, lo storico delle recensioni e la posizione nel ranking. E identifica esattamente per quali parole chiave non stai apparendo.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">L'IA costruisce il tuo piano di contenuti locali</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 post ottimizzati per sede al mese. Mirati alle tue parole chiave di servizio + città, intento "vicino a me", argomenti stagionali e offerte adatte al tuo tipo di attività. Tutto scritto per potenziare i segnali di Maps.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">I post vengono pubblicati. Il ranking sale. Tu non fai nulla.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">I contenuti vengono pubblicati sul tuo GBP secondo il calendario ogni mese. Gli avvisi di recensione arrivano nel momento in cui ne appare una nuova. Il tuo rapporto di posizionamento su Maps si aggiorna mensilmente. Il tuo profilo si rafforza mentre tu gestisci la tua attività.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── WHY STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perché Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            L'unica opzione che fa tutto il lavoro.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Posizionarsi su Maps richiede attività costante su GBP, risposte rapide alle recensioni e contenuti mirati per parole chiave. Ogni mese, senza eccezioni. Nessun'altra opzione offre tutti e tre senza il tuo tempo o un grande budget.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-4 bg-[#f5f3ff] px-0">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Agenzia SEO Locale</div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Da solo</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Stacc</div>
          </div>
          {[
            { label: 'Costo mensile',                           agency: '€800+',       diy: 'Il tuo tempo', stacc: '$49'     },
            { label: 'Post GBP al mese',                        agency: '8–12',        diy: '2–3',          stacc: '30'      },
            { label: 'Targeting per parole chiave locali',      agency: '✓',           diy: '✗',            stacc: '✓'       },
            { label: 'Monitoraggio recensioni',                 agency: '✓',           diy: 'Manuale',      stacc: '✓'       },
            { label: 'Monitoraggio posizione locale',           agency: '✓',           diy: '✗',            stacc: '✓'       },
            { label: 'Tempo richiesto da te',                   agency: 'Qualcosa',    diy: 'Alto',         stacc: 'Nessuno' },
          ].map((row, i) => (
            <div class={`grid grid-cols-4 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.agency}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.diy}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.stacc}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/it/demo/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
          >
            Inizia per $1 oggi
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>


    <!-- ─── FEATURE 1: GBP POSTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
          <div>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pubblicazione GBP</span>
            <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.1rem]">
