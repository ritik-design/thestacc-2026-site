---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const faqs = [
  {
    q: "Google penalizza i contenuti generati dall'IA?",
    a: "Le stesse linee guida di Google lo dicono chiaramente: quello che conta è la qualità e la rilevanza, non come è stato creato il contenuto. Ogni articolo pubblicato da Stacc si basa su vera ricerca di parole chiave, è scritto per rispondere a vere query di ricerca e viene valutato rispetto agli standard SEO prima della pubblicazione. I nostri clienti hanno pubblicato milioni di parole senza una sola penalizzazione manuale o calo di posizionamento.",
  },
  {
    q: "Quanto tempo prima di vedere risultati?",
    a: "La maggior parte dei clienti vede un movimento significativo nel posizionamento entro 60–90 giorni. Alcuni lo vedono prima. La SEO è un asset che si accumula. Ogni articolo che pubblichi rende più facile posizionare il successivo. Prima inizi, maggiore vantaggio costruisci sui concorrenti che ci stanno ancora pensando.",
  },
  {
    q: "Quali piattaforme CMS supportate?",
    a: "WordPress, Webflow e Ghost sono completamente integrati. Pubblicazione diretta, senza plugin. Qualsiasi CMS con supporto REST API o webhook funziona automaticamente. E se usi qualcosa di personalizzato, puoi esportare e incollare. Il contenuto è sempre tuo.",
  },
  {
    q: "Posso modificare gli articoli prima che vengano pubblicati?",
    a: "Ogni articolo è in una coda di revisione prima della pubblicazione. Modifica, approva o attiva la pubblicazione automatica. La maggior parte dei clienti rivede i primi lotti e poi passa alla pubblicazione automatica quando verifica che la qualità si mantiene. Dopo, il contenuto appare semplicemente sul loro sito.",
  },
  {
    q: "Cosa succede se cancello? Mantengo il mio contenuto?",
    a: "Ogni articolo pubblicato sul tuo sito è tuo in modo permanente. Cancella oggi e quelle pagine continueranno a posizionarsi, generare traffico e acquisire contatti. Per sempre. Sei proprietario del 100% di tutto ciò che è stato pubblicato.",
  },
  {
    q: "In cosa si differenzia dall'usare ChatGPT?",
    a: "ChatGPT scrive parole. Stacc posiziona pagine. La differenza sta nello strato SEO: ricerca di parole chiave calibrata per il tuo mercato reale, punteggio di ottimizzazione, link interni, meta tag, schema markup. E poi pubblicazione diretta nel tuo CMS. ChatGPT ti dà una bozza che nessuno troverà. Stacc ti dà una pagina live, indicizzata e posizionata.",
  },
];
---

<BaseLayout
  title="Modulo SEO Blog | theStacc | Trasforma il tuo Sito in una Macchina di Contatti"
  description="Stacc pubblica 30 articoli ottimizzati per SEO sul tuo sito ogni mese, automaticamente. Più articoli = più posizioni = più clienti. Inizia per $1."
  lang="it"
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Modulo SEO Blog · $99/mese</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Trasforma il tuo sito in una<br class="hidden md:block" />
            <span style="color:#4f39f6;">macchina SEO che genera contatti.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc pubblica 30 articoli ottimizzati per SEO sul tuo sito ogni mese. Automaticamente. Più articoli significa più posizioni sui motori di ricerca. Più posizioni significano più clienti che trovano la tua attività, senza che tu tocchi una sola parola.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/it/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Guarda come funziona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Garanzia 30 giorni · Senza carta di credito · Ogni articolo rimane per sempre
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '300k', num: 300000, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Articoli pubblicati' },
              { value: '340+', num: 340,     prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Attività locali' },
              { value: '4.9★', num: 4.9,     prefix: '',  suffix: '★', decimals: 1, from: 0, label: 'Valutazione media' },
              { value: '0',    num: 0,       prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Penalizzazioni di posizionamento' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Attività posizionate con Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 su 127 recensioni</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sai che il contenuto è come ti trovano.<br />Ma i numeri non tornano mai.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Hai bisogno di 30 articoli. Ne hai pubblicati 2 l'anno scorso.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Google premia le attività che appaiono in modo costante. Ogni settimana che non pubblichi, il tuo concorrente lo fa. Quel divario di posizionamento si accumula. E ogni mese che aspetti è più difficile da colmare.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">I copywriter SEO chiedono €200–€400 per articolo. Per articolo.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">30 articoli al mese con un freelance costa €6.000–€12.000. Un'agenzia chiede €3.500 e scrive forse 6 post. I numeri del ROI non tornano mai. Quindi non inizi. E loro continuano a superarti nel posizionamento.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Scrivere senza strategia SEO non posiziona.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Ricerca di parole chiave, link interni, meta tag ottimizzati, schema markup. Sono 3 ore extra per articolo. Se salti qualsiasi parte, avrai pubblicato qualcosa che nessuno troverà. Hai bisogno del sistema completo, non solo delle parole.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Come funziona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Configuralo in 5 minuti.<br />Funziona automaticamente dopo.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Connetti il tuo sito una volta. Stacc mappa i tuoi gap di parole chiave, impara la tua voce di brand e inizia a pubblicare. Senza che tu muova un dito. Vedrai muoversi il traffico prima che tu ci pensi due volte.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connetti il tuo sito web</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Inserisci il tuo URL. Stacc scansiona il tuo sito, legge il posizionamento dei tuoi concorrenti, trova i gap di parole chiave che hanno lasciato aperti, e costruisce tutta la tua strategia di contenuto in meno di 2 minuti.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">L'IA scrive il tuo piano di contenuto</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 articoli completamente ottimizzati scritti per puntare ai termini di ricerca reali che usano i tuoi clienti. Ogni articolo viene valutato rispetto agli standard SEO prima della pubblicazione. Nulla va online se non si posizionerà.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Gli articoli vengono pubblicati. Tu non fai nulla.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Il contenuto viene pubblicato direttamente nel tuo WordPress, Webflow o Ghost secondo il calendario che imposti. Nuovo mese, 30 articoli freschi. Il tuo sito costruisce autorità mentre tu gestisci la tua attività.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── WHY STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perché Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            L'unica opzione che fa tutto il lavoro.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Posizionarsi richiede ricerca di parole chiave, scrittura di qualità, ottimizzazione e pubblicazione costante. Ogni mese, senza eccezioni. Nessun'altra opzione offre i quattro senza consumare il tuo tempo o il tuo budget.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-4 bg-[#f5f3ff] px-0">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Agenzia</div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Freelance</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Stacc</div>
          </div>
          {[
            { label: 'Costo mensile',                    agency: '€3.500+',  freelancer: '€1.200+',  stacc: '$99'      },
            { label: 'Articoli per mese',                agency: '6–8',      freelancer: '4–6',      stacc: '30'       },
            { label: 'Ricerca parole chiave',            agency: '✓',        freelancer: '✗',        stacc: '✓'        },
            { label: 'Ottimizzazione SEO',               agency: '✓',        freelancer: 'A volte',  stacc: '✓'        },
            { label: 'Training voce di brand',           agency: 'A volte',  freelancer: 'A volte',  stacc: '✓'        },
            { label: 'Pubblicazione automatica',         agency: '✗',        freelancer: '✗',        stacc: '✓'        },
            { label: 'Tempo richiesto da parte tua',     agency: 'Alto',     freelancer: 'Medio',    stacc: 'Nessuno'  },
          ].map((row, i) => (
            <div class={`grid grid-cols-4 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.agency}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.freelancer}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.stacc}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a href="/it/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
            Inizia per $1 oggi
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>


    <!-- ─── FEATURE 1: KEYWORD RESEARCH ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
          <div>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ricerca parole chiave</span>
            <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.1rem]">
              Posizionati per ciò che cercano i tuoi clienti. Prima della concorrenza.
            </h2>
            <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
