---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è la reportistica white-label?", a: "La reportistica white-label significa che i report sui risultati SEO vengono consegnati ai clienti con il logo, i colori e il dominio della tua agenzia — non quello di Stacc. I clienti vedono solo il tuo brand professionale, non il software che usi dietro le quinte." },
  { q: "Quali dati vengono inclusi nei report?", a: "I report includono: variazioni di posizionamento per tutti i keyword tracciati, nuove recensioni e punteggio medio, stato delle citazioni e coerenza NAP, attività GBP (post pubblicati, visualizzazioni), e riepilogo delle azioni eseguite nel periodo. Tutti i grafici e le tabelle sono brandizzati con il tuo marchio." },
  { q: "I report vengono consegnati automaticamente?", a: "Sì. Configuri il modello una volta — metriche, logo, colori, frequenza (settimanale o mensile) — e Stacc genera e invia i report automaticamente ai clienti senza che il tuo team debba fare nulla. Zero lavoro manuale di reportistica ogni mese." },
  { q: "Come appaiono i report ai clienti?", a: "I report arrivano via email con il tuo logo nell'intestazione, il tuo dominio come mittente (es. noreply@tuaagenzia.it) e sono disponibili come PDF scaricabile o dashboard interattiva — tutto completamente brandizzato." },
  { q: "Posso rivedere i report prima che vengano inviati?", a: "Sì. Puoi configurare Stacc per inviarti prima una copia di revisione con un intervallo di approvazione (es. 24 ore) prima della consegna automatica ai clienti. Oppure puoi impostare la consegna completamente automatica senza revisione." },
  { q: "I clienti possono avere una dashboard live?", a: "Sì. Oltre ai report periodici, ogni cliente può avere accesso a una dashboard live con dati aggiornati in tempo reale — posizionamenti, recensioni, citazioni — tutto brandizzato con il tuo marchio." },
  { q: "Quanto costa?", a: "Il modulo SEO locale che include la reportistica white-label automatizzata parte da $49/mese. Nessun costo per cliente per la consegna dei report." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Reportistica White-Label",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Report SEO white-label che si generano e si consegnano da soli. Brandizzati con il tuo logo, inviati automaticamente ai clienti, zero lavoro manuale.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Reportistica White-Label", "item": "https://thestacc.com/it/reportistica-white-label/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Reportistica White-Label — Report SEO che si Inviano da Soli. Con il Tuo Marchio | theStacc"
  description="Reportistica SEO white-label automatizzata. theStacc genera i report, li brandizza con il tuo logo e li consegna ai clienti automaticamente — zero ore di reportistica manuale."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Reportistica White-Label · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Report clienti che si generano<br />
            <span style="color:#4f39f6;">e si inviano da soli. Con il tuo brand.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            3 ore per preparare un report × 15 clienti = 45 ore al mese di reportistica manuale. Stacc le elimina. Report generati, brandizzati con il tuo logo e consegnati automaticamente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Come funziona
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- ─── NARRATIVA (PAIN) ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema della reportistica manuale</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La reportistica è la parte più<br />costosa del SEO per le agenzie.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              La maggior parte delle agenzie SEO spende tra 2 e 4 ore per preparare ogni report clienti: estrarre i dati da più strumenti, formattarli in un documento, aggiungere il logo, scrivere il riepilogo esecutivo, inviare per email. Moltiplica per 15 clienti e stai parlando di 30-60 ore al mese solo per la reportistica. Ore che non generano valore SEO — solo comunicazione di risultati.
            </p>
            <p>
              Il problema non è solo il tempo. È che questo processo è soggetto a errori: report in ritardo, dati sbagliati, formattazione inconsistente. Ogni ritardo nella consegna di un report crea un dubbio nel cliente su ciò che l'agenzia sta davvero facendo.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc elimina questa attività interamente. Configuri il template una volta — metriche, logo, colori, frequenza. Dopo, Stacc raccoglie i dati, formatta il report, lo brandizza con il tuo logo e lo invia al cliente automaticamente. Il tuo team non tocca più un report.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW (FUNZIONALITÀ) ─── -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa include la reportistica white-label</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Report che si gestiscono<br />completamente da soli.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Branding completo', body: 'Logo, colori, tipografia e mittente email brandizzati con il marchio della tua agenzia. I clienti vedono solo il tuo brand professionale.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Consegna automatica programmata', body: 'Report inviati settimanalmente o mensilmente in automatico, allo stesso orario. I clienti ricevono sempre aggiornamenti puntuali senza che tu ci pensi.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Dati di posizionamento', body: 'Variazioni di ranking per tutti i keyword tracciati — local pack, Maps e organico — visualizzati con grafici trend brandizzati.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Stato citazioni e recensioni', body: 'Coerenza NAP su 50+ directory, punteggio medio recensioni e nuove review nel periodo — tutto incluso nel report automatico.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Template personalizzabile', body: 'Scegli quali metriche includere, come ordinarle e quale sommario esecutivo aggiungere. Template salvato e riusato per ogni cliente.' },
            { icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z', title: 'Dashboard live clienti', body: 'Oltre ai report periodici, i clienti accedono a una dashboard live con dati aggiornati in tempo reale — brandizzata con il tuo marchio.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità della reportistica automatizzata</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tre flussi di reportistica.<br />Tutti automatici. Tutti brandizzati.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Report PDF mensile -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Report PDF brandizzato</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                PDF mensile con il tuo logo. Inviato dal tuo dominio. Letto e archiviato dai clienti.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Il report PDF è ancora il formato preferito dai clienti aziendali — perché si archivia, si stampa, si presenta in board. Stacc genera un PDF impaginato professionalmente con il tuo logo nell'intestazione, le tue metriche selezionate, i grafici nei tuoi colori e una conclusione precompilata che puoi modificare. Il PDF arriva all'inbox del cliente dal mittente del tuo dominio. Per il cliente è un report dell'agenzia. Punto.
              </p>
              <a href="/it/moduli/seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il modulo SEO Locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Report SEO · Marzo</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Da: report@tuaagenzia.it</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">PDF</span>
              </div>
              {[
                { label: 'Keyword in top 3', val: '12 / 25 totali' },
                { label: 'Variazione media ranking', val: '+2,4 posizioni' },
                { label: 'Recensioni nuove', val: '7 (media 4.7)' },
                { label: 'Citazioni controllate', val: '50/50 coerenti' },
                { label: 'Visite organiche stimate', val: '+34% MoM' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">PDF generato e consegnato il 1° del mese · Logo agenzia · Zero lavoro</p>
            </div>
          </div>

          <!-- Email settimanale -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5 border-b border-[#f5f3ff] pb-4">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Update settimanale</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Lunedì 8:00</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#4f39f6]">EMAIL</span>
              </div>
              <p class="font-sans text-[13px] leading-relaxed text-[#374151] mb-3">Ciao [Cliente], ecco i risultati di questa settimana:</p>
              {[
                { label: '↑ Ranking saliti', val: '5 keyword' },
                { label: '↓ Ranking scesi', val: '1 keyword' },
                { label: '+ Nuove recensioni', val: '2' },
                { label: '⏱ Post GBP pubblicati', val: '7 / 7' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Inviata da report@tuaagenzia.it · Apri rate medio: 84%</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Update settimanali via email</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Email settimanali al cliente. Brevi. Sempre puntuali. Sempre dal tuo dominio.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Tra un report mensile e l'altro, i clienti vogliono sentire che l'agenzia sta lavorando. Stacc invia ogni lunedì mattina un'email breve con le 4-5 metriche chiave della settimana — ranking saliti, recensioni nuove, post pubblicati, attività eseguita. L'email parte dal tuo dominio, ha il tuo logo e il tuo tono. Il cliente la apre, vede progressi, smette di chiedere update. Tu non hai scritto una riga.
              </p>
              <a href="/it/automazione-seo-locale/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri l'automazione SEO locale
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Dashboard live -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dashboard live brandizzata</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                I clienti possono accedere ai dati in tempo reale. Sotto il tuo dominio. Quando vogliono.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                I clienti più sofisticati vogliono vedere i numeri quando vogliono — non aspettare il report del 1° del mese. Stacc ti dà una dashboard live che il cliente raggiunge dal tuo dominio (app.tuaagenzia.it), accede con le sue credenziali e vede ranking, recensioni, citazioni e attività GBP aggiornati in tempo reale. Logo agenzia ovunque. Niente Stacc visibile. È letteralmente come avere costruito un prodotto SaaS interno per i clienti.
              </p>
              <a href="/it/seo-locale-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il SEO locale white-label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Dashboard live · La Tua Agenzia</p>
              {[
                { kw: 'studio dentistico Milano', pack: 1, change: '+2' },
                { kw: 'sbiancamento denti Milano', pack: 2, change: '+1' },
                { kw: 'impianti dentali Milano', pack: 3, change: '+4' },
                { kw: 'ortodonzia invisibile', pack: 5, change: '0' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.change.startsWith('+') ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.change.startsWith('+') ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Aggiornata ogni mattina · Accessibile dal cliente · 0 ore manuali</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICHE DARK ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '3 ore', label: 'Risparmiate per cliente ogni mese', sub: 'Rispetto alla reportistica manuale' },
            { value: '100%', label: 'Consegna puntuale garantita', sub: 'Report automatici, mai in ritardo' },
            { value: '$0', label: 'Costo per consegna report', sub: 'Incluso nel modulo da $49/mese' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
