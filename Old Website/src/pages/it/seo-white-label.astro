---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Cos'è il SEO white-label?", a: "Il SEO white-label significa erogare servizi SEO ai tuoi clienti con il tuo marchio — non quello del software o del provider. La piattaforma di theStacc viene presentata ai clienti con il tuo logo, i tuoi colori e il tuo nome di dominio, in modo che vedano solo il tuo brand e non Stacc." },
  { q: "Cosa viene personalizzato con il white-label?", a: "I report dei clienti, la dashboard di accesso, le notifiche via email e i PDF vengono tutti brandizzati con il tuo logo e i tuoi colori. Il dominio del portale clienti può essere il tuo dominio personalizzato (es. report.tuaagenzia.it). Nessun riferimento a theStacc è visibile ai tuoi clienti." },
  { q: "Quanto tempo richiede la configurazione?", a: "La configurazione iniziale richiede circa 2 ore: carica il tuo logo, imposta i colori del brand, configura il dominio personalizzato. Dopo, l'aggiunta di nuovi clienti richiede solo pochi minuti ciascuno." },
  { q: "I clienti possono accedere autonomamente?", a: "Sì. Ogni cliente riceve le proprie credenziali di accesso al portale white-label. Possono visualizzare i report di rank tracking, dati sulle citazioni e metriche delle recensioni in qualsiasi momento, senza doverti contattare ogni volta." },
  { q: "Supportate domini personalizzati?", a: "Sì. Puoi ospitare il portale di reporting dei clienti su un sottodominio del tuo sito (es. report.tuaagenzia.it) per un'esperienza completamente white-label. La configurazione DNS richiede circa 15 minuti." },
  { q: "Quanto costa?", a: "Il modulo SEO locale parte da $49/mese e include tutte le funzionalità white-label — dashboard brandizzata, report PDF con il tuo logo, portale accesso clienti e notifiche email personalizzate. Nessun costo per cliente e nessuna quota di configurazione." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO White-Label",
      "inLanguage": "it",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Piattaforma SEO white-label per agenzie. Dashboard brandizzata, report automatizzati e accesso clienti — tutto con il tuo marchio, zero riferimenti a Stacc.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD", "description": "Modulo SEO locale — prova gratuita 14 giorni" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inizio", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "SEO White-Label", "item": "https://thestacc.com/it/seo-white-label/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="SEO White-Label — Gestisci il SEO dei Clienti Sotto il Tuo Marchio | theStacc"
  description="Piattaforma SEO white-label per agenzie. theStacc gestisce rank tracking, citazioni, recensioni e report — tutto brandizzato con il tuo logo, il tuo colore e il tuo dominio."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO White-Label · Da $49/mese</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO white-label che funziona<br />
            <span style="color:#4f39f6;">sotto il tuo marchio.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Gestisci il SEO dei clienti, consegna i report e offri l'accesso alla dashboard — tutto con il logo e il dominio della tua agenzia. I clienti vedono solo il tuo brand.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia per $1 oggi
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funzionalita"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Guarda come funziona
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Nessuna carta di credito · Garanzia 30 giorni · Disdici quando vuoi
          </p>
        </div>
      </div>
    </section>


    <!-- VALORE WHITE-LABEL -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il vantaggio del white-label</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            I tuoi clienti vedono la tua agenzia,<br />non la tecnologia che usi.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              La maggior parte delle agenzie SEO usa strumenti di terze parti per gestire il lavoro. Il problema è che queste piattaforme spesso appaiono nei report, nelle email e nelle dashboard — e i clienti cominciano a chiedersi perché stanno pagando l'agenzia invece di usare direttamente lo strumento. Il white-label elimina questo problema.
            </p>
            <p>
              Con Stacc, tutto ciò che i tuoi clienti vedono porta il tuo marchio. I report hanno il tuo logo. La dashboard di accesso è brandizzata con i tuoi colori. Le email partono dal tuo dominio. Non c'è traccia di Stacc nell'esperienza del cliente — solo la tua agenzia che consegna risultati professionali.
            </p>
            <p>
              Questo non è solo un vantaggio estetico. <strong class="text-[#111827]">È la differenza tra essere visto come un rivenditore di software e essere visto come un'agenzia che eroga un servizio premium.</strong> Il white-label ti permette di far pagare il giusto, trattenere i clienti più a lungo e costruire un brand che vale qualcosa.
            </p>
            <p>
              E l'automazione di Stacc fa il lavoro pesante dietro le quinte: pubblica i post GBP, monitora le posizioni, gestisce le citazioni, invia i report — tutto automaticamente, tutto brandizzato con il tuo marchio.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa puoi rivendere</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tre moduli white-label.<br />Un solo brand: il tuo.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Locale', price: '$49/mese', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Rank tracking giornaliero brandizzato', 'Pubblicazione GBP automatica', 'Gestione citazioni e recensioni', 'Report PDF con il tuo logo'], href: '/it/moduli/seo-locale/' },
            { title: 'Blog SEO', price: '$99/mese', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 articoli SEO al mese', 'Pubblicati direttamente sul sito cliente', 'Ricerca keyword inclusa', 'Link interni ottimizzati'], href: '/it/moduli/seo-blog/' },
            { title: 'Social Media', price: '$49/mese', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Post giornalieri con immagini', 'Instagram, LinkedIn, Facebook, X', 'Programmati automaticamente', 'Coerenti al brand del cliente'], href: '/it/moduli/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Scopri di più</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacità chiave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Brand. Dominio. Esperienza cliente.<br />Tutto sotto il tuo controllo.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Branding completo -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Branding Completo</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Il tuo logo, i tuoi colori, il tuo dominio. Stacc invisibile per sempre.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Carica il logo della tua agenzia, imposta la palette del brand e configura il tuo dominio personalizzato (es. report.tuaagenzia.it). Da quel momento, ogni report PDF, ogni email automatica, ogni schermata del portale clienti porta il tuo marchio. I clienti non vedono mai il nome Stacc — vedono solo l'agenzia con cui hanno firmato.
              </p>
              <a href="/it/reportistica-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri la reportistica white-label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-10 w-10 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[14px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[14px] font-semibold text-[#111827]">La Tua Agenzia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">report.tuaagenzia.it</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Brandizzato</span>
              </div>
              {[
                { label: 'Logo personalizzato', val: 'Caricato' },
                { label: 'Colori brand', val: '#4f39f6 + 2 altri' },
                { label: 'Dominio personalizzato', val: 'Attivo' },
                { label: 'Email mittente', val: 'team@tuaagenzia.it' },
                { label: 'Riferimenti a Stacc', val: 'Zero' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Configurato in 2 ore · Stacc invisibile per sempre</p>
            </div>
          </div>

          <!-- Portale clienti -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Accessi portale — questo mese</p>
              {[
                { name: 'Cliente Milano', logins: 12, status: 'Attivo' },
                { name: 'Cliente Roma', logins: 8, status: 'Attivo' },
                { name: 'Cliente Torino', logins: 15, status: 'Attivo' },
                { name: 'Cliente Napoli', logins: 6, status: 'Attivo' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] font-medium text-[#374151] truncate">{r.name}</span>
                  <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{r.logins} accessi</span>
                  <span class="font-mono text-[10px] font-semibold text-[#059669]">{r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Ogni cliente ha le sue credenziali · Self-service 24/7</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Portale Clienti Self-Service</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                I clienti accedono ai loro dati 24 ore su 24. Tu non rispondi più a "come stiamo andando?".
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Ogni cliente riceve credenziali per accedere al suo portale brandizzato sul tuo dominio. Vedono rank tracking, attività GBP, citazioni e recensioni in tempo reale, senza doverti scrivere o aspettare il report mensile. Riduci le richieste in entrata, aumenti la trasparenza percepita e posizioni l'agenzia come tecnologicamente avanzata.
              </p>
              <a href="/it/seo-locale-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il SEO locale white-label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Margini agenzia -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Margini Agenzia</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Vendi a $500–$1.500 al cliente. Paghi $49 a Stacc. Margine 90%+ sull'esecuzione.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Il modello economico del SEO white-label è semplice: il cliente paga la tua agenzia per la strategia e l'esperienza, mentre Stacc gestisce l'esecuzione automatizzata a un costo fisso. Non paghi per cliente, non paghi per sede, non paghi per integrazione. Aggiungi un cliente in pochi minuti e mantieni il margine intatto. Più clienti aggiungi, più scalabile diventa l'economia della tua agenzia.
              </p>
              <a href="/it/rivenditore-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Scopri il programma rivenditore
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Economia per cliente — esempio</p>
              <div class="space-y-3">
                <div class="flex items-center justify-between border-b border-[#f5f3ff] pb-3">
                  <span class="font-sans text-[13px] text-[#57534e]">Fee al cliente</span>
                  <span class="font-sans text-[15px] font-semibold text-[#111827]">$800/mese</span>
                </div>
                <div class="flex items-center justify-between border-b border-[#f5f3ff] pb-3">
                  <span class="font-sans text-[13px] text-[#57534e]">Costo Stacc</span>
                  <span class="font-sans text-[15px] font-semibold text-[#111827]">−$49/mese</span>
                </div>
                <div class="flex items-center justify-between rounded-lg bg-[#f5f3ff] px-3 py-2.5">
                  <span class="font-sans text-[13px] font-bold text-[#4f39f6]">Margine lordo</span>
                  <span class="font-sans text-[18px] font-bold text-[#4f39f6]">$751 (94%)</span>
                </div>
                <div class="flex items-center justify-between border-b border-[#f5f3ff] pb-3 pt-2">
                  <span class="font-sans text-[13px] text-[#57534e]">× 20 clienti</span>
                  <span class="font-sans text-[15px] font-semibold text-[#111827]">$15.020/mese</span>
                </div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Nessun costo per cliente · Nessuna quota di setup</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- FUNZIONALITÀ 6-GRID -->
    <section id="funzionalita" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cosa include il white-label</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutto il necessario per gestire i clienti<br />sotto il tuo marchio.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
