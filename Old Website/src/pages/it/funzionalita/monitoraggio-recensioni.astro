---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quali piattaforme di recensioni monitora Stacc?",
    a: "Stacc monitora principalmente le recensioni di Google Business Profile, che hanno il maggior impatto sul SEO locale. Vengono monitorate anche altre piattaforme come Facebook.",
  },
  {
    q: "Quanto velocemente ricevo avvisi per nuove recensioni?",
    a: "Gli avvisi per le recensioni di Google Business Profile vengono inviati in genere entro 30–60 minuti dalla pubblicazione della recensione. Per altre piattaforme i tempi possono variare in base alla frequenza con cui vengono interrogate da Stacc.",
  },
  {
    q: "Posso ricevere avvisi solo per le recensioni negative?",
    a: "Sì. Puoi configurare le soglie di avviso — ad esempio notifica immediata per tutte le recensioni sotto 4 stelle e notifiche giornaliere riassuntive per tutte le altre. Così resti informato senza ricevere un avviso per ogni recensione positiva.",
  },
  {
    q: "Stacc può aiutarmi a rispondere alle recensioni?",
    a: "Stacc tiene traccia di quali recensioni hanno ricevuto risposta e quali sono in attesa. Per la stesura delle risposte devi rispondere direttamente sulla piattaforma di recensioni — Stacc ti aiuta a non perdere nessuna recensione.",
  },
  {
    q: "Come funziona il monitoraggio delle recensioni per più sedi?",
    a: "Ogni sede ha il proprio feed di recensioni in Stacc. Puoi vedere tutte le recensioni in un feed aggregato o filtrare per sede. Gli avvisi possono essere configurati per ogni singola sede.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Monitoraggio Recensioni",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Ricevi avvisi immediati per le nuove recensioni su Google. Monitora l'andamento della tua valutazione, identifica i pattern e rispondi alle recensioni prima che danneggino la tua reputazione.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Funzionalità", "item": "https://thestacc.com/it/funzionalita/" },
        { "@type": "ListItem", "position": 3, "name": "Monitoraggio Recensioni", "item": "https://thestacc.com/it/funzionalita/monitoraggio-recensioni/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Monitoraggio Recensioni — Monitora le Recensioni Google in Tempo Reale | theStacc"
  description="Ricevi avvisi immediati per le nuove recensioni su Google. Monitora l'andamento della tua valutazione, identifica i pattern e rispondi alle recensioni prima che danneggino la tua reputazione."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Monitoraggio Recensioni · Modulo SEO Locale</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Un cliente ha lasciato oggi una recensione da 1 stella.<br />
            <span style="color:#4f39f6;">Quanto tempo impieghi a scoprirlo?</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Le recensioni negative senza risposta ti costano clienti — ogni ora che rimangono visibili. Stacc ti avvisa immediatamente per ogni nuova recensione, monitora l'andamento della tua valutazione e ti aiuta a identificare i pattern prima che piccoli problemi diventino grandi danni alla reputazione.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inizia il monitoraggio recensioni
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi i prezzi
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Inizia per $1 · Nessuna carta di credito · Cancella quando vuoi
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'Immediato', label: 'Tempo di avviso per nuove recensioni' },
              { value: 'Google+', label: 'Più piattaforme di recensioni monitorate' },
              { value: '4.2+', label: 'Obiettivo di valutazione per i ranking locali' },
              { value: '4.9★', label: 'Valutazione clienti' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ogni ora senza risposta a una recensione negativa ti costa potenziali clienti.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            La maggior parte delle aziende controlla le recensioni settimanalmente — se lo fa. Nel tempo che intercorre tra la pubblicazione di una recensione negativa e la tua risposta, decine di potenziali clienti vedono la critica senza risposta e scelgono un concorrente. Quello che non vedi non puoi risponderci.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Una recensione negativa senza risposta danneggia la tua reputazione ogni giorno.',
              body: 'Per ogni potenziale cliente che vede la tua recensione negativa senza una risposta, la probabilità che ti scelga scende del 30%. Se non sai che la recensione esiste, non puoi rispondere. E ogni ora che passa ti costa altri potenziali clienti.',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Monitorare manualmente le recensioni su più piattaforme non è praticabile.',
              body: 'Controllare ogni giorno ogni piattaforma di recensioni per ogni tua sede richiede ore. La maggior parte delle aziende controlla settimanalmente o meno — il che significa che le recensioni negative a volte rimangono senza risposta per giorni. È troppo tardi.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Senza il tracciamento delle tendenze, vedi i problemi di servizio solo quando è troppo tardi.',
              body: 'Una singola recensione negativa potrebbe essere casuale. Cinque recensioni negative sullo stesso argomento sono un pattern — ma solo se lo vedi. Senza l\'analisi delle recensioni, individui i problemi di servizio solo dopo che hanno già danneggiato la tua valutazione media.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Come funziona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Monitora le recensioni, rispondi ai pattern,<br />proteggi la reputazione.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Tutte le piattaforme di recensioni in un unico feed', body: 'Collega Google Business Profile e altre piattaforme di recensioni. Tutte le nuove recensioni appaiono immediatamente nel tuo dashboard Stacc — da tutte le sedi, in una sola pagina.' },
            { n: '02', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Avvisi immediati per ogni nuova recensione', body: 'Ricevi avvisi immediati via email o dashboard per ogni nuova recensione. Per le recensioni negative (3 stelle o meno) possono essere configurati avvisi con la massima priorità.' },
            { n: '03', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Analizza i pattern, prendi provvedimenti', body: 'Monitora le tendenze delle recensioni nel tempo. Verifica se una sede specifica o un certo periodo genera regolarmente valutazioni più basse. Informazioni basate sui dati ti aiutano a risolvere i problemi di servizio prima che danneggino la tua reputazione complessiva.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tutto incluso</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Gestione completa delle recensioni<br />da un'unica piattaforma.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Avvisi recensioni in tempo reale', body: 'Notifica immediata per ogni nuova recensione — configurabile per piattaforma, sede e valutazione a stelle.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Analisi e tendenze delle recensioni', body: 'Monitora l\'evoluzione della tua valutazione media, il volume delle nuove recensioni e le tendenze del sentiment nel corso di settimane e mesi.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Più piattaforme in un unico dashboard', body: 'Google, Facebook e altre piattaforme unite. Nessun controllo separato di più schede.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Rilevamento argomenti delle recensioni', body: 'Identificazione automatica degli argomenti citati più spesso nelle recensioni — servizio positivo, tempi di attesa, personale, prezzi. Individua i pattern prima che diventino un problema.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
            { title: 'Tracciamento delle risposte', body: 'Tieni traccia di quali recensioni hanno ricevuto risposta e quali sono ancora in attesa. Nessuna risposta mancata su più sedi.', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
            { title: 'Panoramica recensioni multi-sede', body: 'Vedi quali sedi performano meglio o peggio. Identifica dove si concentrano i problemi di servizio e agisci in modo mirato.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Risultati</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Cosa ottengono le aziende con un monitoraggio<br />proattivo delle recensioni.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '87%', label: 'Clienti che leggono le recensioni prima di acquistare', sub: 'aziende con presenza locale' },
            { value: '<2h', label: 'Tempo di risposta alle recensioni negative', sub: 'con gli avvisi in tempo reale di Stacc' },
            { value: '+0,4★', label: 'Miglioramento medio della valutazione', sub: 'entro 6 mesi di monitoraggio costante' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Prima venivo a sapere delle recensioni negative giorni dopo — a volte solo quando un cliente al telefono chiedeva perché non avevamo risposto. Con Stacc ricevo un avviso in pochi minuti e posso rispondere prima che la recensione influenzi l'immagine all'esterno."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">MR</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Marco R.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Titolare, Centro Benessere · 2 sedi</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">Tempo di risposta ridotto da giorni a ore</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Domande frequenti</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Domande sul monitoraggio delle recensioni
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ogni recensione senza risposta ti costa clienti</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Le recensioni negative ti danneggiano solo<br />se rispondi troppo tardi.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            In questo momento qualcuno potrebbe stare scrivendo una recensione negativa sulla tua attività. Ogni ora che passa senza risposta, potenziali clienti vedono quella recensione e scelgono un concorrente. Stacc fa sì che tu sia sempre il primo a saperlo.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Inizia il monitoraggio recensioni
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Vedi i prezzi
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Inizia per $1 · Garanzia 30 giorni · Cancella quando vuoi</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
