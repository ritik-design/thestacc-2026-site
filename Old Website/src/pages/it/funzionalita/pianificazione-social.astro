---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Su quali piattaforme social pubblica Stacc?",
    a: "Stacc pubblica automaticamente su Instagram, LinkedIn, X (Twitter) e Facebook. Ogni post viene adattato al formato e al tono della piattaforma specifica — non si tratta di un semplice copia-incolla dello stesso contenuto su tutte le piattaforme.",
  },
  {
    q: "I post social vengono creati da zero o sono basati sui miei articoli del blog?",
    a: "Ogni articolo blog pubblicato da Stacc viene automaticamente trasformato in contenuto per i social media. L'idea principale, le statistiche chiave e le intuizioni più rilevanti dell'articolo vengono rielaborate in post ottimizzati per ogni piattaforma.",
  },
  {
    q: "Con quale frequenza vengono pubblicati i post social?",
    a: "Dipende dalla frequenza di pubblicazione del blog e dalle tue impostazioni. In genere, per ogni articolo blog vengono creati 3–4 post social distribuiti nel corso della settimana. Puoi configurare la frequenza e i giorni/orari di pubblicazione.",
  },
  {
    q: "Posso rivedere i post prima che vengano pubblicati?",
    a: "Sì. Puoi configurare Stacc per inviarti i post per approvazione prima della pubblicazione, oppure lasciare che vengano pubblicati automaticamente secondo il calendario. La maggior parte dei clienti passa alla pubblicazione automatica dopo il primo mese.",
  },
  {
    q: "Stacc crea anche le immagini per i post social?",
    a: "Sì. Stacc genera automaticamente immagini ottimizzate per ogni piattaforma usando l'IA. Le immagini seguono il tono visivo del tuo brand e sono dimensionate correttamente per ogni canale.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Pianificazione Social Media",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "it",
      "description": "Trasforma ogni articolo del blog in contenuto social per Instagram, LinkedIn, X e Facebook. Pianificato e pubblicato automaticamente. Una strategia social che funziona senza un social media manager.",
      "offers": { "@type": "Offer", "price": "167", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/it/" },
        { "@type": "ListItem", "position": 2, "name": "Funzionalità", "item": "https://thestacc.com/it/funzionalita/" },
        { "@type": "ListItem", "position": 3, "name": "Pianificazione Social", "item": "https://thestacc.com/it/funzionalita/pianificazione-social/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "it",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Pianificazione Social Media Automatica — Instagram, LinkedIn, X, Facebook | theStacc"
  description="Trasforma ogni articolo del blog in contenuto social per Instagram, LinkedIn, X e Facebook. Pianificato e pubblicato automaticamente. Una strategia social che funziona senza un social media manager."
  lang="it"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Social Media Automatico · Modulo Social</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Ogni articolo del blog diventa<br />
            <span style="color:#4f39f6;">contenuto per tutti i tuoi canali social.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc trasforma automaticamente ogni articolo pubblicato in post per Instagram, LinkedIn, X e Facebook. Ottimizzati per ogni piattaforma. Pianificati e pubblicati senza che tu faccia nulla. Una strategia social completa senza un social media manager.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/it/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Automatizza i tuoi social
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/it/prezzi/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Vedi i prezzi
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Inizia per $1 · Nessuna carta di credito · Cancella quando vuoi
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '4', label: 'Piattaforme social gestite automaticamente' },
              { value: 'Auto', label: 'Immagini generate con l\'IA' },
              { value: '0h', label: 'Tempo che dedichi ai social ogni settimana' },
              { value: '4.9★', label: 'Valutazione clienti' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Il problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            I social media richiedono ore ogni settimana. E non puoi permetterti di ignorarli.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Creare contenuti, trovare immagini, scrivere caption diverse per ogni piattaforma, pianificare gli orari ottimali. Per farlo bene servono 5–10 ore a settimana. Per farlo male, non vale la pena farlo.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Crei contenuti per il blog ma non li distribuisci.',
              body: 'Hai scritto un ottimo articolo. L\'hai pubblicato sul sito. Poi non è successo niente. Il contenuto del blog senza distribuzione social è come aprire un negozio eccellente in un vicolo cieco. Ogni articolo dovrebbe diventare 4–5 post social che portano traffico al tuo sito.',
            },
            {
              icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4',
              title: 'Ogni piattaforma vuole un formato diverso.',
              body: 'Un post LinkedIn funziona con testo lungo e professionistico. Instagram vuole immagini forti e caption brevi. X richiede densità e punch in pochi caratteri. Creare contenuti diversi per ogni piattaforma ogni settimana richiede competenze e tempo che la maggior parte delle PMI non ha.',
            },
            {
              icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
              title: 'La costanza è impossibile senza un sistema.',
              body: 'I social media funzionano con la continuità. Un profilo che posta una volta ogni due settimane non cresce. Ma mantenere una cadenza regolare su 4 piattaforme, settimana dopo settimana, richiede un sistema — non buone intenzioni.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Come funziona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Dal blog ai social. Tutto automatico.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Stacc pubblica un articolo sul tuo sito', body: 'Ogni mese vengono pubblicati 30 articoli ottimizzati per SEO. Ogni articolo è una fonte di contenuto social — contiene idee, dati, consigli pratici che funzionano perfettamente sui social media.' },
            { n: '02', icon: 'M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-9 0h10m-10 0H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2h-2m-7 10l2 2 4-4', title: 'L\'IA crea post specifici per ogni piattaforma', body: 'Il contenuto dell\'articolo viene rielaborato in post distinti per Instagram, LinkedIn, X e Facebook. Ogni post è ottimizzato per il formato, la lunghezza e il tono della piattaforma specifica. Le immagini vengono generate automaticamente.' },
            { n: '03', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'I post vengono pianificati e pubblicati', body: 'I post vengono distribuiti nel corso della settimana negli orari ottimali per ogni piattaforma. Pubblicazione automatica senza che tu acceda mai ai social media. Il tuo profilo cresce mentre gestisci la tua attività.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tutto incluso</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Social media completi senza<br />un social media manager.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Instagram, LinkedIn, X, Facebook', body: 'Pubblicazione automatica su tutte e quattro le piattaforme principali. Ogni post adattato al formato e alle aspettative specifiche di ogni canale.', icon: 'M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-9 0h10m-10 0H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2h-2m-7 10l2 2 4-4' },
            { title: 'Generazione immagini con IA', body: 'Per ogni post social viene creata automaticamente un\'immagine ottimizzata per quella piattaforma, coerente con il tono visivo del tuo brand.', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { title: 'Pianificazione negli orari ottimali', body: 'I post vengono pubblicati negli orari in cui il tuo pubblico è più attivo su ogni piattaforma. Nessuna pubblicazione manuale, nessun promemoria da impostare.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
            { title: 'Adattamento automatico per piattaforma', body: 'Lo stesso articolo diventa un thread su X, un post professionale su LinkedIn, una storia visiva su Instagram. Non un copia-incolla — un\'adattamento genuino per ogni formato.', icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4' },
            { title: 'Anteprima e approvazione opzionale', body: 'Configura il flusso di approvazione che preferisci — revisione completa prima della pubblicazione, approvazione rapida o pubblicazione completamente automatica.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
            { title: 'Calendario social integrato', body: 'Vedi tutti i post pianificati in un calendario visivo. Modifica, riprogramma o elimina i post direttamente dal calendario senza entrare nelle singole piattaforme.', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Risultati</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Cosa succede quando i social<br />diventano completamente automatici.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '0h', label: 'Ore settimanali dedicate ai social', sub: 'dopo aver configurato Stacc' },
            { value: '4+', label: 'Piattaforme gestite in automatico', sub: 'Instagram, LinkedIn, X, Facebook' },
            { value: '120+', label: 'Post social pubblicati ogni mese', sub: 'da 30 articoli blog, ottimizzati per piattaforma' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Prima spendevo 6–8 ore a settimana sui social media e ottenevo risultati mediocri. Adesso Stacc pubblica automaticamente su Instagram, LinkedIn e Facebook partendo dai miei articoli. Il mio profilo è più attivo di prima e io non ci penso più."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">LB</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Laura B.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Titolare, Studio di Fisioterapia · Torino</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">Da 8 ore/settimana a zero</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Domande frequenti</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Domande sulla pianificazione social
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


