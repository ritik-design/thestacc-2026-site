---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  { q: "What is white-label reporting?", a: "White-label reporting is when an agency delivers client reports branded with their own logo, agency name, and domain — not the software vendor's. Clients receive professionally formatted reports that reinforce the agency's brand, with no third-party tool names visible anywhere." },
  { q: "What data is included in Stacc's white-label reports?", a: "Reports include keyword rankings (local pack, Maps, organic), GBP activity metrics (posts published, views, call clicks), citation accuracy scores, review data (count, average score, response rate), and month-over-month comparison data. You configure which sections to include per client." },
  { q: "Are reports delivered automatically or do I have to export them?", a: "Fully automated. Configure your delivery schedule for each client — weekly or monthly — and Stacc generates and emails the report automatically. No exports, no formatting, no manual sending. Reports arrive in client inboxes without anyone on your team touching them." },
  { q: "Can the report look like it came from my agency, not Stacc?", a: "Yes. Your logo, your agency name, your domain in the email sender, your color scheme in the PDF. Stacc's name appears nowhere in the client-facing report. Clients experience it as your proprietary reporting system." },
  { q: "Can I review reports before they're sent to clients?", a: "Yes. You can set reports to 'review before send' mode where they're held in your dashboard for approval. Or set them to fully automated delivery where they go directly to clients. Per-client configuration." },
  { q: "Does white-label reporting include live client dashboards?", a: "Yes. In addition to automated report delivery, clients can access a live dashboard on your domain that updates continuously with fresh data. The live dashboard shows current rankings, recent GBP activity, and review stats in real time." },
  { q: "What does white-label reporting cost?", a: "Included in Stacc's Growth and Scale plans. The Local SEO module starts at $49/month. Client report delivery is included with no per-client fee." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — White-Label Reporting", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "White-label SEO reporting for agencies. Automated report generation and delivery under your agency brand — your logo, your domain, your report.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "White-Label Reporting", "item": "https://thestacc.com/white-label-reporting/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="White-Label SEO Reporting for Agencies — Automated, Branded Reports | theStacc"
  description="Automate client SEO reporting under your agency's brand. theStacc generates and delivers white-label reports with your logo and domain — weekly or monthly, zero manual work."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">White-Label Reporting · For Agencies · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Client reports that build and send<br />
            <span style="color:#4f39f6;">themselves. Under your brand.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc generates, brands, and delivers SEO reports for every client automatically on your schedule. Your logo. Your domain. Zero manual work per report.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/features/client-reporting/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See client reporting
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The real cost of manual reporting</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            3 hours per client per month.<br />Multiplied by every client you have.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>For a 15-client agency, manual reporting is 45 hours a month — more than a full work week — spent pulling data, formatting spreadsheets, and writing summaries that clients will skim for 30 seconds. It's the highest-leverage task you can automate, because the time savings compound directly into capacity for more clients.</p>
            <p>But the brand dimension matters just as much as the time. Reports that arrive with a generic tool's name on them are doing something subtle: they're telling your client that your process is a commodity. Reports that arrive with your logo, from your domain, on a professional schedule — those tell your client you're running a professional operation. That perception affects retention.</p>
            <p class="font-semibold text-[#111827]">Stacc automates the generation and delivery of branded reports for every client, on whatever schedule you choose. The time savings alone make it worth it. The brand impression is the bonus.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reporting capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every reporting feature agencies need.<br />All automated, all branded.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Your brand on every report', body: 'Your logo, agency name, and color scheme on every PDF and email. Stacc\'s branding removed completely from all client-facing documents.' },
            { icon: '3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Automated delivery on schedule', body: 'Configure weekly or monthly delivery per client. Reports generate and send automatically — no manual trigger, no export, no formatting.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Complete local SEO data', body: 'Rankings, GBP activity, citation accuracy, review scores, and month-over-month comparisons — all in one report per client.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Live branded dashboards', body: 'Clients also get access to a live dashboard on your domain showing real-time data between report delivery cycles.' },
            { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Review before send mode', body: 'Optionally hold reports for your review before delivery. Approve and send in one click, or let reports go fully automated per client preference.' },
            { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', title: 'Multi-client report management', body: 'See all client reports in a single queue. Track delivery status, open rates, and client engagement from your agency dashboard.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 3, suffix: ' hrs', label: 'Saved per client per month', sub: 'Automation replaces manual report building' },
            { to: 100, suffix: '%', label: 'On-time report delivery', sub: 'No manual steps, no delays, no forgetting' },
            { to: 0, suffix: '$0', label: 'Per client report delivery', sub: 'Unlimited automated reports included' },
          ].map((m, idx) => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                {idx === 2 ? <span>{m.suffix}</span> : <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>}
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            White-label reporting:<br />common questions answered.
          </h2>
          <div class="mt-10 divide-y divide-[#e7e5e4]">
            {faqs.map((f, i) => (
              <div class="py-5">
                <button class="faq-btn flex w-full items-start justify-between gap-4 text-left" aria-expanded="false">
                  <span class="font-sans text-[1rem] font-semibold text-[#111827]">{f.q}</span>
                  <span class="mt-0.5 flex-shrink-0">
                    <svg class="faq-icon-plus h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    <svg class="faq-icon-minus hidden h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                  </span>
                </button>
                <div class="faq-answer hidden pt-3">
                  <p class="font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Related resources</p>
        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {[
            { href: '/features/client-reporting/', label: 'Client Reporting' },
            { href: '/features/white-label-dashboard/', label: 'White-Label Dashboard' },
            { href: '/white-label-seo/', label: 'White-Label SEO' },
            { href: '/white-label-local-seo/', label: 'White-Label Local SEO' },
            { href: '/seo-reseller/', label: 'SEO Reseller' },
            { href: '/solutions/agencies/', label: 'Stacc for Agencies' },
            { href: '/features/multi-location-reporting/', label: 'Multi-Location Reporting' },
            { href: '/local-seo-software/', label: 'Local SEO Software' },
          ].map(l => (
            <a href={l.href} class="flex items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 font-sans text-[13px] font-medium text-[#374151] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              {l.label}
            </a>
          ))}
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.35) 0%,transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-24 text-center">
        <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.8rem]">
          Stop building reports by hand.<br />Let Stacc deliver them for you.
        </h2>
        <p class="mx-auto mt-5 max-w-[520px] font-sans text-[1rem] leading-[1.7]" style="color:#9ca3af;">Start your $1 trial and have your first automated branded report scheduled before the end of the day.</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-12 items-center gap-2 rounded-xl bg-[#4f39f6] px-7 font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
            Start free — no credit card
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/pricing/" class="inline-flex h-12 items-center rounded-xl border border-white/15 bg-white/5 px-7 font-sans text-[15px] font-medium text-white/80 transition-colors hover:bg-white/10">See pricing</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      if (answer) answer.classList.toggle('hidden', expanded);
      btn.querySelector('.faq-icon-plus')?.classList.toggle('hidden', !expanded);
      btn.querySelector('.faq-icon-minus')?.classList.toggle('hidden', expanded);
    });
  });
  document.querySelectorAll<HTMLElement>('[data-count-up]').forEach(el => {
    const from = parseFloat(el.dataset.from || '0'), to = parseFloat(el.dataset.to || '0'), suffix = el.dataset.suffix || '', duration = 1800; let start: number | null = null;
    const obs = new IntersectionObserver(entries => {
      if (!entries[0].isIntersecting) return; obs.disconnect();
      const step = (ts: number) => { if (!start) start = ts; const p = Math.min((ts - start) / duration, 1); el.textContent = (from + (to - from) * (1 - Math.pow(1 - p, 3))).toFixed(0) + suffix; if (p < 1) requestAnimationFrame(step); };
      requestAnimationFrame(step);
    }, { threshold: 0.3 }); obs.observe(el);
  });
</script>
