---
import LegalLayout from '../layouts/LegalLayout.astro';

const toc = [
  { id: 'intro',    label: 'About' },
  { id: 'frontend', label: 'Frontend Technologies' },
  { id: 'fonts',    label: 'Fonts' },
  { id: 'devtools', label: 'Development Tools' },
];

const frontendLibraries = [
  { name: 'Astro',       licence: 'MIT License',          url: 'https://astro.build' },
  { name: 'Tailwind CSS', licence: 'MIT License',         url: 'https://tailwindcss.com' },
  { name: 'Three.js',    licence: 'MIT License',          url: 'https://threejs.org' },
];

const fonts = [
  { name: 'Geist Sans',  licence: 'SIL Open Font License', url: 'https://fonts.google.com/specimen/Geist' },
  { name: 'Geist Mono',  licence: 'SIL Open Font License', url: 'https://fonts.google.com/specimen/Geist+Mono' },
];

const devTools = [
  { name: 'TypeScript',  licence: 'Apache License 2.0',   url: 'https://typescriptlang.org' },
];
---

<LegalLayout
  title="Licences"
  description="Open-source software and font licences used in theStacc. Full attribution and licence details for all third-party components."
  lastUpdated="April 2026"
  badge="Legal · Attribution"
  tocItems={toc}
  currentPath="/licences/"
>
  <div class="flex flex-col gap-10">

    <section id="intro" class="scroll-mt-6">
      <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
        theStacc is built using a variety of open-source software and fonts. We are grateful to the developers and communities who have made their work available. Below is a list of the major open-source libraries and assets we use, along with their respective licences.
      </p>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="frontend" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-5">
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Frontend Technologies</h2>
      </div>
      <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
        <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Library</span>
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Licence</span>
        </div>
        {frontendLibraries.map((item, i) => (
          <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < frontendLibraries.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]"
            >
              {item.name}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
          </div>
        ))}
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="fonts" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-5">
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Fonts</h2>
      </div>
      <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
        <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Font</span>
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Licence</span>
        </div>
        {fonts.map((item, i) => (
          <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < fonts.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]"
            >
              {item.name}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
          </div>
        ))}
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="devtools" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-5">
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Development Tools</h2>
      </div>
      <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
        <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Tool</span>
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Licence</span>
        </div>
        {devTools.map((item, i) => (
          <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < devTools.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]"
            >
              {item.name}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
          </div>
        ))}
      </div>
      <p class="mt-5 font-sans text-[13px] text-[#79716b]">
        For the full list of dependencies and their licences, refer to our <code class="rounded bg-[#f5f3ff] px-1.5 py-0.5 font-mono text-[12px] text-[#4f39f6]">package.json</code> or contact us at <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
      </p>
    </section>

  </div>
</LegalLayout>
