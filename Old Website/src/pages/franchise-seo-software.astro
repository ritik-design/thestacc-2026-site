---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ExitIntent from '../components/common/ExitIntent.astro';

const faqs = [
  { q: "What should franchise SEO software do?", a: "Franchise SEO software should automate the repetitive local SEO tasks that need to happen consistently at every location: GBP post publishing, citation monitoring, rank tracking, review alerts, and reporting. If it only tracks these things and requires manual execution, it's not solving the scalability problem." },
  { q: "How is franchise SEO software different from standard local SEO tools?", a: "Standard local SEO tools are built for single locations or small sets. Franchise SEO software is built for portfolios — bulk editing, network-wide reporting, tiered access for franchisees vs. franchisors, and automation that runs the same tasks for every location without manual repetition per location." },
  { q: "Can Stacc manage both corporate-owned and franchisee locations?", a: "Yes. You can segment locations by ownership type or region and apply different settings, reporting schedules, or access levels to each group. Corporate locations and franchisee locations live in the same dashboard with configurable permission levels." },
  { q: "Does Stacc support white-label reporting for franchise networks?", a: "Yes. White-label reports can carry the franchisor's brand or the franchisee's brand depending on the reporting structure. Reports are generated and delivered automatically on schedule." },
  { q: "How does Stacc handle NAP consistency across franchise locations?", a: "Stacc monitors citation data across 50+ directories for each location and flags inconsistencies in real time. Corrections can be pushed to all affected locations in bulk. Consistent NAP data is one of the highest-impact local ranking factors for franchise businesses." },
  { q: "Is there a setup fee for franchise accounts?", a: "No setup fee. Plans start at $49/month for the Local SEO module, which includes all franchise and multi-location features." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Franchise SEO Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Franchise SEO software that automates local search management across your entire network. GBP, citations, rankings, and reporting for every location, simultaneously.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Franchise SEO Software", "item": "https://thestacc.com/franchise-seo-software/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Franchise SEO Software — Automate Local SEO Across Your Whole Network | theStacc"
  description="Franchise SEO software built for scale. theStacc automates GBP management, citation monitoring, rank tracking, and reporting for every franchise location — no manual work per location."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Franchise SEO Software · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Franchise SEO software that<br />
            <span style="color:#4f39f6;">runs your whole network.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Built for franchise scale: bulk GBP management, network-wide citation monitoring, portfolio ranking dashboards, and automated reporting for every location simultaneously.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/solutions/franchises/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See franchise features
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">500+ franchise locations managed</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">No per-location headcount</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What franchise SEO software must do</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Most SEO tools track at scale.<br />Stacc executes at scale.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Most local SEO tools were built for one location or a small handful. They show you dashboards. They tell you what needs to be done. Then someone on your team has to open each location and do it. That works for five locations. It doesn't work for fifty.</p>
            <p>Franchise SEO software has a different job: automate execution at scale. Not just report on what's happening — actually do it. Publish the GBP posts. Monitor the citations. Send the reports. For every location, every day, without someone scheduling it manually per location.</p>
            <p class="font-semibold text-[#111827]">That's Stacc. Built from the start for multi-location execution — not retrofitted for scale after the fact.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Platform capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Everything franchise networks need<br />in one platform.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Network-wide GBP management', body: 'Publish posts, update hours, and manage attributes for every franchise location in bulk. One action. Every location. Instant propagation.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Citation consistency monitoring', body: 'Monitor NAP accuracy across 50+ directories for every location. Bulk-correct inconsistencies before they affect rankings.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Per-location ranking dashboard', body: 'Daily rank updates for every location in local pack, Maps, and organic. Portfolio view shows all locations side by side with performance trends.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Review management per location', body: 'Centralized review inbox for all franchise locations. Real-time alerts, response management, and review score tracking by location.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Franchisor and franchisee access', body: 'Tiered permissions: franchisors see the full network, franchisees see their own data. Centralized management with individual visibility.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Automated reporting for the network', body: 'Network summaries, location-level reports, and custom group reports — generated and delivered automatically on your schedule.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How Stacc works for franchises</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Your entire franchise network.<br />Managed from one place.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Network Portfolio Dashboard</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Every franchise location ranked. Underperformers surface in seconds.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">The network portfolio dashboard shows all franchise locations side by side — rankings, citation accuracy, GBP activity score, and review average in a single view. Sort by any metric to instantly see which locations are growing, which are stagnating, and exactly where to focus next. No tab-switching, no spreadsheet aggregating — it's done for you every morning.</p>
              <a href="/features/multi-location-reporting/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">See network reporting <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Franchise network — today</p>
              {[
                { name: 'Austin — Downtown', rank: '#1', gbp: 98, reviews: '4.9', trend: '↑' },
                { name: 'Austin — South Lamar', rank: '#2', gbp: 94, reviews: '4.8', trend: '↑' },
                { name: 'Dallas — Uptown', rank: '#4', gbp: 81, reviews: '4.6', trend: '→' },
                { name: 'Houston — Midtown', rank: '#9', gbp: 52, reviews: '4.1', trend: '↓' },
              ].map(loc => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <span class={`flex h-8 w-10 shrink-0 items-center justify-center rounded-lg font-mono text-[11px] font-bold ${loc.rank === '#1' || loc.rank === '#2' ? 'bg-[#4f39f6] text-white' : loc.rank === '#4' ? 'bg-[#f5f3ff] text-[#4f39f6]' : 'bg-[#fff1f2] text-[#ef4444]'}`}>{loc.rank}</span>
                  <span class="flex-1 font-sans text-[12px] text-[#374151]">{loc.name}</span>
                  <div class="h-1.5 w-14 rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${loc.gbp}%`}></div></div>
                  <span class="font-mono text-[11px] text-[#57534e]">{loc.reviews}★</span>
                  <span class={`font-mono text-[11px] font-bold ${loc.trend === '↑' ? 'text-[#059669]' : loc.trend === '↓' ? 'text-[#ef4444]' : 'text-[#79716b]'}`}>{loc.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Updated daily · All 47 franchise locations tracked</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Bulk operation — GBP post</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[12px] font-semibold text-[#111827] mb-2">Apply to</p>
                <div class="flex flex-wrap gap-2">
                  {['All 47 locations', 'Texas region (12)', 'Custom select'].map(opt => (
                    <span class={`rounded-lg px-3 py-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] ${opt === 'All 47 locations' ? 'bg-[#4f39f6] text-white' : 'border border-[#e7e5e4] text-[#79716b]'}`}>{opt}</span>
                  ))}
                </div>
              </div>
              <div class="rounded-xl border border-[#e7e5e4] bg-white p-4">
                <p class="font-sans text-[12px] text-[#57534e] mb-3">"Now open — new holiday menu. Visit us this weekend."</p>
                <div class="flex items-center justify-between">
                  <span class="font-mono text-[11px] text-[#79716b]">Scheduling to all 47 locations</span>
                  <span class="rounded-lg bg-[#059669] px-3 py-1 font-mono text-[10px] font-bold text-white">Publish all</span>
                </div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">47 posts queued · 0 manual logins needed</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Bulk Franchise Operations</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">One action. Every franchise location. No individual logins.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Publish a GBP post to all 47 franchise locations in a single click. Update holiday hours for every location at once. Push a new offer to a specific region in seconds. Bulk operations in Stacc aren't just convenient — they're how franchise networks maintain consistent SEO activity across locations without a dedicated team per location. One decision propagates everywhere.</p>
              <a href="/features/bulk-location-management/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">See bulk management <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated Franchise Reporting</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Network summaries and per-location reports. Delivered automatically.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Stacc generates and delivers network-wide performance reports and individual location reports on your schedule. Franchisors get the full picture. Franchisees get their own location's data. Reports carry your brand — white-labeled with your logo and color scheme — and go out automatically every week or month without anyone remembering to run them.</p>
              <a href="/features/client-reporting/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">See automated reporting <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Monthly network report — April 2025</p>
              {[
                { label: 'Locations in top-3 pack', val: '38 / 47', up: true },
                { label: 'GBP posts published', val: '1,410 total', up: true },
                { label: 'New reviews this month', val: '+284 (avg 4.7★)', up: true },
                { label: 'Citation issues flagged', val: '3 locations', up: false },
                { label: 'Network avg rank change', val: '+2.1 positions', up: true },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">{row.label}</span>
                  <span class={`font-sans text-[12px] font-semibold ${row.up ? 'text-[#059669]' : 'text-[#ef4444]'}`}>{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Auto-delivered to all franchisees · White-labeled</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 500, suffix: '+', label: 'Franchise locations managed', sub: 'Single platform, zero per-location staff' },
            { to: 95, suffix: '%', label: 'Less time per network update', sub: 'Bulk edit vs one-by-one' },
            { to: 3, suffix: '×', label: 'More locations per employee', sub: 'Automation compounds at scale' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-5xl">
          <div class="mb-12 text-center">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What customers say</span>
            <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
              Franchise teams that stopped<br />managing location by location.
            </h2>
          </div>
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            {[
              { name: 'Brandon K.', role: 'VP of Marketing, 34-unit restaurant franchise', stars: 5, quote: "Before Stacc, updating GBP for all 34 locations for a holiday promotion took my team most of a day. Now it takes about 90 seconds. The bulk publish is the single feature that sold me." },
              { name: 'Diane M.', role: 'Franchise Development Director, fitness brand', stars: 5, quote: "Every franchisee gets their own ranking report every Monday morning automatically. No one asks me for data anymore — they have it. That alone has freed up hours per week of back-and-forth." },
              { name: 'Tyler R.', role: 'Regional SEO Manager, 60-location home services', stars: 5, quote: "We went from 18 locations in the local 3-pack to 51 in four months. The citation monitoring caught problems at locations we hadn't touched in two years. Small fixes, massive ranking impact." },
              { name: 'Carla S.', role: 'Director of Digital, national retail franchise', stars: 5, quote: "The tiered access model was exactly what we needed. Corporate sees everything, franchisees see their own location. We finally have network visibility without losing the franchisee relationship." },
            ].map(t => (
              <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7">
                <div class="mb-4 flex gap-0.5">{[1,2,3,4,5].map(() => <svg width="13" height="13" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}</div>
