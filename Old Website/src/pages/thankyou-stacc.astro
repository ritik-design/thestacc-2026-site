---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { SITE_URL } from '../utils/schema';
---

<BaseLayout
  title="You're booked — theStacc"
  description="Your strategy call request is confirmed. Pick a time that works for you and we'll come fully prepared."
  noindex={true}
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden bg-white">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.045) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.045) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 88%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 88%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[480px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.28) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-16 md:py-20" style="max-width:1280px;">
        <div class="mx-auto max-w-[640px] text-center">

          <div class="mb-5 hidden md:inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4ade80]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Request received</span>
          </div>

          <h1 class="font-sans text-[2.5rem] font-semibold leading-[1.1] tracking-[-0.04em] text-[#292524] md:text-[3rem]">
            Pick a Time That<br />
            <span style="color:#4f39f6;">Works for You.</span>
          </h1>

          <p class="mx-auto mt-5 max-w-[500px] font-sans text-[1.05rem] leading-[1.75] text-[#57534e] hidden md:block">
            We've got your details. Choose a slot that works and we'll come prepared — with a real audit of your site, not a generic slide deck.
          </p>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#a8a29e]">30 minutes · Free · No commitment</p>
        </div>

        <!-- Calendar card -->
        <div class="relative mx-auto mt-12 rounded-2xl border border-[#e7e5e4] bg-white shadow-[0_8px_40px_rgba(79,57,246,0.06)]" style="max-width:1080px;" id="calendar">
          <div style="width:100%;min-height:700px;overflow:auto" id="my-cal-inline-30min"></div>
        </div>
      </div>
    </section>


    <!-- ─── DEMO PREVIEW ─── -->
    <section class="border-t border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20" style="max-width:1280px;">
        <div class="mx-auto max-w-[800px]">

          <!-- Label -->
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6] mb-4">What happens in the call</p>

          <!-- Headline -->
          <h2 class="font-sans text-[1.75rem] md:text-[2.25rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] max-w-[620px]">
            30 minutes that could change how customers find you.
          </h2>

          <!-- Body copy -->
          <p class="mt-5 font-sans text-[1rem] leading-[1.8] text-[#57534e] max-w-[600px]">
            We'll show you how your website can rank on Google <em>and</em> appear in AI search results — ChatGPT, Perplexity, Gemini — automatically, without writers or an agency. Most businesses we speak to are losing customers to competitors who simply show up first.
          </p>
          <p class="mt-3 font-sans text-[1rem] leading-[1.8] text-[#57534e] max-w-[600px]">
            Come see if theStacc fixes that for you.
          </p>

          <!-- Three points -->
          <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-3">

            <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
              <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-xl bg-[#ede9fe]">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <circle cx="9" cy="9" r="7.5" stroke="#4f39f6" stroke-width="1.5"/>
                  <path d="M6 9l2 2 4-4" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <p class="font-sans text-[14px] font-semibold text-[#292524] leading-snug">Your Google ranking gaps</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.7] text-[#79716b]">We pull a live snapshot of where you rank vs. competitors for your most valuable keywords.</p>
            </div>

            <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
              <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-xl bg-[#ede9fe]">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <rect x="2" y="3" width="14" height="12" rx="2" stroke="#4f39f6" stroke-width="1.5"/>
                  <path d="M5 7h8M5 10.5h5" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </div>
              <p class="font-sans text-[14px] font-semibold text-[#292524] leading-snug">AI search visibility</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.7] text-[#79716b]">See exactly how (and whether) you appear in ChatGPT, Perplexity, and Gemini answers today.</p>
            </div>

            <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
              <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-xl bg-[#ede9fe]">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M3 14l4-5 3 3 3-4 3 4" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="14" cy="5" r="2" stroke="#4f39f6" stroke-width="1.5"/>
                </svg>
              </div>
              <p class="font-sans text-[14px] font-semibold text-[#292524] leading-snug">A fix, not a pitch</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.7] text-[#79716b]">We come with an actual audit of your site — specific pages, specific issues, and what theStacc would do about them.</p>
            </div>

          </div>
        </div>
      </div>
    </section>


    <!-- ─── REASSURANCE ─── -->
    <section class="border-t border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-14">
        <div class="mx-auto max-w-4xl grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
            <p class="font-sans text-[13px] font-semibold text-[#292524]">Questions before the call?</p>
            <p class="mt-1 font-sans text-[13px] leading-[1.7] text-[#79716b]">
              Email us at <a href="mailto:sidgangal@gmail.com" class="text-[#4f39f6] hover:underline">sidgangal@gmail.com</a> — we respond within one business day.
            </p>
          </div>
          <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
            <p class="font-sans text-[13px] font-semibold text-[#292524]">Need to reschedule?</p>
            <p class="mt-1 font-sans text-[13px] leading-[1.7] text-[#79716b]">
              No problem. Use the confirmation email from Cal.com to pick a different time — no friction, no forms.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── BOTTOM CTA ─── -->
    <section class="border-t border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20" style="max-width:1280px;">
        <div class="mx-auto max-w-[640px] text-center">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6] mb-4">Still here?</p>
          <h2 class="font-sans text-[1.75rem] md:text-[2.25rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524]">
            Your competitors aren't waiting.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-[1.8] text-[#57534e] max-w-[480px] mx-auto">
            Pick a slot above and we'll show you exactly where you're losing ground — and how to take it back.
          </p>
          <a
            href="#calendar"
            onclick="document.getElementById('calendar').scrollIntoView({behavior:'smooth'});return false;"
            class="mt-8 inline-flex items-center gap-2 rounded-xl px-6 py-3.5 font-sans text-[15px] font-semibold text-white transition-colors"
            style="background:#4f39f6;"
            onmouseover="this.style.background='#615fff'"
            onmouseout="this.style.background='#4f39f6'"
          >
            Book your free call
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <!-- Cal inline embed code begins -->
  <script type="text/javascript" is:inline>
    (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", "30min", {origin:"https://app.cal.com"});

    Cal.ns["30min"]("inline", {
      elementOrSelector:"#my-cal-inline-30min",
      config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true"},
      calLink: "thestacc-demo/30min",
    });

    Cal.ns["30min"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});
  </script>
  <!-- Cal inline embed code ends -->
</BaseLayout>
