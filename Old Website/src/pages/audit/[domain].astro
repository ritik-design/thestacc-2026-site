---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

// Extract domain from URL
const domain = Astro.params.domain || '';
const normalizedDomain = domain.replace(/^https?:\/\//, '').replace(/\/+$/, '');
const url = `https://${normalizedDomain}`;
---

<BaseLayout
  title={`SEO Audit Report for ${normalizedDomain} | theStacc`}
  description={`Free SEO audit results for ${normalizedDomain}. Check technical SEO, on-page optimization, content quality, and performance.`}
  noindex={true}
>
  <Header />

  <main class="flex-1">
    <!-- Hero: Audit Report Header -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.45) 0%, transparent 62%);"></div>

      <div class="container-x relative z-10 pt-8 pb-10">
        <nav aria-label="Breadcrumb">
          <ol class="flex items-center gap-1.5 font-mono text-[11px] text-white/30">
            <li><a href="/" class="hover:text-white/60 transition-colors">Home</a></li>
            <li class="before:content-['/'] before:mx-1.5"><a href="/tools/" class="hover:text-white/60 transition-colors">Tools</a></li>
            <li class="before:content-['/'] before:mx-1.5 text-white/50">Audit</li>
          </ol>
        </nav>

        <div class="mt-6 max-w-[600px]">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#818cf8]">Free SEO Audit</p>
          <h1 class="mt-3 font-sans text-[28px] font-bold leading-[1.15] tracking-[-0.03em] text-white md:text-[36px]">
            Audit Report for <span class="text-[#818cf8]">{normalizedDomain}</span>
          </h1>
          <p class="mt-3 font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
            Comprehensive analysis across 7 SEO categories. Score, priorities, and actionable fixes.
          </p>
        </div>
      </div>
    </section>

    <!-- Audit Results -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-3xl">
        <!-- Loading State -->
        <div id="loading-section" class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <div class="space-y-3">
            <div class="flex items-center gap-3" data-step="fetch">
              <span class="step-icon w-5 h-5 text-[#79716b]">
                <svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
              </span>
              <span class="text-[14px] text-[#57534e]">Fetching website...</span>
            </div>
            <div class="flex items-center gap-3" data-step="analyze">
              <span class="step-icon w-5 h-5 text-[#79716b]">
                <svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
              </span>
              <span class="text-[14px] text-[#57534e]">Analyzing SEO signals...</span>
            </div>
            <div class="flex items-center gap-3" data-step="score">
              <span class="step-icon w-5 h-5 text-[#79716b]">
                <svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
              </span>
              <span class="text-[14px] text-[#57534e]">Calculating final score...</span>
            </div>
          </div>
        </div>

        <!-- Error State -->
        <div id="error-section" class="hidden mt-6 rounded-2xl border border-red-200 bg-red-50 p-6 text-center">
          <svg class="mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
          <p class="text-[15px] text-red-700 font-medium">Something went wrong</p>
          <p id="error-message" class="mt-1 text-[13px] text-red-600">Check the URL and try again.</p>
          <a href="/tools/seo-audit/" class="mt-4 inline-flex h-10 items-center gap-2 rounded-lg bg-[#4f39f6] px-5 font-sans text-[13px] font-semibold text-white hover:bg-[#615fff]">Run a new audit</a>
        </div>

        <!-- Results -->
        <div id="results-section" class="hidden space-y-6">
          <!-- Score Gauge -->
          <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
            <div id="score-gauge"></div>
          </div>

          <!-- Partial Preview -->
          <div id="partial-preview"></div>

          <!-- Lead Capture Gate -->
          <div id="lead-gate-section" class="hidden rounded-2xl border-2 border-[#4f39f6] bg-white p-6 md:p-8">
            <div class="text-center mb-6">
              <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-[#f5f3ff]">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              </div>
              <h3 class="font-sans text-[20px] font-bold text-[#292524]">Unlock Your Full Report</h3>
              <p class="mt-2 font-sans text-[14px] text-[#57534e] max-w-md mx-auto">Enter your details to see the complete audit with all category scores, detailed fixes, and personalized recommendations.</p>
            </div>
            <form id="lead-form" class="max-w-md mx-auto space-y-4">
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block font-sans text-[12px] font-semibold text-[#374151] mb-1">First name <span class="text-red-500">*</span></label>
                  <input name="first_name" type="text" required class="h-11 w-full rounded-xl border border-[#e7e5e4] px-4 font-sans text-[14px] outline-none focus:border-[#4f39f6]" placeholder="Jane" />
                </div>
                <div>
                  <label class="block font-sans text-[12px] font-semibold text-[#374151] mb-1">Last name <span class="text-red-500">*</span></label>
                  <input name="last_name" type="text" required class="h-11 w-full rounded-xl border border-[#e7e5e4] px-4 font-sans text-[14px] outline-none focus:border-[#4f39f6]" placeholder="Smith" />
                </div>
              </div>
              <div>
                <label class="block font-sans text-[12px] font-semibold text-[#374151] mb-1">Work email <span class="text-red-500">*</span></label>
                <input name="email" type="email" required class="h-11 w-full rounded-xl border border-[#e7e5e4] px-4 font-sans text-[14px] outline-none focus:border-[#4f39f6]" placeholder="jane@company.com" />
              </div>
              <div>
                <label class="block font-sans text-[12px] font-semibold text-[#374151] mb-1">Phone <span class="text-red-500">*</span></label>
                <input name="phone" type="tel" required class="h-11 w-full rounded-xl border border-[#e7e5e4] px-4 font-sans text-[14px] outline-none focus:border-[#4f39f6]" placeholder="+1 (555) 000-0000" />
              </div>
              <button type="submit" id="lead-submit" class="mt-2 w-full h-12 rounded-xl bg-[#4f39f6] font-sans text-[15px] font-semibold text-white hover:bg-[#615fff] transition-colors">
                Unlock Full Report
              </button>
              <p class="text-center font-mono text-[10px] text-[#a8a29e]">No spam. Unsubscribe anytime.</p>
            </form>
          </div>

          <!-- Full Report (post-unlock) -->
          <div id="full-report-section" class="hidden space-y-6">
            <div id="categories-section" class="space-y-3"></div>
            <div id="priorities-section" class="hidden"></div>
            <div id="pagespeed-section" class="hidden"></div>
            <div id="serp-preview" class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
              <h3 class="font-sans text-[17px] font-semibold text-[#292524] mb-4">Google Search Preview</h3>
              <div id="serp-preview-content"></div>
            </div>
            <div id="stacc-recommendations" class="hidden"></div>
          </div>
        </div>

        <!-- Share Link -->
        <div id="share-link" class="mt-6"></div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section id="cta-banner" class="hidden relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.45) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <div class="mx-auto max-w-lg">
          <p id="cta-headline" class="font-sans text-[22px] font-bold leading-tight text-white"></p>
          <p id="cta-subtext" class="mt-3 font-sans text-[15px] leading-relaxed text-[#94a3b8]"></p>
          <a href="/demo/" class="mt-6 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white hover:bg-[#4f39f6]">
            Start Your $1 Trial &rarr;
          </a>
          <p class="mt-3 font-mono text-xs text-[#64748b]">$1 for 3 days &middot; Cancel anytime</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline src="/js/audit-engine.js"></script>
  <script>
    (function() {
      const domain = '{normalizedDomain}';
      if (domain && window.auditEngine) {
        window.auditEngine.start(domain);
      }
    })();
  </script>
</BaseLayout>
