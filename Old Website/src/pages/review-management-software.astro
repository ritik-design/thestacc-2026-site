---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  {
    q: "What is review management software?",
    a: "Review management software monitors your business reviews across platforms like Google, Facebook, and Yelp — alerting you instantly when new reviews appear, tracking your rating trends over time, and helping you respond faster. Stacc centralizes all reviews in one dashboard so you never miss one.",
  },
  {
    q: "How does Stacc monitor reviews?",
    a: "Stacc connects directly to your Google Business Profile, Facebook page, and Yelp listing. When a new review is posted on any platform, Stacc detects it within minutes and sends you an instant alert. You see the review in your central dashboard without logging into each platform separately.",
  },
  {
    q: "Can Stacc help me get more reviews?",
    a: "Yes. Stacc includes review request automation — you can set up automated follow-up sequences that ask satisfied customers to leave a review. The timing and messaging are customizable. Businesses using Stacc's review request feature average 0.4 stars higher rating over 90 days.",
  },
  {
    q: "How important are reviews for local SEO rankings?",
    a: "Reviews are the #2 ranking factor for the Google local pack — second only to GBP relevance. Review quantity, recency, and average rating all directly influence where you appear in Maps and local search results. A business with 200 recent 4.8-star reviews consistently outranks one with 20 older reviews.",
  },
  {
    q: "Does Stacc work for businesses with multiple locations?",
    a: "Yes. Each location has its own review monitoring dashboard. You can see reviews by location, compare ratings across locations, and get alerts specific to each one. For franchise and multi-location businesses, this is essential — you know what's happening at each location without logging in separately.",
  },
  {
    q: "How fast does Stacc alert me to negative reviews?",
    a: "Stacc detects new reviews within minutes of posting and sends an immediate alert. For negative reviews (below your threshold rating), you can configure priority alerts via email or SMS so you're always the first to know — not the last.",
  },
  {
    q: "Can agencies use Stacc to manage client reviews?",
    a: "Yes. Agencies manage all client review profiles from one dashboard. Review data is included in Stacc's white-label monthly reports — delivered under your brand automatically. Your clients get a professional review report. You spend zero time building it.",
  },
  {
    q: "Does Stacc track review trends over time?",
    a: "Yes. Stacc tracks your rating history, review velocity, and response rate over time. You can see whether your reputation is improving or declining, how quickly you're responding to reviews, and how your review volume compares to previous periods — all in one dashboard.",
  },
  {
    q: "What platforms does Stacc monitor for reviews?",
    a: "Stacc monitors Google Business Profile, Facebook, and Yelp — covering the vast majority of local reviews that influence local search rankings. Industry-specific directories are also supported for relevant business categories.",
  },
  {
    q: "What does review management cost with Stacc?",
    a: "Review monitoring is included in the Local SEO module at $49/month. You also get rank tracking, citation management, GBP posting, and automated reporting — all for the same $49. No per-platform fees, no per-location upcharges.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Review Management Software",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Monitor reviews across Google, Facebook, and Yelp in one dashboard. Get instant alerts, respond faster, and track reputation trends automatically.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Local SEO module including review management — $1 for 3 days"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Review Management Software", "item": "https://thestacc.com/review-management-software/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Review Management Software — Monitor, Respond & Grow Reviews | theStacc"
  description="Monitor reviews across Google, Facebook, and Yelp in one dashboard. Get instant alerts, respond faster, and track reputation trends automatically."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Review Management Software · From $49/month</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stop finding out about bad reviews<br />
            <span style="color:#4f39f6;">from the customer who already left.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Reviews are the #2 local ranking factor. Most businesses find out about negative ones days too late. Stacc monitors Google, Facebook, and Yelp in real time — one dashboard, instant alerts, zero manual checking.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start monitoring reviews free
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $1 for 3 days · No credit card · Cancel anytime
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Google, Facebook, Yelp monitored</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Alerts within minutes</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN NARRATIVE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The review problem most businesses ignore</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            You're not responding to reviews.<br />You're reacting to them — days too late.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              You're the person who logs into Google Business Profile once a week — maybe once a month — and discovers a 2-star review from three days ago that you had no idea was there. By the time you respond, the customer has moved on. The damage is done. The next 20 people who searched for your business saw that review sitting there, unanswered, signaling to them that you don't care.
            </p>
            <p>
              Reviews are the #2 ranking factor for the local pack. Review quantity, recency, velocity, and your response rate all feed directly into where Google places you in Maps results. The businesses that dominate local search aren't just getting more reviews — they're responding to them within hours, which signals engagement to Google and trust to potential customers.
            </p>
            <p>
              The math is simple. A business that responds to reviews within 2 hours looks like a business that's paying attention. A business that responds in 3 days — if it responds at all — looks like one that isn't. Your reputation is being decided right now in reviews you haven't read yet. Stacc makes sure you're always the first to know.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does for reviews</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Monitor. Alert. Track. Report.<br />One dashboard for every platform.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            {
              title: 'Real-Time Monitoring',
              icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
              features: ['Google, Facebook, Yelp monitored', 'Alerts within minutes of posting', 'Priority alerts for negative reviews', 'Multi-location monitoring in one view'],
              href: '/modules/local-seo/',
            },
            {
              title: 'Reputation Tracking',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              features: ['Rating trend history', 'Review velocity tracking', 'Response rate measurement', 'Competitor rating benchmarking'],
              href: '/features/rank-tracking/',
            },
            {
              title: 'Automated Reporting',
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              features: ['Monthly review report included', 'White-label delivery for agencies', 'Rating trends in client reports', 'Zero manual report building'],
              href: '/solutions/agencies/',
            },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Learn more</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How Stacc manages reviews</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every review seen. Every trend tracked.<br />Every client report automated.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Alert -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Instant Review Alerts</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Know about every review within minutes — not days.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc monitors your Google, Facebook, and Yelp profiles continuously. The moment a new review appears, you get an alert. For negative reviews below your threshold rating, you get a priority alert — email or SMS — so you can respond before the situation compounds. Businesses using Stacc respond 73% faster on average than those checking manually.
              </p>
              <a href="/modules/local-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See the Local SEO module
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Recent review alerts</p>
              {[
                { platform: 'Google', rating: '⭐⭐⭐⭐⭐', preview: '"Amazing service, highly recommend"', time: '12 min ago', type: 'positive' },
                { platform: 'Yelp', rating: '⭐⭐', preview: '"Wait time was too long"', time: '2 hrs ago', type: 'negative' },
                { platform: 'Facebook', rating: '⭐⭐⭐⭐⭐', preview: '"Best in town, will be back"', time: '5 hrs ago', type: 'positive' },
              ].map(r => (
                <div class={`rounded-xl p-3 mb-3 border ${r.type === 'negative' ? 'border-[#fecaca] bg-[#fef2f2]' : 'border-[#e7e5e4] bg-[#fafaf9]'}`}>
                  <div class="flex items-center justify-between mb-1">
                    <span class="font-mono text-[11px] font-semibold text-[#374151]">{r.platform}</span>
                    <span class="font-mono text-[10px] text-[#79716b]">{r.time}</span>
                  </div>
                  <p class="font-sans text-[11px] text-[#57534e]">{r.rating} {r.preview}</p>
                  {r.type === 'negative' && <p class="mt-1 font-mono text-[10px] font-semibold text-[#dc2626]">⚠ Priority alert sent</p>}
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">All platforms · Real-time monitoring</p>
            </div>
          </div>

          <!-- Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Reputation score — 90 days</p>
              <div class="flex items-end gap-1 h-24 mb-4">
                {[3.8, 3.9, 4.0, 4.1, 4.0, 4.1, 4.2, 4.3, 4.4, 4.4, 4.5, 4.6].map((v, i) => (
                  <div class="flex-1 rounded-t" style={`height:${((v-3.5)/1.5)*100}%;background:${i >= 9 ? '#4f39f6' : '#e7e5e4'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">90 days ago: 3.8 ★</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">Today: 4.6 ★</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">+0.8 stars in 90 days · Google Business Profile</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rating Trend Tracking</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                See whether your reputation is improving or eroding — automatically.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc tracks your star rating, review count, and response rate over time across every platform. You can see at a glance whether you're trending up or down, which platforms need attention, and how quickly your team is responding. For agencies, this data rolls up into client reports automatically — showing clients the value you're delivering without building a single slide.
              </p>
              <a href="/features/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See all tracking features
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Review Reporting for Agencies</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Review data in your client reports. Delivered automatically. Under your brand.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc's white-label monthly reports include review data automatically — new reviews received, rating trends, response rate, and platform breakdown. Your clients see exactly how their reputation is performing without you spending time on it. Set the template once. Reports deliver themselves every month, branded as yours.
              </p>
              <a href="/solutions/agencies/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See Stacc for agencies
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Your Agency</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Monthly Reputation Report</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Sent</span>
              </div>
              {[
                { label: 'New reviews this month', val: '14 reviews' },
                { label: 'Average rating', val: '4.6 ★ (+0.2)' },
                { label: 'Response rate', val: '94%' },
                { label: 'Platforms monitored', val: 'Google · Facebook · Yelp' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Auto-generated · Delivered under your brand</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#0d1117]/10" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Review management results</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What real-time review monitoring<br />does for your business.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(15,23,42,0.04);">
          {[
            { value: '73%', num: 73, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Faster review response time', sub: 'vs businesses checking manually once a week' },
            { value: '0.4★', num: 0.4, prefix: '', suffix: '★', decimals: 1, from: 0, label: 'Average rating improvement', sub: 'within 90 days of using Stacc review management' },
            { value: '4.2hrs', num: 4.2, prefix: '', suffix: 'hrs', decimals: 1, from: 0, label: 'Saved per week per location', sub: 'on manual review checking across platforms' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/80">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
