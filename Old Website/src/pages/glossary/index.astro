---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { getCollection } from 'astro:content';

const terms = await getCollection('glossary');
const sortedTerms = terms.sort((a, b) => a.data.term.localeCompare(b.data.term));

// Group by first letter
const letterGroups: Record<string, typeof sortedTerms> = {};
for (const term of sortedTerms) {
  const firstChar = term.data.term[0].toUpperCase();
  const letter = /[A-Z]/.test(firstChar) ? firstChar : '#';
  if (!letterGroups[letter]) letterGroups[letter] = [];
  letterGroups[letter].push(term);
}

const alphabet = '#ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const activeLetters = new Set(Object.keys(letterGroups));

// Category counts
const categories = ['All', 'Marketing', 'SEO', 'Local SEO', 'Social Media', 'AI & Emerging'];
const categoryCounts: Record<string, number> = { All: sortedTerms.length };
for (const term of sortedTerms) {
  categoryCounts[term.data.category] = (categoryCounts[term.data.category] || 0) + 1;
}

// Category color map
const categoryColors: Record<string, string> = {
  'Marketing': '#4f39f6',
  'SEO': '#16a34a',
  'Local SEO': '#ea580c',
  'Social Media': '#db2777',
  'AI & Emerging': '#7c3aed',
};

// JSON-LD schema
const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTermSet',
      '@id': 'https://thestacc.com/glossary/',
      name: 'Marketing & SEO Glossary',
      description: `Comprehensive glossary of ${sortedTerms.length}+ marketing, SEO, local SEO, social media, and AI terms with definitions, examples, and expert insights.`,
      url: 'https://thestacc.com/glossary/',
      inLanguage: 'en',
      publisher: { '@id': 'https://thestacc.com/#organization' },
      hasDefinedTerm: sortedTerms.map((t) => ({
        '@type': 'DefinedTerm',
        name: t.data.term,
        description: t.data.definition,
        url: `https://thestacc.com/glossary/${t.data.slug}`,
        inDefinedTermSet: 'https://thestacc.com/glossary/',
      })),
    },
    {
      '@type': 'WebPage',
      '@id': 'https://thestacc.com/glossary/#webpage',
      name: `Marketing & SEO Glossary: ${sortedTerms.length}+ Terms Defined`,
      description: `The complete glossary of marketing, SEO, local SEO, social media, and AI terms.`,
      url: 'https://thestacc.com/glossary/',
      isPartOf: { '@id': 'https://thestacc.com/#website' },
      about: { '@id': 'https://thestacc.com/glossary/' },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://thestacc.com/glossary/#breadcrumb',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://thestacc.com' },
        { '@type': 'ListItem', position: 2, name: 'Glossary', item: 'https://thestacc.com/glossary/' },
      ],
    },
    {
      '@type': 'Organization',
      '@id': 'https://thestacc.com/#organization',
      name: 'theStacc',
      url: 'https://thestacc.com',
      logo: { '@type': 'ImageObject', url: 'https://thestacc.com/stacc-logo.svg' },
      sameAs: ['https://www.linkedin.com/company/thestacc', 'https://x.com/thestacc'],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://thestacc.com/#website',
      name: 'theStacc',
      url: 'https://thestacc.com',
      publisher: { '@id': 'https://thestacc.com/#organization' },
    },
  ],
};
---

<BaseLayout
  title={`Marketing & SEO Glossary: ${sortedTerms.length}+ Terms Defined | theStacc`}
  description={`The complete glossary of marketing, SEO, local SEO, social media, and AI terms. ${sortedTerms.length}+ definitions with examples, visuals, and expert insights. Updated for 2026.`}
>
  <Header />
  <main class="flex-1">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>

      <div class="container-x relative z-10 pt-8 pb-12">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb">
          <ol class="flex items-center gap-1.5 font-mono text-[11px] text-[#a8a29e]">
            <li><a href="/" class="hover:text-[#57534e] transition-colors">Home</a></li>
            <li class="before:content-['/'] before:mx-1.5 text-[#79716b]">Glossary</li>
          </ol>
        </nav>

        <div class="mt-6 max-w-[640px]">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reference</p>
          <h1 class="mt-3 font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[40px]">
            Marketing & SEO Glossary
          </h1>
          <p class="mt-3 font-sans text-[16px] leading-[1.7] text-[#57534e]">
            Every marketing, SEO, local SEO, social media, and AI term you need to know. Defined, explained, and kept current.
          </p>
          <!-- Stat pills -->
          <div class="mt-5 flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              {sortedTerms.length} Terms
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              5 Categories
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Updated 2026
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ░░ STICKY CONTROLS ░░ -->
    <div id="glossary-controls" class="sticky top-0 z-30 border-b border-[#e7e5e4] bg-white/95 backdrop-blur-sm">
      <div class="mx-auto max-w-[80rem] px-6 py-4">
        <!-- Search Bar -->
        <div class="relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-[#79716b]" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input
            id="glossary-search"
            type="search"
            placeholder="Search {sortedTerms.length} terms..."
            class="w-full rounded-xl border border-[#e7e5e4] bg-[#fafaf9] py-2.5 pl-10 pr-20 font-sans text-[15px] text-[#292524] outline-none transition-colors focus:border-[#4f39f6] focus:bg-white placeholder:text-[#79716b]"
            autocomplete="off"
          />
          <span id="glossary-count" class="absolute right-3.5 top-1/2 -translate-y-1/2 font-mono text-[11px] text-[#79716b]">{sortedTerms.length} terms</span>
        </div>

        <!-- Category Filters -->
        <div class="mt-3 flex flex-wrap gap-1.5">
          {categories.map((cat) => (
            <button
              data-category={cat}
              class={`glossary-cat-btn rounded-lg px-3 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] border transition-colors ${cat === 'All' ? 'bg-[#4f39f6] text-white border-[#4f39f6]' : 'bg-white text-[#57534e] border-[#e7e5e4] hover:border-[#4f39f6] hover:text-[#4f39f6]'}`}
            >
              {cat} <span class="font-normal opacity-70 ml-0.5">{categoryCounts[cat] || 0}</span>
            </button>
          ))}
        </div>

        <!-- Alphabet Navigation -->
        <nav class="mt-3 flex flex-wrap gap-0.5" aria-label="Glossary alphabetical navigation">
          {alphabet.map((letter) => (
            <a
              href={activeLetters.has(letter) ? `#letter-${letter}` : undefined}
              class={`glossary-letter-link inline-flex items-center justify-center w-7 h-7 rounded-md font-mono text-[11px] font-semibold transition-colors ${activeLetters.has(letter) ? 'text-[#292524] hover:bg-[#f5f3ff] hover:text-[#4f39f6] cursor-pointer' : 'text-[#d6d3d1] cursor-default'}`}
              aria-label={activeLetters.has(letter) ? `Jump to terms starting with ${letter}` : `No terms starting with ${letter}`}
              data-letter={letter}
            >
              {letter}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- ░░ TERM GRID ░░ -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-[80rem]">
        {alphabet.map((letter) => {
          const group = letterGroups[letter];
          if (!group || group.length === 0) return null;
          return (
            <div id={`letter-${letter}`} class="glossary-letter-section mb-10 scroll-mt-[200px]" data-letter={letter}>
              <!-- Letter header -->
              <div class="mb-4 flex items-center gap-3">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-[#4f39f6] font-mono text-[15px] font-bold text-white">{letter}</span>
                <div class="h-px flex-1 bg-[#e7e5e4]"></div>
                <span class="font-mono text-[11px] text-[#79716b]">{group.length} {group.length === 1 ? 'term' : 'terms'}</span>
              </div>
              <!-- Cards grid -->
              <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
                {group.map((term) => (
                  <a
                    href={`/glossary/${term.data.slug}/`}
                    class="glossary-term-card group block rounded-xl border border-[#e7e5e4] bg-white px-4 py-3.5 transition-all hover:border-[#c4b5fd] hover:shadow-sm"
                    data-term={term.data.term.toLowerCase()}
                    data-category={term.data.category}
                    data-definition={term.data.definition.toLowerCase()}
                  >
                    <div class="flex items-start justify-between gap-2">
                      <h3 class="font-sans text-[14px] font-semibold leading-[20px] text-[#292524] transition-colors group-hover:text-[#4f39f6]">{term.data.term}</h3>
                      <span
                        class="shrink-0 rounded-md px-1.5 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.06em]"
                        style={`color: ${categoryColors[term.data.category] || '#57534e'}; background: ${categoryColors[term.data.category] || '#57534e'}18;`}
                      >{term.data.category}</span>
                    </div>
                    <p class="mt-1.5 line-clamp-2 font-sans text-[12px] leading-[18px] text-[#79716b]">{term.data.definition}</p>
                  </a>
                ))}
              </div>
            </div>
          );
        })}

        <!-- Empty state for search -->
        <div id="glossary-empty" class="hidden py-20 text-center">
          <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#f5f3ff]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <p class="font-sans text-[15px] font-medium text-[#292524]">No terms found</p>
          <p class="mt-1 font-sans text-[13px] text-[#79716b]">Try a different keyword or category</p>
          <button id="glossary-clear" class="mt-4 inline-flex items-center gap-1.5 rounded-lg border border-[#4f39f6] px-4 py-2 font-mono text-[12px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6] transition-colors hover:bg-[#4f39f6] hover:text-white">
            Clear filters
          </button>
        </div>
      </div>
    </section>

    <!-- ░░ FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Ready to automate your SEO?
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          30 GBP posts, 30 blog articles, social media. All on autopilot.
        </p>
        <a
          href="/demo/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Start Your $1 Trial
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">$1 for 3 days · Cancel anytime</p>
      </div>
    </section>
  </main>
  <Footer />

  <!-- Client-side search, filter, and A-Z navigation -->
  <script>
    const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
    const countDisplay = document.getElementById('glossary-count')!;
    const emptyState = document.getElementById('glossary-empty')!;
    const clearBtn = document.getElementById('glossary-clear')!;
    const catBtns = document.querySelectorAll('.glossary-cat-btn');
    const termCards = document.querySelectorAll('.glossary-term-card') as NodeListOf<HTMLElement>;
    const letterSections = document.querySelectorAll('.glossary-letter-section') as NodeListOf<HTMLElement>;

    let activeCategory = 'All';

    function filterTerms() {
      const query = searchInput.value.toLowerCase().trim();
      let visible = 0;

      termCards.forEach((card) => {
        const term = card.dataset.term || '';
        const category = card.dataset.category || '';
        const definition = card.dataset.definition || '';
        const matchesSearch = !query || term.includes(query) || definition.includes(query);
        const matchesCategory = activeCategory === 'All' || category === activeCategory;
        const show = matchesSearch && matchesCategory;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      letterSections.forEach((section) => {
        const visibleCards = section.querySelectorAll('.glossary-term-card:not([style*="display: none"])');
        section.style.display = visibleCards.length > 0 ? '' : 'none';
      });

      countDisplay.textContent = `${visible} term${visible !== 1 ? 's' : ''}`;
      emptyState.classList.toggle('hidden', visible > 0);
    }

    function setActiveCategory(cat: string) {
      activeCategory = cat;
      catBtns.forEach((btn) => {
        const isActive = btn.getAttribute('data-category') === cat;
        btn.classList.toggle('bg-[#4f39f6]', isActive);
        btn.classList.toggle('text-white', isActive);
        btn.classList.toggle('border-[#4f39f6]', isActive);
        btn.classList.toggle('bg-white', !isActive);
        btn.classList.toggle('text-[#57534e]', !isActive);
        btn.classList.toggle('border-[#e7e5e4]', !isActive);
      });
      filterTerms();
    }

    searchInput.addEventListener('input', filterTerms);

    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      setActiveCategory('All');
    });

    catBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        setActiveCategory(btn.getAttribute('data-category') || 'All');
      });
    });
  </script>
</BaseLayout>
