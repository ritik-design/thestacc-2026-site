---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ExitIntent from '../components/common/ExitIntent.astro';
import PricingHero from '../components/sections/PricingHero.astro';
import PricingModules from '../components/sections/PricingModules.astro';
import ComparisonTabs from '../components/sections/ComparisonTabs.astro';
import GrowthGraph from '../components/sections/GrowthGraph.astro';
import FAQ from '../components/sections/FAQ.astro';
import { SITE_URL, LOGO_URL, buildBreadcrumbs } from '../utils/schema';

const pricingSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE_URL}/#software`,
      name: 'theStacc',
      description: 'AI SEO automation platform that writes and publishes blog content, manages Google Business Profiles, and automates social media for local businesses.',
      url: SITE_URL,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: [
        { '@type': 'Offer', name: 'Blog SEO', description: '30 AI-written SEO articles published to your site every month', price: '99.00', priceCurrency: 'USD', url: `${SITE_URL}/pricing/` },
        { '@type': 'Offer', name: 'Local SEO', description: 'Google Business Profile optimization and management', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/pricing/` },
        { '@type': 'Offer', name: 'Social Media', description: 'Automated social media posting and distribution', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/pricing/` },
        { '@type': 'Offer', name: 'Bundle (All Modules)', description: 'Blog SEO + Local SEO + Social Media', price: '167.00', priceCurrency: 'USD', url: `${SITE_URL}/pricing/` },
      ],
      provider: { '@id': `${SITE_URL}/#organization` },
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/pricing/`,
      name: 'Pricing | theStacc | Pick Your Modules, Start Growing',
      description: 'Build your marketing stack. Blog SEO, Local SEO, and Social Media modules. Start with one or bundle all three.',
      url: `${SITE_URL}/pricing/`,
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(`${SITE_URL}/pricing/`, [
      { name: 'Home', url: SITE_URL },
      { name: 'Pricing', url: `${SITE_URL}/pricing/` },
    ]),
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL },
    },
  ],
};

const pricingFaqs = [
  {
    question: "How long until I see results?",
    answer: "SEO compounds over time. Most businesses see meaningful ranking improvements within 3–6 months. Content starts working from day one. It just takes time for search engines to index and rank your pages.",
  },
  {
    question: "Do I need to write anything?",
    answer: "Not a single word. Stacc handles keyword research, content creation, optimization, and publishing. You can review posts before they go live, or let us auto-publish.",
  },
  {
    question: "Can I cancel anytime?",
    answer: "Absolutely. No contracts, no penalties. The content we've published keeps working for you even after you leave.",
  },
  {
    question: "What CMS platforms do you support?",
    answer: "WordPress, Webflow, Ghost, Shopify, and any platform that supports API or webhook publishing. If your CMS isn't listed, reach out. We probably support it.",
  },
  {
    question: "How does the 15% bundle discount work?",
    answer: "Select any two or more modules and the discount applies automatically. No coupon needed. The savings show up in your summary bar as you build your plan.",
  },
  {
    question: "How is this different from hiring a freelancer or agency?",
    answer: "Faster, cheaper, and more consistent. A freelancer writes when they can. An agency bills by the hour. Stacc publishes every day, automatically, at a fraction of the cost.",
  },
];
---

<BaseLayout
  title="Pricing — Plans From $49/mo · $1 Trial, No Contract | theStacc"
  description="theStacc plans from $49/month. Blog SEO ($99), Local SEO ($49), Social Media ($49) — pick one module or bundle all three at 15% off. $1 trial, cancel anytime."
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />
    <PricingHero />
    <PricingModules />
    <ComparisonTabs />
    <GrowthGraph />
    <FAQ faqs={pricingFaqs} />
    <!-- ░░ DARK FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">Pick your modules. Start growing.</h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#57534e]">Blog SEO, Local SEO, and Social Media. Start with one or bundle all three.</p>
        <a href="/demo/" class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">Book a Demo <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></a>
      </div>
    </section>
  </main>
  <Footer />
  <ExitIntent />
</BaseLayout>
