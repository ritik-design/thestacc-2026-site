          {[
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: '30 GBP posts per month', body: 'Stacc publishes 30 posts per location per month targeting local keywords. Consistent activity is one of the strongest GBP ranking signals for Maps placement.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Citation monitoring', body: 'Accurate NAP data across 50+ directories is a core Maps prominence signal. Stacc monitors for inconsistencies and flags them for correction — preventing the ranking drag from data conflicts.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Review monitoring and alerts', body: 'New reviews trigger real-time alerts. Timely review responses contribute to your GBP response rate — a Maps ranking signal. Respond directly from the dashboard without logging into GBP.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Daily Maps rank tracking', body: 'Track your local pack and Maps position for every keyword daily. See exactly where you stand each morning and catch ranking changes at day one — not day thirty.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Unauthorized listing edit protection', body: 'Third-party edits to your GBP listing are caught before they go live. Inaccurate listing data is one of the fastest ways to drop in Maps rankings — Stacc prevents it.' },
            { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Ranking trend analysis', body: '30, 60, 90-day ranking trend views per location and keyword. See the compounding effect of consistent SEO activity on Maps position over time.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
