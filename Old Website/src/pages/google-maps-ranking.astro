                {[
                  { label: 'Day 1', rank: '#8', width: 30, color: '#ef4444' },
                  { label: 'Day 30', rank: '#5', width: 52, color: '#f59e0b' },
                  { label: 'Day 60', rank: '#3', width: 72, color: '#4f39f6' },
                  { label: 'Day 90', rank: '#1', width: 100, color: '#059669' },
                ].map(row => (
                  <div class="flex items-center gap-3">
                    <span class="w-12 font-mono text-[10px] text-[#79716b]">{row.label}</span>
                    <div class="flex-1 h-5 rounded-full bg-[#f5f3ff]">
                      <div class="h-5 rounded-full transition-all" style={`width:${row.width}%;background:${row.color};opacity:0.85`}></div>
                    </div>
                    <span class="w-8 text-right font-mono text-[11px] font-bold" style={`color:${row.color}`}>{row.rank}</span>
                  </div>
                ))}
              </div>
              <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Stacc running since day 1 · 30 GBP posts/mo automated</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Citation monitor — active issues</p>
              {[
                { dir: 'Yelp', status: 'Consistent', ok: true },
                { dir: 'Apple Maps', status: 'Phone mismatch', ok: false },
                { dir: 'Foursquare', status: 'Consistent', ok: true },
                { dir: 'Bing Places', status: 'Address variation', ok: false },
                { dir: 'TripAdvisor', status: 'Consistent', ok: true },
                { dir: 'YellowPages', status: 'Consistent', ok: true },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <span class="font-sans text-[13px] text-[#374151]">{row.dir}</span>
                  <span class={`flex items-center gap-1.5 rounded-full px-2.5 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] ${row.ok ? 'bg-[#f0fdf4] text-[#059669]' : 'bg-[#fff1f2] text-[#ef4444]'}`}>
                    {row.ok ? '✓' : '!'} {row.status}
                  </span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ directories monitored · Alerts on any change</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Citation Consistency Monitor</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">NAP inconsistencies are a silent rank killer. Stacc catches them all.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Google cross-references your business data across the web. A mismatched phone number on Apple Maps or an old address on Bing Places creates data conflicts that reduce your Maps prominence score. Stacc monitors your citation accuracy across 50+ directories continuously — surfacing any inconsistency the moment it appears and letting you correct it before it affects your ranking.</p>
              <a href="/features/citation-management/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">See citation management <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Review Monitoring Feed</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Every new review, every location. Respond before it affects your score.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Review volume, recency, and response rate are all Maps ranking inputs. Stacc sends an instant alert the moment a new review appears so you can respond while it's fresh. Your review response rate — a documented prominence signal — improves automatically when you stop missing reviews. The centralized inbox shows all reviews across every location without logging into each GBP listing.</p>
              <a href="/features/review-monitoring/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">See review monitoring <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Review feed — today</p>
              {[
                { stars: 5, text: 'Fast response, great service. Will definitely return.', time: '2h ago', responded: true },
                { stars: 4, text: 'Very professional. Would recommend.', time: '5h ago', responded: true },
                { stars: 2, text: 'Had to wait 30 minutes. No one explained the delay.', time: '8h ago', responded: false },
                { stars: 5, text: 'Best in the area, hands down.', time: '1d ago', responded: true },
              ].map(rev => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center justify-between mb-1">
                    <div class="flex gap-0.5">{[1,2,3,4,5].map((s) => <svg width="10" height="10" viewBox="0 0 24 24" fill={s <= rev.stars ? '#f59e0b' : '#e7e5e4'} aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}</div>
                    <div class="flex items-center gap-2">
                      <span class="font-mono text-[10px] text-[#79716b]">{rev.time}</span>
                      <span class={`rounded-full px-2 py-0.5 font-mono text-[9px] font-bold uppercase ${rev.responded ? 'bg-[#f0fdf4] text-[#059669]' : 'bg-[#fff1f2] text-[#ef4444]'}`}>{rev.responded ? 'Responded' : 'Needs reply'}</span>
                    </div>
                  </div>
                  <p class="font-sans text-[12px] leading-relaxed text-[#57534e]">{rev.text}</p>
                </div>
              ))}
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alerts sent instantly · Respond from dashboard</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 89, suffix: '%', label: 'GBP ranking lift in 90 days', sub: 'Consistent activity vs inactive baseline' },
            { to: 30, suffix: '/mo', label: 'GBP posts per location', sub: 'Keeping every profile active daily' },
            { to: 50, suffix: '+', label: 'Citation directories monitored', sub: 'NAP consistency across the full network' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-5xl">
          <div class="mb-12 text-center">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What customers say</span>
            <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
              Businesses that moved up in<br />the local pack with Stacc.
            </h2>
          </div>
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            {[
              { name: 'Alex T.', role: 'Owner, independent auto shop', stars: 5, quote: "I was stuck at #7 for two years. Three months after starting Stacc I was in the local 3-pack for 'auto repair near me.' The GBP posting was running daily the whole time — I didn't do anything manually." },
              { name: 'Maria C.', role: 'Marketing manager, multi-location dental group', stars: 5, quote: "Two of our locations had citation issues we didn't know about — old phone numbers on Apple Maps and Bing. Stacc caught them week one. Both locations saw ranking improvements within 45 days of fixing the data." },
              { name: 'James W.', role: 'Owner, HVAC service company', stars: 5, quote: "The review response rate feature is underrated. I was responding to maybe 20% of reviews before. Now I respond to all of them the same day. My ranking for 'HVAC repair' went from outside the top 10 to position 2 over four months." },
              { name: 'Priya N.', role: 'Local SEO consultant, agency owner', stars: 5, quote: "I use Stacc for all my multi-location clients. The ranking trend reports make the ROI conversation easy — clients see the line going up week over week. The citation monitoring alone catches issues that would take me hours to find manually." },
