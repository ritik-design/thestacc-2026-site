---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const changelog = [
  {
    date: "April 2026",
    entries: [
      "Your content plan now stays in sync with your business. Changed your target audience or added a new location? Stacc detects what's stale and lets you refresh individual plans or the entire month in one click.",
      "Plan ahead. You can now generate next month's content plan while this month's posts are still publishing. Stay a full month ahead, always.",
      "Featured images, handled. Pick, swap, or remove hero images right inside the blog editor. They sync to WordPress and Webflow automatically.",
      "Cleaner blog detail page. Generate, edit, or regenerate a plan from one place. No more hunting through sidebars for the right button.",
      "Edit your blog slugs directly from the sidebar. Changes push live to WordPress, Webflow, and WordPress.com instantly.",
      "Ghost users, we see you. Publish directly to Ghost CMS with automatic credential verification.",
      "Running multiple projects? Each one now has fully independent module settings. Turning on Blog SEO for one site won't touch another.",
      "Bulk plan regeneration is 5x faster. What used to take 90 seconds now finishes in under 18.",
    ],
  },
  {
    date: "March 2026",
    entries: [
      "Social Media is here. Stacc now writes, designs, and schedules posts across Instagram, LinkedIn, X, and Facebook. Set your brand voice once and let it run on autopilot.",
      "We rebuilt the entire UI from the ground up. New design system, new icons, faster navigation. Everything feels sharper and more intentional.",
      "Review your content plan before anything gets written. Edit titles, swap keywords, change blog types — all inline, before a single article is generated.",
      "Public Blog API for developers. Grab an API key, set up deploy hooks, and pull your published content into any frontend or static site.",
      "Better team collaboration. Resend invites, track expiry, and control exactly what viewers can access across shared projects.",
      "Shopify integration. Your SEO blog content now publishes directly to your Shopify store.",
    ],
  },
  {
    date: "February 2026",
    entries: [
      "Webflow integration is live. Connect your Webflow site via OAuth and every blog post publishes directly to your CMS with live sync.",
      "Subscribe to exactly what you need. Pick Blog SEO, Local SEO, or Social Media individually — each module has its own plan and billing.",
      "Make every post yours. Set writing style preferences, image guidelines, and linking rules that apply to every article Stacc generates.",
      "Smarter onboarding. Stacc now reads your sitemap and understands your existing content before building your keyword strategy.",
    ],
  },
  {
    date: "January 2026",
    entries: [
      "Local SEO module launched. Automate Google Business Profile posts, monitor reviews with AI-written responses, track local keywords, and manage multiple locations from one dashboard.",
      "WordPress integration. One-click publishing via OAuth or App Password. Categories, tags, and featured images are handled automatically.",
      "Manage multiple websites from a single account. Each project gets its own settings, team members, and content pipeline.",
      "Live SEO scoring. Every blog gets a real-time optimization score with actionable suggestions to improve keyword density, structure, and readability.",
      "Target any location on earth. Search for your city and Stacc discovers nearby areas to expand your keyword reach.",
    ],
  },
  {
    date: "December 2025",
    entries: [
      "theStacc launched. AI-powered content plans, keyword research, blog writing, and auto-publishing — all from one platform.",
      "Smart onboarding. Enter your URL and Stacc extracts your services, finds your competitors, and maps out your first 30+ blog topics.",
      "Visual content calendar. See your entire month at a glance — track what's scheduled, generating, published, or needs attention.",
      "Brand voice and audience targeting. Define your tone and up to 6 ideal customer profiles so every article speaks to the right people.",
    ],
  },
];
---

<BaseLayout
  title="Changelog - theStacc"
  description="What's new at theStacc — product updates, new features, bug fixes, and platform improvements. Updated regularly."
  noindex={true}
>
  <Header />
  <main>
    <section class="bg-white">
      <!-- Header -->
      <div class="px-6 pt-16 pb-10 text-center">
        <p class="font-mono text-sm font-medium uppercase tracking-wide text-[#4f39f6]">Changelog</p>
        <h1 class="mt-4 font-sans text-[28px] leading-[36px] md:text-[36px] md:leading-[44px] font-normal text-[#292524]">
          What's new at theStacc
        </h1>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-base leading-relaxed text-[#79716b]">
          Product updates, new features, and improvements.
        </p>
      </div>

      <!-- Timeline -->
      <div class="mx-auto max-w-3xl px-6 pb-16">
        {changelog.map((month, mi) => (
          <div class={mi > 0 ? "mt-12" : ""}>
            <!-- Month heading -->
            <div class="flex items-center gap-4">
              <div class="h-3 w-3 shrink-0 rounded-full border-2 border-[#4f39f6] bg-white"></div>
              <h2 class="font-mono text-base font-semibold uppercase tracking-wide text-[#292524]">{month.date}</h2>
            </div>

            <!-- Entries -->
            <div class="ml-1.5 border-l border-[#e7e5e4] pl-5 md:pl-8 pt-4">
              <ul class="flex list-disc flex-col gap-3 pl-5">
                {month.entries.map((entry) => (
                  <li class="font-sans text-base leading-relaxed text-[#79716b]">{entry}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
