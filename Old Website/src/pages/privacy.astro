---
import LegalLayout from '../layouts/LegalLayout.astro';

const toc = [
  { id: 'collect',   label: '1. Information We Collect' },
  { id: 'use',       label: '2. How We Use Your Information' },
  { id: 'sharing',   label: '3. Information Sharing' },
  { id: 'security',  label: '4. Data Security' },
  { id: 'rights',    label: '5. Your Rights' },
  { id: 'cookies',   label: '6. Cookies' },
  { id: 'contact',   label: '7. Contact Us' },
];
---

<LegalLayout
  title="Privacy Policy"
  description="How theStacc collects, uses, and protects your personal information. Read our full privacy policy and GDPR compliance details."
  lastUpdated="April 2026"
  badge="Legal · Privacy"
  tocItems={toc}
  currentPath="/privacy/"
>
  <div class="flex flex-col gap-10">

    <section id="collect" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Information We Collect</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          We collect information you provide directly to us, such as when you create an account, use our services, or contact us for support. This may include your name, email address, company name, website URL, and payment information.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="use" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">How We Use Your Information</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          We use the information we collect to provide, maintain, and improve our services, process transactions, send you technical notices and support messages, and respond to your comments and questions.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="sharing" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Information Sharing</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          We do not sell, trade, or otherwise transfer your personal information to third parties without your consent, except as described in this policy or as required by law.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="security" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Data Security</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          We implement appropriate technical and organizational measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="rights" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">5</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Your Rights</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          You have the right to access, correct, or delete your personal information. You may also have the right to restrict or object to certain processing of your data. To exercise these rights, please contact us at <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="cookies" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">6</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Cookies</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          We use cookies and similar tracking technologies to collect and track information about your use of our services. You can control cookies through your browser settings or via our <a href="/cookies/" class="text-[#4f39f6] hover:underline">Cookie Policy</a>.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="contact" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">7</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Contact Us</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          <strong class="font-semibold text-[#111827]">Company:</strong> SOLARTREK VENTURES LLP<br/>
          <strong class="font-semibold text-[#111827]">Address:</strong> Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India<br/>
          <strong class="font-semibold text-[#111827]">Email:</strong> <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>
        </p>
      </div>
    </section>

  </div>
</LegalLayout>
