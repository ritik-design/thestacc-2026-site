---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  { q: "What is multi-location SEO?", a: "Multi-location SEO is the practice of optimizing a business's local search presence across multiple physical locations. It includes managing Google Business Profile listings, building consistent citations, tracking keyword rankings per location, monitoring reviews, and publishing content that targets local search intent for each location's market." },
  { q: "Why is multi-location SEO harder than single-location SEO?", a: "Because every task multiplies by location count. Ranking tracking, GBP management, citation building, review monitoring, and reporting all need to happen independently for each location. At 20+ locations, manual management becomes a full-time team effort — which is why automation is the only scalable approach." },
  { q: "What's the most important factor for ranking multiple locations in Google Maps?", a: "Consistent NAP (Name, Address, Phone) data across all directories, active Google Business Profile management including regular posts and Q&A responses, and strong review volume with recent activity are the three highest-impact factors for Maps rankings at scale." },
  { q: "How does Stacc help with multi-location SEO specifically?", a: "Stacc automates GBP post publishing, citation monitoring and correction, daily rank tracking, and review alerts across every location simultaneously. You configure each location once and the platform runs ongoing SEO tasks automatically — so ranking maintenance doesn't require daily manual work per location." },
  { q: "Can one person manage SEO for 50+ locations?", a: "With the right automation, yes. Stacc customers manage 500+ location portfolios without dedicated per-location SEO staff. The key is automating the repetitive daily work — GBP activity, citation monitoring, rank tracking, reporting — so human attention goes to strategy, not execution." },
  { q: "How long until multi-location SEO improvements show up in rankings?", a: "Citation corrections and GBP activity improvements typically show ranking movement within 4-8 weeks. Consistent posting to GBP compounds over 3-6 months. The exact timeline depends on your current baseline, competitive market, and consistency of activity." },
  { q: "What does Stacc cost for multi-location SEO?", a: "The Local SEO module starts at $49/month and covers all multi-location features including bulk management, portfolio reporting, and automation at scale." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Multi-Location SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Automate multi-location SEO across every location. Rank tracking, GBP management, citation monitoring, and reporting — all running simultaneously for your entire portfolio.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Multi-Location SEO", "item": "https://thestacc.com/multi-location-seo/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Multi-Location SEO — Automate Local SEO Across Every Location | theStacc"
  description="Multi-location SEO at scale requires automation. theStacc manages GBP, rank tracking, citations, and reporting for every location simultaneously — without adding headcount."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Multi-Location SEO · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Multi-location SEO that scales<br />
            <span style="color:#4f39f6;">without scaling your team.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Local SEO for 50 locations requires the same daily work as local SEO for 1 — multiplied by 50. Stacc automates every task across every location so the work doesn't multiply with your location count.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/local-seo-software/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See the platform
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">500+ location portfolios managed</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Setup in under 5 minutes</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The math that breaks multi-location SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every location needs the same work.<br />Most teams can only do a few.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>For a single location, local SEO is manageable: update the GBP listing, fix citations when they drift, respond to reviews, track a few keyword rankings. Maybe 3-4 hours a week. That's fine for one location.</p>
            <p>Now multiply by 20 locations. The work is still the same per location — it just happens 20 times. And in practice, what happens is that some locations get attention and most don't. The well-maintained locations rank. The neglected ones don't. Your portfolio performance is bounded by how many locations your team can manually manage.</p>
            <p class="font-semibold text-[#111827]">Stacc breaks this constraint. Automation handles the repetitive daily work across every location simultaneously — GBP activity, citation monitoring, rank tracking, review alerts — so your human effort goes to strategy, not execution. Your 50-location portfolio gets the same consistent care your one-location competitors give their single listing.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- CAPABILITIES -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc automates</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every multi-location SEO task.<br />Running on autopilot.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP post automation', body: '30 posts per month, per location — published automatically to keep every profile active and signaling relevance to Google\'s Maps algorithm.', href: '/features/social-scheduling/' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Daily rank tracking', body: 'Every keyword, every location, tracked daily in local pack, Maps, and organic. See ranking trends per location and identify underperformers before they slip further.', href: '/features/rank-tracking/' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Citation management', body: 'Monitor and correct citation inconsistencies across 50+ directories for every location. NAP consistency is one of the highest-impact local ranking factors.', href: '/features/citation-management/' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Review monitoring', body: 'Real-time alerts for new reviews across every location. Respond directly from the dashboard. Track review velocity and average score per location.', href: '/features/review-monitoring/' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Bulk location management', body: 'Update hours, addresses, descriptions, and categories across every location simultaneously. New location setup in 2 minutes.', href: '/features/bulk-location-management/' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Portfolio reporting', body: 'Automated reports for every location, delivered on schedule. Compare all locations in a single portfolio view. White-label for client delivery.', href: '/features/multi-location-reporting/' },
          ].map(c => (
            <a href={c.href} class="group bg-white px-7 py-8 transition-colors hover:bg-[#f5f3ff]">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">What consistent multi-location SEO automation delivers</span>
        </div>
        <div class="mx-auto mt-14 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 500, suffix: '+', label: 'Locations in one portfolio', sub: 'No per-location staff needed' },
            { to: 89, suffix: '%', label: 'GBP ranking lift in 90 days', sub: 'Consistent activity vs inactive baseline' },
            { to: 45, suffix: ' min', label: 'Average onboarding time', sub: 'From zero to first automated report' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FAQ -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Multi-location SEO:<br />common questions answered.
          </h2>
          <div class="mt-10 divide-y divide-[#e7e5e4]">
            {faqs.map((f, i) => (
              <div class="py-5">
                <button class="faq-btn flex w-full items-start justify-between gap-4 text-left" aria-expanded="false">
                  <span class="font-sans text-[1rem] font-semibold text-[#111827]">{f.q}</span>
                  <span class="mt-0.5 flex-shrink-0">
                    <svg class="faq-icon-plus h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    <svg class="faq-icon-minus hidden h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                  </span>
                </button>
                <div class="faq-answer hidden pt-3">
                  <p class="font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- INTERNAL LINKS -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Related resources</p>
        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {[
            { href: '/multi-location-seo-software/', label: 'Multi-Location SEO Software' },
            { href: '/local-seo-software/', label: 'Local SEO Software' },
            { href: '/features/bulk-location-management/', label: 'Bulk Location Management' },
            { href: '/features/multi-location-reporting/', label: 'Multi-Location Reporting' },
            { href: '/solutions/franchises/', label: 'Stacc for Franchises' },
            { href: '/solutions/agencies/', label: 'Stacc for Agencies' },
            { href: '/solutions/multi-location-businesses/', label: 'Multi-Location Businesses' },
            { href: '/local-seo-automation/', label: 'Local SEO Automation' },
          ].map(l => (
            <a href={l.href} class="flex items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 font-sans text-[13px] font-medium text-[#374151] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              {l.label}
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- CTA -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.35) 0%,transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-24 text-center">
        <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.8rem]">
          Multi-location SEO that keeps up<br />with your location count.
        </h2>
        <p class="mx-auto mt-5 max-w-[520px] font-sans text-[1rem] leading-[1.7]" style="color:#9ca3af;">Start your $1 trial today. Every location managed from day one.</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-12 items-center gap-2 rounded-xl bg-[#4f39f6] px-7 font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
            Start free — no credit card
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/pricing/" class="inline-flex h-12 items-center rounded-xl border border-white/15 bg-white/5 px-7 font-sans text-[15px] font-medium text-white/80 transition-colors hover:bg-white/10">See pricing</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      if (answer) answer.classList.toggle('hidden', expanded);
      btn.querySelector('.faq-icon-plus')?.classList.toggle('hidden', !expanded);
      btn.querySelector('.faq-icon-minus')?.classList.toggle('hidden', expanded);
    });
  });
  document.querySelectorAll<HTMLElement>('[data-count-up]').forEach(el => {
    const from = parseFloat(el.dataset.from || '0'), to = parseFloat(el.dataset.to || '0'), suffix = el.dataset.suffix || '', duration = 1800; let start: number | null = null;
    const obs = new IntersectionObserver(entries => {
      if (!entries[0].isIntersecting) return; obs.disconnect();
      const step = (ts: number) => { if (!start) start = ts; const p = Math.min((ts - start) / duration, 1); el.textContent = (from + (to - from) * (1 - Math.pow(1 - p, 3))).toFixed(0) + suffix; if (p < 1) requestAnimationFrame(step); };
      requestAnimationFrame(step);
    }, { threshold: 0.3 }); obs.observe(el);
  });
</script>
