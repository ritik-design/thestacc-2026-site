---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  {
    q: "What is local SEO automation?",
    a: "Local SEO automation is the practice of using software to handle the repetitive, time-intensive tasks that drive local search rankings — GBP post publishing, citation monitoring, review alerts, rank tracking, and report generation — without requiring manual effort each time. Instead of logging in daily to check and update things, you configure the rules once and the software executes them on an ongoing basis.",
  },
  {
    q: "What local SEO tasks does Stacc automate?",
    a: "Stacc automates GBP post publishing (30 posts/month per location), daily rank tracking across local pack and organic, real-time review monitoring and alerts, citation accuracy monitoring across 50+ directories, and white-label client report generation and delivery. These are the five highest-volume manual tasks in local SEO — and Stacc handles all of them automatically.",
  },
  {
    q: "How many hours does local SEO automation save?",
    a: "Businesses and agencies using Stacc report saving an average of 8 hours per client per month compared to managing the same work manually. For an agency with 20 clients, that's 160 hours per month — roughly one full-time employee — reclaimed without reducing quality.",
  },
  {
    q: "Does local SEO automation actually improve rankings?",
    a: "Yes, when executed consistently. Google's Maps algorithm rewards active, consistent GBP profiles and accurate citation data. The problem with manual local SEO is inconsistency — weeks pass without GBP posts, citations drift, and review responses slow down. Automation ensures the signals Google looks for are sent consistently, every day, for every location.",
  },
  {
    q: "Can Stacc automate local SEO for multiple locations at once?",
    a: "Yes. Stacc is designed for multi-location management. You can publish GBP posts to all locations simultaneously (or schedule location-specific content), track rankings for each location independently, monitor reviews across all GBPs in one feed, and generate separate or aggregate reports per location.",
  },
  {
    q: "Is local SEO automation suitable for agencies?",
    a: "Local SEO automation is especially powerful for agencies because the time savings multiply across every client. Stacc gives agencies white-label reporting (delivered under your brand), multi-client account management, and the ability to manage dozens of clients at the same level of quality that used to require a dedicated team member per 5–10 clients.",
  },
  {
    q: "Does automation replace the need for SEO strategy?",
    a: "No — automation handles execution, not strategy. You still decide which keywords to target, what services to promote, and how to position each location. Stacc then executes that strategy consistently — publishing the right content, tracking the right keywords, monitoring the right signals — so the strategy actually gets implemented rather than sitting in a doc.",
  },
  {
    q: "How long until I see results from local SEO automation?",
    a: "Most businesses see initial ranking movements within 30–60 days of consistent GBP posting and citation cleanup. Full impact typically shows within 90 days. The key driver is consistency: Stacc posts every day, monitors every day, and corrects issues every day — something manual management almost never achieves at scale.",
  },
  {
    q: "What does Stacc cost?",
    a: "The Local SEO module starts at $49/month. This includes GBP post publishing, daily rank tracking, review monitoring, citation management, and automated reporting. Start with $1 for 3 days — no credit card required.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Local SEO Automation",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Local SEO automation platform that handles rank tracking, citation syncing, review monitoring, and GBP posting automatically — saving 8 hours per client per week.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Local SEO module — $1 for 3 days"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Local SEO Automation", "item": "https://thestacc.com/local-seo-automation/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Local SEO Automation — Automate Rankings, Citations & Reviews | theStacc"
  description="Automate the daily work of local SEO. theStacc handles rank tracking, citation syncing, review monitoring, and GBP posting automatically — 8 hours saved per week."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex flex-wrap items-center justify-center gap-3">
            {['Fully automated', '8hrs saved/month', 'GBP + citations + reviews', 'No credit card', '$49/month'].map(chip => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>{chip}
              </span>
            ))}
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Local SEO automation that<br />runs without you.
            <span style="color:#4f39f6;"> Every day. Every location.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Manual local SEO is a full-time job you're doing part-time. Stacc automates the daily execution work — GBP posting, rank monitoring, citation sync, review alerts, and client reports — so you spend time on strategy, not spreadsheets.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start automating for $1
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See what's automated
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No credit card to start · Cancel anytime
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ agencies using Stacc</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Setup in under 5 minutes</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Why manual local SEO doesn't scale</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Local SEO is a daily job.<br />You're doing it monthly.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Google's local algorithm isn't judging you monthly. It's watching every day. Is your GBP posting consistently? Are your citations matching across directories? Are you responding to reviews quickly? Is your ranking holding in the local pack? These aren't monthly audit questions — they're daily operating conditions. And if you're managing them manually, you're missing most of them most of the time.
            </p>
            <p>
              The agencies and businesses that rank at the top of Google Maps aren't logging in every morning to check their GBP and post manually. <strong class="text-[#111827]">They automated it.</strong> They built a system that executes the daily SEO work without requiring anyone to do it. Consistency — not genius — is what drives local rankings. And consistency at scale is only possible with automation.
            </p>
            <p>
              Think about what you're actually spending time on: checking rankings that could alert you automatically, writing GBP posts that software can generate, building reports that should deliver themselves, monitoring review platforms one tab at a time. Add it up across 10 clients and you're looking at 80+ hours of manual work per month that shouldn't be manual at all.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc was built to replace that 80 hours with one automated system. You set the strategy. Stacc handles execution — every day, for every location, without anyone on your team touching it.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc automates</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every local SEO task that's been<br />eating your team's time.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'Local SEO', price: '$49/mo', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['GBP post publishing — 30/month', 'Daily rank tracking — local pack + organic', 'Review monitoring — real-time alerts', 'Citation management — 50+ directories'], href: '/modules/local-seo/' },
            { title: 'Blog SEO', price: '$99/mo', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 SEO blog posts/month', 'Published directly to your site', 'Keyword research included', 'Internal linking optimized'], href: '/modules/content-seo/' },
            { title: 'Social Media', price: '$49/mo', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Daily posts with images', 'Instagram, LinkedIn, Facebook, X', 'Written and scheduled automatically', 'Brand-consistent content'], href: '/modules/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Learn more</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automation in detail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            What Stacc is doing<br />while you're focused elsewhere.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP Automation -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP Post Automation</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 Google Business Profile posts per month. Written and published automatically.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google's local algorithm actively scores GBP activity. Businesses that post consistently earn higher local pack positions — and businesses that go silent drop. Stacc generates 30 location-specific posts per month targeting your service + city keyword combinations, seasonal topics, and high-intent searches. They publish on schedule. Your profile stays active every single day without anyone on your team logging in.
              </p>
              <a href="/modules/local-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See GBP automation
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Automation activity log</p>
              {[
                { time: '7:02 AM', action: 'GBP post published', loc: 'Austin location', ok: true },
                { time: '7:02 AM', action: 'GBP post published', loc: 'Dallas location', ok: true },
                { time: '6:45 AM', action: 'Rank check completed', loc: '14 keywords tracked', ok: true },
                { time: '6:30 AM', action: 'Citation audit run', loc: '50 directories checked', ok: true },
                { time: '2:14 AM', action: 'New review alert', loc: '5-star review received', ok: true },
              ].map(log => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <span class="font-mono text-[10px] text-[#79716b] shrink-0 mt-0.5">{log.time}</span>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{log.action}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{log.loc}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">All automated · Zero manual triggers</p>
            </div>
          </div>

          <!-- Review Monitoring -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Review monitoring — all locations</p>
              {[
                { stars: 5, text: '"Incredible service. Best plumber in Austin."', platform: 'Google', time: '2h ago', alerted: true },
                { stars: 5, text: '"Fast response, fair price. Highly recommend."', platform: 'Google', time: '1d ago', alerted: true },
                { stars: 3, text: '"Decent but took longer than quoted."', platform: 'Yelp', time: '2d ago', alerted: true },
                { stars: 5, text: '"Best HVAC company in the city. Period."', platform: 'Google', time: '3d ago', alerted: true },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center gap-2 mb-1">
                    <div class="flex gap-0.5">
                      {Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
                    </div>
                    <span class="font-mono text-[10px] text-[#79716b]">{r.platform} · {r.time}</span>
                    {r.alerted && <span class="ml-auto font-mono text-[10px] text-[#059669]">✓ Alerted</span>}
                  </div>
                  <p class="font-sans text-[12px] text-[#57534e] italic">{r.text}</p>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Review Monitoring Automation</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Know about every review the moment it lands. Respond before it affects you.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                A negative review left unresponded for 48 hours does more damage than the review itself. Stacc monitors every review platform across all your locations in real time and fires alerts the moment a new review appears — so you can respond while it's still fresh. For agencies, the unified review feed means you see every client review without logging into 20 different Google accounts.
              </p>
              <a href="/modules/local-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See review monitoring
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Automated Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated Reporting</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Reports that generate, brand, and deliver themselves. Every client. Every week.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                For agencies, reporting is the most expensive part of local SEO — in time. Stacc eliminates it. Configure your template once: metrics to include, your brand colors and logo, delivery schedule. After that, Stacc pulls the data, formats the report, and sends it to the client. Your team never touches it again. The client gets a professional report. You get that time back every single month.
              </p>
              <a href="/solutions/agencies/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See agency reporting automation
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Reporting automation — this month</p>
              {[
                { client: 'Oakridge Plumbing', report: 'Monthly Local SEO', status: 'Delivered', time: 'Apr 1, 9:00 AM' },
                { client: 'City Dental Group', report: 'Monthly Local SEO', status: 'Delivered', time: 'Apr 1, 9:00 AM' },
                { client: 'Elite HVAC', report: 'Monthly Local SEO', status: 'Delivered', time: 'Apr 1, 9:00 AM' },
                { client: 'Metro Law Firm', report: 'Monthly Local SEO', status: 'Delivered', time: 'Apr 1, 9:00 AM' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.time}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Zero manual work · White-label branded</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#0d1117]/10" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Results</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What local SEO automation<br />actually delivers.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(15,23,42,0.04);">
          {[
            { value: '8hrs',  num: 8,   prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Saved per client per month', sub: 'compared to fully manual local SEO management' },
            { value: '89%', num: 89,   prefix: '', suffix: '%', decimals: 0, from: 0, label: 'GBP ranking lift in 90 days', sub: 'consistent activity vs inactive baseline' },
            { value: '30',   num: 30,   prefix: '', suffix: '', decimals: 0, from: 0, label: 'GBP posts published per month', sub: 'location-optimized, auto-published, zero manual effort' },
