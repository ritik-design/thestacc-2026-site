---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é software de SEO multi-localização?", a: "Software de SEO multi-localização permite que empresas gerenciem a otimização de busca local em cada localização a partir de uma única plataforma — rastreamento de posições, gerenciamento de citações, monitoramento de avaliações e publicação no GBP tratados em massa, em vez de uma localização por vez." },
  { q: "Como o Stacc trata o rastreamento de posições multi-localização?", a: "Cada localização tem seu próprio conjunto de palavras-chave rastreadas diariamente. Você vê a posição de cada localização no pacote local, no Maps e nos resultados orgânicos. O painel de portfólio compara todas as localizações lado a lado para que você veja instantaneamente quais estão melhorando e quais precisam de atenção." },
  { q: "Posso publicar posts no GBP para todas as localizações de uma vez?", a: "Sim. Escreva um post e publique-o em todas as localizações simultaneamente, ou personalize detalhes por localização antes de publicar em massa. O Stacc cuida das chamadas de API do GBP para cada localização em uma única ação." },
  { q: "Posso gerenciar citações de múltiplas localizações em massa?", a: "Sim. O Stacc monitora a precisão das citações em mais de 50 diretórios para cada localização e sinaliza inconsistências. As correções podem ser enviadas para múltiplas localizações de uma vez pelo editor em massa." },
  { q: "Há um limite de quantas localizações posso adicionar?", a: "Sem limite rígido. Clientes gerenciam mais de 500 localizações em uma única conta. A plataforma foi projetada para portfólios em escala empresarial." },
  { q: "O Stacc suporta relatórios white-label para clientes multi-localização?", a: "Sim. Cada cliente pode ter seu próprio portal com marca, domínio personalizado e logo. Os relatórios são gerados e entregues automaticamente com a marca da sua agência." },
  { q: "Quanto tempo leva para integrar uma nova localização?", a: "Cerca de 2 minutos. Insira os dados principais da empresa, conecte o perfil GBP e o Stacc propaga a configuração em sua rede de citações automaticamente." },
  { q: "Quanto custa o software de SEO multi-localização?", a: "O módulo de SEO Local do Stacc começa a partir de $49/mês. Todos os recursos multi-localização — gerenciamento em massa, relatórios de portfólio, painel de comparação — estão incluídos." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Software de SEO Multi-Localização", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Software de SEO multi-localização que automatiza posições, citações, gerenciamento de GBP e relatórios em cada localização a partir de um painel.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Software de SEO Multi-Localização", "item": "https://thestacc.com/pt-br/software-seo-multi-localizacao/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de SEO Multi-Localização para Redes e Franquias | theStacc"
  description="Pare de gerenciar SEO local localização por localização. O software de SEO multi-localização do theStacc cuida de rastreamento de posições, citações, GBP e relatórios para cada localização simultaneamente."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de SEO Multi-Localização · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO multi-localização que roda<br />
            <span style="color:#4f39f6;">sozinho em cada localização.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc gerencia posições, posts no GBP, citações, avaliações e relatórios para cada localização simultaneamente. Não um painel que exige trabalho manual — uma plataforma que faz o trabalho.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver o que está incluído
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · Garantia de 30 dias · Cancele quando quiser</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">+500 portfólios de localizações gerenciados</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuração em menos de 5 minutos</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por que o SEO multi-localização quebra em escala</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada localização precisa de trabalho diário.<br />Você não consegue fazer tudo manualmente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Gerenciar SEO local para uma localização é um trabalho de meio período. Gerenciar para dez localizações é um trabalho de período integral. Gerenciar para cinquenta localizações é uma equipe. A matemática quebra em algum ponto — e para a maioria das empresas, quebra por volta da terceira ou quarta localização, quando as planilhas começam a se multiplicar e o trabalho manual começa a se acumular.</p>
            <p>Veja o que "gerenciar manualmente" realmente custa em escala: cada localização precisa de atividade diária no GBP, citações consistentes em mais de 50 diretórios, monitoramento de palavras-chave ranqueadas e gerenciamento de reputação por avaliações. Depois alguém precisa reportar tudo isso. Multiplique por 30 localizações. Isso não é um fluxo de trabalho — é um departamento inteiro.</p>
            <p class="font-semibold text-[#111827]">O Stacc foi construído especificamente para esse problema. Uma plataforma que automatiza cada tarefa de SEO local em cada localização, todos os dias — sem adicionar contratações à medida que o número de localizações cresce.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Uma plataforma. Cada alavanca de SEO local.<br />Tudo automatizado.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Local', price: '$49/mês', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Publicação de posts no GBP — 30/mês', 'Rastreamento diário de posições — pacote local + orgânico', 'Monitoramento de avaliações — alertas em tempo real', 'Gerenciamento de citações — +50 diretórios'], href: '/pt-br/modulos/seo-local/' },
            { title: 'Blog SEO', price: '$99/mês', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 posts de blog SEO/mês', 'Publicados diretamente no seu site', 'Pesquisa de palavras-chave incluída', 'Links internos otimizados'], href: '/pt-br/modulos/seo-conteudo/' },
            { title: 'Redes Sociais', price: '$49/mês', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Posts diários com imagens', 'Instagram, LinkedIn, Facebook, X', 'Escritos e agendados automaticamente', 'Conteúdo consistente com a marca'], href: '/pt-br/modulos/redes-sociais/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Saiba mais</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades principais</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarefa de SEO multi-localização automatizada.<br />Cada resultado visível.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Portfolio dashboard -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Painel de Portfólio de Localizações</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Cada localização classificada lado a lado. Localizações com baixo desempenho aparecem instantaneamente.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">O painel de portfólio exibe todas as localizações comparadas por posições, precisão de citações, pontuação de avaliações e atividade no GBP. Classifique por qualquer métrica para ver instantaneamente quem está vencendo, quem está estagnando e onde sua atenção terá o maior ROI. Chega de trocar de aba para verificar cada localização — a comparação é feita para você todos os dias.</p>
              <a href="/pt-br/funcionalidades/relatorios-multi-localizacao/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">Ver relatórios multi-localização <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Portfólio de localizações — hoje</p>
              {[
                { name: 'Centro de São Paulo', rank: 1, trend: '↑', score: 94 },
                { name: 'Vila Madalena', rank: 2, trend: '↑', score: 91 },
                { name: 'Pinheiros', rank: 3, trend: '→', score: 88 },
                { name: 'Santo André', rank: 7, trend: '↓', score: 61 },
              ].map(loc => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${loc.rank <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#fff1f2] text-[#ef4444]'}`}>#{loc.rank}</div>
                  <span class="flex-1 font-sans text-[13px] text-[#374151]">{loc.name}</span>
                  <div class="h-1.5 w-16 rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${loc.score}%`}></div></div>
                  <span class={`font-mono text-[11px] font-semibold ${loc.trend === '↑' ? 'text-[#059669]' : loc.trend === '↓' ? 'text-[#ef4444]' : 'text-[#79716b]'}`}>{loc.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Atualizado diariamente · Todas as localizações comparadas automaticamente</p>
            </div>
          </div>

          <!-- Bulk management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Atualização em massa — horário de feriado</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Selecionar localizações</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {['Todas as 47 localizações', 'Região São Paulo', 'Seleção personalizada'].map(opt => (
                    <span class={`rounded-lg px-3 py-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] ${opt === 'Todas as 47 localizações' ? 'bg-[#4f39f6] text-white' : 'border border-[#e7e5e4] text-[#79716b]'}`}>{opt}</span>
                  ))}
                </div>
              </div>
              <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-white p-4">
                <span class="font-sans text-[13px] text-[#57534e]">Aplicar horário de feriado a todas as 47</span>
                <span class="rounded-lg bg-[#059669] px-3 py-1 font-mono text-[10px] font-bold text-white">Aplicar</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">2 segundos vs. 47 logins manuais</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gerenciamento em Massa de Localizações</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Atualize cada localização em segundos. Não em horas.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Horários de feriados. Mudanças de categoria. Novos números de telefone. Atualizações de descrição. Qualquer mudança que afete todo o seu portfólio pode ser aplicada a todas as localizações simultaneamente com uma única ação. Sem logins, sem troca de abas, sem erros manuais. As atualizações em massa se propagam para o GBP e sua rede de citações automaticamente.</p>
              <a href="/pt-br/funcionalidades/gerenciamento-em-massa/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">Ver gerenciamento em massa de localizações <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Relatórios Automatizados de Portfólio</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Relatórios para cada localização, entregues no horário certo. Zero trabalho manual.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Configure relatórios automatizados para cada localização ou cada cliente uma vez. O Stacc gera relatórios por localização e resumos de portfólio no seu horário — semanal, mensal ou personalizado — e os entrega automaticamente. Agências podem colocar marca white-label em todos os relatórios. Sem exportações. Sem formatações. Sem esquecimentos.</p>
              <a href="/pt-br/funcionalidades/relatorios-de-clientes/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">Ver relatórios de clientes <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Relatório de portfólio desta semana</p>
              {[
                { label: 'Localizações melhorando', val: '34 de 47' },
                { label: 'Palavras-chave no top 3', val: '+18 esta semana' },
                { label: 'Posts GBP publicados', val: '94 em todas as localizações' },
                { label: 'Avaliações respondidas', val: '12 / média 4,7 ⭐' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Gerado e enviado automaticamente · Sua marca em tudo</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Pelos números</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que a automação consistente de SEO multi-localização<br />faz com os seus números.
          </h2>
        </div>
        <div class="mx-auto mt-14 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
