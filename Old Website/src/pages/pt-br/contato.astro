---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
---

<BaseLayout
  title="Contato | theStacc — Fale com a Equipe do Stacc"
  description="Tem perguntas sobre o Stacc? Entre em contato com nossa equipe. Respondemos em menos de 24 horas."
  lang="pt-BR"
>
  <Header />
  <main class="flex-1">

    <!-- ░░ DARK HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Contato</p>
        <h1 class="mx-auto mt-4 max-w-[560px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[44px]">
          Estamos aqui para ajudar você.
        </h1>
        <p class="mx-auto mt-4 max-w-[460px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          Perguntas sobre um plano, problemas com a configuração ou qualquer outra coisa. Preencha o formulário e respondemos em menos de 24 horas.
        </p>
        <!-- Trust pills -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {[
            'Respondemos em menos de 24 horas',
            'Sem pressão de vendas',
            'Respostas reais, não scripts',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ CONTACT STRIP ░░ -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x">
        <div class="flex flex-wrap items-center justify-center gap-8 py-4">
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="font-mono text-[10px] font-bold uppercase tracking-[0.1em] text-[#79716b]">Escreva diretamente</p>
              <a href="mailto:sidgangal@gmail.com" class="font-sans text-[13px] font-medium text-[#292524] hover:text-[#4f39f6]">sidgangal@gmail.com</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="font-mono text-[10px] font-bold uppercase tracking-[0.1em] text-[#79716b]">Tempo de resposta</p>
              <p class="font-sans text-[13px] font-medium text-[#292524]">Menos de 24 horas</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <p class="font-mono text-[10px] font-bold uppercase tracking-[0.1em] text-[#79716b]">Tipo de suporte</p>
              <p class="font-sans text-[13px] font-medium text-[#292524]">Liderado pelo fundador, não terceirizado</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ░░ FORM SECTION ░░ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mx-auto max-w-[960px]">
          <div class="grid grid-cols-1 gap-12 lg:grid-cols-[340px_1fr] lg:items-start">

            <!-- Left: context panel -->
            <div class="lg:sticky lg:top-24">
              <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Como podemos ajudar?</p>
              <h2 class="mt-3 font-sans text-[22px] font-bold leading-[1.3] tracking-[-0.02em] text-[#111827]">
                Uma resposta real de uma pessoa real.
              </h2>
              <div class="mt-6 space-y-5">
                <div class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-[#292524]">Perguntas sobre o produto</p>
                    <p class="mt-0.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">Pergunte o que quiser sobre os módulos de SEO Blog, SEO Local ou Redes Sociais. Encontraremos o plano certo para você.</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-[#292524]">Suporte técnico</p>
                    <p class="mt-0.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">Problemas para conectar WordPress, Webflow ou seu GBP? Guiamos você passo a passo na configuração.</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-[#292524]">Consultas de agência e parcerias</p>
                    <p class="mt-0.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">Usa o theStacc para vários clientes? Oferecemos preços para agências e opções de marca branca.</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right: form -->
            <div class="overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
              <div class="border-b border-[#f5f5f4] px-6 py-5">
                <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Enviar uma mensagem</p>
              </div>
              <form id="contact-form" class="flex flex-col gap-5 p-6">
                <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                  <div>
                    <label for="contact-name" class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b]">Nome *</label>
                    <input type="text" id="contact-name" name="name" required
                      class="mt-2 w-full rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-[14px] text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
                      placeholder="Seu nome" />
                  </div>
                  <div>
                    <label for="contact-email" class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b]">E-mail *</label>
                    <input type="email" id="contact-email" name="email" required
                      class="mt-2 w-full rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-[14px] text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
                      placeholder="voce@email.com.br" />
                  </div>
                </div>

                <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                  <div>
                    <label for="contact-company" class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b]">Empresa</label>
                    <input type="text" id="contact-company" name="company"
                      class="mt-2 w-full rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-[14px] text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
                      placeholder="Sua empresa (opcional)" />
                  </div>
                  <div>
                    <label class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b]">Área de interesse</label>
                    <div class="relative mt-2" id="dropdown-wrapper">
                      <input type="hidden" name="module" id="contact-module" value="" />
                      <button type="button" id="dropdown-trigger"
                        class="flex w-full items-center justify-between rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 text-left font-sans text-[14px] outline-none transition-colors focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]">
                        <span id="dropdown-label" class="text-[#79716b]">Selecione um tema</span>
                        <svg id="dropdown-chevron" class="h-4 w-4 text-[#79716b] transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                        </svg>
                      </button>
                      <ul id="dropdown-menu" class="absolute left-0 right-0 top-full z-10 mt-1 hidden overflow-hidden rounded-xl border border-[#e7e5e4] bg-white shadow-lg">
                        <li data-value="Blog SEO" class="dropdown-option cursor-pointer px-4 py-2.5 font-sans text-[14px] text-[#292524] transition-colors hover:bg-[#f5f5f4]">SEO Blog</li>
                        <li data-value="Local SEO" class="dropdown-option cursor-pointer px-4 py-2.5 font-sans text-[14px] text-[#292524] transition-colors hover:bg-[#f5f5f4]">SEO Local</li>
                        <li data-value="Social Media" class="dropdown-option cursor-pointer px-4 py-2.5 font-sans text-[14px] text-[#292524] transition-colors hover:bg-[#f5f5f4]">Redes Sociais</li>
                        <li data-value="Managed Services" class="dropdown-option cursor-pointer px-4 py-2.5 font-sans text-[14px] text-[#292524] transition-colors hover:bg-[#f5f5f4]">Serviços Gerenciados</li>
                        <li data-value="Other" class="dropdown-option cursor-pointer px-4 py-2.5 font-sans text-[14px] text-[#292524] transition-colors hover:bg-[#f5f5f4]">Outro</li>
                      </ul>
                    </div>
                  </div>
                </div>

                <div>
                  <label for="contact-message" class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b]">Mensagem *</label>
                  <textarea id="contact-message" name="message" required rows="4"
                    class="mt-2 w-full resize-none rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-[14px] text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
                    placeholder="Como podemos ajudar?"></textarea>
                </div>

                <button type="submit" id="contact-submit"
                  class="flex h-[46px] w-full items-center justify-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6] disabled:cursor-not-allowed disabled:opacity-60">
                  <span id="submit-text">Enviar mensagem</span>
                  <svg id="submit-spinner" class="hidden h-4 w-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                </button>

                <p id="form-status" class="hidden text-center font-sans text-[13px]"></p>

                <!-- Success state -->
                <div id="contact-success" class="hidden rounded-xl border border-[#bbf7d0] bg-[#f0fdf4] p-6 text-center">
                  <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                  <p class="mt-3 font-sans text-[16px] font-semibold text-[#292524]">Mensagem enviada!</p>
                  <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#57534e]">Respondemos em menos de 24 horas.</p>
                </div>

              </form>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ░░ DARK FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Pronto para colocar seu conteúdo no piloto automático?
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          30 artigos de blog, 30 publicações no GBP e conteúdo para redes sociais publicados no seu site todo mês.
        </p>
        <a href="/pt-br/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Comece seu Trial por $1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">$1 por 30 dias · Cancele quando quiser</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  const trigger = document.getElementById('dropdown-trigger')!;
  const menu = document.getElementById('dropdown-menu')!;
  const label = document.getElementById('dropdown-label')!;
  const chevron = document.getElementById('dropdown-chevron')!;
  const hiddenInput = document.getElementById('contact-module') as HTMLInputElement;

  trigger.addEventListener('click', () => {
    const open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', open);
    chevron.classList.toggle('rotate-180', !open);
  });

  document.querySelectorAll('.dropdown-option').forEach(opt => {
    opt.addEventListener('click', () => {
      const value = (opt as HTMLElement).dataset.value!;
      hiddenInput.value = value;
      label.textContent = (opt as HTMLElement).textContent!;
      label.classList.remove('text-[#79716b]');
      label.classList.add('text-[#292524]');
      menu.classList.add('hidden');
      chevron.classList.remove('rotate-180');
    });
  });

  document.addEventListener('click', e => {
    if (!(e.target as Element).closest('#dropdown-wrapper')) {
      menu.classList.add('hidden');
      chevron.classList.remove('rotate-180');
    }
  });

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text')!;
  const spinner = document.getElementById('submit-spinner')!;
  const status = document.getElementById('form-status')!;
  const successBox = document.getElementById('contact-success')!;

  form.addEventListener('submit', async e => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitText.textContent = 'Enviando...';
    spinner.classList.remove('hidden');
    status.classList.add('hidden');

    const data = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value.trim(),
      email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
      company: (form.elements.namedItem('company') as HTMLInputElement).value.trim(),
      module: (form.elements.namedItem('module') as HTMLInputElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
    };

    try {
      const res = await fetch('/api/contact/', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const result = await res.json();
      if (res.ok) {
        form.classList.add('hidden');
        successBox.classList.remove('hidden');
      } else {
        status.textContent = result.error || 'Algo deu errado. Por favor, tente novamente.';
        status.className = 'text-center font-sans text-[13px] text-red-500';
        status.classList.remove('hidden');
      }
    } catch {
      status.textContent = 'Erro de rede. Verifique sua conexão e tente novamente.';
      status.className = 'text-center font-sans text-[13px] text-red-500';
      status.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Enviar mensagem';
      spinner.classList.add('hidden');
    }
  });
</script>
