---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import { getCollection } from 'astro:content';

const enPosts = await getCollection('blog');
const langPosts = await getCollection('blog_ptbr');
const langBySlug = new Map(langPosts.map(p => [p.data.slug, p]));
const posts = enPosts
  .filter(enPost => langBySlug.has(enPost.data.slug))
  .map(enPost => {
    const lp = langBySlug.get(enPost.data.slug)!;
    return { ...enPost, data: { ...enPost.data, title: lp.data.title, description: lp.data.description } };
  });
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const recentPosts = sortedPosts.filter(p => p.data.image);

function getReadTime(post: any): number {
  const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}
---

<BaseLayout
  title="Blog de SEO | theStacc"
  description="Mais de 500 guias, tutoriais e estratégias de SEO para ranquear mais alto e converter mais tráfego. SEO local, estratégia de conteúdo, SEO com IA e crescimento para agências."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "@id": "https://thestacc.com/pt-br/blog/",
      "name": "Blog de SEO — theStacc",
      "description": "Guias, tutoriais e estratégias de SEO para ranquear mais alto e converter mais tráfego.",
      "url": "https://thestacc.com/pt-br/blog/",
      "inLanguage": "pt-BR",
      "publisher": {
        "@type": "Organization",
        "@id": "https://thestacc.com/#organization",
        "name": "theStacc"
      }
    })} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-8 pb-10">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Blog de SEO</p>
        <h1 class="mt-3 max-w-[600px] font-sans text-[28px] font-bold leading-[1.15] tracking-[-0.025em] text-[#292524] md:text-[38px]">
          Biblioteca de Recursos de SEO
        </h1>
        <p class="mt-3 max-w-[500px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          500+ guias, tutoriais e estratégias para ranquear mais alto e converter mais tráfego. Atualizado semanalmente.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            500+ Artigos
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Atualizado semanalmente
          </span>
        </div>
      </div>
    </section>

    <!-- ░░ RECENT POSTS ░░ -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-6xl">
        <p class="mb-6 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Artigos Recentes</p>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {recentPosts.map((post) => (
            <a
              href={`/pt-br/blog/${post.data.slug}/`}
              class="group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm"
            >
              <div class="flex flex-1 flex-col p-5">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                <h3 class="mt-2 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                  {post.data.title}
                </h3>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                    <span class="text-[#e7e5e4]">·</span>
                    <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min de leitura</span>
                  </div>
                  <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Link to full English blog -->
        <div class="mt-10 rounded-2xl border border-[#e7e5e4] bg-white p-6 text-center">
          <p class="font-sans text-[14px] text-[#57534e]">
            Veja todos os artigos em nosso blog completo em inglês — novos conteúdos em português são publicados regularmente.
          </p>
          <a
            href="/blog/"
            class="mt-4 inline-flex h-10 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-mono text-[12px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#615fff]"
          >
            Ver todos os artigos →
          </a>
        </div>
      </div>
    </section>

    <!-- ░░ FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Pare de escrever conteúdo SEO manualmente
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          30 artigos de blog, 30 posts no Google Meu Negócio e conteúdo para redes sociais. Publicados todo mês. Automaticamente.
        </p>
        <a
          href="/pt-br/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Começar por R$1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">R$1 por 30 dias · Cancele quando quiser</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
