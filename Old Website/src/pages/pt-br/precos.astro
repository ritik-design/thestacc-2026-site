---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { SITE_URL, LOGO_URL, buildBreadcrumbs } from '../../utils/schema';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const blogTiers = [
  { label: '30 artigos', count: 30, price: 99 },
  { label: '50 artigos', count: 50, price: 149 },
  { label: '80 artigos', count: 80, price: 199, best: true },
];
const localTiers = [
  { label: '30 publicações', count: 30, price: 49 },
  { label: '60 publicações', count: 60, price: 79 },
  { label: '80 publicações', count: 80, price: 99, best: true },
];
const socialTiers = [
  { label: '30 publicações', count: 30, price: 49 },
  { label: '60 publicações', count: 60, price: 79 },
  { label: '120 publicações', count: 120, price: 129, best: true },
];

const blogFeatures = [
  'Pesquisa de palavras-chave e análise da concorrência',
  'Publicação automática no seu site',
  'WordPress, Webflow, Ghost e mais',
  'Otimizado para SEO na sua voz de marca',
];
const localFeatures = [
  'Publicações automáticas no GBP',
  'Respostas a avaliações com IA',
  'Rastreamento de palavras-chave locais',
  'Suporte a múltiplas localidades',
];
const socialFeatures = [
  'Publicação automática e agendamento',
  'Analytics multiplataforma',
  'Conteúdo com a voz da sua marca',
  '4 plataformas incluídas',
];

const managedPlans = [
  {
    name: 'Crescimento Local',
    tagline: 'Conteúdo + SEO Local, totalmente gerenciado.',
    price: 749,
    annualPrice: 625,
    features: [
      '30 artigos de blog publicados/mês',
      '30 publicações no GBP/mês',
      'Monitoramento e respostas diárias a avaliações',
      'Relatórios de desempenho semanais',
      'Videochamada estratégica mensal',
      '1 localidade incluída (+$150 cada extra)',
    ],
    popular: false,
    comparison: null as string | null,
  },
  {
    name: 'Crescimento Pro',
    tagline: 'Conteúdo + SEO Local + Redes Sociais.',
    price: 999,
    annualPrice: 835,
    features: [
      'Tudo do Crescimento Local',
      '60 publicações em redes em 6 plataformas/mês',
      'Conteúdo e hashtags específicos por plataforma',
      'Horário de publicação otimizado',
      'Monitoramento diário de interações',
      'Análise mensal + chamada estratégica',
    ],
    popular: true,
    comparison: null as string | null,
  },
  {
    name: 'Crescimento Completo',
    tagline: 'Tudo. Blog, local, social e site.',
    price: 1299,
    annualPrice: 999,
    features: [
      'Tudo do Crescimento Pro',
      'Site criado com IA, hospedado e gerenciado',
      'Atualizações mensais do site e ajuste de SEO',
      'Monitoramento de velocidade e correções de segurança',
      'Relatórios semanais + chamada estratégica mensal',
      'Equipe de operações baseada nos EUA',
    ],
    popular: false,
    comparison: 'Comparação: um funcionário de marketing meio período custa <strong>$2.500–$4.000/mês</strong>. Uma agência cobra <strong>$3.000–$10.000/mês</strong> de retainer.',
  },
];

const tabs = [
  {
    id: 'blog',
    label: 'SEO Blog',
    icon: '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>',
    title: 'SEO Blog',
    replaces: ['Plataforma SEO ($99–$399/mês)', 'redatores freelance ($2.000–$5.000/mês)', 'ferramenta de calendário de conteúdo'],
    narrative: "Os negócios que aparecem na primeira página publicam 20–30 artigos por mês. O negócio médio publica 2. O Stacc escreve, otimiza e publica no seu site todos os dias. Mesmo que você nunca tenha ranqueado para uma palavra-chave na vida. Sem briefs. Sem editores. Sem prazos perdidos.",
    stats: [
      { label: 'Velocidade de conteúdo vs. negócio médio', value: '15× mais', percent: 88, color: 'purple' },
      { label: 'Custo vs. redatores freelance', value: '95% menos', percent: 95, color: 'green' },
      { label: 'Tempo até o primeiro movimento de ranking', value: '60–90 dias', percent: 65, color: 'amber' },
    ],
  },
  {
    id: 'local',
    label: 'SEO Local',
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
    title: 'SEO Local',
    replaces: ['Agência de SEO local ($800–$2.000/mês)', 'ferramenta de gestão de avaliações', 'rastreador de posicionamento local'],
    narrative: "Seu perfil do Google Meu Negócio é o espaço mais valioso na busca local. Um perfil inativo é invisível. O Stacc publica 30 vezes por mês, responde avaliações na hora e rastreia cada palavra-chave na sua cidade. Mesmo que você não tenha feito login no seu GBP há meses.",
    stats: [
      { label: 'Publicações no GBP vs. negócio típico', value: '10× mais', percent: 80, color: 'purple' },
      { label: 'Tempo de resposta a avaliações', value: 'Menos de 1h', percent: 95, color: 'green' },
      { label: 'Melhoria de posição no Maps em 90 dias', value: '4,7×', percent: 70, color: 'amber' },
    ],
  },
  {
    id: 'social',
    label: 'Redes Sociais',
    icon: '<path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>',
    title: 'Redes Sociais',
    replaces: ['Social media manager ($2.500–$5.000/mês)', 'ferramenta de agendamento', 'ferramenta de design'],
    narrative: "O algoritmo recompensa consistência. Negócios que publicam diariamente têm mais alcance, mais seguidores, mais clientes. O Stacc gera conteúdo nativo para Instagram, LinkedIn, X e Facebook. Mesmo que você já tenha tentado ferramentas de agendamento antes e abandonado em duas semanas.",
    stats: [
      { label: 'Publicações/mês vs. negócio típico', value: '10× mais', percent: 80, color: 'purple' },
      { label: 'Custo vs. social media manager', value: '98% menos', percent: 98, color: 'green' },
      { label: 'Tempo economizado por semana', value: '5+ horas', percent: 85, color: 'amber' },
    ],
  },
];

const milestones = [
  { month: 'Mês 3', stat: '+47%', desc: 'Páginas indexadas' },
  { month: 'Mês 6', stat: '+180%', desc: 'Tráfego orgânico' },
  { month: 'Mês 12', stat: '+320%', desc: 'Leads qualificados' },
];

const testimonials = [
  {
    quote: "Saímos de 0 para 47 leads mensais em 4 meses. O Stacc substituiu nossa agência de $3.000/mês e os resultados são melhores.",
    name: "Proprietário",
    role: "Clínica Odontológica · São Paulo",
    metric: "47 leads/mês",
    init: "CS",
  },
  {
    quote: "Era cético sobre conteúdo com IA. Mas nossos artigos aparecem na primeira página e clientes os mencionam durante consultas. É o marketing mais crível que já fizemos.",
    name: "Sócio",
    role: "Escritório de Advocacia · Belo Horizonte",
    metric: "3× tráfego orgânico",
    init: "MA",
  },
  {
    quote: "Top 3 no Maps para 'encanador perto de mim' em 90 dias. As publicações no GBP saem todo dia sem eu tocar em nada. Nossa nota foi de 4,1 para 4,8. Por $49 por mês, nada chega perto.",
    name: "Rafael S.",
    role: "Empresa de Encanamento · Curitiba",
    metric: "↑ Top 3 no Maps em 90 dias",
    init: "RS",
  },
  {
    quote: "Visibilidade no Google Maps 200% maior no primeiro trimestre. Recebemos ligações de bairros onde nunca tínhamos aparecido. A configuração levou 10 minutos.",
    name: "Corretora",
    role: "Imobiliária · Rio de Janeiro",
    metric: "200% mais visualizações",
    init: "IM",
  },
];

const faqs = [
  {
    q: "Já tentei marketing de conteúdo antes e não funcionou.",
    a: "O motivo pelo qual a maioria do marketing de conteúdo fracassa não é o conteúdo. É a inconsistência. Você publica 4 artigos, para por 6 semanas, publica mais 2 e abandona porque não vê resultados. O algoritmo do Google recompensa publicação sustentada e regular. O Stacc publica todos os dias, todos os meses, sem interrupção. Os negócios que usam o Stacc e que 'já tentaram conteúdo antes' são os que estão vendo os melhores resultados. Porque desta vez, a publicação não para.",
  },
  {
    q: "Quanto tempo até ver resultados?",
    a: "A maioria dos negócios vê movimento significativo no ranqueamento dentro de 60–90 dias de publicação constante. No primeiro mês, o Google indexa o novo conteúdo. No segundo mês, os rankings começam a se mover. No mês 3–6, o tráfego cresce de forma notável. SEO não é um jogo de um mês. É um investimento de 6 meses que rende dividendos por anos. Cada artigo que o Stacc publica continua trabalhando para você, esteja você assinante ou não.",
  },
  {
    q: "Vale a pena $99/mês? São $1.188 por ano.",
    a: "Um redator freelance cobra entre R$150 e R$500 por artigo. Com 30 artigos por mês, isso é $4.500–$15.000/mês. Ou $54.000–$180.000/ano. Uma plataforma SEO (Ahrefs, Semrush) custa $99–$399/mês só pelos dados, sem redação incluída. Um único cliente novo vindo da busca orgânica paga o custo anual completo do Stacc antes do almoço. As contas fecham de um jeito só.",
  },
  {
    q: "Preciso escrever alguma coisa ou me envolver muito?",
    a: "Nem uma palavra. O Stacc cuida da pesquisa de palavras-chave, análise da concorrência, criação de conteúdo, otimização de SEO e publicação no seu site. Totalmente automatizado. Você pode revisar os artigos antes de publicar se quiser, ou ativar a publicação automática e revisar mensalmente. A maioria dos clientes dedica cerca de 1–2 horas por mês para revisar. O resto do tempo é seu.",
  },
  {
    q: "Posso cancelar a qualquer momento? Tenho medo de ficar preso.",
    a: "Cancele quando quiser. Sem contratos, sem penalidades, sem taxas de cancelamento. O conteúdo que o Stacc publicou permanece no seu site para sempre e continua ranqueando. Você não perde acesso ao trabalho passado quando cancela. Apenas para a publicação futura. A maioria das pessoas que cancelam volta em 60 dias quando vê o tráfego estagnar.",
  },
  {
    q: "Como isso é diferente do ChatGPT ou contratar um assistente virtual?",
    a: "O ChatGPT escreve quando você o ativa. O Stacc publica de acordo com um calendário, automaticamente, todos os dias. Um assistente virtual escreve quando está disponível, perde prazos, precisa de treinamento, vai de férias. O Stacc não. A diferença real está no sistema: pesquisa de palavras-chave → otimização de SEO → publicação no CMS → rastreamento de ranking, tudo automatizado e conectado. ChatGPT é uma ferramenta. Stacc é o fluxo de trabalho completo.",
  },
  {
    q: "Quais plataformas CMS são compatíveis?",
    a: "WordPress, Webflow, Ghost, Shopify e qualquer plataforma que suporte publicação via API ou webhook. Se o seu CMS não está na lista, entre em contato. Suportamos a maioria das plataformas com uma integração personalizada. A configuração leva menos de 10 minutos.",
  },
  {
    q: "Como funciona o desconto de 15% por pacote?",
    a: "Selecione dois ou mais módulos e o desconto é aplicado automaticamente na barra de resumo na parte inferior da tela. Sem códigos de cupom. Sem cálculos manuais. A economia aparece instantaneamente enquanto você monta seu plano.",
  },
];

const pricingSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE_URL}/#software`,
      name: 'theStacc',
      description: 'Plataforma de automação de SEO com IA que escreve e publica conteúdo de blog, gerencia perfis do Google Meu Negócio e automatiza redes sociais para negócios locais.',
      url: SITE_URL,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      inLanguage: 'pt-BR',
      offers: [
        { '@type': 'Offer', name: 'SEO Blog', description: '30 artigos SEO escritos com IA publicados no seu site todo mês', price: '99.00', priceCurrency: 'USD', url: `${SITE_URL}/pt-br/precos/` },
        { '@type': 'Offer', name: 'SEO Local', description: 'Otimização e gerenciamento do perfil do Google Meu Negócio', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/pt-br/precos/` },
        { '@type': 'Offer', name: 'Redes Sociais', description: 'Publicação e distribuição automatizada em redes sociais', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/pt-br/precos/` },
        { '@type': 'Offer', name: 'Pacote (Todos os Módulos)', description: 'SEO Blog + SEO Local + Redes Sociais', price: '167.00', priceCurrency: 'USD', url: `${SITE_URL}/pt-br/precos/` },
      ],
      provider: { '@id': `${SITE_URL}/#organization` },
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/pt-br/precos/`,
      name: 'Preços — theStacc',
      description: 'Escolha o módulo do Stacc que você precisa. SEO Blog a partir de $99/mês, SEO Local a partir de $49/mês, Redes Sociais a partir de $49/mês. Sem contratos. Cancele quando quiser.',
      url: `${SITE_URL}/pt-br/precos/`,
      inLanguage: 'pt-BR',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(`${SITE_URL}/pt-br/precos/`, [
      { name: 'Início', url: `${SITE_URL}/pt-br/` },
      { name: 'Preços', url: `${SITE_URL}/pt-br/precos/` },
    ]),
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL },
    },
  ],
};
---

<BaseLayout
  title="Preços do Stacc — SEO Blog, SEO Local e Redes Sociais a partir de $99/mês"
  description="Escolha o módulo do Stacc que você precisa. SEO Blog a partir de $99/mês, SEO Local a partir de $49/mês, Redes Sociais a partir de $49/mês. Sem contratos. Cancele quando quiser."
  lang="pt-BR"
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[820px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">3 módulos · 1 plataforma · Comece por $1</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Eles publicam todo dia.
            <span style="color:#4f39f6;"> Você não. Essa é a diferença.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc pesquisa, escreve e publica conteúdo de SEO, atualizações do Google Meu Negócio e publicações em redes sociais todo dia. Automaticamente. Escolha seus módulos e comece por $1.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="#pricing"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Monte meu plano
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#compare"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Veja o que você substitui
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem cartão de crédito · Cancele quando quiser
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '12.000+', num: 12000, prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Artigos publicados' },
              { value: '340+',    num: 340,   prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Negócios crescendo' },
              { value: '4,9★',    num: 4.9,   prefix: '',  suffix: '★', decimals: 1, from: 0, label: 'Avaliação dos clientes' },
              { value: '0',       num: 0,     prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Penalizações do Google' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negócios crescendo com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 em 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PRICING MODULES ─── -->
    <section class="bg-white" id="pricing">

      <!-- ── Controls bar ── -->
      <div class="border-b border-[#e7e5e4]">
        <div class="container-x py-4">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-3">
              <div class="flex items-center gap-1.5">
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Escolha seu caminho</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </div>
              <div class="inline-flex overflow-hidden rounded-full border border-[#e7e5e4] bg-[#fafaf9] p-1" role="group" aria-label="Opção de preços">
                <a href="#software-pricing" class="rounded-full px-5 py-2 font-sans text-[13px] font-semibold bg-[#111827] text-white shadow-sm">Software</a>
                <a href="#managed-pricing" class="rounded-full px-5 py-2 font-sans text-[13px] font-semibold text-[#9ca3af] hover:text-[#374151] transition-colors">Serviços</a>
              </div>
            </div>
            <div id="billing-controls" class="flex items-center gap-3">
              <span id="mod-billing-label" class="cursor-pointer font-sans text-[13px] font-semibold text-[#374151]">Cobrado anualmente</span>
              <button id="mod-billing-toggle" class="relative h-[24px] w-[44px] shrink-0 cursor-pointer rounded-full bg-[#4f39f6] transition-colors" aria-label="Alternar cobrança anual" type="button">
                <div id="mod-billing-dot" class="absolute top-[3px] left-[3px] h-[18px] w-[18px] rounded-full bg-white shadow-sm transition-transform" style="transform:translateX(20px)"></div>
              </button>
              <span id="mod-save-badge" class="rounded-md bg-[#4f39f6]/10 px-2 py-0.5 font-mono text-[11px] font-semibold text-[#4f39f6]">Economize 17%</span>
