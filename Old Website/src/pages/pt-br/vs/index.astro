---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import { getCollection } from 'astro:content';

const comparisons = await getCollection('compare');
const sortedComparisons = comparisons.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const visibleComparisons = sortedComparisons.filter(c => c.data.image);

function readTime(body: string): number {
  const words = (body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início', item: 'https://thestacc.com/pt-br/' },
        { '@type': 'ListItem', position: 2, name: 'Comparações VS', item: 'https://thestacc.com/pt-br/vs/' },
      ],
    },
  ],
};
---

<BaseLayout
  title="Comparações de Ferramentas de SEO — theStacc vs Concorrentes | theStacc"
  description="Comparações diretas entre o theStacc e outras plataformas de SEO. Recursos, preços, prós e contras — tudo o que você precisa para tomar a decisão certa."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-12 pb-12">

        <nav aria-label="Caminho de navegação" class="mb-3">
          <ol class="flex items-center gap-1.5 font-mono text-[11px] text-[#a8a29e]">
            <li><a href="/pt-br/" class="hover:text-[#57534e] transition-colors">Início</a></li>
            <li class="before:content-['/'] before:mx-1.5 text-[#79716b]">Comparações VS</li>
          </ol>
        </nav>

        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">VS Comparações</span>
          <span class="h-3 w-px bg-[#e7e5e4]"></span>
          <span class="font-mono text-[10px] text-[#79716b]">{visibleComparisons.length} guias</span>
        </div>

        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px]">
          Comparações de Ferramentas de SEO
        </h1>
        <p class="mt-3 max-w-[560px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Comparações diretas com preços verificados, análise de recursos e veredictos claros. Tome a decisão certa com dados reais.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {[
            `${visibleComparisons.length} comparações`,
            'Preços verificados 2026',
            'Veredictos imparciais',
            'Recursos comprovados',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ CARD GRID ░░ -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-6xl">
        {visibleComparisons.length > 0 ? (
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {visibleComparisons.map((comp) => (
              <a href={`/pt-br/vs/${comp.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
                <div class="flex flex-1 flex-col p-6">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">VS</span>
                  <h2 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{comp.data.title}</h2>
                  <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{comp.data.description}</p>
                  <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                    <span class="font-mono text-[10px] text-[#79716b]">{comp.data.date} · {readTime(comp.body ?? '')} min de leitura</span>
                    <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="py-20 text-center">
            <p class="font-sans text-[16px] text-[#79716b]">As comparações VS serão publicadas em breve.</p>
            <a href="/pt-br/alternativas/" class="mt-4 inline-flex items-center gap-2 font-mono text-[13px] font-semibold text-[#4f39f6] hover:underline">
              Ver alternativas →
            </a>
          </div>
        )}

        <div class="mt-8 text-center">
          <p class="font-sans text-[14px] text-[#57534e]">Veja mais comparações no nosso <a href="/compare/" class="text-[#4f39f6] hover:underline">hub em inglês →</a></p>
        </div>
      </div>
    </section>

    <!-- ░░ FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#818cf8]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Terminou de comparar. Hora de publicar.
        </h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          O theStacc escreve, otimiza e publica 30 artigos de SEO no seu site todo mês. Automaticamente.
        </p>
        <a
          href="/pt-br/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Começar por R$1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">R$1 por 30 dias · Cancele quando quiser</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
