---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é software de automação de SEO?", a: "Software de automação de SEO cuida das tarefas recorrentes e repetitivas de SEO sem exigir execução manual a cada vez — rastreamento de posições, monitoramento de citações, publicação de conteúdo, alertas de avaliações e geração de relatórios. Para SEO local especificamente, a automação é a única forma de manter execução consistente de SEO em múltiplas localizações." },
  { q: "Quais tarefas de SEO local o Stacc automatiza?", a: "Publicação de posts no GBP (30/mês por localização), monitoramento e correção de citações em mais de 50 diretórios, rastreamento diário de posições em cada palavra-chave e localização, alertas de avaliações em tempo real e geração e entrega automatizadas de relatórios. Tudo que de outra forma exigiria trabalho manual por localização, por dia." },
  { q: "A automação de SEO é apenas para agências ou também para equipes internas?", a: "Para ambos. Agências usam o Stacc para escalar a entrega de SEO local em portfólios de clientes sem crescimento proporcional de equipe. Equipes internas de empresas multi-localização usam para manter SEO consistente em cada localização sem precisar de equipe de SEO dedicada por localização." },
  { q: "A automação de SEO realmente produz resultados ou apenas economiza tempo?", a: "Ambos. A economia de tempo é real — clientes do Stacc relatam mais de 8 horas economizadas por mês por localização. E os resultados são reais: atividade consistente no GBP se correlaciona com posições mais altas no Maps, e precisão consistente de citações reduz a penalidade de posição por inconsistência de NAP. A automação entrega tanto eficiência quanto resultados." },
  { q: "Qual é a diferença entre o Stacc e um rastreador de posições padrão?", a: "A maioria dos rastreadores de posições apenas rastreia. O Stacc rastreia e age. Ele publica posts no GBP, monitora citações, alerta sobre avaliações, gera relatórios — tudo automaticamente. É uma plataforma de execução, não um painel de dados que exige que você faça o trabalho real." },
  { q: "Quanto custa o software de automação de SEO?", a: "O módulo de SEO Local do Stacc começa a partir de $49/mês com um teste gratuito de 14 dias. Todos os recursos de automação estão incluídos — sem bloqueio de funcionalidades na automação do GBP, monitoramento de citações ou relatórios." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Software de Automação de SEO Local", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Software de automação de SEO local que executa gerenciamento de GBP, monitoramento de citações, rastreamento de posições e relatórios automaticamente — para que você foque na estratégia, não na execução.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Software de Automação de SEO", "item": "https://thestacc.com/pt-br/software-automacao-seo/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de Automação de SEO Local | theStacc"
  description="Pare de executar SEO local manualmente. O theStacc automatiza publicação no GBP, monitoramento de citações, rastreamento de posições e relatórios — cada localização, todos os dias, sem trabalho manual."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de Automação de SEO · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local que roda sozinho.<br />
            <span style="color:#4f39f6;">Não um painel que você roda manualmente.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc automatiza cada tarefa repetitiva de SEO local — publicação no GBP, monitoramento de citações, rastreamento de posições, alertas de avaliações e relatórios — em cada localização, todos os dias, sem trabalho manual.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver o que é automatizado
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · Garantia de 30 dias · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O custo da execução manual de SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            A maioria das ferramentas de SEO diz o que fazer.<br />O Stacc faz.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>A maioria dos softwares de SEO local foi projetada com a premissa de que um humano vai executar as recomendações. Faça login, veja o que precisa ser feito, vá fazer manualmente. Isso funciona em um mundo onde você tem tempo ilimitado e uma localização para gerenciar. Falha no primeiro ponto de inflexão de escala.</p>
            <p>Automação real de SEO não é apenas agendar uma tarefa — é remover você do ciclo de execução completamente. Os posts saem sem alguém clicar em publicar. As citações são monitoradas sem alguém rodar a auditoria. Os relatórios são entregues sem alguém exportar um CSV. É isso que o Stacc faz: ele completa o trabalho, não apenas o identifica.</p>
            <p class="font-semibold text-[#111827]">As empresas que estão vencendo na busca local agora não estão fazendo mais trabalho. Elas automatizaram o trabalho e estão acumulando resultados todos os dias enquanto seus concorrentes ainda estão clicando em painéis.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que é automatizado</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarefa de SEO local que se repete.<br />Cada uma automatizada.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Publicação de posts no GBP', body: '30 posts otimizados por localização por mês, publicados automaticamente no horário certo. Os perfis ficam ativos todos os dias sem trabalho manual.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreamento diário de posições', body: 'Posições atualizadas diariamente em todas as palavras-chave e localizações. Alertas disparam em mudanças significativas. Sem verificação manual de posições necessária.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoramento de citações', body: 'Monitora continuamente a precisão dos dados NAP em mais de 50 diretórios. Sinaliza inconsistências. Corrija em massa em múltiplas localizações com uma única ação.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Automação de alertas de avaliações', body: 'Novas avaliações disparam alertas instantâneos. Monitore a reputação de cada localização em tempo real sem verificar cada plataforma separadamente.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Geração e entrega de relatórios', body: 'Os relatórios são gerados no horário certo e entregues automaticamente. Sem exportações, sem formatações, sem envios manuais. Os relatórios chegam nas caixas de entrada sem que ninguém da sua equipe os toque.' },
            { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Sincronização de palavras-chave e citações', body: 'Conjuntos de palavras-chave e fontes de citações ficam sincronizados entre localizações. Quando você adiciona novas palavras-chave ou localizações, a automação se estende automaticamente.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automação em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o Stacc está fazendo<br />enquanto você foca em outra coisa.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automação Completa de SEO</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Tudo automatizado — nada é esquecido.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Publicação no GBP, rastreamento de posições, monitoramento de citações, alertas de avaliações e entrega de relatórios. O Stacc executa todas as tarefas diárias de SEO local em cada localização, todos os dias, sem que ninguém da sua equipe precise verificar, lembrar ou clicar. Você configura uma vez. O sistema executa continuamente.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação completa
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Tarefas concluídas hoje</p>
              {[
                { task: 'Post no GBP publicado', detail: 'Unidade de São Paulo · 7h02', ok: true },
                { task: 'Posições verificadas', detail: '14 palavras-chave · 6h45', ok: true },
                { task: 'Citações auditadas', detail: '50 diretórios · 6h30', ok: true },
                { task: 'Avaliação monitorada', detail: 'Nova avaliação · alerta enviado', ok: true },
                { task: 'Relatório gerado', detail: 'Cliente Carvalho · enviado', ok: true },
              ].map(item => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.task}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{item.detail}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tudo automatizado · Zero ações manuais</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Alerta de avaliação — resposta com 1 clique</p>
              <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4 mb-4">
                <div class="flex items-center gap-2 mb-2">
                  <div class="flex gap-0.5">
                    {[1,2,3,4].map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="#e5e7eb" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  </div>
                  <span class="font-mono text-[10px] text-[#79716b]">Google · há 12min</span>
                </div>
                <p class="font-sans text-[12px] text-[#57534e] italic">"Razoável, mas demorou mais do que o esperado."</p>
              </div>
              {[
                { label: 'Modelo de resposta A', desc: 'Tom profissional + pedido de desculpas' },
                { label: 'Modelo de resposta B', desc: 'Empatia + oferta de solução' },
              ].map(item => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.label}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{item.desc}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">Usar →</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alertas em tempo real · Resposta em 1 clique</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestão de Avaliações em Tempo Real</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Avaliações gerenciadas em tempo real.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Uma avaliação negativa sem resposta faz mais dano do que a própria nota. O Stacc monitora todas as plataformas em tempo real e dispara alertas instantâneos com modelos de resposta prontos. Para agências, o feed unificado significa que você vê cada avaliação de cada cliente em um único lugar — sem fazer login em 20 contas Google diferentes.
              </p>
              <a href="/pt-br/software-gestao-avaliacoes/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver gestão de avaliações
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Relatórios Automatizados</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Relatórios enviados automaticamente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Para agências, os relatórios são a parte mais cara do SEO local — em termos de tempo. O Stacc elimina isso. Configure seu template uma vez: métricas a incluir, cores e logo da sua marca, agenda de entrega. Depois disso, o Stacc puxa os dados, formata o relatório e o envia ao cliente. Sua equipe nunca mais toca nisso. O cliente recebe um relatório profissional. Você recupera esse tempo todo mês.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de relatórios para agências
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Entrega de relatórios — este mês</p>
              {[
                { client: 'Encanamentos Carvalho', schedule: 'Mensal · 1 Abr, 9h00', status: 'Entregue' },
                { client: 'Grupo Odontológico Central', schedule: 'Mensal · 1 Abr, 9h00', status: 'Entregue' },
                { client: 'Elite Climatização', schedule: 'Mensal · 1 Abr, 9h00', status: 'Entregue' },
                { client: 'Escritório Metro Advocacia', schedule: 'Mensal · 1 Abr, 9h00', status: 'Entregue' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.schedule}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Zero trabalho manual · Marca white-label</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
