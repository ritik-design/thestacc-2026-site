---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é software de rastreamento de posições?", a: "Software de rastreamento de posições monitora onde seu site e Google Business Profile aparecem nos resultados de busca para suas palavras-chave alvo. O rastreamento de posições local acompanha especificamente sua posição no pacote local do Google, no Google Maps e nos resultados orgânicos — as três superfícies de posicionamento separadas que importam para empresas locais." },
  { q: "Com que frequência o Stacc atualiza as posições?", a: "Diariamente. As posições são atualizadas todos os dias para cada palavra-chave rastreada em cada localização. Você sempre vê os dados de posição do dia atual, não um snapshot semanal ou mensal." },
  { q: "O Stacc rastreia posições no pacote local separadamente das posições orgânicas?", a: "Sim. Para empresas locais, o pacote local e o orgânico são superfícies de posicionamento separadas com algoritmos diferentes. O Stacc rastreia ambos de forma independente para que você veja sua posição no Maps/pacote e sua posição orgânica para a mesma palavra-chave — porque elas frequentemente se comportam de forma diferente." },
  { q: "Posso rastrear posições para múltiplas localizações?", a: "Sim. Cada localização tem seu próprio conjunto de palavras-chave rastreadas de forma independente. O painel de portfólio compara todas as localizações lado a lado. Você pode classificar por qualquer métrica para ver instantaneamente quais localizações estão vencendo e quais têm desempenho inferior." },
  { q: "Como o Stacc me alerta quando as posições mudam?", a: "Você pode configurar alertas de mudança de posição que disparam quando qualquer palavra-chave rastreada cruza um limite — por exemplo, quando uma palavra-chave cai para fora do top 3 ou quando uma palavra-chave entra no top 3 pela primeira vez. Os alertas são entregues por e-mail ou notificação no painel." },
  { q: "Os dados de rastreamento de posições alimentam relatórios de clientes?", a: "Sim. Os dados de posição são incluídos nos relatórios automatizados de clientes. Os relatórios são gerados no seu horário e entregues automaticamente — sem exportação manual necessária. Agências podem colocar marca white-label em todos os relatórios com a sua própria marca." },
  { q: "Quanto custa o software de rastreamento de posições?", a: "O rastreamento de posições está incluído no módulo de SEO Local do Stacc a partir de $49/mês. O rastreamento diário de palavras-chave ilimitadas por localização está incluído." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Software de Rastreamento de Posições SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Software de rastreamento de posições locais com atualizações diárias para cada palavra-chave em cada localização. Rastreie posições no pacote local, Maps e orgânico — tudo em um painel.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Software de Rastreamento de Posições", "item": "https://thestacc.com/pt-br/software-rastreamento-posicoes/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de Rastreamento de Posições SEO Local | theStacc"
  description="Rastreie posições no pacote local, Maps e orgânico diariamente para cada palavra-chave em cada localização. O software de rastreamento de posições do theStacc atualiza automaticamente — sem verificações manuais."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de Rastreamento de Posições · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Posições atualizadas diariamente.<br />
            <span style="color:#4f39f6;">Cada palavra-chave. Cada localização. Automaticamente.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc rastreia posições no pacote local, no Maps e no orgânico para cada palavra-chave em cada localização — atualizado diariamente, comparado entre localizações e alertando você no momento em que algo muda.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/funcionalidades/rastreamento-posicoes/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver detalhes do rastreamento de posições
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · Garantia de 30 dias · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLEM NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por que dados diários de posição importam</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Uma queda de posição detectada hoje<br />custa uma fração de uma descoberta em 30 dias.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Uma palavra-chave que cai da posição 3 para a posição 7 perde mais de 50% da sua taxa de cliques da noite para o dia. Se sua ferramenta de rastreamento atualiza semanalmente ou mensalmente, essa queda pode custar quatro semanas de tráfego perdido antes mesmo de você saber que aconteceu. Quando você diagnostica a causa e toma medidas, está se recuperando de um déficit de um mês — não de um dia.</p>
            <p>O rastreamento diário de posições muda o prazo de resposta. Uma mudança de posição que ocorreu ontem pode ser tratada hoje. Você detecta mudanças algorítmicas, mudanças dos concorrentes e quedas de posição no dia 1 — não no dia 30.</p>
            <p class="font-semibold text-[#111827]">E para empresas locais especificamente, a posição no pacote local e no Maps é um sinal diferente do orgânico — e requer monitoramento diferente. O Stacc rastreia ambos separadamente para que você sempre saiba exatamente onde está em cada tipo de posicionamento.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de rastreamento de posições</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada ponto de dado de posição que você precisa.<br />Todos atualizados diariamente.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreamento de pacote local + Maps', body: 'Rastreie sua posição no pacote local 3 do Google e no Maps separadamente do orgânico. Para empresas locais, a posição no pacote gera os cliques de maior intenção.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Atualizações diárias, zero verificações manuais', body: 'As posições são atualizadas automaticamente a cada 24 horas. Abra seu painel toda manhã e veja onde cada palavra-chave está — sem rastreamento manual necessário.' },
            { icon: 'M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2', title: 'Comparação multi-localização', body: 'Veja todas as localizações classificadas lado a lado para qualquer palavra-chave. Identifique em quais mercados você está vencendo e quais precisam de atenção em uma única visualização de portfólio.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Alertas de mudança de posição', body: 'Configure alertas para movimentos significativos de posição — palavras-chave entrando ou saindo do top 3, quedas de 3+ posições, novas palavras-chave chegando à primeira página.' },
            { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Análise de tendência', body: 'Visualizações de tendência de posição de 30, 60 e 90 dias por palavra-chave e localização. Identifique momentum e detecte sinais de alerta precoces de impacto algorítmico.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Dados de posição em relatórios de clientes', body: 'Os dados de posição alimentam diretamente os relatórios automatizados de clientes. Os relatórios são gerados e entregues no seu horário — com marca white-label da sua agência.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreamento em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o Stacc está rastreando<br />enquanto você foca em outra coisa.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Atualizações Diárias Automáticas</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Posições atualizadas todo dia, sem login.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cada palavra-chave rastreada em cada localização recebe uma atualização diária automática. Você abre o painel de manhã e os dados do dia já estão lá — sem precisar acionar uma verificação manual, sem esperar por um relatório semanal. Quando uma posição sobe ou cai, você sabe no mesmo dia que aconteceu, não 30 dias depois.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de SEO local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posições rastreadas — hoje</p>
              {[
                { kw: 'encanador perto de mim', pos: 2, prev: 4, up: true },
                { kw: 'conserto de canos São Paulo', pos: 1, prev: 1, up: false },
                { kw: 'desentupidora emergência', pos: 3, prev: 5, up: true },
                { kw: 'encanador residencial', pos: 7, prev: 6, up: false },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[12px] text-[#374151] flex-1 min-w-0 truncate">{row.kw}</span>
                  <div class="flex items-center gap-2 shrink-0 ml-4">
                    <span class="font-mono text-[13px] font-bold text-[#111827]">#{row.pos}</span>
                    {row.up
                      ? <span class="font-mono text-[10px] text-[#059669]">▲ {row.prev - row.pos}</span>
                      : <span class="font-mono text-[10px] text-[#dc2626]">▼ {row.pos - row.prev}</span>
                    }
                  </div>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Atualizado automaticamente · Sem verificações manuais</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Rastreamento por superfície — "climatização São Paulo"</p>
              {[
                { surface: 'Maps', pos: 2, label: 'Google Maps' },
                { surface: 'Pack', pos: 2, label: 'Pacote Local 3' },
                { surface: 'Orgânico', pos: 11, label: 'Resultado orgânico' },
              ].map(row => (
                <div class="border-t border-[#f5f3ff] py-4">
                  <div class="flex items-center justify-between mb-1">
                    <span class="font-sans text-[12px] font-semibold text-[#111827]">{row.label}</span>
                    <span class="font-mono text-[13px] font-bold text-[#4f39f6]">#{row.pos}</span>
                  </div>
                  <div class="h-1.5 w-full rounded-full bg-[#f5f3ff]">
                    <div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${Math.max(10, 100 - (row.pos - 1) * 8)}%`}></div>
                  </div>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Três superfícies · Um painel</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreamento Completo Local</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Rastreamento de Maps, local pack e orgânico.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Para empresas locais, Maps, pacote local e orgânico são superfícies completamente diferentes com algoritmos distintos. Uma empresa pode estar no top 3 do pacote local mas na página 2 do orgânico — ou vice-versa. O Stacc rastreia as três de forma independente para que você saiba exatamente onde está em cada canal e possa tomar decisões específicas por superfície.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver rastreamento local completo
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alertas Automáticos</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Alertas automáticos de movimentos. Saiba antes de perder tráfego.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Quando uma palavra-chave importante sobe ou cai além de um limite configurável, o Stacc envia um alerta imediato. Você define os limites — top 3, queda de 5 posições, entrada na primeira página — e o sistema monitora todos os dias. Para agências, isso significa detectar problemas nos clientes no dia 1, não quando o cliente liga reclamando.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver alertas automáticos
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Alerta de movimento de posição</p>
              <div class="rounded-xl border border-[#dcfce7] bg-[#f0fdf4] p-4 mb-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="font-mono text-[10px] font-semibold text-[#059669] uppercase tracking-wide">↑ Subida detectada</span>
                  <span class="ml-auto font-mono text-[10px] text-[#79716b]">há 3min</span>
                </div>
                <p class="font-sans text-[13px] font-semibold text-[#111827]">"desentupidora emergência SP"</p>
                <p class="font-mono text-[11px] text-[#57534e] mt-1">Posição <strong>#8</strong> → <strong>#3</strong> no Pacote Local</p>
              </div>
              <div class="rounded-xl border border-[#fee2e2] bg-[#fef2f2] p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="font-mono text-[10px] font-semibold text-[#dc2626] uppercase tracking-wide">↓ Queda detectada</span>
                  <span class="ml-auto font-mono text-[10px] text-[#79716b]">ontem</span>
                </div>
                <p class="font-sans text-[13px] font-semibold text-[#111827]">"encanador bairro Pinheiros"</p>
                <p class="font-mono text-[11px] text-[#57534e] mt-1">Posição <strong>#2</strong> → <strong>#6</strong> no Maps</p>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alertas por e-mail + painel · Limites configuráveis</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
