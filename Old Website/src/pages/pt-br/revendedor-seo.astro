---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é um revendedor SEO?", a: "Um revendedor SEO é uma agência ou consultor que entrega serviços de SEO local a clientes utilizando uma plataforma de terceiros — personalizada com sua própria marca. A agência define seus próprios preços, gerencia os relacionamentos com clientes e entrega resultados por meio da plataforma de revenda sob sua própria identidade." },
  { q: "Como o Stacc funciona como plataforma de revendedor SEO?", a: "Você se cadastra no Stacc, configura as definições white-label (seu logo, domínio, cores) e depois gerencia todo o SEO local dos clientes pelo seu painel personalizado. Os clientes veem a sua marca. Você entrega resultados reais de SEO local — gestão de GBP, rastreamento de posições, citações, avaliações e relatórios — sob o seu nome." },
  { q: "Qual margem posso obter revendendo o Stacc?", a: "O Stacc começa a partir de $49/mês para o módulo de SEO Local. A maioria das agências cobra dos clientes entre $300 e $1.500/mês por serviços de SEO local. A margem entre o seu custo e os preços que você define para os clientes é toda sua." },
  { q: "Os clientes precisam saber que estou usando o Stacc?", a: "Não. White-label significa substituição completa de marca. O seu logo em cada tela, o seu domínio em cada URL, o seu nome em cada relatório. A marca do Stacc nunca aparece em nenhuma parte da experiência do cliente." },
  { q: "Posso gerenciar todos os meus clientes de revenda a partir de uma única conta?", a: "Sim. Uma conta do Stacc cobre todos os seus clientes. Cada cliente recebe seu próprio login com acesso restrito ao seu painel personalizado. Você tem visibilidade administrativa sobre todos os clientes em uma única visão de agência." },
  { q: "Que trabalho contínuo preciso fazer por cliente?", a: "Mínimo. Após a configuração inicial (conectar GBP, definir palavras-chave, configurar relatórios), o Stacc automatiza o trabalho contínuo: publicação no GBP, rastreamento de posições, monitoramento de citações, alertas de avaliações e entrega de relatórios — automaticamente. O seu trabalho por cliente se reduz a supervisão estratégica, não a execução diária." },
  { q: "Posso oferecer revenda de SEO local sem uma equipe de SEO existente?", a: "Sim. A automação do Stacc cuida da execução que normalmente exigiria um especialista em SEO por cliente. Muitos operadores individuais e pequenas agências usam o Stacc para oferecer serviços de SEO local sem uma equipe de SEO dedicada internamente." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Plataforma de Revendedor SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Plataforma de revendedor SEO white-label. Entregue resultados de SEO local a clientes sob a marca da sua agência. Automação completa, white-label completo, marca Stacc zero visível.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Revendedor SEO", "item": "https://thestacc.com/pt-br/revendedor-seo/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Programa de Revendedor SEO | theStacc"
  description="Revenda serviços de SEO local sob a marca da sua agência. O theStacc é uma plataforma completa de revendedor SEO white-label — entrega automatizada, painéis personalizados, marca Stacc zero visível."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Revendedor SEO · SEO Local White-Label · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Revenda serviços de SEO local<br />
            <span style="color:#4f39f6;">totalmente sob a sua marca.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc é a plataforma de SEO local white-label que permite entregar resultados a clientes sob a sua própria marca. Automação completa, painéis personalizados, relatórios automatizados — e o Stacc nunca aparece em nada que os clientes vejam.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/solucoes/agencias/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funcionalidades para agências
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · 30 dias de garantia · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona a revenda de SEO com o Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Você vende. O Stacc entrega.<br />Os clientes veem a sua marca o tempo todo.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>A economia de um negócio de revendedor SEO funciona quando o custo por cliente é baixo e a entrega é automatizada. Clientes de SEO local normalmente pagam entre $300 e $1.500/mês. O módulo de SEO Local do Stacc começa a partir de $49/mês por conta, sem taxas por cliente além da contagem de localizações. A margem entre o seu custo e os preços que você define para os clientes fica com você.</p>
            <p>O modelo operacional é direto: você incorpora um cliente (conecta GBP, define palavras-chave, configura relatórios) e, a partir desse ponto, o Stacc cuida da execução contínua — posts no GBP, rastreamento de posições, monitoramento de citações, alertas de avaliações e entrega de relatórios — automaticamente. O seu tempo por cliente cai para supervisão estratégica e respostas ocasionais a avaliações. Você escala adicionando clientes, não contratações.</p>
            <p class="font-semibold text-[#111827]">E como tudo é white-label, os seus clientes o vivenciam como sua plataforma exclusiva. Eles nunca sabem que o Stacc existe. O relacionamento, o valor de marca e a margem são inteiramente seus.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades da plataforma de revendedor</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tudo que um revendedor de SEO local<br />precisa em uma única plataforma.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'White-label completo', body: 'Seu domínio, seu logo, suas cores em tudo voltado ao cliente. A marca do Stacc completamente invisível. $0 por login de cliente.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automação de GBP por cliente', body: '30 posts no GBP por mês por localização do cliente, publicados automaticamente. Perfis permanecem ativos sem nenhum trabalho seu ou dos clientes.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreamento de posições para todos os clientes', body: 'Posições diárias para cada cliente no pacote local, Maps e orgânico. Os painéis dos clientes mostram apenas os dados deles — o seu admin vê tudo.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Relatórios automatizados para clientes', body: 'Relatórios personalizados gerados e entregues aos clientes conforme o seu calendário. Sem exportação manual, sem formatação, sem esquecer o relatório mensal de um cliente.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Gestão de citações', body: 'Monitoramento e correção de citações para cada localização do cliente em mais de 50 diretórios. Fator de posicionamento local de alto impacto gerenciado automaticamente.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Gerenciamento de múltiplos clientes', body: 'Visão completa do portfólio de todos os seus clientes de revenda. Veja o desempenho de cada cliente, configure novos clientes rapidamente e gerencie tudo em um único painel admin.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Revendedor em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o Stacc entrega para<br />o seu negócio de revenda.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">White-Label Completo</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sua marca. Em cada tela.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Quando seus clientes fazem login, eles veem o seu logo, o seu domínio e as suas cores. Não existe nenhuma referência ao Stacc em nenhuma tela voltada ao cliente — nem nos relatórios, nem nos e-mails, nem no painel. O cliente experimenta a plataforma como se fosse sua, exclusivamente. Isso constrói equity de marca para a sua agência a cada interação, enquanto o Stacc cuida de toda a execução em segundo plano.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver white-label para agências
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
