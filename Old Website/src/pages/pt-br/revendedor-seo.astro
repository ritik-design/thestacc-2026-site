              <div class="mb-4 flex items-center gap-3 rounded-xl border border-[#e7e5e4] bg-[#f5f3ff] px-4 py-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#4f39f6]">
                  <span class="font-mono text-[10px] font-bold text-white">AG</span>
                </div>
                <div>
                  <p class="font-sans text-[12px] font-semibold text-[#111827]">Agência Digital Pro</p>
                  <p class="font-mono text-[10px] text-[#79716b]">seo.agenciadigitalpro.com.br</p>
                </div>
                <span class="ml-auto font-mono text-[10px] text-[#059669]">● Ao vivo</span>
              </div>
              {[
                { label: 'Posição média no Maps', value: '#2,4', change: '↑ 1,8' },
                { label: 'Posts no GBP este mês', value: '30/30', change: '✓ Completo' },
                { label: 'Citações verificadas', value: '50/50', change: '✓ Corretas' },
                { label: 'Novas avaliações', value: '7', change: '★ 4,8 média' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">{row.label}</span>
                  <div class="text-right">
                    <span class="font-sans text-[12px] font-semibold text-[#111827]">{row.value}</span>
                    <span class="ml-2 font-mono text-[10px] text-[#059669]">{row.change}</span>
                  </div>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Stacc invisível · Sua marca em tudo</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Margem de revenda — exemplo por cliente</p>
              <div class="space-y-3">
                <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">Custo da plataforma Stacc</span>
                  <span class="font-mono text-[12px] font-semibold text-[#6b7280]">$49/mês</span>
                </div>
                <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">Preço cobrado do cliente</span>
                  <span class="font-mono text-[12px] font-semibold text-[#111827]">$500/mês</span>
                </div>
                <div class="flex items-center justify-between rounded-xl border-2 border-[#4f39f6] bg-[#f5f3ff] px-4 py-3">
                  <span class="font-sans text-[12px] font-semibold text-[#4f39f6]">Margem por cliente</span>
                  <span class="font-mono text-[13px] font-bold text-[#4f39f6]">$451/mês</span>
                </div>
                <div class="pt-2 border-t border-[#e7e5e4]">
