---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "O que é software de SEO local?",
    a: "Software de SEO local ajuda empresas a gerenciar os sinais que determinam como elas aparecem nas buscas locais — incluindo atividade no Google Business Profile, classificações de palavras-chave no pacote local e no Google Maps, consistência de citações em diretórios e avaliações de clientes. O Stacc automatiza todas essas tarefas em uma plataforma para que empresas locais e agências não precisem gerenciá-las manualmente.",
  },
  {
    q: "O que o Stacc faz que um rastreador de posições básico não faz?",
    a: "A maioria dos rastreadores de posições apenas monitora posições. O Stacc também publica no seu Google Business Profile diariamente, monitora e alerta sobre avaliações em tempo real, gerencia citações em mais de 50 diretórios e gera relatórios white-label para clientes que se entregam sozinhos. É um sistema operacional completo de SEO local — não apenas um painel de dados.",
  },
  {
    q: "O Stacc funciona para empresas com múltiplas localizações?",
    a: "Sim — o gerenciamento multi-localização é uma das capacidades centrais do Stacc. Gerencie todas as localizações em um painel, publique posts para todas simultaneamente e gere relatórios individuais ou consolidados para cada localização. Não há limite prático de quantas localizações você pode adicionar.",
  },
  {
    q: "O Stacc foi criado para agências ou equipes de marketing interno?",
    a: "Para ambos. Agências obtêm relatórios white-label, gerenciamento de contas de múltiplos clientes e portais de clientes com marca personalizada. Equipes internas de empresas multi-localização obtêm ferramentas de gerenciamento em massa e relatórios automatizados para stakeholders internos. A mesma plataforma serve ambos os fluxos de trabalho.",
  },
  {
    q: "Como o Stacc é diferente de gerenciar SEO local manualmente?",
    a: "SEO local manual significa fazer login em ferramentas separadas para posições, GBP, citações e avaliações — depois montar relatórios à mão todo mês. O Stacc conecta tudo isso em um sistema automatizado. Os dados fluem automaticamente. Os relatórios são gerados e enviados automaticamente. Você foca na estratégia. O Stacc cuida da execução.",
  },
  {
    q: "Quanto tempo leva para configurar o Stacc para uma nova localização ou cliente?",
    a: "A maioria das configurações é concluída em menos de 5 minutos — localizações adicionadas, palavras-chave configuradas, GBP conectado e relatórios automatizados agendados. Para clientes com mais de 10 localizações, calcule uma hora. Após a configuração, o Stacc cuida de tudo continuamente sem tempo adicional da sua equipe.",
  },
  {
    q: "O Stacc inclui relatórios white-label para agências?",
    a: "Sim. Relatórios white-label — com seu logo, cores da marca e domínio personalizado — estão disponíveis nos planos Growth e Scale. Os relatórios são entregues com a sua marca. Não há nenhuma marca do Stacc visível para seus clientes.",
  },
  {
    q: "Quais integrações o Stacc suporta?",
    a: "O Stacc integra com Google Business Profile, Google Search Console, Google Analytics, Facebook, Instagram, WordPress, Webflow, Ghost e Wix. Todas as integrações estão incluídas — sem taxas por integração.",
  },
  {
    q: "Posso cancelar a qualquer momento?",
    a: "Sim. Sem contratos. Sem taxas de cancelamento. Exporte todo o histórico de dados a qualquer momento antes de cancelar. Seus dados pertencem a você.",
  },
  {
    q: "Quanto custa o Stacc?",
    a: "Os planos começam a partir de $49/mês para o módulo de SEO Local. O módulo Blog SEO é $99/mês. O módulo de Redes Sociais é $49/mês. Todos os módulos incluem um período de teste gratuito de 14 dias a partir de $1.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software de SEO Local",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "Software de SEO local que automatiza gerenciamento de GBP, rastreamento de posições, monitoramento de citações, gerenciamento de avaliações e relatórios para empresas locais e agências.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Módulo de SEO Local — teste de 14 dias a partir de $1"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Software de SEO Local", "item": "https://thestacc.com/pt-br/software-seo-local/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Software de SEO Local — Automatize GBP, Citações e Avaliações | theStacc"
  description="O theStacc é o software de SEO local que faz o trabalho — não apenas rastreia. Gerenciamento de GBP, rastreamento de posições, monitoramento de citações e relatórios automatizados no piloto automático."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de SEO Local · A partir de $49/mês</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local que<br />faz o trabalho por você.
            <span style="color:#4f39f6;"> Não apenas rastreia.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            A maioria das ferramentas de SEO local oferece painéis. O Stacc oferece automação. Google Business Profile, rastreamento de posições, gerenciamento de citações, monitoramento de avaliações e relatórios white-label — tudo funcionando automaticamente em cada localização.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver o que está incluído
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sem cartão de crédito para começar · Garantia de 30 dias · Cancele quando quiser
          </p>

          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">+1.200 localizações gerenciadas</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuração em menos de 5 minutos</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema com a maioria das ferramentas de SEO local</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Você já tentou as ferramentas.<br />Ainda está fazendo o trabalho.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Talvez você tenha um rastreador de posições. Talvez uma ferramenta de citações. Talvez algo para avaliações. E talvez você tenha conectado tudo com planilhas e mensagens no Slack e um ritual semanal de fazer login em cinco plataformas diferentes para montar um relatório que levou três horas e parecia ter levado quinze minutos.
            </p>
            <p>
              Esse é o segredo sujo da maioria dos softwares de SEO local: <strong class="text-[#111827]">eles rastreiam coisas. Não fazem coisas.</strong> Você ainda faz as coisas. O software apenas oferece uma visão mais bonita de quanto trabalho você tem a fazer.
            </p>
            <p>
              Veja o que isso custa. Cada verificação manual de posições são 45 minutos que você não está faturando. Cada auditoria de citações são duas horas do dia de alguém. Cada relatório de cliente é um imposto sobre sua sexta-feira à tarde. Multiplique isso por 20 clientes, 50 localizações, 12 meses — e você gastou um ano fazendo trabalho que deveria ser automatizado.
            </p>
            <p class="font-semibold text-[#111827]">
              Seus concorrentes estão automatizando isso. Eles estão atendendo mais clientes, escalando mais rápido e parecendo mais profissionais — não porque são mais inteligentes, mas porque pararam de fazer manualmente o que o software deveria fazer automaticamente.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Uma plataforma. Cada alavanca de SEO local.<br />Tudo automatizado.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Local', price: '$49/mês', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Publicação de posts no GBP — 30/mês', 'Rastreamento diário de posições — pacote local + orgânico', 'Monitoramento de avaliações — alertas em tempo real', 'Gerenciamento de citações — +50 diretórios'], href: '/pt-br/modulos/seo-local/' },
            { title: 'Blog SEO', price: '$99/mês', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 posts de blog SEO/mês', 'Publicados diretamente no seu site', 'Pesquisa de palavras-chave incluída', 'Links internos otimizados'], href: '/pt-br/modulos/seo-conteudo/' },
            { title: 'Redes Sociais', price: '$49/mês', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Posts diários com imagens', 'Instagram, LinkedIn, Facebook, X', 'Escritos e agendados automaticamente', 'Conteúdo consistente com a marca'], href: '/pt-br/modulos/redes-sociais/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Saiba mais</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades principais</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarefa de SEO local automatizada.<br />Cada resultado visível.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automação de Posts no GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 posts no GBP por mês. Publicados automaticamente. Direcionando buscas que geram ligações.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O algoritmo do Google Maps recompensa empresas que postam de forma consistente com maior visibilidade no pacote local. O Stacc escreve 30 posts otimizados por localização por mês — direcionando suas combinações de palavra-chave serviço + cidade, intenção "perto de mim", buscas de emergência e tópicos sazonais — e os publica no horário certo. Seu perfil permanece ativo todos os dias. Você não toca nele.
              </p>
              <a href="/pt-br/modulos/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver o módulo de SEO Local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posts GBP deste mês</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 20 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Posts publicados até agora</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">20 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:66%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">10 agendados · Todos automatizados · Zero trabalho manual</p>
            </div>
          </div>

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Atualização de posições de hoje</p>
              {[
                { kw: 'dentista perto de mim', pack: 1, change: '+2', trend: 'up' },
                { kw: 'dentista de emergência [cidade]', pack: 2, change: '+1', trend: 'up' },
                { kw: 'clareamento dental perto de mim', pack: 3, change: '+4', trend: 'up' },
                { kw: 'implante dentário [cidade]', pack: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Atualizado diariamente · Pacote local + orgânico + Maps</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreamento Diário de Posições</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Saiba onde você se posiciona — no pacote local, no Maps e no orgânico — toda manhã.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                As posições são atualizadas diariamente em cada palavra-chave rastreada em cada localização. Você vê sua posição nos resultados orgânicos e no pacote local 3 separadamente — porque para empresas locais, o pacote 3 é onde quase todos os cliques de alta intenção realmente chegam. Alertas disparam automaticamente quando as posições mudam significativamente, para que você sempre saiba antes do seu cliente.
              </p>
              <a href="/pt-br/funcionalidades/rastreamento-posicoes/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver rastreamento de posições em detalhe
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Relatórios White-Label Automatizados</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Relatórios que se criam e enviam sozinhos. Cada cliente. Toda semana. Com a sua marca.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O momento em que você para de criar relatórios manualmente é o momento em que começa a escalar. Configure seu modelo uma vez por cliente. O Stacc gera o relatório, formata com a marca da sua agência e o entrega na caixa de entrada do cliente no horário certo. Ninguém da sua equipe toca nele. Isso não é apenas uma economia de tempo — é o que permite dobrar sua base de clientes sem dobrar sua equipe.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agências
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
