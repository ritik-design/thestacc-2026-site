---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é software para Google Business Profile?", a: "Software para Google Business Profile ajuda empresas a gerenciar seus perfis GBP com mais eficiência — publicando posts, respondendo avaliações, atualizando horários e atributos, e monitorando o desempenho — especialmente em múltiplas unidades onde o gerenciamento manual se torna impraticável." },
  { q: "Como o Stacc ajuda no gerenciamento do Google Business Profile?", a: "O Stacc automatiza a publicação de posts no GBP (30 posts por mês por unidade), monitora avaliações em tempo real, sinaliza edições sugeridas antes de serem aplicadas e rastreia sinais de desempenho do GBP. Para negócios com múltiplas unidades, tudo isso acontece em todas as unidades simultaneamente a partir de um único painel." },
  { q: "Publicar no GBP realmente melhora o posicionamento no Google Maps?", a: "Sim. A atividade regular de posts no GBP é um sinal de posicionamento local documentado. O Google trata a publicação consistente como um indicador de uma empresa ativa e legítima — o que se correlaciona com maior visibilidade no pacote local e no Maps. Empresas que publicam de forma consistente apresentam melhorias de posicionamento mensuráveis comparadas às suas baselines de perfil inativo." },
  { q: "Posso publicar posts em massa no GBP para várias unidades?", a: "Sim. Escreva um post, selecione todas as unidades ou um grupo específico, e publique simultaneamente. Personalizações específicas por unidade (endereço, telefone, hashtags locais) podem ser adicionadas por unidade antes da publicação em massa." },
  { q: "Como o Stacc lida com edições sugeridas no GBP?", a: "O Stacc monitora seus perfis GBP para edições sugeridas por terceiros e alerta você antes de serem aplicadas. Você pode aprovar, rejeitar ou modificar as edições sugeridas pelo painel sem fazer login em cada GBP individualmente." },
  { q: "O Stacc consegue gerenciar GBP para empresas com mais de 100 unidades?", a: "Sim. Não há limite prático de unidades. As operações em massa funcionam de forma idêntica se você tiver 10 ou 500 unidades. As mesmas ferramentas de gerenciamento GBP que funcionam para 10 unidades funcionam para 500 — você apenas seleciona mais unidades antes de aplicar a ação." },
  { q: "Quanto custa o software para GBP?", a: "O módulo de SEO Local do Stacc — que inclui gerenciamento completo do GBP — começa em $49/mês com teste grátis de 14 dias." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Software para Google Business Profile", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Software para Google Business Profile que automatiza a publicação de posts, monitoramento de avaliações e gerenciamento de perfis em todas as unidades simultaneamente.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Software Google Business Profile", "item": "https://thestacc.com/pt-br/software-google-business-profile/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software para Google Business Profile — Automatize Seu GBP | theStacc"
  description="Automatize o gerenciamento do Google Business Profile em todas as unidades. O theStacc publica 30 posts por mês, monitora avaliações e gerencia perfis — sem logins manuais."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software para Google Business Profile · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            GBP gerenciado automaticamente.<br />
            <span style="color:#4f39f6;">Toda unidade. Todo dia.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc publica 30 posts no GBP por mês por unidade, monitora avaliações em tempo real e gerencia seus perfis em todas as unidades — sem nenhum login manual.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/integracoes/google-business-profile/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver integração GBP
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · Garantia de 30 dias · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLEM SECTION -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por que o gerenciamento do GBP precisa de software</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perfis GBP inativos perdem posições.<br />O gerenciamento manual não acompanha.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>O algoritmo de posicionamento local do Google recompensa perfis GBP ativos. Publicação regular de posts, respostas rápidas a avaliações e informações atualizadas na listagem contribuem para a visibilidade no pacote local e no Maps. Pare de postar por três semanas e sua pontuação de atividade cai. Deixe avaliações sem resposta e seus sinais de taxa de resposta caem. Deixe um horário de funcionamento desatualizado no perfil e você cria uma inconsistência de confiança que prejudica seu posicionamento.</p>
            <p>Manter um GBP ativo para uma unidade dá 3 a 4 horas de trabalho por semana. Para 20 unidades, são 80 horas. O software para GBP elimina esse trabalho automatizando a execução — não apenas mostrando o que precisa ser feito, mas realmente fazendo.</p>
            <p class="font-semibold text-[#111827]">O Stacc publica posts, monitora avaliações, observa edições não autorizadas e mantém seus perfis GBP consistentemente ativos — para que seus perfis nunca fiquem quietos, mesmo quando você não está de olho.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de gerenciamento do GBP</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Toda tarefa do GBP automatizada.<br />Toda unidade coberta.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: '30 posts no GBP por mês, automatizados', body: 'O Stacc escreve e publica 30 posts por unidade por mês segmentando suas combinações de palavras-chave serviço + localidade. Os perfis ficam ativos todos os dias, automaticamente.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitoramento de avaliações em tempo real', body: 'Novas avaliações aparecem instantaneamente no seu painel. Responda diretamente sem fazer login no GBP. Rastreie taxas de resposta e pontuação média por unidade.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Monitoramento de edições não autorizadas', body: 'Edições sugeridas por terceiros nos seus perfis são sinalizadas antes de serem aplicadas. Aprove, rejeite ou modifique pelo painel — nunca perca uma alteração não autorizada.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Atualizações em massa de perfis', body: 'Atualize horários, descrições, atributos e categorias em todas as unidades simultaneamente. Sem logins individuais no GBP de cada unidade.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Rastreamento de desempenho do GBP', body: 'Rastreie visualizações, cliques, solicitações de chamada e pedidos de rotas por unidade ao longo do tempo. Veja quais atividades do GBP se correlacionam com mudanças de desempenho.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Gerenciamento de perguntas e respostas', body: 'Monitore e gerencie a seção de perguntas e respostas de cada perfil GBP. Garanta que respostas precisas sejam visíveis para os pesquisadores antes que encontrem informações incorretas.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o Stacc está fazendo<br />no seu GBP enquanto você foca em outra coisa.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicação automática de posts GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 posts no GBP por mês, no piloto automático.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O Stacc gera e publica 30 posts por unidade por mês no Google Business Profile — segmentando suas combinações de palavras-chave serviço + localidade, tópicos sazonais e pesquisas de alta intenção. Os posts são publicados no horário agendado, todos os dias, sem que ninguém da sua equipe precise fazer login. Seu perfil fica ativo e relevante para o algoritmo local do Google de forma consistente.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de posts GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendário de posts GBP — abril</p>
              {[
                { day: 'Seg 1', post: 'Serviço de encanamento em São Paulo — disponível hoje', ok: true },
                { day: 'Qua 3', post: 'Encanador de emergência 24h em SP', ok: true },
                { day: 'Sex 5', post: 'Desentupimento rápido — São Paulo e região', ok: true },
                { day: 'Seg 8', post: 'Instalação de aquecedor em SP — orçamento grátis', ok: true },
                { day: 'Qua 10', post: 'Manutenção de encanamento residencial SP', ok: true },
              ].map(item => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-2.5">
                  <span class="font-mono text-[10px] text-[#79716b] shrink-0 w-12">{item.day}</span>
                  <p class="font-sans text-[12px] text-[#374151] flex-1 min-w-0 truncate">{item.post}</p>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 posts/mês · Publicados automaticamente</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Alertas de avaliações — todas as unidades</p>
              {[
                { stars: 5, text: '"Serviço excelente. Chegaram na hora marcada."', platform: 'Google', time: 'há 15min', alerted: true },
                { stars: 4, text: '"Muito bom, resolveram o problema rapidinho."', platform: 'Google', time: 'há 2h', alerted: true },
                { stars: 3, text: '"Razoável, mas o preço poderia ser menor."', platform: 'Yelp', time: 'há 5h', alerted: true },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center gap-2 mb-1">
                    <div class="flex gap-0.5">
                      {Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
                    </div>
                    <span class="font-mono text-[10px] text-[#79716b]">{r.platform} · {r.time}</span>
                    {r.alerted && <span class="ml-auto font-mono text-[10px] text-[#059669]">✓ Alertado</span>}
                  </div>
                  <p class="font-sans text-[12px] text-[#57534e] italic">{r.text}</p>
                  <div class="mt-2 flex gap-2">
                    <button class="rounded-lg border border-[#e7e5e4] px-2.5 py-1 font-mono text-[10px] text-[#4f39f6]">Responder agora</button>
                    <button class="rounded-lg border border-[#e7e5e4] px-2.5 py-1 font-mono text-[10px] text-[#79716b]">Usar template</button>
                  </div>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Monitoramento de avaliações</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Monitoramento de avaliações em tempo real.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O Stacc monitora todas as plataformas de avaliações em todas as suas unidades em tempo real e dispara alertas no momento em que uma nova avaliação aparece — para que você possa responder enquanto ainda é relevante. Templates de resposta rápida estão prontos no painel. Para múltiplas unidades, o feed unificado significa que você vê cada avaliação de cada localização sem acessar 20 GBPs diferentes.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver monitoramento de avaliações
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Monitoramento de citações</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Consistência de citações em 50+ diretórios.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Dados NAP inconsistentes em diretórios locais prejudicam seu posicionamento no Google Maps — muitas vezes sem você saber. O Stacc monitora suas citações em mais de 50 diretórios continuamente, detecta inconsistências e as corrige automaticamente. Um endereço errado no Yelp ou um número de telefone desatualizado no Foursquare não vai passar despercebido.
              </p>
              <a href="/pt-br/software-construcao-citacoes/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver gerenciamento de citações
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Status de citações — 50+ diretórios</p>
              {[
                { dir: 'Google Business Profile', status: 'Consistente', ok: true },
                { dir: 'Yelp', status: 'Consistente', ok: true },
                { dir: 'Facebook', status: 'Consistente', ok: true },
                { dir: 'Apple Maps', status: 'Consistente', ok: true },
                { dir: 'Foursquare', status: 'Consistente', ok: true },
              ].map(item => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.dir}</p>
                  <span class="font-mono text-[11px] text-[#059669]">✓ {item.status}</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Monitoramento contínuo · Autocorreção ativa</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
