---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const faqs = [
  {
    q: "O Google penaliza publicações automáticas no Google Meu Negócio?",
    a: "Não. As próprias diretrizes do Google incentivam atividade regular no Google Meu Negócio. Publicações, atualizações, fotos e respostas. O Stacc publica conteúdo que segue as melhores práticas do GMN: relevante, local e variado. Nossos clientes publicam 30 vezes por mês sem uma única suspensão de perfil ou penalização de ranking.",
  },
  {
    q: "Quanto tempo até aparecer mais alto no Maps?",
    a: "A maioria dos clientes vê movimento significativo no Maps em 60–90 dias de atividade constante no Google Meu Negócio. O algoritmo local do Google recompensa frequência, relevância e engajamento. Os três são entregues pelo Stacc automaticamente todo mês. Os negócios que veem resultados mais rápido são os que antes publicavam zero.",
  },
  {
    q: "E se eu tiver várias unidades?",
    a: "Cada unidade recebe seu próprio conteúdo personalizado. Publicações direcionadas à cidade, serviços e palavras-chave específicas daquela localização. Tudo gerenciado a partir de um único painel. Adicione quantas unidades quiser e o Stacc trata cada uma como uma entidade local independente.",
  },
  {
    q: "Posso revisar as publicações antes de serem publicadas?",
    a: "Sim. Cada publicação está disponível em uma fila de revisão antes de ir ao ar. Aprove, edite ou ative a publicação automática. A maioria dos clientes revisa os primeiros lotes e depois muda para publicação automática ao comprovar a qualidade do conteúdo. Depois disso, as publicações simplesmente aparecem no seu perfil do GMN conforme o calendário.",
  },
  {
    q: "O que inclui o monitoramento de avaliações?",
    a: "Alertas instantâneos no momento em que uma nova avaliação aparece no seu Google Meu Negócio. Positiva ou negativa. Acompanhamento da tendência de nota semana a semana. Modelos de resposta para tipos comuns de avaliações para que você possa responder em menos de um minuto. Todas as avaliações visíveis em um único painel em todas as suas unidades.",
  },
  {
    q: "Como isso é diferente de outras ferramentas de SEO local?",
    a: "Ferramentas empresariais de SEO local são criadas para grandes redes. Custam R$1.500–R$4.000/mês e exigem onboarding e contratos longos. O Stacc é construído para negócios locais: $49/mês, configuração em minutos, sem contratos. Além disso, geramos automaticamente o conteúdo do seu GMN. Outras ferramentas exigem que você escreva suas próprias publicações.",
  },
];
---

<BaseLayout
  title="Módulo SEO Local | theStacc | Domine o Google Maps por $49/mês"
  description="Stacc publica no seu Google Meu Negócio todo dia, gerencia suas avaliações e rastreia sua posição no Maps. Tudo automaticamente. Comece por $1."
  lang="pt-BR"
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Módulo SEO Local · $49/mês</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Alguém acabou de buscar "[serviço] perto de mim".<br />
            <span style="color:#4f39f6;">Seu concorrente apareceu.<br />Você não.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc publica no seu Google Meu Negócio todo dia, monitora suas avaliações e rastreia sua posição no Maps. Tudo automaticamente. Mais atividade significa maior visibilidade. Maior visibilidade significa mais ligações.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Ver como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem cartão de crédito · Publicações no seu GMN para sempre
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '2.800+', num: 2800, prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Publicações no GMN por mês' },
              { value: '340+',   num: 340,  prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Negócios locais' },
              { value: '4,7×',   num: 4.7,  prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Melhora média de posição no Maps' },
              { value: '0',      num: 0,    prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Avaliações perdidas' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negócios locais posicionados com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            "Perto de mim" é a busca local mais valiosa.<br />Você é invisível para ela.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">O Google recompensa perfis ativos. Você publicou duas vezes no mês passado.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">O algoritmo do Maps favorece negócios que publicam de forma consistente, respondem avaliações e se mantêm ativos. Cada semana que você some, um concorrente que publica diariamente ganha terreno que vai levar meses para recuperar.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação negativa sem resposta pode custar clientes por meses.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">88% dos clientes locais leem avaliações antes de ligar. Uma avaliação de 1 estrela sem resposta por uma semana diz a todos os outros que você não se importa. Sua nota é sua reputação na rua. Merece atenção diária.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você não sabe onde aparece nas buscas "perto de mim".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Sua posição no Maps para "encanador perto de mim" em um bairro é completamente diferente de outro a dois quilômetros. Sem rastreamento, você voa às cegas. E provavelmente está perdendo ligações que nem sabe que está perdendo.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia sua presença<br />no Maps a partir daí.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sem entrar no GMN. Sem escrever publicações. Sem revisar avaliações manualmente. Configure uma vez e seu Google Meu Negócio se gerencia sozinho. Todo dia.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Conecte seu Google Meu Negócio</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Encontre seu negócio por nome e localização. O Stacc obtém seus dados atuais do GMN, histórico de avaliações e posição de ranking. E identifica exatamente para quais palavras-chave você não está aparecendo.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">A IA cria seu plano de conteúdo local</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 publicações otimizadas por localização por mês. Direcionadas às suas palavras-chave de serviço + cidade, intenção "perto de mim", temas sazonais e ofertas que combinam com seu tipo de negócio. Tudo escrito para potencializar os sinais do Maps.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">As publicações vão ao ar. Os rankings sobem. Você não faz nada.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">O conteúdo é publicado no seu GMN conforme o calendário todo mês. Os alertas de avaliações chegam no instante em que uma nova aparece. Seu relatório de posição no Maps é atualizado mensalmente. Seu perfil se fortalece enquanto você gerencia seu negócio.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── WHY STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por que o Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            A única opção que faz todo o trabalho.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Rankear no Maps exige atividade constante no GMN, respostas rápidas a avaliações e conteúdo direcionado por palavras-chave. Todo mês, sem falhar. Nenhuma outra opção entrega os três sem o seu tempo nem um grande orçamento.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-4 bg-[#f5f3ff] px-0">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Agência de SEO Local</div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Por conta própria</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Stacc</div>
          </div>
          {[
            { label: 'Custo mensal',                              agency: 'R$1.500+',    diy: 'Seu tempo', stacc: '$49'    },
            { label: 'Publicações no GMN por mês',                agency: '8–12',        diy: '2–3',        stacc: '30'     },
            { label: 'Segmentação por palavras-chave locais',     agency: '✓',           diy: '✗',          stacc: '✓'      },
            { label: 'Monitoramento de avaliações',               agency: '✓',           diy: 'Manual',     stacc: '✓'      },
            { label: 'Rastreamento de posição local',             agency: '✓',           diy: '✗',          stacc: '✓'      },
            { label: 'Tempo exigido de você',                     agency: 'Algum',       diy: 'Alto',       stacc: 'Nenhum' },
          ].map((row, i) => (
            <div class={`grid grid-cols-4 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.agency}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.diy}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.stacc}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/pt-br/demo/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
          >
            Comece por $1 hoje
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>


    <!-- ─── FEATURE 1: GMN POSTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
          <div>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicações no GMN</span>
