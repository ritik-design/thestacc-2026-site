---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é uma ferramenta de automação de redes sociais?", a: "Uma ferramenta de automação de redes sociais agenda, publica e gerencia posts de redes sociais sem exigir execução manual a cada vez. Para negócios locais, a automação mais impactante é publicar no Google Business Profile, Facebook e Instagram em múltiplas unidades simultaneamente." },
  { q: "Quais plataformas o Stacc automatiza?", a: "O Stacc automatiza a publicação no Google Business Profile, páginas do Facebook Business e contas do Instagram Business. Os posts podem ser publicados em uma plataforma ou nas três simultaneamente a partir de um único fluxo de trabalho." },
  { q: "O Stacc pode publicar em várias unidades ao mesmo tempo?", a: "Sim. A publicação em massa em múltiplas unidades é uma funcionalidade central. Escreva um post, selecione todas as unidades, e o Stacc publica nos perfis de cada unidade selecionada simultaneamente — em todas as plataformas conectadas." },
  { q: "A automação de redes sociais realmente melhora o posicionamento no GBP?", a: "Sim. A atividade regular de posts no GBP é um sinal de posicionamento local documentado. A publicação consistente mantém sua pontuação de atividade do perfil alta, o que se correlaciona com melhor visibilidade no pacote local. A publicação automatizada e consistente supera a publicação manual esporádica em termos de impacto no posicionamento do GBP." },
  { q: "Posso agendar conteúdo com semanas de antecedência?", a: "Sim. O calendário de conteúdo permite agendar posts com a antecedência que desejar. Você também pode definir uma agenda de publicação recorrente e o Stacc publicará automaticamente nessa cadência — diária, semanal ou personalizada." },
  { q: "A automação de redes sociais está incluída no módulo de SEO Local?", a: "A automação de posts no GBP está incluída no módulo de SEO Local ($49/mês). O agendamento para Facebook e Instagram faz parte do módulo de Redes Sociais ($49/mês), que também inclui gerenciamento completo do calendário de conteúdo." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Ferramenta de Automação de Redes Sociais", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Ferramenta de automação de redes sociais para negócios locais. Agende e publique posts no GBP, Facebook e Instagram em todas as unidades simultaneamente.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Ferramenta de Automação de Redes Sociais", "item": "https://thestacc.com/pt-br/ferramenta-automacao-redes-sociais/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Ferramenta de Automação de Redes Sociais para Negócios Locais | theStacc"
  description="Automatize a publicação em redes sociais em todas as unidades. O theStacc publica no GBP, Facebook e Instagram simultaneamente — publicação em massa, calendário e entrega agendada."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Automação de Redes Sociais · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Publique em todas as unidades de uma vez.<br />
            <span style="color:#4f39f6;">GBP, Facebook, Instagram. Automatizado.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Escreva uma vez. O Stacc publica no Google Business Profile, Facebook e Instagram em todas as suas unidades simultaneamente — no horário agendado, com personalização por unidade, sem trabalho manual por unidade.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver o que é automatizado
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · Garantia de 30 dias · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por que a publicação manual não funciona em escala</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Copiar e colar posts em 20 unidades<br />significa que a maioria fica sem publicação.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Para uma unidade, a publicação manual em redes sociais é gerenciável. Para cinco, é irritante. Para vinte, simplesmente não acontece — não de forma consistente. Então algumas unidades recebem posts, a maioria não, e as que ficam em silêncio começam a perder terreno no posicionamento do GBP para concorrentes que continuaram publicando. A lacuna de publicação se acumula: uma vez que você está atrás na atividade do GBP, recuperar o status de ativo leva tempo que você não tem.</p>
            <p class="font-semibold text-[#111827]">A automação de redes sociais para negócios locais não é um luxo — é a única forma de manter uma publicação consistente em escala. O Stacc escreve os posts, os agenda e publica em todas as unidades e plataformas simultaneamente. Seus perfis ficam ativos todos os dias sem nenhuma ação manual.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de automação</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Toda tarefa de publicação social automatizada.<br />Toda unidade coberta.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', title: 'GBP, Facebook, Instagram', body: 'Publique nas três plataformas simultaneamente a partir de um único fluxo de trabalho. Ou segmente plataformas específicas por post. Uma ação cobre todos os canais.' },
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Publicação em massa para múltiplas unidades', body: 'Selecione todas as unidades ou um grupo específico e publique simultaneamente. 20 unidades atualizadas no tempo que antes levava para publicar em 1.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Gerenciamento de calendário de conteúdo', body: 'Planeje e agende semanas ou meses de conteúdo em uma única sessão. Configure agendamentos recorrentes e o Stacc publica automaticamente na sua cadência.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Personalização por unidade', body: 'Substitua detalhes específicos por unidade — endereço, telefone, hashtags locais — antes da publicação em massa. O conteúdo principal permanece consistente; os detalhes locais são localizados.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Alertas de posts com falha', body: 'Se algum post falhar por conta de uma conta desconectada, o Stacc sinaliza imediatamente e coloca o post em fila. Você reconecta a conta e o post é publicado.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Relatórios de desempenho de publicação', body: 'Rastreie o desempenho dos posts em todas as unidades e plataformas. Veja quais tipos de conteúdo geram mais visualizações e engajamento no GBP por unidade.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automação em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o Stacc está fazendo<br />enquanto você foca em outra coisa.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicação Automática de Conteúdo</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Conteúdo publicado automaticamente, todo dia.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O algoritmo local do Google pontua ativamente a atividade do GBP. Empresas que publicam de forma consistente conquistam posições mais altas no pacote local. O Stacc gera e publica 30 posts por unidade por mês no Google Business Profile e nas redes sociais conectadas — no horário agendado, com conteúdo específico por localidade, sem que ninguém da sua equipe precise clicar em publicar.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de publicação
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendário de publicação — este mês</p>
              {[
                { day: 'Seg 07', post: 'Post no GBP publicado', status: true },
                { day: 'Ter 08', post: 'Post no GBP publicado', status: true },
                { day: 'Qua 09', post: 'Post no GBP publicado', status: true },
                { day: 'Qui 10', post: 'Post no GBP publicado', status: true },
                { day: 'Sex 11', post: 'Post no GBP publicado', status: true },
              ].map(item => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.post}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{item.day}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669]">✓ Publicado</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 posts/mês · Zero ações manuais</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Fila de conteúdo — prontos para publicar</p>
              {[
                { title: 'Post de serviço — Unidade SP', date: 'Aprovado · Publica 14 Abr', ok: true },
                { title: 'Post sazonal — Unidade RJ', date: 'Aprovado · Publica 15 Abr', ok: true },
                { title: 'Post de oferta — Unidade BH', date: 'Aprovado · Publica 16 Abr', ok: true },
                { title: 'Post de avaliação — Unidade SP', date: 'Aprovado · Publica 17 Abr', ok: true },
              ].map(item => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.title}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{item.date}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Calendário unificado · Sem toque manual</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Calendário Unificado</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Do calendário ao feed, sem toque manual.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Agende semanas ou meses de conteúdo em uma única sessão. O Stacc gerencia a fila completa — GBP, Facebook e Instagram — e publica automaticamente na cadência definida por você. Não há login diário, não há copiar e colar entre plataformas, não há risco de semanas puladas. O calendário roda sozinho enquanto sua equipe foca em estratégia.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver calendário de conteúdo
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Performance das Redes Sociais</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Relatórios de performance das redes entregues automaticamente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Acompanhe impressões, cliques, engajamento e crescimento de seguidores em todas as unidades e plataformas sem montar relatórios manualmente. O Stacc consolida os dados de performance em relatórios white-label entregues automaticamente — para você ou diretamente para o cliente, no dia e horário que você definir.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver relatórios para agências
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Resumo de performance — Abril</p>
              {[
                { metric: 'Impressões totais', value: '12.480', delta: '+18%' },
                { metric: 'Cliques no perfil', value: '843', delta: '+24%' },
                { metric: 'Posts publicados', value: '30', delta: '100%' },
                { metric: 'Engajamento médio', value: '4,2%', delta: '+0,6pp' },
              ].map(item => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.metric}</p>
                  <div class="text-right">
                    <p class="font-mono text-[12px] font-bold text-[#111827]">{item.value}</p>
                    <p class="font-mono text-[10px] text-[#059669]">{item.delta}</p>
                  </div>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Entregue automaticamente · White-label</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que a automação de redes sociais<br />realmente entrega.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '30', num: 30, prefix: '', suffix: '', decimals: 0, from: 0, label: 'Posts publicados por mês automaticamente', sub: 'GBP e redes sociais, sem toque manual por unidade' },
            { value: '8hrs', num: 8, prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Economizadas por unidade/mês', sub: 'comparado à publicação manual em todas as plataformas' },
            { value: '4,7×', num: 4.7, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Melhora de posicionamento no GBP', sub: 'publicação consistente vs. baseline inativo' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
