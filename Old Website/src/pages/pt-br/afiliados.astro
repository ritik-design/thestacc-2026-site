                <li data-value="Newsletter" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Newsletter</li>
                <li data-value="Redes Sociais" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Redes Sociais</li>
                <li data-value="Podcast" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Podcast</li>
                <li data-value="Agência / Consultoria" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Agência / Consultoria</li>
                <li data-value="Outro" class="aff-dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Outro</li>
              </ul>
            </div>
          </div>

          <div>
            <label for="aff-message" class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Fale sobre seu público</label>
            <textarea
              id="aff-message"
              name="message"
              rows="3"
              class="mt-2 w-full resize-none rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 font-sans text-base text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
              placeholder="Quem é o seu público? Como você promoveria o theStacc? (opcional)"
            ></textarea>
          </div>

          <button
            type="submit"
            id="aff-submit"
            class="mt-1 flex h-[44px] w-full items-center justify-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] font-mono text-sm font-semibold uppercase tracking-wide text-white transition-colors hover:bg-[#4f39f6] disabled:cursor-not-allowed disabled:opacity-60"
          >
            <span id="aff-submit-text">Candidatar-se ao Programa de Afiliados</span>
            <svg id="aff-submit-spinner" class="hidden h-4 w-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </button>

          <p id="aff-form-status" class="hidden text-center font-sans text-sm"></p>

          <!-- Estado de Sucesso (oculto por padrão) -->
          <div id="aff-success" class="hidden rounded-xl border border-green-200 bg-green-50 p-6 text-center">
            <svg class="mx-auto" xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <p class="mt-4 font-sans text-[18px] font-medium text-[#292524]">Bem-vindo ao programa!</p>
            <p class="mt-2 font-sans text-[15px] leading-[24px] text-[#57534e]">
              Verifique seu e-mail para receber seu link de afiliado, código de cupom e guia de início.
            </p>
            <div id="aff-link-box" class="mt-4 rounded-lg border border-[#e7e5e4] bg-white px-4 py-3">
              <p class="font-mono text-[12px] font-medium uppercase tracking-wide text-[#79716b]">Seu Link de Afiliado</p>
              <div class="mt-1 flex items-center justify-center gap-2">
                <p id="aff-link-value" class="font-mono text-[14px] font-semibold text-[#4f39f6] break-all"></p>
                <button type="button" id="aff-copy-btn" class="shrink-0 rounded-lg border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5 font-mono text-[12px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f5f4]">
                  Copiar
                </button>
              </div>
            </div>
          </div>
        </form>
      </div>
    </section>

    <!-- ░░ DARK FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Programa de Afiliados</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Comece a ganhar renda recorrente hoje.
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Entre no programa de afiliados do theStacc e ganhe até 25% de cada pagamento das suas indicações, por até 3 anos.
        </p>
        <a href="#aplicar"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Candidatar-se Agora
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">Gratuito para entrar · Pagamentos mensais · Sem limite de ganhos</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  // ── Calculadora de Ganhos ──
  const referralsSlider = document.getElementById('calc-referrals') as HTMLInputElement;
  const referralsValue = document.getElementById('calc-referrals-value')!;
  const calcMonthly = document.getElementById('calc-monthly')!;
  const calcYearly = document.getElementById('calc-yearly')!;
  const calc3Year = document.getElementById('calc-3year')!;
  const planButtons = document.querySelectorAll('.calc-plan-btn');

  let selectedPlan = 99;

  function formatCurrency(amount: number): string {
    return '$' + amount.toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
  }

  function updateCalc() {
    const referrals = parseInt(referralsSlider.value);
    referralsValue.textContent = referrals.toString();
    const monthly = referrals * selectedPlan * 0.25;
    const yearly = monthly * 12;
    const threeYear = monthly * 36;
    calcMonthly.textContent = formatCurrency(monthly);
    calcYearly.textContent = formatCurrency(yearly);
    calc3Year.textContent = formatCurrency(threeYear);
  }

  referralsSlider.addEventListener('input', updateCalc);

  planButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      planButtons.forEach((b) => {
        b.classList.remove('active', 'border-[#4f39f6]', 'bg-[#f5f3ff]', 'text-[#4f39f6]', 'font-semibold');
        b.classList.add('border-[#e7e5e4]', 'bg-white', 'text-[#57534e]', 'font-medium');
      });
      btn.classList.add('active', 'border-[#4f39f6]', 'bg-[#f5f3ff]', 'text-[#4f39f6]', 'font-semibold');
      btn.classList.remove('border-[#e7e5e4]', 'bg-white', 'text-[#57534e]', 'font-medium');
      selectedPlan = parseInt((btn as HTMLElement).dataset.plan!);
      updateCalc();
    });
  });

  // ── FAQ Acordeão ──
  document.querySelectorAll('.aff-faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const parent = btn.parentElement;
      const answer = parent?.querySelector('.aff-faq-answer');
      const iconPlus = btn.querySelector('.aff-faq-icon-plus');
      const iconMinus = btn.querySelector('.aff-faq-icon-minus');
      const isOpen = answer?.classList.contains('hidden') === false;

      document.querySelectorAll('.aff-faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.aff-faq-icon-plus').forEach(i => i.classList.remove('hidden'));
      document.querySelectorAll('.aff-faq-icon-minus').forEach(i => i.classList.add('hidden'));

      if (!isOpen) {
        answer?.classList.remove('hidden');
        iconPlus?.classList.add('hidden');
        iconMinus?.classList.remove('hidden');
      }
    });
  });

  // ── Lógica do Dropdown ──
  const affTrigger = document.getElementById('aff-dropdown-trigger')!;
  const affMenu = document.getElementById('aff-dropdown-menu')!;
  const affLabel = document.getElementById('aff-dropdown-label')!;
  const affChevron = document.getElementById('aff-dropdown-chevron')!;
  const affHiddenInput = document.getElementById('aff-channel') as HTMLInputElement;
  const affOptions = document.querySelectorAll('.aff-dropdown-option');

  function openAffDropdown() {
    affMenu.classList.remove('hidden');
    affChevron.classList.add('rotate-180');
  }

  function closeAffDropdown() {
    affMenu.classList.add('hidden');
    affChevron.classList.remove('rotate-180');
  }

  affTrigger.addEventListener('click', () => {
    affMenu.classList.contains('hidden') ? openAffDropdown() : closeAffDropdown();
  });

  affOptions.forEach((opt) => {
    opt.addEventListener('click', () => {
      const value = (opt as HTMLElement).dataset.value!;
      affHiddenInput.value = value;
      affLabel.textContent = value;
      affLabel.classList.remove('text-[#79716b]');
      affLabel.classList.add('text-[#292524]');
      closeAffDropdown();
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('#aff-dropdown-wrapper')) {
      closeAffDropdown();
    }
  });

  // ── Envio do Formulário ──
  const affForm = document.getElementById('affiliate-form') as HTMLFormElement;
  const affSubmitBtn = document.getElementById('aff-submit') as HTMLButtonElement;
  const affSubmitText = document.getElementById('aff-submit-text')!;
  const affSpinner = document.getElementById('aff-submit-spinner')!;
  const affStatus = document.getElementById('aff-form-status')!;
  const affSuccess = document.getElementById('aff-success')!;
  const affLinkValue = document.getElementById('aff-link-value')!;
  const affCopyBtn = document.getElementById('aff-copy-btn')!;

  affForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const channel = affHiddenInput.value;
    if (!channel) {
      affStatus.textContent = 'Por favor, selecione um canal de promoção.';
      affStatus.className = 'text-center font-sans text-sm text-red-500';
      affStatus.classList.remove('hidden');
      return;
    }

    affSubmitBtn.disabled = true;
    affSubmitText.textContent = 'Enviando...';
    affSpinner.classList.remove('hidden');
    affStatus.classList.add('hidden');

    const data = {
      name: (affForm.elements.namedItem('name') as HTMLInputElement).value.trim(),
      email: (affForm.elements.namedItem('email') as HTMLInputElement).value.trim(),
      website: (affForm.elements.namedItem('website') as HTMLInputElement).value.trim(),
      audience: (affForm.elements.namedItem('audience') as HTMLInputElement).value.trim(),
      channel,
      message: (affForm.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
    };

    try {
      const res = await fetch('/api/affiliate-signup/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok) {
        affForm.classList.add('hidden');
        affSuccess.classList.remove('hidden');
        affLinkValue.textContent = result.affiliateLink;
      } else {
        affStatus.textContent = result.error || 'Algo deu errado. Por favor, tente novamente.';
        affStatus.className = 'text-center font-sans text-sm text-red-500';
        affStatus.classList.remove('hidden');
      }
    } catch {
      affStatus.textContent = 'Erro de rede. Verifique sua conexão e tente novamente.';
      affStatus.className = 'text-center font-sans text-sm text-red-500';
      affStatus.classList.remove('hidden');
    } finally {
      affSubmitBtn.disabled = false;
      affSubmitText.textContent = 'Candidatar-se ao Programa de Afiliados';
      affSpinner.classList.add('hidden');
    }
  });

  // Botão de copiar
  affCopyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(affLinkValue.textContent || '').then(() => {
      affCopyBtn.textContent = 'Copiado!';
      setTimeout(() => { affCopyBtn.textContent = 'Copiar'; }, 2000);
    });
  });
</script>
