---
import LegalLayout from '../../layouts/LegalLayout.astro';

const toc = [
  { id: 'controller',   label: '1. Controlador de Dados' },
  { id: 'types',        label: '2. Tipos de Dados Processados' },
  { id: 'legal-basis',  label: '3. Base Legal para Tratamento' },
  { id: 'retention',    label: '4. Retenção de Dados' },
  { id: 'processors',   label: '5. Processadores Terceiros' },
  { id: 'transfers',    label: '6. Transferências Internacionais' },
  { id: 'rights',       label: '7. Seus Direitos (GDPR)' },
  { id: 'contact',      label: '8. Contato' },
];

const dataTypes = [
  { label: 'Dados de conta',    body: 'Nome, endereço de e-mail, nome da empresa, endereço de faturamento.' },
  { label: 'Dados de uso',      body: 'Interações com o serviço, histórico de geração de conteúdo, padrões de uso de funcionalidades.' },
  { label: 'Dados empresariais', body: 'URLs de sites, palavras-chave, descrições de negócio que você fornece para configurar nossos serviços.' },
  { label: 'Dados técnicos',    body: 'Endereços IP, tipo de navegador, identificadores de dispositivo e outros dados de registro.' },
];

const gdprRights = [
  { label: 'Direito de acesso',           body: 'Solicitar uma cópia dos dados que mantemos sobre você.' },
  { label: 'Direito de retificação',      body: 'Solicitar a correção de dados imprecisos ou incompletos.' },
  { label: 'Direito ao apagamento',       body: 'Solicitar a exclusão dos seus dados pessoais em determinadas circunstâncias.' },
  { label: 'Direito à restrição',         body: 'Solicitar que limitemos o uso dos seus dados.' },
  { label: 'Direito à portabilidade',     body: 'Receber seus dados em formato estruturado e legível por máquina.' },
  { label: 'Direito de oposição',         body: 'Opor-se ao tratamento baseado em interesses legítimos.' },
];
---

<LegalLayout
  title="Processamento de Dados"
  description="Como o theStacc processa seus dados de acordo com o GDPR. Abrange base legal, períodos de retenção de dados, subprocessadores e seus direitos como titular de dados."
  lastUpdated="Abril 2026"
  badge="Jurídico · Conformidade"
  tocItems={toc}
  currentPath="/pt-br/processamento-dados/"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebPage",
        "name": "Processamento de Dados | theStacc",
        "url": "https://thestacc.com/pt-br/processamento-dados/",
        "inLanguage": "pt-BR",
        "description": "Como o theStacc processa seus dados de acordo com o GDPR."
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
          { "@type": "ListItem", "position": 2, "name": "Processamento de Dados", "item": "https://thestacc.com/pt-br/processamento-dados/" }
        ]
      }
    ]
  })} />

  <div class="flex flex-col gap-10">

    <section id="controller" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Controlador de Dados</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          A SOLARTREK VENTURES LLP atua como controladora de dados pessoais processados por meio de nossa plataforma. Determinamos as finalidades e os meios de tratamento dos seus dados pessoais de acordo com as leis de proteção de dados aplicáveis, incluindo o Regulamento Geral sobre a Proteção de Dados (GDPR) onde aplicável.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="types" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Tipos de Dados Processados</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">No âmbito da prestação dos nossos serviços, tratamos as seguintes categorias de dados:</p>
        <div class="flex flex-col gap-3">
          {dataTypes.map(item => (
            <div class="flex items-start gap-3">
              <span class="mt-[5px] h-1.5 w-1.5 shrink-0 rounded-full bg-[#4f39f6]"></span>
              <p class="font-sans text-[15px] leading-[1.7] text-[#57534e]">
                <strong class="font-semibold text-[#111827]">{item.label}:</strong> {item.body}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="legal-basis" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Base Legal para Tratamento</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">Tratamos seus dados pessoais com base nas seguintes justificativas legais:</p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {[
            { label: 'Necessidade contratual', body: 'Tratamento necessário para entregar os serviços aos quais você assinou.' },
            { label: 'Interesses legítimos',   body: 'Aprimoramento da plataforma, prevenção de fraudes e segurança.' },
            { label: 'Obrigação legal',        body: 'Conformidade com as leis e regulamentos aplicáveis.' },
            { label: 'Consentimento',          body: 'Para comunicações opcionais e cookies não essenciais quando exigido.' },
          ].map(item => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-4">
              <p class="font-sans text-[13px] font-semibold text-[#111827] mb-1">{item.label}</p>
              <p class="font-sans text-[13px] leading-[1.65] text-[#79716b]">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="retention" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Retenção de Dados</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Retemos seus dados pessoais enquanto sua conta estiver ativa ou conforme necessário para fornecer nossos serviços. Após o encerramento da conta, excluiremos ou anonimizaremos seus dados pessoais em até 90 dias, salvo se formos obrigados a retê-los por mais tempo para cumprir obrigações legais, resolver disputas ou fazer cumprir nossos acordos.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="processors" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">5</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Processadores Terceiros</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Contratamos subprocessadores terceiros confiáveis para ajudar a entregar nossos serviços, incluindo provedores de infraestrutura em nuvem, processadores de pagamento e provedores de modelos de IA. Todos os subprocessadores estão vinculados por acordos de tratamento de dados e são obrigados a implementar medidas de segurança adequadas. Uma lista atualizada de subprocessadores está disponível mediante solicitação.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="transfers" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">6</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Transferências Internacionais</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Seus dados podem ser transferidos e processados em países fora do seu país de residência, incluindo os Estados Unidos. Quando transferimos dados do Espaço Econômico Europeu, nos apoiamos em Cláusulas Contratuais Padrão ou outras salvaguardas adequadas reconhecidas pelo GDPR para garantir um nível adequado de proteção.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="rights" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">7</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Seus Direitos (GDPR)</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">
          Se você estiver localizado no Espaço Econômico Europeu, tem os seguintes direitos em relação aos seus dados pessoais:
        </p>
        <div class="flex flex-col gap-3">
          {gdprRights.map(item => (
            <div class="flex items-start gap-3">
              <svg class="mt-[3px] shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <p class="font-sans text-[15px] leading-[1.7] text-[#57534e]">
                <strong class="font-semibold text-[#111827]">{item.label}</strong> — {item.body}
              </p>
            </div>
          ))}
        </div>
        <p class="mt-5 font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Para exercer qualquer um desses direitos, entre em contato conosco em <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>. Responderemos em até 30 dias.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="contact" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">8</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Contato</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Para consultas sobre proteção de dados, entre em contato com nossa equipe em <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
        </p>
        <div class="mt-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-4">
          <p class="font-sans text-[13px] font-semibold text-[#111827] mb-1">Razão Social</p>
          <p class="font-sans text-[13px] leading-[1.65] text-[#79716b] mb-3">SOLARTREK VENTURES LLP</p>
          <p class="font-sans text-[13px] font-semibold text-[#111827] mb-1">Endereço</p>
          <p class="font-sans text-[13px] leading-[1.65] text-[#79716b]">Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India</p>
        </div>
      </div>
    </section>

  </div>
</LegalLayout>
