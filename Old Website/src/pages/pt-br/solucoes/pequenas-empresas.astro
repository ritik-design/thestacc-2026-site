---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Preciso ter conhecimentos de SEO para usar o Stacc?",
    a: "Nenhum. O Stacc foi criado para proprietários de negócios que nunca usaram uma ferramenta de SEO. A configuração guia você passo a passo. Uma vez que seu Google Business Profile esteja conectado e suas palavras-chave definidas, o Stacc funciona no piloto automático. Você não precisa entender como o SEO local funciona — só precisa ver seu negócio aparecer quando os clientes pesquisam.",
  },
  {
    q: "Quanto tempo leva a configuração?",
    a: "A maioria das pequenas empresas fica completamente configurada em menos de 15 minutos. Conecte seu Google Business Profile via OAuth (3 minutos), defina suas palavras-chave alvo e área de atendimento (5 minutos) e configure seu calendário de publicações (5 minutos). Depois disso, o Stacc gerencia tudo automaticamente.",
  },
  {
    q: "Por que usar o Stacc em vez de contratar uma agência de SEO?",
    a: "Uma agência de SEO local cobra normalmente entre R$5.000 e R$12.000 por mês e exige um compromisso de 6 meses. O Stacc custa R$49 por mês, sem contrato, cancele quando quiser. Para a maioria dos negócios locais, o Stacc entrega resultados comparáveis — muitas vezes melhores — porque a automação é consistente de um jeito que o trabalho manual das agências frequentemente não é. Você é dono dos dados e dos resultados.",
  },
  {
    q: "Vou realmente ranquear mais alto no Google Maps?",
    a: "89% dos clientes do Stacc veem melhorias no ranking em 30 dias. Os fatores mais importantes são a completude do GBP, a consistência das publicações, a precisão das citações e a velocidade de resposta às avaliações — tudo o que o Stacc gerencia automaticamente. Os resultados variam conforme a competitividade do mercado, mas a execução consistente supera o esforço esporádico sempre.",
  },
  {
    q: "E se eu tiver apenas uma localização?",
    a: "O Stacc funciona perfeitamente para negócios com uma única localização. Na verdade, foi para isso que ele foi criado originalmente — o proprietário-operador que precisava de resultados de SEO local no nível de uma agência, sem o preço nem a curva de aprendizado da agência. Todas as funcionalidades estão disponíveis desde a sua primeira localização.",
  },
  {
    q: "Como o Stacc gerencia minhas avaliações do Google?",
    a: "O Stacc monitora suas avaliações do Google em tempo real. No momento em que uma nova avaliação chega, você recebe um alerta com o texto, a pontuação de estrelas e uma resposta sugerida. Você pode responder diretamente pelo Stacc. As taxas de resposta a avaliações são um dos sinais mais fortes que o Google usa para classificar negócios locais — o Stacc torna fácil manter um bom histórico de respostas.",
  },
  {
    q: "O que acontece depois do meu teste gratuito?",
    a: "Após seu teste gratuito de 14 dias, sua conta continua a R$49 por mês se você decidir ficar. Não é necessário cartão de crédito para iniciar o teste. Se você decidir que o Stacc não é adequado para você, cancele antes do fim do teste e nunca será cobrado. Sem contratos nem taxas de cancelamento.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO Local para Pequenas Empresas",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "Apareça no Google Maps e na busca local sem contratar uma agência de SEO. O theStacc automatiza o trabalho diário que leva os negócios locais ao topo dos resultados de busca local.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Soluções", "item": "https://thestacc.com/pt-br/solucoes/" },
        { "@type": "ListItem", "position": 3, "name": "Pequenas Empresas", "item": "https://thestacc.com/pt-br/solucoes/pequenas-empresas/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Ferramenta de SEO para Pequenas Empresas — Posicione-se no Google Maps Sem Agência | theStacc"
  description="Apareça no Google Maps e na busca local sem contratar uma agência de SEO. O theStacc automatiza o trabalho diário que leva os negócios locais aos primeiros resultados."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Para Pequenas Empresas · Sem Conhecimentos de SEO Necessários</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Apareça no Google Maps<br />antes do seu concorrente chegar ao trabalho.
            <span style="color:#4f39f6;"> Sem agência. Sem complicações.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc automatiza o SEO local que faz os clientes encontrarem você — publicações no GBP, monitoramento de avaliações, rastreamento de posições e citações. Configuração em 15 minutos. Funciona enquanto você dorme.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Começar por R$1
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/modulos/seo-local/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sem cartão de crédito · Atualizações diárias · Configuração em menos de 15 minutos
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '89%',   num: 89,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Veem melhorias em 30 dias' },
              { value: 'R$49',  num: 49,  prefix: 'R$', suffix: '', decimals: 0, from: 0, label: 'Por mês — sem contrato' },
              { value: '15min', num: 15,  prefix: '', suffix: 'min', decimals: 0, from: 0, label: 'Tempo de configuração' },
              { value: '4.9★',  num: 4.9, prefix: '', suffix: '★', decimals: 1, from: 0, label: 'Avaliação média' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema real</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Seus concorrentes estão<br />aparecendo. Você não.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Você tem o melhor produto ou serviço da sua região. Você sabe disso. Mas quando alguém pesquisa o que você oferece no Google, seu concorrente aparece primeiro — e aquele cliente nunca chega a te conhecer. Não porque você é pior. Mas porque eles estão fazendo o trabalho de SEO local que você não tem tempo de fazer.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Seu GBP está sem atualização há meses.',
              body: 'O Google recompensa perfis ativos. Um perfil de Google Business Profile que não publica regularmente é praticamente invisível no Maps. Seus concorrentes publicam. Você não tem tempo. A diferença em visibilidade é enorme.',
            },
            {
              icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
              title: 'Uma avaliação negativa leva semanas sem resposta.',
              body: 'Cada avaliação sem resposta destrói sua pontuação de confiança. Clientes em potencial leem as avaliações. E também as respostas. Uma resposta profissional a uma avaliação de 1 estrela converte mais do que a estrela perfeita sem resposta.',
            },
            {
              icon: 'M13 10V3L4 14h7v7l9-11h-7z',
              title: 'Você não sabe se está ranqueando ou não.',
              body: 'Quanto dinheiro você está deixando na mesa por não aparecer nas buscas certas? Sem rastreamento de posições, você está operando no escuro. Seus concorrentes sabem exatamente onde ganham e onde perdem. Você não.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Configure em 15 minutos.<br />O Stacc faz o trabalho o resto do tempo.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Conecte seu Google Business Profile', body: 'Um processo de 3 minutos. O Stacc se conecta ao seu GBP via OAuth seguro. Você não precisa de senhas nem acesso especial. Basta autorizar a conexão e o Stacc tem tudo o que precisa.' },
            { n: '02', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Defina suas palavras-chave e área', body: 'Diga o que você oferece e onde. O Stacc sugere palavras-chave locais de alto valor com base no seu tipo de negócio e cidade. 5 minutos e você tem um plano de SEO local que normalmente levaria horas de pesquisa.' },
            { n: '03', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'O Stacc publica, monitora e reporta', body: '30 publicações no GBP por mês. Alertas instantâneos de avaliações. Rastreamento diário de posições. Relatórios automatizados. Tudo acontece automaticamente. Você vê os resultados sem fazer o trabalho.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tudo incluído</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            SEO local no nível de agência.<br />A R$49 por mês.
          </h2>
        </div>

        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: '30 Publicações GBP por Mês', body: 'Seu perfil de Google Business Profile permanece ativo com publicações diárias. O Google recompensa perfis que publicam regularmente com maior visibilidade no Maps.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Alertas de Avaliações Instantâneos', body: 'No momento em que uma nova avaliação chega ao Google, Facebook ou Yelp, você recebe um alerta. Responda rápido. Proteja sua reputação antes que o dano se espalhe.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Rastreamento Diário de Posições', body: 'Cada palavra-chave, todo dia. Você sabe exatamente onde aparece no Google Maps e na busca orgânica antes de qualquer cliente perguntar.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Gestão de Citações', body: 'Seu nome, endereço e telefone verificados em mais de 50 diretórios. As inconsistências destroem o SEO local. O Stacc as encontra e corrige automaticamente.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
            { title: 'Respostas a Avaliações com IA', body: 'Respostas profissionais sugeridas para cada nova avaliação. Responda em segundos, não em horas. Os clientes percebem quando você responde rápido — e o Google também.', icon: 'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z' },
            { title: 'Relatórios de Desempenho', body: 'Um resumo semanal das suas posições, atividade do GBP, novas avaliações e saúde das citações. Tudo em um e-mail. Tudo sem você precisar fazer nada.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados reais</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que acontece quando você automatiza<br />o SEO local do seu negócio.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '89%', num: 89, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Melhoram posições em 30 dias', sub: 'com publicação consistente no GBP e otimização de citações' },
            { value: '10×', num: 10, prefix: '', suffix: '×', decimals: 0, from: 0, label: 'Mais publicações que a concorrência', sub: '30 publicações por mês vs 2-3 do negócio típico' },
            { value: 'R$49', num: 49, prefix: 'R$', suffix: '', decimals: 0, from: 0, label: 'Por mês vs R$5.000+ em agência', sub: 'resultados comparáveis ou melhores sem o contrato' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
