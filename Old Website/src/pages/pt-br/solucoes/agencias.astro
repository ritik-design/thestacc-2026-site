---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "O painel de marca branca está disponível em todos os planos?",
    a: "Os relatórios de marca branca — seu logo, suas cores, seu domínio — estão disponíveis nos planos Growth e Scale. O plano Starter inclui relatórios com a marca Stacc. Você pode fazer upgrade a qualquer momento e os calendários de relatórios existentes são transferidos automaticamente.",
  },
  {
    q: "Quantas contas de cliente posso gerenciar?",
    a: "Todos os planos suportam contas de cliente ilimitadas. O preço é baseado no número de localizações que você gerencia, não no número de clientes. Uma agência com 20 clientes com uma localização cada paga o mesmo que uma agência com 10 clientes com duas localizações — se o total de localizações for o mesmo.",
  },
  {
    q: "Posso controlar o que os clientes veem no painel?",
    a: "Sim. Você decide exatamente quais dados, funções e relatórios cada cliente pode ver. Você pode limitar a visibilidade por módulo, intervalo de datas ou localização. Os clientes veem o que é útil para eles. Você mantém visibilidade total sobre tudo.",
  },
  {
    q: "Quanto tempo leva para incorporar um novo cliente?",
    a: "A maioria dos novos clientes fica completamente configurada — localizações adicionadas, palavras-chave definidas, GBP conectado e calendário de relatórios automatizado ativo — em menos de 45 minutos. Para clientes com mais de 10 localizações, planeje uma hora. Depois disso, o Stacc gerencia tudo automaticamente.",
  },
  {
    q: "O Stacc substitui minhas ferramentas de SEO atuais?",
    a: "Para SEO local especificamente — rastreamento de posições, gestão de citações, gestão de GBP, monitoramento de avaliações e relatórios de clientes — sim. A maioria das agências consolida de 4 a 6 ferramentas separadas no Stacc e reduz seu orçamento de ferramentas em 60–70%. Para link building avançado ou auditorias de SEO técnico, o Stacc complementa essas ferramentas em vez de substituí-las.",
  },
  {
    q: "Posso revender o Stacc como serviço para meus clientes?",
    a: "Sim. Muitas agências usam o Stacc como plataforma base para suas retenções de SEO local. Com relatórios e portais de cliente de marca branca, os clientes interagem com sua marca em todo momento — o Stacc é invisível. Não restringimos a revenda.",
  },
  {
    q: "Quais integrações estão disponíveis para os relatórios de clientes?",
    a: "Os relatórios são enviados por e-mail para as caixas de entrada dos clientes, estão disponíveis por meio de portais de cliente de marca branca e podem enviar dados para o Google Sheets, Looker Studio e Slack para agências com fluxos de trabalho de relatórios personalizados.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc para Agências",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "A plataforma de SEO local projetada para agências. Gerencie o GBP, posições, avaliações e relatórios de cada cliente a partir de um painel de marca branca.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Soluções", "item": "https://thestacc.com/pt-br/solucoes/" },
        { "@type": "ListItem", "position": 3, "name": "Para Agências", "item": "https://thestacc.com/pt-br/solucoes/agencias/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Ferramenta de SEO para Agências — Gerencie Cada Cliente, Automatize Tudo | theStacc"
  description="O theStacc é a plataforma de SEO local projetada para agências. Gerencie posições, GBP, avaliações e relatórios automatizados de marca branca para cada cliente em um painel."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Para Agências de SEO · Marca Branca Incluída</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            A ferramenta de SEO<br />projetada para agências.
            <span style="color:#4f39f6;"> Gerencie cada cliente. Automatize tudo.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Um painel para o SEO local de cada cliente — rastreamento de posições, gestão de GBP, monitoramento de avaliações, citações e relatórios de marca branca. Tudo automatizado. Tudo sob sua marca.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Ver uma demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Começar teste gratuito
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            400+ agências · Marca branca em todos os planos Growth · Configuração em menos de 5 minutosutos
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '400+',  num: 400,  prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Agências usando o Stacc' },
              { value: '45min', num: 45,   prefix: '', suffix: 'min', decimals: 0, from: 0, label: 'Tempo médio de incorporação' },
              { value: '80%',   num: 80,   prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Menos tempo em relatórios manuais' },
              { value: '3×',    num: 3,    prefix: '', suffix: '×', decimals: 0, from: 0, label: 'Mais clientes, mesma equipe' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Se você dirige uma agência de SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Você já sabe exatamente<br />como isso se sente.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'O imposto do relatório.',
              body: 'Toda segunda-feira de manhã, alguém da sua equipe constrói relatórios em vez de fazer SEO de verdade. 4 horas por cliente por mês. Com 20 clientes, são 80 horas por mês. Isso é um funcionário em tempo integral fazendo apenas PDFs que ninguém pediu para serem feitos à mão.',
            },
            {
              icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
              title: '"Estamos bem posicionados?" — numa sexta à tarde.',
              body: 'Um cliente liga. Você não tem a resposta na tela. Abre uma aba anônima. Está ganhando tempo enquanto eles perdem confiança. Você não deveria precisar de 20 minutos para responder uma pergunta que já deveria saber.',
            },
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Seis ferramentas. Seis logins. Uma equipe afogada em abas.',
              body: 'Rastreador de posições. Ferramenta de citações. Gestão de GBP. Plataforma de avaliações. Software de relatórios. Painel de analytics. Cada cliente precisa das seis. Cada ferramenta tem seu próprio login, seu próprio formato de dados, seu próprio processo de exportação. O stack que deveria torná-lo eficiente é o que o freia.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'O crescimento custa capacidade antes de gerar dinheiro.',
              body: 'Cada novo cliente significa mais trabalho manual — mais relatórios para construir, mais painéis para revisar, mais abas para abrir. Em algum momento você para de aceitar novos clientes para conter o sangramento. O negócio que deveria crescer está batendo num teto feito de planilhas.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── WHAT CHANGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que muda com o Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Uma plataforma. Cada cliente.<br />Nada manual.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Sem Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Com Stacc</div>
          </div>
          {[
            { label: 'Relatórios de clientes',        before: '4–6 horas manuais / cliente / mês', after: 'Automatizados, entregues no horário' },
            { label: 'Stack de ferramentas',          before: '4–6 ferramentas, 4–6 faturas',      after: 'Uma plataforma, uma fatura' },
            { label: 'Visibilidade do cliente',       before: 'Cliente pergunta → você corre',      after: 'Painel sempre atualizado' },
            { label: 'Incorporação de novo cliente',  before: 'Mínimo 3–4 horas',                  after: 'Menos de 45 minutos' },
            { label: 'Monitoramento de posições',     before: 'Revisão manual ou exportação semanal', after: 'Alertas automáticos diários' },
            { label: 'Gestão de GBP',                 before: 'Login em cada conta individualmente', after: 'Todas as localizações em um lugar' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── AGENCY FEATURES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Projetado para agências</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada função que sua agência precisa.<br />Nada que atrapalhe.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- White Label -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Painel de Marca Branca</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Os clientes acessam sua plataforma. Não a nossa.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cada superfície voltada ao cliente — o painel, os relatórios, a entrega por e-mail — carrega seu logo, suas cores e seu domínio. Os clientes interagem com sua marca em todo momento. Nunca veem o Stacc. Acreditam que você construiu tudo. Você não precisa corrigi-los.
              </p>
              <ul class="mt-6 space-y-3">
                {['Seu logo e cores de marca em todo o painel do cliente', 'Relatórios entregues do seu domínio — não de um e-mail do Stacc', 'URLs do portal do cliente sob o subdomínio da sua agência', 'Remova toda a marca Stacc nos planos Growth e Scale'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center gap-3">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Seu Nome de Agência</p>
                  <p class="font-mono text-[10px] text-[#79716b]">relatorios.suaagencia.com.br</p>
                </div>
                <span class="ml-auto rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">Totalmente personalizado</span>
              </div>
              <div class="space-y-3">
                {['Portal de acesso para clientes', 'Entrega semanal de relatório de posições', 'Alertas de monitoramento de avaliações', 'Painel de desempenho do GBP', 'Resumo de saúde de citações'].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#374151]">{item}</span>
                    <span class="ml-auto font-mono text-[10px] font-semibold text-[#4f39f6]">Sua marca</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Automated Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Segunda 7:00 · Relatórios de clientes enviados</p>
              {[
                { client: 'Hidráulica Garcia', stat: '+4 posições', type: 'Relatório de Posições' },
                { client: 'Clínica Dental Verde', stat: '3 novas avaliações', type: 'Relatório de Avaliações' },
                { client: 'Climatização Amanhecer', stat: '28 publicações GBP', type: 'Relatório de GBP' },
                { client: 'Assessoria Jurídica Cidade', stat: 'Top 3 local — 3 palavras-chave', type: 'Relatório de SEO Local' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <div class="h-8 w-8 rounded-full bg-[#f5f3ff] flex items-center justify-center shrink-0">
                    <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">{r.client[0]}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[13px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.type}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669] shrink-0">{r.stat}</span>
                </div>
              ))}
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Todos enviados automaticamente · Você não fez nada</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Relatórios Automatizados</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Relatórios que se constroem e enviam sozinhos. Cada cliente. Toda semana.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configure o template de relatório uma vez por cliente. A partir desse dia, o Stacc gera o relatório, formata com sua marca e entrega na caixa de entrada do cliente conforme o calendário. Ninguém na sua equipe toca nisso. As 80 horas por mês que você gastava em relatórios estão agora disponíveis para trabalho real.
              </p>
              <ul class="mt-6 space-y-3">
                {['Configure uma vez — entrega para sempre conforme seu calendário', 'Formato de marca branca com a marca da sua agência e comentários', 'Cobre posições, atividade de GBP, avaliações, citações em um relatório', 'Os clientes recebem prova do seu trabalho toda semana sem que você diga uma palavra'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
