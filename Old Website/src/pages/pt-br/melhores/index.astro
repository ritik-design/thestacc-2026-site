---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import { getCollection } from 'astro:content';

const enPosts = await getCollection('best');
const langPosts = await getCollection('best_ptbr');
const langBySlug = new Map(langPosts.map(p => [p.data.slug, p]));
const bestPosts = enPosts.filter(p => langBySlug.has(p.data.slug)).map(p => langBySlug.get(p.data.slug)!);
const visibleBest = bestPosts.filter(p => p.data.image).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function readTime(body: string): number {
  const words = (body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}
---

<BaseLayout
  title="Melhores Ferramentas de SEO 2026 — Listas Ranqueadas | theStacc"
  description="As melhores ferramentas de SEO local, software de gestão de avaliações, ferramentas de agendamento social e muito mais. Listas ranqueadas e atualizadas regularmente."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "@id": "https://thestacc.com/pt-br/melhores/",
      "name": "Melhores Ferramentas de SEO — theStacc",
      "description": "Listas ranqueadas das melhores ferramentas de SEO, marketing e automação.",
      "url": "https://thestacc.com/pt-br/melhores/",
      "inLanguage": "pt-BR"
    })} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-12 pb-12">
        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Melhores Listas</span>
          <span class="h-3 w-px bg-[#e7e5e4]"></span>
          <span class="font-mono text-[10px] text-[#79716b]">{visibleBest.length} guias ranqueados</span>
        </div>
        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px]">
          As Melhores Ferramentas de SEO e Marketing
        </h1>
        <p class="mt-3 max-w-[560px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Listas ranqueadas e honestas das melhores ferramentas de SEO local, gestão de avaliações, agendamento de redes sociais e muito mais. Avaliadas por profissionais.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {[
            `${visibleBest.length} listas ranqueadas`,
            'Atualizado regularmente',
            'Avaliações imparciais',
            'Com preços verificados',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ GRID ░░ -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {visibleBest.slice(0, 12).map(post => (
            <a
              href={`/pt-br/melhores/${post.data.slug}/`}
              class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm"
            >
              <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
              <div class="flex flex-1 flex-col p-6">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Lista Ranqueada</span>
                <h3 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{post.data.title}</h3>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                  <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                  <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        {visibleBest.length > 12 && (
          <div class="mt-8 text-center">
            <a href="/best/" class="inline-flex h-10 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-mono text-[12px] font-semibold uppercase tracking-[0.08em] text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              Ver todas as {visibleBest.length} listas →
            </a>
          </div>
        )}
      </div>
    </section>

    <!-- ░░ FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Pare de avaliar ferramentas. Comece a ranquear.
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          O theStacc publica 30 artigos de blog, 30 posts no GMN e conteúdo para redes sociais. Automaticamente. Todo mês.
        </p>
        <a
          href="/pt-br/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Começar por R$1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">R$1 por 30 dias · Cancele quando quiser</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
