---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const changelog = [
  {
    date: "Abril 2026",
    tag: "Mais Recente",
    entries: [
      { title: "Sincronização de plano ao vivo", body: "Seu plano de conteúdo agora fica sincronizado com o seu negócio. Mudou seu público-alvo ou adicionou uma nova localização? O Stacc detecta o que ficou desatualizado e permite que você atualize planos individuais ou o mês inteiro com um clique." },
      { title: "Publicação com um mês de antecedência", body: "Planeje com antecedência. Agora você pode gerar o plano de conteúdo do próximo mês enquanto os posts deste mês ainda estão sendo publicados. Fique sempre um mês à frente." },
      { title: "Editor de imagem destacada", body: "Imagens destacadas cuidadas. Escolha, troque ou remova imagens de capa diretamente no editor do blog. Elas sincronizam automaticamente com o WordPress e o Webflow." },
      { title: "Página de detalhes do blog mais limpa", body: "Gere, edite ou regenere um plano em um só lugar. Sem mais procurar nas barras laterais o botão certo." },
      { title: "Edição de slug ao vivo", body: "Edite os slugs do seu blog diretamente na barra lateral. As alterações são enviadas instantaneamente ao WordPress, Webflow e WordPress.com." },
      { title: "Integração com Ghost CMS", body: "Publique diretamente no Ghost CMS com verificação automática de credenciais." },
      { title: "Configurações de módulo independentes", body: "Gerencia múltiplos projetos? Cada um agora tem configurações de módulo totalmente independentes. Ativar o Blog SEO em um site não afeta outro." },
      { title: "Regeneração em massa 5x mais rápida", body: "A regeneração em massa de planos agora é 5x mais rápida. O que antes levava 90 segundos agora termina em menos de 18." },
    ],
  },
  {
    date: "Março 2026",
    tag: null,
    entries: [
      { title: "Módulo de Redes Sociais lançado", body: "O Stacc agora escreve, projeta e agenda posts no Instagram, LinkedIn, X e Facebook. Configure a voz da sua marca uma vez e deixe no piloto automático." },
      { title: "Redesign completo da interface", body: "Reconstruímos toda a interface do zero. Novo sistema de design, novos ícones, navegação mais rápida. Tudo ficou mais preciso e intencional." },
      { title: "Revisão do plano de conteúdo", body: "Revise seu plano de conteúdo antes que qualquer coisa seja escrita. Edite títulos, troque palavras-chave, altere tipos de blog. Tudo inline, antes de um único artigo ser gerado." },
      { title: "API pública do Blog", body: "Para desenvolvedores: obtenha uma chave de API, configure deploy hooks e puxe seu conteúdo publicado para qualquer frontend ou site estático." },
      { title: "Melhor colaboração em equipe", body: "Reenvie convites, acompanhe o vencimento e controle exatamente o que os visualizadores podem acessar em projetos compartilhados." },
      { title: "Integração com Shopify", body: "Seu conteúdo de blog SEO agora é publicado diretamente na sua loja Shopify." },
    ],
  },
  {
    date: "Fevereiro 2026",
    tag: null,
    entries: [
      { title: "Integração com Webflow", body: "Conecte seu site Webflow via OAuth e cada post do blog é publicado diretamente no seu CMS com sincronização ao vivo." },
      { title: "Assinaturas modulares", body: "Assine exatamente o que precisa. Escolha Blog SEO, SEO Local ou Redes Sociais individualmente. Cada módulo tem seu próprio plano e faturamento." },
      { title: "Controles de voz e estilo da marca", body: "Defina preferências de estilo de escrita, diretrizes de imagem e regras de linkagem que se aplicam a todos os artigos gerados pelo Stacc." },
      { title: "Integração mais inteligente", body: "O Stacc agora lê seu sitemap e entende seu conteúdo existente antes de construir sua estratégia de palavras-chave." },
    ],
  },
  {
    date: "Janeiro 2026",
    tag: null,
    entries: [
      { title: "Módulo de SEO Local lançado", body: "Automatize publicações no Google Business Profile, monitore avaliações com respostas escritas por IA, acompanhe palavras-chave locais e gerencie múltiplas localizações em um único painel." },
      { title: "Integração com WordPress", body: "Publicação com um clique via OAuth ou Senha de Aplicativo. Categorias, tags e imagens destacadas são gerenciadas automaticamente." },
      { title: "Suporte a múltiplos projetos", body: "Gerencie múltiplos sites em uma única conta. Cada projeto tem suas próprias configurações, membros de equipe e pipeline de conteúdo." },
      { title: "Pontuação de SEO ao vivo", body: "Cada blog recebe uma pontuação de otimização em tempo real com sugestões acionáveis para melhorar densidade de palavras-chave, estrutura e legibilidade." },
      { title: "Segmentação por localização", body: "Segmente qualquer localização do planeta. Pesquise sua cidade e o Stacc descobre áreas próximas para expandir seu alcance de palavras-chave." },
    ],
  },
  {
    date: "Dezembro 2025",
    tag: "Lançamento",
    entries: [
      { title: "theStacc lançado", body: "Planos de conteúdo com IA, pesquisa de palavras-chave, criação de blog e publicação automática. Tudo em uma plataforma." },
      { title: "Integração inteligente", body: "Informe seu URL e o Stacc extrai seus serviços, encontra seus concorrentes e mapeia seus primeiros 30 tópicos de blog." },
      { title: "Calendário de conteúdo visual", body: "Veja todo o seu mês de relance. Acompanhe o que está agendado, sendo gerado, publicado ou precisa de atenção." },
      { title: "Voz da marca e segmentação de público", body: "Defina seu tom e até 6 perfis de cliente ideal para que cada artigo fale com as pessoas certas." },
    ],
  },
];
---

<BaseLayout
  title="Registro de Atualizações | theStacc"
  description="Novidades no theStacc. Atualizações de produto, novas funcionalidades e melhorias na plataforma. Atualizado mensalmente."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebPage",
          "name": "Registro de Atualizações | theStacc",
          "description": "Novidades no theStacc. Atualizações de produto, novas funcionalidades e melhorias na plataforma.",
          "url": "https://thestacc.com/pt-br/changelog/",
          "inLanguage": "pt-BR"
        },
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
            { "@type": "ListItem", "position": 2, "name": "Registro de Atualizações", "item": "https://thestacc.com/pt-br/changelog/" }
          ]
        }
      ]
    })} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ░░ DARK HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Registro de Atualizações</p>
        <h1 class="mx-auto mt-4 max-w-[560px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[44px]">
          O que há de novo no theStacc
        </h1>
        <p class="mx-auto mt-4 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          Atualizações de produto, novas integrações e melhorias na plataforma. Atualizado todo mês.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {[
            'Atualizado mensalmente',
            `${changelog.reduce((n, m) => n + m.entries.length, 0)} atualizações entregues`,
            'Dezembro 2025 até hoje',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ LINHA DO TEMPO ░░ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mx-auto max-w-[760px]">
          <div class="space-y-14">
            {changelog.map((month, mi) => (
              <div>
                <!-- Cabeçalho do mês -->
                <div class="flex items-center gap-3 mb-6">
                  <div class="h-2.5 w-2.5 shrink-0 rounded-full bg-[#4f39f6]"></div>
                  <h2 class="font-mono text-[13px] font-bold uppercase tracking-[0.12em] text-[#292524]">{month.date}</h2>
                  {month.tag && (
                    <span class={`rounded-full px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.1em] ${month.tag === 'Lançamento' ? 'bg-[#fef3c7] text-[#92400e]' : 'bg-[#f0fdf4] text-[#166534]'}`}>{month.tag}</span>
                  )}
                  <div class="flex-1 border-t border-[#e7e5e4]"></div>
                </div>

                <!-- Cards de entrada -->
                <div class="ml-5 space-y-3">
                  {month.entries.map(entry => (
                    <div class="rounded-xl border border-[#e7e5e4] bg-white px-5 py-4 transition-colors hover:border-[#c4b5fd]">
                      <p class="font-sans text-[14px] font-semibold text-[#292524]">{entry.title}</p>
                      <p class="mt-1 font-sans text-[13px] leading-[1.65] text-[#79716b]">{entry.body}</p>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ░░ DARK FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Experimente tudo que estamos construindo.
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Cada atualização acima está disponível na sua conta desde o primeiro dia. Comece por $1 e veja tudo em ação.
        </p>
        <a href="/pt-br/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Comece Seu Trial por $1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">$1 por 30 dias · Cancele quando quiser</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
