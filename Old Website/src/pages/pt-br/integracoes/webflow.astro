---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Como o Stacc se conecta ao Webflow?",
    a: "O Stacc se conecta ao Webflow via API do Webflow e um script leve adicionado às configurações de código personalizado do seu site Webflow. O plano Developer do Webflow não é necessário: a integração funciona com planos Business e superiores.",
  },
  {
    q: "O Stacc pode sincronizar dados com os campos do CMS do Webflow?",
    a: "Sim. O Stacc pode enviar dados do negócio — nome, endereço, horário, telefone e descrições de serviços — para campos de coleção do CMS do Webflow designados. Isso mantém as páginas de localização precisas sem atualizações manuais do CMS.",
  },
  {
    q: "O Stacc injeta schema local no Webflow?",
    a: "Sim. O Stacc adiciona o schema JSON-LD de LocalBusiness à seção de código personalizado do cabeçalho do seu site Webflow. Esses dados estruturados informam ao Google sua localização exata, horário e serviços, sem precisar editar JSON-LD manualmente.",
  },
  {
    q: "Posso integrar um widget de avaliações no Webflow?",
    a: "Sim. O Stacc fornece um HTML de integração que você adiciona a qualquer página do Webflow por meio de um componente HTML Embed. Suas avaliações mais recentes do Google e do Facebook são exibidas dinamicamente, atualizando-se automaticamente à medida que novas avaliações chegam, sem nenhuma alteração manual no seu site.",
  },
  {
    q: "Isso funciona para sites Webflow criados por agências?",
    a: "Sim. As agências podem conectar os sites Webflow de seus clientes ao Stacc e implantar schema local, sincronização NAP e feeds de avaliações em vários projetos de clientes a partir de uma única conta do Stacc. Cada site de cliente se conecta de forma independente e é sincronizado com os dados de localização correspondentes.",
  },
  {
    q: "Preciso modificar o tema ou os componentes do Webflow?",
    a: "Não. A integração do Stacc adiciona dados por meio das configurações de código personalizado do Webflow e da API do CMS, sem necessidade de modificar nenhum componente de design existente. Seu design no Webflow permanece exatamente como está.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integração com Webflow",
      "inLanguage": "pt-BR",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Conecte o Webflow ao theStacc. Sincronize dados de negócio local com campos do CMS, injete schema local automaticamente e integre feeds de avaliações em tempo real em sites Webflow.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Integrações", "item": "https://thestacc.com/pt-br/integracoes/" },
        { "@type": "ListItem", "position": 3, "name": "Webflow", "item": "https://thestacc.com/pt-br/integracoes/webflow/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integração com Webflow — Automação de SEO Local para Sites Webflow | theStacc"
  description="Mantenha os dados de negócio local do seu site Webflow sincronizados com o Google Business Profile e mais de 50 diretórios. Automatize o schema local e o NAP sem código personalizado."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integração · Webflow</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="#4353FF" aria-label="Webflow" aria-hidden="true">
                <path d="M17.44 7.636C16.26 9.87 15.42 11.54 14.65 13.03c-.17-.96-.27-2.04-.4-3.44l-.05-.61H10.8L8.56 16.36 7.34 9H4L6.56 21h3.37l2.3-7.3c.14 1.06.29 2.11.54 3.07l.56 2.23h3l4.67-11.36h-3.04z"/>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Webflow.<br />
            <span style="color:#4f39f6;">SEO local sempre sincronizado.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Conecte seu site Webflow ao Stacc e mantenha todos os dados de negócio local precisos automaticamente. Campos do CMS sincronizados, schema local injetado, feeds de avaliações integrados — sem modificar seu design nem escrever código personalizado.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conecte o Webflow gratuitamente
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sem código personalizado · Sincronização via API do CMS · Para agências e multi-localização
          </p>
        </div>
      </div>
    </section>


    <!-- ─── O QUE VOCÊ OBTÉM ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que você obtém</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Os dados de SEO local fluem do Stacc<br />para o CMS do Webflow automaticamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Sincronização de campos do CMS', body: 'Os dados do negócio — nome, endereço, horário, telefone, serviços — são enviados automaticamente para os campos de coleção do CMS do Webflow. As páginas de localização permanecem precisas sem edições manuais.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Injeção de schema local', body: 'O schema JSON-LD de LocalBusiness é injetado automaticamente pelas configurações de código personalizado do Webflow. Dados estruturados limpos para o Google, sem editar JSON-LD nem precisar de um desenvolvedor.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Feed de avaliações dinâmico', body: 'Integre um feed de avaliações em tempo real em qualquer página do Webflow por meio de um componente HTML Embed. As avaliações mais recentes do Google e do Facebook são exibidas automaticamente, sempre atualizadas.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Sincronização de horário', body: 'O horário atualizado no Stacc é enviado automaticamente para os campos do CMS do Webflow. Os clientes no seu site Webflow sempre veem o horário correto, sem atualizações manuais.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Ponte de dados de serviços', body: 'Nomes e descrições de serviços são sincronizados do seu GBP, via Stacc, para o Webflow. Informações de serviços coerentes em todos os lugares onde clientes e mecanismos de busca procuram por você.' },
            { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', title: 'Compatibilidade com CMS multi-localização', body: 'Para builds Webflow com múltiplas localizações, o Stacc sincroniza dados específicos de cada localização para elementos individuais do CMS, mantendo cada página de localização precisa sem gestão manual do CMS.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── COMO CONECTAR ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Três passos. Sem mudanças no design.<br />Webflow conectado.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Gere um token de API do Webflow', body: 'No Webflow, vá em Configurações da conta → Integrações → Acesso à API → Gerar token de API. Copie o token e cole-o no Stacc em Integrações → Webflow. O Stacc se conecta ao seu projeto imediatamente.' },
            { step: '02', title: 'Mapeie os campos do CMS com os dados do Stacc', body: 'O Stacc exibe as coleções do CMS do seu site Webflow. Mapeie os campos de localização (endereço, horário, telefone) com os dados correspondentes do Stacc. O Stacc manterá esses campos atualizados automaticamente.' },
            { step: '03', title: 'Adicione o código de schema e a integração de avaliações', body: 'Copie o trecho de schema do Stacc e cole-o na seção de código personalizado do cabeçalho do seu site Webflow. Adicione o HTML do widget de avaliações a qualquer página por meio de um componente Embed. Pronto: tudo funciona automaticamente a partir daí.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── ANTES / DEPOIS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. depois</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que muda quando o Webflow<br />se conecta ao Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarefa</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sem Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Com Stacc</div>
          </div>
          {[
            ['Adicionar schema local ao Webflow', 'Editar código personalizado manualmente ou contratar desenvolvedor', 'Injetado automaticamente pelo Stacc ao conectar'],
            ['Atualizar horário na página de localização', 'Entrar no CMS do Webflow, encontrar o item, editar', 'Atualize no Stacc, sincroniza com o CMS automaticamente'],
            ['Exibir avaliações no Webflow', 'Captura de tela + colar depoimentos no CMS', 'Integração em tempo real, sempre mostra as avaliações mais recentes'],
            ['Lançar nova página de localização', 'Inserir todos os dados manualmente na coleção do CMS', 'O Stacc envia automaticamente os dados da nova localização'],
            ['Manter NAP coerente', 'Atualizar Webflow, GBP e diretórios separadamente', 'Uma mudança no Stacc sincroniza em todas as plataformas'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUEM USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quem usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Três fluxos de trabalho que esta<br />integração ativa imediatamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Agências Webflow', title: 'Automação de SEO local em todos os sites de clientes', body: 'Conecte todos os sites Webflow de clientes ao Stacc e implante marcação schema, sincronização NAP e feeds de avaliações em cada projeto a partir de um único painel — em minutos, não horas por cliente.' },
            { label: 'Builds Webflow multi-localização', title: 'Páginas de localização que sempre exibem os dados corretos', body: 'Cada página de localização no Webflow exibe o endereço, horário e avaliações corretos para aquela localização, sincronizados automaticamente pelo Stacc sem tocar no CMS.' },
            { label: 'Negócios locais no Webflow', title: 'Um site Webflow que se mantém sozinho', body: 'Seu design no Webflow permanece exatamente como está. O Stacc adiciona a camada de SEO local por baixo: schema, NAP, avaliações — tudo mantido com precisão automaticamente.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── INTEGRAÇÕES RELACIONADAS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Usadas juntas com frequência</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O Webflow funciona melhor<br />ao lado destas.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'As alterações no GBP são sincronizadas com o Stacc e enviadas automaticamente para os campos do CMS do Webflow. O ciclo completo de dados, fechado.', href: '/pt-br/integracoes/google-business-profile/' },
            { title: 'Gestão de Citações', desc: 'Mantenha a coerência do NAP em mais de 50 diretórios, incluindo seu site Webflow, tudo gerenciado em um só lugar.', href: '/pt-br/funcionalidades/gestao-de-citacoes/' },
            { title: 'Painel Marca Branca', desc: 'Agências que entregam sites Webflow podem apresentar aos clientes um painel do Stacc com marca personalizada junto com a entrega do site.', href: '/pt-br/funcionalidades/painel-marca-branca/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perguntas frequentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perguntas sobre a<br />integração com Webflow
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA FINAL ─── -->
    <section class="relative overflow-hidden py-24" style="background:#ffffff;">
