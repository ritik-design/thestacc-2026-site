---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quais dados são sincronizados entre o Stacc e o Ghost?",
    a: "O nome do negócio, o endereço, o número de telefone, o horário e as descrições dos serviços são sincronizados do Stacc para o seu site Ghost. Qualquer atualização feita no Stacc, incluindo as alterações obtidas automaticamente do Google Business Profile, pode ser enviada ao conteúdo do Ghost sem necessidade de edições manuais.",
  },
  {
    q: "O Stacc injeta schema local no Ghost?",
    a: "Sim. O Stacc envia o schema JSON-LD de LocalBusiness para a seção de cabeçalho do seu site Ghost por meio da função de Injeção de Código. Esses dados estruturados ajudam o Google a entender a localização, o horário e a categoria do seu negócio para o posicionamento na busca local.",
  },
  {
    q: "Posso integrar um widget de avaliações no Ghost?",
    a: "Sim. O Stacc fornece um feed de avaliações incorporável que você pode adicionar a qualquer página ou publicação do Ghost por meio de um cartão HTML personalizado. Suas últimas avaliações do Google e do Facebook são exibidas dinamicamente, sem necessidade de atualizações manuais.",
  },
  {
    q: "A integração com o Ghost requer um desenvolvedor?",
    a: "Não. A integração utiliza as funções integradas de Injeção de Código e Integrações Personalizadas do Ghost, sem necessidade de modificar o tema nem escrever código personalizado. Se você consegue colar texto nas configurações do Ghost, consegue configurar isso.",
  },
  {
    q: "Quais planos do Ghost são compatíveis?",
    a: "A integração do Stacc funciona com o Ghost Pro (planos Starter, Creator, Team e Business) e com instalações de Ghost auto-hospedadas. A função de Injeção de Código do Ghost, necessária para a injeção de schema, está disponível em todos os planos pagos do Ghost Pro.",
  },
  {
    q: "Posso usar isso para um site Ghost com múltiplas localizações?",
    a: "Sim. Para negócios com múltiplas localizações, o Stacc pode preencher dados específicos de cada localização em diferentes páginas ou seções do Ghost. Os dados de cada localização — endereço, horário e avaliações — são mantidos precisos e sincronizados em todo o seu site Ghost.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integração com Ghost",
      "inLanguage": "pt-BR",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Conecte o Ghost ao theStacc. Sincronize dados de negócio local, injete schema local automaticamente e integre feeds de avaliações em tempo real no seu site com Ghost.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Integrações", "item": "https://thestacc.com/pt-br/integracoes/" },
        { "@type": "ListItem", "position": 3, "name": "Ghost", "item": "https://thestacc.com/pt-br/integracoes/ghost/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integração com Ghost — Sincronize Dados de SEO Local com seu Site Ghost | theStacc"
  description="Conecte o Ghost ao theStacc para manter os dados de negócio local consistentes no seu site com Ghost. Automatize o schema local e a sincronização NAP sem tocar no código."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integração · Ghost</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" aria-label="Ghost" aria-hidden="true">
                <circle cx="12" cy="12" r="10" fill="#15212A"/>
                <text x="12" y="17" font-size="14" font-weight="bold" fill="white" text-anchor="middle" font-family="sans-serif">G</text>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Ghost.<br />
            <span style="color:#4f39f6;">SEO local, integrado.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Conecte seu site Ghost ao Stacc e mantenha todos os dados de negócio local precisos automaticamente. NAP sincronizado, schema local injetado e feed de avaliações em tempo real integrado, sem tocar no seu tema nem escrever nenhum código.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conecte o Ghost gratuitamente
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sem código · Configuração em 3 minutos · Ghost Pro + auto-hospedado
          </p>
        </div>
      </div>
    </section>


    <!-- ─── O QUE VOCÊ OBTÉM ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que você obtém</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Os sinais de SEO local fluem do Stacc<br />para o seu site Ghost automaticamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Sincronização de dados NAP', body: 'O nome, endereço e telefone do negócio são mantidos precisos entre o Stacc, o Google e o seu site Ghost. Uma atualização no Stacc corrige tudo.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Injeção de schema local', body: 'O schema JSON-LD de LocalBusiness é enviado automaticamente para a seção de Injeção de Código do seu site Ghost. Dados estruturados limpos para o Google sem nenhum trabalho manual.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Feed de avaliações dinâmico', body: 'Integre suas últimas avaliações do Google e do Facebook em qualquer página do Ghost. O feed é atualizado automaticamente conforme novas avaliações chegam, sempre exibindo prova social recente.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Sincronização de horário', body: 'O horário atualizado no Stacc é enviado automaticamente para o seu site Ghost. Alterações de temporada, horários de feriados: os clientes sempre veem a informação correta.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Sincronização de serviços e descrição', body: 'As descrições de serviços do seu perfil do GBP são sincronizadas com as páginas do Ghost. Descrições precisas e consistentes onde quer que clientes e mecanismos de busca encontrem você.' },
            { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', title: 'Compatibilidade com múltiplas localizações', body: 'Conecte vários sites Ghost — um por localização — e sincronize dados específicos de cada localização em cada um. Cada site é mantido preciso sem gerenciamento manual.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── COMO CONECTAR ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Três etapas. Sem desenvolvedor.<br />Ghost conectado.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Gere uma chave de API no Ghost', body: 'No painel de administração do Ghost, vá em Configurações → Integrações → Adicionar Integração Personalizada. Dê um nome (por exemplo, "Stacc") e copie a Chave de API de administrador gerada. É isso que o Stacc usa para enviar dados ao seu site.' },
            { step: '02', title: 'Adicione a chave de API ao Stacc', body: 'Nas configurações do Stacc, em Integrações → Ghost, cole sua Chave de API de administrador e a URL do seu site Ghost. O Stacc verifica a conexão e confirma a qual localização ela está vinculada.' },
            { step: '03', title: 'Ative a sincronização e integre o widget de avaliações', body: 'Ative a sincronização NAP, a injeção de schema e a sincronização de horário. Obtenha o código de integração do widget de avaliações do Stacc e adicione-o a qualquer página do Ghost por meio de um cartão HTML personalizado. Pronto.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── ANTES / DEPOIS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. depois</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que muda quando o Ghost<br />se conecta ao Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarefa</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sem Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Com Stacc</div>
          </div>
          {[
            ['Adicionar schema local ao Ghost', 'Contratar desenvolvedor ou adicionar JSON-LD manualmente ao tema', 'Injetado automaticamente via Injeção de Código'],
            ['Atualizar o horário no site', 'Editar o conteúdo da página do Ghost manualmente', 'Atualize no Stacc, é enviado automaticamente'],
            ['Exibir avaliações no site Ghost', 'Capturar tela e colar avaliações manualmente', 'Integração em tempo real, sempre exibe as últimas avaliações'],
            ['Manter NAP consistente', 'Atualizar Ghost, GBP e diretórios separadamente', 'Uma alteração no Stacc sincroniza em todo lugar'],
            ['Alterar endereço do negócio', 'Atualizar 6+ plataformas manualmente', 'Atualize uma vez, o Stacc envia para todas as plataformas conectadas'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUEM USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quem usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Três fluxos de trabalho que esta<br />integração ativa imediatamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Negócios locais no Ghost', title: 'Dados locais sempre precisos sem ajuda de desenvolvedor', body: 'Seu site Ghost é mantido sincronizado com os dados reais do seu negócio automaticamente. Horário, endereço, telefone e avaliações: precisos em todo lugar sem atualizações manuais.' },
            { label: 'Negócios locais focados em conteúdo', title: 'Páginas locais otimizadas para SEO com schema correto', body: 'O Ghost foi feito para conteúdo. O Stacc adiciona a camada de SEO local: marcação de schema, consistência NAP e sinais de avaliações, para que seu conteúdo posicione localmente.' },
            { label: 'Agências de SEO', title: 'Automatize o SEO local para clientes no Ghost', body: 'Conecte os sites Ghost dos clientes ao Stacc e implante schema local, sincronização NAP e feeds de avaliações em todos os sites de clientes em minutos em vez de horas.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── INTEGRAÇÕES RELACIONADAS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Frequentemente usadas juntas</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O Ghost funciona melhor<br />ao lado destas.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'A fonte da verdade. As alterações no GBP são sincronizadas com o Stacc e depois enviadas automaticamente para o seu site Ghost.', href: '/pt-br/integracoes/google-business-profile/' },
            { title: 'Gestão de Citações', desc: 'Mantenha a consistência NAP em mais de 50 diretórios, incluindo seu site Ghost, a partir de um único painel.', href: '/pt-br/funcionalidades/gestao-de-citacoes/' },
            { title: 'Monitoramento de Avaliações', desc: 'Monitore avaliações em todas as plataformas e exiba as mais recentes no Ghost com a integração de avaliações em tempo real.', href: '/pt-br/funcionalidades/monitoramento-de-avaliacoes/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perguntas frequentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perguntas sobre a<br />integração com Ghost
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA FINAL ─── -->
    <section class="relative overflow-hidden py-24" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Conecte em minutos</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">
            Seu site Ghost.<br />SEO local gerenciado automaticamente.
          </h2>
