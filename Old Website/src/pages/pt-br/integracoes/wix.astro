---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quais dados são sincronizados entre o Stacc e meu site Wix?",
    a: "O nome do negócio, endereço, número de telefone, horário e descrições de serviços são sincronizados do Stacc para os campos de informações do negócio do seu site Wix. Qualquer atualização feita no Stacc — incluindo alterações obtidas do Google Business Profile — é enviada automaticamente ao Wix.",
  },
  {
    q: "O Stacc injeta schema local no Wix?",
    a: "Sim. O Stacc adiciona o schema JSON-LD de LocalBusiness ao seu site Wix por meio do código personalizado ou da seção de Metatags do Wix. Esses dados estruturados informam ao Google sua localização exata, horário e categoria de negócio, melhorando sua visibilidade na busca local sem necessidade de programação.",
  },
  {
    q: "Posso integrar um widget de avaliações no meu site Wix?",
    a: "Sim. O Stacc fornece um código HTML de integração que você adiciona a qualquer página do Wix por meio do widget de HTML incorporado. Suas avaliações mais recentes do Google e do Facebook são exibidas dinamicamente, atualizando-se automaticamente à medida que novas avaliações chegam.",
  },
  {
    q: "O Stacc funciona com os planos Wix Business e eCommerce?",
    a: "Sim. A integração do Stacc funciona com todos os planos Wix Business. Os recursos de integração de HTML e código personalizado necessários para a integração estão disponíveis nos planos pagos do Wix (Business Basic e superiores).",
  },
  {
    q: "Preciso de um desenvolvedor Wix para configurar isso?",
    a: "Não. A integração usa o widget de HTML incorporado do Wix e as configurações de código personalizado, sem necessidade de programação em Velo nem acesso de desenvolvedor ao Wix. Se você consegue adicionar uma seção ao seu site Wix, consegue configurar isso.",
  },
  {
    q: "As páginas de localização no Wix podem usar dados específicos de cada localização do Stacc?",
    a: "Sim. Para negócios multi-localização que usam o Wix, o Stacc pode fornecer dados de negócio específicos por localização — endereço, horário e telefone únicos por localização — para páginas individuais do Wix. Isso mantém cada página de localização precisa sem gestão manual.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integração com Wix",
      "inLanguage": "pt-BR",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Conecte o Wix ao theStacc. Sincronize dados de negócio local, injete schema local automaticamente e integre feeds de avaliações em tempo real no seu site de negócio Wix.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Integrações", "item": "https://thestacc.com/pt-br/integracoes/" },
        { "@type": "ListItem", "position": 3, "name": "Wix", "item": "https://thestacc.com/pt-br/integracoes/wix/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integração com Wix — Automatize o SEO Local no Seu Site de Negócio Wix | theStacc"
  description="Sincronize seu site Wix com o theStacc para manter dados de localização, horário e avaliações coerentes em todos os lugares. Automação de SEO local para sites de negócio Wix."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integração · Wix</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" aria-label="Wix" aria-hidden="true">
                <rect x="2" y="8" width="20" height="8" rx="2" fill="#FAAD00"/>
                <text x="12" y="15" font-size="9" font-weight="bold" fill="#000" text-anchor="middle" font-family="sans-serif">Wix</text>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Wix.<br />
            <span style="color:#4f39f6;">SEO local no piloto automático.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Conecte seu site de negócio Wix ao Stacc e mantenha os dados de negócio local precisos automaticamente. Schema injetado, NAP sincronizado, avaliações exibidas — sem tocar no design do seu Wix nem contratar um desenvolvedor.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conecte o Wix gratuitamente
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sem Velo · Configuração em 3 minutos · Funciona com qualquer template Wix
          </p>
        </div>
      </div>
    </section>


    <!-- ─── O QUE VOCÊ OBTÉM ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que você obtém</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Seu site Wix se mantém preciso<br />sem atualizações manuais.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Sincronização de dados NAP', body: 'O nome, endereço e telefone do negócio são mantidos coerentes entre o Stacc, o Google e o seu site Wix. Uma mudança no Stacc atualiza tudo automaticamente.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Injeção de schema local', body: 'O schema JSON-LD de LocalBusiness é injetado automaticamente no código personalizado do seu site Wix. Dados estruturados limpos para o Google, sem edição manual de JSON.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Widget de avaliações em tempo real', body: 'Adicione a integração de avaliações do Stacc a qualquer página do Wix. Suas avaliações mais recentes do Google e do Facebook são exibidas automaticamente, sempre atualizadas.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Sincronização de horário', body: 'O horário alterado no Stacc é enviado automaticamente ao seu site Wix. Mudanças sazonais, horários de feriados: os clientes sempre veem a informação correta.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Sincronização do mapa do Google incorporado', body: 'Seu mapa do Google incorporado é atualizado automaticamente quando seu endereço ou área de atendimento muda no Stacc, sem necessidade de atualizar o iframe.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Automação de páginas de localização', body: 'Para negócios Wix com múltiplas localizações, o Stacc preenche as páginas de localização individuais com os dados corretos de cada endereço, mantendo-as precisas automaticamente.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── COMO CONECTAR ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Três passos. Sem desenvolvedor.<br />Wix conectado.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Adicione a URL do seu site Wix ao Stacc', body: 'Nas configurações do Stacc, em Integrações → Wix, insira a URL do seu site Wix. O Stacc gerará um token de conexão e os trechos de código de schema e integração para o seu site.' },
            { step: '02', title: 'Adicione o código de schema ao código personalizado do Wix', body: 'No painel do Wix, vá em Configurações → Código Personalizado → Cabeçalho. Cole o trecho de schema fornecido pelo Stacc. Isso ativa a injeção automática de schema local e a sincronização de dados.' },
            { step: '03', title: 'Integre o widget de avaliações onde for necessário', body: 'Copie a integração do widget de avaliações do Stacc. No editor do Wix, adicione um widget de HTML a qualquer página e cole o código. As avaliações são exibidas imediatamente e atualizadas automaticamente.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── ANTES / DEPOIS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. depois</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que muda quando o Wix<br />se conecta ao Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarefa</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sem Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Com Stacc</div>
          </div>
          {[
            ['Adicionar schema local ao Wix', 'JSON-LD manual ou contratar desenvolvedor', 'Injetado automaticamente na seção de código personalizado'],
            ['Atualizar horário no site', 'Editar a página do Wix manualmente', 'Atualize no Stacc, sincroniza com o Wix automaticamente'],
            ['Exibir avaliações no Wix', 'Captura de tela e colar depoimentos manualmente', 'Integração em tempo real, atualiza automaticamente com novas avaliações'],
            ['Manter NAP coerente', 'Atualizar Wix, GBP e 50 diretórios separadamente', 'Uma mudança no Stacc atualiza em todos os lugares'],
            ['Alterar endereço', 'Entrar no Wix e atualizar todas as páginas individualmente', 'Atualize uma vez, o Stacc sincroniza em todas as plataformas'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUEM USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quem usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Três fluxos de trabalho que esta<br />integração ativa imediatamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Negócios locais de serviços', title: 'Site Wix que sempre exibe informações precisas', body: 'Sem mais horários desatualizados nem números de telefone incorretos no seu site Wix. O Stacc mantém tudo sincronizado automaticamente sem precisar entrar no Wix toda vez que algo muda.' },
            { label: 'Restaurantes no Wix', title: 'Horário, cardápio e avaliações sempre atualizados', body: 'Atualize o horário do seu negócio no Stacc uma vez e ele é enviado para o Google, Wix e mais de 50 diretórios simultaneamente. Seus clientes sempre veem a informação correta.' },
            { label: 'Agências de SEO', title: 'Implante SEO local em todos os sites Wix de clientes', body: 'Conecte todos os sites Wix dos clientes ao Stacc e adicione marcação schema, sincronização NAP e widgets de avaliações a cada site em minutos, não horas por cliente.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── INTEGRAÇÕES RELACIONADAS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Usadas juntas com frequência</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O Wix funciona melhor<br />ao lado destas.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'O GBP é a fonte de verdade. As alterações no GBP são sincronizadas com o Stacc e enviadas automaticamente ao seu site Wix.', href: '/pt-br/integracoes/google-business-profile/' },
            { title: 'Gestão de Citações', desc: 'Mantenha a coerência do NAP em mais de 50 diretórios, incluindo seu site Wix, a partir de um único painel.', href: '/pt-br/funcionalidades/gestao-de-citacoes/' },
            { title: 'Monitoramento de Avaliações', desc: 'Monitore novas avaliações do Google e do Facebook, depois exiba-as no Wix com a integração de avaliações em tempo real.', href: '/pt-br/funcionalidades/monitoramento-de-avaliacoes/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perguntas frequentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perguntas sobre a<br />integração com Wix
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA FINAL ─── -->
    <section class="relative overflow-hidden py-24" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Conecte em minutos</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">
            Seu site Wix.<br />Sempre preciso, automaticamente.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
