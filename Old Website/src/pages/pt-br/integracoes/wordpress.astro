---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quais dados são sincronizados entre o Stacc e o WordPress?",
    a: "O nome do negócio, endereço, número de telefone, horário e descrições de serviços são sincronizados automaticamente com os campos de informações do negócio do seu site WordPress. Qualquer atualização feita no Stacc — incluindo alterações obtidas do Google Business Profile — é enviada para os campos correspondentes do WordPress sem necessidade de atualizações manuais.",
  },
  {
    q: "O Stacc injeta marcação schema no WordPress automaticamente?",
    a: "Sim. O Stacc envia automaticamente a marcação de schema LocalBusiness para suas páginas do WordPress. Esses dados estruturados informam ao Google exatamente o que é seu negócio, onde está localizado e quando abre, ajudando suas páginas locais a posicionarem melhor nos resultados de busca local.",
  },
  {
    q: "Posso exibir avaliações no meu site WordPress?",
    a: "Sim. O Stacc fornece um widget de avaliações que você adiciona às páginas do WordPress via shortcode ou bloco. Ele busca dinamicamente suas avaliações mais recentes do Google e do Facebook, de modo que o widget sempre exibe prova social atualizada sem necessidade de atualizações manuais.",
  },
  {
    q: "Funciona com construtores de página como Elementor ou Divi?",
    a: "Sim. O widget de avaliações do Stacc e os campos de dados locais funcionam com construtores de página do WordPress, incluindo Elementor, Divi e Beaver Builder. O shortcode pode ser inserido em qualquer lugar onde um shortcode padrão do WordPress funcione.",
  },
  {
    q: "Quantos sites WordPress posso conectar?",
    a: "Você pode conectar um site WordPress por localização de negócio. As agências podem conectar vários sites WordPress de clientes em diferentes contas do Stacc ou dentro de uma única conta de agência, dependendo do plano contratado.",
  },
  {
    q: "É necessário um plugin do WordPress?",
    a: "Sim. O plugin do Stacc para WordPress é gratuito e está disponível no diretório de plugins do WordPress. Instale-o, adicione sua chave de API do Stacc na página de configurações e a conexão estará estabelecida. A configuração leva menos de 3 minutos.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integração com WordPress",
      "inLanguage": "pt-BR",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Conecte o WordPress ao theStacc. Sincronize dados de negócio local, injete schema automaticamente e integre widgets de avaliações em tempo real no seu site.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Integrações", "item": "https://thestacc.com/pt-br/integracoes/" },
        { "@type": "ListItem", "position": 3, "name": "WordPress", "item": "https://thestacc.com/pt-br/integracoes/wordpress/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integração com WordPress — Sincronize os Dados de Negócio Local com seu Site WordPress | theStacc"
  description="Mantenha seu site WordPress sincronizado com o Google Business Profile. Atualize horário, serviços e dados NAP no Stacc e eles são enviados ao WordPress automaticamente com schema local."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integração · WordPress</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="#21759B" aria-label="WordPress" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zM3.5 12c0-1.232.254-2.406.706-3.474L7.942 19.25A8.507 8.507 0 013.5 12zm8.5 8.5a8.498 8.498 0 01-2.416-.35l2.565-7.453 2.629 7.198a.764.764 0 00.058.112A8.496 8.496 0 0112 20.5zm1.172-11.217c.512-.027.972-.08.972-.08.457-.054.403-.726-.054-.699 0 0-1.374.108-2.263.108-.833 0-2.234-.107-2.234-.107-.458-.027-.512.672-.054.699 0 0 .433.053.891.08l1.323 3.623-1.858 5.574-3.094-9.197c.512-.027.972-.08.972-.08.457-.054.403-.726-.054-.699 0 0-1.374.108-2.263.108-.159 0-.347-.004-.546-.01A8.5 8.5 0 0120.398 9.3c-.044.001-.087.005-.131.005-.833 0-1.585.726-1.585 1.504 0 .699.403 1.29.833 1.989.322.565.699 1.29.699 2.343 0 .726-.28 1.569-.646 2.747l-.847 2.829L15.45 9.283zm2.64 10.375l2.61-7.542c.487-1.219.648-2.194.648-3.063 0-.315-.021-.607-.059-.886A8.5 8.5 0 0120.5 12a8.5 8.5 0 01-4.688 7.658z"/>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + WordPress.<br />
            <span style="color:#4f39f6;">Seu site, sempre sincronizado.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Mantenha os dados de negócio local do seu site WordPress precisos em todos os lugares que importam. Atualize as informações do seu negócio no Stacc uma única vez e elas são sincronizadas com o WordPress, schema local é injetado automaticamente e seu widget de avaliações é mantido sempre atualizado.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conecte o WordPress gratuitamente
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Plugin gratuito · Configuração em 3 minutos · Funciona com qualquer tema WordPress
          </p>
        </div>
      </div>
    </section>


    <!-- ─── O QUE VOCÊ OBTÉM ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que você obtém</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Os dados de SEO local fluem do Stacc<br />para o WordPress automaticamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Sincronização NAP automática', body: 'O nome, endereço e telefone do negócio são mantidos coerentes entre o Stacc, o Google e o seu site WordPress. Uma mudança no Stacc atualiza tudo.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Injeção de schema local', body: 'O schema JSON-LD de LocalBusiness é enviado automaticamente para suas páginas WordPress. Informa ao Google sua localização exata, horário e categoria sem precisar tocar no código do tema.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Widget de avaliações em tempo real', body: 'Integre um feed de avaliações dinâmico em qualquer página do WordPress. Suas avaliações mais recentes do Google e do Facebook são atualizadas automaticamente, sempre exibindo prova social atualizada.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Sincronização de horário', body: 'O horário atualizado no Stacc ou obtido do Google é enviado ao WordPress automaticamente. Mudanças de horário em feriados se propagam para todos os lugares em 30 segundos.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Sincronização de serviços e descrição', body: 'As listas de serviços e descrições do negócio do seu GBP são enviadas ao WordPress. Descrições coerentes e precisas em todos os lugares onde clientes e mecanismos de busca procuram por você.' },
            { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', title: 'Automação de páginas de localização', body: 'Para negócios com múltiplas localizações, o Stacc pode preencher páginas de localização individuais no WordPress com os dados corretos de cada endereço, de forma automática.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── COMO CONECTAR ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Três passos. Menos de três minutos.<br />WordPress conectado.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Instale o plugin do Stacc para WordPress', body: 'Pesquise "theStacc" no diretório de plugins do WordPress, instale e ative. O plugin é gratuito e não requer programação: adiciona uma página de configurações ao painel de administração do WordPress.' },
            { step: '02', title: 'Insira sua chave de API do Stacc', body: 'Copie sua chave de API nas configurações do Stacc (em Integrações → WordPress) e cole-a na página de configurações do plugin. Isso conecta seu site WordPress à sua conta do Stacc.' },
            { step: '03', title: 'Escolha o que sincronizar', body: 'Selecione quais dados sincronizar: NAP, horário, serviços, marcação schema e widgets de avaliações. Ative a sincronização automática e o Stacc manterá o WordPress atualizado automaticamente sempre que os dados do seu negócio mudarem.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── ANTES / DEPOIS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. depois</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que muda quando o WordPress<br />se conecta ao Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarefa</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sem Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Com Stacc</div>
          </div>
          {[
            ['Atualizar horário no site', 'Entrar no WordPress, encontrar o campo, atualizar manualmente', 'Atualize no Stacc, é enviado ao WP automaticamente'],
            ['Adicionar schema às páginas de localização', 'Contratar desenvolvedor ou instalar plugin de schema', 'Injetado automaticamente pelo Stacc ao conectar'],
            ['Exibir avaliações no site', 'Captura de tela e atualização manual da página de depoimentos', 'Widget em tempo real, sempre exibe as avaliações mais recentes'],
            ['Manter NAP coerente', 'Atualizar GBP, depois WP, depois mais de 50 sites separadamente', 'Uma mudança no Stacc sincroniza em todos os lugares'],
            ['Mudar para um novo endereço', 'Atualizar 8+ lugares manualmente', 'Atualize uma vez, o Stacc envia para todas as plataformas'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUEM USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quem usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Três fluxos de trabalho que esta<br />integração ativa imediatamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Negócios locais de serviços', title: 'Site sempre preciso sem atualizações manuais', body: 'O horário muda, os telefones mudam, os endereços mudam. Com o Stacc, seu site WordPress é atualizado automaticamente quando algo muda no seu GBP sem precisar de um desenvolvedor web.' },
            { label: 'Agências de SEO', title: 'Automatize o schema local para todos os sites WordPress de clientes', body: 'Conecte todos os sites WordPress de clientes ao Stacc. A marcação schema é instalada sozinha. Os sites dos clientes permanecem precisos. Horas de configuração por cliente reduzidas a um clique.' },
            { label: 'Negócios multi-localização', title: 'Páginas de localização que sempre exibem os dados corretos', body: 'Cada página de localização no WordPress exibe o horário, endereço e avaliações corretos para aquela localização específica, sincronizados automaticamente pelo Stacc.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── INTEGRAÇÕES RELACIONADAS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Usadas juntas com frequência</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O WordPress funciona melhor<br />ao lado destas.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'A fonte de verdade para seus dados locais. As alterações no GBP são sincronizadas com o Stacc e enviadas automaticamente ao WordPress.', href: '/pt-br/integracoes/google-business-profile/' },
            { title: 'Gestão de Citações', desc: 'Coerência de NAP em mais de 50 diretórios, incluindo seu site WordPress, tudo gerenciado em um só lugar.', href: '/pt-br/funcionalidades/gestao-de-citacoes/' },
            { title: 'Monitoramento de Avaliações', desc: 'Monitore avaliações no Google e Facebook, depois exiba-as no seu site WordPress com o widget de avaliações em tempo real.', href: '/pt-br/funcionalidades/monitoramento-de-avaliacoes/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perguntas frequentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perguntas sobre a<br />integração com WordPress
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
