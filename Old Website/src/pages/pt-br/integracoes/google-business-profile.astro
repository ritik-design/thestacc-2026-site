---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quais dados são sincronizados do Google Business Profile para o Stacc?",
    a: "Nome do negócio, endereço, telefone, horário, categorias, serviços, fotos, publicações e avaliações. As respostas a avaliações podem ser redigidas e publicadas pelo Stacc. As pontuações de completude do perfil e os alertas de campos faltantes são atualizados automaticamente quando os dados do perfil no Google mudam.",
  },
  {
    q: "Com que frequência os dados de avaliações são atualizados?",
    a: "O monitoramento de avaliações é em tempo real. Novas avaliações aparecem no Stacc em poucos minutos após serem publicadas no Google. Você receberá um alerta instantâneo — com o texto da avaliação, a pontuação em estrelas e o nome do avaliador — no momento em que chegar.",
  },
  {
    q: "Posso agendar publicações no GBP com antecedência?",
    a: "Sim. Escreva publicações e agende-as para datas e horários específicos, em localizações individuais ou em massa em todas as localizações conectadas simultaneamente. Você também pode definir um calendário de publicação recorrente e deixar o Stacc gerar e publicar conteúdo automaticamente com a cadência que você controla.",
  },
  {
    q: "Posso gerenciar contas do GBP com múltiplas localizações?",
    a: "Sim. Conecte tantas localizações quantas tiver. Todas aparecem em um único painel. Publique uma postagem em todas de uma vez, atualize o horário em todas em uma única ação ou gerencie cada localização individualmente. Adicione mais localizações a qualquer momento.",
  },
  {
    q: "A integração com o GBP está disponível em todos os planos?",
    a: "A conexão com o Google Business Profile está disponível em todos os planos do Stacc, incluindo o Starter. O número de localizações conectadas pode variar conforme o plano. Todos os planos incluem monitoramento de avaliações em tempo real, agendamento de publicações e acompanhamento do status do perfil.",
  },
  {
    q: "O Stacc usa OAuth ou armazena minha senha do Google?",
    a: "O Stacc usa exclusivamente o Google OAuth. A autenticação é feita pelo próprio login do Google: o Stacc nunca vê nem armazena sua senha. Você pode revogar o acesso nas configurações da sua conta do Google a qualquer momento.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integração com Google Business Profile",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "Conecte o Google Business Profile ao Stacc. Gerencie o GBP de cada localização a partir de um único painel: publicações automáticas, alertas de avaliações em tempo real e atualizações em massa.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Integrações", "item": "https://thestacc.com/pt-br/integracoes/" },
        { "@type": "ListItem", "position": 3, "name": "Google Business Profile", "item": "https://thestacc.com/pt-br/integracoes/google-business-profile/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integração com Google Business Profile — Gerencie Todas as Localizações em um Painel | theStacc"
  description="Conecte o Google Business Profile ao theStacc. Gerencie publicações, avaliações e atualizações de perfil em todas as suas localizações a partir de um único painel. A configuração leva 2 minutos."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integração · Google Business Profile</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/><path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z" fill="#4285F4"/>
                <path d="M17.04 12.2c0-.4-.04-.8-.1-1.2H12v2.28h2.84c-.12.66-.5 1.22-1.06 1.6v1.32h1.72c1-.94 1.54-2.32 1.54-4z" fill="#4285F4"/>
                <path d="M12 18c1.44 0 2.64-.48 3.52-1.28l-1.72-1.32c-.48.32-1.08.52-1.8.52-1.38 0-2.56-.94-2.98-2.2H7.26v1.36C8.14 16.94 9.96 18 12 18z" fill="#34A853"/>
                <path d="M9.02 13.72c-.1-.32-.16-.66-.16-1.02s.06-.7.16-1.02V10.3H7.26C6.9 10.96 6.7 11.7 6.7 12.7s.2 1.72.56 2.38l1.76-1.36z" fill="#FBBC05"/>
                <path d="M12 9.5c.78 0 1.48.26 2.02.78l1.52-1.52C14.64 7.88 13.44 7.3 12 7.3c-2.04 0-3.86 1.06-4.74 2.62l1.76 1.36C9.44 10.44 10.62 9.5 12 9.5z" fill="#EA4335"/>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Google Business Profile.<br />
            <span style="color:#4f39f6;">Todas as localizações, um painel.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Conecte seu Google Business Profile uma vez. O Stacc gerencia as publicações, monitora suas avaliações em tempo real, detecta inconsistências no perfil e acompanha suas posições no Maps, para cada localização, automaticamente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conectar GBP gratuitamente
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Como funciona
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Seguro com OAuth · Configuração em 2 minutos · Para 1 ou 100 localizações
          </p>
        </div>
      </div>
    </section>


    <!-- ─── O QUE VOCÊ OBTÉM ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que você obtém</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte o GBP uma vez. Tudo funciona<br />automaticamente a partir daí.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z', title: 'Publique em todas as localizações de uma vez', body: 'Escreva uma publicação e publique em 1 ou em todas as localizações simultaneamente. Sem acessar contas GBP separadamente. Sem copiar e colar. Uma ação, tudo feito.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Alertas de avaliações em tempo real', body: 'Novas avaliações aparecem no Stacc em poucos minutos após chegarem ao Google. Você recebe um alerta instantâneo com o texto, a pontuação e um modelo de resposta pronto para usar.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoramento do status do perfil', body: 'Campos incompletos, horários inconsistentes, fotos faltando: o Stacc detecta as lacunas do perfil automaticamente para que sua ficha esteja sempre completa e seus sinais de ranqueamento fortes.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Edição em massa de horários e informações', body: 'Atualize o horário de funcionamento, o telefone e a descrição em todas as localizações em uma única ação. Horários especiais enviados para 50 localizações em 30 segundos.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Correlação de ranqueamento no Maps', body: 'Observe como a atividade de publicações e a completude do perfil se correlacionam com sua posição no pacote local e no Maps, semana a semana.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Relatórios de desempenho do GBP', body: 'Visualizações, cliques, pedidos de rota e ligações: os dados do GBP são incorporados automaticamente aos seus relatórios de clientes toda semana.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── SETUP STEPS ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            3 etapas. Leva 2 minutos.<br />Funciona sozinho depois.
          </h2>
        </div>
        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Autentique-se com o Google', body: 'Faça login com a conta do Google que gerencia seus perfis de negócio. O Stacc usa OAuth: sua senha nunca é armazenada nem compartilhada. Você pode revogar o acesso nas configurações da sua conta do Google a qualquer momento.' },
            { n: '02', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Selecione suas localizações', body: 'Escolha quais localizações conectar: uma ou todas. Cada localização aparece no Stacc como sua própria entidade com seu próprio painel, calendário de conteúdo e acompanhamento de desempenho.' },
            { n: '03', icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Tudo funciona automaticamente', body: 'As publicações são agendadas. As avaliações alertam em tempo real. As pontuações de status do perfil são atualizadas diariamente. O ranqueamento é acompanhado semanalmente. Você gerencia a estratégia. O Stacc gerencia a execução.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
        <p class="mt-6 text-center font-mono text-[11px] uppercase tracking-[0.14em] text-[#79716b]">
          Tempo médio de configuração: 2 minutos · Sem conhecimentos técnicos necessários
        </p>
      </div>
    </section>


    <!-- ─── BEFORE / AFTER ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que é automatizado</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarefa manual do GBP, resolvida.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Cada item desta tabela é algo que você faz manualmente hoje. Após conectar o GBP ao Stacc, tudo funciona automaticamente.
          </p>
        </div>
        <div class="mx-auto mt-10 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-2 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Sem Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Com Stacc</div>
          </div>
          {[
            { before: 'Fazer login em cada conta GBP separadamente', after: 'Um painel para todas as localizações' },
            { before: 'Publicar em cada localização individualmente', after: 'Escreva uma vez, publique em todas — agendado ou imediato' },
            { before: 'Verificar novas avaliações recarregando o GBP manualmente', after: 'Alerta em tempo real em poucos minutos após uma nova avaliação' },
            { before: 'Auditar cada perfil manualmente para ver completude', after: 'Pontuação de status automática + alertas de campos faltantes' },
            { before: 'Atualizar horários localização por localização', after: 'Edição em massa — atualize todas em uma única ação' },
            { before: 'Exportar dados do GBP para relatórios de clientes', after: 'Os dados do GBP fluem para relatórios automáticos de clientes' },
          ].map((row, i) => (
            <div class={`grid grid-cols-2 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 flex items-center gap-3">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                <span class="font-sans text-[13px] text-[#6b7280]">{row.before}</span>
              </div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 flex items-center gap-3">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUEM USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quem usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Projetado para equipes que gerenciam<br />GBP em qualquer escala.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-5xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { type: 'Agências', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', desc: 'As contas GBP de cada cliente ficam em um espaço de trabalho separado. Publique conteúdo, monitore avaliações e relate o status do GBP para cada cliente sem acessar suas contas do Google individualmente.', highlight: 'Relatórios de marca branca incluídos' },
            { type: 'Negócios com múltiplas localizações', icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10', desc: 'Gerencie o GBP para 10 ou 100 localizações com o mesmo esforço que para 1. Envie horários especiais para todas de uma vez. Publique uma promoção em todas simultaneamente. Monitore todas as avaliações a partir de um único feed.', highlight: 'Todas as localizações, um painel' },
            { type: 'Negócios de localização única', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', desc: 'Conecte seu GBP uma vez. Defina um calendário de publicação. Receba alertas de avaliações na hora. Pare de acessar manualmente: o Stacc gerencia a manutenção contínua enquanto você dirige o negócio.', highlight: 'Funciona no piloto automático' },
          ].map(u => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={u.icon}/></svg>
              </div>
              <p class="font-sans text-[15px] font-semibold text-[#111827]">{u.type}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#57534e]">{u.desc}</p>
              <div class="mt-4 inline-flex items-center gap-2 rounded-full bg-[#f5f3ff] px-3 py-1.5">
                <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
                <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">{u.highlight}</span>
              </div>
            </div>
          ))}
        </div>
