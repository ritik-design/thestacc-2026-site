---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "Quais fatores determinam o posicionamento no Google Maps?", a: "Os posicionamentos no Google Maps (pacote local) são determinados principalmente por três fatores: relevância (quão bem seu perfil corresponde à pesquisa), distância (proximidade ao pesquisador) e destaque (o quão conhecido seu negócio é online, incluindo quantidade e qualidade das avaliações, consistência de citações e sinais de atividade do GBP)." },
  { q: "Publicar no GBP melhora o posicionamento no Google Maps?", a: "Sim. A atividade regular de posts no GBP é um sinal de posicionamento documentado para visibilidade no pacote local e no Maps. O Google trata a publicação consistente como um indicador de uma empresa ativa e legítima — o que se correlaciona positivamente com a posição no pacote local. Empresas que publicam consistentemente geralmente superam perfis inativos em uma janela de 90 dias." },
  { q: "Como as citações afetam o posicionamento no Google Maps?", a: "A consistência de citações é um fator central de posicionamento no Maps. O Google faz referência cruzada das informações da sua empresa (nome, endereço, telefone) em toda a web. Quando seus dados NAP são consistentes em mais de 50 diretórios, isso sinaliza precisão dos dados — o que melhora sua pontuação de confiança no Maps. Citações inconsistentes criam confusão que prejudica os posicionamentos." },
  { q: "Como as avaliações afetam o posicionamento no Google Maps?", a: "A quantidade, recência, nota média e taxa de resposta a avaliações contribuem para a pontuação de destaque no Maps. Empresas com maior volume de avaliações recentes e positivas com respostas do proprietário superam empresas com menos avaliações ou avaliações mais antigas em mercados locais competitivos." },
  { q: "Quanto tempo leva para melhorar o posicionamento no Google Maps?", a: "A maioria das empresas vê uma melhora mensurável em 60 a 90 dias de atividade consistente no GBP e limpeza de citações. Mercados mais competitivos levam mais tempo. As melhorias de posicionamento se acumulam: atividade consistente por 6 meses produz resultados significativamente mais duradouros do que esforços de curto prazo." },
  { q: "O Stacc ajuda especificamente com o posicionamento no Google Maps?", a: "Sim. O Stacc automatiza as três atividades de maior impacto para o posicionamento no Maps: publicação consistente de posts no GBP (30/mês por unidade), monitoramento e correção de precisão de citações em mais de 50 diretórios, e monitoramento de avaliações para garantir respostas oportunas. As três rodam automaticamente — você não precisa se lembrar de fazê-las." },
  { q: "O Stacc pode melhorar o posicionamento no Maps para múltiplas unidades?", a: "Sim. O Stacc gerencia posts no GBP, citações e monitoramento de avaliações em todas as unidades simultaneamente. Cada unidade recebe a mesma atividade consistente de SEO — que é a chave para escalar posicionamentos no Maps sem escalar sua equipe." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Posicionamento no Google Maps", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Automatize as atividades que melhoram os posicionamentos no Google Maps: publicação de posts no GBP, monitoramento de citações e gestão de avaliações — em todas as unidades, todos os dias.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Posicionamento no Google Maps", "item": "https://thestacc.com/pt-br/posicionamento-google-maps/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Posicionamento no Google Maps — Apareça no Pacote Local | theStacc"
  description="Melhore o posicionamento no Google Maps automatizando posts no GBP, gestão de citações e monitoramento de avaliações. O theStacc executa os três de forma consistente em todas as unidades."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Posicionamento no Google Maps · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Automatize os sinais que melhoram<br />
            <span style="color:#4f39f6;">seu posicionamento no Google Maps.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O posicionamento no Google Maps responde à atividade consistente no GBP, precisão de citações e sinais de avaliações. O Stacc automatiza os três — em todas as unidades, todos os dias — para que suas melhorias de posicionamento se acumulem sem esforço manual.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver como funciona
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · Garantia de 30 dias · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como o posicionamento no Google Maps realmente funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Os negócios que vencem no Maps<br />fazem três coisas de forma consistente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Os posicionamentos no Google Maps no pacote local são determinados por relevância, distância e destaque. Você não pode mudar sua localização física (distância), e a relevância vem da categoria e conteúdo do seu GBP. O que você pode realmente influenciar é o destaque — e o destaque é uma função de três coisas que você controla: sua atividade no GBP, a consistência das suas citações e seu perfil de avaliações.</p>
            <p>Os negócios que aparecem consistentemente no pacote local dos 3 primeiros resultados estão publicando no GBP várias vezes por semana, mantendo dados NAP precisos em todos os principais diretórios, e respondendo ativamente às avaliações. Não ocasionalmente — de forma consistente, ao longo de meses. O efeito cumulativo da atividade consistente é o que separa os negócios nas posições 1 a 3 das posições 4 a 10.</p>
            <p class="font-semibold text-[#111827]">O Stacc automatiza os três. Todo dia. Para cada unidade. Sem lembretes, sem trabalho manual, sem semanas puladas. Apenas sinais de posicionamento consistentes se acumulando mês após mês até que a posição no Maps que você quer se torne a posição no Maps que você tem.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc automatiza para o posicionamento no Maps</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todos os sinais de alto impacto para o Maps.<br />Todos automatizados. Todos consistentes.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: '30 posts no GBP por mês', body: 'O Stacc publica 30 posts por unidade por mês segmentando palavras-chave locais. A atividade consistente é um dos sinais de posicionamento no GBP mais fortes para o posicionamento no Maps.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoramento de citações', body: 'Dados NAP precisos em mais de 50 diretórios são um sinal central de destaque no Maps. O Stacc monitora inconsistências e as sinaliza para correção — evitando a queda de posicionamento por conflitos de dados.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitoramento e alertas de avaliações', body: 'Novas avaliações disparam alertas em tempo real. Respostas oportunas às avaliações contribuem para sua taxa de resposta no GBP — um sinal de posicionamento no Maps. Responda diretamente pelo painel sem fazer login no GBP.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreamento diário de posição no Maps', body: 'Rastreie sua posição no pacote local e no Maps para cada palavra-chave diariamente. Veja exatamente onde você está a cada manhã e detecte mudanças de posicionamento no primeiro dia — não no trigésimo.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Proteção contra edições não autorizadas', body: 'Edições de terceiros no seu perfil GBP são detectadas antes de entrarem no ar. Dados imprecisos no perfil são uma das formas mais rápidas de cair no posicionamento do Maps — o Stacc evita isso.' },
            { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Análise de tendências de posicionamento', body: 'Visões de tendência de posicionamento de 30, 60 e 90 dias por unidade e palavra-chave. Veja o efeito cumulativo da atividade consistente de SEO na posição no Maps ao longo do tempo.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automação em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o Stacc está fazendo<br />para seu posicionamento no Maps todo dia.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreamento Diário de Posição</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sua posição no Maps, todo dia, sem login.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Você não pode gerenciar o que não mede. O Stacc rastreia sua posição no pacote local e no Maps para cada palavra-chave em cada unidade, atualizando diariamente. Veja exatamente onde você está toda manhã. Quando a posição se move — para cima ou para baixo — você recebe um alerta no mesmo dia, não semanas depois quando o dano já foi feito.
              </p>
              <a href="/pt-br/software-rastreamento-posicoes/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver rastreamento de posições
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posições no Maps — hoje</p>
              {[
                { keyword: 'encanador São Paulo', pos: '#1', trend: '↑ +2' },
                { keyword: 'encanador zona sul SP', pos: '#2', trend: '↑ +1' },
                { keyword: 'conserto canos 24h SP', pos: '#3', trend: '→ 0' },
                { keyword: 'desentupidora SP', pos: '#4', trend: '↑ +3' },
                { keyword: 'encanador perto de mim', pos: '#2', trend: '↑ +1' },
              ].map(item => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <p class="font-sans text-[12px] font-medium text-[#374151]">{item.keyword}</p>
                  <div class="flex items-center gap-3">
                    <span class="font-mono text-[12px] font-bold text-[#111827]">{item.pos}</span>
                    <span class="font-mono text-[11px] text-[#059669]">{item.trend}</span>
                  </div>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Atualizado diariamente · Alertas automáticos</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendário de posts GBP — abril</p>
              {[
                { date: '01 Abr', title: 'Promoção de serviço de primavera', status: true },
                { date: '08 Abr', title: 'Post de destaque do serviço', status: true },
                { date: '15 Abr', title: 'Post de avaliação de cliente', status: true },
                { date: '22 Abr', title: 'Post de oferta especial', status: true },
                { date: '29 Abr', title: 'Post de perguntas frequentes', status: true },
              ].map(item => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.title}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{item.date}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669]">✓ Publicado</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 posts/mês · Sinais GBP consistentes</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Sinais de Atividade GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sinais de atividade GBP melhoram posicionamento.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Posts regulares no GBP são um sinal de posicionamento documentado para o algoritmo local do Google. O Stacc publica 30 posts por unidade por mês — segmentando palavras-chave locais, tópicos sazonais e pesquisas de alta intenção — mantendo cada perfil ativo todos os dias. A atividade consistente se acumula em meses: é isso que move a agulha do posicionamento no Maps da posição 7 para o Top 3.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Consistência de Citações</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Consistência de citações no Maps.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O Google faz referência cruzada das informações do seu negócio em toda a web. Quando seu nome, endereço e telefone (NAP) são inconsistentes em diretórios, isso cria confusão que prejudica sua pontuação de confiança no Maps. O Stacc monitora continuamente seus dados em mais de 50 diretórios, sinaliza inconsistências e permite corrigi-las em massa — mantendo a precisão que o algoritmo do Maps exige.
              </p>
              <a href="/pt-br/software-construcao-citacoes/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver gestão de citações
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Status de citações — principais diretórios</p>
              {[
                { dir: 'Google Business Profile', status: 'Consistente', ok: true },
                { dir: 'Bing Places', status: 'Consistente', ok: true },
                { dir: 'Yelp', status: 'Consistente', ok: true },
                { dir: 'Apple Maps', status: 'Consistente', ok: true },
                { dir: 'Facebook Business', status: 'Consistente', ok: true },
              ].map(item => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <p class="font-sans text-[12px] font-medium text-[#374151]">{item.dir}</p>
                  <span class="font-mono text-[11px] text-[#059669]">✓ {item.status}</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ diretórios monitorados · NAP consistente</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que a automação de posicionamento<br />no Google Maps realmente entrega.
