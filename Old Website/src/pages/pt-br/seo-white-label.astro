---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é SEO white-label?", a: "SEO white-label é quando uma agência entrega serviços de SEO local a clientes utilizando um software com a marca da própria agência — logo e domínio dela, não do fornecedor do software. Os clientes vivenciam a marca da agência em todos os painéis, relatórios e notificações, sem visibilidade sobre as ferramentas utilizadas." },
  { q: "O que é personalizado com a marca no Stacc?", a: "Tudo que o cliente vê: a URL do painel (seu domínio via CNAME), logos e cores, PDFs de relatórios, e-mails de entrega automática de relatórios e notificações de login do cliente. O nome e a marca do Stacc nunca aparecem em nada que um cliente visualize." },
  { q: "Preciso de conhecimentos técnicos para configurar a marca branca?", a: "Não é necessário nenhum desenvolvedor. Você faz upload do seu logo, define o nome e o esquema de cores da agência e configura um registro CNAME para o seu subdomínio. A configuração completa leva cerca de 2 horas. Tudo é feito pelo painel — sem código, sem necessidade de conhecimento técnico." },
  { q: "Cada cliente pode ter seu próprio login?", a: "Sim. Cada cliente recebe um login com acesso limitado aos seus próprios locais. Os clientes não conseguem ver dados de outros clientes. Você mantém acesso administrativo total a todos os clientes. Os logins de clientes são incluídos a R$0, independentemente de quantos clientes você adicionar." },
  { q: "Posso usar um domínio personalizado para os painéis dos clientes?", a: "Sim. Aponte seu subdomínio (ex.: seo.suaagencia.com.br) para o Stacc via registro CNAME. Todos os painéis voltados ao cliente carregam no seu domínio. O domínio do Stacc nunca aparece em nenhuma URL do cliente." },
  { q: "A marca branca afeta o preço?", a: "As funcionalidades de marca branca estão incluídas nos planos Growth e Scale do Stacc. Os planos começam a partir de $49/mês para o módulo de SEO Local. Os logins de clientes são sempre $0 por acesso." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO White-Label", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Software de SEO local white-label para agências. Painéis personalizados, relatórios e logins de clientes no seu domínio — o Stacc nunca aparece em nada que os clientes vejam.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "SEO White-Label", "item": "https://thestacc.com/pt-br/seo-white-label/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de SEO White-Label para Agências — Sua Marca em Tudo | theStacc"
  description="SEO local white-label para agências. Painéis personalizados, relatórios e logins de clientes no seu domínio. Configuração em 2 horas. Logins de clientes a $0 por acesso."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO White-Label · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local entregue<br />
            <span style="color:#4f39f6;">com a marca da sua agência.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Cada painel, relatório e login de cliente carrega o logo e o domínio da sua agência. O Stacc nunca aparece em nada que os clientes vejam. A sua marca fica mais forte cada vez que um cliente faz login e vê os resultados.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/funcionalidades/painel-marca-branca/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funcionalidades white-label
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · 30 dias de garantia · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLEM NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por que a marca importa em cada interação com o cliente</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada ferramenta com o logo de um fornecedor<br />é um ponto de contato que a sua marca não controla.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Quando um cliente faz login em um painel com o nome de um fornecedor, ele não está pensando na sua agência — está pensando naquele fornecedor. Cada login, cada relatório, cada e-mail está construindo o reconhecimento de marca do fornecedor à sua custa. E se ele acessar a página de preços desse fornecedor, começa a fazer uma pergunta que você não quer que ele faça.</p>
            <p>O SEO white-label muda essa dinâmica. Cada interação que um cliente tem com o seu serviço — cada login, cada relatório, cada alerta — carrega o nome e o logo da sua agência. Os resultados que ele vê são mentalmente atribuídos à sua equipe. O valor da sua marca se acumula a cada relatório recebido. E os clientes que veem sua marca de forma consistente em resultados positivos ficam por mais tempo.</p>
            <p class="font-semibold text-[#111827]">A configuração white-label do Stacc leva 2 horas. Os logins de clientes custam $0. E cada ponto de contato com o cliente a partir daí constrói a sua marca — não a nossa.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades white-label</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tudo voltado ao cliente.<br />Toda a sua marca, nada da nossa.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Domínio personalizado (CNAME)', body: 'Os painéis dos clientes carregam no seu subdomínio (ex.: seo.suaagencia.com.br). O domínio do Stacc nunca aparece em nenhuma URL do cliente.' },
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Logo e personalização de marca completos', body: 'Faça upload do seu logo, defina o esquema de cores e configure o nome da sua agência. Identidade de marca consistente em todas as telas que os clientes veem.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Relatórios automatizados com sua marca', body: 'Os relatórios carregam o seu logo, são enviados do seu domínio e formatados com suas cores. Entregues conforme a sua agenda — semanal ou mensal — sem trabalho manual.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: '$0 por login de cliente', body: 'Adicione logins ilimitados de clientes. O preço é baseado em localizações gerenciadas — não em acessos. Você pode dar a cada cliente seu próprio login sem impacto na sua fatura.' },
            { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Notificações por e-mail com sua marca', body: 'Alertas automáticos e e-mails de entrega de relatórios são enviados do seu domínio. Nenhum endereço de e-mail thestacc.com aparece na caixa de entrada dos seus clientes.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Acesso de clientes por função', body: 'Os clientes veem apenas seus próprios locais e dados. Sua equipe tem visibilidade administrativa total sobre todos os clientes. As permissões são aplicadas no nível dos dados.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">SEO white-label em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que a sua marca parece quando<br />o Stacc entrega os resultados.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Plataforma Completa White-Label</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Plataforma completa. Sua marca.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O Stacc entrega uma plataforma de SEO local completa — rastreamento de posições, automação de GBP, gestão de citações, monitoramento de avaliações e relatórios — inteiramente sob a marca da sua agência. Você configura o CNAME para o seu subdomínio, faz upload do logo e define as cores uma única vez. A partir daí, cada cliente entra em um ambiente 100% com a sua marca. O Stacc nunca aparece.
              </p>
              <a href="/pt-br/seo-local-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver SEO local white-label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between rounded-xl bg-[#4f39f6] px-4 py-3">
                <span class="font-sans text-[13px] font-bold text-white">Sua Agência Digital</span>
                <span class="font-mono text-[10px] text-white/60">app.suaagencia.com.br</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-3">Visão geral — todos os clientes</p>
              {[
                { client: 'Clínica Carvalho', status: 'Ativo', score: '94/100' },
                { client: 'Grupo Gastronômico', status: 'Ativo', score: '87/100' },
                { client: 'Auto Center Norte', status: 'Ativo', score: '91/100' },
                { client: 'Studio Fit Pinheiros', status: 'Ativo', score: '89/100' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <span class="font-sans text-[12px] text-[#374151]">{row.client}</span>
                  <div class="flex items-center gap-2">
                    <span class="rounded-full bg-[#dcfce7] px-2 py-0.5 font-mono text-[9px] font-semibold text-[#059669]">{row.status}</span>
                    <span class="font-mono text-[11px] font-bold text-[#4f39f6]">{row.score}</span>
                  </div>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Zero menção ao Stacc · Só a sua marca</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Estrutura de precificação — revendedor</p>
              <div class="space-y-3">
                <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                  <p class="font-mono text-[10px] text-[#79716b] uppercase tracking-wide mb-1">Seu custo (Stacc)</p>
                  <p class="font-sans text-[1.5rem] font-bold text-[#374151]">$49<span class="text-[14px] font-normal text-[#79716b]">/mês</span></p>
                  <p class="font-mono text-[10px] text-[#79716b] mt-1">por localização gerenciada</p>
                </div>
                <div class="flex items-center justify-center text-[#79716b]">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                </div>
                <div class="rounded-xl border border-[#4f39f6] bg-[#f5f3ff] p-4">
                  <p class="font-mono text-[10px] text-[#4f39f6] uppercase tracking-wide mb-1">Você cobra do cliente</p>
                  <p class="font-sans text-[1.5rem] font-bold text-[#4f39f6]">$300–$1.500<span class="text-[14px] font-normal text-[#818cf8]">/mês</span></p>
                  <p class="font-mono text-[10px] text-[#818cf8] mt-1">margem total sua</p>
                </div>
              </div>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Modelo de Revenda</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                $300–$1.500 de margem por cliente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                A flexibilidade de precificação do modelo white-label é onde o Stacc cria valor real para as agências. Você paga $49/mês pela plataforma e cobra dos seus clientes o que faz sentido para o seu mercado — normalmente $300 a $1.500 por localização gerenciada. A diferença é a sua margem. Com 10 clientes a $500/mês, são $4.510 de margem bruta por mês de um serviço de SEO local automatizado.
              </p>
              <a href="/pt-br/revendedor-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver programa de revendedor
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Escale Sem Contratar</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Escale sem contratar. O Stacc faz a entrega por você.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O principal gargalo para escalar uma agência de SEO local é o tempo de execução por cliente. O Stacc elimina esse gargalo. Com a entrega automatizada, cada cliente recebe o mesmo nível de serviço — 30 posts no GBP, rastreamento diário, monitoramento de citações, alertas de avaliações e relatórios mensais — independentemente de você ter 5 ou 50 clientes. Você não precisa contratar mais ninguém para atender mais um cliente.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver solução para agências
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Painel da agência — 20 clientes ativos</p>
              {[
                { client: 'Clínica Norte', posts: '30/30', rank: '#2', status: '✓' },
                { client: 'Auto Pinheiros', posts: '30/30', rank: '#3', status: '✓' },
                { client: 'Studio Fit', posts: '30/30', rank: '#1', status: '✓' },
                { client: 'Advocacia Central', posts: '30/30', rank: '#4', status: '✓' },
              ].map(row => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-2.5">
                  <span class="flex-1 font-sans text-[12px] text-[#374151] truncate">{row.client}</span>
                  <span class="font-mono text-[10px] text-[#79716b]">{row.posts} posts</span>
                  <span class="font-mono text-[11px] font-bold text-[#4f39f6]">{row.rank}</span>
                  <span class="font-mono text-[11px] text-[#059669]">{row.status}</span>
                </div>
              ))}
              <div class="mt-3 flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-3 py-2">
                <span class="font-mono text-[10px] text-[#79716b]">+ 16 clientes adicionais</span>
                <span class="font-mono text-[10px] font-semibold text-[#059669]">Todos automatizados ✓</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
