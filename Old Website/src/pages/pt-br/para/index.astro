---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const localSEO = [
  { label: 'Academias',                href: '/pt-br/para/academias/'                },
  { label: 'Advogados',                href: '/pt-br/para/advogados/'                },
  { label: 'Aulas Particulares',       href: '/pt-br/para/aulas-particulares/'       },
  { label: 'Casamentos',               href: '/pt-br/para/casamentos/'               },
  { label: 'Climatização',             href: '/pt-br/para/climatizacao/'             },
  { label: 'Consultores Financeiros',  href: '/pt-br/para/consultores-financeiros/'  },
  { label: 'Contadores',               href: '/pt-br/para/contadores/'               },
  { label: 'Dentistas',                href: '/pt-br/para/dentistas/'                },
  { label: 'Eletricistas',             href: '/pt-br/para/eletricistas/'             },
  { label: 'Empreiteiros',             href: '/pt-br/para/empreiteiros/'             },
  { label: 'Encanadores',              href: '/pt-br/para/encanadores/'              },
  { label: 'Fotógrafos',               href: '/pt-br/para/fotografos/'               },
  { label: 'Imobiliárias',             href: '/pt-br/para/imobiliarias/'             },
  { label: 'Inspetores Residenciais',  href: '/pt-br/para/inspetores-residenciais/'  },
  { label: 'Mudanças',                 href: '/pt-br/para/mudancas/'                 },
  { label: 'Paisagismo',               href: '/pt-br/para/paisagismo/'               },
  { label: 'Quiropratas',              href: '/pt-br/para/quiropraticos/'            },
  { label: 'Restaurantes',             href: '/pt-br/para/restaurantes/'             },
  { label: 'Revendedores de Veículos', href: '/pt-br/para/revendedores-automoveis/'  },
  { label: 'Salões de Beleza',         href: '/pt-br/para/saloes-beleza/'            },
  { label: 'Saúde',                    href: '/pt-br/para/saude/'                    },
  { label: 'Seguros',                  href: '/pt-br/para/seguros/'                  },
  { label: 'Serviços de Limpeza',      href: '/pt-br/para/servicos-limpeza/'         },
  { label: 'Serviços Pet',             href: '/pt-br/para/servicos-pet/'             },
  { label: 'Telhadores',               href: '/pt-br/para/telhadores/'               },
  { label: 'Terapeutas',               href: '/pt-br/para/terapeutas/'               },
  { label: 'Veterinários',             href: '/pt-br/para/veterinarios/'             },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "name": "theStacc para Cada Setor | Automação de SEO por Tipo de Negócio | theStacc",
      "url": "https://thestacc.com/pt-br/para/",
      "inLanguage": "pt-BR",
      "description": "O Stacc automatiza SEO para mais de 27 setores — de prestadores de serviços locais a empresas de todo o Brasil. Encontre o seu setor e veja como o Stacc aumenta o tráfego orgânico do seu negócio."
    },
    {
      "@type": "BreadcrumbList",
      "inLanguage": "pt-BR",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Início",
          "item": "https://thestacc.com/pt-br/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Setores",
          "item": "https://thestacc.com/pt-br/para/"
        }
      ]
    }
  ]
};
---

<BaseLayout
  lang="pt-BR"
  title="theStacc para Cada Setor | Automação de SEO por Tipo de Negócio | theStacc"
  description="O Stacc automatiza SEO para mais de 27 setores no Brasil — de prestadores de serviços locais a negócios de todo o país. Encontre o seu setor e veja como o Stacc aumenta seu tráfego orgânico."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-[680px] text-center">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">27 Setores · SEO Local &amp; SEO de Blog</span>
          </div>
          <h1 class="font-sans text-[2.2rem] font-semibold leading-[1.15] tracking-[-0.035em] text-[#111827] md:text-[3rem]">
            SEO feito para o seu setor.
          </h1>
          <p class="mx-auto mt-5 max-w-[540px] font-sans text-[1.05rem] leading-[1.7] text-[#57534e]">
            Cada setor tem palavras-chave diferentes, compradores diferentes e sinais de posicionamento diferentes. O Stacc é treinado na sua categoria — para que os posts, artigos e otimizações publicados todo mês sejam específicos para como os seus clientes realmente pesquisam.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Começar por R$1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/pt-br/precos/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#292524] transition-colors hover:bg-[#fafaf9]"
            >
              Ver preços
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── MODULE EXPLAINER STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-10">
        <div class="mx-auto grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-2">
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">SEO Local</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">R$49/mês</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">Para negócios que dependem da pesquisa local — posts no GBP, monitoramento de avaliações e rastreamento de posição no Maps. Ideal para prestadores de serviços, comércio físico e qualquer negócio que queira aparecer no Map Pack.</p>
            </div>
          </div>
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">SEO de Blog</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">R$99/mês</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">Para negócios que crescem com conteúdo orgânico — 30 artigos de SEO publicados no seu site todo mês. Ideal para SaaS, e-commerce e serviços profissionais que competem em âmbito nacional.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── LOCAL SEO INDUSTRIES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Módulo de SEO Local</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">R$49/mês · {localSEO.length} setores</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Negócios de serviços locais
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            Posts no GBP, gestão de avaliações e rastreamento de posição no Map Pack — tudo automatizado.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {localSEO.map(item => (
            <a
              href={item.href}
              class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BOTTOM CTA ─── -->
    <section class="relative overflow-hidden py-16 md:py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.18) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.03) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>

      <div class="container-x relative">
        <div class="mx-auto max-w-xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Não encontrou o seu setor?</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.03em] text-[#292524] md:text-[2.4rem]">
            O Stacc funciona para qualquer<br />negócio que precisa de tráfego orgânico.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Se seus clientes pesquisam por você no Google, o Stacc pode automatizar o SEO que faz você ser encontrado. Agende uma demo e mostraremos como funciona para o seu negócio específico.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]"
            >
              Agendar uma demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/pt-br/precos/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff] bg-white"
            >
              Ver preços
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
