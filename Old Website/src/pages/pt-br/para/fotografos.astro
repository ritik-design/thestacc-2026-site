---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo leva para meu negócio de fotografia aparecer melhor no Google Maps?",
    a: "A maioria dos fotógrafos vê movimentação significativa no Maps em 60 a 90 dias de atividade consistente no GBP. O algoritmo local do Google recompensa frequência, relevância e engajamento — os três que o Stacc fornece automaticamente todo mês. Negócios que não publicavam nada antes tendem a ver resultados mais rápido.",
  },
  {
    q: "Publicar no GBP realmente ajuda um fotógrafo a rankear?",
    a: "Sim. A própria documentação do Google afirma que perfis de empresa atualizados regularmente têm mais chances de aparecer nos resultados de pesquisa local. O algoritmo do Maps considera frequência de publicação, capacidade de resposta a avaliações e relevância de palavras-chave. Cada semana que seu perfil fica sem atividade, um fotógrafo concorrente que publica consistentemente ganha terreno. O Stacc publica 30 vezes por mês para que seu perfil nunca fique sem atividade.",
  },
  {
    q: "Quais palavras-chave de fotografia o Stacc segmenta?",
    a: "O Stacc segmenta combinações de especialidade + cidade — 'fotógrafo de casamento perto de mim', 'fotógrafo de família [cidade]', 'estúdio de retrato [cidade]', 'fotografia newborn [cidade]', 'fotos de formatura [cidade]' e 'fotografia comercial [cidade]'. Todas calibradas para suas especialidades específicas e localização.",
  },
  {
    q: "Meu negócio já tem um Google Perfil da Empresa. Preciso fazer algo especial?",
    a: "Basta conectar. O Stacc importa seus dados do GBP existente — nome do negócio, serviços, fotos, histórico de avaliações e posição de ranking atual — e constrói um plano de conteúdo a partir daí. A configuração leva menos de cinco minutos. Depois disso, o Stacc cuida de tudo: escreve posts, publica no cronograma, envia alertas de avaliações e monitora seu ranking no Maps mês a mês.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "O Stacc envia um alerta instantâneo no momento em que uma nova avaliação aparece, positiva ou negativa. Você recebe o texto da avaliação, a classificação em estrelas e um modelo de resposta para que possa responder em menos de um minuto. Responder rapidamente a avaliações negativas é especialmente importante em fotografia, onde os clientes estão contratando você para momentos únicos na vida — uma resposta cuidadosa sinaliza a cada futuro cliente que você leva a experiência deles a sério.",
  },
  {
    q: "Vocês atendem fotógrafos que trabalham com múltiplas especialidades?",
    a: "Sim. O Stacc segmenta todas as suas especialidades fotográficas simultaneamente — casamento, retrato, família, newborn, eventos comerciais. Cada especialidade recebe sua própria estratégia de palavras-chave e segmentação de conteúdo. Você também pode adicionar localizações ou estúdios adicionais, cada um com seus próprios relatórios de ranking e calendários de conteúdo.",
  },
  {
    q: "Como o Stacc é diferente de uma agência de marketing para fotógrafos?",
    a: "Uma agência de marketing para fotógrafos cobra entre US$ 500–US$ 1.500/mês e exige chamadas de onboarding e contratos longos. O Stacc automatiza cada parte desse processo — pesquisa, redação, agendamento, monitoramento de avaliações, rastreamento de ranking — por US$ 49/mês. O resultado é o mesmo. O overhead e as margens da agência somem.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog para fotógrafo ou apenas com o GBP?",
    a: "O módulo de SEO Local do Stacc cuida de posts no GBP, monitoramento de avaliações e rastreamento de ranking. Se você quer artigos de dicas de fotografia e bastidores publicados no seu site todo mês — do tipo que rankeia para 'como escolher um fotógrafo de casamento' e 'melhores locais para fotos de família em [cidade]' — esse é o módulo de SEO de Blog por US$ 99/mês. Muitos fotógrafos usam os dois juntos para cobertura total de busca orgânica.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc para Fotógrafos",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "O Stacc publica no Google Perfil da Empresa do seu negócio de fotografia todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Conquiste mais clientes de fotografia pelo Google por US$ 49/mês.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Setores", "item": "https://thestacc.com/pt-br/para/" },
        { "@type": "ListItem", "position": 3, "name": "Fotógrafos", "item": "https://thestacc.com/pt-br/para/fotografos/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO para Fotógrafos | Conquiste Mais Clientes pelo Google | theStacc"
  description="O Stacc publica no Google Perfil da Empresa do seu negócio de fotografia todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Mais clientes de fotografia pelo Google por US$ 49/mês."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Fotógrafos · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais clientes de fotografia pelo Google.<br />
            <span style="color:#4f39f6;">Sem depender do Instagram.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            560.000 pessoas pesquisam fotógrafos no Google todo mês. 84% dos clientes pesquisam fotógrafos online antes de contratar. O Stacc garante que seu negócio apareça primeiro — publicando no seu GBP diariamente, gerenciando avaliações e monitorando seu ranking no Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Comece por US$ 1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Veja como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem contratos · Publica no seu GBP todos os dias
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '560K', num: 560, prefix: '', suffix: 'K', decimals: 0, from: 0, label: 'Buscas mensais por fotógrafos no Google' },
              { value: '84%',  num: 84,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Clientes pesquisam online antes de contratar' },
              { value: '4.4×', num: 4.4, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Média de melhora no ranking do Maps' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Avaliações capturadas instantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Fotógrafos rankeando com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Fotografia de Casamento Visionary — São Paulo, SP', 'Estúdio de Retrato Estrela — Rio de Janeiro, RJ', 'Fotografia Luz do Deserto — Belo Horizonte, MG', 'Grupo Fotografia Summit — Curitiba, PR', 'Estúdio Pacífico — Porto Alegre, RS', 'Fotografia Sunshine — Salvador, BA', 'Retratos do Sul — Florianópolis, SC', 'Fotografia de Casamento Visionary — São Paulo, SP', 'Estúdio de Retrato Estrela — Rio de Janeiro, RJ', 'Fotografia Luz do Deserto — Belo Horizonte, MG', 'Grupo Fotografia Summit — Curitiba, PR', 'Estúdio Pacífico — Porto Alegre, RS', 'Fotografia Sunshine — Salvador, BA', 'Retratos do Sul — Florianópolis, SC'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Seus melhores clientes estão pesquisando no Google.<br />Eles estão contratando outro fotógrafo.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            89% dos clientes verificam avaliações antes de contratar um fotógrafo. A única questão é qual perfil eles encontram primeiro.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">O alcance orgânico do Instagram está em queda. O Google Maps é onde os clientes estão realmente pesquisando.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">O alcance orgânico do Instagram caiu mais de 70% desde 2020. Clientes que estão prontos para contratar um fotógrafo não ficam rolando feeds do Instagram — eles pesquisam 'fotógrafo de casamento perto de mim' ou 'fotógrafo de família [cidade]' no Google. Os fotógrafos que rankeiam no Map Pack para essas buscas capturam os clientes com real intenção de contratação.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação sem resposta sobre edição ruim ou fotos perdidas está te custando reservas de R$ 5.000+.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">89% dos clientes verificam avaliações antes de contratar um fotógrafo. Fotografia é um serviço único na vida para muitos clientes — casamentos, newborn, formaturas. Uma avaliação negativa sobre fotos desfocadas ou entrega lenta que fica sem resposta diz a cada futuro cliente exatamente o que eles temem. Sua classificação de estrelas determina se eles te contratam ou continuam rolando.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você recebe curtidas no Instagram. Seu concorrente recebe reservas pelo Google Maps.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Curtidas não pagam equipamentos. Fotógrafos que investem em rankings no Google Maps capturam clientes que estão ativamente pesquisando e prontos para contratar — não espectadores passivos. Se você não está no Map Pack para 'fotógrafo perto de mim' na sua cidade, essas reservas vão para quem está.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz para fotógrafos</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todos os recursos que geram novas reservas fotográficas pelo Google. Resolvido.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para fotógrafos exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo direcionado por palavras-chave — todos os meses. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicação de Posts no GBP',
              body: '30 posts otimizados por localização por mês — destaques de portfólio, promoções de sessão, bastidores, mini sessões sazonais e destaques de especialidade. Publicados automaticamente no cronograma.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Segmentação de Palavras-Chave para Fotografia',
              body: 'Combinações de especialidade + cidade — fotógrafo de casamento, fotógrafo de família, estúdio de retrato, fotografia newborn, fotos de formatura, fotografia comercial. Calibradas para suas especialidades específicas e localização.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoramento de Avaliações',
              body: 'Alertas instantâneos no momento em que uma nova avaliação aparece no seu Google Perfil da Empresa. Monitoramento de tendência da classificação de estrelas semana a semana. Modelos de resposta para que você possa responder em menos de um minuto — crítico quando os clientes estão confiando a você momentos insubstituíveis.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Rastreamento de Ranking Local',
              body: 'Relatórios de ranking no Maps baseados em grade mostrando exatamente onde seu negócio de fotografia está para cada palavra-chave alvo em sua cidade. Monitoramento mês a mês para ver seu progresso se consolidar.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestão de Múltiplas Especialidades',
              body: 'Fotografa casamentos, retratos e comercial? Cada especialidade recebe sua própria segmentação de palavras-chave e conteúdo — tudo gerenciado em um único painel. Veja quais especialidades estão gerando mais visibilidade e reservas.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construção de Citações',
              body: 'Verificações de consistência de NAP e envios para diretórios de fotografia — Yelp, The Knot, WeddingWire, Thumbtack e mais de 50 outros. Os sinais de autoridade que ajudam você a superar concorrentes no seu mercado.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia a presença<br />do seu negócio de fotografia no Maps a partir daí.
