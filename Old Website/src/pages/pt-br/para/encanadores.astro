---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo leva para minha empresa de encanamento aparecer melhor no Google Maps?",
    a: "A maioria das empresas de encanamento vê movimentação significativa no Maps em 60 a 90 dias de atividade consistente no GBP. Negócios de serviços de emergência tendem a ver resultados mais rápidos porque a intenção local é muito alta e muitos concorrentes estão completamente inativos no GBP. Empresas que não publicavam nada antes do Stacc costumam ver movimentação no ranking já nos primeiros 30 dias.",
  },
  {
    q: "Publicar no GBP realmente ajuda uma empresa de encanamento a ranquear?",
    a: "Sim. O algoritmo local do Google considera frequência de publicação, responsividade a avaliações e relevância de palavras-chave. Cada dia que seu GBP fica inativo, o encanador que publica consistentemente ganha terreno. O Stacc publica 30 vezes por mês para que seu perfil sinalize atividade constante ao Google — exatamente o que o algoritmo do Maps recompensa.",
  },
  {
    q: "Quais palavras-chave de encanamento o Stacc trabalha?",
    a: "O Stacc trabalha combinações de serviço + cidade — 'encanador perto de mim', 'encanador de emergência [cidade]', 'conserto de aquecedor de água [cidade]', 'desentupimento [cidade]', 'reparo de encanamento [cidade]', 'detecção de vazamento perto de mim'. As palavras-chave são calibradas para seus serviços específicos e as cidades que você atende.",
  },
  {
    q: "Minha empresa já tem um GBP. Preciso fazer algo para configurar?",
    a: "Basta conectar. O Stacc importa seus dados existentes do GBP — nome do negócio, serviços, fotos, histórico de avaliações e posicionamento atual — e cria um plano de conteúdo a partir daí. A configuração leva menos de cinco minutos. Depois disso, o Stacc cuida de tudo automaticamente.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "O Stacc envia um alerta instantâneo assim que uma nova avaliação aparece. Você recebe o texto da avaliação, a nota e um modelo de resposta para que possa responder em menos de um minuto. Em serviços domésticos, respostas rápidas a avaliações negativas têm um dos melhores ROIs possíveis — elas sinalizam para futuros clientes que você leva o atendimento a sério.",
  },
  {
    q: "Vocês atendem empresas de encanamento que cobrem múltiplas cidades?",
    a: "Sim. Cada área de atendimento tem sua própria estratégia de palavras-chave, calendário de conteúdo, programação de posts no GBP e relatório de ranking — tudo em um único painel. Os posts segmentam os termos de busca específicos de cada cidade para que você apareça em toda a sua área de atendimento.",
  },
  {
    q: "Como o Stacc é diferente de uma agência de marketing para encanadores?",
    a: "Uma agência de marketing para encanadores escreve seus posts no GBP manualmente, cobra entre R$ 3.000 e R$ 7.500/mês e exige chamadas de onboarding e contratos longos. O Stacc automatiza todo esse processo por US$ 49/mês. O resultado é o mesmo. A sobrecarga e as margens da agência desaparecem.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog para encanadores ou apenas com o GBP?",
    a: "O módulo de SEO Local do Stacc cuida de posts no GBP, monitoramento de avaliações e rastreamento de ranking. Se você quiser conteúdo de blog de encanamento no seu site — artigos que ranqueiam para 'como desentupir um ralo' e 'sinais de que seu aquecedor precisa de substituição' — esse é o módulo de Blog SEO por US$ 99/mês. Muitas empresas de encanamento usam os dois para cobertura completa de busca orgânica.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc para Encanadores",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "Stacc publica posts no Google Business Profile da sua empresa de encanamento todos os dias, gerencia avaliações e rastreia seu ranking no Maps — automaticamente. Consiga mais chamadas de encanamento pelo Google por US$ 49/mês.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Setores", "item": "https://thestacc.com/pt-br/para/" },
        { "@type": "ListItem", "position": 3, "name": "Encanadores", "item": "https://thestacc.com/pt-br/para/encanadores/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO para Encanadores | Conquiste Mais Chamadas pelo Google | theStacc"
  description="Stacc publica posts no GBP da sua empresa de encanamento todos os dias, gerencia avaliações e rastreia seu ranking no Maps — automaticamente. Mais chamadas de encanamento pelo Google por US$ 49/mês."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Encanadores · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais chamadas de encanamento pelo Google.<br />
            <span style="color:#4f39f6;">Começando este mês.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            450.000 pessoas pesquisam "encanador perto de mim" todo mês. 72% pesquisam encanadores online antes de ligar. O Stacc garante que sua empresa apareça primeiro — publicando no seu Google Business Profile diariamente, gerenciando avaliações e rastreando seu ranking no Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Começar por US$ 1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Ver como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem contratos · Posts no seu GBP todos os dias
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '450K', num: 450, prefix: '',  suffix: 'K', decimals: 0, from: 0, label: 'Buscas mensais por "encanador perto de mim"' },
              { value: '72%',  num: 72,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Clientes pesquisam online antes de ligar' },
              { value: '91%',  num: 91,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Ligam para o primeiro resultado encontrado' },
              { value: '4,6×', num: 4.6, prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Melhora média no ranking do Maps' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Empresas locais com ranking no Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Encanamentos Silva — São Paulo, SP', 'Hidráulica Express — Rio de Janeiro, RJ', 'Encanador 24h — Belo Horizonte, MG', 'Serviços Hidráulicos Costa — Curitiba, PR', 'Encanamentos Oliveira — Porto Alegre, RS', 'Hidráulica Rápida — Brasília, DF', 'Encanador Urgente — Fortaleza, CE', 'Encanamentos Silva — São Paulo, SP', 'Hidráulica Express — Rio de Janeiro, RJ', 'Encanador 24h — Belo Horizonte, MG', 'Serviços Hidráulicos Costa — Curitiba, PR', 'Encanamentos Oliveira — Porto Alegre, RS', 'Hidráulica Rápida — Brasília, DF', 'Encanador Urgente — Fortaleza, CE'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Seus melhores clientes estão pesquisando agora.<br />Eles estão ligando para o concorrente.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            91% dos proprietários que encontram um encanador na busca local ligam para o primeiro resultado que veem. A única questão é de quem é esse negócio.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Seu concorrente publica todos os dias. Seu GBP está silencioso há 3 semanas.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Chamadas de encanamento de emergência são urgentes — os proprietários ligam para o primeiro encanador que encontram no Google Maps. O algoritmo do Maps recompensa com rankings mais altos as empresas com atividade consistente no GBP. Cada dia que seu perfil fica em silêncio, o encanador da cidade que publica diariamente recebe aquela ligação de emergência no lugar de você.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação de 2 estrelas está enviando seus clientes para o concorrente.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">74% dos proprietários verificam avaliações antes de ligar para um encanador. Uma avaliação negativa que fica sem resposta por dias diz a cada cliente em potencial a mesma coisa: esta empresa não responde. Em um negócio de confiança como encanamento, sua nota no Google vale mais do que qualquer anúncio que você possa fazer.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você aparece para o nome da sua empresa. Não para "encanador de emergência perto de mim".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Novos clientes não pesquisam pelo nome da sua empresa — eles não o conhecem. Eles pesquisam 'encanador de emergência [cidade]', 'conserto de aquecedor perto de mim' e 'desentupimento [cidade]'. Se você não está no Map Pack para esses termos, esses serviços vão para quem está. Você não tem ideia de quantas chamadas está perdendo toda semana.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz para encanadores</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada alavanca que gera novas chamadas de encanamento pelo Google. Resolvida.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para empresas de encanamento exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo direcionado por palavras-chave — todo mês. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicação de Posts no GBP',
              body: '30 posts otimizados por localização por mês, direcionados para encanamento de emergência, desentupimento, conserto de aquecedor, reparo de tubulação e conteúdo sazonal. Publicados automaticamente no horário certo.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Palavras-chave de Encanamento',
              body: 'Combinações de serviço + cidade para cada serviço que sua equipe realiza — encanamento de emergência, instalação de aquecedor, reparo de esgoto, detecção de vazamento, desentupimento. Tudo calibrado para sua área específica.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoramento de Avaliações',
              body: 'Alertas instantâneos assim que uma nova avaliação aparece. Acompanhamento semanal da tendência de notas. Modelos de resposta para que você possa responder em menos de um minuto e proteger a reputação que impulsiona seu negócio por indicação.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Rastreamento de Ranking Local',
              body: 'Relatórios de ranking no Maps baseados em grade mostrando exatamente onde sua empresa aparece para cada palavra-chave alvo em toda a sua área de atendimento. Acompanhamento mês a mês para ver seu progresso.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestão Multirregional',
              body: 'Múltiplas áreas de atendimento? Cada uma tem sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de desempenho — tudo em um único painel. Acompanhe a melhora em cada cidade que você atende.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construção de Citações',
              body: 'Verificações de consistência de NAP e envios para diretórios de serviços domésticos — HomeAdvisor, Angi, Thumbtack, Yelp e mais de 50 outros. Os sinais de autoridade que ajudam você a superar os encanadores concorrentes.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia a presença<br />da sua empresa de encanamento no Maps a partir daí.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sem logins no GBP. Sem escrever posts. Sem verificar avaliações manualmente. Configure uma vez e seu Google Business Profile funciona sozinho — para você se concentrar nos serviços.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
