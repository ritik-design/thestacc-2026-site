---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo leva para meu restaurante aparecer melhor no Google Maps?",
    a: "A maioria dos restaurantes vê movimentação significativa no Maps em 60 a 90 dias de atividade consistente no GBP. Restaurantes que não publicavam nada antes tendem a ver resultados mais rápido. O algoritmo do Maps imediatamente recompensa conteúdo novo e consistente — especialmente em mercados gastronômicos competitivos.",
  },
  {
    q: "Publicar no GBP realmente ajuda um restaurante a rankear?",
    a: "Sim. O algoritmo local do Google considera frequência de publicação, capacidade de resposta a avaliações e relevância de palavras-chave. Cada semana que seu GBP fica sem atividade, o restaurante da esquina que publica diariamente ganha terreno nas buscas por 'restaurante perto de mim'. O Stacc publica 30 vezes por mês para que seu perfil esteja sempre atualizado.",
  },
  {
    q: "Quais palavras-chave de restaurante o Stacc segmenta?",
    a: "O Stacc segmenta combinações de culinária + cidade e pesquisas baseadas em ocasião — 'restaurante italiano perto de mim', 'melhor brunch [cidade]', 'jantar em família [cidade]', 'restaurante para casal [cidade]', 'happy hour [cidade]'. Todas calibradas para seu tipo de culinária, faixa de preço e as ocasiões gastronômicas que você quer dominar.",
  },
  {
    q: "Meu restaurante já tem um GBP. Preciso fazer algo especial para configurar?",
    a: "Basta conectar. O Stacc importa seus dados do GBP existente — nome do restaurante, tipo de culinária, fotos, histórico de avaliações e ranking atual — e constrói um plano de conteúdo a partir daí. A configuração leva menos de cinco minutos.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "O Stacc envia um alerta instantâneo no momento em que uma nova avaliação aparece no Google, com o texto da avaliação e um modelo de resposta. No setor de restaurantes, a forma como você responde a uma crítica negativa publicamente costuma ser mais importante do que a própria avaliação — mostra a cada futuro cliente como você lida com problemas.",
  },
  {
    q: "Vocês atendem grupos de restaurantes e redes com múltiplas localizações?",
    a: "Sim. Cada localização recebe sua própria estratégia de palavras-chave, calendário de conteúdo, cronograma de posts no GBP e relatório de ranking — tudo gerenciado em um único painel. Os posts segmentam o bairro específico e as palavras-chave gastronômicas locais de cada estabelecimento.",
  },
  {
    q: "Como o Stacc é diferente de uma agência de marketing para restaurantes?",
    a: "Uma agência de marketing para restaurantes cobra entre US$ 500–US$ 1.500/mês pelo gerenciamento manual do GBP e exige contratos longos. O Stacc automatiza tudo por US$ 49/mês. A maioria dos proprietários de restaurantes que usa o Stacc pagava anteriormente a agências muito mais por menos volume e menos consistência.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog para restaurante?",
    a: "O módulo de SEO Local do Stacc cuida de posts no GBP, monitoramento de avaliações e rastreamento de ranking. Se você quer conteúdo de blog — artigos como 'melhores restaurantes para jantar a dois em [cidade]' ou 'guia da semana do restaurante [cidade]' que rankeiam no Google e atraem tráfego orgânico — esse é o módulo de SEO de Blog por US$ 99/mês.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc para Restaurantes",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "O Stacc publica no Google Perfil da Empresa do seu restaurante todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Conquiste mais clientes pelo Google por US$ 49/mês.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Setores", "item": "https://thestacc.com/pt-br/para/" },
        { "@type": "ListItem", "position": 3, "name": "Restaurantes", "item": "https://thestacc.com/pt-br/para/restaurantes/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO para Restaurantes | Conquiste Mais Clientes pelo Google | theStacc"
  description="O Stacc publica no Google Perfil da Empresa do seu restaurante todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Mais clientes pelo Google por US$ 49/mês."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Restaurantes · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais clientes pelo Google.<br />
            <span style="color:#4f39f6;">Todos os dias.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            1,8 milhão de pessoas pesquisam "restaurante perto de mim" todos os dias. 86% dessas buscas resultam em uma visita em até 24 horas. O Stacc garante que seu restaurante apareça primeiro — publicando no seu Google Perfil da Empresa diariamente, gerenciando suas avaliações e monitorando seu ranking no Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Comece por US$ 1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Veja como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem contratos · Publica no seu GBP todos os dias
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '1.8M', num: 1.8, prefix: '', suffix: 'M', decimals: 1, from: 0, label: 'Buscas diárias por "restaurante perto de mim"' },
              { value: '86%',  num: 86,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Pesquisadores visitam em até 24 horas' },
              { value: '4.4×', num: 4.4, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Média de melhora no ranking do Maps' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Avaliações capturadas instantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negócios locais rankeando com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Bistrô da Esquina — São Paulo, SP', 'Casa do Sol — Rio de Janeiro, RJ', 'Cozinha do Deserto — Belo Horizonte, MG', 'Mesa da Montanha — Curitiba, PR', 'Restaurante Pier 42 — Porto Alegre, RS', 'Grill da Baía — Salvador, BA', 'Mesa do Sul — Florianópolis, SC', 'Bistrô da Esquina — São Paulo, SP', 'Casa do Sol — Rio de Janeiro, RJ', 'Cozinha do Deserto — Belo Horizonte, MG', 'Mesa da Montanha — Curitiba, PR', 'Restaurante Pier 42 — Porto Alegre, RS', 'Grill da Baía — Salvador, BA', 'Mesa do Sul — Florianópolis, SC'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Clientes estão pesquisando agora.<br />Eles estão sentados na mesa do concorrente.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            86% das pessoas que encontram um restaurante na pesquisa local visitam em até 24 horas. A única questão é qual restaurante elas encontram.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Seu concorrente publica promoções diárias e eventos. O seu GBP foi atualizado mês passado.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">O algoritmo do Maps recompensa restaurantes que publicam consistentemente — promoções diárias, eventos de fim de semana, atualizações do cardápio, horários de feriados. Cada semana que seu GBP fica sem atividade, um restaurante concorrente que publica regularmente recebe mais das buscas por 'restaurante perto de mim' que deveriam ser suas.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação de 2 estrelas sobre comida fria está deixando mesas vazias.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">90% dos clientes verificam avaliações online antes de escolher um restaurante. Uma avaliação negativa deixada sem resposta diz aos futuros clientes que você não se importa — o que é a única coisa que um restaurante nunca pode demonstrar. Sua classificação de estrelas determina se você enche as mesas ou as vê ficar vazias.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você aparece quando pesquisam seu nome. Não quando estão com fome.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Pessoas com fome não pesquisam o nome do seu restaurante — elas pesquisam 'restaurante italiano perto de mim', 'melhor brunch [cidade]' e 'restaurante aberto agora'. Se você não está no Map Pack para essas buscas, esses clientes estão sentados na mesa do concorrente esta noite.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz para restaurantes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todos os recursos que atraem novos clientes pelo Google. Resolvido.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para restaurantes exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo direcionado por palavras-chave — todos os meses. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicação de Posts no GBP',
              body: '30 posts otimizados por localização por mês — promoções diárias, cardápios sazonais, eventos, horários de feriados e conteúdo de "melhor [culinária] em [cidade]". Publicados automaticamente no cronograma para que seu perfil esteja sempre ativo.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Segmentação de Palavras-Chave para Restaurantes',
              body: 'Combinações de culinária + cidade, pesquisas baseadas em ocasião e palavras-chave com intenção específica — "brunch perto de mim", "restaurante para jantar a dois [cidade]", "melhor pizza [cidade]". Calibradas para seu tipo de culinária e as ocasiões que você quer dominar.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoramento de Avaliações',
              body: 'Alertas instantâneos no momento em que uma nova avaliação aparece — Yelp, Google, TripAdvisor. Monitoramento de tendência da classificação de estrelas semana a semana. Modelos de resposta para que você possa responder em menos de um minuto e proteger a reputação que enche suas mesas.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Rastreamento de Ranking Local',
              body: 'Relatórios de ranking no Maps baseados em grade mostrando exatamente onde seu restaurante está para cada palavra-chave alvo em seu bairro e cidade. Monitoramento mês a mês para ver sua posição se consolidar.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestão de Múltiplas Localizações',
              body: 'Vários estabelecimentos? Cada um recebe sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de desempenho — tudo em um único painel. Veja quais estabelecimentos precisam de atenção e monitore o ranking no Maps de cada um lado a lado.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construção de Citações',
              body: 'Verificações de consistência de NAP e envios para plataformas de restaurantes — Yelp, TripAdvisor, OpenTable, iFood e mais de 50 outros. Os sinais de autoridade que ajudam você a rankear acima dos restaurantes concorrentes.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia a presença<br />do seu restaurante no Maps a partir daí.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sem logins no GBP. Sem escrever posts. Sem verificar avaliações manualmente. Configure uma vez e seu Google Perfil da Empresa funciona sozinho — para que você possa se concentrar em gerir a cozinha.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
