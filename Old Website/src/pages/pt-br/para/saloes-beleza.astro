---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo leva para meu salão ranquear melhor no Google Maps?",
    a: "A maioria dos salões nota movimentação significativa no Maps dentro de 60 a 90 dias de atividade consistente no GBP. O algoritmo local do Google recompensa frequência, relevância e engajamento — os três que o Stacc fornece automaticamente todo mês. Salões que não publicavam nada antes tendem a ver resultados mais rápido.",
  },
  {
    q: "Publicar no GBP realmente ajuda um salão a ranquear?",
    a: "Sim. A própria documentação do Google afirma que perfis comerciais atualizados regularmente têm mais probabilidade de aparecer nos resultados de busca local. O algoritmo do Maps considera frequência de publicações, responsividade a avaliações e relevância de palavras-chave. Cada dia inativo, um concorrente que publica consistentemente ganha terreno. O Stacc publica 30 vezes por mês para que seu perfil nunca fique inativo.",
  },
  {
    q: "Quais palavras-chave de salão o Stacc foca?",
    a: "O Stacc foca suas combinações de serviço + cidade principais — 'salão de beleza perto de mim', 'balayage perto de mim', 'luzes [cidade]', 'tratamento de cabelo [cidade]', 'escova progressiva [cidade]', 'alongamento de cabelo [cidade]' e 'melhor salão [cidade]'. Também focamos conteúdo sazonal como 'tendências de cor para o inverno' e 'escova para festas de fim de ano'. Todas as palavras-chave são calibradas para seus serviços e localização específicos.",
  },
  {
    q: "Meu salão já tem um Google Business Profile. Preciso fazer algo especial para configurar?",
    a: "Basta conectar. O Stacc importa seus dados do GBP — nome do salão, serviços, fotos, histórico de avaliações e posição de ranking atual — e monta um plano de conteúdo a partir daí. A configuração leva menos de cinco minutos. Depois disso, o Stacc cuida de tudo: escrita de publicações, publicação no horário, envio de alertas de avaliações e rastreamento do seu ranking no Maps mês a mês.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "O Stacc envia um alerta instantâneo quando uma nova avaliação aparece, positiva ou negativa. Você recebe o texto, a nota e um modelo de resposta para responder em menos de um minuto. Responder rapidamente a avaliações negativas é uma das ações de maior retorno para um dono de salão — sinaliza a cada futuro cliente que você leva a sério a qualidade do seu trabalho.",
  },
  {
    q: "Sou cabelereiro autônomo em espaço compartilhado, não um salão tradicional. O Stacc funciona para mim?",
    a: "Sim. Seja um estilista independente em um espaço compartilhado ou um salão com múltiplas cadeiras, o Stacc funciona da mesma forma. Seu GBP é sua vitrine digital — publicar consistentemente conteúdo de serviços, fotos de antes e depois e respostas a avaliações sinaliza ao algoritmo do Maps que você é um negócio local ativo e relevante.",
  },
  {
    q: "Como o Stacc se diferencia de uma agência de marketing para salões?",
    a: "Uma agência de marketing para salões escreve suas publicações no GBP manualmente, cobra de R$1.500 a R$4.000/mês e exige onboardings e contratos longos. O Stacc automatiza todo esse processo por $49/mês. O resultado é o mesmo. Os custos operacionais e a margem da agência desaparecem.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog sobre cabelos ou apenas GBP?",
    a: "O módulo de SEO Local do Stacc cuida de publicações no GBP, monitoramento de avaliações e rastreamento de ranking. Se você quiser artigos sobre cuidados com cabelos publicados no seu site todo mês — do tipo que ranqueia para 'como manter o balayage em casa' ou 'melhor rotina de cuidados para cabelos coloridos' — esse é o módulo de Blog SEO por $99/mês. Muitos salões usam os dois juntos para cobertura total de busca orgânica.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "O Stacc publica no GBP do seu salão todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Conquiste mais clientes para seu salão pelo Google por $49/mês.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "billingDuration": "P1M"
        }
      },
      "inLanguage": "pt-BR",
      "url": "https://thestacc.com/pt-br/para/saloes-beleza/"
    },
    {
      "@type": "BreadcrumbList",
      "inLanguage": "pt-BR",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Início",
          "item": "https://thestacc.com/pt-br/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Setores",
          "item": "https://thestacc.com/pt-br/para/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Salões de Beleza",
          "item": "https://thestacc.com/pt-br/para/saloes-beleza/"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  lang="pt-BR"
  title="SEO para Salões de Beleza | Mais Clientes pelo Google | theStacc"
  description="O Stacc publica no GBP do seu salão todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Conquiste mais clientes para seu salão pelo Google por $49/mês."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Salões · Com Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais clientes para seu salão pelo Google.<br />
            <span style="color:#4f39f6;">Toda semana.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            850.000 pessoas pesquisam "salão de beleza perto de mim" todo mês. 80% das clientes pesquisam salões online antes de agendar o primeiro atendimento. O Stacc garante que seu salão apareça primeiro — publicando no seu GBP diariamente, gerenciando avaliações e monitorando seu ranking no Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Veja como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem contratos · Publica no seu GBP todos os dias
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '850K', num: 850, prefix: '', suffix: 'K', decimals: 0, from: 0, label: 'Buscas mensais por "salão perto de mim"' },
              { value: '80%',  num: 80,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Clientes pesquisam salões online primeiro' },
              { value: '4.4×', num: 4.4, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Melhora média no ranking no Maps' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Avaliações capturadas instantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Salões ranqueando com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Studio Elle Cabelos — São Paulo, SP', 'Salão das Divas — Rio de Janeiro, RJ', 'Desert Bloom Studio — Belo Horizonte, MG', 'Arte & Estilo Hair — Curitiba, PR', 'Litoral Beauty Studio — Florianópolis, SC', 'Glamour Hair Salon — Porto Alegre, RS', 'Capital Beleza Studio — Brasília, DF', 'Studio Elle Cabelos — São Paulo, SP', 'Salão das Divas — Rio de Janeiro, RJ', 'Desert Bloom Studio — Belo Horizonte, MG', 'Arte & Estilo Hair — Curitiba, PR', 'Litoral Beauty Studio — Florianópolis, SC', 'Glamour Hair Salon — Porto Alegre, RS', 'Capital Beleza Studio — Brasília, DF'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Suas melhores clientes estão pesquisando agora.<br />E estão agendando em outro salão.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            83% das clientes que encontram um salão na busca local acabam entrando em contato com ele. A única pergunta é: de quem é o perfil que elas encontram primeiro.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Alguém se muda para o seu bairro. Pesquisa "salão de beleza perto de mim". Agenda com seu concorrente.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Novos moradores pesquisam salões locais na semana em que chegam — e o salão que eles escolhem primeiro geralmente os mantém por anos. O algoritmo do Maps recompensa atividade consistente no GBP com fotos de resultados, promoções sazonais e conteúdo de estilo. Cada semana que seu perfil fica inativo, esse novo cliente vai para quem aparece primeiro.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação de 2 estrelas sobre uma coloração mal-feita está deixando cadeiras vazias.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">83% das pessoas verificam avaliações antes de agendar em um salão. Uma avaliação negativa sobre um resultado de cor ruim ou atendimento descortês deixada sem resposta diz a cada cliente potencial o que sua experiência pode ser. Em um negócio construído sobre confiança e estética, sua nota no Google é seu portfólio e sua reputação em um só lugar.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você ranqueia pelo nome do seu salão. Não por "balayage perto de mim".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Novas clientes não pesquisam o nome do seu salão quando buscam algo novo — elas pesquisam "balayage perto de mim", "salão de cabelos [cidade]" e "escova progressiva perto de mim". Se você não está no Map Pack para essas buscas, essas clientes agendam em outro lugar — e as cadeiras dos estilistas ficam pela metade.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz para salões</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada alavanca que gera novos clientes pelo Google. Resolvida.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para salões exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo com palavras-chave específicas — todo mês, sem exceção. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicação no GBP',
              body: '30 publicações otimizadas por localidade por mês focando em tendências de cabelo sazonais, promoções, conteúdo de antes e depois, lembretes de agendamento para festas e dicas de estilo. Publicadas automaticamente no horário certo.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Palavras-chave para Salões',
              body: 'Combinações de serviço + cidade para cada serviço que seu salão oferece — balayage, luzes, progressiva, alongamento, correção de cor, escova, cortes. Tudo calibrado para sua localização e clientela específicas.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoramento de Avaliações',
              body: 'Alertas instantâneos quando uma nova avaliação aparecer no Google, Yelp ou plataformas de agendamento. Rastreamento de tendência de estrelas semana a semana. Modelos de resposta para que você responda em menos de um minuto.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Rastreamento de Ranking Local',
              body: 'Relatórios de ranking no Maps em grade mostrando exatamente onde seu salão aparece para cada palavra-chave no seu bairro. Acompanhamento mês a mês para ver seu progresso crescer.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestão Multi-unidade',
              body: 'Múltiplas unidades de salão? Cada uma recebe sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de desempenho — tudo em um único painel. Acompanhe o desempenho em cada cadeira e cada localidade.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construção de Citações',
              body: 'Verificação de consistência NAP e envio a diretórios de salões — Yelp, Booksy, Vagaro e mais de 50 outros. Os sinais de autoridade nos bastidores que ajudam você a superar concorrentes.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia a presença<br />do seu salão no Maps a partir desse dia.
