---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo até minha empresa de limpeza aparecer melhor no Google Maps?",
    a: "A maioria das empresas de limpeza vê movimentação significativa no Maps em 60–90 dias de atividade consistente no GBP. Empresas que não postavam nada antes tendem a ver resultados mais rápido — muitos concorrentes locais ainda têm GBPs inativos.",
  },
  {
    q: "Postar no GBP realmente ajuda uma empresa de limpeza a ranquear?",
    a: "Sim. O algoritmo local do Google recompensa frequência de postagens, responsividade a avaliações e relevância de palavras-chave. Para empresas de limpeza, isso significa postar consistentemente sobre serviços, disponibilidade e promoções — e responder a avaliações rapidamente. O Stacc automatiza tudo isso.",
  },
  {
    q: "Quais palavras-chave de limpeza o Stacc foca?",
    a: "O Stacc foca em combinações de serviço + cidade — 'empresa de limpeza perto de mim', 'faxineira [cidade]', 'limpeza residencial [cidade]', 'limpeza comercial [cidade]', 'limpeza pós-obra [cidade]'. Todas calibradas para seus serviços e área de atuação.",
  },
  {
    q: "Minha empresa já tem um Google Business Profile. Preciso fazer algo especial?",
    a: "Só conectar. O Stacc puxa seus dados do GBP, histórico de avaliações e posição de ranking atual — e cria um plano de conteúdo focando nas palavras-chave de limpeza para as quais você não aparece. A configuração leva menos de cinco minutos.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "O Stacc envia um alerta instantâneo no momento em que uma nova avaliação aparece. Você recebe o texto da avaliação e um modelo de resposta para poder responder em menos de um minuto. Responder rapidamente a avaliações negativas é uma das ações de maior retorno que uma empresa de limpeza pode tomar.",
  },
  {
    q: "Vocês atendem empresas de limpeza que cobrem múltiplas áreas?",
    a: "Sim. Cada área de serviço tem sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de ranking — tudo em um único painel.",
  },
  {
    q: "Como o Stacc é diferente de uma agência de marketing para limpeza?",
    a: "Uma agência de marketing para limpeza cobra $500–$1.200/mês pelo gerenciamento manual do GBP e exige contratos longos. O Stacc automatiza tudo por $49/mês — a mesma qualidade, sem a sobrecarga.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog para empresas de limpeza?",
    a: "O módulo de SEO Local do Stacc cuida de postagens no GBP, monitoramento de avaliações e rastreamento de ranking. Se você quiser conteúdo de blog no seu site — artigos que ranqueiam para 'como limpar tapete de forma profissional' — esse é o módulo de Blog SEO por $99/mês.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "O Stacc posta no Google Business Profile da sua empresa de limpeza todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD", "priceValidUntil": "2026-12-31" },
      "inLanguage": "pt-BR"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Setores", "item": "https://thestacc.com/pt-br/para/" },
        { "@type": "ListItem", "position": 3, "name": "Para Serviços de Limpeza", "item": "https://thestacc.com/pt-br/para/servicos-limpeza/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="SEO para Empresas de Limpeza | Mais Clientes pelo Google | theStacc"
  description="O Stacc posta no Google Business Profile da sua empresa de limpeza todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Mais clientes pelo Google por $49/mês."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Empresas de Limpeza · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais clientes de limpeza pelo Google.<br />
            <span style="color:#4f39f6;">Por $49 — não $500 por mês.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            440.000 pessoas pesquisam "empresa de limpeza perto de mim" todo mês. 78% dos clientes pesquisam empresas de limpeza online antes de contratar. O Stacc garante que sua empresa apareça primeiro — postando no seu GBP diariamente, gerenciando avaliações e rastreando seu ranking no Maps. Tudo automaticamente.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Começar por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-funciona" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Garantia de 30 dias · Sem contratos · Posta no seu GBP todos os dias</p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '440K', num: 440, prefix: '', suffix: 'K', decimals: 0, from: 0, label: 'Buscas mensais por "empresa de limpeza perto de mim"' },
              { value: '78%',  num: 78,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Clientes pesquisam online primeiro' },
              { value: '4.4×', num: 4.4, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Melhoria média de ranking no Maps' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Avaliações capturadas instantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]" data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negócios locais ranqueando com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">{[1,2,3,4,5].map(() => (<svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>))}</div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Lopez Clean Team — Chicago, IL', 'Desert Clean Pro — Phoenix, AZ', 'Summit Cleaning Services — Denver, CO', 'Pacific Maids — Seattle, WA', 'Sunshine Clean — Miami, FL', 'Metro Cleaning Group — Atlanta, GA', 'Lone Star Maids — Houston, TX', 'Lopez Clean Team — Chicago, IL', 'Desert Clean Pro — Phoenix, AZ', 'Summit Cleaning Services — Denver, CO', 'Pacific Maids — Seattle, WA', 'Sunshine Clean — Miami, FL', 'Metro Cleaning Group — Atlanta, GA', 'Lone Star Maids — Houston, TX'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Clientes prontos para contratar uma empresa de limpeza estão pesquisando agora.<br />Estão ligando para outra empresa.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            78% dos clientes pesquisam empresas de limpeza online antes de contratar. A única questão é de quem aparece primeiro.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Um cliente procura limpeza para sua casa. Ele pesquisa e liga para quem aparece primeiro — não para você.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Serviços de limpeza têm alta intenção — quem pesquisa está pronto para contratar. Se seu GBP está inativo, você não aparece no Map Pack, e esse cliente recorrente vai para outra empresa — e pode ficar com ela por anos.</p>
          </div>
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação sem resposta está dizendo que sua equipe não é confiável.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Clientes de limpeza deixam entrar estranhos em suas casas — confiança é tudo. Uma avaliação negativa sobre um item faltando ou limpeza ruim que fica sem resposta destrói essa confiança antes que o cliente potencial ligue.</p>
          </div>
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você ranqueia para o nome da empresa. Não para "faxineira perto de mim".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Clientes novos não pesquisam pelo nome da sua empresa — eles pesquisam "faxineira perto de mim", "limpeza residencial [cidade]" e "limpeza pós-obra [cidade]". Se você não aparece no Map Pack, esses clientes recorrentes vão para quem aparece.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz para empresas de limpeza</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada alavanca que gera novos clientes recorrentes pelo Google. Resolvida.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para empresas de limpeza exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo com palavras-chave — todo mês. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Publicação de Posts no GBP', body: '30 posts otimizados por localização por mês — dicas de limpeza residencial, limpeza profunda sazonal, limpeza pós-obra, disponibilidade de serviço e promoções. Publicados automaticamente.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Foco em Palavras-chave de Limpeza', body: 'Combinações de serviço + cidade — faxineira, limpeza residencial, limpeza comercial, limpeza pós-obra, limpeza profunda. Calibrado para seus serviços e área de atuação.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
            { title: 'Monitoramento de Avaliações', body: 'Alertas instantâneos no momento em que uma nova avaliação aparece. Rastreamento de tendência de estrelas. Modelos de resposta para responder em menos de um minuto.', icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' },
            { title: 'Rastreamento de Ranking Local', body: 'Relatórios de ranking no Maps baseados em grade mostrando onde sua empresa aparece para cada palavra-chave alvo em sua área. Rastreamento mês a mês.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Gestão Multi-área', body: 'Múltiplas áreas de serviço? Cada uma tem sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de desempenho — tudo em um único painel.', icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10' },
            { title: 'Construção de Citações', body: 'Envios a diretórios — HomeAdvisor, Angi, Thumbtack, Yelp e 50+ outros. Os sinais de autoridade que ajudam você a superar empresas concorrentes.', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia a presença da sua<br />empresa no Maps a partir desse dia.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sem logins no GBP. Sem escrever posts. Sem verificar avaliações manualmente. Configure uma vez e seu Google Business Profile roda sozinho.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Conecte seu Google Business Profile</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Pesquise pelo nome da sua empresa de limpeza. O Stacc puxa seus dados do GBP, histórico de avaliações e posição de ranking — e identifica quais palavras-chave você não aparece.</p>
            </div>
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
