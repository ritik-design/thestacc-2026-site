---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo leva para minha imobiliária aparecer melhor no Google Maps?",
    a: "A maioria das imobiliárias nota movimentação significativa no Maps dentro de 60 a 90 dias de atividade consistente no GBP. Corretores que não publicavam nada antes tendem a ver resultados mais rápido — o algoritmo do Maps recompensa imediatamente conteúdo novo e consistente. A dominância em uma área de atuação geralmente se consolida ao longo de 3 a 6 meses.",
  },
  {
    q: "Publicar no GBP realmente ajuda uma imobiliária a ranquear?",
    a: "Sim. O algoritmo local do Google considera frequência de publicações, responsividade a avaliações e relevância de palavras-chave. Cada semana que seu GBP fica inativo, um corretor concorrente que publica atualizações de mercado, novos imóveis e conteúdo de bairro ganha terreno. O Stacc publica 30 vezes por mês para que seu perfil sinalize atividade consistente — exatamente o que o algoritmo do Maps recompensa.",
  },
  {
    q: "Quais palavras-chave do mercado imobiliário o Stacc foca?",
    a: "O Stacc foca combinações de serviço + localização — 'corretor de imóveis perto de mim', 'imobiliária [cidade]', 'apartamentos à venda [bairro]', 'corretor comprador [cidade]', 'imóveis de luxo [cidade]' e buscas por bairros específicos. Tudo calibrado para sua área de atuação e o tipo de transações que você deseja.",
  },
  {
    q: "Minha imobiliária já tem um GBP. Preciso fazer algo especial?",
    a: "Basta conectar. O Stacc importa seus dados do GBP e monta um plano de conteúdo a partir daí. A configuração leva menos de cinco minutos. Depois disso, o Stacc cuida de tudo: escreve publicações, publica no horário, envia alertas de avaliações e monitora seu ranking no Maps.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "O Stacc envia um alerta instantâneo no momento em que uma nova avaliação aparece. Você recebe o texto, a nota em estrelas e um modelo de resposta para que possa responder profissionalmente em menos de um minuto. Em um negócio movido por indicações como o mercado imobiliário, a forma como você responde a críticas diz tudo para futuros clientes.",
  },
  {
    q: "Vocês atendem equipes de corretores e imobiliárias?",
    a: "Sim. Cada corretor ou localidade recebe sua própria estratégia de palavras-chave, calendário de conteúdo, agenda de publicações no GBP e relatório de ranking — tudo gerenciado em um único painel. Você pode ver o desempenho no Maps de cada corretor ou localidade lado a lado.",
  },
  {
    q: "Como o Stacc se diferencia de uma agência de marketing imobiliário?",
    a: "Uma agência de marketing imobiliário cobra de R$3.000 a R$9.000 por mês pelo gerenciamento manual do GBP e exige contratos longos. O Stacc automatiza tudo por $49/mês. O resultado é o mesmo. Os custos operacionais e a margem da agência desaparecem.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog imobiliário?",
    a: "O módulo de SEO Local do Stacc cuida de publicações no GBP, monitoramento de avaliações e rastreamento de ranking. Se você quiser conteúdo de blog no seu site — artigos como 'melhores bairros em [cidade]' e 'mercado imobiliário [cidade] 2025' — esse é o módulo de Blog SEO por $99/mês. Muitas imobiliárias utilizam os dois juntos.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "O Stacc publica no seu Google Business Profile todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Conquiste mais clientes imobiliários pelo Google por $49/mês.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "billingDuration": "P1M"
        }
      },
      "inLanguage": "pt-BR",
      "url": "https://thestacc.com/pt-br/para/imobiliarias/"
    },
    {
      "@type": "BreadcrumbList",
      "inLanguage": "pt-BR",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Início",
          "item": "https://thestacc.com/pt-br/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Setores",
          "item": "https://thestacc.com/pt-br/para/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Imobiliárias",
          "item": "https://thestacc.com/pt-br/para/imobiliarias/"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  lang="pt-BR"
  title="SEO para Imobiliárias | Mais Clientes pelo Google | theStacc"
  description="O Stacc publica no GBP da sua imobiliária todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Conquiste mais clientes imobiliários pelo Google por $49/mês."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Imobiliárias · Com Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais clientes imobiliários pelo Google.<br />
            <span style="color:#4f39f6;">No piloto automático.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            246.000 pessoas pesquisam "corretor de imóveis perto de mim" todo mês. 76% dos compradores pesquisam corretores online antes de entrar em contato. O Stacc garante que sua imobiliária apareça primeiro — publicando no seu Google Business Profile diariamente, gerenciando avaliações e monitorando seu ranking no Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Veja como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem contratos · Publica no seu GBP todos os dias
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '246K', num: 246, prefix: '',  suffix: 'K', decimals: 0, from: 0, label: 'Buscas mensais por "corretor perto de mim"' },
              { value: '76%',  num: 76,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Compradores pesquisam online antes de contato' },
              { value: '4.5×', num: 4.5, prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Melhora média no ranking no Maps' },
              { value: '100%', num: 100, prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Avaliações capturadas instantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Imobiliárias ranqueando com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Grupo Silva Imóveis — São Paulo, SP', 'Imobiliária Costa — Rio de Janeiro, RJ', 'Casa Nova Imóveis — Belo Horizonte, MG', 'Terra Boa Imobiliária — Curitiba, PR', 'Litoral Imóveis — Florianópolis, SC', 'Serra Alta Imobiliária — Porto Alegre, RS', 'Horizonte Imóveis — Brasília, DF', 'Grupo Silva Imóveis — São Paulo, SP', 'Imobiliária Costa — Rio de Janeiro, RJ', 'Casa Nova Imóveis — Belo Horizonte, MG', 'Terra Boa Imobiliária — Curitiba, PR', 'Litoral Imóveis — Florianópolis, SC', 'Serra Alta Imobiliária — Porto Alegre, RS', 'Horizonte Imóveis — Brasília, DF'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Seus melhores clientes estão pesquisando agora.<br />E estão ligando para outro corretor.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            83% dos compradores que encontram um corretor na busca local acabam entrando em contato com ele. A única pergunta é: de quem é o perfil que eles encontram primeiro.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">O Google recompensa perfis ativos. Seu GBP está quieto há semanas.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">O algoritmo do Maps favorece corretores que publicam consistentemente, respondem a avaliações e permanecem ativos. Cada semana que seu GBP fica inativo, um corretor concorrente que posta atualizações de mercado, novos imóveis e conteúdo de bairro ganha terreno. No mercado imobiliário, o corretor mais visível é o que recebe a ligação.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação sem resposta está desviando compradores para outro corretor.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">76% dos compradores e vendedores leem avaliações online antes de escolher um corretor. Uma avaliação negativa sem resposta diz a cada futuro cliente que você está ocupado demais — ou indiferente — para responder. Em um negócio de relacionamento, sua reputação online é o boca a boca em escala.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você ranqueia pelo seu nome. Não por "corretor de imóveis perto de mim".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Compradores não pesquisam seu nome quando começam a busca — eles ainda não o conhecem. Eles pesquisam "corretor de imóveis perto de mim", "apartamentos à venda [bairro]" e "imobiliária [cidade]". Se você não está no Map Pack para esses termos, está invisível para os compradores prontos para agir agora.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz para imobiliárias</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada alavanca que gera novos clientes pelo Google. Resolvida.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para imobiliárias exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo com palavras-chave específicas — todo mês, sem exceção. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicação no GBP',
              body: '30 publicações otimizadas por localidade por mês — novos imóveis, atualizações de mercado, guias de bairro, dicas para compradores e vendedores, direcionadas às suas regiões específicas. Publicadas automaticamente no horário certo.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Palavras-chave Imobiliárias',
              body: 'Combinações de serviço + localização para cada mercado que você atende — corretor comprador, corretor vendedor, imóveis de luxo, apartamentos, imóveis para investimento, bairros específicos. Tudo calibrado para sua área de atuação.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoramento de Avaliações',
              body: 'Alertas instantâneos quando uma nova avaliação aparecer. Rastreamento da tendência de estrelas semana a semana. Modelos de resposta para que você responda em menos de um minuto e construa a reputação que gera indicações.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Rastreamento de Ranking Local',
              body: 'Relatórios de ranking no Maps baseados em grade mostrando exatamente onde sua imobiliária aparece para cada palavra-chave em toda a sua área de atuação. Acompanhamento mês a mês para ver sua posição crescer.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestão Multi-mercado',
              body: 'Atende vários bairros ou cidades? Cada mercado recebe sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de desempenho — tudo em um único painel. Veja quais mercados precisam de atenção.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construção de Citações',
              body: 'Verificação de consistência NAP e envio a diretórios em plataformas imobiliárias — ZAP Imóveis, OLX, Viva Real, Imovelweb e mais de 50 outros. Os sinais de autoridade que impulsionam seu ranking no Maps.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia sua presença<br />no Maps a partir desse dia.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sem logins no GBP. Sem escrever publicações. Sem verificar avaliações manualmente. Configure uma vez e seu Google Business Profile funciona sozinho — para você focar nos clientes.
          </p>
        </div>

