---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo até meu negócio de aulas particulares subir no Google Maps?",
    a: "A maioria dos negócios de aulas particulares vê movimentação significativa no Maps em 60 a 90 dias de atividade consistente no GBP. O algoritmo local do Google recompensa frequência, relevância e engajamento — os três que o Stacc entrega automaticamente todo mês. Negócios que não publicavam nada antes tendem a ver resultados mais rápido.",
  },
  {
    q: "Publicar no GBP realmente ajuda um negócio de aulas particulares a rankear?",
    a: "Sim. A própria documentação do Google afirma que Perfis de Empresa atualizados regularmente têm mais probabilidade de aparecer nos resultados de pesquisa local. O algoritmo do Maps considera frequência de publicações, velocidade de resposta a avaliações e relevância de palavras-chave. Cada mês que seu perfil fica inativo, um professor particular ou centro de aulas concorrente constrói a autoridade no Maps que você levará meses para recuperar.",
  },
  {
    q: "Quais palavras-chave de aulas particulares o Stacc segmenta?",
    a: "O Stacc segmenta combinações de matéria + cidade — 'professor particular de matemática perto de mim', 'preparação para o ENEM [cidade]', 'professor de leitura perto de mim', 'professor de STEM [cidade]', 'preparação para vestibular [cidade]', 'professor particular para concursos [cidade]'. Todas as palavras-chave são calibradas para suas matérias e área de atendimento específicas.",
  },
  {
    q: "Meu negócio já tem um Perfil de Empresa no Google. Preciso fazer alguma coisa para configurar?",
    a: "Basta conectar. O Stacc puxa os dados existentes do seu GBP — nome do negócio, serviços, fotos, histórico de avaliações e posição de ranking atual — e cria um plano de conteúdo a partir daí. A configuração leva menos de cinco minutos. Depois disso, o Stacc cuida de tudo: redigir publicações, publicar no cronograma, enviar alertas de avaliações e rastrear seu ranking no Maps mês a mês.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "O Stacc envia um alerta instantâneo no momento em que uma nova avaliação aparece, seja positiva ou negativa. Você recebe o texto da avaliação, a classificação em estrelas e um modelo de resposta para que possa responder em menos de um minuto. Em aulas particulares, cada aluno de longo prazo vale R$2.400–R$9.600 em receita anual — responder prontamente a avaliações negativas sinaliza a todo futuro responsável que você leva o progresso do filho a sério.",
  },
  {
    q: "Vocês atendem centros de aulas com múltiplas unidades?",
    a: "Sim. Cada unidade recebe sua própria estratégia de palavras-chave, calendário de conteúdo, cronograma de publicações no GBP e relatório de ranking — tudo gerenciado em um único painel. As publicações segmentam a cidade específica, matérias e intenção de busca local daquela unidade. Você pode ver o desempenho de todas as unidades lado a lado e identificar quais precisam de mais atenção.",
  },
  {
    q: "Como o Stacc é diferente de uma agência de marketing para aulas particulares?",
    a: "Uma agência de marketing para aulas particulares cobra R$2.000–R$5.000/mês e exige reuniões de integração e contratos longos. O Stacc automatiza todo esse processo — pesquisa, redação, agendamento, monitoramento de avaliações, rastreamento de ranking — por $49/mês. O resultado é o mesmo. A sobrecarga e as margens somem.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog para aulas particulares ou apenas com GBP?",
    a: "O módulo de SEO Local do Stacc cuida de publicações no GBP, monitoramento de avaliações e rastreamento de ranking. Se você quer artigos com dicas de estudo e guias de matérias publicados no seu site todo mês — do tipo que rankeia para 'como melhorar nas notas de matemática' e 'dicas de preparação para o ENEM' — esse é o módulo de Blog SEO por $99/mês. Muitos negócios de aulas particulares usam ambos juntos para cobertura completa de busca orgânica.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "O Stacc publica no Perfil de Empresa do Google do seu negócio de aulas particulares todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "billingDuration": "P1M"
        }
      },
      "inLanguage": "pt-BR"
    },
    {
      "@type": "BreadcrumbList",
      "inLanguage": "pt-BR",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Início",
          "item": "https://thestacc.com/pt-br/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Setores",
          "item": "https://thestacc.com/pt-br/para/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Aulas Particulares",
          "item": "https://thestacc.com/pt-br/para/aulas-particulares/"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  lang="pt-BR"
  title="SEO para Aulas Particulares | Mais Alunos pelo Google | theStacc"
  description="O Stacc publica no Perfil de Empresa do Google do seu negócio de aulas particulares todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Consiga mais alunos pelo Google por $49/mês."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Aulas Particulares · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais alunos de aulas particulares pelo Google.<br />
            <span style="color:#4f39f6;">O ano todo, não só antes das provas.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            340.000 pessoas buscam "professor particular perto de mim" todo mês. 77% dos responsáveis pesquisam professores online antes de entrar em contato. O Stacc garante que seu negócio apareça primeiro — publicando no seu GBP diariamente, gerenciando avaliações e rastreando seu ranking no Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Veja como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Garantia de 30 dias · Sem contratos · Publica no seu GBP todos os dias
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '340K',  num: 340,  prefix: '',  suffix: 'K',  decimals: 0, from: 0, label: 'Buscas mensais por "professor particular perto de mim"' },
              { value: '77%',   num: 77,   prefix: '',  suffix: '%',  decimals: 0, from: 0, label: 'Responsáveis pesquisam online primeiro' },
              { value: '4.3×',  num: 4.3,  prefix: '',  suffix: '×',  decimals: 1, from: 0, label: 'Melhora média de ranking no Maps' },
              { value: '100%',  num: 100,  prefix: '',  suffix: '%',  decimals: 0, from: 0, label: 'Avaliações capturadas instantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negócios de aulas particulares rankeando com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Centro de Reforço Escolar Silva — São Paulo, SP','Aulas Particulares Costa — Rio de Janeiro, RJ','Instituto Aprender BH — Belo Horizonte, MG','Centro Educacional Paraná — Curitiba, PR','Reforço Escolar Gaúcho — Porto Alegre, RS','Instituto Educação Brasília — Brasília, DF','Centro de Reforço Fortaleza — Fortaleza, CE','Centro de Reforço Escolar Silva — São Paulo, SP','Aulas Particulares Costa — Rio de Janeiro, RJ','Instituto Aprender BH — Belo Horizonte, MG','Centro Educacional Paraná — Curitiba, PR','Reforço Escolar Gaúcho — Porto Alegre, RS','Instituto Educação Brasília — Brasília, DF','Centro de Reforço Fortaleza — Fortaleza, CE'].map((name, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Responsáveis estão buscando um professor agora mesmo.<br />Eles estão ligando para outro.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            79% dos responsáveis verificam avaliações antes de contratar um professor. A única questão é qual perfil eles encontram primeiro.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Fevereiro e agosto chegam. Responsáveis buscam reforço escolar. Eles ligam para quem aparece primeiro no Maps.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">As buscas por aulas particulares disparam em fevereiro e agosto — início dos semestres letivos no Brasil. O algoritmo do Maps constrói autoridade ao longo de meses de atividade consistente. Negócios de aulas que publicam o ano todo — durante o recesso, nas férias — rankeiam significativamente melhor quando a demanda aumenta. Cada mês que seu GBP fica inativo, um professor concorrente constrói essa autoridade no lugar de você.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação negativa sem resposta de um responsável frustrado está custando um aluno de longo prazo.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">79% dos responsáveis verificam avaliações antes de contratar um professor. Os responsáveis estão confiando a você o futuro acadêmico de seus filhos. Uma avaliação negativa sobre má comunicação ou falta de resultados que fica sem resposta diz a todo futuro responsável exatamente o que eles temem. Em aulas particulares, cada aluno de longo prazo vale R$2.400–R$9.600 em receita anual — sua nota em estrelas determina se você recebe a ligação.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você rankeia pelo nome do seu centro. Não por "professor particular de matemática perto de mim".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Responsáveis que buscam um professor não pesquisam pelo nome do seu centro — eles pesquisam 'professor particular de matemática perto de mim', 'aulas para o ENEM [cidade]' e 'reforço escolar perto de mim'. Se você não está no Map Pack para essas buscas, esses alunos — que muitas vezes ficam por vários anos letivos — ligam para quem está.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz para aulas particulares</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todos os recursos que atraem novos alunos pelo Google. Resolvidos.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para negócios de aulas particulares exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo com palavras-chave segmentadas — todo mês. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicação no GBP',
              body: '30 publicações otimizadas por localização por mês — dicas de estudo, destaques de matérias, conteúdo de preparação para provas, promoções de volta às aulas e conteúdo sazonal. Publicado automaticamente no cronograma.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Segmentação de Palavras-chave',
              body: 'Combinações de matéria + cidade para cada especialidade que você oferece — matemática, preparação para o ENEM, leitura, STEM, preparação para vestibular, língua estrangeira. Tudo calibrado para seus serviços e localização específicos.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoramento de Avaliações',
              body: 'Alertas instantâneos no momento em que uma nova avaliação aparece no seu Perfil de Empresa. Acompanhamento semanal da tendência de nota. Modelos de resposta para que você possa responder em menos de um minuto — essencial quando responsáveis estão tomando decisões sobre a educação de seus filhos.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Rastreamento de Ranking Local',
              body: 'Relatórios de ranking no Maps em grade mostrando exatamente onde seu negócio de aulas rankeia para cada palavra-chave em toda a sua área de atendimento. Acompanhamento mês a mês — especialmente útil quando a demanda semestral aumenta.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestão de Múltiplas Unidades',
              body: 'Várias unidades do seu centro de aulas? Cada uma recebe sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de desempenho — tudo em um único painel. Veja quais unidades precisam de atenção e acompanhe a melhora em cada centro.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construção de Citações',
              body: 'Verificações de consistência NAP e submissões em diretórios de educação — Superprof, Guru, ProAluno, Yelp e mais de 50 outros. Os sinais de autoridade nos bastidores que ajudam você a superar os concorrentes no seu mercado.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
