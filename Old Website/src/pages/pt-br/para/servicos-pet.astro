---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo leva para meu negócio de serviços pet ranquear melhor no Google Maps?",
    a: "A maioria dos negócios pet começa a perceber movimentação significativa no Maps entre 60 e 90 dias de atividade consistente no GBP. Buscas por serviços pet têm intenção local muito alta — uma vez que você ranqueia no Map Pack, os agendamentos chegam rapidamente.",
  },
  {
    q: "Publicar no GBP realmente ajuda um pet shop ou hotel para pets a ranquear?",
    a: "Sim. O algoritmo do Maps recompensa atividade consistente no GBP — conteúdo sobre cuidados com pets, atualizações de serviços, dicas de banho e tosa, promoções sazonais e posts com fotos. Cada semana que seu perfil fica inativo, um concorrente constrói o ranking que você precisa.",
  },
  {
    q: "Quais palavras-chave de serviços pet o Stacc segmenta?",
    a: "O Stacc segmenta combinações de serviço + cidade — 'banho e tosa perto de mim', 'hotel para cães [cidade]', 'creche para cães perto de mim', 'adestramento de cães [cidade]', 'banho em gatos [cidade]'. Tudo calibrado para seus serviços específicos e área de atendimento.",
  },
  {
    q: "Meu negócio já tem um GBP. Preciso fazer alguma configuração especial?",
    a: "Basta conectar. O Stacc importa seus dados existentes e cria um plano de conteúdo em menos de 5 minutos.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "Alerta instantâneo com o texto da avaliação e um modelo de resposta para que você possa responder rapidamente. Em serviços pet, a confiança é a barreira definitiva — os tutores precisam acreditar que seus animais estarão seguros e felizes. Responder rápido a críticas mostra aos futuros clientes como você lida com preocupações.",
  },
  {
    q: "Vocês trabalham com negócios pet que possuem múltiplas unidades?",
    a: "Sim. Cada unidade recebe sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de ranking — tudo gerenciado em um único painel.",
  },
  {
    q: "Como o Stacc é diferente de uma agência de marketing para pet shops?",
    a: "Agências cobram R$ 2.500–R$ 6.000/mês (equivalente a $500–$1.200) pelo gerenciamento manual do GBP. O Stacc automatiza tudo por $49/mês com mais volume — 30 posts/mês contra os típicos 8–12.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog sobre cuidados com pets?",
    a: "Sim — o módulo de Blog SEO por $99/mês publica artigos como 'com que frequência devo dar banho no meu cachorro' e 'o que procurar em um hotel para cães' que ranqueiam no Google e geram novos agendamentos. Muitos negócios pet usam os dois juntos.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "theStacc posta no Perfil de Empresa no Google do seu negócio de serviços pet todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "priceValidUntil": "2026-12-31"
      },
      "inLanguage": "pt-BR"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Início",
          "item": "https://thestacc.com/pt-br/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Setores",
          "item": "https://thestacc.com/pt-br/para/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Serviços Pet",
          "item": "https://thestacc.com/pt-br/para/servicos-pet/"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO para Serviços Pet | Mais Clientes pelo Google | theStacc"
  description="O Stacc posta no Perfil de Empresa no Google do seu negócio de serviços pet todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Atraia mais clientes pelo Google por $49/mês."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Serviços Pet · Desenvolvido pelo Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais clientes para seu negócio pet pelo Google.<br />
            <span style="color:#4f39f6;">Toda semana.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Centenas de milhares de pessoas pesquisam "banho e tosa perto de mim" ou "hotel para cães perto de mim" todo mês. 80% dos tutores de pets pesquisam serviços online antes de agendar. O Stacc garante que seu negócio apareça primeiro — postando no seu GBP diariamente, gerenciando avaliações e rastreando seu ranking no Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Veja como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem contratos · Posts no seu GBP todos os dias
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '620K',  num: 620,  prefix: '',  suffix: 'K', decimals: 0, from: 0, label: 'Buscas mensais por serviços pet no Google' },
              { value: '80%',   num: 80,   prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Tutores pesquisam online primeiro' },
              { value: '4,5×',  num: 4.5,  prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Média de melhoria de ranking no Maps' },
              { value: '100%',  num: 100,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Avaliações capturadas instantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Empresas locais ranqueando com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Patinhas Felizes Banho e Tosa — São Paulo, SP', 'Mundo Pet Resort — Belo Horizonte, MG', 'Patas Douradas — Curitiba, PR', 'Sul Pet Hotel — Porto Alegre, RS', 'Ilha dos Pets — Florianópolis, SC', 'Pet Nordeste — Recife, PE', 'Bahia Pet Care — Salvador, BA', 'Patinhas Felizes Banho e Tosa — São Paulo, SP', 'Mundo Pet Resort — Belo Horizonte, MG', 'Patas Douradas — Curitiba, PR', 'Sul Pet Hotel — Porto Alegre, RS', 'Ilha dos Pets — Florianópolis, SC', 'Pet Nordeste — Recife, PE', 'Bahia Pet Care — Salvador, BA'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444c0-1.061-.162-2.2-.493-3.309m-9.243-6.082A8.801 8.801 0 0 1 12 5c.78 0 1.5.108 2.161.306"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tutores de pets na sua região estão pesquisando agora.<br />Eles estão agendando com o seu concorrente.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            85% dos tutores verificam avaliações antes de confiar seus animais a alguém. A única questão é qual negócio eles encontram primeiro no Map Pack.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Tutores escolhem seu banho e tosa ou hotel pet por quem aparece primeiro no Google Maps.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Buscas por serviços pet têm intenção local muito alta — um tutor pesquisando "banho e tosa perto de mim" está agendando nesta semana, não pesquisando indefinidamente. O algoritmo do Maps recompensa atividade consistente no GBP com conteúdo de cuidados com pets, atualizações de serviços e posts com fotos. Cada semana que seu perfil fica inativo, um concorrente constrói o ranking que você precisa.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação de 2 estrelas sobre um pet machucado está esvaziando sua agenda de agendamentos.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">85% dos tutores verificam avaliações antes de confiar seus animais a alguém. Em serviços pet, a confiança é a barreira definitiva — os donos precisam acreditar que seus pets ficarão seguros e felizes. Uma avaliação negativa sem resposta sobre uma experiência ruim envia cada futuro cliente para o seu concorrente.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você ranqueia pelo nome do seu negócio. Não por "banho e tosa perto de mim".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Tutores em busca de serviços pesquisam "banho e tosa perto de mim", "hotel para cães [cidade]" e "creche para cães perto de mim". Se você não está no Map Pack para essas buscas, esses clientes — que muitas vezes vêm semanalmente — vão para quem está aparecendo.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz para negócios de serviços pet</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada alavanca que atrai novos clientes pet pelo Google. Automatizada.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para negócios pet exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo segmentado por palavras-chave — todo mês. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicação de Posts no GBP',
              body: '30 posts/mês — dicas de tosa, cuidados sazonais com pets, promoções de hospedagem em feriados, destaques de raças e promoções para novos clientes. Publicados automaticamente.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Segmentação de Palavras-Chave Pet',
              body: 'Serviço + cidade: banho e tosa perto de mim, hotel para cães, creche para cães, adestramento, banho em gatos. Calibrado para seus serviços e área de atendimento.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoramento de Avaliações',
              body: 'Alertas instantâneos de avaliações com modelos de resposta para proteger a reputação baseada em confiança que os tutores precisam antes de agendar.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Rastreamento de Ranking Local',
              body: 'Relatórios de ranking no Maps baseados em grade para cada palavra-chave em toda a sua área de atendimento. Rastreamento mês a mês para que você veja sua posição acumular.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestão de Múltiplas Unidades',
              body: 'Várias unidades? Cada uma recebe sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de desempenho — tudo em um único painel.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construção de Citações',
              body: 'Submissões em diretórios como Yelp, Pet Anjo e mais de 50 outros. Os sinais de autoridade que ajudam seu negócio pet a superar a concorrência.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia a presença<br />no Maps do seu negócio pet a partir daí.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sem logins no GBP. Sem escrever posts. Sem verificar avaliações manualmente. Configure uma vez e seu Perfil de Empresa no Google funciona sozinho — para você se concentrar nos animais.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
