---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quanto tempo leva para minha assessoria financeira ranquear melhor no Google Maps?",
    a: "A maioria dos assessores independentes começa a perceber movimentação significativa no Maps entre 60 e 90 dias de atividade consistente no GBP. A assessoria financeira tem forte demanda de busca local e muitos profissionais que nunca atualizaram seu Perfil de Empresa no Google — portanto, a oportunidade de ranking é expressiva.",
  },
  {
    q: "Publicar no GBP realmente ajuda um consultor financeiro a ranquear?",
    a: "Sim. O algoritmo do Maps recompensa atividade consistente no GBP — atualizações de mercado, dicas de planejamento para aposentadoria, lembretes de temporada de imposto e conteúdo sobre eventos de vida. Assessores que se mantêm na mente dos clientes por meio de postagens consistentes ranqueiam melhor e capturam clientes no momento da decisão financeira.",
  },
  {
    q: "Quais palavras-chave de consultor financeiro o Stacc segmenta?",
    a: "O Stacc segmenta combinações de serviço + cidade — 'consultor financeiro perto de mim', 'planejador de aposentadoria [cidade]', 'gestão de patrimônio [cidade]', 'assessor de investimentos [cidade]', 'fiduciário [cidade]'. Tudo calibrado para sua especialidade e localização específicas.",
  },
  {
    q: "Meu escritório já tem um Perfil de Empresa no Google. Preciso fazer algo especial?",
    a: "Basta conectar. O Stacc importa seus dados existentes e cria um plano de conteúdo em menos de 5 minutos. Depois disso, os posts são publicados automaticamente e os alertas de avaliações chegam instantaneamente.",
  },
  {
    q: "O que acontece quando recebo uma avaliação negativa?",
    a: "Alerta imediato com o texto da avaliação e um modelo de resposta para que você possa responder prontamente. Quando alguém está decidindo quem vai administrar sua aposentadoria, sua resposta a uma crítica diz tudo sobre como você trata os relacionamentos com os clientes.",
  },
  {
    q: "Vocês trabalham com assessorias financeiras com múltiplos escritórios?",
    a: "Sim. Cada escritório recebe sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de ranking em um único painel.",
  },
  {
    q: "Como o Stacc é diferente de uma agência de marketing financeiro?",
    a: "Agências cobram $1.000–$3.000/mês pelo gerenciamento manual do GBP. O Stacc automatiza tudo por $49/mês com mais resultado — 30 posts/mês contra os típicos 8–12.",
  },
  {
    q: "O Stacc ajuda com conteúdo de blog de planejamento financeiro?",
    a: "Sim — o módulo de Blog SEO por $99/mês publica artigos como 'quando devo começar a poupar para a aposentadoria' e 'como escolher um consultor financeiro' que ranqueiam no Google e geram novas consultas de clientes. Muitos assessores usam os dois.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "O theStacc posta no Perfil de Empresa no Google da sua assessoria financeira todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "priceValidUntil": "2026-12-31"
      },
      "inLanguage": "pt-BR"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Início",
          "item": "https://thestacc.com/pt-br/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Setores",
          "item": "https://thestacc.com/pt-br/para/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Consultores Financeiros",
          "item": "https://thestacc.com/pt-br/para/consultores-financeiros/"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO para Consultores Financeiros | Mais Clientes pelo Google | theStacc"
  description="O Stacc posta no Perfil de Empresa no Google da sua assessoria financeira todos os dias, gerencia suas avaliações e rastreia seu ranking no Maps — automaticamente. Consiga mais clientes de planejamento financeiro pelo Google por $49/mês."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Consultores Financeiros · Desenvolvido pelo Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mais clientes de planejamento financeiro pelo Google.<br />
            <span style="color:#4f39f6;">Sem prospecção ativa.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            160.000 pessoas pesquisam "consultor financeiro perto de mim" todo mês. 71% das pessoas pesquisam assessores financeiros online antes de entrar em contato. O Stacc garante que sua assessoria apareça primeiro — postando no seu Perfil de Empresa no Google diariamente, gerenciando avaliações e rastreando seu ranking no Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/pt-br/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Veja como funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 dias de garantia · Sem contratos · Posts no seu GBP todos os dias
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '160K',  num: 160,  prefix: '',  suffix: 'K', decimals: 0, from: 0, label: 'Buscas mensais por "consultor financeiro perto de mim"' },
              { value: '71%',   num: 71,   prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Clientes pesquisam assessores online primeiro' },
              { value: '4,3×',  num: 4.3,  prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Média de melhoria de ranking no Maps' },
              { value: '100%',  num: 100,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Avaliações capturadas instantaneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Empresas locais ranqueando com o Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 avaliações</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Capital Invest Assessoria — São Paulo, SP', 'Sul Patrimônio — Porto Alegre, RS', 'Nordeste Wealth — Recife, PE', 'Planalto Finanças — Brasília, DF', 'Carioca Investimentos — Rio de Janeiro, RJ', 'Horizonte Financeiro — Belo Horizonte, MG', 'Litoral Assessoria — Florianópolis, SC', 'Capital Invest Assessoria — São Paulo, SP', 'Sul Patrimônio — Porto Alegre, RS', 'Nordeste Wealth — Recife, PE', 'Planalto Finanças — Brasília, DF', 'Carioca Investimentos — Rio de Janeiro, RJ', 'Horizonte Financeiro — Belo Horizonte, MG', 'Litoral Assessoria — Florianópolis, SC'].map((name, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Clientes em potencial estão pesquisando agora.<br />Eles estão ligando para um assessor concorrente.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            73% das pessoas leem avaliações antes de escolher um consultor financeiro. A única questão é qual assessoria elas encontram primeiro no Pacote de Mapas.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Seu GBP nunca foi atualizado. Seu concorrente posta conteúdo de planejamento de aposentadoria toda semana.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Consultores financeiros que se mantêm na mente dos clientes com atividade consistente no GBP — atualizações de mercado, dicas de planejamento de aposentadoria, lembretes de declaração de IR e conteúdo sobre eventos de vida — ranqueiam mais alto no Maps E capturam clientes no momento da decisão financeira. Cada semana que seu perfil fica inativo, um assessor concorrente constrói a visibilidade e a confiança que traz novos clientes para ele.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Uma avaliação negativa sem resposta está custando a você um cliente com R$1M em patrimônio.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">73% das pessoas leem avaliações antes de escolher um consultor financeiro. Quando alguém está decidindo quem vai administrar sua aposentadoria, ela pesquisa você a fundo. Uma avaliação sobre má comunicação ou taxas inesperadas sem resposta diz a cada cliente futuro a pior coisa possível: que você não apoia seu serviço. Sua classificação de estrelas é sua credibilidade em escala.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Você ranqueia para o nome do seu escritório. Não para "consultor financeiro perto de mim".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Pessoas que precisam de um consultor financeiro pesquisam "consultor financeiro perto de mim", "planejador de aposentadoria [cidade]" e "gestão de patrimônio [cidade]". Elas não pesquisam o nome do seu escritório. Se você não está no Pacote de Mapas para essas buscas, é invisível para as pessoas que estão prontas para transferir seu PGBL ou iniciar seu plano de aposentadoria agora.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o Stacc faz por consultores financeiros</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada alavanca que gera novos clientes pelo Google. Resolvida.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            O ranking no Maps para consultores financeiros exige atividade consistente no GBP, respostas rápidas a avaliações e conteúdo direcionado por palavras-chave — todo mês sem exceção. O Stacc cuida de tudo automaticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicação de Posts no GBP',
              body: '30 posts/mês — atualizações de mercado, dicas de planejamento de aposentadoria, lembretes de declaração de IR, marcos financeiros de eventos de vida e conteúdo educativo. Publicados automaticamente.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Segmentação por Palavras-chave Financeiras',
              body: 'Serviço + cidade: consultor financeiro, planejador de aposentadoria, gestão de patrimônio, assessor de investimentos, fiduciário. Calibrado para sua especialidade e localização.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoramento de Avaliações',
              body: 'Alertas instantâneos de avaliações com modelos de resposta para proteger a credibilidade que conquista clientes que estão confiando a você seu futuro financeiro.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Rastreamento de Ranking Local',
              body: 'Relatórios de ranking no Maps baseados em grade para cada palavra-chave em toda a sua área de atuação. Acompanhamento mês a mês para que você veja sua posição crescer.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestão de Múltiplos Escritórios',
              body: 'Múltiplos escritórios? Cada um recebe sua própria estratégia de palavras-chave, calendário de conteúdo e relatório de ranking em um único painel.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construção de Citações',
              body: 'Submissões em diretórios do setor financeiro, Yelp e outros 50+. Sinais de autoridade que constroem confiança e ajudam no ranking.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecte uma vez. O Stacc gerencia a presença no Maps<br />da sua assessoria a partir desse dia.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sem logins no GBP. Sem escrever posts. Sem verificar avaliações manualmente. Configure uma vez e seu Perfil de Empresa no Google funciona sozinho — para que você possa focar em clientes e carteiras.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
