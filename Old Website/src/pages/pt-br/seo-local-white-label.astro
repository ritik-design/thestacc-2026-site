---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é SEO local white-label?", a: "SEO local white-label é a prática de agências entregarem serviços de otimização em busca local aos clientes por meio de uma plataforma personalizada com a identidade da própria agência — seu logo, domínio e cores — e não com a marca do fornecedor do software. Os clientes vivenciam a marca da agência em todos os painéis, relatórios e comunicações." },
  { q: "Quais tarefas de SEO local o Stacc automatiza em modo white-label?", a: "Todas elas: publicação de posts no GBP (30 por mês por localização), rastreamento diário de posições, monitoramento de citações em mais de 50 diretórios, alertas de avaliações em tempo real e geração e entrega automatizadas de relatórios. Tudo é totalmente automatizado e entregue sob a marca da sua agência." },
  { q: "Posso revender os serviços de SEO local do Stacc como meus?", a: "Sim. O Stacc foi desenvolvido especificamente para esse caso de uso. Você entrega resultados de SEO local por meio de uma plataforma que carrega a sua marca. Os clientes nunca veem o nome do Stacc. Você define seus próprios preços para os clientes e mantém a margem entre o que cobra e o que o Stacc custa." },
  { q: "Posso ter templates de relatório diferentes para clientes diferentes?", a: "Sim. Cada cliente pode ter uma configuração de relatório personalizada — métricas diferentes, agendas de entrega diferentes, logos diferentes se você tiver submarcas. Os relatórios são gerados e entregues automaticamente para cada cliente com base na configuração dele." },
  { q: "Há um mínimo de clientes para usar o white-label?", a: "Nenhum mínimo. Você pode configurar o white-label com um único cliente e escalar a partir daí. O preço é baseado em localizações gerenciadas, não no número de clientes." },
  { q: "O Stacc oferece suporte para onboarding white-label?", a: "Sim. A equipe do Stacc oferece suporte para configuração white-label e onboarding inicial de clientes. A maioria das agências conclui a configuração white-label de forma independente em cerca de 2 horas." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO Local White-Label", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Plataforma de SEO local white-label para agências. Entregue gestão de GBP, rastreamento de posições, monitoramento de citações e relatórios sob a sua própria marca.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "SEO Local White-Label", "item": "https://thestacc.com/pt-br/seo-local-white-label/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de SEO Local White-Label para Agências | theStacc"
  description="Plataforma de SEO local white-label para agências. Gestão de GBP, rastreamento de posições, citações e relatórios — automatizados e entregues sob a marca da sua agência para cada cliente."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Local White-Label · Para Agências · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local white-label que seus clientes<br />
            <span style="color:#4f39f6;">vivenciam como sua própria plataforma.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc entrega automação completa de SEO local — GBP, posições, citações, avaliações e relatórios — por meio de uma plataforma totalmente sob a sua marca. Os clientes veem o seu logo, o seu domínio, os seus relatórios.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/solucoes/agencias/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funcionalidades para agências
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · 30 dias de garantia · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLEM NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que o SEO local white-label realmente entrega</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Os clientes veem a sua marca. Você entrega<br />resultados reais de SEO local. Automaticamente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>SEO local white-label não é apenas colocar o seu logo no painel de outra empresa. É ter a capacidade de entregar execução de SEO local de alta qualidade e automatizada sob a sua própria marca — para que você possa escalar sua base de clientes sem aumentar a equipe na mesma proporção.</p>
            <p>O Stacc automatiza cada tarefa contínua de SEO local: 30 posts por mês no GBP, rastreamento diário de posições, monitoramento de citações em mais de 50 diretórios, alertas de avaliações em tempo real e relatórios automáticos para clientes. Tudo acontece sob a sua marca. Você configura os clientes uma vez e a plataforma executa o trabalho contínuo automaticamente — dando a você a capacidade de atender três vezes mais clientes de SEO local sem triplicar a equipe.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que está incluído</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            SEO local completo sob a sua marca.<br />Cada tarefa. Cada cliente.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automação de posts no GBP', body: 'O Stacc publica 30 posts por mês por localização, segmentando a intenção de busca local. Os perfis permanecem ativos diariamente — sem trabalho do cliente, sem trabalho da agência.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreamento diário de posições', body: 'Cada palavra-chave atualizada diariamente para cada localização do cliente. Posições visíveis em painéis personalizados com dados de tendência e alertas de variação.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoramento de citações', body: 'Monitoramento contínuo de precisão de NAP em mais de 50 diretórios para cada cliente. Inconsistências sinalizadas e corrigidas automaticamente.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestão de avaliações', body: 'Alertas de avaliações em tempo real para cada localização do cliente. Responda direto pelo painel da agência. Acompanhe taxas de resposta e pontuações de reputação por cliente.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Relatórios automatizados com sua marca', body: 'Relatórios gerados conforme o calendário, formatados com o seu logo e entregues do seu domínio. Zero etapas manuais por cliente por mês.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Domínio personalizado + marca', body: 'Os clientes acessam os painéis no seu subdomínio. O seu logo e suas cores em cada tela. $0 por login de cliente. O nome do Stacc nunca aparece.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">White-label em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que a sua marca parece<br />em cada tela do cliente.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Experiência Completa White-Label</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sua marca. Em cada tela do cliente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cada interação que um cliente tem com a plataforma — login, painel, relatório, alerta por e-mail — carrega o logo e o domínio da sua agência. O Stacc é invisível. Você sobe o logo uma vez, configura o CNAME para o seu subdomínio e a partir daí cada cliente vive dentro da sua marca. Não existe co-branding, não existe "powered by Stacc", não existe nenhuma referência ao fornecedor em nenhuma tela voltada ao cliente.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver solução para agências
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between rounded-xl bg-[#4f39f6] px-4 py-3">
                <span class="font-sans text-[13px] font-bold text-white">Agência SEO Digital</span>
                <span class="font-mono text-[10px] text-white/60">seo.suaagencia.com.br</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-3">Painel do Cliente — Vista do cliente</p>
              {[
                { label: 'Posts GBP este mês', value: '30 publicados', ok: true },
                { label: 'Posição média no Local Pack', value: '#2,4', ok: true },
                { label: 'Avaliações monitoradas', value: '14 novas', ok: true },
                { label: 'Citações verificadas', value: '52 diretórios ✓', ok: true },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <span class="font-sans text-[12px] text-[#57534e]">{row.label}</span>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">{row.value}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Zero menção ao Stacc · Só a sua marca</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Entregas do mês — Cliente: Clínica Carvalho</p>
              {[
                { task: '30 posts no GBP publicados', status: '✓ Concluído', ok: true },
                { task: 'Posições rastreadas diariamente', status: '✓ Concluído', ok: true },
                { task: '3 citações corrigidas', status: '✓ Concluído', ok: true },
                { task: '8 avaliações alertadas', status: '✓ Concluído', ok: true },
                { task: 'Relatório mensal entregue', status: '✓ Entregue', ok: true },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <span class="font-sans text-[12px] text-[#374151]">{row.task}</span>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">{row.status}</span>
                </div>
              ))}
              <div class="mt-3 flex items-center gap-2 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-3 py-2">
                <span class="font-mono text-[10px] text-[#79716b]">Relatório enviado por</span>
                <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">relatorios@suaagencia.com.br</span>
              </div>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">SEO Local Completo Sob Sua Marca</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                GBP, citações, avaliações e relatórios — todos white-labeled.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Não é apenas o painel que tem a sua marca. Cada elemento da entrega de SEO local está coberto: posts no GBP publicados automaticamente, citações monitoradas e corrigidas, avaliações alertadas em tempo real e relatórios mensais enviados do seu domínio de e-mail. Do ponto de vista do cliente, é a sua agência fazendo tudo isso — porque é exatamente essa a experiência que eles têm.
              </p>
              <a href="/pt-br/relatorios-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver relatórios white-label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Relatórios Automatizados</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Relatórios que provam seu trabalho. Entregues automaticamente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Relatórios mensais são a principal forma que os clientes avaliam o valor da sua agência. O Stacc gera relatórios com seu logo, os envia do seu domínio e os entrega no horário que você configurar — sem nenhuma etapa manual. Cada cliente recebe um relatório profissional com dados reais de posição, atividade no GBP, métricas de avaliação e status de citações. Você recupera o tempo que antes gastava montando esses relatórios.
              </p>
              <a href="/pt-br/relatorios-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver relatórios automatizados
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Relatório SEO Local — Abril 2026</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">Sua Agência</span>
              </div>
              {[
                { metric: 'Posição média no Local Pack', value: '#2,1', change: '▲ +1,3' },
                { metric: 'Posts GBP publicados', value: '30', change: '100%' },
                { metric: 'Avaliações novas (Google)', value: '7', change: '▲ +3' },
                { metric: 'Citações em dia', value: '52/52', change: '✓' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[12px] text-[#374151]">{row.metric}</span>
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-[12px] font-bold text-[#111827]">{row.value}</span>
                    <span class="font-mono text-[10px] text-[#059669]">{row.change}</span>
                  </div>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Entregue automaticamente · relatorios@suaagencia.com.br</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que o SEO local white-label<br />realmente entrega para agências.
          </h2>
        </div>
