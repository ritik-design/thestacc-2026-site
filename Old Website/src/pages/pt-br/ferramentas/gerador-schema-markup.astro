---
import ToolLayout from '../../../components/tools/ToolLayout.astro';

const pageTitle = 'Gerador Gratuito de Schema Markup para Negócios Locais | theStacc';
const pageDescription = 'Gere schema markup LocalBusiness, FAQ e Service em JSON-LD. Pré-preenchido para dentistas, encanadores, advogados. Copie para a área de transferência, valide com o Google. Gratuito.';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Gerador Gratuito de Schema Markup',
  description: 'Gere schema markup LocalBusiness, FAQ e Service em JSON-LD com presets de setor para mais de 23 tipos de negócio. Copie para a área de transferência ou baixe.',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Organization', name: 'theStacc', url: 'https://thestacc.com' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'O que é schema markup?', acceptedAnswer: { '@type': 'Answer', text: 'Schema markup é código de dados estruturados (geralmente JSON-LD) que você adiciona ao seu site para ajudar os mecanismos de busca a entenderem seu conteúdo. Para negócios locais, ele indica ao Google seu nome comercial, endereço, telefone, serviços, horários e avaliações em um formato legível por máquinas. Isso pode resultar em resultados enriquecidos como classificações por estrelas, listas suspensas de FAQ e painéis de empresa nos resultados de busca.' } },
    { '@type': 'Question', name: 'Como adiciono schema markup ao meu site?', acceptedAnswer: { '@type': 'Answer', text: 'Copie o código JSON-LD e cole-o no seu HTML antes da tag de fechamento </head>. No WordPress, use o plugin "Insert Headers and Footers". No Webflow, vá em Configurações da Página > Código Personalizado > Código do Cabeçalho. No Squarespace, vá em Configurações > Avançado > Injeção de Código > Cabeçalho. Em seguida, valide com o Teste de Resultados Enriquecidos do Google.' } },
    { '@type': 'Question', name: 'Preciso de schema markup para SEO local?', acceptedAnswer: { '@type': 'Answer', text: 'Sim. O schema markup ajuda o Google a entender os detalhes do seu negócio e pode melhorar sua visibilidade nos resultados de busca local. Negócios com schema markup correto têm mais probabilidade de aparecer no pacote local, painéis de conhecimento e resultados enriquecidos. É especialmente importante para os tipos de schema LocalBusiness, FAQ e Service.' } },
    { '@type': 'Question', name: 'Quais tipos de schema um negócio local deve usar?', acceptedAnswer: { '@type': 'Answer', text: 'Todo negócio local deve ter schema LocalBusiness (com seu tipo específico como Dentist ou Plumber), schema FAQPage para perguntas comuns, schema Service para cada serviço oferecido e schema BreadcrumbList para navegação. Combiná-los em um único @graph oferece aos mecanismos de busca a imagem mais completa do seu negócio.' } },
    { '@type': 'Question', name: 'Este gerador de schema markup é gratuito?', acceptedAnswer: { '@type': 'Answer', text: 'Sim, 100% gratuito. Sem cadastro necessário. Selecione seu setor para preencher automaticamente os campos, personalize os detalhes do seu negócio e copie o código JSON-LD válido instantaneamente. Tudo é executado no seu navegador. Nenhum dado é enviado a servidores.' } },
  ],
};
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Gerador Gratuito de Schema Markup"
  toolDescription="Gere schema LocalBusiness, FAQ e Service em JSON-LD. Os presets de setor preenchem automaticamente seu tipo de negócio, serviços e sugestões de FAQ. Copie ou baixe."
  wide={true}
  lang="pt-BR"
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <Fragment slot="head">
  </Fragment>

  <!-- ==================== TOOL ==================== -->
  <Fragment slot="tool">
    <div class="flex flex-col lg:flex-row gap-6">
      <!-- LEFT: Form Column -->
      <div class="lg:w-[60%] space-y-6" id="form-column">

        <!-- Section 1: Schema Type Checkboxes -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-3">Tipos de Schema</p>
          <div class="space-y-3">
            <label class="flex items-start gap-3 rounded-xl border-2 border-[#4f39f6] bg-[#f5f3ff] p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-local" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" checked />
              <div class="flex-1">
                <span class="text-[14px] font-semibold text-[#292524]">LocalBusiness</span>
                <p class="text-[12px] text-[#79716b] mt-0.5">Nome, endereço, telefone, horários, avaliações, coordenadas geográficas</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-faq" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <span class="text-[14px] font-semibold text-[#292524]">FAQPage</span>
                <p class="text-[12px] text-[#79716b] mt-0.5">Pares de perguntas e respostas. Aparecem como listas suspensas nos resultados de busca</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-service" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="text-[14px] font-semibold text-[#292524]">Service</span>
                  <span class="rounded-full bg-[#fef3c7] px-2 py-0.5 text-[10px] font-bold uppercase text-[#92400e]">Exclusivo</span>
                </div>
                <p class="text-[12px] text-[#79716b] mt-0.5">Entradas de serviço individuais com informações do provedor. Raramente gerado por outras ferramentas</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-breadcrumb" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <span class="text-[14px] font-semibold text-[#292524]">BreadcrumbList</span>
                <p class="text-[12px] text-[#79716b] mt-0.5">Caminho de navegação. Ajuda o Google a entender a estrutura do site</p>
              </div>
            </label>
          </div>
        </div>

        <!-- Section 2: Industry Selector -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="industry-select">Setor</label>
          <select id="industry-select" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors cursor-pointer">
            <option value="">Selecione seu setor (preenche os campos automaticamente)</option>
            <option value="dentist">Dentista</option>
            <option value="chiropractor">Quiropraxista</option>
            <option value="orthodontist">Ortodontista</option>
            <option value="optometrist">Optometrista</option>
            <option value="dermatologist">Dermatologista</option>
            <option value="plumber">Encanador</option>
            <option value="hvac">HVAC / Climatização</option>
            <option value="electrician">Eletricista</option>
            <option value="roofing">Telhados</option>
            <option value="landscaping">Jardinagem</option>
            <option value="pest_control">Controle de Pragas</option>
            <option value="auto_repair">Oficina Mecânica</option>
            <option value="lawyer">Advogado</option>
            <option value="accountant">Contador</option>
            <option value="realtor">Corretor de Imóveis</option>
            <option value="insurance">Seguradora</option>
            <option value="financial_advisor">Consultor Financeiro</option>
            <option value="restaurant">Restaurante</option>
            <option value="salon">Salão / Spa</option>
            <option value="gym">Academia / Fitness</option>
            <option value="veterinarian">Veterinário</option>
            <option value="cleaning">Serviço de Limpeza</option>
            <option value="moving">Empresa de Mudanças</option>
            <option value="other">Outro / Geral</option>
          </select>
          <p class="mt-1 text-[11px] text-[#79716b]">Define seu tipo de schema e pré-preenche os serviços e sugestões de FAQ.</p>
        </div>

        <!-- Section 3: LocalBusiness Fields -->
        <div id="section-local" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 space-y-4">
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1">Detalhes do Negócio</p>

          <!-- Core Info -->
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-name">Nome do Negócio <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obrigatório</span></label>
            <input type="text" id="f-name" placeholder="ex., Odontologia Família Silva" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-description">Descrição <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
            <textarea id="f-description" rows="2" placeholder="Breve descrição do seu negócio..." class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors resize-none"></textarea>
          </div>

          <!-- Contact -->
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-phone">Telefone <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obrigatório</span></label>
              <input type="tel" id="f-phone" placeholder="(11) 1234-5678" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-email">E-mail <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
              <input type="email" id="f-email" placeholder="info@exemplo.com.br" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-url">URL do Site <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obrigatório</span></label>
            <input type="url" id="f-url" placeholder="https://www.exemplo.com.br" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>

          <!-- Address -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Endereço</p>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-street">Rua e Número <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obrigatório</span></label>
            <input type="text" id="f-street" placeholder="Av. Paulista 1234, Andar 2" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-city">Cidade <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obrigatório</span></label>
              <input type="text" id="f-city" placeholder="São Paulo" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-state">Estado <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
              <input type="text" id="f-state" placeholder="SP" maxlength="2" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-zip">CEP <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
              <input type="text" id="f-zip" placeholder="01310-100" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-country">País <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
            <input type="text" id="f-country" placeholder="BR" value="BR" maxlength="2" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>

          <!-- Media & Rating -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Mídia e Avaliação</p>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-logo">URL do Logo <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
              <input type="url" id="f-logo" placeholder="https://exemplo.com.br/logo.png" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-image">URL da Imagem <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
              <input type="url" id="f-image" placeholder="https://exemplo.com.br/foto.jpg" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-price">Faixa de Preços <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
            <select id="f-price" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors cursor-pointer">
              <option value="">Selecione a faixa de preços...</option>
              <option value="$">$. Econômico</option>
              <option value="$$">$$. Moderado</option>
              <option value="$$$">$$$. Premium</option>
              <option value="$$$$">$$$$. Luxo</option>
            </select>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-rating">Avaliação <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
              <input type="number" id="f-rating" placeholder="4.8" min="1" max="5" step="0.1" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-reviewcount">Número de Avaliações <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
              <input type="number" id="f-reviewcount" placeholder="127" min="0" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>

          <!-- Opening Hours -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Horário de Funcionamento <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></p>
          <div id="hours-container" class="space-y-2"></div>
          <button type="button" id="btn-copy-hours" class="mt-2 cursor-pointer rounded-lg border border-[#e7e5e4] px-3 py-1.5 text-[12px] font-medium text-[#57534e] hover:border-[#c4b5fd] hover:text-[#4f39f6] transition-colors">Copiar horário da segunda-feira para os dias úteis</button>

          <!-- Geo -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Coordenadas Geográficas <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></p>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-lat">Latitude</label>
              <input type="text" id="f-lat" placeholder="-23.5505" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-lng">Longitude</label>
              <input type="text" id="f-lng" placeholder="-46.6333" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>

          <!-- Social Profiles -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Perfis Sociais <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></p>
          <div class="space-y-2" id="social-container">
            <input type="url" class="social-url w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" placeholder="https://facebook.com/seunegocio" />
            <input type="url" class="social-url w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" placeholder="https://instagram.com/seunegocio" />
            <input type="url" class="social-url w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" placeholder="https://linkedin.com/company/seunegocio" />
          </div>
        </div>

        <!-- Section 4: FAQ Fields -->
        <div id="section-faq" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 hidden">
          <div class="flex items-center justify-between mb-4">
            <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Entradas de FAQ</p>
            <button type="button" id="btn-add-faq" class="cursor-pointer rounded-lg bg-[#f5f3ff] px-3 py-1.5 text-[12px] font-semibold text-[#4f39f6] hover:bg-[#ede9fe] transition-colors">+ Adicionar FAQ</button>
          </div>
