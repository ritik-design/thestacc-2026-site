---
import ToolLayout from '../../../components/tools/ToolLayout.astro';

const pageTitle = 'Gerador Gratuito de Publicações para Google Business Profile | theStacc';
const pageDescription = 'Gere publicações prontas para o Google Business Profile em 10 segundos. Escolha seu setor, tipo de publicação e chamada para ação. Grátis, sem cadastro.';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Gerador Gratuito de Publicações para Google Business Profile',
  description: 'Gere atualizações de GBP prontas para publicar para qualquer negócio local. Escolha setor, tipo de publicação e botão de chamada para ação.',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Organization', name: 'theStacc', url: 'https://thestacc.com' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Com que frequência devo publicar no Google Business Profile?', acceptedAnswer: { '@type': 'Answer', text: 'Publique pelo menos uma vez por semana. Os negócios que publicam semanalmente no GBP têm até 2x mais buscas de descoberta. As publicações permanecem visíveis por 6 meses, mas o Google premia a frequência.' } },
    { '@type': 'Question', name: 'Qual tipo de publicação GBP gera mais engajamento?', acceptedAnswer: { '@type': 'Answer', text: 'Publicações de oferta com desconto claro e data de validade geram mais cliques. Dicas educativas e histórias de clientes geram mais visualizações. Sempre inclua um botão de chamada para ação e uma foto real.' } },
    { '@type': 'Question', name: 'As publicações do Google Business Profile ajudam no SEO local?', acceptedAnswer: { '@type': 'Answer', text: 'Sim. As publicações GBP são um sinal de ranqueamento local confirmado. Perfis ativos com publicações regulares, fotos e respostas a avaliações aparecem mais alto no Google Map Pack.' } },
    { '@type': 'Question', name: 'Este gerador de publicações GBP é gratuito?', acceptedAnswer: { '@type': 'Answer', text: 'Sim, 100% gratuito. Sem cadastro ou cartão de crédito. Você recebe 1 publicação instantaneamente. Informe seu e-mail para desbloquear as 3 variações.' } },
  ],
};

const industries = [
  'Dentista / Ortodontia','Jurídico / Escritório de Advocacia','Encanamento / HVAC','Eletricista',
  'Telhados / Construção','Imobiliária','Contabilidade / Impostos','Restaurante / Cafeteria',
  'Salão / Spa / Beleza','Mecânica / Detalhamento Automotivo','Serviços de Limpeza','Jardinagem / Paisagismo',
  'Veterinária / Pets','Quiropraxia / Fisioterapia','TI / Consultoria',
  'Fitness / Academia / Yoga','Fotografia / Videografia','Seguros / Serviços Financeiros',
  'Decoração de Interiores','Tutoria / Educação','Pet Shop / Hospedagem de Pets',
  'Mudanças / Armazenagem','Controle de Pragas',
];
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Gerador Gratuito de Publicações para Google Business Profile"
  toolDescription="Gere 3 atualizações de GBP prontas para publicar com vocabulário específico do setor, palavras-chave locais e a chamada para ação certa. Sem cadastro."
  lang="pt-BR"
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <Fragment slot="head">
  </Fragment>

  <!-- ==================== TOOL ==================== -->
  <Fragment slot="tool">
    <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
      <form id="form" novalidate>
        <!-- Business Name -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="biz">Nome do Negócio <span class="text-red-500">*</span></label>
          <input type="text" id="biz" required maxlength="100" placeholder="ex., Clínica Dental Família Silva" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          <p class="mt-1 hidden text-xs text-red-500" id="err-biz">Por favor, informe o nome do seu negócio</p>
        </div>

        <!-- City -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="city">Cidade / Localização <span class="text-red-500">*</span></label>
          <input type="text" id="city" required maxlength="60" placeholder="ex., São Paulo, SP" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          <p class="mt-1 hidden text-xs text-red-500" id="err-city">Por favor, informe sua cidade ou localização</p>
        </div>

        <!-- Industry -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="ind">Setor <span class="text-red-500">*</span></label>
          <select id="ind" required class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2379716b%22%20stroke-width%3D%222.5%22%3E%3Cpath%20d%3D%22m6%209%206%206%206-6%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_16px_center] bg-no-repeat">
            <option value="" disabled selected>Selecione seu setor</option>
            {industries.map(ind => <option>{ind}</option>)}
            <option value="__other__">Outro (digite o seu)</option>
          </select>
          <p class="mt-1 hidden text-xs text-red-500" id="err-ind">Por favor, selecione seu setor</p>
          <input type="text" id="ind-other" placeholder="ex., Organização de casamentos, Limpeza de piscinas, Estúdio de tatuagem" maxlength="60" class="mt-1.5 hidden w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
        </div>

        <!-- Post Angle -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-2">Tipo de publicação <span class="text-red-500">*</span></label>
          <div class="grid grid-cols-3 gap-2 sm:grid-cols-3">
            {[
              { val: 'tip', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`, label: 'Dica / Guia' },
              { val: 'seasonal', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`, label: 'Sazonal' },
              { val: 'story', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`, label: 'História de cliente' },
              { val: 'offer', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`, label: 'Oferta / Promo' },
              { val: 'bts', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`, label: 'Bastidores' },
              { val: 'faq', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`, label: 'FAQ / Mito' },
            ].map((a, i) => (
              <label class="cursor-pointer">
                <input type="radio" name="angle" value={a.val} checked={i === 0} class="peer sr-only" />
                <span class="flex flex-col items-center gap-1 rounded-[10px] border border-[#e7e5e4] p-3 text-center transition-all peer-checked:border-[#4f39f6] peer-checked:bg-[#f5f3ff]">
                  <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-[#f5f3ff]" set:html={a.icon}></span>
                  <span class="text-[12px] font-semibold text-[#57534e] peer-checked:text-[#4f39f6]">{a.label}</span>
                </span>
              </label>
            ))}
          </div>
        </div>

        <!-- Tone -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-2">Tom</label>
          <div class="flex gap-2">
            {[
              { val: 'professional', label: 'Profissional' },
              { val: 'friendly', label: 'Amigável' },
              { val: 'casual', label: 'Casual' },
            ].map((t, i) => (
              <label class="cursor-pointer">
                <input type="radio" name="tone" value={t.val} checked={i === 0} class="peer sr-only" />
                <span class="inline-block rounded-lg border border-[#e7e5e4] px-4 py-2 text-[13px] font-medium text-[#57534e] transition-all peer-checked:border-[#4f39f6] peer-checked:bg-[#f5f3ff] peer-checked:text-[#4f39f6]">{t.label}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- Offer Fields (conditional) -->
        <div id="offer-f" class="mb-5 hidden rounded-xl border border-dashed border-[#ddd6fe] bg-[#faf5ff]/50 p-4 space-y-4">
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="offer-t">Título da oferta <span class="text-red-500">*</span></label>
            <input type="text" id="offer-t" placeholder="ex., 20% de desconto na revisão de primavera" maxlength="80" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="coupon">Código do cupom</label>
              <input type="text" id="coupon" placeholder="ex., PRIMAVERA20" maxlength="20" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="terms">Condições da oferta</label>
              <input type="text" id="terms" placeholder="ex., Válido até 30 de abril" maxlength="100" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
        </div>

        <!-- Key Message -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="topic">Mensagem principal <span class="font-normal normal-case tracking-normal text-[#79716b]">. Opcional</span></label>
          <textarea id="topic" maxlength="300" rows="2" placeholder="ex., Oferta para novos pacientes, horário de fim de semana, contratamos novo técnico" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors resize-none"></textarea>
          <p class="mt-1 text-right font-mono text-xs text-[#79716b]"><span id="tc">0</span> / 300</p>
          <div id="idea-chips" class="mt-2 hidden flex-wrap gap-1.5"></div>
        </div>

        <!-- No-Hashtag Note -->
        <div class="mb-5 flex items-start gap-2 rounded-lg bg-[#fffbeb] border border-[#fde68a] p-3">
          <span class="mt-0.5 shrink-0"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg></span>
          <p class="text-[13px] text-[#92400e] leading-relaxed"><strong>GBP não é Instagram.</strong> Hashtags não funcionam no Google Business Profile. Geramos publicações limpas, sem hashtags, com palavras-chave locais que realmente ajudam no seu ranqueamento.</p>
        </div>

        <!-- CTA Button -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="cta">Botão de chamada para ação</label>
          <select id="cta" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2379716b%22%20stroke-width%3D%222.5%22%3E%3Cpath%20d%3D%22m6%209%206%206%206-6%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_16px_center] bg-no-repeat">
            <option value="Book">Reservar</option>
            <option value="Order online">Pedir online</option>
            <option value="Learn more" selected>Saiba mais</option>
            <option value="Call now">Ligue agora</option>
            <option value="Sign up">Cadastre-se</option>
            <option value="Get offer">Obter oferta</option>
          </select>
        </div>

        <button type="submit" id="gen-btn" class="w-full cursor-pointer rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3.5 font-mono text-sm font-bold uppercase tracking-wide text-white transition-all hover:bg-[#4f39f6] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
          Gerar 3 variações de publicação
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 hidden">
      <div class="mb-4 flex items-center justify-center gap-1.5 rounded-lg bg-[#fafaf9] border border-[#e7e5e4] px-4 py-2 font-mono text-xs text-[#79716b]">
        Publicações geradas nesta sessão: <strong class="text-[#6d28d9]" id="gen-count">0</strong> &middot; Gere novamente a qualquer momento para resultados diferentes
      </div>

      <!-- Post 1 -->
      <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6 mb-4">
        <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]">Curta &middot; Direta</span>
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs text-[#79716b]" id="st1"></span>
            <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="1">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span>Copiar</span>
            </button>
          </div>
        </div>
        <div class="mt-3 whitespace-pre-wrap font-sans text-[15px] leading-[1.7] text-[#292524]" id="pt1"></div>
        <div id="tr1" class="mt-3 hidden"><hr class="border-t border-dashed border-[#c4b5fd]" /><p class="mt-1 font-mono text-[10px] text-[#8b5cf6]">↑ Visível antes de "Ver mais" no mobile</p></div>
        <div id="hs1" class="mt-2 inline-flex items-center gap-1 rounded-md px-2.5 py-1 font-mono text-[11px] font-semibold"></div>
        <div id="tip1" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
      </div>

      <!-- Email Gate -->
      <div id="gate" class="mb-4 rounded-2xl border border-[#e7e5e4] bg-gradient-to-b from-[#fafaf9] to-white p-6 text-center">
        <p class="font-sans text-[17px] font-semibold text-[#292524]">Desbloqueie mais 2 variações</p>
        <p class="mt-1 font-sans text-sm text-[#79716b]">Receba as versões média e detalhada. Mais um calendário de publicações GBP de 30 dias.</p>
        <div class="mt-4 flex gap-2 max-w-[400px] mx-auto">
          <input type="email" id="gate-em" placeholder="seu@empresa.com" class="flex-1 rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          <button id="unlock-btn" class="cursor-pointer rounded-lg bg-[#615fff] px-5 py-2.5 font-mono text-sm font-semibold uppercase text-white whitespace-nowrap hover:bg-[#4f39f6] transition-colors">Desbloquear</button>
        </div>
        <p id="gate-err" class="mt-1.5 hidden text-xs text-red-500">Por favor, informe um e-mail válido</p>
        <p class="mt-2 text-[11px] text-[#79716b]">Sem spam. Cancele a qualquer momento.</p>
      </div>

      <!-- Gated Posts 2 & 3 -->
      <div id="gated" class="hidden space-y-4">
        <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6">
          <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]">Média &middot; Detalhada</span>
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-[#79716b]" id="st2"></span>
              <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="2"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg><span>Copiar</span></button>
            </div>
          </div>
          <div class="mt-3 whitespace-pre-wrap font-sans text-[15px] leading-[1.7] text-[#292524]" id="pt2"></div>
          <div id="tip2" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
        </div>
        <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6">
          <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]">Longa &middot; Narrativa</span>
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-[#79716b]" id="st3"></span>
              <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="3"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg><span>Copiar</span></button>
            </div>
          </div>
          <div class="mt-3 whitespace-pre-wrap font-sans text-[15px] leading-[1.7] text-[#292524]" id="pt3"></div>
          <div id="tip3" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
        </div>
      </div>

      <!-- GBP Preview -->
      <div class="mt-6">
