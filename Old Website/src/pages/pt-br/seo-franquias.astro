---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que é SEO para franquias?", a: "SEO para franquias é a prática de otimizar a visibilidade em busca local para negócios de franquia em múltiplas localizações. Cada unidade da franquia precisa ter seu próprio Google Business Profile gerenciado, suas próprias citações locais mantidas e seus próprios posicionamentos de palavras-chave rastreados — enquanto a consistência da marca é preservada em toda a rede." },
  { q: "Qual é o maior desafio de SEO exclusivo para franquias?", a: "Consistência em escala. Cada localização precisa do mesmo trabalho de SEO básico feito corretamente — citações precisas, GBP ativo, perfis de avaliações robustos. Mas com 50 ou 500 localizações, isso não pode ser feito manualmente. As localizações que recebem atenção se posicionam. As que não recebem, não. A automação é a única forma de aplicar esforço de SEO consistente em toda a sua rede." },
  { q: "Como o Stacc lida com a dinâmica entre franqueador e franqueado?", a: "O Stacc suporta acesso em camadas. Franqueadores têm uma visão do portfólio de todas as localizações com comparação de desempenho. Franqueados podem acessar o painel da própria localização. Gestão centralizada e visibilidade individual podem coexistir na mesma plataforma." },
  { q: "O Stacc consegue gerenciar o GBP de 200 localizações de franquia?", a: "Sim. O Stacc publica posts no GBP para todas as localizações simultaneamente. Atualizações em lote de horários, descrições e atributos se aplicam a todas as localizações em uma única ação. Não há limite prático de contagem de localizações." },
  { q: "Como manter a consistência da marca nos posts do GBP em todas as localizações?", a: "A publicação em lote do Stacc permite escrever um post e publicá-lo em todas as localizações simultaneamente. Você pode adicionar personalizações por localização (endereço, telefone local, hashtags locais) antes de publicar em lote. A mensagem central da marca permanece consistente; os detalhes locais são localizados." },
  { q: "Com que rapidez posso incorporar uma nova unidade de franquia?", a: "Cerca de 2 minutos. Insira os dados básicos do negócio, conecte a listagem do GBP e o Stacc propaga a configuração pela sua rede de citações automaticamente. Sem entrada manual diretório por diretório." },
  { q: "Quanto custa o software de SEO para franquias?", a: "O módulo de SEO Local do Stacc começa a partir de $49/mês e inclui todos os recursos de gerenciamento de múltiplas localizações e franquias." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO para Franquias", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Automação de SEO para franquias que gerencia GBP, citações, posicionamentos e relatórios em todas as unidades da franquia simultaneamente.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "SEO para Franquias", "item": "https://thestacc.com/pt-br/seo-franquias/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="SEO para Franquias — Gerencie Todas as Unidades em Um Painel | theStacc"
  description="SEO para franquias em escala requer automação. O theStacc gerencia GBP, citações, rastreamento de posições e relatórios para cada unidade da franquia simultaneamente — marca consistente, desempenho local."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Franquias · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO para franquias que roda<br />
            <span style="color:#4f39f6;">em toda a sua rede.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Cada unidade da franquia precisa de trabalho diário consistente de SEO local para se posicionar no seu mercado. O Stacc automatiza esse trabalho em toda a sua rede — para que cada localização compita com plena força, não apenas as que alguém lembrou de atualizar.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/solutions/franchises/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funcionalidades para franquias
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · 30 dias de garantia · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLEM SECTION -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema do SEO para franquias</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Algumas localizações se posicionam. A maioria não.<br />Porque a maioria não recebe SEO consistente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Em toda rede de franquias, existe um padrão familiar: um punhado de localizações de alto desempenho que se posicionam de forma consistente, e uma longa cauda de baixo desempenho invisível na busca local. A diferença quase nunca é qualidade do serviço — é qualidade da execução de SEO local. As localizações que se posicionam têm perfis de GBP ativos, citações consistentes e avaliações recentes. As invisíveis têm listagens desatualizadas, inconsistências de NAP e perfis que não são atualizados há meses.</p>
            <p>A razão não é descuido — é capacidade. Não há como manter manualmente o SEO local adequado em 50 ou 500 localizações. Algo sempre fica de fora. O Stacc garante que nada fique de fora, automatizando cada tarefa de SEO contínua para cada localização automaticamente.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de SEO para franquias</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada localização. Cada tarefa.<br />Tudo automatizado.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Gerenciamento de GBP em lote', body: 'Publique posts em todas as unidades da franquia simultaneamente. Atualize horários, descrições e atributos em toda a rede em uma única ação.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreamento de posições por localização', body: 'Posições diárias para cada unidade no pacote local, Maps e orgânico. Compare todas as localizações lado a lado para identificar quais mercados precisam de atenção.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoramento de consistência de citações', body: 'Detecte e sinalize inconsistências de NAP em mais de 50 diretórios para cada localização. Citações consistentes são um fator central de posicionamento local.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitoramento de avaliações por localização', body: 'Alertas de avaliações em tempo real para cada unidade da franquia. Responda de um painel central. Acompanhe o desempenho de avaliações por localização.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Relatórios de desempenho da rede', body: 'O painel de portfólio compara todas as localizações. Identifique os melhores e piores imediatamente. Gere relatórios automatizados para toda a rede ou localizações individuais.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Acesso em camadas para franqueados', body: 'Franqueadores veem toda a rede. Franqueados veem suas próprias localizações. Gestão centralizada com responsabilidade individual.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">SEO para franquias em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o Stacc está fazendo<br />em cada unidade da sua rede.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Posts localizados por unidade</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Cada unidade rankeando com força total.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O Stacc automatiza a publicação de posts no GBP para cada unidade da franquia com palavras-chave específicas da cidade. Em vez de conteúdo genérico para toda a rede, cada localização recebe 30 posts mensais segmentando as combinações serviço + cidade do seu mercado local — "encanador em Curitiba", "clínica odontológica em Campinas" — publicados automaticamente, todos os dias, sem que a equipe central precise tocar.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de posts GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posts GBP da franquia — hoje</p>
              {[
                { unit: 'Unidade de São Paulo — SP', post: 'Melhor serviço de encanamento em São Paulo', ok: true },
                { unit: 'Unidade de Curitiba — PR', post: 'Encanador rápido e confiável em Curitiba', ok: true },
                { unit: 'Unidade de Campinas — SP', post: 'Serviço de encanamento 24h em Campinas', ok: true },
              ].map(item => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.unit}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{item.post}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓ Publicado</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 posts/mês por unidade · Palavras-chave localizadas</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posicionamento no Maps — portfólio de franquias</p>
              {[
                { unit: 'SP — São Paulo', kw: 'encanador são paulo', pos: '#2', trend: '↑' },
                { unit: 'PR — Curitiba', kw: 'encanador curitiba', pos: '#1', trend: '↑' },
                { unit: 'SP — Campinas', kw: 'encanador campinas', pos: '#4', trend: '↑' },
                { unit: 'RJ — Rio de Janeiro', kw: 'encanador rio de janeiro', pos: '#3', trend: '→' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{row.unit}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{row.kw}</p>
                  </div>
                  <span class="font-mono text-[13px] font-bold text-[#4f39f6]">{row.pos} <span class="text-[#059669]">{row.trend}</span></span>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Painel centralizado de portfólio</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Visão de portfólio em tempo real.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O painel central do Stacc mostra o posicionamento de todas as unidades da franquia lado a lado. Veja quais mercados estão performando, quais precisam de atenção e onde há oportunidades de crescimento — tudo em uma única tela, atualizado diariamente. Sem exportar planilhas. Sem verificar cada GBP individualmente. Uma visão clara de toda a rede.
              </p>
              <a href="/solutions/franchises/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver painel de portfólio
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Relatórios automatizados</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Relatórios automáticos por unidade.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                No início de cada mês, o Stacc gera e entrega automaticamente relatórios de desempenho para cada unidade da franquia. Franqueadores recebem a visão consolidada da rede. Franqueados recebem os dados da própria unidade. Sem trabalho manual. Sem formatação. Sem envio. O sistema cuida de tudo — com a sua marca, no horário agendado.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de relatórios
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Entrega de relatórios — este mês</p>
              {[
                { unit: 'Unidade São Paulo', time: '1 Abr, 9h00', status: 'Entregue' },
                { unit: 'Unidade Curitiba', time: '1 Abr, 9h00', status: 'Entregue' },
                { unit: 'Unidade Campinas', time: '1 Abr, 9h00', status: 'Entregue' },
                { unit: 'Unidade Rio de Janeiro', time: '1 Abr, 9h00', status: 'Entregue' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.unit}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.time}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Zero trabalho manual · Todas as unidades cobertas</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que o SEO automatizado para<br />franquias realmente entrega.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
