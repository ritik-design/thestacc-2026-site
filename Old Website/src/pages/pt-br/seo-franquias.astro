  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });

    document.querySelectorAll('[data-count-up]').forEach((el) => {
      const target = parseFloat((el as HTMLElement).dataset.target || '0');
      const from = parseFloat((el as HTMLElement).dataset.from || '0');
      const prefix = (el as HTMLElement).dataset.prefix || '';
      const suffix = (el as HTMLElement).dataset.suffix || '';
      const decimals = parseInt((el as HTMLElement).dataset.decimals || '0');
      const duration = 1800;
      let start: number | null = null;
      const obs = new IntersectionObserver(entries => {
        if (!entries[0].isIntersecting) return;
        obs.disconnect();
        const step = (ts: number) => {
          if (!start) start = ts;
          const p = Math.min((ts - start) / duration, 1);
          const val = from + (target - from) * (1 - Math.pow(1 - p, 3));
          (el as HTMLElement).textContent = prefix + val.toFixed(decimals) + suffix;
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }, { threshold: 0.3 });
      obs.observe(el as HTMLElement);
    });
  </script>
