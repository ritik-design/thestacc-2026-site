---
import LegalLayout from '../../layouts/LegalLayout.astro';

const toc = [
  { id: 'what',     label: '1. O que São Cookies' },
  { id: 'types',    label: '2. Tipos de Cookies que Usamos' },
  { id: 'managing', label: '3. Gerenciar Cookies' },
  { id: 'contact',  label: '4. Contato' },
];
---

<LegalLayout
  title="Política de Cookies"
  description="Como o theStacc usa cookies e como você pode gerenciar suas preferências. Entenda nossa política de cookies e seus controles de privacidade."
  lastUpdated="Abril 2026"
  badge="Jurídico · Cookies"
  tocItems={toc}
  currentPath="/pt-br/cookies/"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebPage",
        "name": "Política de Cookies | theStacc",
        "url": "https://thestacc.com/pt-br/cookies/",
        "inLanguage": "pt-BR",
        "description": "Como o theStacc usa cookies e como você pode gerenciar suas preferências."
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
          { "@type": "ListItem", "position": 2, "name": "Política de Cookies", "item": "https://thestacc.com/pt-br/cookies/" }
        ]
      }
    ]
  })} />

  <div class="flex flex-col gap-10">

    <section id="what" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">O que São Cookies</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Cookies são pequenos arquivos de texto colocados no seu dispositivo quando você visita um site. Eles são amplamente utilizados para fazer os sites funcionarem de forma mais eficiente, bem como para fornecer informações aos proprietários dos sites. Usamos cookies para aprimorar sua experiência no theStacc e para entender como nossos serviços são utilizados.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="types" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Tipos de Cookies que Usamos</h2>
      </div>
      <div class="pl-9 flex flex-col gap-6">
        {[
          {
            title: 'Cookies Necessários',
            body: 'Esses cookies são essenciais para o funcionamento adequado do site. Eles habilitam funcionalidades básicas como segurança, gerenciamento de rede e acesso à conta. O site não pode funcionar corretamente sem esses cookies e eles não podem ser desativados.',
          },
          {
            title: 'Cookies de Análise',
            body: 'Esses cookies nos ajudam a entender como os visitantes interagem com nosso site, coletando e reportando informações de forma anônima. Eles nos ajudam a melhorar o funcionamento do nosso site, por exemplo, garantindo que os usuários encontrem facilmente o que procuram.',
          },
          {
            title: 'Cookies de Marketing',
            body: 'Esses cookies são usados para rastrear visitantes em sites e exibir anúncios relevantes com base em seus interesses. Eles são definidos por nossos parceiros de publicidade e podem ser usados para construir um perfil de seus interesses.',
          },
        ].map(item => (
          <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-5 py-4">
            <p class="font-sans text-[14px] font-semibold text-[#111827] mb-2">{item.title}</p>
            <p class="font-sans text-[14px] leading-[1.7] text-[#57534e]">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="managing" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Gerenciar Cookies</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Você pode controlar e gerenciar cookies de várias formas. A maioria dos navegadores permite recusar cookies ou excluir cookies já definidos. Observe que desativar cookies pode afetar a funcionalidade do theStacc. Para optar por não receber rastreamento analítico, você também pode usar extensões de navegador como uBlock Origin ou ferramentas similares.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="contact" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Contato</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Se tiver dúvidas sobre o uso de cookies, entre em contato conosco em <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
        </p>
        <div class="mt-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-4">
          <p class="font-sans text-[13px] font-semibold text-[#111827] mb-1">Razão Social</p>
          <p class="font-sans text-[13px] leading-[1.65] text-[#79716b] mb-3">SOLARTREK VENTURES LLP</p>
          <p class="font-sans text-[13px] font-semibold text-[#111827] mb-1">Endereço</p>
          <p class="font-sans text-[13px] leading-[1.65] text-[#79716b]">Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India</p>
        </div>
      </div>
    </section>

  </div>
</LegalLayout>
