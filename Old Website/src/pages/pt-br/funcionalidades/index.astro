---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const features = [
  {
    slug: 'rastreamento-de-posicoes',
    title: 'Rastreamento de Posições',
    description: 'Atualizações diárias de posições para todas as suas palavras-chave. Veja exatamente onde você está ranqueando e como você progride ao longo do tempo.',
    icon: 'M22 7L13.5 15.5 8.5 10.5 2 17',
  },
  {
    slug: 'pesquisa-de-palavras-chave',
    title: 'Pesquisa de Palavras-chave',
    description: 'Encontre lacunas que seus concorrentes estão perdendo. Classificadas por potencial de tráfego e dificuldade.',
    icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  },
  {
    slug: 'gestao-de-citacoes',
    title: 'Gestão de Citações',
    description: 'Envios em 50+ diretórios para melhorar sua visibilidade local e consistência de NAP.',
    icon: 'M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71',
  },
  {
    slug: 'monitoramento-de-avaliacoes',
    title: 'Monitoramento de Avaliações',
    description: 'Alertas instantâneos e respostas automáticas de IA para manter sua reputação impecável.',
    icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
  },
  {
    slug: 'agendamento-social',
    title: 'Agendamento Social',
    description: 'Publicação automática em todas as plataformas. Conteúdo otimizado por SEO, agendado e publicado sem esforço.',
    icon: 'M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01',
  },
  {
    slug: 'relatorios-de-clientes',
    title: 'Relatórios para Clientes',
    description: 'Relatórios em PDF e CSV com sua marca. Impressione clientes com dados claros e apresentações profissionais.',
    icon: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z',
  },
  {
    slug: 'relatorios-multi-localizacao',
    title: 'Relatórios Multi-Localização',
    description: 'Visão de portfólio para todas as suas localizações em um único painel centralizado.',
    icon: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  },
  {
    slug: 'gestao-de-multiplas-localizacoes',
    title: 'Gestão de Múltiplas Localizações',
    description: 'Atualize 500+ localizações de uma vez. Gestão em escala sem o trabalho manual.',
    icon: 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z',
  },
  {
    slug: 'painel-marca-branca',
    title: 'Painel Marca Branca',
    description: 'Sua marca, sem logotipo do Stacc. Perfeito para agências que entregam SEO com sua identidade visual.',
    icon: 'M3 3h18v18H3zM3 9h18M9 21V9',
  },
];
---

<BaseLayout
  title="Funcionalidades — Plataforma Completa de SEO Local | theStacc"
  description="Todas as funcionalidades do theStacc: rastreamento de posições, gestão de citações, monitoramento de avaliações, agendamento social, relatórios e muito mais."
  lang="pt-BR"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-10 pb-12">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Funcionalidades</p>
        <h1 class="mt-3 max-w-[620px] font-sans text-[28px] font-bold leading-[1.15] tracking-[-0.025em] text-[#292524] md:text-[40px]">
          Tudo que você precisa para dominar o SEO local
        </h1>
        <p class="mt-3 max-w-[500px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          Uma plataforma completa de SEO local com automação de conteúdo, gestão de avaliações, rastreamento de posições e muito mais.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/pt-br/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#615fff]">
            Começar por R$1
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/pt-br/precos/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] px-6 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-[#292524] transition-colors hover:bg-[#f5f3ff]">
            Ver preços
          </a>
        </div>
      </div>
    </section>

    <!-- ░░ FEATURES GRID ░░ -->
    <section class="bg-[#fafaf9] px-6 py-12">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {features.map(feature => (
            <a
              href={`/pt-br/funcionalidades/${feature.slug}/`}
              class="group flex flex-col rounded-xl border border-[#e7e5e4] bg-white p-6 transition-all hover:border-[#c4b5fd] hover:shadow-sm"
            >
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#f5f3ff] transition-colors group-hover:bg-[#ede9fe]">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d={feature.icon} />
                </svg>
              </div>
              <h3 class="mt-4 font-sans text-[16px] font-semibold text-[#292524] transition-colors group-hover:text-[#4f39f6]">{feature.title}</h3>
              <p class="mt-2 flex-1 font-sans text-[14px] leading-[1.6] text-[#57534e]">{feature.description}</p>
              <span class="mt-4 font-mono text-[11px] font-semibold text-[#4f39f6]">Saiba mais →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Comece hoje com todas as funcionalidades incluídas
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          30 artigos de blog, 30 posts no GMN e conteúdo para redes sociais. Publicados automaticamente todo mês.
        </p>
        <a
          href="/pt-br/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Começar por R$1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">R$1 por 30 dias · Cancele quando quiser</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
