---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "O que exatamente é personalizado com a marca branca?",
    a: "Tudo o que o cliente vê: a URL do painel (seu domínio), o logotipo, o nome da sua agência, os PDFs de relatórios, os e-mails de relatórios automáticos e as notificações que o cliente recebe. O nome do Stacc e sua marca não aparecem em nenhum lugar da experiência do cliente.",
  },
  {
    q: "Cada cliente pode ter seu próprio acesso?",
    a: "Sim. Você cria acessos individuais de cliente com escopo para suas localizações específicas. Cada cliente vê apenas seus próprios dados — nunca os dos seus outros clientes. Você mantém acesso de administrador completo a todos os clientes pela sua conta de agência.",
  },
  {
    q: "Quanto tempo leva para configurar a marca branca?",
    a: "Aproximadamente 2 horas. Você sobe seu logotipo, configura o nome da sua agência e o domínio (registro CNAME), define seu esquema de cores e pronto. Não é necessário trabalho de desenvolvedor — tudo se configura pelo painel.",
  },
  {
    q: "É preciso pagar por cada acesso de cliente?",
    a: "Não. Os acessos de cliente estão incluídos a $0 por cliente independentemente de quantos clientes você adicionar. Seu custo se baseia no número de localizações gerenciadas — não no número de acessos de cliente. Você pode dar a cada cliente seu próprio acesso sem afetar sua fatura.",
  },
  {
    q: "Posso usar um domínio personalizado para os painéis de clientes?",
    a: "Sim. Aponte um subdomínio (por exemplo, seo.suaagencia.com.br) ao Stacc por meio de um registro CNAME e todos os painéis de cliente carregam no seu domínio. Os clientes nunca veem thestacc.com na URL.",
  },
  {
    q: "Os relatórios com marca branca podem ser enviados automaticamente aos clientes?",
    a: "Sim. Configure a entrega automática de relatórios para cada cliente — semanal ou mensal. Os relatórios são gerados com sua marca e enviados do seu domínio automaticamente. Você pode revisar os relatórios antes que saiam ou deixar que sejam enviados em piloto automático completo.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Painel de Marca Branca para Agências",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "Entregue resultados de SEO local sob a marca da sua agência. Painéis, relatórios e acessos de cliente com marca branca — seu logotipo, seu domínio, sua marca em tudo o que os clientes veem.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Funcionalidades", "item": "https://thestacc.com/pt-br/funcionalidades/" },
        { "@type": "ListItem", "position": 3, "name": "Painel de Marca Branca", "item": "https://thestacc.com/pt-br/funcionalidades/painel-marca-branca/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Painel SEO com Marca Branca para Agências — Sua Marca em Tudo que os Clientes Veem | theStacc"
  description="Ofereça aos clientes um painel de SEO local com seu logotipo e domínio. Painéis, relatórios e acessos de cliente com marca branca — nenhuma referência ao Stacc visível."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Painel de Marca Branca · Para Agências</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Seus clientes veem sua marca.<br />
            <span style="color:#4f39f6;">Não a nossa.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Tudo o que seus clientes veem traz seu logotipo, seu domínio e suas cores. O painel SEO, os relatórios, os e-mails automáticos, os acessos de cliente — tudo sob sua marca. O Stacc é a infraestrutura. Você é a agência.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Configure sua marca branca
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/precos/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver preços
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mês · Configuração em 2 horas · Sem mencionar o Stacc
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '2hrs', label: 'Configuração completa de marca branca' },
              { value: '$0', label: 'Custo adicional por acesso de cliente' },
              { value: '100%', label: 'Marca branca — sem rastro do Stacc' },
              { value: 'CNAME', label: 'Domínio personalizado para painéis' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Quando o cliente vê o nome da ferramenta,<br />você deixa de ser o especialista.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Você trabalha semanas para construir uma relação de confiança com um cliente. Você é o especialista em SEO local. Você é quem sabe o que funciona. E então o cliente abre o relatório, vê o logo de outra plataforma no cabeçalho, pesquisa o nome no Google, e começa a se perguntar se poderia contratar diretamente. A marca branca não é um luxo — é proteção da relação que você construiu.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              title: 'O cliente vê a ferramenta, não o seu valor.',
              body: 'Quando o relatório traz o logo do Stacc, o cliente pode pensar "por que pago à agência se a ferramenta faz todo o trabalho?". A marca branca mantém o foco nos seus resultados e na sua estratégia — não na infraestrutura que você usa para entregá-los.',
            },
            {
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
              title: 'Os clientes que conhecem a ferramenta podem buscá-la diretamente.',
              body: 'Uma vez que o cliente sabe que você usa o Stacc, pode explorar se pode contratá-lo diretamente sem intermediário. A marca branca elimina esse risco — o cliente só vê sua agência como a fonte dos resultados.',
            },
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'Relatórios genéricos não reforçam seu posicionamento.',
              body: 'Um relatório que traz sua marca, com suas cores e seu estilo visual, reforça a percepção de profissionalidade e consistência. Um relatório genérico de ferramenta não diz nada sobre quem você é. Cada ponto de contato com o cliente é uma oportunidade de se posicionar — ou de desperdiçá-la.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tudo incluído</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Marca branca completa em cada<br />ponto de contato com o cliente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Domínio Personalizado', body: 'Aponte um subdomínio (seo.suaagencia.com.br) ao Stacc por CNAME. Os painéis de cliente carregam na sua URL — thestacc.com nunca aparece no navegador do cliente.', icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9' },
            { title: 'Logotipo e Cores', body: 'Suba seu logotipo e defina sua paleta de cores corporativas uma vez. Aplicam-se automaticamente a painéis, relatórios PDF e e-mails de entrega.', icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01' },
            { title: 'Relatórios PDF com Marca', body: 'Cada relatório gerado traz seu logotipo, cabeçalho e rodapé personalizados. O cliente recebe um documento profissional que reforça sua marca em cada página.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
            { title: 'E-mails de Relatório Personalizados', body: 'Os e-mails de entrega de relatórios são enviados do seu domínio com sua assinatura. O cliente recebe o e-mail como se você tivesse enviado — não um e-mail automático de plataforma.', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
            { title: 'Acessos de Cliente Incluídos', body: 'Crie acessos de cliente ilimitados sem custo adicional. Cada cliente vê apenas seus dados. Você mantém acesso de administrador completo a todos pela sua conta.', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
            { title: 'Configuração em 2 Horas', body: 'Sem desenvolvedor. Sem código. Todo o setup de marca branca — domínio, logo, cores, configuração de e-mail — é feito pelo painel de administração em menos de 2 horas.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que sua agência ganha quando<br />tudo traz sua marca.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '2hrs', label: 'Setup completo de marca branca', sub: 'sem programador, sem código' },
            { value: '$0', label: 'Custo por acesso de cliente', sub: 'ilimitados sem afetar sua fatura' },
            { value: '100%', label: 'Experiência do cliente sob sua marca', sub: 'painel, relatórios, e-mails, URL' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Meus clientes acessam 'seo.minhaagencia.com.br', veem meu logotipo, recebem relatórios em PDF com meu cabeçalho e recebem os e-mails do meu domínio. Para eles, tudo é minha plataforma. Isso me posiciona como agência tecnológica mesmo sendo uma operação de duas pessoas — e me diferencia dos freelancers que entregam capturas de tela de ferramentas genéricas."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">IS</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Irene S.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Consultora SEO Local · 18 clientes, operação individual</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">100% marca de agência</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perguntas frequentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perguntas sobre o painel de marca branca
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Sua tecnologia. Sua marca.</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Entregue SEO local de nível enterprise<br />com o nome da sua agência em tudo.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            O Stacc te dá a infraestrutura tecnológica que você precisa para competir com agências muito maiores — e a marca branca garante que todo o valor percebido vai para a sua agência. Configure em 2 horas. Comece seu teste gratuito hoje.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Configure sua marca branca
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
