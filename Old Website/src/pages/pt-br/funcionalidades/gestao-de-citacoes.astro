---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "O que são citações e por que são importantes para o SEO local?",
    a: "Citações são qualquer menção online do nome, endereço e telefone (NAP) do seu negócio. O Google usa as citações como sinal de confiança — dados NAP consistentes em diretórios de autoridade confirmam que você é um negócio local real e estável. Citações inconsistentes (endereço errado, telefones diferentes, nomes de empresa distintos) diluem essa confiança e afetam diretamente sua posição no pacote local.",
  },
  {
    q: "Por que a consistência do NAP é tão importante?",
    a: "Se seu endereço aparece como 'Rua Principal 123' no Google, 'R. Principal, 123, Ap. 1' no Yelp e 'Principal 123' no Apple Maps, o Google pode estar vendo três negócios potencialmente diferentes. Essa fragmentação enfraquece sua autoridade local. O Stacc audita cada citação contra seus dados NAP principais e sinaliza ou corrige automaticamente as discrepâncias em 50+ diretórios.",
  },
  {
    q: "Com quais diretórios o Stacc sincroniza as citações?",
    a: "O Stacc sincroniza com 50+ diretórios, incluindo Google Business Profile, Apple Maps, Bing Places, Yelp, Facebook, Foursquare, TripAdvisor, Páginas Amarelas e dezenas de diretórios setoriais e regionais. A lista completa de diretórios está disponível no seu painel.",
  },
  {
    q: "Quanto tempo leva para ver resultados das correções de citações?",
    a: "A maioria dos diretórios aceita atualizações em 1-5 dias úteis. O Google normalmente reflete mudanças de citações em 2-4 semanas. As melhorias de ranking derivadas de citações corrigidas costumam aparecer na sua posição no pacote local em 4-8 semanas, pois o Google precisa de tempo para rastrear, reconciliar e reavaliar sua pontuação de consistência NAP.",
  },
  {
    q: "O Stacc gerencia a remoção de listagens duplicadas?",
    a: "Sim. A auditoria de citações detecta automaticamente listagens duplicadas — o mesmo negócio, mesma localização aparecendo várias vezes no mesmo diretório. Os duplicados confundem o Google e dividem sua autoridade de citações. O Stacc os sinaliza para remoção e, onde a API do diretório permite, gerencia a supressão automaticamente.",
  },
  {
    q: "Posso gerenciar citações para vários locais?",
    a: "Sim, e aqui é onde o Stacc economiza mais tempo. Cada local tem seu próprio conjunto de dados NAP. Quando você atualiza horários, muda de endereço ou modifica um telefone, atualiza no Stacc uma vez — e isso se propaga para 50+ diretórios para aquela localização automaticamente. Sem atualizações manuais diretório por diretório.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Gestão de Citações",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "Citações inconsistentes prejudicam seu posicionamento local. O theStacc audita, corrige e constrói citações em 50+ diretórios automaticamente para que seus dados NAP estejam sempre atualizados em todos os lugares.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Funcionalidades", "item": "https://thestacc.com/pt-br/funcionalidades/" },
        { "@type": "ListItem", "position": 3, "name": "Gestão de Citações", "item": "https://thestacc.com/pt-br/funcionalidades/gestao-de-citacoes/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Gestão de Citações SEO — Corrija e Sincronize seu NAP em 50+ Diretórios | theStacc"
  description="Citações inconsistentes prejudicam seu posicionamento local. O theStacc audita, corrige e constrói citações em 50+ diretórios automaticamente — seus dados sempre corretos em todos os lugares."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Gestão de Citações · Módulo SEO Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Seu negócio aparece diferente<br />em cada diretório.
            <span style="color:#4f39f6;"> O Google percebe.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc audita seus dados NAP em 50+ diretórios, corrige inconsistências, elimina duplicados e constrói novas citações automaticamente. Uma atualização no Stacc. Todos os diretórios sincronizados.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Audite suas citações grátis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/precos/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver preços
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mês · Teste gratuito 14 dias · Sem cartão de crédito
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '50+', label: 'Diretórios auditados e sincronizados' },
              { value: '1 clique', label: 'Para atualizar todos os diretórios de uma vez' },
              { value: '4-8 sem.', label: 'Para ver melhorias de ranking típicas' },
              { value: '4.9★', label: 'Avaliação média do Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada diretório diz algo diferente<br />sobre seu negócio. Isso tem um custo.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Seu endereço atual está correto no Google. Mas no Yelp aparece o endereço antigo. No Apple Maps está um número de telefone diferente. Nas Páginas Amarelas, o nome do negócio tem um hífen que você não usa mais. Nenhum desses erros parece grave isoladamente. Mas juntos enviam ao Google um sinal de incerteza sobre quem você é e onde está — e esse sinal se traduz em posição mais baixa no pacote local.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'A inconsistência do NAP dilui sua autoridade local.',
              body: 'O Google reconcilia suas informações em centenas de fontes. Quando o mesmo endereço aparece com formatos diferentes em 15 diretórios distintos, o algoritmo local perde confiança no seu dado. Essa perda de confiança se traduz diretamente em posições mais baixas no Maps.',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Atualizar diretórios manualmente é um trabalho de tempo integral.',
              body: 'Você muda de endereço. Ou de telefone. Ou de nome de negócio. Agora precisa entrar em 50+ diretórios, um por um, e atualizar o dado. Alguns exigem verificação. Outros, reclamação do perfil. Nenhum tem o mesmo processo. São entre 8 e 20 horas de trabalho manual por mudança.',
            },
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Os duplicados dividem sua autoridade entre duas fichas.',
              body: 'Você aparece duas vezes no mesmo diretório — uma ficha ativa e uma antiga que ninguém reivindicou. Cada ficha recebe parte da autoridade que deveria ser toda sua. Os duplicados também confundem o Google sobre qual é a localização real, o que freia sua capacidade de posicionar no pacote de mapas.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Atualize uma vez no Stacc.<br />Todos os diretórios se sincronizam sozinhos.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Defina seus dados NAP principais', body: 'Você insere suas informações oficiais: nome exato, endereço completo, telefone principal, site e categorias de negócio. Esses são seus dados principais — tudo que o Stacc sincroniza nos 50+ diretórios parte daqui.' },
            { n: '02', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', title: 'Auditoria automática das citações existentes', body: 'O Stacc rastreia seu negócio em 50+ diretórios e compara cada listagem com seus dados principais. As inconsistências, dados ausentes e duplicados são sinalizados em uma fila de correções priorizados por impacto.' },
            { n: '03', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Correção automática e sincronização contínua', body: 'O Stacc envia correções para cada diretório automaticamente — sem formulários manuais nem verificações individuais. Quando você altera qualquer dado no Stacc, a atualização se propaga para todos os diretórios em questão de dias.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tudo incluído</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Gestão completa de citações<br />sem atualizações manuais.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Auditoria de 50+ Diretórios', body: 'Verificação automática do seu NAP em todos os principais diretórios — Google, Apple Maps, Yelp, Bing, Facebook, TripAdvisor, Páginas Amarelas e muito mais.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
            { title: 'Correção Automática de NAP', body: 'As inconsistências detectadas são corrigidas automaticamente em cada diretório. Sem formulários, sem processos de verificação manuais, sem trabalho diretório por diretório.', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
            { title: 'Remoção de Duplicados', body: 'Listagens duplicadas detectadas e marcadas para supressão. Onde a API do diretório permite, a remoção é gerenciada automaticamente sem intervenção manual.', icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16' },
            { title: 'Construção de Novas Citações', body: 'Identifica diretórios relevantes onde seu negócio ainda não está listado e constrói novas citações automaticamente para ampliar sua presença de autoridade local.', icon: 'M12 4v16m8-8H4' },
            { title: 'Saúde de Citações por Localização', body: 'Pontuação de saúde de citações para cada localização. Veja de relance quais unidades têm NAP limpo e quais precisam de atenção — com detalhamento por diretório.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Sincronização Multi-Localização', body: 'Atualize os dados NAP de qualquer localização uma vez no Stacc. A sincronização se propaga para todos os diretórios para aquela unidade automaticamente — sem duplicar o trabalho por unidade.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que acontece quando seu NAP<br />é consistente em todos os lugares.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '50+', label: 'Diretórios sincronizados', sub: 'com uma única atualização no Stacc' },
            { value: '4-8 sem.', label: 'Para ver melhorias de ranking', sub: 'após correção de inconsistências NAP' },
            { value: '0', label: 'Atualizações manuais necessárias', sub: 'uma vez configurada a sincronização' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Tínhamos 12 lojas com um histórico de 8 anos de mudanças de endereço, telefone e nome. O caos de citações era enorme — em alguns diretórios aparecíamos com três endereços diferentes para a mesma loja. O Stacc limpou tudo em duas semanas e mantém sincronizado desde então. Em 6 semanas, 9 das 12 lojas melhoraram sua posição no pacote de mapas."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">JF</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Jorge F.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Diretor de Marketing · Rede de óticas, 12 lojas</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">9 de 12 lojas subiram no Maps</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perguntas frequentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perguntas sobre gestão de citações
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Limpe suas citações uma vez. Para sempre.</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Cada inconsistência de NAP que você não corrige<br />é um sinal de ranking que você perde.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Agora mesmo seus dados NAP estão incorretos em pelo menos alguns dos 50+ diretórios que o Google rastreia. Essa inconsistência freia seu posicionamento local mesmo que você faça tudo mais certo. Uma auditoria do Stacc leva menos de 10 minutos e mostra exatamente onde estão os problemas.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Audite suas citações grátis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/precos/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Ver planos
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Teste gratuito 14 dias · Sem cartão de crédito · Cancele quando quiser</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
