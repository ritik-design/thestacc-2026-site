---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Em quais plataformas posso agendar publicações?",
    a: "O Stacc permite publicar no Google Business Profile, páginas do Facebook Business e contas do Instagram Business. As publicações podem ser feitas em uma plataforma ou nas três simultaneamente a partir de um único fluxo de trabalho.",
  },
  {
    q: "Posso publicar o mesmo post em múltiplas localizações ao mesmo tempo?",
    a: "Sim. A publicação em massa é uma função central. Escreva um post e selecione múltiplas localizações — o Stacc publica em todos os perfis de localização selecionados simultaneamente. Para 20 localizações, é uma ação em vez de 20.",
  },
  {
    q: "Posso adicionar detalhes específicos por localização aos posts em massa?",
    a: "Sim. Antes de publicar em massa, você pode adicionar ajustes específicos por localização — endereços diferentes, telefones diferentes no corpo do post, hashtags específicas por localização. O conteúdo principal do post permanece consistente; os detalhes locais são personalizados por conta.",
  },
  {
    q: "Publicar no GBP realmente melhora minha posição no Google Maps?",
    a: "Sim. A atividade no Google Business Profile — incluindo publicações regulares — é um sinal de ranking local documentado. Negócios que publicam de forma consistente no GBP melhoram sua visibilidade no pacote local em relação a perfis inativos. A automação de publicações no GBP do Stacc é projetada especificamente para manter seu perfil ativo com a frequência que influencia os rankings.",
  },
  {
    q: "Posso agendar publicações com semanas ou meses de antecedência?",
    a: "Sim. O calendário de conteúdo permite planejar e agendar posts com toda a antecedência que você precisar. Você também pode estabelecer um calendário de publicação recorrente e o Stacc publicará na sua cadência escolhida automaticamente — diária, semanal ou com um horário personalizado.",
  },
  {
    q: "O que acontece com um post agendado se uma conta se desconectar?",
    a: "O Stacc sinaliza a conta desconectada imediatamente e coloca o post em fila em vez de falhar silenciosamente. Você recebe um alerta para reconectar a conta, e o post em fila pode ser publicado assim que a conexão for restaurada.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Agendamento de Redes Sociais",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "Agende publicações no Google Business Profile, Facebook e Instagram em todas as suas localizações simultaneamente. Um post, publicado em todo lugar, automaticamente.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Funcionalidades", "item": "https://thestacc.com/pt-br/funcionalidades/" },
        { "@type": "ListItem", "position": 3, "name": "Agendamento Social", "item": "https://thestacc.com/pt-br/funcionalidades/agendamento-social/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Agendamento de Redes Sociais para Negócios Locais — Publique em Todas as suas Localizações | theStacc"
  description="Agende publicações em todas as suas localizações em minutos. O theStacc publica no Google Business Profile, Facebook e Instagram simultaneamente — com personalização por localização."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Agendamento Social · Módulo SEO Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Publique em todas as suas localizações<br />
            <span style="color:#4f39f6;">ao mesmo tempo. Não uma a uma.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc publica no Google Business Profile, Facebook e Instagram em todas as suas localizações simultaneamente. Escreva uma vez, selecione todas, agende — cada localização permanece ativa sem copiar, colar ou fazer login 20 vezes.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece grátis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/precos/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver preços
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mês · Teste gratuito 14 dias · Sem cartão de crédito
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '3 plat.', label: 'GBP, Facebook e Instagram em um fluxo' },
              { value: '500+', label: 'Localizações publicáveis em 1 clique' },
              { value: '8 seg.', label: 'Para publicar em 47 localizações simultâneas' },
              { value: '4.9★', label: 'Avaliação média do Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Seus perfis no Google estão há três meses<br />sem uma única publicação.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Você sabe que deveria publicar no Google Business Profile regularmente. Sabe que afeta o ranking. Mas entre gerenciar as localizações, responder avaliações e atender seus clientes, acaba sendo o que se adia toda semana. E enquanto isso, seu concorrente — o que publica duas vezes por semana — aparece no pacote de mapas quando seus clientes pesquisam exatamente o que você oferece.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Publicar em cada perfil separadamente consome horas.',
              body: 'Para uma única campanha em 10 localizações: entre no GBP localização 1, publique, saia, entre na localização 2, publique, saia... 10 logins, 10 publicações, 45 minutos de trabalho para um post que deveria levar 3 minutos. E isso é só o Google — sem Facebook nem Instagram.',
            },
            {
              icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
              title: 'Perfis inativos penalizam no ranking.',
              body: 'O Google recompensa a atividade. Um perfil GBP com posts regulares ganha sinais de ranking que um inativo não tem. Cada semana que passa sem publicar é uma semana em que seu concorrente ativo ganha vantagem no pacote de mapas. A inatividade tem um custo invisível que se acumula.',
            },
            {
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              title: 'A consistência é impossível sem um sistema.',
              body: 'Algumas localizações publicam, outras não. Algumas têm conteúdo de qualidade, outras têm o mínimo. Sem um sistema centralizado, a consistência — que é exatamente o que o Google e os clientes valorizam — é impossível de manter quando você tem mais de 3 localizações.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Como funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Escreva uma vez.<br />Publique em todo lugar automaticamente.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1', title: 'Conecte seus perfis e páginas', body: 'Vincule seus perfis do Google Business, páginas do Facebook e Instagram Business. Para múltiplas localizações, conecte todas as contas de uma vez. Configuração em menos de 10 minutos, sem necessidade de programador.' },
            { n: '02', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Escreva seu post e selecione localizações', body: 'Crie seu conteúdo uma única vez. Selecione as localizações em que quer publicar — todas, um grupo regional ou localizações específicas. Adicione personalizações por localização se precisar. Um fluxo, zero repetição.' },
            { n: '03', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Publique agora ou agende com antecedência', body: 'Publique imediatamente ou agende para qualquer data e hora. Estabeleça calendários de publicação recorrentes e o Stacc publicará automaticamente na sua cadência escolhida. Seu conteúdo sempre no horário, sem lembretes manuais.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── MOCK UI + DEEP DIVE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl">
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Publicação em Massa · Campanha de Verão</p>
              <div class="rounded-xl bg-[#fafaf9] p-4 mb-4">
                <p class="font-sans text-[13px] text-[#374151]">"Horário especial de verão! Abertos das 9h às 22h de segunda a domingo. Te esperamos!"</p>
              </div>
              <div class="space-y-2 mb-5">
                {[
                  { ch: 'Google Business Profile', locs: '47 localizações' },
                  { ch: 'Facebook Business Pages', locs: '47 localizações' },
                  { ch: 'Instagram Business', locs: '47 localizações' },
                ].map(row => (
                  <div class="flex items-center gap-3 rounded-lg border border-[#e7e5e4] px-3 py-2">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[12px] text-[#374151] flex-1">{row.ch}</span>
                    <span class="font-mono text-[10px] text-[#059669]">{row.locs}</span>
                  </div>
                ))}
              </div>
              <button class="w-full rounded-xl bg-[#4f39f6] py-3 font-sans text-[13px] font-semibold text-white">Publicar nas 47 localizações</button>
              <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">141 publicações · Tempo estimado: 8 segundos</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicação em Massa com Personalização</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Um post. Publicado em todas as suas localizações. Com os detalhes locais corretos.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Os modelos dinâmicos do Stacc personalizam cada publicação com o nome da localização, a cidade, o endereço ou os dados de contato locais — automaticamente. Você publica uma campanha e cada perfil recebe uma versão personalizada para o seu mercado local. Presença local autêntica, em escala.
              </p>
              <ul class="mt-6 space-y-3">
                {['Publique no GBP, Facebook e Instagram em um único fluxo', 'Modelos dinâmicos personalizam automaticamente o conteúdo por localização', 'Agende com semanas de antecedência em todas as localizações', 'Atualize horários, descrições e fichas de serviços em massa'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que os negócios conseguem quando<br />publicam de forma consistente.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '3×', label: 'Mais atividade GBP', sub: 'comparado com publicação manual' },
            { value: '45min', label: 'Economizados por campanha', sub: 'em negócios com 10+ localizações' },
            { value: '100%', label: 'Consistência de publicação', sub: 'todas as localizações, todas as semanas' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Gerenciamos 23 lojas e antes do Stacc publicar no GBP era algo que 'tentávamos fazer'. Agora cada loja tem posts semanais no Google, Facebook e Instagram — e nem penso nisso. Configurei uma vez, estabeleci o calendário e o Stacc gerencia. Em 90 dias subimos da posição 6 para a posição 2 no pacote de mapas em 17 das nossas localizações."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">MG</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Miguel G.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Diretor de Marketing · Rede de varejo, 23 lojas</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">Top 2 no Maps em 17 localizações</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perguntas frequentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perguntas sobre agendamento de redes sociais
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Pare de publicar uma localização de cada vez</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Cada semana sem publicar no GBP<br />é uma semana que seu concorrente ganha.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            A publicação consistente no Google Business Profile é um dos sinais de ranking local mais diretos que você pode controlar. Não requer mais orçamento nem mais equipe — só um sistema. O Stacc é esse sistema. Comece seu teste gratuito hoje.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Comece a publicar em todas as localizações
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/precos/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Ver planos
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Teste gratuito 14 dias · Sem cartão de crédito · Cancele quando quiser</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
