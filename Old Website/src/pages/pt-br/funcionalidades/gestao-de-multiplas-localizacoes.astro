---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "Quantas localizações posso gerenciar ao mesmo tempo?",
    a: "Não há limite prático. O Stacc foi construído para gerenciar portfólios em escala empresarial — os clientes gerenciam 500+ localizações em uma única conta. As operações em massa funcionam igualmente bem com 10 ou com 500 localizações.",
  },
  {
    q: "O que posso atualizar em massa em todas as localizações?",
    a: "Horários comerciais, horários especiais, números de telefone, endereços, URLs do site, descrições do negócio e categorias. Para o Google Business Profile especificamente: você também pode atualizar atributos, menus de serviços e imagens de capa em todas as localizações simultaneamente.",
  },
  {
    q: "Quanto tempo leva para adicionar uma nova localização?",
    a: "Aproximadamente 2 minutos. Você insere as informações básicas do negócio uma vez, conecta o perfil GBP e outras plataformas, e o Stacc propaga a configuração automaticamente pela sua rede de citações. Sem entrada manual diretório por diretório.",
  },
  {
    q: "Posso fazer atualizações diferentes para subconjuntos diferentes de localizações?",
    a: "Sim. Você pode agrupar localizações por região, marca, franqueado ou qualquer etiqueta personalizada. As atualizações em massa podem ser aplicadas a todo o portfólio, a um grupo específico ou a localizações individuais selecionadas. Você tem controle completo sobre o escopo.",
  },
  {
    q: "O que acontece se uma localização tem endereço ou telefone únicos?",
    a: "As atualizações em massa gerenciam os campos compartilhados. Para campos específicos de localização como endereço ou telefone direto, o Stacc mantém os dados únicos de cada unidade e não os sobrescreve com uma atualização em massa a menos que você escolha explicitamente. Dados compartilhados são atualizados em massa; os únicos permanecem únicos.",
  },
  {
    q: "Posso usar importação CSV para adicionar ou atualizar localizações em massa?",
    a: "Sim. O Stacc suporta importação CSV para criação e atualização em massa de localizações. Faça upload de uma planilha com seus dados de localização e o Stacc mapeia os campos automaticamente. Útil para a configuração inicial de grandes portfólios ou sincronização periódica de dados dos seus próprios sistemas.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Gestão em Massa de Localizações",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "pt-BR",
      "description": "Atualize centenas de localizações simultaneamente. Mude horários, endereços, descrições e categorias em todo o seu portfólio em minutos — não em dias.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" },
        { "@type": "ListItem", "position": 2, "name": "Funcionalidades", "item": "https://thestacc.com/pt-br/funcionalidades/" },
        { "@type": "ListItem", "position": 3, "name": "Gestão de Múltiplas Localizações", "item": "https://thestacc.com/pt-br/funcionalidades/gestao-de-multiplas-localizacoes/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "pt-BR",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Gestão em Massa de Localizações — Atualize 500+ Unidades em Minutos | theStacc"
  description="Pare de atualizar localizações uma a uma. A gestão em massa do Stacc permite alterar horários, endereços e informações em todo o seu portfólio com uma única ação."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Gestão em Massa de Localizações · Módulo SEO Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Alterar o horário em 50 localizações<br />
            <span style="color:#4f39f6;">deveria levar 2 minutos, não 2 dias.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc permite atualizar horários, endereços, descrições e muito mais em todas as suas localizações com uma única ação. Gerencie todo o portfólio em um painel centralizado — sem entrar em cada GBP separadamente.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece grátis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/precos/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver preços
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mês · Teste gratuito 14 dias · Sem cartão de crédito
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '500+', label: 'Localizações atualizáveis em 1 ação' },
              { value: '2 min', label: 'Para adicionar uma nova localização' },
              { value: 'CSV', label: 'Importação em massa para configuração inicial' },
              { value: '4.9★', label: 'Avaliação média do Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada mudança de dados multiplica seu trabalho<br />pelo número de localizações.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Você muda de telefone na sede central. Agora precisa atualizar o GBP de cada uma das 30 localizações. E o Yelp. E o Apple Maps. E o Bing Places. E todos os diretórios setoriais. Uma mudança de dado de 30 segundos vira um projeto de dois dias porque o sistema foi projetado para você fazer um a um. Isso não é gestão — é trabalho de entrada de dados que não deveria existir.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'As mudanças de horário consomem tardes inteiras.',
              body: 'Semana Santa. Férias de verão. Um novo horário estendido para toda a rede. Cada mudança de horários no GBP exige entrar em cada perfil separadamente. Em 30 localizações, são 30 logins, 30 atualizações, e entre 2 e 4 horas de trabalho para um dado que deveria mudar em segundos.',
            },
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Alguns perfis sempre ficam sem atualizar.',
              body: 'Quando atualizar é tão tedioso, inevitavelmente algumas localizações são puladas. O horário de Natal continua aparecendo em fevereiro. O endereço antigo da unidade que mudou há seis meses ainda está em três diretórios. Esses erros são vistos pelos clientes — e pelo Google também.',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Adicionar novas localizações demora demais.',
              body: 'Você abre uma nova unidade. Precisa criar o perfil GBP, verificá-lo, preencher todas as informações, publicá-lo em todos os diretórios relevantes... um por um. Na maioria dos negócios, uma nova localização leva dias para estar completamente configurada. Com o Stacc, 2 minutos.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tudo incluído</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Gestão em massa de localizações sem<br />trabalho manual repetitivo.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Atualização em Massa de Horários', body: 'Mude horários comerciais e especiais em todas as localizações simultaneamente. Defina horários especiais por temporada e aplique-os a todo o portfólio com um clique.', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { title: 'Edição em Massa de Dados', body: 'Atualize telefones, endereços, URLs do site, descrições do negócio e categorias em grupos de localizações ou em todo o portfólio com uma única ação.', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
            { title: 'Grupos de Localizações', body: 'Organize localizações por região, marca, franqueado ou qualquer etiqueta personalizada. Aplique atualizações a grupos específicos sem afetar o restante do portfólio.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
            { title: 'Importação CSV', body: 'Importe dados de localizações em massa a partir de uma planilha. Útil para o setup inicial de grandes portfólios ou sincronização periódica dos seus sistemas internos.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
            { title: 'Sincronização com Diretórios', body: 'Cada mudança de dados no Stacc se propaga automaticamente para 50+ diretórios para as localizações afetadas — Google, Apple Maps, Yelp e todos os demais. Uma mudança, propagação completa.', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
            { title: 'Controle de Acesso por Papel', body: 'Atribua permissões granulares por localização ou grupo. Um gerente regional vê e edita apenas suas unidades. Seu time central gerencia todo o portfólio. Sem acessos indesejados nem mudanças acidentais.', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que você recupera quando para de<br />atualizar localizações uma a uma.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '2 min', label: 'Para adicionar uma nova localização', sub: 'vs. horas de configuração manual' },
            { value: '8hrs', label: 'Economizadas por semana por operador', sub: 'antes dedicadas a atualizações manuais' },
            { value: '500+', label: 'Localizações atualizáveis em 1 ação', sub: 'sem limite máximo de portfólio' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Temos 65 lojas e antes do Stacc, atualizar os horários de Natal era o projeto que todos temiam em dezembro. Duas pessoas passavam três dias inteiros atualizando perfis um a um. No ano passado com o Stacc fizemos em 20 minutos. Atualizei as 65 lojas no GBP, Facebook e todos os diretórios em um único painel. Ainda não acredito."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">BT</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Beatriz T.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Responsável de Operações · Rede de lojas de moda, 65 unidades</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">3 dias de trabalho → 20 minutos</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Perguntas frequentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Perguntas sobre gestão em massa de localizações
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Pare de atualizar localizações uma a uma</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Seu tempo é valioso demais para gastar<br />horas em entrada de dados.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Cada hora atualizando perfis um a um é uma hora que você não está gerando resultados. O Stacc converte tarefas de dias em ações de minutos para que sua equipe se dedique ao trabalho que realmente move o negócio. Comece seu teste gratuito hoje.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/"
