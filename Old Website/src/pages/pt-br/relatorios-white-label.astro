---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que são relatórios white-label?", a: "Relatórios white-label são quando uma agência entrega relatórios para clientes com o seu próprio logo, nome da agência e domínio — e não com o nome do fornecedor do software. Os clientes recebem relatórios com formatação profissional que reforçam a marca da agência, sem nenhum nome de ferramenta de terceiros visível." },
  { q: "Quais dados estão incluídos nos relatórios white-label do Stacc?", a: "Os relatórios incluem posições de palavras-chave (pacote local, Maps, orgânico), métricas de atividade do GBP (posts publicados, visualizações, cliques em ligações), pontuações de precisão de citações, dados de avaliações (quantidade, média, taxa de resposta) e dados comparativos mês a mês. Você configura quais seções incluir por cliente." },
  { q: "Os relatórios são entregues automaticamente ou preciso exportá-los?", a: "Totalmente automatizados. Configure o calendário de entrega para cada cliente — semanal ou mensal — e o Stacc gera e envia o relatório automaticamente. Sem exportações, sem formatação, sem envio manual. Os relatórios chegam nas caixas de entrada dos clientes sem que ninguém na sua equipe precise tocá-los." },
  { q: "O relatório pode parecer que veio da minha agência, e não do Stacc?", a: "Sim. O seu logo, o nome da sua agência, o seu domínio no remetente do e-mail, o seu esquema de cores no PDF. O nome do Stacc não aparece em nenhum lugar do relatório voltado ao cliente. Os clientes o vivenciam como seu sistema de relatórios exclusivo." },
  { q: "Posso revisar os relatórios antes de enviá-los aos clientes?", a: "Sim. Você pode configurar os relatórios no modo 'revisar antes de enviar', onde ficam retidos no seu painel para aprovação. Ou configurá-los para entrega totalmente automatizada, onde vão direto para os clientes. Configuração por cliente." },
  { q: "Os relatórios white-label incluem painéis ao vivo para clientes?", a: "Sim. Além da entrega automatizada de relatórios, os clientes podem acessar um painel ao vivo no seu domínio que é atualizado continuamente com dados novos. O painel ao vivo mostra as posições atuais, atividade recente do GBP e estatísticas de avaliações em tempo real." },
  { q: "Quanto custam os relatórios white-label?", a: "Incluídos nos planos Growth e Scale do Stacc. O módulo de SEO Local começa a partir de $49/mês. A entrega de relatórios para clientes está incluída sem taxa por cliente." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Relatórios White-Label", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Relatórios de SEO white-label para agências. Geração e entrega automatizadas de relatórios sob a marca da sua agência — seu logo, seu domínio, seu relatório.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Relatórios White-Label", "item": "https://thestacc.com/pt-br/relatorios-white-label/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Relatórios White-Label para Agências de SEO | theStacc"
  description="Automatize relatórios de SEO para clientes sob a marca da sua agência. O theStacc gera e entrega relatórios white-label com o seu logo e domínio — semanais ou mensais, zero trabalho manual."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Relatórios White-Label · Para Agências · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Relatórios de clientes que se constroem e enviam<br />
            <span style="color:#4f39f6;">sozinhos. Sob a sua marca.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            O Stacc gera, personaliza e entrega relatórios de SEO para cada cliente automaticamente, conforme o seu calendário. Seu logo. Seu domínio. Zero trabalho manual por relatório.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/solucoes/agencias/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver relatórios de clientes
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · 30 dias de garantia · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O custo real dos relatórios manuais</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            3 horas por cliente por mês.<br />Multiplicadas por cada cliente que você tem.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Para uma agência com 15 clientes, os relatórios manuais representam 45 horas por mês — mais de uma semana de trabalho completa — gastas coletando dados, formatando planilhas e escrevendo resumos que os clientes vão ler por 30 segundos. É a tarefa de maior alavancagem que você pode automatizar, porque a economia de tempo se converte diretamente em capacidade para mais clientes.</p>
            <p>Mas a dimensão da marca importa tanto quanto o tempo. Relatórios que chegam com o nome de uma ferramenta genérica estão fazendo algo sutil: estão dizendo ao seu cliente que o seu processo é commodity. Relatórios que chegam com o seu logo, do seu domínio, em um calendário profissional — esses dizem ao cliente que você administra uma operação de primeira linha. Essa percepção afeta a retenção.</p>
            <p class="font-semibold text-[#111827]">O Stacc automatiza a geração e a entrega de relatórios personalizados para cada cliente, no calendário que você escolher. A economia de tempo por si só já vale a pena. A impressão de marca é o bônus.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de relatórios</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todas as funcionalidades de relatório que agências precisam.<br />Tudo automatizado, tudo com sua marca.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Sua marca em cada relatório', body: 'Seu logo, nome da agência e esquema de cores em cada PDF e e-mail. A marca do Stacc removida completamente de todos os documentos voltados ao cliente.' },
            { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Entrega automatizada conforme o calendário', body: 'Configure a entrega semanal ou mensal por cliente. Os relatórios são gerados e enviados automaticamente — sem acionamento manual, sem exportação, sem formatação.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Dados completos de SEO local', body: 'Posições, atividade de GBP, precisão de citações, pontuações de avaliações e comparações mês a mês — tudo em um único relatório por cliente.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Painéis ao vivo com sua marca', body: 'Os clientes também têm acesso a um painel ao vivo no seu domínio com dados em tempo real entre os ciclos de entrega de relatórios.' },
            { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Modo de revisão antes do envio', body: 'Opcionalmente, retenha os relatórios para revisão antes da entrega. Aprove e envie com um clique, ou deixe os relatórios serem entregues totalmente automatizados por preferência de cliente.' },
            { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', title: 'Gerenciamento de relatórios para múltiplos clientes', body: 'Veja todos os relatórios de clientes em uma única fila. Acompanhe status de entrega, taxas de abertura e engajamento dos clientes pelo seu painel de agência.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Relatórios em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o sistema de relatórios<br />do Stacc faz por você.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Entrega Automatizada</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Relatórios que se criam e enviam sozinhos.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configure o template uma vez: selecione as métricas, carregue o seu logo, defina o esquema de cores e o calendário de entrega. O Stacc cuida do resto — coleta os dados, formata o relatório com a sua marca e o entrega na caixa de entrada do cliente na data programada. Sem exportações manuais. Sem formatação. Sem risco de esquecer o relatório de um cliente. O processo funciona para 1 cliente ou para 100, sem trabalho adicional da sua equipe.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de relatórios
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Relatório mensal — Agência Digital Pro</p>
              <div class="mb-4 flex items-center gap-3 rounded-xl border border-[#e7e5e4] bg-[#f5f3ff] px-4 py-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#4f39f6]">
                  <span class="font-mono text-[10px] font-bold text-white">AG</span>
                </div>
                <div>
                  <p class="font-sans text-[12px] font-semibold text-[#111827]">Relatório de SEO Local — Abril 2026</p>
                  <p class="font-mono text-[10px] text-[#79716b]">agenciadigitalpro.com.br · Para: Encanamentos Silva</p>
                </div>
              </div>
              {[
                { label: 'Posição média no Maps', value: '#2,4', note: '↑ de #4,1' },
                { label: 'Posts no GBP publicados', value: '30', note: '100% automático' },
                { label: 'Novas avaliações', value: '6', note: '★ 4,8 média' },
                { label: 'Citações verificadas', value: '50/50', note: '✓ Corretas' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">{row.label}</span>
                  <div class="text-right">
                    <span class="font-sans text-[12px] font-semibold text-[#111827]">{row.value}</span>
                    <span class="ml-2 font-mono text-[10px] text-[#059669]">{row.note}</span>
                  </div>
                </div>
              ))}
              <div class="mt-3 flex items-center justify-between rounded-xl bg-[#dcfce7] px-4 py-2">
                <span class="font-sans text-[12px] font-semibold text-[#059669]">Enviado automaticamente</span>
                <span class="font-mono text-[11px] text-[#059669]">✓ Enviado</span>
              </div>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Configuração do template de relatório</p>
              <div class="space-y-4">
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-[#79716b] mb-2">Logo da agência</p>
                  <div class="flex items-center gap-3 rounded-xl border-2 border-dashed border-[#c7c0fc] bg-[#f5f3ff] px-4 py-3">
                    <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#4f39f6]">
                      <span class="font-mono text-[10px] font-bold text-white">AG</span>
                    </div>
                    <span class="font-sans text-[12px] text-[#4f39f6]">logo-agencia.svg · carregado ✓</span>
                  </div>
                </div>
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-[#79716b] mb-2">Cor principal</p>
                  <div class="flex items-center gap-2">
                    <div class="h-6 w-6 rounded-lg bg-[#4f39f6]"></div>
                    <span class="font-mono text-[12px] text-[#111827]">#4f39f6</span>
                    <span class="ml-auto font-mono text-[10px] text-[#059669]">✓ Aplicado</span>
                  </div>
                </div>
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-[#79716b] mb-2">Calendário de entrega</p>
                  <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                    <span class="font-sans text-[12px] text-[#57534e]">Todo dia 1 do mês às 9h</span>
                    <span class="font-mono text-[10px] text-[#059669]">✓ Ativo</span>
                  </div>
                </div>
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-[#79716b] mb-2">Domínio remetente</p>
                  <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                    <span class="font-sans text-[12px] text-[#57534e]">relatorios@agenciadigitalpro.com.br</span>
                    <span class="font-mono text-[10px] text-[#059669]">✓</span>
                  </div>
                </div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Configure uma vez · Entrega automática para sempre</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Configuração Única</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Configure uma vez. Entregue para sempre.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Leva menos de 15 minutos para configurar o template de relatório de um cliente: carregue o logo, defina as cores, escolha as métricas e o calendário de entrega. Depois disso, o Stacc gera e entrega automaticamente todo mês — sem precisar que ninguém na sua equipe toque. A configuração é por cliente, mas o trabalho contínuo é zero. Escale para 50 clientes e o tempo de geração de relatórios ainda é zero.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver solução para agências
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">White-Label Completo</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Seus clientes veem sua marca.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cada relatório entregue aos clientes tem o seu logo, o nome da sua agência, o seu domínio e as suas cores. O Stacc é completamente invisível. Os clientes recebem o relatório como se você tivesse construído do zero uma plataforma de relatórios exclusiva para eles. Isso reforça a percepção do valor da sua agência a cada ciclo de entrega — e cria um motivo concreto para os clientes permanecerem.
              </p>
              <a href="/pt-br/precos/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver preços
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
