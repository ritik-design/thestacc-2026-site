---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "O que um software de SEO para franquias deve fazer?", a: "Um software de SEO para franquias deve automatizar as tarefas repetitivas de SEO local que precisam acontecer de forma consistente em cada unidade: publicação de posts no GBP, monitoramento de citações, rastreamento de posição, alertas de avaliações e geração de relatórios. Se ele apenas rastreia essas coisas e exige execução manual, não está resolvendo o problema de escalabilidade." },
  { q: "Como o software de SEO para franquias difere das ferramentas comuns de SEO local?", a: "As ferramentas comuns de SEO local foram criadas para uma ou poucas unidades. O software de SEO para franquias foi construído para portfólios — edição em massa, relatórios para toda a rede, acesso segmentado para franqueados vs. franqueadores, e automação que executa as mesmas tarefas em cada unidade sem repetição manual por unidade." },
  { q: "O Stacc consegue gerenciar unidades corporativas e de franqueados?", a: "Sim. Você pode segmentar as unidades por tipo de propriedade ou região e aplicar diferentes configurações, agendas de relatório ou níveis de acesso a cada grupo. Unidades corporativas e de franqueados convivem no mesmo painel com níveis de permissão configuráveis." },
  { q: "O Stacc suporta relatórios white-label para redes de franquias?", a: "Sim. Os relatórios white-label podem carregar a marca do franqueador ou do franqueado, dependendo da estrutura de relatório. Os relatórios são gerados e entregues automaticamente no horário agendado." },
  { q: "Como o Stacc lida com a consistência NAP nas unidades de franquia?", a: "O Stacc monitora os dados de citações em mais de 50 diretórios para cada unidade e sinaliza inconsistências em tempo real. As correções podem ser aplicadas em todas as unidades afetadas em massa. Os dados NAP consistentes são um dos fatores de posicionamento local de maior impacto para negócios de franquia." },
  { q: "Existe taxa de configuração para contas de franquia?", a: "Sem taxa de configuração. Os planos começam em $49/mês pelo módulo de SEO Local, que inclui todos os recursos de franquia e multi-unidade." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Software de SEO para Franquias", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "pt-BR", "description": "Software de SEO para franquias que automatiza o gerenciamento da pesquisa local em toda a sua rede. GBP, citações, posicionamentos e relatórios para cada unidade, simultaneamente.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Início", "item": "https://thestacc.com/pt-br/" }, { "@type": "ListItem", "position": 2, "name": "Software de SEO para Franquias", "item": "https://thestacc.com/pt-br/software-seo-franquias/" }] },
    { "@type": "FAQPage", "inLanguage": "pt-BR", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de SEO para Franquias — Gerencie Todas as Unidades | theStacc"
  description="Software de SEO para franquias construído para escala. O theStacc automatiza gerenciamento GBP, monitoramento de citações, rastreamento de posição e relatórios para cada unidade — sem trabalho manual por unidade."
  lang="pt-BR"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de SEO para Franquias · A partir de $49/mês</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Software de SEO para franquias que<br />
            <span style="color:#4f39f6;">gerencia toda a sua rede.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Construído para a escala de franquias: gerenciamento em massa do GBP, monitoramento de citações em toda a rede, painéis de posicionamento do portfólio e relatórios automatizados para cada unidade simultaneamente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/pt-br/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Comece por $1 hoje
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pt-br/solucoes/franquias/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funcionalidades para franquias
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sem cartão de crédito para começar · Garantia de 30 dias · Cancele quando quiser</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas e agências</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ unidades gerenciadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLEM SECTION -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">O que um software de SEO para franquias deve fazer</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            A maioria das ferramentas de SEO rastreia em escala.<br />O Stacc executa em escala.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>A maioria das ferramentas de SEO local foi construída para uma unidade ou um pequeno conjunto. Elas mostram painéis. Dizem o que precisa ser feito. Então alguém da sua equipe precisa abrir cada unidade e fazer. Isso funciona para cinco unidades. Não funciona para cinquenta.</p>
            <p>O software de SEO para franquias tem uma função diferente: automatizar a execução em escala. Não apenas relatar o que está acontecendo — realmente fazer. Publicar os posts no GBP. Monitorar as citações. Enviar os relatórios. Para cada unidade, todos os dias, sem que alguém precise agendar manualmente por unidade.</p>
            <p class="font-semibold text-[#111827]">Esse é o Stacc. Construído desde o início para execução multi-unidade — não adaptado para escala depois do fato.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades da plataforma</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tudo que as redes de franquias precisam<br />em uma única plataforma.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Gerenciamento do GBP para toda a rede', body: 'Publique posts, atualize horários e gerencie atributos para todas as unidades de franquia em massa. Uma ação. Cada unidade. Propagação instantânea.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoramento de consistência de citações', body: 'Monitore a precisão NAP em mais de 50 diretórios para cada unidade. Corrija inconsistências em massa antes que afetem os posicionamentos.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Painel de posicionamento por unidade', body: 'Atualizações diárias de posição para cada unidade no pacote local, Maps e orgânico. A visão do portfólio mostra todas as unidades lado a lado com tendências de desempenho.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestão de avaliações por unidade', body: 'Caixa de entrada centralizada de avaliações para todas as unidades de franquia. Alertas em tempo real, gerenciamento de respostas e rastreamento de pontuação por unidade.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Acesso de franqueador e franqueado', body: 'Permissões segmentadas: franqueadores veem toda a rede, franqueados veem seus próprios dados. Gerenciamento centralizado com visibilidade individual.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Relatórios automatizados para a rede', body: 'Resumos da rede, relatórios por unidade e relatórios personalizados por grupo — gerados e entregues automaticamente no seu horário.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Software em detalhe</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            O que o software faz<br />por cada unidade da franquia.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Posts GBP localizados por unidade</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Publicação de posts localizada por unidade.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O Stacc gera posts específicos para cada cidade da rede de franquias — não conteúdo genérico aplicado a todas as unidades. A unidade de Belo Horizonte recebe posts com "serviço em BH". A do Recife, com referências ao Recife. Cada uma das 30 publicações mensais é localizada para o mercado da unidade e publicada automaticamente no horário certo.
              </p>
              <a href="/pt-br/automacao-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de posts GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posts GBP publicados hoje — rede de franquias</p>
              {[
                { city: 'Belo Horizonte — MG', post: 'Melhor clínica odontológica em BH', ok: true },
                { city: 'Recife — PE', post: 'Clínica odontológica de confiança em Recife', ok: true },
                { city: 'Porto Alegre — RS', post: 'Atendimento odontológico especializado em POA', ok: true },
              ].map(item => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{item.city}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{item.post}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓ Publicado</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Conteúdo localizado · Zero trabalho manual</p>
            </div>
          </div>

          <!-- Section 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Rastreamento de posições — rede de franquias</p>
              {[
                { unit: 'MG — Belo Horizonte', kw: 'clínica odontológica bh', pos: '#2', trend: '↑' },
                { unit: 'PE — Recife', kw: 'dentista recife', pos: '#3', trend: '↑' },
                { unit: 'RS — Porto Alegre', kw: 'clínica dentária poa', pos: '#1', trend: '↑' },
                { unit: 'CE — Fortaleza', kw: 'dentista fortaleza', pos: '#5', trend: '↑' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{row.unit}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{row.kw}</p>
                  </div>
                  <span class="font-mono text-[13px] font-bold text-[#4f39f6]">{row.pos} <span class="text-[#059669]">{row.trend}</span></span>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreamento centralizado de posições</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Rastreamento de posições em toda a rede.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                O painel de portfólio do Stacc rastreia as posições de cada unidade no pacote local, Maps e orgânico — atualizadas diariamente, side by side. Veja quais mercados estão subindo, quais estagnaram e onde concentrar esforços. Um painel. Toda a rede. Sem exportar planilhas de 20 ferramentas diferentes.
              </p>
              <a href="/solutions/franchises/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver rastreamento multi-unidade
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Relatórios automatizados</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Relatórios de desempenho automáticos.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configure o template uma vez — métricas, logo, agenda de entrega. O Stacc puxa os dados, formata o relatório e envia para cada franqueado automaticamente. Relatórios consolidados para o franqueador. Relatórios individuais para cada unidade. Entregues no dia certo, sem que ninguém da equipe precise tocar.
              </p>
              <a href="/pt-br/solucoes/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automação de relatórios
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Relatórios entregues — este mês</p>
              {[
                { unit: 'Unidade Belo Horizonte', time: '1 Abr, 9h00', status: 'Entregue' },
                { unit: 'Unidade Recife', time: '1 Abr, 9h00', status: 'Entregue' },
                { unit: 'Unidade Porto Alegre', time: '1 Abr, 9h00', status: 'Entregue' },
                { unit: 'Relatório consolidado da rede', time: '1 Abr, 9h00', status: 'Entregue' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.unit}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.time}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Zero trabalho manual · White-label</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            O que o software de SEO para franquias<br />realmente entrega.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '300+', num: 300, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Unidades de franquia gerenciadas', sub: 'plataforma única, zero equipe por unidade' },
            { value: '2min', num: 2, prefix: '', suffix: 'min', decimals: 0, from: 0, label: 'Para adicionar nova unidade', sub: 'do zero a completamente gerenciado' },
            { value: '89%', num: 89, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Melhora de posicionamento no GBP em 90 dias', sub: 'atividade consistente vs. baseline inativo' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
