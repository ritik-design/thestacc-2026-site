        },
        {
          q: 'contador para pequena empresa',
          rows: [
            { domain: 'contabilidade-precisao.com.br', title: 'Contador para Pequena Empresa. Mais Bem Avaliado em Curitiba', snip: '47 avaliações 5 estrelas. Especialista MEI e Simples. Consulta grátis.', pos: 1,    yours: false },
