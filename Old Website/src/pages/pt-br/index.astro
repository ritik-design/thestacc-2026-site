        { score:87, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Antes de contratar: checklist de [serviço]' },
        { score:89, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Perguntas para fazer ao seu prestador de [serviço]' },
        { score:85, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Seguro de [serviço]: o que está coberto?' },
        { score:93, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Como comparar preços de [serviço]' },
        { score:82, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Sinais de alerta na hora de contratar [serviço]' },
        { score:88, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Custos escondidos de [serviço] que você precisa saber' },
        { score:86, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Quando chamar profissional vs. fazer sozinho' },
        { score:90, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Checklist antes do prestador chegar em casa' },
        { score:84, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Cuidados depois de [serviço]: o que fazer' },
        { score:91, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Guia de manutenção sazonal de [serviço]' },
        { score:87, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'FAQ de [serviço]: dúvidas mais comuns' },
        { score:89, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'Como achar a melhor oferta de [serviço]' },
        { score:85, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILA',     labelColor:'#9ca3af', title:'O guia completo de [serviço]' },
      ];

      const grid    = document.getElementById('article-grid');
      const countEl = document.getElementById('grid-count');
      if (!grid) return;

      TILES.forEach((t) => {
        const el = document.createElement('div');
        el.className = `article-tile ${t.type}`;
        el.innerHTML = `
          <span style="font-family:monospace;font-size:11px;font-weight:800;line-height:1;color:${t.scoreColor}">${t.score}</span>
          <span style="font-family:monospace;font-size:7px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;line-height:1;color:${t.labelColor}">${t.label}</span>
          <div class="tile-tooltip">${t.title}</div>
        `;
        grid.appendChild(el);
      });

      let cascadeTimer: ReturnType<typeof setTimeout> | null = null;

      function animateIn(delay = 0) {
        const tiles = grid.querySelectorAll('.article-tile');
        let count = 0;
        tiles.forEach((tile, i) => {
          setTimeout(() => {
            tile.classList.add('tile-visible');
            count++;
            if (countEl) countEl.textContent = count + ' artigos na fila';
          }, delay + i * 72);
        });
      }

      function resetAndAnimate() {
        if (cascadeTimer) clearTimeout(cascadeTimer);
        const tiles = grid.querySelectorAll<HTMLElement>('.article-tile');
        tiles.forEach((t) => {
          t.style.transition = 'none';
          t.classList.remove('tile-visible');
        });
        grid.getBoundingClientRect();
        tiles.forEach((t) => { t.style.transition = ''; });
        if (countEl) countEl.textContent = '0 artigos na fila';
        cascadeTimer = setTimeout(() => animateIn(0), 80);
      }

      document.querySelectorAll<HTMLElement>('.grid-month-tab').forEach((tab) => {
        tab.addEventListener('click', () => {
          document.querySelectorAll<HTMLElement>('.grid-month-tab').forEach((t) => {
            t.style.color = '#374151';
            t.style.borderBottomColor = 'transparent';
          });
          tab.style.color = '#818cf8';
          tab.style.borderBottomColor = '#4f39f6';
          resetAndAnimate();
        });
      });

      const obs = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) { obs.disconnect(); animateIn(300); }
        },
        { threshold: 0.2 }
      );
      obs.observe(grid);
    })();
  </script>
</BaseLayout>
