---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ExitIntent from '../components/common/ExitIntent.astro';

const faqs = [
  { q: "What is multi-location SEO software?", a: "Multi-location SEO software lets businesses manage local search optimization across every location from a single platform — ranking tracking, citation management, review monitoring, and GBP posting handled in bulk instead of one location at a time." },
  { q: "How does Stacc handle multi-location rank tracking?", a: "Each location gets its own keyword set tracked daily. You see each location's ranking in the local pack, Maps, and organic results. The portfolio dashboard compares all locations side by side so you can instantly see which are improving and which need attention." },
  { q: "Can I publish GBP posts to all locations at once?", a: "Yes. Write one post and publish it to every location simultaneously, or customize per-location details before bulk-publishing. Stacc handles the GBP API calls for every location in a single action." },
  { q: "Can I manage citations for multiple locations in bulk?", a: "Yes. Stacc monitors citation accuracy across 50+ directories for each location and flags inconsistencies. Corrections can be pushed to multiple locations at once from the bulk editor." },
  { q: "Is there a limit on how many locations I can add?", a: "No hard limit. Customers manage 500+ locations in a single account. The platform is designed for enterprise-scale portfolios." },
  { q: "Does Stacc support white-label reporting for multi-location clients?", a: "Yes. Each client can get their own branded portal with a custom domain and logo. Reports are generated and delivered automatically under your agency's brand." },
  { q: "How long does it take to onboard a new location?", a: "About 2 minutes. Enter the core business data, connect the GBP listing, and Stacc propagates setup across your citation network automatically." },
  { q: "What does multi-location SEO software cost?", a: "Stacc's Local SEO module starts at $49/month. All multi-location features — bulk management, portfolio reporting, comparison dashboard — are included." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Multi-Location SEO Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Multi-location SEO software that automates ranking, citations, GBP management, and reporting across every location from one dashboard.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Multi-Location SEO Software", "item": "https://thestacc.com/multi-location-seo-software/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Multi-Location SEO Software — Manage Every Location from One Dashboard | theStacc"
  description="Stop managing local SEO location by location. theStacc's multi-location SEO software handles rank tracking, citations, GBP, and reporting for every location simultaneously."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Multi-Location SEO Software · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Multi-location SEO that runs<br />
            <span style="color:#4f39f6;">itself across every location.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc manages rankings, GBP posts, citations, reviews, and reporting for every location simultaneously. Not a dashboard that requires manual work — a platform that does the work.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See what's included
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">500+ location portfolios managed</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Setup in under 5 minutes</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Why multi-location SEO breaks at scale</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every location needs daily work.<br />You can't do it all manually.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Managing local SEO for one location is a part-time job. Managing it for ten locations is a full-time job. Managing it for fifty locations is a team. The math breaks at some point — and for most businesses, it breaks around location three or four, when the spreadsheets start multiplying and the manual work starts compounding.</p>
            <p>Here's what "managing manually" actually costs at scale: each location needs daily GBP activity, consistent citations across 50+ directories, ranked keyword monitoring, and reviewed reputation management. Then someone needs to report on all of it. Multiply by 30 locations. That's not a workflow — that's a full department.</p>
            <p class="font-semibold text-[#111827]">Stacc is built specifically for this problem. One platform that automates every local SEO task across every location, every day — without adding headcount as your location count grows.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            One platform. Every local SEO lever.<br />All of it automated.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'Local SEO', price: '$49/mo', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['GBP post publishing — 30/month', 'Daily rank tracking — local pack + organic', 'Review monitoring — real-time alerts', 'Citation management — 50+ directories'], href: '/modules/local-seo/' },
            { title: 'Blog SEO', price: '$99/mo', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 SEO blog posts/month', 'Published directly to your site', 'Keyword research included', 'Internal linking optimized'], href: '/modules/content-seo/' },
            { title: 'Social Media', price: '$49/mo', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Daily posts with images', 'Instagram, LinkedIn, Facebook, X', 'Written and scheduled automatically', 'Brand-consistent content'], href: '/modules/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Learn more</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Key capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every multi-location SEO task automated.<br />Every result visible.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Portfolio dashboard -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Location Portfolio Dashboard</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Every location ranked side by side. Underperformers surface instantly.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">The portfolio dashboard shows all locations compared across rankings, citation accuracy, review score, and GBP activity. Sort by any metric to instantly see who's winning, who's stagnating, and where your attention will have the highest ROI. No more tab-switching to check each location — the comparison is done for you every day.</p>
              <a href="/features/multi-location-reporting/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">See multi-location reporting <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Location portfolio — today</p>
              {[
                { name: 'Downtown Chicago', rank: 1, trend: '↑', score: 94 },
                { name: 'River North', rank: 2, trend: '↑', score: 91 },
                { name: 'Lincoln Park', rank: 3, trend: '→', score: 88 },
                { name: 'Hyde Park', rank: 7, trend: '↓', score: 61 },
              ].map(loc => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${loc.rank <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#fff1f2] text-[#ef4444]'}`}>#{loc.rank}</div>
                  <span class="flex-1 font-sans text-[13px] text-[#374151]">{loc.name}</span>
                  <div class="h-1.5 w-16 rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${loc.score}%`}></div></div>
                  <span class={`font-mono text-[11px] font-semibold ${loc.trend === '↑' ? 'text-[#059669]' : loc.trend === '↓' ? 'text-[#ef4444]' : 'text-[#79716b]'}`}>{loc.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Updated daily · All locations compared automatically</p>
            </div>
          </div>

          <!-- Bulk management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Bulk update — holiday hours</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Select locations</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {['All 47 locations', 'Chicago region', 'Custom selection'].map(opt => (
                    <span class={`rounded-lg px-3 py-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] ${opt === 'All 47 locations' ? 'bg-[#4f39f6] text-white' : 'border border-[#e7e5e4] text-[#79716b]'}`}>{opt}</span>
                  ))}
                </div>
              </div>
              <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-white p-4">
                <span class="font-sans text-[13px] text-[#57534e]">Apply Thanksgiving hours to all 47</span>
                <span class="rounded-lg bg-[#059669] px-3 py-1 font-mono text-[10px] font-bold text-white">Apply</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">2 seconds vs. 47 manual logins</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Bulk Location Management</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Update every location in seconds. Not hours.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Holiday hours. Category changes. New phone numbers. Description updates. Any change that affects your entire portfolio can be applied to all locations simultaneously from a single action. No logins, no tab-switching, no manual errors. Bulk updates propagate to GBP and your citation network automatically.</p>
              <a href="/features/bulk-location-management/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">See bulk location management <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated Portfolio Reporting</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Reports for every location, delivered on schedule. Zero manual work.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Set up automated reporting for every location or every client once. Stacc generates location-level reports and portfolio summaries on your schedule — weekly, monthly, or custom — and delivers them automatically. Agencies can white-label every report under their brand. No exporting. No formatting. No forgetting.</p>
              <a href="/features/client-reporting/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">See client reporting <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">This week's portfolio report</p>
              {[
                { label: 'Locations improving', val: '34 of 47' },
                { label: 'Top-3 pack keywords', val: '+18 this week' },
                { label: 'GBP posts published', val: '94 across all locations' },
                { label: 'Reviews responded', val: '12 / avg 4.7 ⭐' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generated and sent automatically · Your brand on everything</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIALS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-5xl">
          <div class="mb-12 text-center">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What customers say</span>
            <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
              Multi-location teams that stopped<br />managing one location at a time.
            </h2>
          </div>
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            {[
              { name: 'Kevin S.', role: 'Head of Local Marketing, 28-location restaurant group', stars: 5, quote: "We used to spend two days a month just updating GBP hours and preparing ranking reports. With Stacc that's zero days. Everything runs automatically and the portfolio dashboard tells me where to focus in about 30 seconds." },
              { name: 'Rachel T.', role: 'Agency owner, 60+ multi-location clients', stars: 5, quote: "I onboard new multi-location clients in under an hour now. Stacc propagates setup across the citation network automatically — what used to take a week of manual work is done before the client's first check-in call." },
              { name: 'Dan M.', role: 'VP Operations, national service franchise', stars: 5, quote: "The comparison dashboard showing all locations side by side is what sold us. We found four locations with citation problems we'd had for over a year — fixing them moved two locations into the top 3 in their markets within 60 days." },
              { name: 'Yuki H.', role: 'Digital Director, regional retail chain', stars: 5, quote: "Our best locations are now in position 1-3 for their primary keywords. The automation is doing work our team just couldn't keep up with manually — 30 GBP posts per location per month, for 22 locations. That's 660 posts we don't have to write." },
            ].map(t => (
              <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7">
                <div class="mb-4 flex gap-0.5">{[1,2,3,4,5].map(() => <svg width="13" height="13" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}</div>
                <p class="font-sans text-[0.95rem] leading-[1.7] text-[#374151]">"{t.quote}"</p>
                <div class="mt-5 flex items-center gap-3">
                  <div class="flex h-9 w-9 items-center justify-center rounded-full bg-[#4f39f6] font-sans text-[13px] font-bold text-white">{t.name.split(' ').map((n: string) => n[0]).join('')}</div>
                  <div>
                    <p class="font-sans text-[13px] font-semibold text-[#111827]">{t.name}</p>
                    <p class="font-sans text-[12px] text-[#79716b]">{t.role}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── COMPARISON ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-5xl">
          <div class="mb-12 text-center">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How Stacc compares</span>
            <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
              Execution at scale.<br />Not just reporting at scale.
            </h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[640px] border-collapse">
              <thead>
                <tr class="border-b border-[#e7e5e4]">
                  <th class="py-4 pr-6 text-left font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Capability</th>
                  {['Stacc', 'BrightLocal', 'Yext', 'Semrush Local'].map(tool => (
                    <th class={`px-4 py-4 text-center font-mono text-[11px] font-semibold uppercase tracking-[0.12em] ${tool === 'Stacc' ? 'text-[#4f39f6]' : 'text-[#79716b]'}`}>{tool}</th>
                  ))}
                </tr>
