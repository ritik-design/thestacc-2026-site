---
import LegalLayout from '../layouts/LegalLayout.astro';

const toc = [
  { id: 'controller',   label: '1. Data Controller' },
  { id: 'types',        label: '2. Types of Data Processed' },
  { id: 'legal-basis',  label: '3. Legal Basis for Processing' },
  { id: 'retention',    label: '4. Data Retention' },
  { id: 'processors',   label: '5. Third-Party Processors' },
  { id: 'transfers',    label: '6. Cross-Border Transfers' },
  { id: 'rights',       label: '7. Your Rights (GDPR)' },
  { id: 'contact',      label: '8. Contact' },
];

const dataTypes = [
  { label: 'Account data',   body: 'Name, email address, company name, billing address.' },
  { label: 'Usage data',     body: 'Service interactions, content generation history, feature usage patterns.' },
  { label: 'Business data',  body: 'Website URLs, keywords, business descriptions you provide to configure our services.' },
  { label: 'Technical data', body: 'IP addresses, browser type, device identifiers, and other log data.' },
];

const gdprRights = [
  { label: 'Right of access',         body: 'Request a copy of the data we hold about you.' },
  { label: 'Right to rectification',  body: 'Request correction of inaccurate or incomplete data.' },
  { label: 'Right to erasure',        body: 'Request deletion of your personal data in certain circumstances.' },
  { label: 'Right to restriction',    body: 'Request that we limit how we use your data.' },
  { label: 'Right to portability',    body: 'Receive your data in a structured, machine-readable format.' },
  { label: 'Right to object',         body: 'Object to processing based on legitimate interests.' },
];
---

<LegalLayout
  title="Data Processing Agreement"
  description="How theStacc processes your data under GDPR. Covers legal basis, data retention periods, sub-processors, and your data subject rights."
  lastUpdated="April 2026"
  badge="Legal · Compliance"
  tocItems={toc}
  currentPath="/data-processing/"
>
  <div class="flex flex-col gap-10">

    <section id="controller" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Data Controller</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          SOLARTREK VENTURES LLP acts as the data controller for personal data processed through our platform. We determine the purposes and means of processing your personal data in accordance with applicable data protection laws, including the General Data Protection Regulation (GDPR) where applicable.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="types" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Types of Data Processed</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">In the course of providing our services, we process the following categories of data:</p>
        <div class="flex flex-col gap-3">
          {dataTypes.map(item => (
            <div class="flex items-start gap-3">
              <span class="mt-[5px] h-1.5 w-1.5 shrink-0 rounded-full bg-[#4f39f6]"></span>
              <p class="font-sans text-[15px] leading-[1.7] text-[#57534e]">
                <strong class="font-semibold text-[#111827]">{item.label}:</strong> {item.body}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="legal-basis" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Legal Basis for Processing</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">We process your personal data on the following legal grounds:</p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {[
            { label: 'Contractual necessity', body: 'Processing required to deliver the services you have subscribed to.' },
            { label: 'Legitimate interests',  body: 'Improving our platform, fraud prevention, and security.' },
            { label: 'Legal obligation',      body: 'Compliance with applicable laws and regulations.' },
            { label: 'Consent',               body: 'For optional communications and non-essential cookies where required.' },
          ].map(item => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-4">
              <p class="font-sans text-[13px] font-semibold text-[#111827] mb-1">{item.label}</p>
              <p class="font-sans text-[13px] leading-[1.65] text-[#79716b]">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="retention" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Data Retention</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          We retain your personal data for as long as your account is active or as needed to provide our services. Upon account termination, we will delete or anonymize your personal data within 90 days, unless we are required to retain it for longer to comply with legal obligations, resolve disputes, or enforce our agreements.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="processors" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">5</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Third-Party Processors</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          We engage trusted third-party sub-processors to help deliver our services, including cloud infrastructure providers, payment processors, and AI model providers. All sub-processors are bound by data processing agreements and are required to implement appropriate security measures. A current list of sub-processors is available on request.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="transfers" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">6</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Cross-Border Transfers</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Your data may be transferred to and processed in countries outside your country of residence, including the United States. Where we transfer data from the European Economic Area, we rely on Standard Contractual Clauses or other appropriate safeguards as recognized under GDPR to ensure an adequate level of protection.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="rights" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">7</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Your Rights (GDPR)</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">
          If you are located in the European Economic Area, you have the following rights regarding your personal data:
        </p>
        <div class="flex flex-col gap-3">
          {gdprRights.map(item => (
            <div class="flex items-start gap-3">
              <svg class="mt-[3px] shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <p class="font-sans text-[15px] leading-[1.7] text-[#57534e]">
                <strong class="font-semibold text-[#111827]">{item.label}</strong> ,  {item.body}
              </p>
            </div>
          ))}
        </div>
        <p class="mt-5 font-sans text-[15px] leading-[1.75] text-[#57534e]">
          To exercise any of these rights, contact us at <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>. We will respond within 30 days.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="contact" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">8</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Contact</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          <strong class="font-semibold text-[#111827]">Company:</strong> SOLARTREK VENTURES LLP<br/>
          <strong class="font-semibold text-[#111827]">Address:</strong> Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India<br/>
          <strong class="font-semibold text-[#111827]">Email:</strong> <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>
        </p>
      </div>
    </section>

  </div>
</LegalLayout>
