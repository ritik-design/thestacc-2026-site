          <div class="tile-tooltip">${t.title}</div>
        `;
        grid.appendChild(el);
      });

      let cascadeTimer: ReturnType<typeof setTimeout> | null = null;

      function animateIn(delay = 0) {
        const tiles = grid.querySelectorAll('.article-tile');
        let count = 0;
        tiles.forEach((tile, i) => {
          setTimeout(() => {
            tile.classList.add('tile-visible');
            count++;
            if (countEl) countEl.textContent = count + ' articles queued';
          }, delay + i * 72);
        });
      }

      function resetAndAnimate() {
        if (cascadeTimer) clearTimeout(cascadeTimer);
        const tiles = grid.querySelectorAll<HTMLElement>('.article-tile');
        tiles.forEach((t) => {
          t.style.transition = 'none';
          t.classList.remove('tile-visible');
        });
        grid.getBoundingClientRect(); // force reflow
        tiles.forEach((t) => { t.style.transition = ''; });
        if (countEl) countEl.textContent = '0 articles queued';
        cascadeTimer = setTimeout(() => animateIn(0), 80);
      }

      // Month tab switching
      document.querySelectorAll<HTMLElement>('.grid-month-tab').forEach((tab) => {
