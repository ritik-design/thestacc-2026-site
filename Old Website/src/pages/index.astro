            t.style.borderBottomColor = 'transparent';
          });
          tab.style.color = '#818cf8';
          tab.style.borderBottomColor = '#4f39f6';
          resetAndAnimate();
        });
      });

      // Scroll-triggered first run
      const obs = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) { obs.disconnect(); animateIn(300); }
        },
        { threshold: 0.2 }
      );
      obs.observe(grid);
    })();
  </script>
