---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ExitIntent from '../components/common/ExitIntent.astro';
import { SITE_URL, LOGO_URL } from '../utils/schema';

const homepageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL, width: 512, height: 512 },
      description: 'AI-powered SEO content writing platform that publishes 30+ blog posts per month, manages Google Business Profiles, and automates social media for growing businesses.',
      founder: { '@type': 'Person', name: 'Siddharth Gangal', url: `${SITE_URL}/about/` },
      sameAs: ['https://www.linkedin.com/company/thestacc', 'https://x.com/thestacc'],
      contactPoint: { '@type': 'ContactPoint', contactType: 'customer support', url: `${SITE_URL}/contact/` },
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      name: 'theStacc',
      url: SITE_URL,
      publisher: { '@id': `${SITE_URL}/#organization` },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE_URL}/#software`,
      name: 'theStacc',
      description: 'AI-powered SEO content writing software that writes 30+ blog posts per month, automates SEO, and handles social media distribution.',
      url: SITE_URL,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: [
        { '@type': 'Offer', name: 'Blog SEO', price: '99.00', priceCurrency: 'USD', url: `${SITE_URL}/pricing/` },
        { '@type': 'Offer', name: 'Local SEO', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/pricing/` },
        { '@type': 'Offer', name: 'Social Media', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/pricing/` },
        { '@type': 'Offer', name: 'Bundle', price: '167.00', priceCurrency: 'USD', url: `${SITE_URL}/pricing/` },
