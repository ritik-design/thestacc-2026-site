---

<BaseLayout
  title="AI SEO Automation Software — Publish 30+ Posts/Month | theStacc"
  description="theStacc automates SEO content writing, Google Business Profile updates, and social media — publishing 30+ optimized posts a month on autopilot. $1 trial, cancel anytime."
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(homepageSchema)} />

    <!-- ─────────────────────────────────────────────────
         HERO. Dark, centered, interactive particle background
         Step 1: GET ATTENTION. Loss aversion, present-tense threat
         Step 2: PROBLEM agitation in subhead
         Step 3: SOLUTION. Mechanism + specifics
         ───────────────────────────────────────────────── -->
    <section id="hero-section" class="relative overflow-hidden" style="background:#ffffff;">
      <!-- Interactive particle canvas -->
      <canvas id="hero-canvas" class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

      <!-- Static grid overlay -->
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);" aria-hidden="true"></div>

      <!-- Purple radial glow top-center -->
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[700px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);" aria-hidden="true"></div>

      <!-- Mouse-follow interactive glow -->
      <div id="hero-mouse-glow" class="pointer-events-none absolute inset-0" aria-hidden="true"></div>

      <div class="container-x relative py-24 md:py-32 lg:py-40">
        <div class="mx-auto max-w-[1100px] text-center">

          <!-- Chip badge. Social proof upfront -->
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 font-mono text-[11px] font-medium text-[#79716b] shadow-sm backdrop-blur-sm">
            <span class="flex -space-x-1.5">
              {['DW','MR','JL','SP'].map((init) => (
                <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border-2 border-white font-mono text-[7px] font-bold text-white" style="background:linear-gradient(135deg,#4f39f6,#818cf8);">{init}</span>
              ))}
            </span>
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            127 businesses · 300k articles published · 4.9★ rating
          </span>

          <!-- H1: present-tense threat. Primal brain: loss aversion + identity threat -->
          <h1 class="mt-7 font-sans text-[2.25rem] font-semibold leading-[1.15] tracking-[-0.045em] text-[#292524] sm:text-[2.75rem] md:text-[3.5rem] lg:text-[4rem]">
            <span class="block"><span id="engine-word" style="display:inline-block;transition:opacity 0.2s ease,transform 0.2s ease;">Google</span> is sending your <span style="color:#ffffff;background:#4f39f6;padding:0 10px 2px;display:inline-block;">Customers</span></span>
            <span class="block">to your competitor<span class="text-[#292524]"> right now.</span></span>
          </h1>

          <!-- Subhead: agitate. Names the cause, makes inaction feel like a choice -->
          <p class="mx-auto mt-6 max-w-[540px] font-sans text-[0.95rem] leading-[1.7] text-[#57534e] md:text-[1.05rem]">
            Not because they're better at what they do. Because they're easier to find. Every search your customer runs is a chance for your competitor to answer that call instead of you.
          </p>

          <!-- Demo CTA -->
          <div class="mt-10 flex justify-center">
            <a
              href="/demo/"
              class="inline-flex items-center justify-center gap-2.5 rounded-xl bg-[#4f39f6] px-8 py-4 font-sans text-[15px] font-semibold text-white shadow-md transition-all hover:bg-[#615fff] hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0"
