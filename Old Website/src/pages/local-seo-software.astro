---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ExitIntent from '../components/common/ExitIntent.astro';

const faqs = [
  {
    q: "What is local SEO software?",
    a: "Local SEO software helps businesses manage the signals that determine how they rank in local search — including Google Business Profile activity, keyword rankings in the local pack and Google Maps, citation consistency across directories, and customer reviews. Stacc automates all of these tasks in one platform so local businesses and agencies don't have to manage them manually.",
  },
  {
    q: "What does Stacc do that a basic rank tracker doesn't?",
    a: "Most rank trackers only track rankings. Stacc also posts to your Google Business Profile daily, monitors and alerts on reviews in real time, manages citations across 50+ directories, and generates white-label client reports that deliver themselves. It's a complete local SEO operating system — not just a data dashboard.",
  },
  {
    q: "Does Stacc work for businesses with multiple locations?",
    a: "Yes — multi-location management is one of Stacc's core capabilities. Manage all locations from one dashboard, publish posts to all of them simultaneously, and generate individual or aggregate reports for each location. There's no practical limit on how many locations you can add.",
  },
  {
    q: "Is Stacc built for agencies or in-house marketing teams?",
    a: "Both. Agencies get white-label reporting, multi-client account management, and branded client portals. In-house teams at multi-location businesses get bulk management tools and automated reporting for internal stakeholders. The same platform serves both workflows.",
  },
  {
    q: "How is Stacc different from managing local SEO manually?",
    a: "Manual local SEO means logging into separate tools for rankings, GBP, citations, and reviews — then building reports by hand every month. Stacc connects all of these into one automated system. Data flows automatically. Reports generate and send automatically. You focus on strategy. Stacc handles execution.",
  },
  {
    q: "How long does it take to set up Stacc for a new location or client?",
    a: "Most setups complete in under 5 minutes — locations added, keywords configured, GBP connected, and automated reporting scheduled. For agencies with 10+ locations, allow 15–20 minutes. After setup, Stacc handles everything ongoing without additional time from your team.",
  },
  {
    q: "Does Stacc include white-label reporting for agencies?",
    a: "Yes. White-label reports — your logo, brand colors, and custom domain — are available on Growth and Scale plans. Reports are delivered under your brand. There's no Stacc branding visible to your clients.",
  },
  {
    q: "What integrations does Stacc support?",
    a: "Stacc integrates with Google Business Profile, Google Search Console, Google Analytics, Facebook, Instagram, WordPress, Webflow, Ghost, and Wix. All integrations are included — no per-integration fees.",
  },
  {
    q: "Can I cancel anytime?",
    a: "Yes. No contracts. No cancellation fees. Export your complete data history at any time before canceling. Your data belongs to you.",
  },
  {
    q: "What does Stacc cost?",
    a: "Plans start at $49/month for the Local SEO module. The Blog SEO module is $99/month. The Social Media module is $49/month. All modules include a $1 for 3 days.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Local SEO Software",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Local SEO software that automates GBP management, rank tracking, citation monitoring, review management, and client reporting for local businesses and agencies.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Local SEO module — $1 for 3 days"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Local SEO Software", "item": "https://thestacc.com/local-seo-software/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Local SEO Software for Agencies & Multi-Location Brands | theStacc"
  description="Automate local SEO across every location — GBP posting, citation building, rank tracking, review responses, and white-label reports. Built for agencies and multi-location brands. $1 trial."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Local SEO Software · From $49/month</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Local SEO that<br />does the work for you.
            <span style="color:#4f39f6;"> Not just tracks it.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Most local SEO tools give you dashboards. Stacc gives you automation. Google Business Profile, rank tracking, citation management, review monitoring, and white-label reporting — all running on their own, across every location.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See what's included
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No credit card to start · Cancel anytime
          </p>

          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">1,200+ locations managed</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Setup in under 5 minutes</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem with most local SEO tools</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            You've tried the tools.<br />You're still doing the work.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Maybe you have a rank tracker. Maybe you have a citation tool. Maybe you have something for reviews. And maybe you've stitched it together with spreadsheets and Slack messages and a weekly ritual of logging into five different platforms to build a report that took three hours and looked like it took fifteen minutes.
            </p>
            <p>
              That's the dirty secret of most local SEO software: <strong class="text-[#111827]">it tracks things. It doesn't do things.</strong> You still do things. The software just gives you a nicer view of how much work you have to do.
            </p>
            <p>
              Here's what that costs. Every manual rank check is 45 minutes you're not billing. Every citation audit is two hours of someone's day. Every client report is a tax on your Friday afternoon. Multiply that by 20 clients, 50 locations, 12 months — and you've spent a year doing work that should be automated.
            </p>
            <p class="font-semibold text-[#111827]">
              Your competitors are automating it. They're serving more clients, scaling faster, and looking more professional — not because they're smarter, but because they stopped doing manually what software should do automatically.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            One platform. Every local SEO lever.<br />All of it automated.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'Local SEO', price: '$49/mo', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['GBP post publishing — 30/month', 'Daily rank tracking — local pack + organic', 'Review monitoring — real-time alerts', 'Citation management — 50+ directories'], href: '/modules/local-seo/' },
            { title: 'Blog SEO', price: '$99/mo', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 SEO blog posts/month', 'Published directly to your site', 'Keyword research included', 'Internal linking optimized'], href: '/modules/content-seo/' },
            { title: 'Social Media', price: '$49/mo', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Daily posts with images', 'Instagram, LinkedIn, Facebook, X', 'Written and scheduled automatically', 'Brand-consistent content'], href: '/modules/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Learn more</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Key capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every local SEO task automated.<br />Every result visible.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP Post Automation</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 GBP posts a month. Published automatically. Targeting searches that drive calls.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google's Maps algorithm rewards businesses that post consistently with higher local pack visibility. Stacc writes 30 location-optimized posts per month — targeting your service + city keyword combinations, "near me" intent, emergency searches, and seasonal topics — then publishes them on schedule. Your profile stays active every day. You don't touch it.
              </p>
              <a href="/modules/local-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See the Local SEO module
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">This month's GBP posts</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 20 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Posts published so far</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">20 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:66%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">10 more scheduled · All automated · Zero manual work</p>
            </div>
          </div>

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Today's rank update</p>
              {[
                { kw: 'dentist near me', pack: 1, change: '+2', trend: 'up' },
                { kw: 'emergency dentist [city]', pack: 2, change: '+1', trend: 'up' },
                { kw: 'teeth whitening near me', pack: 3, change: '+4', trend: 'up' },
                { kw: 'dental implants [city]', pack: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Updated daily · Local pack + organic + Maps</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Daily Rank Tracking</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Know where you rank — in the local pack, in Maps, and in organic — every morning.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Rankings update daily across every tracked keyword at every location. You see your position in organic results and the local 3-pack separately — because for local businesses, the 3-pack is where almost all the high-intent clicks actually land. Alerts fire automatically when rankings change significantly, so you always know before your client does.
              </p>
              <a href="/features/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See rank tracking in detail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated White-Label Reporting</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Reports that build and send themselves. Every client. Every week. Under your brand.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                The moment you stop building reports by hand is the moment you start scaling. Set your template once per client. Stacc generates the report, formats it with your agency's branding, and delivers it to the client's inbox on schedule. No one on your team touches it. That's not just a time-saver — it's the thing that lets you double your client base without doubling your headcount.
              </p>
              <a href="/solutions/agencies/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See Stacc for agencies
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Your Agency</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Weekly Local SEO Report</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Sent</span>
              </div>
              {[
                { label: 'Ranking improvements', val: '+6 keywords in top 3' },
                { label: 'GBP posts published', val: '8 this week' },
                { label: 'New reviews received', val: '4 ⭐ avg 4.8' },
                { label: 'Estimated traffic value', val: '+$1,200 organic' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generated and delivered automatically · No manual work</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#0d1117]/10" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Results</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What consistent local SEO automation<br />does to your numbers.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Averages from businesses and agencies that let Stacc run their local SEO.
          </p>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(15,23,42,0.04);">
          {[
            { value: '4.7×',  num: 4.7,  prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Avg Maps ranking improvement', sub: 'within 90 days of consistent GBP activity' },
            { value: '8hrs',  num: 8,    prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Saved per client per month', sub: 'on manual local SEO and reporting tasks' },
            { value: '50+',   num: 50,   prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Directories monitored', sub: 'for citation accuracy — automatically' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/80">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
