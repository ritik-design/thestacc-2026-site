---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  { q: "What is a social media automation tool?", a: "A social media automation tool schedules, publishes, and manages social media posts without requiring manual execution each time. For local businesses, the most impactful automation is posting to Google Business Profile, Facebook, and Instagram across multiple locations simultaneously." },
  { q: "Which platforms does Stacc automate?", a: "Stacc automates publishing to Google Business Profile, Facebook Business Pages, and Instagram Business accounts. Posts can be published to one platform or all three simultaneously from a single workflow." },
  { q: "Can Stacc publish to multiple locations at once?", a: "Yes. Bulk publishing across locations is core functionality. Write one post, select all locations, and Stacc publishes to every selected location's profiles simultaneously — across all connected platforms." },
  { q: "Does social media automation actually improve GBP rankings?", a: "Yes. Regular GBP post activity is a documented local ranking signal. Consistent posting keeps your profile activity score high, which correlates with improved local pack visibility. Automated, consistent posting outperforms sporadic manual posting in terms of GBP ranking impact." },
  { q: "Can I schedule content weeks in advance?", a: "Yes. The content calendar lets you schedule posts as far in advance as needed. You can also set a recurring posting schedule and Stacc will publish automatically on that cadence — daily, weekly, or custom." },
  { q: "Is social media automation included in the Local SEO module?", a: "GBP post automation is included in the Local SEO module ($49/month). Facebook and Instagram scheduling are part of the Social Media module ($49/month), which also includes full content calendar management." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Social Media Automation Tool", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Social media automation tool for local businesses. Schedule and publish posts to GBP, Facebook, and Instagram across all locations simultaneously.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Social Media Automation Tool", "item": "https://thestacc.com/social-media-automation-tool/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Social Media Automation Tool for Local Businesses — Post to Every Location | theStacc"
  description="Automate social media posting across every location. theStacc publishes to GBP, Facebook, and Instagram simultaneously — bulk publishing, content calendar, and scheduled delivery."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Social Media Automation · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Post to every location at once.<br />
            <span style="color:#4f39f6;">GBP, Facebook, Instagram. Automated.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Write once. Stacc publishes to Google Business Profile, Facebook, and Instagram across all your locations simultaneously — on schedule, with location-specific customization, without manual work per location.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/features/social-scheduling/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See social scheduling
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">GBP automation</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Facebook scheduling</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Instagram scheduling</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Bulk multi-location</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Why manual posting doesn't work at scale</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Copy-paste posting across 20 locations<br />means most locations go dark.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>For one location, manual social posting is manageable. For five, it's annoying. For twenty, it doesn't happen — not consistently. So some locations get posts, most don't, and the ones that go quiet start losing GBP ranking ground to competitors who kept posting. The posting gap compounds: once you're behind on GBP activity, getting back to active status takes time you don't have.</p>
            <p class="font-semibold text-[#111827]">Social media automation for local businesses isn't a luxury — it's the only way to maintain consistent posting at scale. Stacc writes the posts, schedules them, and publishes to every location and every platform simultaneously. Your profiles stay active every single day without a single manual action.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automation capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every social publishing task automated.<br />Every location covered.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', title: 'GBP, Facebook, Instagram', body: 'Publish to all three platforms simultaneously from a single workflow. Or target specific platforms per post. One action covers every channel.' },
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Bulk multi-location publishing', body: 'Select all locations or a specific group and publish simultaneously. 20 locations updated in the time it used to take to post to 1.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Content calendar management', body: 'Plan and schedule weeks or months of content in a single session. Set recurring schedules and Stacc publishes automatically on your cadence.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Location-specific customization', body: 'Override per-location details — address, phone, local hashtags — before bulk publishing. Core content stays consistent; local details get localized.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Failed post alerts', body: 'If any post fails due to a disconnected account, Stacc flags it immediately and queues the post. You reconnect the account and the post publishes.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Publishing performance reporting', body: 'Track post performance across all locations and platforms. See which content types drive the most GBP views and engagement per location.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Social automation in action</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Write once. Publish everywhere.<br />Every location. Every platform.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Multi-Platform Bulk Publishing</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                One post brief. All platforms. All locations. Published simultaneously.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Write your post once, select which platforms to publish to (GBP, Facebook, Instagram — or all three), select which locations to target, and Stacc handles everything from there. Location-specific details like address, phone number, and local hashtags can be automatically swapped in per location before publishing. What used to take hours of tab-switching and copy-paste takes under two minutes for an entire portfolio.
              </p>
              <a href="/modules/social-media/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See the Social Media module
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Bulk publish — new promotion</p>
              <div class="mb-4 space-y-2">
                <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] bg-[#fafaf9] px-3 py-2">
                  <span class="font-sans text-[12px] text-[#374151]">Platforms</span>
                  <div class="flex gap-1.5">
                    {['GBP', 'FB', 'IG'].map(p => <span class="rounded bg-[#4f39f6] px-1.5 py-0.5 font-mono text-[9px] font-bold text-white">{p}</span>)}
                  </div>
                </div>
                <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] bg-[#fafaf9] px-3 py-2">
                  <span class="font-sans text-[12px] text-[#374151]">Locations</span>
                  <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">All 24 selected</span>
                </div>
                <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] bg-[#fafaf9] px-3 py-2">
                  <span class="font-sans text-[12px] text-[#374151]">Schedule</span>
                  <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">Tomorrow 9:00 AM</span>
                </div>
              </div>
              <div class="flex items-center justify-between rounded-xl bg-[#4f39f6] px-4 py-3">
                <span class="font-sans text-[13px] font-semibold text-white">Publish to all 24 locations</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">72 posts scheduled across 3 platforms</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Content calendar — this week</p>
              {[
                { day: 'Mon', platform: 'GBP + FB', content: 'Service spotlight — residential', status: 'published' },
                { day: 'Tue', platform: 'IG', content: 'Before/after project photos', status: 'published' },
                { day: 'Wed', platform: 'GBP', content: '"near me" seasonal post', status: 'scheduled' },
                { day: 'Thu', platform: 'GBP + FB + IG', content: 'Promo — 10% off this week', status: 'scheduled' },
                { day: 'Fri', platform: 'GBP', content: 'Weekend availability reminder', status: 'scheduled' },
              ].map(d => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-2.5">
                  <span class="w-8 font-mono text-[11px] font-semibold text-[#79716b]">{d.day}</span>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-medium text-[#111827] truncate">{d.content}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{d.platform}</p>
                  </div>
                  <span class={`shrink-0 rounded-full px-2 py-0.5 font-mono text-[9px] font-semibold ${d.status === 'published' ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>{d.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">All locations · All platforms · Auto-published</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Content Calendar</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Plan weeks of content in one session. Stacc publishes it automatically.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Batch your content work: plan and schedule a month of posts in a single session, then let Stacc execute everything on schedule. You can set recurring cadences (daily GBP posts, weekly Facebook updates, etc.) and Stacc handles all future publishing without further input. Content goes out every day, across every location, without anyone on your team remembering to post.
              </p>
              <a href="/features/social-scheduling/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See social scheduling features
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP Post Automation + Rankings</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Consistent GBP posting is a Maps ranking signal. Automation makes it consistent.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google rewards active GBP profiles with higher local pack visibility. Businesses that post consistently outperform those that post sporadically — which means automation doesn't just save time, it produces better ranking outcomes than manual posting ever does. Automated posting runs every day regardless of what's happening on your team. No holidays, no forgotten Fridays, no gaps in activity that cost you ranking ground.
              </p>
              <a href="/google-maps-ranking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See how GBP posting affects Maps ranking
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">GBP posting activity — 90 days</p>
              <div class="grid grid-cols-13 gap-1 mb-4" style="grid-template-columns: repeat(13, 1fr)">
                {Array.from({length: 90}).map((_, i) => (
                  <div class={`aspect-square rounded-sm ${i < 78 ? (i % 3 === 0 ? 'bg-[#4f39f6]' : 'bg-[#818cf8]/60') : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between mb-2">
                <span class="font-sans text-[12px] text-[#57534e]">Maps rank — "plumber near me"</span>
                <span class="font-mono text-[11px] font-semibold text-[#059669]">↑ #8 → #2</span>
              </div>
              <div class="h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-gradient-to-r from-[#ef4444] to-[#4f39f6]" style="width:75%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">90 days consistent posting · 6 position improvement</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 8, suffix: ' hrs', label: 'Saved per month per location', sub: 'No more manual copy-paste posting' },
            { to: 3, suffix: '×', label: 'More consistent posting', sub: 'Automated schedule vs manual memory' },
            { to: 89, suffix: '%', label: 'GBP ranking lift in 90 days', sub: 'Consistent activity vs inactive baseline' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What customers say</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every location stays active.<br />Every platform. Every day.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-2">
          {[
            { quote: "We manage 20 location pages across Facebook, Instagram, and GBP. Before Stacc, most locations went dark for weeks. Now they all get content every day without anyone on my team touching a post.", name: "Kevin M.", role: "Marketing Manager · 20 locations", result: "20 locations posting daily" },
            { quote: "The write-once, publish-everywhere workflow is the killer feature. One post brief and it's live on all platforms for all locations. Nobody else does this cleanly for local businesses at this price.", name: "Sarah T.", role: "Agency Owner · 30 clients", result: "All platforms in one workflow" },
            { quote: "GBP post consistency improved our Maps ranking faster than anything else we tried. And it's all automated — I haven't manually logged into a GBP account in three months.", name: "Mike D.", role: "HVAC Business Owner · Phoenix", result: "No manual GBP logins in 3 months" },
            { quote: "The failed post alerts are underrated. We used to have locations go dark when Facebook tokens expired and not know for days. Now we get notified immediately and fix it.", name: "Lisa N.", role: "Franchise Marketing Director", result: "Zero silent posting failures" },
          ].map(t => (
