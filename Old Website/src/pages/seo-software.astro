---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ExitIntent from '../components/common/ExitIntent.astro';

const faqs = [
  {
    q: "What is SEO software?",
    a: "SEO software helps businesses manage the signals that determine how they rank in search engines — including keyword rankings, on-page optimization, citations, Google Business Profile activity, and review generation. Modern SEO software goes beyond dashboards to automate the actual execution work: publishing content, updating listings, monitoring reviews, and delivering reports automatically.",
  },
  {
    q: "How is theStacc different from other SEO software?",
    a: "Most SEO tools are data tools. They track what's happening but leave all the doing to you. Stacc actually does the work — publishing GBP posts, syncing citations, monitoring reviews in real time, and delivering white-label reports on schedule. It's an execution platform, not just a reporting dashboard.",
  },
  {
    q: "Do I need multiple SEO tools if I use Stacc?",
    a: "For local SEO, no. Stacc replaces standalone rank trackers, GBP management tools, citation services, review monitoring tools, and reporting software. You manage everything from one platform. Agencies typically eliminate 4–5 separate subscriptions when switching to Stacc.",
  },
  {
    q: "Does Stacc work for businesses with multiple locations?",
    a: "Yes — multi-location management is a core capability. Manage every location from one dashboard, publish GBP posts to all locations simultaneously, and generate individual or aggregate performance reports per location. There's no practical cap on the number of locations you can add.",
  },
  {
    q: "Is Stacc built for agencies or in-house teams?",
    a: "Both. Agencies get white-label reporting, multi-client account management, and branded client portals. In-house teams at multi-location businesses get bulk management tools and automated reporting for internal stakeholders. The same platform serves both workflows without compromise.",
  },
  {
    q: "What does setup look like?",
    a: "Most setups complete in under 5 minutes — locations added, keywords configured, GBP connected, and automated reporting scheduled. After setup, Stacc handles everything ongoing without additional time from your team. There's no lengthy onboarding or technical integration required.",
  },
  {
    q: "Does Stacc include white-label reporting?",
    a: "Yes. White-label reports — your logo, brand colors, and custom domain — are available on Growth and Scale plans. Reports generate and deliver under your brand. Your clients never see any Stacc branding.",
  },
  {
    q: "What integrations does Stacc support?",
    a: "Stacc integrates with Google Business Profile, Google Search Console, Google Analytics, Facebook, Instagram, WordPress, Webflow, Ghost, and Wix. All integrations are included with your plan — no per-integration fees.",
  },
  {
    q: "How much does Stacc cost?",
    a: "Plans start at $49/month for the Local SEO module, which includes GBP post publishing, daily rank tracking, review monitoring, and citation management. The Blog SEO module is $99/month. The Social Media module is $49/month. All modules include a $1 for 3 days.",
  },
  {
    q: "Can I cancel anytime?",
    a: "Yes. No contracts. No cancellation fees. Export your complete data history at any time before canceling. Your data belongs to you.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO Software",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "All-in-one SEO software that automates local rankings, citations, reviews, GBP management, and reporting for businesses and agencies.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Local SEO module — starts at $49/month"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "SEO Software", "item": "https://thestacc.com/seo-software/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO Software — All-in-One Local SEO Automation at $49/Month | theStacc"
  description="Stop juggling 5 SEO tools. theStacc is the all-in-one SEO software that automates local rankings, citations, reviews, and reporting for businesses and agencies."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex flex-wrap items-center justify-center gap-3">
            {['All-in-one platform', '$49/month', '400+ agencies', 'No credit card', '$1 for 3 days'].map(chip => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>{chip}
              </span>
            ))}
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO software that<br />does the work.
            <span style="color:#4f39f6;"> Not just the tracking.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            You searched for SEO software because you're tired of paying for tools that give you data but leave the work to you. Stacc is different — it automates GBP posts, rank tracking, citation management, review monitoring, and white-label reporting. One platform. Everything automated.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No credit card to start · Cancel anytime
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ businesses and agencies</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1,200+ locations managed</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem with most SEO software</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            You're paying for five tools<br />and still doing all the work.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Here's how it usually goes. You sign up for a rank tracker. Then you add a citation tool because the rank tracker doesn't do that. Then you buy a GBP management tool because the citation tool doesn't post. Then you add a review platform. Then you're building your monthly reports in a spreadsheet because none of these tools talk to each other and none of them generate the kind of report a real client wants to look at.
            </p>
            <p>
              You now have five subscriptions, five logins, and you're spending more time managing your SEO toolstack than actually managing SEO. <strong class="text-[#111827]">The tools became the work.</strong> The real work — strategy, client relationships, growth — got pushed to whatever's left of Friday.
            </p>
            <p>
              This is the problem with fragmented SEO software: every tool optimizes for its own niche and no one solves for the whole workflow. You fill the gaps with your own time. And your time is the most expensive resource in the business.
            </p>
            <p class="font-semibold text-[#111827]">
              The agencies winning on local SEO right now aren't working harder. They consolidated everything into one automated platform and let the software handle execution. That's what Stacc is.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc includes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            One platform. Every SEO lever.<br />All of it automated.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'Local SEO', price: '$49/mo', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['GBP post publishing — 30/month', 'Daily rank tracking — local pack + organic', 'Review monitoring — real-time alerts', 'Citation management — 50+ directories'], href: '/modules/local-seo/' },
            { title: 'Blog SEO', price: '$99/mo', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 SEO blog posts/month', 'Published directly to your site', 'Keyword research included', 'Internal linking optimized'], href: '/modules/content-seo/' },
            { title: 'Social Media', price: '$49/mo', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Daily posts with images', 'Instagram, LinkedIn, Facebook, X', 'Written and scheduled automatically', 'Brand-consistent content'], href: '/modules/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Learn more</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Key capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Replace five tools with one.<br />Cut your time cost in half.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated Rank Tracking</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Every keyword, every location, every morning — without logging into a thing.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc tracks your rankings in the local 3-pack, Google Maps, and organic results daily across every keyword you care about. Alerts fire automatically when positions move significantly. You wake up knowing where you stand — without opening a single dashboard. For agencies managing 20 clients, this is the difference between spending Tuesday on rank checks or spending Tuesday on strategy.
              </p>
              <a href="/features/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See rank tracking in detail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Today's rank update — all clients</p>
              {[
                { client: 'Oakridge Plumbing', kw: 'plumber near me', pos: 1, change: '+3', trend: 'up' },
                { client: 'City Dental Group', kw: 'dentist [city]', pos: 2, change: '+2', trend: 'up' },
                { client: 'Elite HVAC', kw: 'HVAC repair near me', pos: 2, change: '+5', trend: 'up' },
                { client: 'Metro Law Firm', kw: 'lawyer near me', pos: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Updated daily · Local pack + organic + Maps</p>
            </div>
          </div>

          <!-- Citation Management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Citation health — all directories</p>
              {[
                { dir: 'Google Business Profile', status: 'Accurate', ok: true },
                { dir: 'Yelp', status: 'Accurate', ok: true },
                { dir: 'Apple Maps', status: 'Accurate', ok: true },
                { dir: 'Yellow Pages', status: 'Mismatch fixed', ok: true },
                { dir: 'Foursquare', status: 'Auto-corrected', ok: true },
              ].map(c => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{c.dir}</span>
                  <span class={`flex items-center gap-1.5 font-mono text-[11px] font-semibold ${c.ok ? 'text-[#059669]' : 'text-[#dc2626]'}`}>
                    {c.ok ? '✓' : '✗'} {c.status}
                  </span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ directories monitored · Corrections automated</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Citation Management</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Inconsistent citations hurt your rankings. Stacc finds and fixes them automatically.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google cross-references your business data across 50+ directories to verify you are who you say you are. When your name, address, or phone number doesn't match, your local rankings suffer. Stacc monitors every major directory continuously — and when it finds a discrepancy, it corrects it automatically. No more quarterly citation audits. No more manual submission tools.
              </p>
              <a href="/modules/local-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See citation management
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated Client Reporting</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Reports that build and send themselves. Under your brand. Every single week.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                For most agencies, client reporting is the tax that never goes away — hours every month that you can't bill and can't eliminate. Stacc eliminates them. Set your template once per client. Stacc generates the report, formats it with your branding, and delivers it to the client's inbox on schedule. The moment reporting becomes automatic is the moment you can scale past your current headcount ceiling.
              </p>
              <a href="/solutions/agencies/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See Stacc for agencies
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Your Agency</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Monthly SEO Performance Report</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Sent</span>
              </div>
              {[
                { label: 'Keywords moved to top 3', val: '+8 this month' },
                { label: 'GBP posts published', val: '30 automated' },
                { label: 'Reviews received', val: '11 ⭐ avg 4.7' },
                { label: 'Citation accuracy', val: '100% across 50+ dirs' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generated + delivered automatically · White-label branded</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#0d1117]/10" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Results</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What happens when SEO software<br />actually does the work.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Averages from businesses and agencies running local SEO on Stacc.
          </p>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(15,23,42,0.04);">
          {[
            { value: '5',    num: 5,   prefix: '', suffix: '', decimals: 0, from: 0, label: 'Tools replaced by one Stacc account', sub: 'rank tracker, citations, reviews, GBP, reporting' },
            { value: '8hrs', num: 8,   prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Saved per client per month', sub: 'on manual SEO and reporting tasks' },
            { value: '4.7×', num: 4.7, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Avg Maps ranking improvement', sub: 'within 90 days of consistent automation' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
