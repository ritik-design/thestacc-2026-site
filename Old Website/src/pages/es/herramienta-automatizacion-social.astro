---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué es una herramienta de automatización de redes sociales?", a: "Una herramienta de automatización de redes sociales programa, publica y gestiona posts en redes sociales sin necesidad de ejecución manual en cada ocasión. Para negocios locales, la automatización más impactante consiste en publicar en Google Business Profile, Facebook e Instagram en múltiples ubicaciones simultáneamente." },
  { q: "¿Qué plataformas automatiza Stacc?", a: "Stacc automatiza la publicación en Google Business Profile, páginas de Facebook Business y cuentas de Instagram Business. Los posts pueden publicarse en una sola plataforma o en las tres simultáneamente desde un único flujo de trabajo." },
  { q: "¿Puede Stacc publicar en varias ubicaciones a la vez?", a: "Sí. La publicación masiva entre ubicaciones es una funcionalidad central. Redacta un post, selecciona todas las ubicaciones y Stacc lo publica en los perfiles de todas las ubicaciones seleccionadas simultáneamente — en todas las plataformas conectadas." },
  { q: "¿La automatización de redes sociales mejora realmente el posicionamiento en GBP?", a: "Sí. La actividad regular de publicación en GBP es una señal de posicionamiento local documentada. La publicación constante mantiene alta la puntuación de actividad de tu perfil, lo que se correlaciona con una mayor visibilidad en el paquete local. La publicación automatizada y consistente supera a la publicación manual esporádica en cuanto al impacto en el posicionamiento de GBP." },
  { q: "¿Puedo programar contenido con semanas de antelación?", a: "Sí. El calendario de contenido te permite programar posts con la antelación que necesites. También puedes establecer una programación de publicación recurrente y Stacc publicará automáticamente con esa cadencia — diaria, semanal o personalizada." },
  { q: "¿La automatización de redes sociales está incluida en el módulo de SEO Local?", a: "La automatización de posts en GBP está incluida en el módulo de SEO Local ($49/mes). La programación en Facebook e Instagram forma parte del módulo de Redes Sociales ($49/mes), que también incluye la gestión completa del calendario de contenido." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "inLanguage": "es", "name": "theStacc — Herramienta de Automatización de Redes Sociales", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Herramienta de automatización de redes sociales para negocios locales. Programa y publica posts en GBP, Facebook e Instagram en todas las ubicaciones simultáneamente.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Herramienta de Automatización de Redes Sociales", "item": "https://thestacc.com/es/herramienta-automatizacion-social/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Herramienta de Automatización de Redes Sociales para Negocios Locales — Publica en Cada Ubicación | theStacc"
  description="Automatiza la publicación en redes sociales en todas tus ubicaciones. theStacc publica en GBP, Facebook e Instagram simultáneamente — publicación masiva, calendario de contenido y entrega programada."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Automatización de Redes Sociales · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Publica en todas las ubicaciones a la vez.<br />
            <span style="color:#4f39f6;">GBP, Facebook, Instagram. Automatizado.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Redacta una vez. Stacc publica en Google Business Profile, Facebook e Instagram en todas tus ubicaciones simultáneamente — de forma programada, con personalización por ubicación y sin trabajo manual por cada localización.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/funciones/programacion-social/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver programación social
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito para empezar · 30 días de garantía · Cancela en cualquier momento</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas y agencias</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ ubicaciones gestionadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué la publicación manual no funciona a escala</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Copiar y pegar posts en 20 ubicaciones<br />significa que la mayoría se quedan en silencio.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Para una ubicación, la publicación manual en redes sociales es manejable. Para cinco, es molesta. Para veinte, directamente no ocurre — no de forma consistente. Entonces, algunas ubicaciones reciben posts, la mayoría no, y las que se quedan sin actividad empiezan a perder posicionamiento en GBP frente a competidores que siguieron publicando. La brecha de publicación se acumula: una vez que quedas atrás en actividad de GBP, recuperarla requiere tiempo que no tienes.</p>
            <p class="font-semibold text-[#111827]">La automatización de redes sociales para negocios locales no es un lujo — es la única forma de mantener una publicación consistente a escala. Stacc redacta los posts, los programa y los publica en cada ubicación y plataforma simultáneamente. Tus perfiles se mantienen activos todos los días sin una sola acción manual.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de automatización</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarea de publicación social automatizada.<br />Cada ubicación cubierta.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', title: 'GBP, Facebook, Instagram', body: 'Publica en las tres plataformas simultáneamente desde un único flujo de trabajo. O selecciona plataformas específicas por post. Una acción cubre todos los canales.' },
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Publicación masiva en múltiples ubicaciones', body: 'Selecciona todas las ubicaciones o un grupo específico y publica simultáneamente. 20 ubicaciones actualizadas en el tiempo que antes se tardaba en publicar en 1.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Gestión del calendario de contenido', body: 'Planifica y programa semanas o meses de contenido en una sola sesión. Establece programaciones recurrentes y Stacc publicará automáticamente con tu cadencia.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Personalización por ubicación', body: 'Modifica detalles por ubicación — dirección, teléfono, hashtags locales — antes de publicar en masa. El contenido principal se mantiene coherente; los detalles locales se localizan.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Alertas de publicaciones fallidas', body: 'Si algún post falla por una cuenta desconectada, Stacc lo señala de inmediato y lo pone en cola. Reconecta la cuenta y el post se publica.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Informes de rendimiento de publicaciones', body: 'Controla el rendimiento de los posts en todas las ubicaciones y plataformas. Comprueba qué tipos de contenido generan más visualizaciones y engagement en GBP por ubicación.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatización social en detalle</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cómo Stacc mantiene tus perfiles activos<br />sin que toques nada.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Feature 1 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicación automática diaria</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Contenido publicado automáticamente, cada día.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc genera y publica 30 posts al mes por ubicación en GBP sin que ningún miembro de tu equipo tenga que escribir, programar o hacer clic en publicar. El contenido se alinea con las palabras clave locales de tu negocio, los servicios que ofreces y las búsquedas de alta intención en tu mercado. Cada post sale en el horario programado. Los perfiles permanecen activos todos los días — que es exactamente lo que Google recompensa con mejor posicionamiento en Maps.
              </p>
              <a href="/es/funciones/programacion-social/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver programación social
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario de publicaciones — mayo</p>
              <div class="grid grid-cols-7 gap-1 mb-3">
                {['L','M','X','J','V','S','D'].map(d => (
                  <div class="text-center font-mono text-[9px] text-[#79716b] uppercase">{d}</div>
                ))}
                {Array.from({length: 31}).map((_, i) => (
                  <div class={`rounded text-center font-mono text-[10px] py-1 ${i < 28 ? 'bg-[#f5f3ff] text-[#4f39f6] font-semibold' : 'bg-[#fafaf9] text-[#79716b]'}`}>
                    {i + 1 <= 31 ? i + 1 : ''}
                  </div>
                ))}
              </div>
              <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 posts publicados · 0 acciones manuales</p>
            </div>
          </div>

          <!-- Feature 2 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Cola de contenido — próximos posts</p>
              {[
                { title: 'Servicio de instalación de caldera', platform: 'GBP + Facebook', status: 'Programado ✓', date: '15 May, 10:00' },
                { title: 'Mantenimiento de climatización — oferta verano', platform: 'GBP + Instagram', status: 'Programado ✓', date: '18 May, 10:00' },
                { title: '¿Problema con tu fontanería? Disponibles 24h', platform: 'GBP', status: 'Programado ✓', date: '21 May, 10:00' },
                { title: 'Reseñas de clientes satisfechos', platform: 'GBP + Facebook + Instagram', status: 'Programado ✓', date: '24 May, 10:00' },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center justify-between">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.title}</p>
                    <span class="font-mono text-[10px] text-[#059669]">{r.status}</span>
                  </div>
                  <div class="mt-1 flex items-center gap-3">
                    <p class="font-mono text-[10px] text-[#79716b]">{r.platform}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.date}</p>
                  </div>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Del calendario al feed · Sin trabajo manual</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Flujo sin fricción</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Del calendario al feed, sin trabajo manual.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El flujo completo de publicación — desde la creación del contenido hasta la publicación en las plataformas — ocurre de forma autónoma. Puedes programar el contenido con semanas de antelación en una sesión y Stacc ejecuta la publicación en los horarios programados. Para las ubicaciones con contenido específico, puedes personalizar los detalles locales antes de programar. Una vez aprobado, el proceso de publicación es completamente automático.
              </p>
              <a href="/es/automatizacion-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automatización SEO local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Feature 3 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Métricas de rendimiento</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes de rendimiento en redes.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc no solo publica — también mide. El panel de rendimiento te muestra qué posts generan más vistas, clics en llamadas y engagement en cada plataforma por ubicación. Puedes comparar el rendimiento entre ubicaciones, identificar qué tipos de contenido funcionan mejor y refinar tu estrategia con datos reales. Para las agencias, los datos de rendimiento social se incluyen en los informes white label que se entregan automáticamente a los clientes.
              </p>
              <a href="/es/software-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver software SEO local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Resumen de rendimiento — mayo</p>
              {[
                { metric: 'Posts publicados', value: '30', change: '✓ Completo' },
                { metric: 'Vistas en GBP', value: '1.842', change: '▲ +23%' },
                { metric: 'Clics en llamadas desde GBP', value: '94', change: '▲ +18%' },
                { metric: 'Interacciones en Facebook', value: '312', change: '▲ +11%' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">{r.metric}</span>
                  <div class="text-right">
                    <span class="font-mono text-[12px] font-semibold text-[#111827]">{r.value}</span>
                    <span class="ml-2 font-mono text-[10px] text-[#059669]">{r.change}</span>
                  </div>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Datos actualizados automáticamente</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que entrega la automatización<br />social consistente.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '30', num: 30, prefix: '', suffix: '', decimals: 0, from: 0, label: 'Posts publicados al mes automáticamente', sub: 'por ubicación, sin ninguna acción manual' },
            { value: '8 hrs', num: 8, prefix: '', suffix: ' hrs', decimals: 0, from: 0, label: 'Economizadas por ubicación/mes', sub: 'la automatización elimina el trabajo de publicación manual' },
            { value: '4,7×', num: 4.7, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Mejora en posicionamiento GBP', sub: 'la publicación consistente mejora la visibilidad en Maps' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
