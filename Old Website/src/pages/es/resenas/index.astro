---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import { getCollection } from 'astro:content';

const enReviews = await getCollection('reviews');
const langReviews = await getCollection('reviews_es');
const langBySlug = new Map(langReviews.map(r => [r.data.slug, r]));
const reviews = enReviews.filter(r => langBySlug.has(r.data.slug)).map(r => langBySlug.get(r.data.slug)!);
const byDate = [...reviews].sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const byAlpha = [...reviews].sort((a, b) => a.data.title.localeCompare(b.data.title));
const visibleByDate = byDate.filter(r => r.data.image);
const visibleByAlpha = byAlpha.filter(r => r.data.image);

function readTime(body: string): number {
  const words = (body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const howWeReview = [
  { icon: '💰', label: 'Precios reales', detail: 'Verificados en páginas oficiales' },
  { icon: '⚖️', label: 'Pros y contras honestos', detail: 'Incluyendo dónde perdemos' },
  { icon: '🏁', label: 'Veredicto claro', detail: 'Para quién es, quién debe omitirlo' },
  { icon: '📊', label: 'Desglose de funciones', detail: 'Comparación lado a lado con alternativas' },
];

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://thestacc.com/es/' },
        { '@type': 'ListItem', position: 2, name: 'Reseñas', item: 'https://thestacc.com/es/resenas/' },
      ],
    },
  ],
};
---

<BaseLayout
  title="Reseñas de Herramientas SEO 2026 — Calificaciones y Veredictos Honestos | theStacc"
  description="Reseñas honestas y detalladas de las principales herramientas SEO y de contenido con IA. Precios reales, pros y contras reales, veredictos reales. Escritas por profesionales."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  <main class="flex-1">

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-12 pb-12">

        <nav aria-label="Migas de pan" class="mb-3">
          <ol class="flex items-center gap-1.5 font-mono text-[11px] text-[#a8a29e]">
            <li><a href="/es/" class="hover:text-[#57534e] transition-colors">Inicio</a></li>
            <li class="before:content-['/'] before:mx-1.5 text-[#79716b]">Reseñas</li>
          </ol>
        </nav>

        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Reseñas</span>
          <span class="h-3 w-px bg-[#e7e5e4]"></span>
          <span class="font-mono text-[10px] text-[#79716b]">{visibleByDate.length} herramientas reseñadas</span>
        </div>

        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px]">
          Reseñas de Herramientas SEO
        </h1>
        <p class="mt-3 max-w-[560px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Lee antes de comprar. Reseñas honestas y detalladas de las principales herramientas SEO y de contenido con IA. Precios reales, pros y contras reales, veredictos reales. Escritas por profesionales.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {[
            `${visibleByDate.length} herramientas reseñadas`,
            'Actualizado marzo 2026',
            'Veredictos reales',
            'Declarado: escrito por competidor',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- HOW WE REVIEW -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x">
        <div class="flex items-center gap-6 overflow-x-auto py-4" style="-ms-overflow-style:none;scrollbar-width:none;">
          {howWeReview.map(item => (
            <div class="flex shrink-0 items-center gap-2.5">
              <span class="text-[16px]">{item.icon}</span>
              <div>
                <p class="font-mono text-[11px] font-bold text-[#292524]">{item.label}</p>
                <p class="font-mono text-[10px] text-[#79716b]">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- SORT + DISCLOSURE -->
    <div class="sticky top-0 z-20 border-b border-[#e7e5e4] bg-white">
      <div class="container-x flex items-center justify-between py-3">
        <div class="flex items-center gap-1" id="sort-tabs">
          <button data-sort="date" class="sort-tab active">Más recientes</button>
          <button data-sort="alpha" class="sort-tab">A–Z</button>
        </div>
        <p class="hidden font-mono text-[10px] text-[#79716b] sm:block">
          Aviso: escrito por theStacc, un producto competidor. Todos los datos verificados públicamente.
        </p>
      </div>
    </div>

    <!-- CARD GRID -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-6xl">

        <div id="grid-date" class="sort-panel">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {visibleByDate.map((review) => (
              <a href={`/es/resenas/${review.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
                <div class="flex flex-1 flex-col p-6">
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Reseña</span>
                    <span class="ml-auto flex items-center gap-0.5">
                      {[1,2,3,4,5].map(s => (
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill={s <= 4 ? '#f59e0b' : 'none'} stroke="#f59e0b" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      ))}
                    </span>
                  </div>
                  <h2 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{review.data.title}</h2>
                  <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{review.data.description}</p>
                  <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                    <span class="font-mono text-[10px] text-[#79716b]">{review.data.date} · {readTime(review.body ?? '')} min</span>
                    <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div id="grid-alpha" class="sort-panel hidden">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {visibleByAlpha.map((review) => (
              <a href={`/es/resenas/${review.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
                <div class="flex flex-1 flex-col p-6">
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Reseña</span>
                    <span class="ml-auto flex items-center gap-0.5">
                      {[1,2,3,4,5].map(s => (
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill={s <= 4 ? '#f59e0b' : 'none'} stroke="#f59e0b" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      ))}
                    </span>
                  </div>
                  <h2 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{review.data.title}</h2>
                  <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{review.data.description}</p>
                  <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                    <span class="font-mono text-[10px] text-[#79716b]">{review.data.date} · {readTime(review.body ?? '')} min</span>
                    <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- FOOTER CTA -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#818cf8]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Omite la investigación. Obtén el tráfico.
        </h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          theStacc publica 30 artículos SEO en tu sitio cada mes. Automáticamente. Sin escritores. Sin flujo de trabajo.
        </p>
        <a
          href="/es/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Comenzar por $1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">$1 por 30 días · Cancela cuando quieras</p>
      </div>
    </section>

  </main>
  <Footer />

  <style>
  .sort-tab { cursor: pointer; padding: 0.4rem 0.875rem; font-family: var(--font-geist-mono); font-size: 12px; font-weight: 600; color: #57534e; background: transparent; border: none; white-space: nowrap; transition: color 0.1s, background 0.1s; }
  .sort-tab:hover { color: #4f39f6; background: #f5f3ff; }
  .sort-tab.active { color: #4f39f6; background: #f5f3ff; }
  </style>

  <script>
  const sortTabs = document.querySelectorAll('.sort-tab');
  const sortPanels = document.querySelectorAll('.sort-panel');
  sortTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const sort = (tab as HTMLElement).dataset.sort;
      sortTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      sortPanels.forEach((panel: any) => { const id = panel.id.replace('grid-', ''); panel.classList.toggle('hidden', id !== sort); });
    });
  });
  </script>
</BaseLayout>
