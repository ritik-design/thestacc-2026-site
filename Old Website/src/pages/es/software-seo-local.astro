---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué es el software de SEO local?",
    a: "El software de SEO local ayuda a las empresas a gestionar las señales que determinan su posicionamiento en la búsqueda local — incluyendo la actividad en Google Business Profile, las posiciones de palabras clave en el pack local y Google Maps, la consistencia de citaciones en directorios, y las reseñas de clientes. Stacc automatiza todas estas tareas en una sola plataforma para que negocios locales y agencias no tengan que gestionarlas manualmente.",
  },
  {
    q: "¿Qué hace Stacc que un rastreador de posiciones básico no hace?",
    a: "La mayoría de los rastreadores solo monitorizan posiciones. Stacc también publica en tu Google Business Profile diariamente, monitoriza y alerta sobre reseñas en tiempo real, gestiona citaciones en más de 50 directorios y genera informes de marca blanca para clientes que se envían solos. Es un sistema operativo completo de SEO local — no solo un panel de datos.",
  },
  {
    q: "¿Stacc funciona para negocios con múltiples ubicaciones?",
    a: "Sí — la gestión multi-ubicación es una de las capacidades principales de Stacc. Gestiona todas las ubicaciones desde un panel, publica en todas ellas simultáneamente y genera informes individuales o agregados para cada ubicación. No hay límite práctico en el número de ubicaciones que puedes añadir.",
  },
  {
    q: "¿Stacc está diseñado para agencias o para equipos de marketing internos?",
    a: "Para ambos. Las agencias obtienen informes de marca blanca, gestión de cuentas multi-cliente y portales de cliente personalizados. Los equipos internos en negocios multi-ubicación obtienen herramientas de gestión masiva e informes automatizados para partes interesadas internas. La misma plataforma sirve ambos flujos de trabajo.",
  },
  {
    q: "¿En qué se diferencia Stacc de gestionar el SEO local manualmente?",
    a: "El SEO local manual significa iniciar sesión en herramientas separadas para posiciones, GBP, citaciones y reseñas — y luego construir informes a mano cada mes. Stacc conecta todo esto en un sistema automatizado. Los datos fluyen automáticamente. Los informes se generan y envían automáticamente. Tú te enfocas en la estrategia. Stacc se encarga de la ejecución.",
  },
  {
    q: "¿Cuánto tiempo lleva configurar Stacc para una nueva ubicación o cliente?",
    a: "La mayoría de las configuraciones se completan en menos de 5 minutos — ubicaciones añadidas, palabras clave configuradas, GBP conectado y reportes automáticos programados. Para clientes con más de 10 ubicaciones, calcula una hora. Tras la configuración, Stacc lo gestiona todo sin tiempo adicional de tu equipo.",
  },
  {
    q: "¿Stacc incluye informes de marca blanca para agencias?",
    a: "Sí. Los informes de marca blanca — tu logo, colores de marca y dominio personalizado — están disponibles en los planes Growth y Scale. Los informes se entregan bajo tu marca. No hay ninguna marca visible de Stacc para tus clientes.",
  },
  {
    q: "¿Qué integraciones admite Stacc?",
    a: "Stacc se integra con Google Business Profile, Google Search Console, Google Analytics, Facebook, Instagram, WordPress, Webflow, Ghost y Wix. Todas las integraciones están incluidas — sin cargos por integración.",
  },
  {
    q: "¿Puedo cancelar en cualquier momento?",
    a: "Sí. Sin contratos. Sin cargos por cancelación. Exporta tu historial completo de datos en cualquier momento antes de cancelar. Tus datos son tuyos.",
  },
  {
    q: "¿Cuánto cuesta Stacc?",
    a: "Los planes comienzan en $49/mes para el módulo de SEO Local. El módulo de Blog SEO es $99/mes. El módulo de Redes Sociales es $49/mes. Todos los módulos incluyen un período de prueba gratuita de 14 días comenzando desde $1.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software de SEO Local",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Software de SEO local que automatiza la gestión de GBP, rastreo de posiciones, monitoreo de citaciones, gestión de reseñas e informes para negocios locales y agencias.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Módulo de SEO Local — prueba de 14 días desde $1"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Software de SEO Local", "item": "https://thestacc.com/es/software-seo-local/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Software de SEO Local — Automatiza el SEO Local en Cada Ubicación | theStacc"
  description="theStacc es el software de SEO local que hace el trabajo — no solo lo monitoriza. Gestión de GBP, rastreo de posiciones, monitoreo de citaciones e informes automatizados en piloto automático."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de SEO Local · Desde $49/mes</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local que<br />hace el trabajo por ti.
            <span style="color:#4f39f6;"> No solo lo monitoriza.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            La mayoría de herramientas de SEO local te dan paneles. Stacc te da automatización. Google Business Profile, rastreo de posiciones, gestión de citaciones, monitoreo de reseñas e informes de marca blanca — todo funcionando solo, en cada ubicación.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empezar desde $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver qué incluye
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sin tarjeta de crédito para empezar · 30 días de garantía · Cancela cuando quieras
          </p>

          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">+1.200 ubicaciones gestionadas</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuración en menos de 5 minutos</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema con la mayoría de herramientas de SEO local</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Probaste las herramientas.<br />Sigues haciendo el trabajo tú.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Quizás tienes un rastreador de posiciones. Quizás una herramienta de citaciones. Quizás algo para las reseñas. Y tal vez lo has unido todo con hojas de cálculo, mensajes de Slack y el ritual semanal de iniciar sesión en cinco plataformas para construir un informe que llevó tres horas y parecía que llevó quince minutos.
            </p>
            <p>
              Ese es el secreto sucio de la mayoría del software de SEO local: <strong class="text-[#111827]">monitoriza cosas. No hace cosas.</strong> Sigues haciendo tú las cosas. El software solo te da una vista más bonita de cuánto trabajo tienes que hacer.
            </p>
            <p>
              Esto es lo que cuesta. Cada verificación manual de posiciones son 45 minutos que no facturas. Cada auditoría de citaciones son dos horas del día de alguien. Cada informe de cliente es un impuesto en tu tarde del viernes. Multiplícalo por 20 clientes, 50 ubicaciones, 12 meses — y has pasado un año haciendo trabajo que debería estar automatizado.
            </p>
            <p class="font-semibold text-[#111827]">
              Tus competidores lo están automatizando. Atienden más clientes, escalan más rápido y parecen más profesionales — no porque sean más inteligentes, sino porque dejaron de hacer manualmente lo que el software debería hacer automáticamente.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lo que hace Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una plataforma. Cada palanca de SEO local.<br />Todo automatizado.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Local', price: '$49/mes', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Publicaciones GBP — 30/mes', 'Rastreo diario de posiciones — pack local + orgánico', 'Monitoreo de reseñas — alertas en tiempo real', 'Gestión de citaciones — +50 directorios'], href: '/es/modulos/seo-local/' },
            { title: 'Blog SEO', price: '$99/mes', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 artículos SEO/mes', 'Publicados directamente en tu sitio', 'Investigación de palabras clave incluida', 'Enlazado interno optimizado'], href: '/es/modulos/seo-contenido/' },
            { title: 'Redes Sociales', price: '$49/mes', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Publicaciones diarias con imágenes', 'Instagram, LinkedIn, Facebook, X', 'Escritas y programadas automáticamente', 'Contenido consistente con la marca'], href: '/es/modulos/redes-sociales/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Saber más</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades clave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarea de SEO local automatizada.<br />Cada resultado visible.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatización de Publicaciones GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 publicaciones GBP al mes. Publicadas automáticamente. Orientadas a búsquedas que generan llamadas.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El algoritmo de Maps de Google recompensa a los negocios que publican con consistencia con mayor visibilidad en el pack local. Stacc escribe 30 publicaciones optimizadas por ubicación al mes — orientadas a tus combinaciones de servicio + ciudad, intención "cerca de mí", búsquedas de emergencia y temas estacionales — y las publica según el calendario. Tu perfil permanece activo cada día. Tú no lo tocas.
              </p>
              <a href="/es/modulos/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el módulo de SEO Local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Publicaciones GBP de este mes</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 20 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Publicaciones realizadas hasta ahora</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">20 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:66%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">10 más programadas · Todo automatizado · Cero trabajo manual</p>
            </div>
          </div>

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Actualización de posiciones de hoy</p>
              {[
                { kw: 'dentista cerca de mí', pack: 1, change: '+2', trend: 'up' },
                { kw: 'dentista urgencias [ciudad]', pack: 2, change: '+1', trend: 'up' },
                { kw: 'blanqueamiento dental cerca de mí', pack: 3, change: '+4', trend: 'up' },
                { kw: 'implantes dentales [ciudad]', pack: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Actualizado diariamente · Pack local + orgánico + Maps</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreo Diario de Posiciones</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sabe dónde posicionas — en el pack local, en Maps y en orgánico — cada mañana.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Las posiciones se actualizan diariamente en cada palabra clave rastreada en cada ubicación. Ves tu posición en resultados orgánicos y en el pack local de 3 por separado — porque para negocios locales, el pack de 3 es donde aterrizan casi todos los clics de alta intención. Las alertas se activan automáticamente cuando las posiciones cambian significativamente, para que siempre lo sepas antes que tu cliente.
              </p>
              <a href="/es/funciones/rastreo-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el rastreo de posiciones en detalle
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informes Automatizados de Marca Blanca</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes que se construyen y envían solos. Cada cliente. Cada semana. Bajo tu marca.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El momento en que dejas de construir informes a mano es el momento en que empiezas a escalar. Configura tu plantilla una vez por cliente. Stacc genera el informe, lo formatea con la marca de tu agencia y lo entrega en la bandeja de entrada del cliente según el calendario. Nadie en tu equipo lo toca. Eso no es solo un ahorro de tiempo — es lo que te permite duplicar tu base de clientes sin duplicar tu plantilla.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Tu Agencia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Informe Semanal de SEO Local</p>
                </div>
