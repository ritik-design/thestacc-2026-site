---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué es el software SEO para múltiples ubicaciones?", a: "El software SEO para múltiples ubicaciones permite a las empresas gestionar la optimización en búsqueda local en todas sus sedes desde una sola plataforma: seguimiento de posiciones, gestión de citaciones, monitoreo de reseñas y publicación en GBP de forma masiva, en lugar de hacerlo ubicación por ubicación." },
  { q: "¿Cómo gestiona Stacc el seguimiento de posiciones para múltiples ubicaciones?", a: "Cada ubicación tiene su propio conjunto de palabras clave rastreadas diariamente. Puedes ver el posicionamiento de cada sede en el paquete local, Maps y los resultados orgánicos. El panel de portafolio compara todas las ubicaciones en paralelo para que puedas ver al instante cuáles están mejorando y cuáles necesitan atención." },
  { q: "¿Puedo publicar posts en GBP para todas las ubicaciones a la vez?", a: "Sí. Redacta un post y publícalo en todas las ubicaciones simultáneamente, o personaliza detalles por sede antes de publicar de forma masiva. Stacc gestiona las llamadas a la API de GBP para cada ubicación con una sola acción." },
  { q: "¿Puedo gestionar citaciones para múltiples ubicaciones de forma masiva?", a: "Sí. Stacc monitorea la precisión de las citaciones en más de 50 directorios para cada ubicación y señala las inconsistencias. Las correcciones se pueden aplicar a múltiples ubicaciones a la vez desde el editor masivo." },
  { q: "¿Existe un límite en la cantidad de ubicaciones que puedo agregar?", a: "Sin límite estricto. Los clientes gestionan más de 500 ubicaciones en una sola cuenta. La plataforma está diseñada para portafolios de escala empresarial." },
  { q: "¿Stacc admite informes de marca blanca para clientes con múltiples ubicaciones?", a: "Sí. Cada cliente puede tener su propio portal con marca personalizada, dominio propio y logotipo. Los informes se generan y entregan automáticamente bajo la marca de tu agencia." },
  { q: "¿Cuánto tiempo lleva incorporar una nueva ubicación?", a: "Aproximadamente 2 minutos. Introduce los datos básicos del negocio, conecta el perfil de GBP y Stacc propaga la configuración a través de tu red de citaciones automáticamente." },
  { q: "¿Cuánto cuesta el software SEO para múltiples ubicaciones?", a: "El módulo SEO local de Stacc comienza desde $49/mes. Todas las funciones para múltiples ubicaciones — gestión masiva, informes de portafolio, panel comparativo — están incluidas." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "inLanguage": "es", "name": "theStacc — Software SEO para Múltiples Ubicaciones", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Software SEO para múltiples ubicaciones que automatiza posicionamiento, citaciones, gestión de GBP e informes en todas tus sedes desde un solo panel.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Software SEO para Múltiples Ubicaciones", "item": "https://thestacc.com/es/software-seo-multi-ubicacion/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software SEO para Múltiples Ubicaciones — Gestiona Todas tus Sedes desde un Solo Panel | theStacc"
  description="Deja de gestionar el SEO local sede por sede. El software SEO para múltiples ubicaciones de theStacc gestiona seguimiento de posiciones, citaciones, GBP e informes de todas tus sedes simultáneamente."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software SEO Multi-Ubicación · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO multi-ubicación que se gestiona<br />
            <span style="color:#4f39f6;">solo en todas tus sedes.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc gestiona posicionamiento, posts de GBP, citaciones, reseñas e informes para todas las ubicaciones simultáneamente. No es un panel que requiere trabajo manual — es una plataforma que hace el trabajo.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver qué está incluido
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito · Cancela cuando quieras</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Portafolios de más de 500 ubicaciones gestionados</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuración en menos de 5 minutos</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué el SEO multi-ubicación se rompe a escala</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada ubicación necesita trabajo diario.<br />No puedes hacerlo todo manualmente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Gestionar el SEO local de una ubicación es un trabajo a tiempo parcial. Gestionarlo para diez ubicaciones es un trabajo a tiempo completo. Para cincuenta ubicaciones se necesita un equipo. Las matemáticas se rompen en algún momento — y para la mayoría de los negocios, eso ocurre alrededor de la tercera o cuarta sede, cuando las hojas de cálculo empiezan a multiplicarse y el trabajo manual comienza a acumularse.</p>
            <p>Esto es lo que realmente cuesta "gestionar manualmente" a escala: cada ubicación necesita actividad diaria en GBP, citaciones consistentes en más de 50 directorios, monitoreo de posicionamiento por palabra clave y gestión de reseñas. Luego alguien tiene que informar sobre todo eso. Multiplica por 30 ubicaciones. Eso no es un flujo de trabajo — eso es un departamento completo.</p>
            <p class="font-semibold text-[#111827]">Stacc está diseñado específicamente para este problema. Una plataforma que automatiza cada tarea de SEO local en cada ubicación, todos los días — sin añadir personal a medida que crece el número de sedes.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Qué hace Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una plataforma. Cada palanca de SEO local.<br />Todo automatizado.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Local', price: '$49/mes', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Publicación de posts en GBP — 30/mes', 'Seguimiento diario de posiciones — paquete local + orgánico', 'Monitoreo de reseñas — alertas en tiempo real', 'Gestión de citaciones — más de 50 directorios'], href: '/es/modulos/seo-local/' },
            { title: 'SEO de Blog', price: '$99/mes', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 posts de blog SEO/mes', 'Publicados directamente en tu web', 'Investigación de palabras clave incluida', 'Enlazado interno optimizado'], href: '/es/modulos/seo-contenido/' },
            { title: 'Redes Sociales', price: '$49/mes', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Posts diarios con imágenes', 'Instagram, LinkedIn, Facebook, X', 'Redactados y programados automáticamente', 'Contenido consistente con tu marca'], href: '/es/modulos/redes-sociales/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Ver más</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades clave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarea de SEO multi-ubicación automatizada.<br />Cada resultado visible.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Portfolio dashboard -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Panel de Portafolio de Ubicaciones</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Todas las ubicaciones comparadas en paralelo. Las que tienen bajo rendimiento aparecen al instante.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">El panel de portafolio muestra todas las ubicaciones comparadas por posicionamiento, precisión de citaciones, puntuación de reseñas y actividad en GBP. Ordena por cualquier métrica para ver al instante quién está ganando, quién está estancado y dónde tu atención tendrá mayor ROI. Sin necesidad de cambiar de pestaña para revisar cada sede — la comparación se hace sola cada día.</p>
              <a href="/es/funciones/informes-multi-ubicacion/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">Ver informes multi-ubicación <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Portafolio de ubicaciones — hoy</p>
              {[
                { name: 'Centro de Madrid', rank: 1, trend: '↑', score: 94 },
                { name: 'Salamanca', rank: 2, trend: '↑', score: 91 },
                { name: 'Chamberí', rank: 3, trend: '→', score: 88 },
                { name: 'Vallecas', rank: 7, trend: '↓', score: 61 },
              ].map(loc => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${loc.rank <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#fff1f2] text-[#ef4444]'}`}>#{loc.rank}</div>
                  <span class="flex-1 font-sans text-[13px] text-[#374151]">{loc.name}</span>
                  <div class="h-1.5 w-16 rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${loc.score}%`}></div></div>
                  <span class={`font-mono text-[11px] font-semibold ${loc.trend === '↑' ? 'text-[#059669]' : loc.trend === '↓' ? 'text-[#ef4444]' : 'text-[#79716b]'}`}>{loc.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Actualizado diariamente · Todas las ubicaciones comparadas automáticamente</p>
            </div>
          </div>

          <!-- Bulk management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Actualización masiva — horario festivo</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Seleccionar ubicaciones</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {['Las 47 ubicaciones', 'Región Madrid', 'Selección personalizada'].map(opt => (
                    <span class={`rounded-lg px-3 py-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] ${opt === 'Las 47 ubicaciones' ? 'bg-[#4f39f6] text-white' : 'border border-[#e7e5e4] text-[#79716b]'}`}>{opt}</span>
                  ))}
                </div>
              </div>
              <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-white p-4">
                <span class="font-sans text-[13px] text-[#57534e]">Aplicar horario navideño a las 47 sedes</span>
                <span class="rounded-lg bg-[#059669] px-3 py-1 font-mono text-[10px] font-bold text-white">Aplicar</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">2 segundos frente a 47 accesos manuales</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestión Masiva de Ubicaciones</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Actualiza todas las sedes en segundos. No en horas.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Horarios festivos. Cambios de categoría. Nuevos números de teléfono. Actualizaciones de descripción. Cualquier cambio que afecte a todo el portafolio puede aplicarse a todas las ubicaciones simultáneamente con una sola acción. Sin accesos, sin cambiar de pestaña, sin errores manuales. Las actualizaciones masivas se propagan a GBP y a tu red de citaciones automáticamente.</p>
              <a href="/es/funciones/gestion-masiva-ubicaciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">Ver gestión masiva de ubicaciones <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informes Automatizados de Portafolio</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Informes para cada ubicación, entregados según tu calendario. Cero trabajo manual.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Configura los informes automatizados para cada ubicación o cliente una sola vez. Stacc genera informes por sede y resúmenes de portafolio según tu calendario — semanal, mensual o personalizado — y los entrega automáticamente. Las agencias pueden incluir su marca blanca en cada informe. Sin exportaciones. Sin formateo. Sin olvidos.</p>
              <a href="/es/funciones/informes-clientes/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">Ver informes para clientes <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg></a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Informe de portafolio de esta semana</p>
              {[
                { label: 'Ubicaciones mejorando', val: '34 de 47' },
                { label: 'Palabras clave en top-3 local', val: '+18 esta semana' },
                { label: 'Posts en GBP publicados', val: '94 en todas las sedes' },
                { label: 'Reseñas respondidas', val: '12 / media 4.7 ⭐' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generado y enviado automáticamente · Tu marca en todo</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">En cifras</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que la automatización consistente del SEO<br />multi-ubicación hace a tus números.
          </h2>
        </div>
        <div class="mx-auto mt-14 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 500, suffix: '+', label: 'Ubicaciones gestionadas por un solo equipo', sub: 'Sin personal adicional' },
            { to: 90, suffix: '%', label: 'Menos tiempo por actualización de sede', sub: 'Masivo frente a uno a uno' },
            { to: 3, suffix: '×', label: 'Más ubicaciones atendidas por empleado', sub: 'La automatización se multiplica a escala' },
