---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué es un revendedor de SEO?", a: "Un revendedor de SEO es una agencia o consultor que ofrece servicios de SEO local a clientes usando una plataforma de terceros — con marca blanca como propia. La agencia establece sus propios precios, gestiona las relaciones con los clientes y entrega resultados a través de la plataforma de revendedor bajo su propia marca." },
  { q: "¿Cómo funciona Stacc como plataforma de revendedor de SEO?", a: "Te registras en Stacc, configuras los ajustes white label (tu logo, dominio, colores) y luego gestionas todo el SEO local de los clientes a través de tu panel con tu marca. Los clientes ven tu marca. Tú entregas resultados reales de SEO local — gestión de GBP, rastreo de posiciones, citaciones, reseñas, informes — bajo tu nombre." },
  { q: "¿Qué margen puedo obtener revendiendo Stacc?", a: "Stacc comienza en $49/mes para el módulo de SEO local. La mayoría de las agencias cobran a los clientes entre $300 y $1.500/mes por servicios de SEO local. El margen entre tu coste y el precio que cobras a tus clientes es tuyo." },
  { q: "¿Necesitan saber mis clientes que uso Stacc?", a: "No. White label significa reemplazo completo de marca. Tu logo en cada pantalla, tu dominio en cada URL, tu nombre en cada informe. La marca de Stacc nunca aparece en ningún lugar de la experiencia del cliente." },
  { q: "¿Puedo gestionar todos mis clientes revendedor desde una sola cuenta?", a: "Sí. Una cuenta de Stacc cubre todos tus clientes. Cada cliente obtiene su propio inicio de sesión con alcance limitado a tu panel con tu marca. Tú tienes visibilidad de administrador sobre todos los clientes desde una única vista de agencia." },
  { q: "¿Qué trabajo continuo tengo que hacer por cliente?", a: "Mínimo. Después de la configuración inicial (conectar GBP, configurar palabras clave, establecer informes), Stacc automatiza el trabajo continuo: publicación en GBP, rastreo de posiciones, monitoreo de citaciones, alertas de reseñas y entrega de informes. Tu trabajo continuo por cliente es supervisión estratégica, no ejecución diaria." },
  { q: "¿Puedo ofrecer revendedor de SEO local sin tener un equipo SEO existente?", a: "Sí. La automatización de Stacc gestiona la ejecución que normalmente requeriría un especialista en SEO por cliente. Muchos operadores independientes y agencias pequeñas usan Stacc para ofrecer servicios de SEO local sin personal SEO interno dedicado." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Plataforma Revendedor SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "es", "description": "Plataforma de revendedor SEO white label. Entrega resultados de SEO local a clientes bajo la marca de tu agencia. Automatización completa, white label completo, cero marca de Stacc visible.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Revendedor SEO", "item": "https://thestacc.com/es/revendedor-seo/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Programa Revendedor SEO — SEO Local White Label para Agencias | theStacc"
  description="Revende servicios de SEO local bajo la marca de tu agencia. theStacc es una plataforma completa de revendedor SEO white label — entrega automatizada, paneles con tu marca, cero marca de Stacc visible."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Revendedor SEO · SEO Local White Label · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Revende servicios de SEO local<br />
            <span style="color:#4f39f6;">completamente bajo tu marca.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc es la plataforma de SEO local white label que te permite entregar resultados a clientes bajo tu propia marca. Automatización completa, paneles con tu marca, informes automatizados — y Stacc nunca aparece en nada que los clientes vean.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empezar por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/soluciones/agencias/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funciones para agencias
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito · Cancela cuando quieras</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas y agencias</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ ubicaciones gestionadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo funciona la reventa de SEO con Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tú vendes. Stacc entrega.<br />Los clientes ven tu marca en todo momento.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>El negocio de revendedor de SEO funciona cuando tu coste por cliente es bajo y tu entrega está automatizada. Los clientes de SEO local suelen pagar entre $300 y $1.500/mes. El módulo de SEO local de Stacc comienza en $49/mes por cuenta sin tarifas por cliente más allá del número de ubicaciones. El margen entre tu coste y el precio que cobras a tus clientes es tuyo.</p>
            <p>El modelo operativo es sencillo: incorporas a un cliente (conectas GBP, configuras palabras clave, estableces informes), y a partir de ese momento Stacc gestiona la ejecución continua — posts en GBP, rastreo de posiciones, monitoreo de citaciones, alertas de reseñas y entrega de informes — automáticamente. Tu tiempo por cliente se reduce a supervisión estratégica y respuestas ocasionales a reseñas. Escala añadiendo clientes, no más plantilla.</p>
            <p class="font-semibold text-[#111827]">Y como todo está con marca blanca, tus clientes lo experimentan como tu plataforma propia. Nunca saben que Stacc existe. La relación, el valor de marca y el margen son completamente tuyos.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de la plataforma revendedor</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todo lo que necesita un revendedor de SEO local<br />en una sola plataforma.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'White label completo', body: 'Tu dominio, tu logo, tus colores en todo lo que el cliente ve. La marca de Stacc completamente invisible. $0 por acceso de cliente.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automatización de GBP por cliente', body: '30 posts de GBP al mes por ubicación de cliente, publicados automáticamente. Los perfiles permanecen activos sin ningún trabajo tuyo ni de tus clientes.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreo de posiciones para todos los clientes', body: 'Posiciones diarias para cada cliente en paquete local, Maps y orgánico. Los paneles de clientes muestran solo sus datos — tu administrador lo ve todo.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Informes automatizados de clientes', body: 'Los informes con tu marca se generan y se entregan a los clientes según tu calendario. Sin exportación manual, sin formateo, sin olvidarse del informe mensual de un cliente.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Gestión de citaciones', body: 'Monitoreo y corrección de citaciones para cada ubicación de cliente en 50+ directorios. Factor de posicionamiento local de alto impacto gestionado automáticamente.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Gestión multi-cliente', body: 'Vista completa de cartera de todos tus clientes revendedor. Consulta el rendimiento de cada cliente, incorpora nuevos clientes rápidamente y gestiona todo desde un panel de administrador.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">La plataforma revendedor en detalle</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Lo que Stacc hace por ti<br />mientras tú te centras en crecer.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Feature 1 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">White Label Completo</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Tu marca. En cada pantalla.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El panel que ven tus clientes lleva tu logo, tus colores y tu dominio. No hay rastro de Stacc en ninguna parte de la experiencia del cliente. Tú configuras el white label una vez — subiendo tu logo, definiendo los colores de tu agencia, ajustando el dominio personalizado — y todos los clientes que incorpores desde ese momento verán únicamente tu marca. El valor percibido es tuyo. La retención es tuya. La referencia es tuya.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver soluciones para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Panel de cliente — vista con marca de agencia</p>
              <div class="mb-4 flex items-center gap-3 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center shrink-0">
                  <span class="font-mono text-[10px] font-bold text-white">AG</span>
                </div>
                <div>
                  <p class="font-sans text-[12px] font-semibold text-[#111827]">AgenciaMarketing Pro</p>
                  <p class="font-mono text-[10px] text-[#79716b]">panel.agenciamarketingpro.com</p>
                </div>
              </div>
              {[
                { client: 'Fontanería López', status: 'Activo', rank: '#2 Maps' },
                { client: 'Clínica Dental Sur', status: 'Activo', rank: '#1 Maps' },
                { client: 'Climatización Rivas', status: 'Activo', rank: '#3 Maps' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.status}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">{r.rank}</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Marca Stacc eliminada · Tu logo en todo</p>
            </div>
          </div>

          <!-- Feature 2 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Modelo de precios revendedor — por cliente</p>
              <div class="space-y-3">
                {[
                  { label: 'Tu coste en Stacc', value: '$49/mes', highlight: false },
                  { label: 'Precio básico a cliente', value: '$300/mes', highlight: false },
                  { label: 'Precio estándar a cliente', value: '$600/mes', highlight: false },
                  { label: 'Precio premium a cliente', value: '$1.500/mes', highlight: false },
                ].map(row => (
                  <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] px-4 py-2.5">
                    <span class="font-sans text-[12px] text-[#57534e]">{row.label}</span>
                    <span class="font-mono text-[12px] font-semibold text-[#111827]">{row.value}</span>
                  </div>
                ))}
                <div class="flex items-center justify-between rounded-lg border border-[#4f39f6] bg-[#f5f3ff] px-4 py-2.5">
                  <span class="font-sans text-[12px] font-semibold text-[#4f39f6]">Tu margen por cliente</span>
                  <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">$251–$1.451/mes</span>
                </div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tú estableces el precio · Stacc cubre la ejecución</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Matemática del margen</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                $300–$1.500 de margen por cliente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Los servicios de SEO local se venden entre $300 y $1.500 al mes según el mercado, la competencia y el nivel de servicio. Tu coste en Stacc es de $49/mes — independientemente de cuántos clientes gestiones bajo esa cuenta. El margen que queda entre tu coste y el precio que cobras es tuyo al 100%. A 10 clientes con precio estándar de $500/mes, estás generando $4.510/mes de margen bruto desde la plataforma.
              </p>
              <a href="/es/precios/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver precios
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Feature 3 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Escala sin contratar</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Escala sin contratar.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El cuello de botella en las agencias de SEO es siempre la capacidad de ejecución: cuántos clientes puede gestionar manualmente un miembro del equipo. Con Stacc, ese límite desaparece. La automatización cubre la publicación de GBP, el monitoreo de citaciones, el rastreo de posiciones y la entrega de informes para todos los clientes simultáneamente. Pasar de 10 a 20 clientes no requiere contratar a nadie — solo incorporar más cuentas. Tu margen por cliente se mantiene mientras la base de clientes crece.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Cartera de clientes activos</p>
              {[
                { name: 'Fontanería López', location: 'Madrid', status: 'GBP ✓ · Citas ✓ · Informe ✓' },
                { name: 'Clínica Dental Sur', location: 'Sevilla', status: 'GBP ✓ · Citas ✓ · Informe ✓' },
                { name: 'Restaurante Casa Pepe', location: 'Barcelona', status: 'GBP ✓ · Citas ✓ · Informe ✓' },
                { name: 'Abogados Martínez', location: 'Valencia', status: 'GBP ✓ · Citas ✓ · Informe ✓' },
                { name: 'Taller Mecánico Rivas', location: 'Bilbao', status: 'GBP ✓ · Citas ✓ · Informe ✓' },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-2.5">
                  <div class="flex items-center justify-between">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.name}</p>
                    <span class="font-mono text-[10px] text-[#79716b]">{r.location}</span>
                  </div>
                  <p class="font-mono text-[10px] text-[#059669]">{r.status}</p>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">20 cuentas · mismo equipo · todo automatizado</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
