---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { SITE_URL, LOGO_URL, buildBreadcrumbs } from '../../utils/schema';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL, width: 512, height: 512 },
      description: 'theStacc is building the operating system for organic growth. Bringing together blog SEO, local SEO, and distribution into a single automated engine.',
      founder: { '@id': `${SITE_URL}/about/#founder` },
      sameAs: [
        'https://www.linkedin.com/company/thestacc',
        'https://x.com/thestacc',
      ],
      knowsAbout: ['SEO Automation', 'AI Content Generation', 'Local SEO', 'Google Business Profile Management'],
    },
    {
      '@type': 'Person',
      '@id': `${SITE_URL}/about/#founder`,
      name: 'Siddharth Gangal',
      url: `${SITE_URL}/about/`,
      jobTitle: 'Founder',
      worksFor: { '@id': `${SITE_URL}/#organization` },
      description: 'Founder of theStacc and Arka360. Graduate of IIT Mandi. Building the automated content engine for organic growth.',
      knowsAbout: ['SEO', 'AI', 'SaaS', 'Content Marketing'],
    },
    {
      '@type': 'AboutPage',
      '@id': `${SITE_URL}/about/`,
      name: 'About theStacc',
      url: `${SITE_URL}/about/`,
      isPartOf: { '@id': `${SITE_URL}/#website` },
      mainEntity: { '@id': `${SITE_URL}/#organization` },
    },
    buildBreadcrumbs(`${SITE_URL}/about/`, [
      { name: 'Home', url: SITE_URL },
      { name: 'About', url: `${SITE_URL}/about/` },
    ]),
  ],
};

const values = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    name: 'Ejecución sobre investigación',
    statement: 'Los paneles que te dicen qué hacer no son lo mismo que los sistemas que lo hacen por ti.',
    proof: 'Cada plan en theStacc termina con una publicación programada, no con una recomendación. Tu contenido se publica aunque no inicies sesión.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    name: 'Calidad que se acumula',
    statement: 'No publicamos relleno. Cada artículo está construido para posicionarse, generar tráfico y envejecer bien.',
    proof: 'Investigación de palabras clave, enlazado interno, estructura SEO y legibilidad. Aplicados a cada pieza automáticamente. No como una ocurrencia de última hora.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    name: 'Transparencia sobre exageración',
    statement: 'Competimos con varias herramientas que reseñamos. Lo decimos. Siempre.',
    proof: 'Cada página de reseña y comparación en theStacc incluye una divulgación editorial clara. Mostramos métricas reales, no números de vanidad.',
  },
];

const icpCards = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M3 9h6"/><path d="M3 15h6"/><path d="M15 9h3"/><path d="M15 15h3"/></svg>`,
    title: 'Pequeñas y medianas empresas',
    body: 'Necesitas 30 artículos al mes para competir con presupuestos empresariales. Pero no tienes un equipo de contenido de 10 personas. theStacc te da resultados de empresa sin el personal.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Negocios locales y áreas de servicio',
    body: 'Dentistas, contratistas, despachos de abogados, agencias. Negocios que ganan siendo la opción más visible localmente. Automatizamos publicaciones en GBP, contenido SEO local y respuestas a reseñas.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: 'Equipos de marketing bajo presión',
    body: 'Tienes una estrategia de contenido pero no suficiente tiempo para ejecutarla. theStacc se encarga del 80% inferior de la producción de contenido para que tu equipo pueda enfocarse en el 20% superior.',
  },
];
---

<BaseLayout
  title="Acerca de theStacc | La Historia de Siddharth Gangal y la Misión"
  description="Stacc fue fundada por Siddharth Gangal (IIT Mandi, Arka360) con la misión de hacer que el crecimiento orgánico sea un sistema, no un sprint."
  lang="es"
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-20 text-center">

        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Acerca de theStacc</p>
        <h1 class="mx-auto mt-4 max-w-[700px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[48px]">
          Construido para eliminar el trabajo repetitivo<br class="hidden md:block" /> que frena el crecimiento.
        </h1>
        <p class="mx-auto mt-5 max-w-[520px] font-sans text-[16px] leading-[1.7] text-[#94a3b8]">
          La mayoría de los negocios tienen la estrategia SEO correcta. Solo no tienen el tiempo, el equipo ni el presupuesto para ejecutarla de forma consistente. theStacc es el sistema que lo hace por ellos.
        </p>

        <!-- CTAs -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/es/demo/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-7 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
          >
            Empieza por $1
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/modules/"
            class="inline-flex h-[46px] items-center gap-2 rounded-xl border border-[rgba(255,255,255,0.12)] px-7 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-[#94a3b8] transition-colors hover:border-[rgba(255,255,255,0.25)] hover:text-[#292524]"
          >
            Ver cómo funciona
          </a>
        </div>

        <!-- Trust pills -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
          {[
            '30 artículos de blog/mes',
            '30 publicaciones GBP/mes',
            'Redes sociales incluidas',
            '$1 para empezar',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>

      </div>
    </section>

    <!-- ░░ BY THE NUMBERS ░░ -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mb-10 text-center">
          <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">En cifras</p>
          <h2 class="mt-2 font-sans text-[26px] font-bold tracking-[-0.02em] text-[#111827] md:text-[32px]">Lo que theStacc entrega, cada mes</h2>
        </div>

        <!-- Bento grid -->
        <div class="grid grid-cols-2 gap-4 md:grid-cols-4">

          <!-- Large tile: 30 articles -->
          <div class="col-span-2 overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-8">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Módulo Blog SEO</p>
            <p class="mt-2 font-sans text-[60px] font-bold leading-none tracking-[-0.04em] text-[#4f39f6]"
               data-count-up data-target="30" data-from="0" data-prefix="" data-suffix="" data-decimals="0">30</p>
            <p class="mt-2 font-sans text-[17px] font-semibold text-[#292524]">Artículos de blog SEO publicados en tu sitio cada mes</p>
            <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b]">Con investigación de palabras clave, enlazado interno y estructura optimizada para posicionarse. Publicados en tu dominio automáticamente.</p>
          </div>

          <!-- GBP posts -->
          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">SEO Local</p>
            <p class="mt-2 font-sans text-[48px] font-bold leading-none tracking-[-0.04em] text-[#292524]"
               data-count-up data-target="30" data-from="0" data-prefix="" data-suffix="" data-decimals="0">30</p>
            <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">Publicaciones GBP al mes</p>
            <p class="mt-1 font-sans text-[12px] leading-[1.6] text-[#79716b]">Contenido para Google Business Profile que mantiene tu presencia local activa.</p>
          </div>

          <!-- Industries -->
          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Cobertura</p>
            <p class="mt-2 font-sans text-[48px] font-bold leading-none tracking-[-0.04em] text-[#292524]"
               data-count-up data-target="70" data-from="0" data-prefix="" data-suffix="+" data-decimals="0">70+</p>
            <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">Sectores atendidos</p>
            <p class="mt-1 font-sans text-[12px] leading-[1.6] text-[#79716b]">Desde SaaS hasta solar y dental. Un motor, cualquier nicho.</p>
          </div>

          <!-- $1 trial -->
          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Para empezar</p>
            <p class="mt-2 font-sans text-[48px] font-bold leading-none tracking-[-0.04em] text-[#4f39f6]"
               data-count-up data-target="1" data-from="0" data-prefix="$" data-suffix="" data-decimals="0">$1</p>
            <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">Durante tus primeros 30 días</p>
            <p class="mt-1 font-sans text-[12px] leading-[1.6] text-[#79716b]">Sin compromiso con tarjeta de crédito. Cancela antes del día 30 y no pagas nada más.</p>
          </div>

          <!-- Modules -->
          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Módulos integrados</p>
            <p class="mt-2 font-sans text-[48px] font-bold leading-none tracking-[-0.04em] text-[#292524]"
               data-count-up data-target="3" data-from="0" data-prefix="" data-suffix="" data-decimals="0">3</p>
            <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">Blog · Local · Social</p>
            <p class="mt-1 font-sans text-[12px] leading-[1.6] text-[#79716b]">Una suscripción, todos los canales. Todo conectado.</p>
          </div>

          <!-- Social content -->
          <div class="col-span-2 overflow-hidden rounded-2xl border border-[#4f39f6] bg-[#fafaf9] p-8" style="background:linear-gradient(135deg,#f5f3ff 0%,#fafaf9 100%);">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Módulo Redes Sociales</p>
            <p class="mt-2 font-sans text-[17px] font-semibold text-[#292524]">Contenido social listo para cada plataforma. Redactado, programado y publicado en LinkedIn, Facebook, Instagram y más. Cada mes. Automáticamente.</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {['LinkedIn', 'Facebook', 'Instagram', 'X / Twitter'].map(p => (
                <span class="rounded-full border border-[#c4b5fd] bg-white px-3 py-1 font-mono text-[11px] font-semibold text-[#4f39f6]">{p}</span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ░░ FOUNDER STORY ░░ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.6fr] lg:items-start">

          <!-- Left: Founder identity -->
          <div class="flex flex-col items-center text-center">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Fundador</p>
            <div class="mt-6 overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white p-6">
              <img
                src="/images/siddharth-gangal.webp"
                alt="Siddharth Gangal, Fundador de theStacc"
                width="300"
                height="300"
                class="mx-auto h-[160px] w-[160px] rounded-full object-cover ring-4 ring-[#f5f3ff]"
                loading="lazy"
              />
              <h3 class="mt-5 font-sans text-[22px] font-bold text-[#111827]">Siddharth Gangal</h3>
              <p class="mt-1 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">Fundador, theStacc</p>
              <div class="mt-4 flex flex-wrap justify-center gap-2">
                <span class="inline-flex items-center rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1 font-mono text-[11px] text-[#57534e]">IIT Mandi</span>
                <span class="inline-flex items-center rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1 font-mono text-[11px] text-[#57534e]">Fundador, Arka360</span>
                <span class="inline-flex items-center rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1 font-mono text-[11px] text-[#57534e]">Solar Labs</span>
              </div>
              <div class="mt-5 flex justify-center gap-3">
                <a href="https://www.linkedin.com/in/siddharth-gangal" target="_blank" rel="noopener noreferrer"
                  class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white transition-colors hover:border-[#c4b5fd]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="#0077b5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <a href="https://x.com/thestacc" target="_blank" rel="noopener noreferrer"
                  class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white transition-colors hover:border-[#c4b5fd]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#111827"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Right: Narrative -->
          <div class="flex flex-col justify-start">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">La historia</p>
            <h2 class="mt-3 font-sans text-[28px] font-bold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[34px]">
              Por qué construí theStacc
            </h2>

            <div class="mt-6 space-y-4">
              <p class="font-sans text-[16px] leading-[1.75] text-[#57534e]">
                En Arka360, dirigí una empresa de software de ingeniería solar. Teníamos un gran producto, una retención sólida y un equipo que conocía el sector mejor que casi nadie. Pero éramos invisibles en internet. No porque no supiéramos qué hacer. Lo sabíamos. Teníamos una estrategia de contenido, objetivos de palabras clave, un calendario de publicación. Lo que no teníamos eran suficientes horas para ejecutarla.
              </p>
              <p class="font-sans text-[16px] leading-[1.75] text-[#57534e]">
                Estábamos dedicando entre el 30 y el 40% de nuestro tiempo de marketing a la producción de contenido: redactar, editar, formatear, publicar, actualizar. Y repetir. El trabajo era importante, pero era mecánico. El tipo de trabajo que debería funcionar en piloto automático.
              </p>
              <p class="font-sans text-[16px] leading-[1.75] text-[#57534e]">
                Revisé todas las herramientas del mercado. Todas tenían la misma respuesta: aquí tienes datos, aquí tienes recomendaciones, aquí tienes un calendario. Ninguna publicaba nada realmente. Ninguna eliminaba el paso manual.
              </p>
            </div>

            <!-- Pull quote -->
            <div class="mt-6 rounded-xl border-l-[3px] border-[#4f39f6] bg-white px-5 py-4">
              <p class="font-sans text-[17px] leading-[1.65] font-medium text-[#111827]">
                "La mayoría de los negocios no fallan en contenido por falta de estrategia. Fallan porque la ejecución es lenta, manual y fragmentada. Quería solucionar eso. Para cualquier negocio, no solo para los que tienen grandes equipos."
              </p>
              <p class="mt-3 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">,  Siddharth Gangal, Fundador</p>
            </div>

            <p class="mt-5 font-sans text-[16px] leading-[1.75] text-[#57534e]">
              theStacc es el sistema que desearía haber tenido en Arka360. No solo sugiere contenido. Lo escribe, lo optimiza y lo publica. Cada mes. Sin que nadie tenga que iniciar sesión.
            </p>

            <div class="mt-7">
              <a
                href="/es/demo/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-[44px] items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-mono text-[12px] font-bold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#615fff]"
              >
                Empieza por $1 →
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ░░ MISSION / VISION ░░ -->
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.03) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 50%,black 40%,transparent 90%);"></div>
      <div class="container-x relative z-10 py-20">
        <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:items-center">
          <div>
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Nuestra misión</p>
            <h2 class="mt-3 font-sans text-[28px] font-bold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[34px]">
              Hacer que el crecimiento orgánico sea un sistema, no un sprint.
            </h2>
            <p class="mt-4 font-sans text-[15px] leading-[1.7] text-[#57534e]">
              Creemos que el contenido consistente y de alta calidad es el motor más fiable para el crecimiento orgánico. También creemos que la mayoría de los negocios no pueden sostenerlo manualmente. Nuestra misión es cerrar esa brecha. Haciendo accesible lo que antes requería agencias o grandes equipos a cualquier negocio que tenga un sitio web.
            </p>
          </div>
          <div class="rounded-2xl border p-8" style="background:rgba(15,23,42,0.04);border-color:rgba(255,255,255,0.08);">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Nuestra visión</p>
            <p class="mt-4 font-sans text-[22px] font-bold leading-[1.3] text-[#292524]">
              El sistema operativo para el crecimiento orgánico.
            </p>
            <p class="mt-3 font-sans text-[14px] leading-[1.7] text-[#57534e]">
              Una plataforma de crecimiento nativa de IA donde cada parte del flujo de trabajo de contenido — investigación, creación, optimización y distribución — está automatizada, conectada y mejorando continuamente. Los negocios se conectan una vez y crecen de forma compuesta con el tiempo.
            </p>
            <!-- Three pillars -->
            <div class="mt-6 grid grid-cols-3 gap-3">
              {[
                { n: '01', label: 'Genera contenido' },
                { n: '02', label: 'Lo distribuye' },
                { n: '03', label: 'Multiplica el crecimiento' },
              ].map(p => (
