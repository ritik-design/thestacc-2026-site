---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué debe hacer el software SEO para franquicias?", a: "El software SEO para franquicias debe automatizar las tareas de SEO local repetitivas que necesitan ejecutarse de forma consistente en cada sede: publicación de posts en GBP, monitoreo de citaciones, seguimiento de posiciones, alertas de reseñas e informes. Si solo rastrea estas cosas y requiere ejecución manual, no está resolviendo el problema de escalabilidad." },
  { q: "¿En qué se diferencia el software SEO para franquicias de las herramientas SEO estándar?", a: "Las herramientas SEO locales estándar están diseñadas para una sola ubicación o un conjunto pequeño. El software SEO para franquicias está creado para portafolios — edición masiva, informes a nivel de toda la red, acceso escalonado para franquiciados frente a franquiciadores, y automatización que ejecuta las mismas tareas para cada sede sin repetición manual por ubicación." },
  { q: "¿Puede Stacc gestionar tanto las ubicaciones de la corporación como las de los franquiciados?", a: "Sí. Puedes segmentar las ubicaciones por tipo de propiedad o región y aplicar diferentes configuraciones, calendarios de informes o niveles de acceso a cada grupo. Las sedes corporativas y las de los franquiciados conviven en el mismo panel con niveles de permisos configurables." },
  { q: "¿Admite Stacc informes de marca blanca para redes de franquicias?", a: "Sí. Los informes de marca blanca pueden llevar la marca del franquiciador o la del franquiciado, según la estructura de informes. Los informes se generan y entregan automáticamente según el calendario establecido." },
  { q: "¿Cómo gestiona Stacc la consistencia del NAP en las sedes de la franquicia?", a: "Stacc monitorea los datos de citaciones en más de 50 directorios para cada ubicación y señala inconsistencias en tiempo real. Las correcciones pueden aplicarse a todas las sedes afectadas de forma masiva. Los datos NAP consistentes son uno de los factores de posicionamiento local de mayor impacto para las empresas de franquicia." },
  { q: "¿Existe algún cargo de configuración para las cuentas de franquicia?", a: "Sin cargo de configuración. Los planes comienzan desde $49/mes para el módulo SEO local, que incluye todas las funciones para franquicias y múltiples ubicaciones." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "inLanguage": "es", "name": "theStacc — Software SEO para Franquicias", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Software SEO para franquicias que automatiza la gestión de búsqueda local en toda tu red. GBP, citaciones, posicionamiento e informes para cada sede, simultáneamente.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Software SEO para Franquicias", "item": "https://thestacc.com/es/software-seo-franquicias/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software SEO para Franquicias — Automatiza el SEO Local en Toda tu Red | theStacc"
  description="Software SEO para franquicias diseñado para escalar. theStacc automatiza la gestión de GBP, monitoreo de citaciones, seguimiento de posiciones e informes para cada sede de la franquicia — sin trabajo manual por ubicación."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software SEO para Franquicias · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Software SEO para franquicias que<br />
            <span style="color:#4f39f6;">gestiona toda tu red.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Diseñado para la escala de las franquicias: gestión masiva de GBP, monitoreo de citaciones a nivel de red, paneles de posicionamiento del portafolio e informes automatizados para todas las sedes simultáneamente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/soluciones/franquicias/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funciones para franquicias
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito · Cancela cuando quieras</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas y agencias</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ ubicaciones gestionadas</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lo que debe hacer el software SEO para franquicias</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La mayoría de las herramientas SEO rastrean a escala.<br />Stacc ejecuta a escala.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>La mayoría de las herramientas SEO locales se construyeron para una ubicación o un pequeño grupo. Te muestran paneles. Te dicen lo que hay que hacer. Luego alguien de tu equipo tiene que abrir cada sede y hacerlo manualmente. Eso funciona para cinco ubicaciones. No funciona para cincuenta.</p>
            <p>El software SEO para franquicias tiene un trabajo diferente: automatizar la ejecución a escala. No solo informar sobre lo que está ocurriendo — sino hacerlo de verdad. Publicar los posts de GBP. Monitorear las citaciones. Enviar los informes. Para cada ubicación, todos los días, sin que nadie tenga que programarlo manualmente por sede.</p>
            <p class="font-semibold text-[#111827]">Eso es Stacc. Construido desde el principio para la ejecución multi-ubicación — no adaptado para escalar a posteriori.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de la plataforma</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todo lo que las redes de franquicias necesitan<br />en una sola plataforma.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Gestión de GBP para toda la red', body: 'Publica posts, actualiza horarios y gestiona atributos para todas las sedes de la franquicia de forma masiva. Una acción. Cada ubicación. Propagación instantánea.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoreo de consistencia de citaciones', body: 'Monitorea la precisión del NAP en más de 50 directorios para cada sede. Corrige masivamente las inconsistencias antes de que afecten al posicionamiento.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Panel de posicionamiento por sede', body: 'Actualizaciones diarias de posiciones para cada ubicación en paquete local, Maps y orgánico. La vista de portafolio muestra todas las sedes en paralelo con tendencias de rendimiento.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestión de reseñas por sede', body: 'Bandeja de entrada centralizada de reseñas para todas las sedes. Alertas en tiempo real, gestión de respuestas y seguimiento de puntuación por ubicación.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Acceso para franquiciador y franquiciado', body: 'Permisos escalonados: el franquiciador ve toda la red, el franquiciado ve sus propios datos. Gestión centralizada con visibilidad individual.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Informes automatizados para la red', body: 'Resúmenes de red, informes por sede e informes personalizados por grupo — generados y entregados automáticamente según tu calendario.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Software en detalle</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Lo que Stacc ejecuta por tu red<br />todos los días.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Posts localizados por unidad</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Publicación de posts localizada por unidad.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc genera posts de GBP personalizados para cada sede — con la ciudad, el servicio y las palabras clave específicas de esa unidad. Los posts de Madrid hablan de Madrid. Los de Barcelona hablan de Barcelona. La localización real importa para el algoritmo local de Google.
              </p>
              <a href="/es/soluciones/franquicias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver publicación multi-sede
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posts de GBP publicados hoy</p>
              {[
                { city: 'Madrid Centro', post: 'Fontanería urgente Madrid Centro — disponible 24h', ok: true },
                { city: 'Barcelona Gràcia', post: 'Reparación calefacción Gràcia · Presupuesto gratis', ok: true },
                { city: 'Valencia Russafa', post: 'Instalación aire acondicionado Russafa · oferta julio', ok: true },
              ].map(r => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.city}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.post}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Posts localizados · Sin trabajo manual</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posiciones — portafolio de franquicias</p>
              {[
                { loc: 'Madrid', kw: 'fontanero Madrid', pack: 2, maps: 2 },
                { loc: 'Barcelona', kw: 'fontanero Barcelona', pack: 1, maps: 1 },
                { loc: 'Valencia', kw: 'fontanero Valencia', pack: 3, maps: 4 },
                { loc: 'Sevilla', kw: 'fontanero Sevilla', pack: 5, maps: 5 },
              ].map(r => (
                <div class="grid grid-cols-4 items-center border-t border-[#f5f3ff] py-3 gap-2">
                  <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.loc}</p>
                  <p class="font-mono text-[10px] text-[#79716b] col-span-1 truncate">{r.kw}</p>
                  <span class="text-center font-mono text-[12px] font-bold text-[#4f39f6]">#{r.pack}</span>
                  <span class="text-center font-mono text-[11px] text-[#059669]">Maps #{r.maps}</span>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreo centralizado de posiciones</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Rastreo de posiciones en toda la red.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El panel de portafolio de Stacc muestra las posiciones de todas tus sedes en paralelo — Maps, paquete local y orgánico — actualizadas cada día. Identifica al instante qué franquicias están ganando y cuáles están perdiendo terreno, sin abrir un panel por sede.
              </p>
              <a href="/es/software-rastreo-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver rastreo de posiciones
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informes automáticos por sede</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes de rendimiento automáticos.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cada sede recibe su informe mensual de rendimiento. Los franquiciadores reciben el resumen de red. Todo se genera y se entrega automáticamente según el calendario que configures. Sin exportaciones manuales, sin formateo, sin envío manual por sede.
              </p>
              <a href="/es/funciones/informes-multi-ubicacion/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver informes multi-sede
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Entrega de informes — este mes</p>
              {[
                { loc: 'Franquicia Madrid', tipo: 'Informe SEO Local Mensual', status: 'Entregado', time: '1 Abr, 9:00' },
                { loc: 'Franquicia Barcelona', tipo: 'Informe SEO Local Mensual', status: 'Entregado', time: '1 Abr, 9:00' },
                { loc: 'Franquicia Valencia', tipo: 'Informe SEO Local Mensual', status: 'Entregado', time: '1 Abr, 9:00' },
                { loc: 'Resumen de red', tipo: 'Informe de portafolio completo', status: 'Entregado', time: '1 Abr, 9:00' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.loc}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.time}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Cero trabajo manual · Todas las sedes</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que consiguen las redes<br />de franquicia con Stacc.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '300+', num: 300, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Unidades de franquicia gestionadas', sub: 'en una sola cuenta de Stacc' },
            { value: '2 min', num: 2, prefix: '', suffix: ' min', decimals: 0, from: 0, label: 'Para añadir nueva unidad', sub: 'de cero a completamente gestionado' },
            { value: '89%', num: 89, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Mejora en GBP en 90 días', sub: 'actividad consistente vs. línea base inactiva' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- TESTIMONIALS -->
