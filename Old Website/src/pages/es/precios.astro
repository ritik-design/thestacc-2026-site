  <script>
    // ─── MODULE SELECTOR ───

    const blogTiers = [
      { label: '30 artículos', count: 30, price: 99 },
      { label: '50 artículos', count: 50, price: 149 },
      { label: '80 artículos', count: 80, price: 199 },
    ];
    const localTiers = [
      { label: '30 publicaciones', count: 30, price: 49 },
      { label: '60 publicaciones', count: 60, price: 79 },
      { label: '80 publicaciones', count: 80, price: 99 },
    ];
    const socialTiers = [
      { label: '30 publicaciones', count: 30, price: 49 },
      { label: '60 publicaciones', count: 60, price: 79 },
      { label: '120 publicaciones', count: 120, price: 129 },
    ];

    type ModKey = 'blog' | 'local' | 'social';
    const tiers: Record<ModKey, typeof blogTiers> = { blog: blogTiers, local: localTiers, social: socialTiers };
    const modNames: Record<ModKey, string> = { blog: 'Blog SEO', local: 'Local SEO', social: 'Social' };

    let selectedIdx: Record<ModKey, number> = { blog: 0, local: 0, social: 0 };
    let isAnnual = true;

    function round(n: number) { return Math.round(n); }

    function getPrice(mod: ModKey) {
      const base = tiers[mod][selectedIdx[mod]].price;
      return isAnnual ? round(base * 0.83) : base;
    }

    function getSaving(mod: ModKey) {
      const base = tiers[mod][selectedIdx[mod]].price;
      return round(base * 12 - round(base * 0.83) * 12);
    }

    function updateAll() {
      (['blog', 'local', 'social'] as ModKey[]).forEach(mod => {
        const priceEl = document.getElementById(`mod-${mod}-price`);
        const savingEl = document.getElementById(`mod-${mod}-saving`);
        if (priceEl) priceEl.textContent = String(getPrice(mod));
        if (savingEl) {
          if (isAnnual) {
            savingEl.textContent = `Estás ahorrando $${getSaving(mod)}/año`;
            savingEl.classList.remove('hidden');
          } else {
            savingEl.classList.add('hidden');
          }
        }
      });

      const dot = document.getElementById('mod-billing-dot');
      const toggle = document.getElementById('mod-billing-toggle');
      const label = document.getElementById('mod-billing-label');
      const badge = document.getElementById('mod-save-badge');
      if (dot) dot.style.transform = isAnnual ? 'translateX(20px)' : 'translateX(0)';
      if (toggle) toggle.style.backgroundColor = isAnnual ? '#4f39f6' : '#d1d5db';
      if (label) label.textContent = isAnnual ? 'Facturado anualmente' : 'Facturado mensualmente';
      if (badge) badge.style.display = isAnnual ? '' : 'none';

    }

    document.getElementById('mod-billing-toggle')?.addEventListener('click', () => { isAnnual = !isAnnual; updateAll(); });
    document.getElementById('mod-billing-label')?.addEventListener('click', () => { isAnnual = !isAnnual; updateAll(); });

    (['blog', 'local', 'social'] as const).forEach(mod => {
      document.querySelectorAll<HTMLButtonElement>(`[data-mod-tier="${mod}"]`).forEach(btn => {
        btn.addEventListener('click', () => {
          selectedIdx[mod] = parseInt(btn.getAttribute('data-tier-idx') || '0');
          document.querySelectorAll(`[data-mod-tier="${mod}"]`).forEach((b, i) => {
            const isActive = i === selectedIdx[mod];
            (b as HTMLElement).style.borderColor = isActive ? '#4f39f6' : '#e7e5e4';
            (b as HTMLElement).style.backgroundColor = isActive ? 'rgba(79,57,246,0.06)' : 'transparent';
            (b as HTMLElement).style.color = isActive ? '#4f39f6' : '#374151';
          });
          updateAll();
        });
      });
    });

    updateAll();


    // ─── COMPARISON TABS ───

    document.querySelectorAll<HTMLButtonElement>('.compare-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        document.querySelectorAll('.compare-tab').forEach(t => {
          (t as HTMLElement).style.borderColor = '#e7e5e4';
          (t as HTMLElement).style.backgroundColor = 'transparent';
          (t as HTMLElement).style.color = '#79716b';
          t.setAttribute('aria-selected', 'false');
        });
        (btn as HTMLElement).style.borderColor = '#4f39f6';
        (btn as HTMLElement).style.backgroundColor = 'rgba(79,57,246,0.05)';
        (btn as HTMLElement).style.color = '#4f39f6';
        btn.setAttribute('aria-selected', 'true');

        document.querySelectorAll('.compare-panel').forEach(p => {
          p.classList.add('hidden', 'opacity-0');
          p.classList.remove('block', 'opacity-100');
        });
        const panel = document.querySelector(`[data-panel="${tabId}"]`);
        if (panel) {
          panel.classList.remove('hidden', 'opacity-0');
          panel.classList.add('block');
          requestAnimationFrame(() => {
            panel.classList.add('opacity-100');
            panel.querySelectorAll<HTMLElement>('.stat-bar').forEach(bar => {
              bar.style.transition = 'width 1.2s cubic-bezier(0.16,1,0.3,1)';
              bar.style.width = bar.getAttribute('data-width') + '%';
            });
          });
        }
      });
    });

    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.querySelectorAll<HTMLElement>('.stat-bar').forEach(bar => {
            bar.style.transition = 'width 1.2s cubic-bezier(0.16,1,0.3,1)';
            bar.style.width = bar.getAttribute('data-width') + '%';
          });
          statObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('.compare-panel').forEach(p => statObserver.observe(p));


    // ─── GROWTH CHART ───

    const chartObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const line = entry.target.querySelector('.growth-line');
          const area = entry.target.querySelector('.growth-area');
          line?.classList.add('animate');
          area?.classList.add('animate');
          chartObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    const chart = document.getElementById('growth-chart');
    if (chart) chartObserver.observe(chart);


    // ─── FAQ ACCORDION ───

    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>

  <style>
    @keyframes drawLine { to { stroke-dashoffset: 0; } }
    @keyframes fadeArea { to { opacity: 1; } }
    .growth-line.animate { animation: drawLine 2s cubic-bezier(0.16,1,0.3,1) forwards; }
    .growth-area.animate { animation: fadeArea 1.5s 0.6s cubic-bezier(0.16,1,0.3,1) forwards; }
  </style>
