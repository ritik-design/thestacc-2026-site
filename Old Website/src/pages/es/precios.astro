---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { SITE_URL, LOGO_URL, buildBreadcrumbs } from '../../utils/schema';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const blogTiers = [
  { label: '30 artículos', count: 30, price: 99 },
  { label: '50 artículos', count: 50, price: 149 },
  { label: '80 artículos', count: 80, price: 199, best: true },
];
const localTiers = [
  { label: '30 publicaciones', count: 30, price: 49 },
  { label: '60 publicaciones', count: 60, price: 79 },
  { label: '80 publicaciones', count: 80, price: 99, best: true },
];
const socialTiers = [
  { label: '30 publicaciones', count: 30, price: 49 },
  { label: '60 publicaciones', count: 60, price: 79 },
  { label: '120 publicaciones', count: 120, price: 129, best: true },
];

const blogFeatures = [
  'Investigación de palabras clave y análisis de competencia',
  'Publicación automática en tu sitio',
  'WordPress, Webflow, Ghost y más',
  'Optimizado para SEO y en tu voz de marca',
];
const localFeatures = [
  'Publicaciones automáticas en GBP',
  'Respuestas a reseñas con IA',
  'Seguimiento de palabras clave locales',
  'Soporte para múltiples ubicaciones',
];
const socialFeatures = [
  'Publicación automática y programación',
  'Analíticas multiplataforma',
  'Contenido con voz de marca',
  '4 plataformas incluidas',
];

const managedPlans = [
  {
    name: 'Crecimiento Local',
    tagline: 'Contenido + SEO Local, totalmente gestionado.',
    price: 749,
    annualPrice: 625,
    features: [
      '30 artículos de blog publicados/mes',
      '30 publicaciones de GBP/mes',
      'Monitoreo y respuestas de reseñas diarias',
      'Informes de rendimiento semanales',
      'Videollamada de estrategia mensual',
      '1 ubicación incluida (+$150 c/u extra)',
    ],
    popular: false,
    comparison: null as string | null,
  },
  {
    name: 'Crecimiento Pro',
    tagline: 'Contenido + SEO Local + Redes Sociales.',
    price: 999,
    annualPrice: 835,
    features: [
      'Todo en Crecimiento Local',
      '60 publicaciones en redes en 6 plataformas/mes',
      'Contenido y hashtags específicos por plataforma',
      'Horario de publicación optimizado',
      'Monitoreo de interacciones diario',
      'Análisis mensual + llamada de estrategia',
    ],
    popular: true,
    comparison: null as string | null,
  },
  {
    name: 'Crecimiento Completo',
    tagline: 'Todo. Blog, local, social y sitio web.',
    price: 1299,
    annualPrice: 999,
    features: [
      'Todo en Crecimiento Pro',
      'Sitio web creado con IA, alojado y gestionado',
      'Actualizaciones mensuales del sitio y ajuste SEO',
      'Monitoreo de velocidad y parches de seguridad',
      'Informes semanales + llamada de estrategia mensual',
      'Equipo de operaciones basado en EE.UU.',
    ],
    popular: false,
    comparison: 'Comparación: un empleado de marketing a tiempo parcial cuesta <strong>$2,500–$4,000/mes</strong>. Una agencia cobra <strong>$3,000–$10,000/mes</strong> de retención.',
  },
];

const tabs = [
  {
    id: 'blog',
    label: 'SEO Blog',
    icon: '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>',
    title: 'SEO Blog',
    replaces: ['Plataforma SEO ($99–$399/mes)', 'redactores freelance ($2,000–$5,000/mes)', 'herramienta de calendario de contenido'],
    narrative: "Los negocios que aparecen en la primera página publican 20–30 artículos al mes. El negocio promedio publica 2. Stacc redacta, optimiza y publica en tu sitio cada día. Aunque nunca hayas posicionado para una palabra clave en tu vida. Sin briefs. Sin editores. Sin plazos incumplidos.",
    stats: [
      { label: 'Velocidad de contenido vs. negocio promedio', value: '15× más', percent: 88, color: 'purple' },
      { label: 'Costo vs. redactores freelance', value: '95% menos', percent: 95, color: 'green' },
      { label: 'Tiempo hasta el primer movimiento de ranking', value: '60–90 días', percent: 65, color: 'amber' },
    ],
  },
  {
    id: 'local',
    label: 'SEO Local',
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
    title: 'SEO Local',
    replaces: ['Agencia de SEO local ($800–$2,000/mes)', 'herramienta de gestión de reseñas', 'rastreador de posicionamiento local'],
    narrative: "Tu perfil de Google Business Profile es el espacio más valioso en la búsqueda local. Un perfil inactivo es invisible. Stacc publica 30 veces al mes, responde reseñas al instante y rastrea cada palabra clave en tu ciudad. Aunque no hayas iniciado sesión en tu GBP en meses.",
    stats: [
      { label: 'Publicaciones en GBP vs. negocio típico', value: '10× más', percent: 80, color: 'purple' },
      { label: 'Tiempo de respuesta a reseñas', value: 'Menos de 1 h', percent: 95, color: 'green' },
      { label: 'Mejora de posición en Maps a los 90 días', value: '4.7×', percent: 70, color: 'amber' },
    ],
  },
  {
    id: 'social',
    label: 'Redes Sociales',
    icon: '<path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>',
    title: 'Redes Sociales',
    replaces: ['Community manager ($2,500–$5,000/mes)', 'herramienta de programación', 'herramienta de diseño'],
    narrative: "El algoritmo premia la consistencia. Los negocios que publican a diario obtienen más alcance, más seguidores, más clientes. Stacc genera contenido nativo para Instagram, LinkedIn, X y Facebook. Aunque hayas probado herramientas de programación antes y las hayas abandonado a las dos semanas.",
    stats: [
      { label: 'Publicaciones/mes vs. negocio típico', value: '10× más', percent: 80, color: 'purple' },
      { label: 'Costo vs. community manager', value: '98% menos', percent: 98, color: 'green' },
      { label: 'Tiempo ahorrado por semana', value: '5+ horas', percent: 85, color: 'amber' },
    ],
  },
];

const milestones = [
  { month: 'Mes 3', stat: '+47%', desc: 'Páginas indexadas' },
  { month: 'Mes 6', stat: '+180%', desc: 'Tráfico orgánico' },
  { month: 'Mes 12', stat: '+320%', desc: 'Leads calificados' },
];

const testimonials = [
  {
    quote: "Pasamos de 0 a 47 leads mensuales en 4 meses. Stacc reemplazó nuestra agencia de $3,000/mes y los resultados son mejores.",
    name: "Propietario/a",
    role: "Clínica Dental · Chicago",
    metric: "47 leads/mes",
    init: "DP",
  },
  {
    quote: "Era escéptico sobre el contenido de IA. Pero nuestras entradas del blog aparecen en la primera página y los clientes las mencionan durante las consultas. Es el marketing más creíble que hemos hecho.",
    name: "Socio Director",
    role: "Despacho de Abogados · Atlanta",
    metric: "3× tráfico orgánico",
    init: "LP",
  },
  {
    quote: "Top 3 en Maps para 'reparación de climatización cerca de mí' en 90 días. Las publicaciones en GBP se publican cada día sin que toque nada. Nuestra valoración pasó de 4.1 a 4.8. Por $49 al mes, nada se acerca.",
    name: "Sarah D.",
    role: "Empresa de Climatización · Phoenix",
    metric: "↑ Top 3 en Maps en 90 días",
    init: "SD",
  },
  {
    quote: "Visibilidad en Google Maps un 200% mayor en el primer trimestre. Recibimos llamadas de zonas en las que nunca habíamos posicionado. La configuración tardó 10 minutos.",
    name: "Agente",
    role: "Agencia Inmobiliaria · Dallas",
    metric: "200% más vistas en Maps",
    init: "RE",
  },
];

const faqs = [
  {
    q: "Ya intenté el marketing de contenido antes y no funcionó.",
    a: "La razón por la que la mayoría del marketing de contenido fracasa no es el contenido. Es la inconsistencia. Publicas 4 entradas, paras 6 semanas, publicas 2 más y luego lo abandonas porque no ves resultados. El algoritmo de Google premia la publicación sostenida y regular. Stacc publica todos los días, todos los meses, sin interrupciones. Los negocios que usan Stacc y que 'ya intentaron el contenido antes' son los que están viendo los mejores resultados. Porque esta vez, la publicación no se detiene.",
  },
  {
    q: "¿Cuánto tiempo hasta ver resultados?",
    a: "La mayoría de los negocios ven un movimiento significativo en el posicionamiento dentro de los 60–90 días de publicación constante. El primer mes, Google indexa el nuevo contenido. El segundo mes, los rankings empiezan a moverse. Para el mes 3–6, el tráfico crece de forma notable. El SEO no es un juego de un mes. Es una inversión de 6 meses que da dividendos durante años. Cada artículo que Stacc publica sigue trabajando para ti estés suscrito o no.",
  },
  {
    q: "¿Vale la pena $99/mes? Son $1,200 al año.",
    a: "Un redactor freelance cobra entre $150 y $500 por artículo. Con 30 artículos al mes, eso son $4,500–$15,000/mes. O $54,000–$180,000/año. Una plataforma SEO (Ahrefs, Semrush) cuesta $99–$399/mes solo por los datos, sin redacción incluida. Un solo cliente nuevo desde la búsqueda orgánica paga el costo anual completo de Stacc antes del almuerzo. Las matemáticas solo funcionan de una forma.",
  },
  {
    q: "¿Tengo que escribir algo o estar muy involucrado?",
    a: "Ni una sola palabra. Stacc se encarga de la investigación de palabras clave, el análisis de la competencia, la creación de contenido, la optimización SEO y la publicación en tu sitio. Totalmente automatizado. Puedes revisar las entradas antes de publicarlas si quieres, o activar la publicación automática y revisar mensualmente. La mayoría de los clientes dedican unas 1–2 horas al mes a revisar. El resto del tiempo es tuyo.",
  },
  {
    q: "¿Puedo cancelar en cualquier momento? Me preocupa quedar atrapado.",
    a: "Cancela cuando quieras. Sin contratos, sin penalizaciones, sin cargos por cancelación. El contenido que Stacc ha publicado permanece en tu sitio para siempre y sigue posicionando. No pierdes acceso al trabajo pasado cuando cancelas. Solo detienes la publicación futura. La mayoría de las personas que cancelan vuelven en 60 días cuando ven que su tráfico se estanca.",
  },
  {
    q: "¿En qué se diferencia esto de ChatGPT o contratar a un asistente virtual?",
    a: "ChatGPT escribe cuando lo activas. Stacc publica según un calendario, automáticamente, todos los días. Un asistente virtual escribe cuando está disponible, incumple plazos, necesita formación, se va de vacaciones. Stacc no. La diferencia real está en el sistema: investigación de palabras clave → optimización SEO → publicación en el CMS → seguimiento del posicionamiento, todo automatizado y conectado. ChatGPT es una herramienta. Stacc es el flujo de trabajo completo.",
  },
  {
    q: "¿Qué plataformas CMS son compatibles?",
    a: "WordPress, Webflow, Ghost, Shopify y cualquier plataforma que admita publicación vía API o webhook. Si tu CMS no aparece en la lista, contáctanos. Admitimos la mayoría de plataformas con una integración personalizada. La configuración tarda menos de 10 minutos.",
  },
  {
    q: "¿Cómo funciona el 15% de descuento por paquete?",
    a: "Selecciona dos o más módulos y el descuento se aplica automáticamente en la barra de resumen en la parte inferior de tu pantalla. Sin códigos de cupón. Sin cálculos manuales. El ahorro aparece al instante mientras construyes tu plan.",
  },
];

const pricingSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE_URL}/#software`,
      name: 'theStacc',
      description: 'Plataforma de automatización SEO con IA que redacta y publica contenido de blog, gestiona perfiles de Google Business y automatiza redes sociales para negocios locales.',
      url: SITE_URL,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: [
        { '@type': 'Offer', name: 'SEO Blog', description: '30 artículos SEO escritos con IA publicados en tu sitio cada mes', price: '99.00', priceCurrency: 'USD', url: `${SITE_URL}/es/precios/` },
        { '@type': 'Offer', name: 'SEO Local', description: 'Optimización y gestión del perfil de Google Business', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/es/precios/` },
        { '@type': 'Offer', name: 'Redes Sociales', description: 'Publicación y distribución automatizada en redes sociales', price: '49.00', priceCurrency: 'USD', url: `${SITE_URL}/es/precios/` },
        { '@type': 'Offer', name: 'Paquete (Todos los Módulos)', description: 'SEO Blog + SEO Local + Redes Sociales', price: '167.00', priceCurrency: 'USD', url: `${SITE_URL}/es/precios/` },
      ],
      provider: { '@id': `${SITE_URL}/#organization` },
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/es/precios/`,
      name: 'Precios. TheStacc',
      description: 'Elige el módulo de Stacc que necesitas. Blog SEO desde $99/mes, SEO Local desde $49/mes, Redes Sociales desde $49/mes. Sin contratos. Cancela cuando quieras.',
      url: `${SITE_URL}/es/precios/`,
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(`${SITE_URL}/es/precios/`, [
      { name: 'Inicio', url: SITE_URL },
      { name: 'Precios', url: `${SITE_URL}/es/precios/` },
    ]),
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL },
    },
  ],
};
---

<BaseLayout
  title="Precios de Stacc — SEO Blog, SEO Local y Redes Sociales desde $99/mes"
  description="Elige el módulo de Stacc que necesitas. Blog SEO desde $99/mes, SEO Local desde $49/mes, Redes Sociales desde $49/mes. Sin contratos. Cancela cuando quieras."
  lang="es"
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(pricingSchema)} />

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[820px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">3 módulos · 1 plataforma · Empieza por $1</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Ellos publican a diario.
            <span style="color:#4f39f6;"> Tú no. Esa es la diferencia.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc investiga, redacta y publica contenido SEO, actualizaciones de Google Business Profile y publicaciones en redes sociales cada día. Automáticamente. Elige tus módulos y empieza por $1.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="#pricing"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Arma mi plan
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#compare"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Ve qué reemplazas
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 días de garantía · Sin tarjeta de crédito · Cancela cuando quieras
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '12,000+', num: 12000, prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Artículos publicados' },
              { value: '340+',    num: 340,   prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Negocios creciendo' },
              { value: '4.9★',    num: 4.9,   prefix: '',  suffix: '★', decimals: 1, from: 0, label: 'Valoración de clientes' },
              { value: '0',       num: 0,     prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Penalizaciones de Google' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negocios creciendo con Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 en 127 reseñas</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PRICING MODULES ─── -->
    <section class="bg-white" id="pricing">

      <!-- ── Controls bar ── -->
      <div class="border-b border-[#e7e5e4]">
        <div class="container-x py-4">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <!-- Left: path label + anchor tabs -->
            <div class="flex flex-wrap items-center gap-3">
              <div class="flex items-center gap-1.5">
                <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Elige tu camino</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </div>
              <div class="inline-flex overflow-hidden rounded-full border border-[#e7e5e4] bg-[#fafaf9] p-1" role="group" aria-label="Opción de precios">
                <a href="#software-pricing" class="rounded-full px-5 py-2 font-sans text-[13px] font-semibold bg-[#111827] text-white shadow-sm">Software</a>
                <a href="#managed-pricing" class="rounded-full px-5 py-2 font-sans text-[13px] font-semibold text-[#9ca3af] hover:text-[#374151] transition-colors">Servicios</a>
              </div>
            </div>
            <!-- Right: billing toggle (software only) -->
            <div id="billing-controls" class="flex items-center gap-3">
              <span id="mod-billing-label" class="cursor-pointer font-sans text-[13px] font-semibold text-[#374151]">Facturado anualmente</span>
              <button id="mod-billing-toggle" class="relative h-[24px] w-[44px] shrink-0 cursor-pointer rounded-full bg-[#4f39f6] transition-colors" aria-label="Cambiar facturación anual" type="button">
                <div id="mod-billing-dot" class="absolute top-[3px] left-[3px] h-[18px] w-[18px] rounded-full bg-white shadow-sm transition-transform" style="transform:translateX(20px)"></div>
              </button>
              <span id="mod-save-badge" class="rounded-md bg-[#4f39f6]/10 px-2 py-0.5 font-mono text-[11px] font-semibold text-[#4f39f6]">Ahorra 17%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ── SOFTWARE PANEL ── -->
      <div id="software-pricing" class="container-x pb-8 pt-8">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Precios de Software</span>
