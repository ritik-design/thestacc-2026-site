---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué son los reportes white label?", a: "Los reportes white label son cuando una agencia entrega informes a clientes con su propio logo, nombre de agencia y dominio — no los del proveedor del software. Los clientes reciben informes con formato profesional que refuerzan la marca de la agencia, sin que aparezca ningún nombre de herramienta de terceros en ningún lugar." },
  { q: "¿Qué datos incluyen los informes white label de Stacc?", a: "Los informes incluyen posiciones de palabras clave (paquete local, Maps, orgánico), métricas de actividad de GBP (posts publicados, vistas, clics en llamadas), puntuaciones de precisión de citaciones, datos de reseñas (cantidad, puntuación media, tasa de respuesta) y datos de comparación mes a mes. Tú configuras qué secciones incluir por cliente." },
  { q: "¿Los informes se entregan automáticamente o tengo que exportarlos?", a: "Totalmente automatizado. Configura el calendario de entrega para cada cliente — semanal o mensual — y Stacc genera y envía por email el informe automáticamente. Sin exportaciones, sin formateo, sin envío manual. Los informes llegan a las bandejas de entrada de los clientes sin que nadie de tu equipo los toque." },
  { q: "¿Puede el informe parecer que viene de mi agencia, no de Stacc?", a: "Sí. Tu logo, el nombre de tu agencia, tu dominio en el remitente del email, tu esquema de colores en el PDF. El nombre de Stacc no aparece en ningún lugar del informe orientado al cliente. Los clientes lo experimentan como tu sistema de informes propio." },
  { q: "¿Puedo revisar los informes antes de que se envíen a los clientes?", a: "Sí. Puedes configurar los informes en modo 'revisar antes de enviar' donde se retienen en tu panel para aprobación. O configúralos para entrega completamente automatizada donde van directamente a los clientes. Configuración por cliente." },
  { q: "¿Los reportes white label incluyen paneles de clientes en vivo?", a: "Sí. Además de la entrega automatizada de informes, los clientes pueden acceder a un panel en vivo en tu dominio que se actualiza continuamente con datos frescos. El panel en vivo muestra posiciones actuales, actividad reciente de GBP y estadísticas de reseñas en tiempo real." },
  { q: "¿Cuánto cuestan los reportes white label?", a: "Incluidos en los planes Growth y Scale de Stacc. El módulo de SEO local comienza en $49/mes. La entrega de informes a clientes está incluida sin cargo por cliente." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Reportes White Label", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "es", "description": "Reportes SEO white label para agencias. Generación y entrega automatizada de informes bajo la marca de tu agencia — tu logo, tu dominio, tu informe.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Reportes White Label", "item": "https://thestacc.com/es/reportes-white-label/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Reportes SEO White Label para Agencias — Informes Automatizados con Tu Marca | theStacc"
  description="Automatiza los reportes SEO de clientes bajo la marca de tu agencia. theStacc genera y entrega informes white label con tu logo y dominio — semanales o mensuales, sin trabajo manual."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Reportes White Label · Para Agencias · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Informes de clientes que se construyen y se envían<br />
            <span style="color:#4f39f6;">solos. Bajo tu marca.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc genera, marca y entrega informes SEO para cada cliente automáticamente según tu calendario. Tu logo. Tu dominio. Cero trabajo manual por informe.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empezar por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/funciones/reportes-clientes/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver reportes de clientes
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito · Cancela cuando quieras</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas y agencias</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ ubicaciones gestionadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El coste real de los informes manuales</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            3 horas por cliente al mes.<br />Multiplicadas por cada cliente que tienes.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Para una agencia con 15 clientes, los informes manuales son 45 horas al mes — más de una semana laboral completa — dedicadas a extraer datos, formatear hojas de cálculo y escribir resúmenes que los clientes ojearán durante 30 segundos. Es la tarea de mayor apalancamiento que puedes automatizar, porque el ahorro de tiempo se convierte directamente en capacidad para más clientes.</p>
            <p>Pero la dimensión de marca importa tanto como el tiempo. Los informes que llegan con el nombre de una herramienta genérica hacen algo sutil: le dicen a tu cliente que tu proceso es un commodity. Los informes que llegan con tu logo, desde tu dominio, con un calendario profesional — esos le dicen a tu cliente que llevas una operación profesional. Esa percepción afecta a la retención.</p>
            <p class="font-semibold text-[#111827]">Stacc automatiza la generación y entrega de informes con tu marca para cada cliente, en el calendario que elijas. El ahorro de tiempo solo ya lo justifica. La impresión de marca es el beneficio adicional.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de reporting</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada función de reporting que necesitan las agencias.<br />Todo automatizado, todo con tu marca.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Tu marca en cada informe', body: 'Tu logo, el nombre de tu agencia y tu esquema de colores en cada PDF y email. La marca de Stacc eliminada completamente de todos los documentos orientados al cliente.' },
            { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Entrega automatizada según calendario', body: 'Configura la entrega semanal o mensual por cliente. Los informes se generan y envían automáticamente — sin activación manual, sin exportación, sin formateo.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Datos completos de SEO local', body: 'Posiciones, actividad de GBP, precisión de citaciones, puntuaciones de reseñas y comparativas mes a mes — todo en un informe por cliente.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Paneles en vivo con tu marca', body: 'Los clientes también tienen acceso a un panel en vivo en tu dominio que muestra datos en tiempo real entre ciclos de entrega de informes.' },
            { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Modo revisar antes de enviar', body: 'Opcionalmente retén los informes para tu revisión antes de la entrega. Aprueba y envía con un clic, o deja que los informes vayan totalmente automatizados según la preferencia por cliente.' },
            { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', title: 'Gestión de informes multi-cliente', body: 'Consulta todos los informes de clientes en una única cola. Rastrea el estado de entrega, las tasas de apertura y la interacción de los clientes desde tu panel de agencia.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reporting white label en detalle</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cómo funciona el reporting<br />automático con tu marca.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Feature 1 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Entrega Automatizada</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes que se crean y se envían solos.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configura el calendario de entrega una vez por cliente — semanal, quincenal o mensual — y Stacc se encarga del resto. En la fecha programada, el sistema extrae los datos actualizados de SEO local, monta el informe con tu plantilla de marca y lo envía directamente a la bandeja de entrada del cliente. No hay ningún paso manual. Tu equipo no toca el informe. Simplemente llega, con tu logo, en el horario que prometiste.
              </p>
              <a href="/es/funciones/reportes-clientes/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver reportes de clientes
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Cola de entrega de informes — este mes</p>
              {[
                { client: 'Fontanería López', report: 'Informe SEO Local Mensual', status: 'Enviado ✓', time: '1 May, 9:00' },
                { client: 'Clínica Dental Sur', report: 'Informe SEO Local Mensual', status: 'Enviado ✓', time: '1 May, 9:00' },
                { client: 'Climatización Rivas', report: 'Informe SEO Local Mensual', status: 'Enviado ✓', time: '1 May, 9:00' },
                { client: 'Abogados Martínez', report: 'Informe SEO Local Mensual', status: 'Enviado ✓', time: '1 May, 9:00' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.time}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">{r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Cero trabajo manual · Marca white label</p>
            </div>
          </div>

          <!-- Feature 2 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Configuración de plantilla — una vez</p>
              <div class="space-y-3">
                <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">Logo de agencia</span>
                  <span class="font-mono text-[11px] text-[#059669]">Subido ✓</span>
                </div>
                <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">Colores de marca</span>
                  <span class="font-mono text-[11px] text-[#059669]">Configurado ✓</span>
                </div>
                <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                  <span class="font-sans text-[12px] text-[#57534e]">Dominio de email</span>
                  <span class="font-mono text-[11px] text-[#059669]">Verificado ✓</span>
                </div>
                <div class="flex items-center justify-between rounded-lg border border-[#4f39f6] bg-[#f5f3ff] px-4 py-3">
                  <span class="font-sans text-[12px] font-semibold text-[#4f39f6]">Estado del sistema</span>
                  <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">Activo — entrega automática</span>
                </div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Configura una vez · Entrega para siempre</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Configuración única</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Configura una vez. Entrega para siempre.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                La configuración del sistema de informes white label toma menos de una hora. Subes tu logo, defines los colores de tu agencia, conectas tu dominio de email y configuras el calendario de entrega por cliente. A partir de ese momento, el sistema funciona de forma completamente autónoma. Puedes añadir nuevos clientes y se incorporan automáticamente a la misma plantilla de marca. No hay nada que actualizar ni mantener mensualmente — simplemente funciona.
              </p>
              <a href="/es/revendedor-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver programa revendedor
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Feature 3 -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">White label completo</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Tus clientes ven tu marca.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cuando el informe llega a la bandeja de entrada de tu cliente, lo único que ve es tu marca. Tu logo en la cabecera, el nombre de tu agencia como remitente, tus colores en el diseño del PDF. No hay mención de Stacc en ninguna parte del documento. Para tu cliente, esto confirma que llevas una operación profesional con herramientas propias. Esa percepción afecta a la retención y a las referencias que tus clientes hacen de tu agencia.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Informe recibido por el cliente</p>
              <div class="mb-4 flex items-center gap-3 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center shrink-0">
                  <span class="font-mono text-[10px] font-bold text-white">AG</span>
                </div>
                <div>
                  <p class="font-sans text-[12px] font-semibold text-[#111827]">Informe Mensual SEO Local</p>
                  <p class="font-mono text-[10px] text-[#79716b]">De: informes@tuagencia.com</p>
                </div>
              </div>
              {[
                { metric: 'Posición media en Maps', value: '#2,3', change: '▲ +1,4' },
                { metric: 'Posts GBP publicados', value: '30', change: '✓ Completo' },
                { metric: 'Citaciones correctas', value: '51/53', change: '▲ +2' },
                { metric: 'Reseñas respondidas', value: '100%', change: '✓ Sin pendientes' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <span class="font-sans text-[12px] text-[#57534e]">{r.metric}</span>
                  <div class="text-right">
                    <span class="font-mono text-[12px] font-semibold text-[#111827]">{r.value}</span>
                    <span class="ml-2 font-mono text-[10px] text-[#059669]">{r.change}</span>
                  </div>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Sin mención de Stacc · Tu marca en todo</p>
            </div>
