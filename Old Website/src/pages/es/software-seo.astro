---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué es el software SEO?",
    a: "El software SEO ayuda a las empresas a gestionar las señales que determinan cómo posicionan en los motores de búsqueda — incluidas las posiciones de palabras clave, la optimización on-page, las citaciones, la actividad del Perfil de Negocio de Google y la generación de reseñas. El software SEO moderno va más allá de los paneles y automatiza el trabajo de ejecución real: publicar contenido, actualizar listados, monitorear reseñas y entregar informes automáticamente.",
  },
  {
    q: "¿En qué se diferencia theStacc del resto del software SEO?",
    a: "La mayoría de las herramientas SEO son herramientas de datos. Rastrean lo que ocurre pero te dejan todo el trabajo a ti. Stacc realmente hace el trabajo — publicando publicaciones de GBP, sincronizando citaciones, monitoreando reseñas en tiempo real y entregando informes de marca blanca según el calendario. Es una plataforma de ejecución, no solo un panel de informes.",
  },
  {
    q: "¿Necesito varias herramientas SEO si uso Stacc?",
    a: "Para SEO local, no. Stacc reemplaza los rastreadores de posiciones independientes, las herramientas de gestión de GBP, los servicios de citaciones, las herramientas de monitoreo de reseñas y el software de informes. Gestionas todo desde una plataforma. Las agencias suelen eliminar 4–5 suscripciones separadas al pasarse a Stacc.",
  },
  {
    q: "¿Funciona Stacc para negocios con múltiples ubicaciones?",
    a: "Sí — la gestión multi-ubicación es una capacidad central. Gestiona cada ubicación desde un panel, publica publicaciones de GBP en todas las ubicaciones simultáneamente y genera informes de rendimiento individuales o agregados por ubicación. No hay límite práctico en el número de ubicaciones que puedes añadir.",
  },
  {
    q: "¿Está Stacc diseñado para agencias o para equipos internos?",
    a: "Para ambos. Las agencias obtienen informes de marca blanca, gestión de cuentas de múltiples clientes y portales de cliente personalizados. Los equipos internos en negocios multi-ubicación obtienen herramientas de gestión masiva e informes automatizados para partes interesadas internas. La misma plataforma sirve a ambos flujos de trabajo sin compromisos.",
  },
  {
    q: "¿Cómo es el proceso de configuración?",
    a: "La mayoría de las configuraciones se completan en menos de 5 minutos — ubicaciones añadidas, palabras clave configuradas, GBP conectado y reportes automatizados programados. Después de la configuración, Stacc gestiona todo de forma continua sin tiempo adicional de tu equipo. No se requiere incorporación prolongada ni integración técnica.",
  },
  {
    q: "¿Incluye Stacc informes de marca blanca?",
    a: "Sí. Los informes de marca blanca — tu logo, colores de marca y dominio personalizado — están disponibles en los planes Growth y Scale. Los informes se generan y entregan bajo tu marca. Tus clientes nunca ven la marca de Stacc.",
  },
  {
    q: "¿Qué integraciones admite Stacc?",
    a: "Stacc se integra con Google Business Profile, Google Search Console, Google Analytics, Facebook, Instagram, WordPress, Webflow, Ghost y Wix. Todas las integraciones están incluidas en tu plan — sin tarifas por integración.",
  },
  {
    q: "¿Cuánto cuesta Stacc?",
    a: "Los planes comienzan desde $49/mes para el módulo de SEO Local, que incluye publicación de publicaciones de GBP, rastreo de posiciones diario, monitoreo de reseñas y gestión de citaciones. El módulo de Blog SEO es $99/mes. El módulo de Redes Sociales es $49/mes. Todos los módulos incluyen una prueba gratuita de 14 días.",
  },
  {
    q: "¿Puedo cancelar en cualquier momento?",
    a: "Sí. Sin contratos. Sin tarifas de cancelación. Exporta tu historial completo de datos en cualquier momento antes de cancelar. Tus datos te pertenecen.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Software SEO",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Software SEO todo en uno que automatiza posicionamiento local, citaciones, reseñas, gestión de GBP e informes para negocios y agencias.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Módulo de SEO Local — desde $49/mes"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Software SEO", "item": "https://thestacc.com/es/software-seo/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Software SEO — Automatización SEO Local Todo en Uno desde $49/mes | theStacc"
  description="Deja de malabarear 5 herramientas SEO. theStacc es el software SEO todo en uno que automatiza posicionamiento local, citaciones, reseñas e informes para negocios y agencias."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex flex-wrap items-center justify-center gap-3">
            {['Plataforma todo en uno', '$49/mes', '400+ agencias', 'Sin tarjeta de crédito', 'Prueba gratuita 14 días'].map(chip => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>{chip}
              </span>
            ))}
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Software SEO que<br />hace el trabajo.
            <span style="color:#4f39f6;"> No solo el rastreo.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Buscaste software SEO porque estás cansado de pagar por herramientas que te dan datos pero te dejan el trabajo a ti. Stacc es diferente — automatiza publicaciones de GBP, rastreo de posiciones, gestión de citaciones, monitoreo de reseñas e informes de marca blanca. Una plataforma. Todo automatizado.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empezar por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver precios
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sin tarjeta de crédito · Cancela cuando quieras
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ negocios y agencias</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ ubicaciones gestionadas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema con la mayoría del software SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Estás pagando por cinco herramientas<br />y aún así haciendo todo el trabajo.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Así suele ir. Te registras en un rastreador de posiciones. Luego añades una herramienta de citaciones porque el rastreador no hace eso. Luego compras una herramienta de gestión de GBP porque la herramienta de citaciones no publica. Luego añades una plataforma de reseñas. Luego estás construyendo tus informes mensuales en una hoja de cálculo porque ninguna de estas herramientas se comunica entre sí y ninguna genera el tipo de informe que un cliente real quiere ver.
            </p>
            <p>
              Ahora tienes cinco suscripciones, cinco logins y estás gastando más tiempo gestionando tu stack de herramientas SEO que gestionando el SEO en sí. <strong class="text-[#111827]">Las herramientas se convirtieron en el trabajo.</strong> El trabajo real — estrategia, relaciones con clientes, crecimiento — quedó para lo que sobre del viernes.
            </p>
            <p>
              Este es el problema con el software SEO fragmentado: cada herramienta optimiza para su propio nicho y nadie resuelve el flujo de trabajo completo. Tú rellenas los huecos con tu propio tiempo. Y tu tiempo es el recurso más caro del negocio.
            </p>
            <p class="font-semibold text-[#111827]">
              Las agencias que están ganando en SEO local ahora mismo no trabajan más duro. Consolidaron todo en una plataforma automatizada y dejaron que el software se encargue de la ejecución. Eso es Stacc.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Qué incluye Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una plataforma. Cada palanca SEO.<br />Todo automatizado.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Local', price: '$49/mes', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Publicación de publicaciones GBP — 30/mes', 'Rastreo de posiciones diario — pack local + orgánico', 'Monitoreo de reseñas — alertas en tiempo real', 'Gestión de citaciones — 50+ directorios'], href: '/modules/local-seo/' },
            { title: 'Blog SEO', price: '$99/mes', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 entradas de blog SEO/mes', 'Publicadas directamente en tu sitio', 'Investigación de palabras clave incluida', 'Enlazado interno optimizado'], href: '/modules/content-seo/' },
            { title: 'Redes Sociales', price: '$49/mes', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Publicaciones diarias con imágenes', 'Instagram, LinkedIn, Facebook, X', 'Escritas y programadas automáticamente', 'Contenido coherente con la marca'], href: '/modules/social-media/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Saber más</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades clave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Reemplaza cinco herramientas con una.<br />Reduce tu coste de tiempo a la mitad.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreo de Posiciones Automatizado</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Cada palabra clave, cada ubicación, cada mañana — sin iniciar sesión en nada.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc rastrea tus posiciones en el pack local, Google Maps y resultados orgánicos diariamente para cada palabra clave que te importa. Las alertas se activan automáticamente cuando las posiciones cambian significativamente. Te despiertas sabiendo dónde estás — sin abrir un solo panel. Para agencias que gestionan 20 clientes, esta es la diferencia entre pasar el martes en verificaciones de posiciones o pasarlo en estrategia.
              </p>
              <a href="/features/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el rastreo de posiciones en detalle
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Actualización de posiciones de hoy — todos los clientes</p>
              {[
                { client: 'Fontanería Robles', kw: 'fontanero cerca de mí', pos: 1, change: '+3', trend: 'up' },
                { client: 'Clínica Dental Ciudad', kw: 'dentista [ciudad]', pos: 2, change: '+2', trend: 'up' },
                { client: 'Climatización Elite', kw: 'reparación HVAC cerca', pos: 2, change: '+5', trend: 'up' },
                { client: 'Bufete Metro', kw: 'abogado cerca de mí', pos: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Actualizado diariamente · Pack local + orgánico + Maps</p>
            </div>
          </div>

          <!-- Citation Management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Salud de citaciones — todos los directorios</p>
              {[
                { dir: 'Google Business Profile', status: 'Correcto', ok: true },
                { dir: 'Yelp', status: 'Correcto', ok: true },
                { dir: 'Apple Maps', status: 'Correcto', ok: true },
                { dir: 'Yellow Pages', status: 'Discrepancia corregida', ok: true },
                { dir: 'Foursquare', status: 'Corregido automáticamente', ok: true },
              ].map(c => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{c.dir}</span>
                  <span class={`flex items-center gap-1.5 font-mono text-[11px] font-semibold ${c.ok ? 'text-[#059669]' : 'text-[#dc2626]'}`}>
                    {c.ok ? '✓' : '✗'} {c.status}
                  </span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ directorios monitoreados · Correcciones automatizadas</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestión de Citaciones</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Las citaciones inconsistentes perjudican tus posiciones. Stacc las encuentra y corrige automáticamente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google cruza los datos de tu negocio en más de 50 directorios para verificar que eres quien dices ser. Cuando tu nombre, dirección o teléfono no coinciden, tus posiciones locales sufren. Stacc monitorea continuamente cada directorio importante — y cuando encuentra una discrepancia, la corrige automáticamente. Sin más auditorías trimestrales de citaciones. Sin más herramientas de envío manual.
              </p>
              <a href="/modules/local-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver gestión de citaciones
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informes Automatizados para Clientes</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes que se construyen y envían solos. Bajo tu marca. Cada semana.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Para la mayoría de las agencias, los informes de clientes son el impuesto que nunca desaparece — horas cada mes que no puedes facturar y no puedes eliminar. Stacc los elimina. Configura tu plantilla una vez por cliente. Stacc genera el informe, lo formatea con tu marca y lo entrega en la bandeja del cliente según el calendario. El momento en que los informes se vuelven automáticos es el momento en que puedes escalar más allá de tu techo actual de headcount.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
