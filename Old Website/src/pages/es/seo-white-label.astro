---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué es el SEO white label?", a: "El SEO white label es cuando una agencia entrega servicios de SEO local a clientes usando software con la marca propia de la agencia — su logo y dominio — en lugar de la marca del proveedor del software. Los clientes interactúan con la marca de la agencia en cada panel, informe y notificación, sin visibilidad de las herramientas subyacentes." },
  { q: "¿Qué se incluye en el white label de Stacc?", a: "Todo lo que el cliente puede ver: la URL del panel (tu dominio mediante CNAME), todos los logos y colores, los PDFs de informes, los emails de entrega de informes automatizados y las notificaciones de inicio de sesión del cliente. El nombre y la marca de Stacc nunca aparecen en nada que un cliente vea." },
  { q: "¿Necesito conocimientos técnicos para configurar el white label?", a: "No se necesita ningún desarrollador. Subes tu logo, estableces el nombre de tu agencia y el esquema de colores, y configuras un registro CNAME para tu subdominio. La configuración completa lleva unas 2 horas. Todo se configura desde el panel — sin código, sin experiencia técnica necesaria." },
  { q: "¿Puede cada cliente tener su propio inicio de sesión?", a: "Sí. Cada cliente obtiene un inicio de sesión limitado a sus propias ubicaciones. Los clientes no pueden ver datos de otros clientes. Tú mantienes acceso de administrador completo sobre todos los clientes. Los inicios de sesión de clientes están incluidos a $0 independientemente de cuántos clientes añadas." },
  { q: "¿Puedo usar un dominio personalizado para los paneles de clientes?", a: "Sí. Apunta tu subdominio (ej., seo.tuagencia.com) a Stacc mediante un registro CNAME. Todos los paneles orientados al cliente se cargan en tu dominio. El dominio de Stacc nunca aparece en ninguna URL del cliente." },
  { q: "¿El white label afecta al precio?", a: "Las funciones white label vienen incluidas en el módulo de SEO Local de Stacc desde $49/mes — logo, colores y dominio personalizado, sin cargo extra. Los inicios de sesión de clientes siempre son $0 por plaza. Si necesitas operación gestionada con servicio premium, está disponible desde $749/mes." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO White Label", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "es", "description": "Software de SEO local white label para agencias. Paneles con tu marca, informes y accesos de clientes en tu dominio — Stacc nunca aparece en nada que los clientes vean.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "SEO White Label", "item": "https://thestacc.com/es/seo-white-label/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de SEO White Label para Agencias — Tu Marca en Todo | theStacc"
  description="SEO local white label para agencias. Paneles con tu marca, informes y accesos de clientes en tu dominio. Configuración en 2 horas. Accesos de clientes a $0 por plaza."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO White Label · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO entregado<br />
            <span style="color:#4f39f6;">bajo la marca de tu agencia.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Cada panel, informe y acceso de cliente lleva el logo y el dominio de tu agencia. Stacc nunca aparece en ningún lugar que los clientes puedan ver. Tu marca se fortalece cada vez que un cliente inicia sesión y ve resultados.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empezar por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funciones white label
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito · Cancela cuando quieras</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Dominio personalizado (CNAME)</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">$0 por acceso de cliente</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuración en 2 horas</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">400+ agencias</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué la marca importa en cada interacción con el cliente</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada herramienta con el logo de un proveedor<br />es un punto de contacto que tu marca no posee.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Cuando un cliente inicia sesión en un panel con el nombre de un proveedor, no está pensando en tu agencia — está pensando en ese proveedor. Cada inicio de sesión, cada informe, cada email está construyendo el reconocimiento de marca del proveedor a tu costa. Y si buscan la página de precios de ese proveedor, empiezan a hacerse una pregunta que no quieres que se hagan.</p>
            <p>El SEO white label cambia esa dinámica. Cada interacción que un cliente tiene con tu servicio — cada inicio de sesión, cada informe, cada alerta — lleva el nombre y el logo de tu agencia. Los resultados que ven se atribuyen mentalmente a tu equipo. El valor de tu marca se acumula con cada informe que llega. Y los clientes que ven tu marca de forma consistente en resultados positivos permanecen más tiempo.</p>
            <p class="font-semibold text-[#111827]">La configuración white label de Stacc lleva 2 horas. Los accesos de clientes cuestan $0. Y cada punto de contacto con el cliente desde ese momento construye tu marca — no la nuestra.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades white label</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todo lo que el cliente ve.<br />Tu marca en todo, la nuestra en nada.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Dominio personalizado (CNAME)', body: 'Los paneles de clientes se cargan en tu subdominio (ej., seo.tuagencia.com). El dominio de Stacc nunca aparece en ninguna URL del cliente.' },
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Personalización completa de logo y marca', body: 'Sube tu logo, establece tu esquema de colores, configura el nombre de tu agencia. Identidad de marca consistente en cada pantalla que los clientes ven.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Informes automatizados con tu marca', body: 'Los informes llevan tu logo, se envían desde tu dominio y se formatean con tus colores. Entregados según tu calendario — semanal o mensual — sin trabajo manual.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: '$0 por acceso de cliente', body: 'Añade accesos de clientes ilimitados. El precio se basa en las ubicaciones gestionadas — no en las plazas. Puedes dar a cada cliente su propio acceso sin que afecte tu factura.' },
            { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Notificaciones por email con tu marca', body: 'Las alertas automatizadas y los emails de entrega de informes se envían desde tu dominio. Ninguna dirección de email de thestacc.com en la bandeja de entrada de ningún cliente.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Acceso de clientes basado en roles', body: 'Los clientes solo ven sus propias ubicaciones y datos. Tu equipo tiene visibilidad de administrador completa sobre todos los clientes. Los permisos se aplican a nivel de datos.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades clave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada palanca de SEO ejecutada<br />bajo tu marca, no la nuestra.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestión de Google Business Profile</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Activad GBP de cada cliente desde un panel con tu marca. 30 publicaciones al mes. Cero trabajo manual.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc redacta y publica 30 posts optimizados al mes en cada GBP que gestionas — orientados a búsquedas de servicio, intención "cerca de mí" y temas estacionales. Tu equipo aprueba el flujo desde tu panel con tu logo. Los clientes ven cómo su perfil se activa cada día y atribuyen el resultado a tu agencia, porque cada notificación viene de tu dominio.
              </p>
              <a href="/es/modulos/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el módulo de SEO Local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Panel — seo.tuagencia.com</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 24 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Posts entregados este mes</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">24 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:80%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tu logo · Tu dominio · Sin marca de Stacc</p>
            </div>
          </div>

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posiciones — Cliente: Mueblería Sur</p>
              {[
                { kw: 'tienda muebles [ciudad]', pack: 1, change: '+2', trend: 'up' },
                { kw: 'sofás cerca de mí', pack: 2, change: '+3', trend: 'up' },
                { kw: 'muebles oficina [barrio]', pack: 4, change: '+1', trend: 'up' },
                { kw: 'comprar mesa comedor [ciudad]', pack: 6, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Datos diarios · Pack local + orgánico + Maps · Bajo tu marca</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreo de posiciones diario</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Datos de posición frescos cada mañana — para ti y para cada cliente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Las posiciones se actualizan a diario en cada palabra clave rastreada por cliente. Tu equipo trabaja desde una vista de administrador con todas las cuentas; cada cliente entra a su propio panel a través de tu subdominio y ve únicamente sus datos. Los cambios significativos disparan alertas que se envían desde tu dominio, con tu logo y tu firma — nunca desde Stacc.
              </p>
              <a href="/es/funciones/rastreo-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el rastreo de posiciones en detalle
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informes white label</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes que se construyen, se marcan y se envían solos. Cada cliente. Cada semana.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configura cada cliente una vez: métricas, calendario, frecuencia. Stacc genera el PDF con tu logo, lo envía desde tu dominio y aterriza con tu firma en la bandeja de entrada del cliente. El informe llega antes de que tu cliente abra Slack el lunes — y todo el reconocimiento es para tu agencia. El equipo no lo toca, pero el cliente ve un servicio premium.
              </p>
              <a href="/es/reportes-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver reportes white label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Tu Agencia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Informe Semanal — Mueblería Sur</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Enviado</span>
              </div>
              {[
                { label: 'Posiciones top 3 (pack local)', val: '+4 palabras clave' },
                { label: 'Tráfico orgánico estimado', val: '+18% vs sem. anterior' },
                { label: 'Citaciones nuevas', val: '6 directorios' },
                { label: 'Reseñas nuevas', val: '5 ⭐ media 4.8' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Enviado desde reports@tuagencia.com · Tu marca, no la nuestra</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que la marca propia<br />consistente hace a tu agencia.
