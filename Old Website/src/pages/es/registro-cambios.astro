---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const changelog = [
  {
    date: "Abril 2026",
    tag: "Reciente",
    entries: [
      { title: "Sincronización del plan en vivo", body: "Tu plan de contenido ahora se mantiene sincronizado con tu negocio. ¿Has cambiado tu audiencia objetivo o añadido una nueva ubicación? Stacc detecta lo que está desactualizado y te permite actualizar planes individuales o todo el mes en un clic." },
      { title: "Publicación con un mes de antelación", body: "Planifica con anticipación. Ahora puedes generar el plan de contenido del mes siguiente mientras los posts de este mes todavía se están publicando. Mantente siempre un mes por delante." },
      { title: "Editor de imagen destacada", body: "Imágenes destacadas, gestionadas. Selecciona, cambia o elimina imágenes principales directamente dentro del editor del blog. Se sincronizan automáticamente con WordPress y Webflow." },
      { title: "Página de detalle del blog más limpia", body: "Genera, edita o regenera un plan desde un solo lugar. Sin tener que buscar el botón correcto entre barras laterales." },
      { title: "Edición de slug en vivo", body: "Edita los slugs de tu blog directamente desde la barra lateral. Los cambios se publican en vivo en WordPress, Webflow y WordPress.com al instante." },
      { title: "Integración con Ghost CMS", body: "Publica directamente en Ghost CMS con verificación automática de credenciales." },
      { title: "Configuración de módulos independientes", body: "¿Gestionas múltiples proyectos? Cada uno ahora tiene su propia configuración de módulos completamente independiente. Activar Blog SEO para un sitio no afectará a otro." },
      { title: "Regeneración masiva 5 veces más rápida", body: "La regeneración masiva de planes es ahora 5 veces más rápida. Lo que antes tardaba 90 segundos ahora termina en menos de 18." },
    ],
  },
  {
    date: "Marzo 2026",
    tag: null,
    entries: [
      { title: "Lanzamiento del módulo de Redes Sociales", body: "Stacc ahora escribe, diseña y programa posts en Instagram, LinkedIn, X y Facebook. Configura tu voz de marca una vez y déjalo funcionar en piloto automático." },
      { title: "Rediseño completo de la interfaz", body: "Hemos reconstruido toda la interfaz desde cero. Nuevo sistema de diseño, nuevos iconos, navegación más rápida. Todo se siente más nítido e intencionado." },
      { title: "Revisión del plan de contenido", body: "Revisa tu plan de contenido antes de que se escriba nada. Edita títulos, cambia palabras clave, cambia tipos de blog. Todo en línea, antes de que se genere un solo artículo." },
      { title: "API pública de Blog", body: "Para desarrolladores: obtén una clave de API, configura hooks de despliegue y extrae tu contenido publicado a cualquier frontend o sitio estático." },
      { title: "Mejor colaboración en equipo", body: "Reenvía invitaciones, rastrea la caducidad y controla exactamente a qué pueden acceder los visualizadores en proyectos compartidos." },
      { title: "Integración con Shopify", body: "Tu contenido de blog SEO ahora se publica directamente en tu tienda Shopify." },
    ],
  },
  {
    date: "Febrero 2026",
    tag: null,
    entries: [
      { title: "Integración con Webflow", body: "Conecta tu sitio Webflow vía OAuth y cada post del blog se publica directamente en tu CMS con sincronización en vivo." },
      { title: "Suscripciones modulares", body: "Suscríbete exactamente a lo que necesitas. Elige Blog SEO, SEO Local o Redes Sociales individualmente. Cada módulo tiene su propio plan y facturación." },
      { title: "Controles de voz de marca y estilo", body: "Configura preferencias de estilo de escritura, directrices de imagen y reglas de enlazado que se aplican a todos los artículos que genera Stacc." },
      { title: "Incorporación más inteligente", body: "Stacc ahora lee tu mapa del sitio y comprende tu contenido existente antes de construir tu estrategia de palabras clave." },
    ],
  },
  {
    date: "Enero 2026",
    tag: null,
    entries: [
      { title: "Lanzamiento del módulo de SEO Local", body: "Automatiza los posts de Google Business Profile, monitorea reseñas con respuestas escritas por IA, rastrea palabras clave locales y gestiona múltiples ubicaciones desde un panel." },
      { title: "Integración con WordPress", body: "Publicación con un clic vía OAuth o contraseña de aplicación. Categorías, etiquetas e imágenes destacadas se gestionan automáticamente." },
      { title: "Soporte multi-proyecto", body: "Gestiona múltiples sitios web desde una sola cuenta. Cada proyecto tiene su propia configuración, miembros del equipo y pipeline de contenido." },
      { title: "Puntuación SEO en vivo", body: "Cada blog recibe una puntuación de optimización en tiempo real con sugerencias accionables para mejorar la densidad de palabras clave, la estructura y la legibilidad." },
      { title: "Segmentación por ubicación", body: "Apunta a cualquier ubicación del mundo. Busca tu ciudad y Stacc descubre áreas cercanas para ampliar tu alcance de palabras clave." },
    ],
  },
  {
    date: "Diciembre 2025",
    tag: "Lanzamiento",
    entries: [
      { title: "Lanzamiento de theStacc", body: "Planes de contenido potenciados por IA, investigación de palabras clave, redacción de blogs y publicación automática. Todo desde una sola plataforma." },
      { title: "Incorporación inteligente", body: "Introduce tu URL y Stacc extrae tus servicios, encuentra tus competidores y mapea tus primeros 30 temas de blog." },
      { title: "Calendario de contenido visual", body: "Ve todo tu mes de un vistazo. Rastrea lo que está programado, generando, publicado o necesita atención." },
      { title: "Voz de marca y segmentación de audiencia", body: "Define tu tono y hasta 6 perfiles de cliente ideal para que cada artículo hable a las personas adecuadas." },
    ],
  },
];
---

<BaseLayout
  title="Registro de Cambios | theStacc"
  description="Novedades en theStacc. Actualizaciones de producto, nuevas funciones y mejoras de la plataforma. Actualizado mensualmente."
  lang="es"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ░░ DARK HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Registro de Cambios</p>
        <h1 class="mx-auto mt-4 max-w-[560px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[44px]">
          Novedades en theStacc
        </h1>
        <p class="mx-auto mt-4 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          Actualizaciones de producto, nuevas integraciones y mejoras de la plataforma. Actualizado cada mes.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {[
            'Actualizado mensualmente',
            `${changelog.reduce((n, m) => n + m.entries.length, 0)} actualizaciones publicadas`,
            'Diciembre 2025 hasta el presente',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ LÍNEA DE TIEMPO ░░ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mx-auto max-w-[760px]">
          <div class="space-y-14">
            {changelog.map((month, mi) => (
              <div>
                <!-- Encabezado del mes -->
                <div class="flex items-center gap-3 mb-6">
                  <div class="h-2.5 w-2.5 shrink-0 rounded-full bg-[#4f39f6]"></div>
                  <h2 class="font-mono text-[13px] font-bold uppercase tracking-[0.12em] text-[#292524]">{month.date}</h2>
                  {month.tag && (
                    <span class={`rounded-full px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.1em] ${month.tag === 'Lanzamiento' ? 'bg-[#fef3c7] text-[#92400e]' : 'bg-[#f0fdf4] text-[#166534]'}`}>{month.tag}</span>
                  )}
                  <div class="flex-1 border-t border-[#e7e5e4]"></div>
                </div>

                <!-- Tarjetas de entrada -->
                <div class="ml-5 space-y-3">
                  {month.entries.map(entry => (
                    <div class="rounded-xl border border-[#e7e5e4] bg-white px-5 py-4 transition-colors hover:border-[#c4b5fd]">
                      <p class="font-sans text-[14px] font-semibold text-[#292524]">{entry.title}</p>
                      <p class="mt-1 font-sans text-[13px] leading-[1.65] text-[#79716b]">{entry.body}</p>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ░░ DARK FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Prueba lo que hemos estado construyendo.
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Cada actualización anterior está disponible en tu cuenta desde el primer día. Empieza por 1 $ y ve todo en acción.
        </p>
        <a href="/es/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Empieza tu prueba por 1 $
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">1 $ durante 30 días · Cancela cuando quieras</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
