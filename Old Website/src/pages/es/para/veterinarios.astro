---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Cuánto tarda mi clínica veterinaria en subir posiciones en Google Maps?",
    a: "La mayoría de las clínicas veterinarias ven movimiento significativo en Maps en 60–90 días de actividad constante en el GBP. Las clínicas que no publicaban nada antes tienden a ver resultados más rápido.",
  },
  {
    q: "¿Publicar en el GBP realmente ayuda a posicionar una clínica veterinaria?",
    a: "Sí. El algoritmo de Maps premia la actividad constante en el GBP — consejos de cuidado de mascotas, recordatorios de vacunación, contenido de salud estacional e información de veterinario de urgencias. Cada semana que tu perfil está inactivo, una clínica competidora que publica a diario recibe esas llamadas urgentes.",
  },
  {
    q: "¿Qué palabras clave veterinarias trabaja Stacc?",
    a: "Stacc trabaja combinaciones de servicio + ciudad — 'veterinario cerca de mí,' 'veterinario de perros [ciudad],' 'veterinario de gatos [ciudad],' 'veterinario de urgencias cerca de mí,' 'veterinario de animales exóticos [ciudad],' 'veterinario económico [ciudad].' Todo calibrado al tipo de práctica y ubicación.",
  },
  {
    q: "Mi clínica ya tiene un GBP. ¿Necesito hacer algo especial?",
    a: "Solo conéctala. Stacc extrae los datos actuales y construye un plan de contenido en menos de 5 minutos.",
  },
  {
    q: "¿Qué sucede cuando recibo una reseña negativa?",
    a: "Alerta instantánea con el texto de la reseña y una plantilla de respuesta para que puedas responder rápidamente. Los dueños de mascotas son protectores con sus animales — responder con rapidez a una experiencia negativa les muestra a los futuros clientes cómo manejas los problemas.",
  },
  {
    q: "¿Trabajan con prácticas veterinarias con múltiples ubicaciones?",
    a: "Sí. Cada ubicación recibe su propia estrategia de palabras clave, calendario de contenido e informe de ranking desde un solo panel.",
  },
  {
    q: "¿En qué se diferencia Stacc de una agencia de marketing veterinario?",
    a: "Las agencias cobran $800–$2,000/mes por gestión manual del GBP. Stacc automatiza todo por $49/mes con mayor producción — 30 publicaciones/mes frente a las típicas 8–12.",
  },
  {
    q: "¿Stacc ayuda con contenido de blog veterinario?",
    a: "Sí — el módulo SEO Blog a $99/mes publica artículos como 'con qué frecuencia debo llevar a mi perro al veterinario' y 'señales de que tu gato necesita atención de urgencia' que posicionan en Google y generan nuevas reservas de pacientes. Muchas clínicas usan ambos.",
  },
];
---

<BaseLayout
  title="SEO para Veterinarios | Más Pacientes desde Google Maps | theStacc"
  description="Stacc publica en el Perfil de Negocio de tu clínica veterinaria todos los días, gestiona tus reseñas y hace seguimiento de tu posición en Maps — automáticamente. Más pacientes desde Google por $49/mes."
  lang="es"
>
  <Fragment slot="head">
  </Fragment>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO para Veterinarios · Desarrollado por Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Más pacientes animales desde Google.<br />
            <span style="color:#4f39f6;">A partir de este mes.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            880,000 personas buscan "veterinario cerca de mí" cada mes. El 78% de los dueños de mascotas investigan clínicas veterinarias en línea antes de reservar. Stacc se asegura de que tu clínica aparezca primero — publicando en tu GBP a diario, gestionando reseñas y haciendo seguimiento de tu ranking en Maps.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#como-funciona"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Ver cómo funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 días de garantía · Sin contratos · Publica en tu GBP todos los días
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '880K',  num: 880,  prefix: '',  suffix: 'K', decimals: 0, from: 0, label: 'Búsquedas mensuales de "veterinario cerca"' },
              { value: '78%',   num: 78,   prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Dueños de mascotas investigan en línea primero' },
              { value: '4.6×',  num: 4.6,  prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Mejora promedio en ranking de Maps' },
              { value: '100%',  num: 100,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Reseñas capturadas al instante' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negocios locales posicionando con Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 reseñas</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Lakeside Animal Hospital — Chicago, IL', 'Lone Star Vet Clinic — Houston, TX', 'Desert Paws Vet — Phoenix, AZ', 'Summit Animal Hospital — Denver, CO', 'Pacific Paws Veterinary — Seattle, WA', 'Sunshine Animal Hospital — Miami, FL', 'Southern Vet Clinic — Atlanta, GA', 'Lakeside Animal Hospital — Chicago, IL', 'Lone Star Vet Clinic — Houston, TX', 'Desert Paws Vet — Phoenix, AZ', 'Summit Animal Hospital — Denver, CO', 'Pacific Paws Veterinary — Seattle, WA', 'Sunshine Animal Hospital — Miami, FL', 'Southern Vet Clinic — Atlanta, GA'].map((name, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444c0-1.061-.162-2.2-.493-3.309m-9.243-6.082A8.801 8.801 0 0 1 12 5c.78 0 1.5.108 2.161.306"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Dueños de mascotas en tu vecindario están buscando ahora mismo.<br />Están reservando en otra clínica.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            El 81% de los dueños de mascotas revisa las reseñas antes de elegir un veterinario. La única pregunta es cuya clínica encuentran primero en el Map Pack.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Las búsquedas de veterinarios de urgencia son urgentes. Los dueños de mascotas llaman a quien aparece primero.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Cuando una mascota está enferma a las 10 de la noche, el dueño busca "veterinario de urgencias cerca de mí" y llama a la primera clínica que aparece. El algoritmo de Maps premia a las clínicas veterinarias que publican con regularidad — consejos de cuidado de mascotas, recordatorios de vacunación, contenido de salud estacional. Cada semana que tu GBP está inactivo, una clínica competidora que publica a diario recibe esas llamadas urgentes.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Una reseña negativa sin respuesta sobre una mala experiencia está enviando dueños de mascotas a otra parte.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">El 81% de los dueños de mascotas revisa las reseñas antes de elegir un veterinario. Los dueños de mascotas son protectores con sus animales — elegir un veterinario es una de las decisiones más basadas en la confianza que toman. Una reseña negativa sin respuesta sobre trato brusco o cargos inesperados le dice a cada futuro dueño de mascota lo que podría ser su experiencia.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Apareces para el nombre de tu clínica. No para "veterinario cerca de mí."</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Los nuevos dueños de mascotas en tu vecindario no buscan el nombre de tu clínica — buscan "veterinario cerca de mí," "veterinario de perros [ciudad]" y "veterinario de gatos [ciudad]." Si no estás en el Map Pack para esas búsquedas, esos pacientes y los ingresos de las visitas anuales recurrentes van a quien esté.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Qué hace Stacc para clínicas veterinarias</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada palanca que impulsa nuevos pacientes desde Google. Cubierta.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            El posicionamiento en Maps para clínicas veterinarias requiere actividad constante en el GBP, respuestas rápidas a reseñas y contenido orientado a palabras clave — todos los meses. Stacc lo gestiona todo automáticamente.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publicación en GBP',
              body: '30 publicaciones/mes — peligros estacionales para mascotas, recordatorios de vacunación, consejos de cuidado, información sobre hospedaje en fiestas y contenido de bienvenida a nuevos pacientes. Publicado automáticamente.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Palabras Clave Veterinarias',
              body: 'Servicio + ciudad: veterinario cerca de mí, veterinario de perros, veterinario de gatos, veterinario de urgencias, veterinario de animales exóticos, veterinario económico. Calibrado a las especialidades y ubicación de tu clínica.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Monitoreo de Reseñas',
              body: 'Alertas instantáneas de reseñas con plantillas de respuesta para proteger la reputación basada en la confianza que trae nuevos pacientes — y mantiene a los existentes volviendo cada año.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Seguimiento de Ranking Local',
              body: 'Ranking en Maps basado en cuadrícula para cada palabra clave en toda tu área de servicio. Seguimiento mes a mes para que veas cómo se acumula tu posición.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Gestión Multi-Ubicación',
              body: '¿Múltiples ubicaciones de clínicas? Cada una recibe su propia estrategia de palabras clave, calendario de contenido e informe de ranking desde un solo panel.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Construcción de Citaciones',
              body: 'Envíos a directorios en Yelp, PetMD, Vetstreet y más de 50 más. Las señales de autoridad que ayudan a tu clínica a superar a los competidores.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conéctate una vez. Stacc gestiona la presencia en<br />Maps de tu clínica veterinaria desde ese día en adelante.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sin inicios de sesión en el GBP. Sin escribir publicaciones. Sin revisar reseñas manualmente. Configúralo una vez y tu Perfil de Negocio de Google funciona solo — para que puedas enfocarte en tus pacientes.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Conecta tu Perfil de Negocio de Google</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Busca tu clínica veterinaria. Stacc identifica las palabras clave de cuidado de mascotas para las que no apareces — veterinario cerca de mí, veterinario de perros, veterinario de gatos, veterinario de urgencias y más.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
