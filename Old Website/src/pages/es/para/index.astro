---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const localSEO = [
  { label: 'Contadores',              href: '/es/para/contadores/'          },
  { label: 'Concesionarios de Autos', href: '/es/para/concesionarios-autos/' },
  { label: 'Quiroprácticos',          href: '/es/para/quiropracticos/'       },
  { label: 'Servicios de Limpieza',   href: '/es/para/servicios-limpieza/'   },
  { label: 'Contratistas',            href: '/es/para/contratistas/'         },
  { label: 'Dentistas',               href: '/es/para/dentistas/'            },
  { label: 'Electricistas',           href: '/es/para/electricistas/'        },
  { label: 'Asesores Financieros',    href: '/es/para/asesores-financieros/' },
  { label: 'Gimnasios',               href: '/es/para/gimnasios/'            },
  { label: 'Salud',                   href: '/es/para/salud/'                },
  { label: 'Inspectores de Hogar',    href: '/es/para/inspectores-hogar/'    },
  { label: 'HVAC',                    href: '/es/para/hvac/'                 },
  { label: 'Seguros',                 href: '/es/para/seguros/'              },
  { label: 'Paisajistas',             href: '/for/landscapers/'              },
  { label: 'Abogados',                href: '/for/lawyers/'                  },
  { label: 'Mudanzas',                href: '/for/movers/'                   },
  { label: 'Servicios para Mascotas', href: '/for/pet-services/'             },
  { label: 'Fotógrafos',              href: '/for/photographers/'            },
  { label: 'Plomeros',                href: '/for/plumbers/'                 },
  { label: 'Bienes Raíces',           href: '/for/real-estate/'              },
  { label: 'Restaurantes',            href: '/for/restaurants/'              },
  { label: 'Techadores',              href: '/for/roofers/'                  },
  { label: 'Salones de Belleza',      href: '/for/salons/'                   },
  { label: 'Terapeutas',              href: '/for/therapists/'               },
  { label: 'Tutorías',                href: '/for/tutoring/'                 },
  { label: 'Veterinarios',            href: '/for/veterinarians/'            },
  { label: 'Proveedores de Bodas',    href: '/for/wedding/'                  },
];

const blogSEO = [
  { label: 'Consultoras',  href: '/es/para/consultoras/'  },
  { label: 'Ecommerce',    href: '/es/para/ecommerce/'    },
  { label: 'SaaS',         href: '/for/saas/'             },
];
---

<BaseLayout
  title="Stacc para Cada Industria | Automatización SEO por Tipo de Negocio | theStacc"
  description="Stacc automatiza el SEO para más de 30 industrias — desde negocios de servicio local hasta empresas SaaS. Encuentra tu industria y descubre exactamente cómo Stacc hace crecer tu tráfico orgánico."
  lang="es"
>
  <Fragment slot="head">
  </Fragment>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-[680px] text-center">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">30 Industrias · SEO Local &amp; SEO de Blog</span>
          </div>
          <h1 class="font-sans text-[2.2rem] font-semibold leading-[1.15] tracking-[-0.035em] text-[#111827] md:text-[3rem]">
            SEO diseñado para tu industria.
          </h1>
          <p class="mx-auto mt-5 max-w-[540px] font-sans text-[1.05rem] leading-[1.7] text-[#57534e]">
            Cada industria tiene palabras clave diferentes, compradores diferentes y señales de posicionamiento distintas. Stacc está entrenado en tu categoría — para que los artículos, publicaciones y optimizaciones que salen cada mes sean específicos a cómo tus clientes buscan realmente.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/es/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#292524] transition-colors hover:bg-[#fafaf9]"
            >
              Ver precios
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── MODULE EXPLAINER STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-10">
        <div class="mx-auto grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-2">
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">SEO Local</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$49/mes</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">Para negocios que dependen de la búsqueda local — publicaciones en GBP, seguimiento de reseñas y rastreo de posición en Maps. Ideal para negocios de servicios, tiendas físicas y cualquiera que quiera aparecer en el Map Pack.</p>
            </div>
          </div>
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">SEO de Blog</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$99/mes</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">Para negocios que crecen con contenido orgánico — 30 artículos SEO publicados en tu sitio cada mes. Ideal para SaaS, ecommerce y servicios profesionales que compiten a nivel nacional.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── LOCAL SEO INDUSTRIES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Módulo SEO Local</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$49/mes · {localSEO.length} industrias</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Negocios de servicio local
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            Publicaciones en GBP, gestión de reseñas y rastreo de posición en el Map Pack — todo automatizado.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {localSEO.map(item => (
            <a
              href={item.href}
              class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BLOG SEO INDUSTRIES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Módulo SEO de Blog</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$99/mes · {blogSEO.length} industrias</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Negocios impulsados por contenido
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            30 artículos SEO publicados en tu sitio cada mes — investigados, escritos y en vivo.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3">
          {blogSEO.map(item => (
            <a
              href={item.href}
              class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BOTTOM CTA ─── -->
    <section class="relative overflow-hidden py-16 md:py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.18) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.03) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>

      <div class="container-x relative">
        <div class="mx-auto max-w-xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">¿No ves tu industria?</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.03em] text-[#292524] md:text-[2.4rem]">
            Stacc funciona para cualquier<br />negocio que necesita tráfico orgánico.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Si tus clientes te buscan en Google, Stacc puede automatizar el SEO para que te encuentren. Reserva una demo y te mostraremos cómo funciona para tu negocio específico.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/es/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]"
            >
              Reservar una demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff] bg-white"
            >
              Ver precios
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
