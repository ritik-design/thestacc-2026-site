---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Cómo gestiona Stacc el control de marca entre franquiciados?",
    a: "La sede central establece las plantillas de contenido aprobadas, las directrices de marca y la cadencia de publicación obligatoria en Stacc. Los franquiciados pueden publicar dentro de esos parámetros — pueden localizar el contenido pero no desviarse de los estándares de marca. La sede mantiene visibilidad sobre la actividad de cada franquiciado y puede anular o eliminar contenido en cualquier momento.",
  },
  {
    q: "¿Qué pasa si un franquiciado no quiere usar Stacc?",
    a: "Con una tasa de adopción del 95%, la mayoría de los franquiciados adoptan Stacc rápidamente porque facilita su trabajo. Para franquiciados reacios, el equipo de incorporación de Stacc puede hacer una demostración directa. La sede también puede gestionar el SEO local de un franquiciado de forma centralizada si este decide no participar — en cualquier caso, la ubicación permanece activa.",
  },
  {
    q: "¿Pueden los franquiciados ver los datos de rendimiento de los demás?",
    a: "No. Cada franquiciado ve solo los datos de su propia ubicación. La sede y los directores regionales ven la cartera completa. Los permisos son basados en roles — los franquiciados no tienen visibilidad sobre el rendimiento, reseñas o posiciones de otros franquiciados. La sede puede compartir benchmarks competitivos si decide hacerlo.",
  },
  {
    q: "¿Se integra Stacc con nuestro software de gestión de franquicias?",
    a: "Stacc se conecta con plataformas comunes de gestión de franquicias y CRM mediante importación CSV, integración con Zapier y API directa. Los datos de ubicación — direcciones, números de teléfono, horarios, gestores — pueden sincronizarse automáticamente para que tus cuentas de Stacc se mantengan actualizadas a medida que crece tu red de franquicias.",
  },
  {
    q: "¿Cómo gestiona Stacc a los franquiciados en diferentes comunidades autónomas o países?",
    a: "Cada ubicación de franquiciado rastrea posiciones en su mercado geográfico específico. La gestión de citaciones maneja automáticamente las variaciones de directorios regionales. Para redes de franquicias internacionales, Stacc admite información de negocio específica por ubicación en formatos locales.",
  },
  {
    q: "¿Qué ve la sede que no ven los franquiciados?",
    a: "La sede ve la cartera completa — todas las posiciones de ubicación, puntuaciones de reseñas, salud de citaciones, actividad de GBP e historial de publicaciones de contenido en cada franquiciado. La sede también puede ver qué franquiciados están participando en la plataforma y cuáles están inactivos. Los informes de inactividad alertan a la sede cuando una ubicación no ha publicado o actualizado en un número establecido de días.",
  },
  {
    q: "¿Podemos aplicar marca blanca a Stacc para nuestra red de franquicias?",
    a: "Sí. Las redes de franquicias en los planes Growth y Scale pueden aplicar marca blanca al panel orientado al franquiciado bajo su marca. Los franquiciados acceden a 'Hub Local de TuMarca' — no a Stacc. Esto aumenta la adopción porque los franquiciados lo ven como tu sistema, no como una herramienta de terceros.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO para Franquicias",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Consigue las mejores posiciones locales para cada franquiciado sin perder el control de marca. theStacc permite a la sede establecer la estrategia mientras cada ubicación ejecuta localmente — automáticamente.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Soluciones", "item": "https://thestacc.com/es/soluciones/" },
        { "@type": "ListItem", "position": 3, "name": "Franquicias", "item": "https://thestacc.com/es/soluciones/franquicias/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Software SEO para Franquicias — SEO Local para Cada Franquiciado, Gestionado Centralmente | theStacc"
  description="Consigue las mejores posiciones locales para cada franquiciado sin perder el control de marca. theStacc permite a la sede establecer la estrategia mientras cada ubicación ejecuta localmente."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Para Redes de Franquicias · Control Central + Ejecución Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Cada franquiciado visible en Google.<br />
            <span style="color:#4f39f6;">Cada publicación dentro de los estándares de tu marca.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            La sede establece la estrategia. Cada ubicación ejecuta localmente. Automatizado. Visible. Bajo control. Stacc es la plataforma que conecta ambos lados de la ecuación de la franquicia.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Ver una demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Hablar con el equipo
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            95% tasa de adopción · Control central de marca · Configuración por ubicación en menos de 30 min
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '95%',  num: 95,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Tasa de adopción de franquiciados' },
              { value: '500+', num: 500, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Ubicaciones gestionadas' },
              { value: '30min', num: 30, prefix: '', suffix: 'min', decimals: 0, from: 0, label: 'Configuración por ubicación' },
              { value: '4.9★', num: 4.9, prefix: '', suffix: '★', decimals: 1, from: 0, label: 'Valoración media' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema de las franquicias</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Construiste una red de franquicias.<br />No deberías necesitar un equipo de SEO para cada una.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Ubicaciones que no publican. Perfiles que se pudren.',
              body: 'Tu estándar de marca dice que cada ubicación debe publicar 3 veces por semana en GBP. La realidad es que el 60% de tus franquiciados no ha publicado en semanas. Google lo ve. Los clientes locales te ven menos. La invisibilidad se acumula.',
            },
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'No sabes qué ubicaciones están ganando ni perdiendo.',
              body: 'Tienes 40 ubicaciones. No tienes forma de ver de un vistazo cuáles están en el top 3 local y cuáles ni siquiera aparecen. Sin visibilidad centralizada, los problemas se descubren cuando un franquiciado llama a quejarse — meses después de que el daño ya está hecho.',
            },
            {
              icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'La inconsistencia de NAP destruye el SEO de toda la red.',
              body: 'Cuando una ubicación tiene 3 versiones diferentes de su dirección en distintos directorios, Google pierde la confianza en toda la red. Una citación incorrecta en 50 directorios multiplicada por 40 ubicaciones es el peor enemigo de tu presencia local.',
            },
            {
              icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
              title: 'Reseñas negativas sin respuesta dañan la marca global.',
              body: 'Una reseña de 1 estrella sin respuesta en la ubicación de un franquiciado no es solo un problema local — es un problema de marca. Los clientes potenciales en cualquier ciudad buscan tu nombre y ven lo que no respondes. La reputación de la red se construye o destruye a nivel de ubicación individual.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW STACC WORKS FOR FRANCHISES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dos niveles, una plataforma</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La sede controla la estrategia.<br />Los franquiciados ejecutan localmente. Stacc automatiza todo.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-14">

          <!-- HQ View -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Vista de Sede Central</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Toda la red. Un panel. Control total.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                La sede ve el rendimiento de cada ubicación en tiempo real. Posiciones, actividad de GBP, puntuaciones de reseñas, salud de citaciones — todo en un panel centralizado. Aprueba plantillas de contenido, establece estándares de publicación y monitorea el cumplimiento sin visitar cada panel individualmente.
              </p>
              <ul class="mt-6 space-y-3">
                {['Cartera completa: posiciones, reseñas, GBP y citaciones en todas las ubicaciones', 'Aprueba plantillas de contenido que los franquiciados usan para publicar localmente', 'Alertas de inactividad cuando una ubicación deja de publicar', 'Informes de rendimiento comparativo entre ubicaciones'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Panel de Red — Vista Sede Central</p>
              {[
                { loc: 'Madrid Centro', rank: '#1 Local', status: 'Activa', color: '#059669' },
                { loc: 'Barcelona Eixample', rank: '#2 Local', status: 'Activa', color: '#059669' },
                { loc: 'Valencia Centro', rank: '#4 Local', status: 'Alerta', color: '#d97706' },
                { loc: 'Sevilla Norte', rank: '#3 Local', status: 'Activa', color: '#059669' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <div class="h-8 w-8 rounded-full bg-[#f5f3ff] flex items-center justify-center shrink-0">
                    <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">{r.loc[0]}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[13px] font-semibold text-[#111827] truncate">{r.loc}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.rank}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold shrink-0" style={`color:${r.color}`}>{r.status}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Franchisee View -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Panel de Franquiciado — Mi Ubicación</p>
              <div class="space-y-4">
                <div class="rounded-xl bg-[#f5f3ff] p-4">
                  <div class="flex items-center justify-between">
                    <span class="font-sans text-[13px] font-semibold text-[#111827]">Publicaciones GBP este mes</span>
                    <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">28 / 30</span>
                  </div>
                  <div class="mt-2 h-1.5 w-full rounded-full bg-[#e7e5e4]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:93%"></div></div>
                </div>
                <div class="rounded-xl bg-[#fafaf9] p-4">
                  <div class="flex items-center justify-between">
                    <span class="font-sans text-[13px] font-semibold text-[#111827]">Posición en Maps</span>
                    <span class="font-sans text-[13px] font-semibold text-[#059669]">#2 ↑</span>
                  </div>
                </div>
                <div class="rounded-xl bg-[#fafaf9] p-4">
                  <div class="flex items-center justify-between">
                    <span class="font-sans text-[13px] font-semibold text-[#111827]">Reseñas respondidas</span>
                    <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">100%</span>
                  </div>
                </div>
                <p class="text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Todo automatizado · Dentro de los estándares de marca</p>
              </div>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Vista del Franquiciado</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Los franquiciados ven sus datos. Publican dentro de tu marca. Stacc hace el trabajo.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cada franquiciado accede a un panel simplificado con solo sus datos de ubicación. Ven sus posiciones, reseñas y actividad de GBP. Pueden publicar contenido personalizado localmente — pero solo dentro de las plantillas aprobadas por la sede. Sin desviaciones de marca. Sin sorpresas.
              </p>
              <ul class="mt-6 space-y-3">
                {['Solo datos de su ubicación — sin visibilidad sobre otros franquiciados', 'Publicación local dentro de las plantillas aprobadas por la sede', 'Alertas de reseñas y herramientas de respuesta integradas', 'Marca blanca opcional — ven tu marca, no Stacc'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados en redes de franquicias</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que cambia cuando cada ubicación<br />ejecuta el SEO local automáticamente.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '95%', num: 95, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Tasa de adopción de franquiciados', sub: 'porque facilita su trabajo, no lo complica' },
            { value: '3×',  num: 3,  prefix: '', suffix: '×', decimals: 0, from: 0, label: 'Más publicaciones por ubicación', sub: 'frente al estándar de publicación manual' },
            { value: '1',   num: 1,  prefix: '', suffix: ' panel', decimals: 0, from: 0, label: 'Para gestionar toda la red', sub: 'sin importar cuántas ubicaciones tengas' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas que hacen las redes de franquicias
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Tu red. Visible en todas partes.</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Cada franquiciado posicionando localmente.<br />
            <span style="color:#818cf8;">Cada publicación dentro de los estándares de tu marca.</span>
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Las redes de franquicias que ganan no tienen mejor producto. Tienen mejor ejecución de SEO local en cada ubicación. Stacc convierte cada franquiciado en una máquina de SEO local — sin que la sede pierda el control. La demo tarda 20 minutos.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Obtener demo para franquicias
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Ver precios
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">30 días de garantía · Sin contratos · Onboarding incluido</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
