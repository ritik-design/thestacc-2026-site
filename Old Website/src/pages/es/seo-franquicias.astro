                    <p class="font-mono text-[10px] text-[#79716b]">{r.post}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">3 franquicias · Posts localizados · Automático</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
