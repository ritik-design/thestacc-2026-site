              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes automáticos para cada franquicia.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cada franquiciado recibe su informe mensual de rendimiento generado y entregado automáticamente. Los franquiciadores reciben el resumen de red. Todo configurado una vez — Stacc lo ejecuta para siempre. Sin exportaciones manuales, sin formateo, sin envío manual.
              </p>
              <a href="/es/funciones/informes-multi-ubicacion/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver informes automatizados
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Entrega de informes mensuales</p>
              {[
                { loc: 'Franquicia Madrid Centro', status: 'Entregado', time: '1 Abr, 9:00' },
                { loc: 'Franquicia Barcelona Eixample', status: 'Entregado', time: '1 Abr, 9:00' },
                { loc: 'Franquicia Valencia Norte', status: 'Entregado', time: '1 Abr, 9:00' },
                { loc: 'Franquicia Sevilla Sur', status: 'Entregado', time: '1 Abr, 9:00' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
