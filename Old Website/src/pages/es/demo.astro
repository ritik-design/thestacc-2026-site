                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Right: form -->
          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-8">

            <!-- Plan summary (shown when arriving from /review) -->
            <div id="plan-summary-banner" class="hidden mb-5 rounded-xl border border-[#4f39f6]/25 bg-[#4f39f6]/[0.05] px-4 py-3">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.1em] text-[#4f39f6]">Tu plan seleccionado</p>
                  <p id="plan-summary-text" class="mt-1 font-sans text-[13px] leading-[20px] text-[#374151]"></p>
                </div>
                <a id="plan-back-link" href="/review/" class="shrink-0 font-sans text-[12px] font-medium text-[#4f39f6] hover:underline">Editar →</a>
              </div>
            </div>

            <p class="font-sans text-[15px] font-semibold text-[#111827]">Reserva tu llamada de estrategia gratuita</p>
            <p class="mt-1 font-sans text-[13px] text-[#79716b]">Confirmaremos en 1 día hábil.</p>

            <form
              id="demo-form"
              class="mt-6 flex flex-col gap-4"
              novalidate
            >
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="flex flex-col gap-1.5">
                  <label for="demo-fname" class="font-sans text-[12px] font-semibold text-[#374151]">Nombre <span class="text-[#ef4444]">*</span></label>
                  <input
                    id="demo-fname" name="first_name" type="text" required autocomplete="given-name"
                    placeholder="Ana"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="demo-lname" class="font-sans text-[12px] font-semibold text-[#374151]">Apellido <span class="text-[#ef4444]">*</span></label>
                  <input
                    id="demo-lname" name="last_name" type="text" required autocomplete="family-name"
                    placeholder="García"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="flex flex-col gap-1.5">
                  <label for="demo-email" class="font-sans text-[12px] font-semibold text-[#374151]">Correo de trabajo <span class="text-[#ef4444]">*</span></label>
                  <input
                    id="demo-email" name="email" type="email" required autocomplete="email"
                    placeholder="ana@tunegocio.com"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="demo-phone" class="font-sans text-[12px] font-semibold text-[#374151]">Número de teléfono <span class="text-[#ef4444]">*</span></label>
                  <input
                    id="demo-phone" name="phone" type="tel" required autocomplete="tel"
                    placeholder="+1 (555) 000-0000"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                  />
                </div>
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="demo-website" class="font-sans text-[12px] font-semibold text-[#374151]">URL del sitio web</label>
                <input
                  id="demo-website" name="website" type="url" autocomplete="url"
                  placeholder="https://tunegocio.com"
                  class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                />
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="demo-business" class="font-sans text-[12px] font-semibold text-[#374151]">Nombre y sector del negocio</label>
                <input
                  id="demo-business" name="business" type="text" required
                  placeholder="Clínica García · Odontología"
                  class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                />
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="demo-plan" class="font-sans text-[12px] font-semibold text-[#374151]">¿Qué plan te interesa?</label>
                <select
                  id="demo-plan" name="plan"
                  class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#374151] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10 cursor-pointer"
                >
                  <option value="">Aún no lo sé</option>
                  <option value="local-growth">Crecimiento Local · $749/mes</option>
                  <option value="growth-pro">Crecimiento Pro · $999/mes</option>
                  <option value="growth-complete">Crecimiento Completo · $1,299/mes</option>
                </select>
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="demo-goal" class="font-sans text-[12px] font-semibold text-[#374151]">¿Cuál es tu mayor reto de marketing ahora mismo?</label>
                <textarea
                  id="demo-goal" name="goal" rows="3"
                  placeholder="ej. No aparecemos en Google Maps, nuestro blog no se ha actualizado en 2 años..."
                  class="rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10 resize-none leading-relaxed"
                ></textarea>
              </div>

              <input type="hidden" id="demo-modules" name="selected_modules" />

              <button
                type="submit"
                id="demo-submit"
                class="mt-2 flex h-12 w-full cursor-pointer items-center justify-center gap-2 rounded-xl bg-[#4f39f6] font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
              >
                Reservar mi llamada de estrategia gratuita
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>

              <!-- Success state -->
              <div id="demo-success" class="hidden rounded-xl border border-[#bbf7d0] bg-[#f0fdf4] px-5 py-4 text-center">
                <p class="font-sans text-[14px] font-semibold text-[#15803d]">¡Solicitud recibida!</p>
                <p class="mt-1 font-sans text-[13px] text-[#166534]">Confirmaremos tu franja horaria en 1 día hábil.</p>
              </div>
            </form>

            <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.14em] text-[#79716b]">
              Sin compromiso · Gratuita · 30 minutos
            </p>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    // ─── PRICING FLOW CONTEXT ───
    (function () {
      const urlParams = new URLSearchParams(window.location.search);
      const billing = urlParams.get('billing') || 'annual';
      const tierMap: Record<string, { label: string; price: number }[]> = {
        blog:   [{ label: '30 artículos', price: 99 }, { label: '50 artículos', price: 149 }, { label: '80 artículos', price: 199 }],
        local:  [{ label: '30 posts',     price: 49 }, { label: '60 posts',     price: 79  }, { label: '80 posts',     price: 99  }],
        social: [{ label: '30 posts',     price: 49 }, { label: '60 posts',     price: 79  }, { label: '120 posts',    price: 129 }],
      };
      const moduleNames: Record<string, string> = { blog: 'Blog SEO', local: 'SEO Local', social: 'Redes Sociales' };
      const selectedKeys = (['blog', 'local', 'social'] as const).filter(m => urlParams.has(m));

      if (selectedKeys.length === 0) return;

      document.getElementById('pricing-step-indicator')?.classList.remove('hidden');

      const parts = selectedKeys.map(mod => {
        const idx = Math.min(parseInt(urlParams.get(mod) || '0'), tierMap[mod].length - 1);
        const tier = tierMap[mod][idx];
        const price = billing === 'annual' ? Math.round(tier.price * 0.83) : tier.price;
        return `${moduleNames[mod]} · ${tier.label} · $${price}/mes`;
      });
      const hasBundleDiscount = selectedKeys.length >= 2;
      const summaryText = parts.join('\n') + (hasBundleDiscount ? '\n15% de descuento por bundle aplicado' : '');

      const banner = document.getElementById('plan-summary-banner');
      const summaryTextEl = document.getElementById('plan-summary-text');
      const backLink = document.getElementById('plan-back-link') as HTMLAnchorElement | null;
      if (banner && summaryTextEl) {
        summaryTextEl.style.whiteSpace = 'pre-line';
        summaryTextEl.textContent = summaryText;
        banner.classList.remove('hidden');
      }
      if (backLink) {
        backLink.href = '/review/?' + urlParams.toString();
      }

      const modulesInput = document.getElementById('demo-modules') as HTMLInputElement | null;
      if (modulesInput) {
        modulesInput.value = selectedKeys.join(',');
      }

      if (document.referrer.includes('/review')) {
        document.getElementById('book')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    })();

    // ─── FAQ ACCORDION ───
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });

    // ─── FORM SUBMISSION ───
    const form = document.getElementById('demo-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('demo-submit') as HTMLButtonElement | null;
    const successEl = document.getElementById('demo-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !successEl) return;

      const originalText = submitBtn.textContent ?? '';
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      try {
        const fd = new FormData(form);
        const data = {
          first_name: (fd.get('first_name') as string)?.trim(),
          last_name: (fd.get('last_name') as string)?.trim(),
          email: (fd.get('email') as string)?.trim(),
          phone: (fd.get('phone') as string)?.trim(),
          website: (fd.get('website') as string)?.trim() || undefined,
          business: (fd.get('business') as string)?.trim() || undefined,
          plan: (fd.get('plan') as string) || undefined,
          goal: (fd.get('goal') as string)?.trim() || undefined,
        };

        const res = await fetch('/api/demo/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.reset();
          successEl.classList.remove('hidden');
          submitBtn.classList.add('hidden');
        } else {
          const result = await res.json().catch(() => ({}));
          throw new Error(result.error || 'Network error');
        }
      } catch (err) {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        const msg = err instanceof Error ? err.message : 'Something went wrong.';
        alert(`${msg} Email us directly at sidgangal@gmail.com`);
      }
    });
  </script>
</BaseLayout>
