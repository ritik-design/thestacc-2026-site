---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué es el software de automatización SEO?", a: "El software de automatización SEO gestiona las tareas recurrentes y repetitivas del SEO sin necesidad de ejecución manual cada vez — rastreo de posiciones, monitoreo de citaciones, publicación de contenido, alertas de reseñas y generación de informes. Para el SEO local específicamente, la automatización es la única manera de mantener una ejecución SEO consistente en múltiples ubicaciones." },
  { q: "¿Qué tareas de SEO local automatiza Stacc?", a: "Publicación de posts en GBP (30/mes por ubicación), monitoreo y corrección de citaciones en más de 50 directorios, rastreo diario de posiciones para cada palabra clave y ubicación, alertas de reseñas en tiempo real y generación y entrega automatizada de informes. Todo lo que de otro modo requeriría trabajo manual por sede, cada día." },
  { q: "¿La automatización SEO es solo para agencias o también para equipos internos?", a: "Para ambos. Las agencias usan Stacc para escalar la entrega de SEO local en portafolios de clientes sin un crecimiento proporcional de personal. Los equipos internos de negocios con múltiples ubicaciones lo usan para mantener un SEO consistente en todas las sedes sin necesitar personal SEO dedicado por ubicación." },
  { q: "¿La automatización SEO realmente produce resultados o solo ahorra tiempo?", a: "Ambas cosas. El ahorro de tiempo es real — los clientes de Stacc reportan más de 8 horas ahorradas por mes por ubicación. Y los resultados son reales: la actividad consistente en GBP se correlaciona con mejores posicionamientos en Maps, y la precisión constante de citaciones reduce la penalización de posicionamiento por inconsistencia de NAP. La automatización ofrece tanto eficiencia como resultados." },
  { q: "¿Cuál es la diferencia entre Stacc y un rastreador de posiciones estándar?", a: "La mayoría de los rastreadores de posiciones solo rastrean. Stacc rastrea y actúa. Publica posts en GBP, monitorea citaciones, alerta sobre reseñas, genera informes — todo automáticamente. Es una plataforma de ejecución, no un panel de datos que requiere que tú hagas el trabajo real." },
  { q: "¿Cuánto cuesta el software de automatización SEO?", a: "El módulo SEO local de Stacc comienza desde $49/mes con una prueba gratuita de 14 días. Todas las funciones de automatización están incluidas — sin restricciones de funciones en la automatización de GBP, monitoreo de citaciones o informes." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "inLanguage": "es", "name": "theStacc — Software de Automatización SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Software de automatización SEO local que ejecuta la gestión de GBP, monitoreo de citaciones, rastreo de posiciones e informes automáticamente — para que te centres en la estrategia, no en la ejecución.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Software de Automatización SEO", "item": "https://thestacc.com/es/software-automatizacion-seo/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de Automatización SEO para Negocios Locales — Deja de Hacer SEO Manualmente | theStacc"
  description="Deja de gestionar el SEO local a mano. theStacc automatiza la publicación en GBP, monitoreo de citaciones, rastreo de posiciones e informes — cada ubicación, cada día, sin trabajo manual."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de Automatización SEO · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local que se gestiona solo.<br />
            <span style="color:#4f39f6;">No un panel que gestionas manualmente.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc automatiza cada tarea repetitiva de SEO local — publicación en GBP, monitoreo de citaciones, rastreo de posiciones, alertas de reseñas e informes — en cada ubicación, cada día, sin trabajo manual.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/automatizacion-seo-local/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver resumen de automatización
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito · Cancela cuando quieras</p>
        </div>
      </div>
    </section>


    <!-- ─── PAIN ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El coste de la ejecución manual del SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La mayoría de las herramientas SEO te dicen qué hacer.<br />Stacc lo hace.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>La mayoría del software SEO local está diseñado asumiendo que una persona ejecutará las recomendaciones. Accedes, ves lo que hay que hacer y lo haces manualmente. Eso funciona en un mundo donde tienes tiempo ilimitado y una sola ubicación. Falla en el primer punto de inflexión de escala.</p>
            <p>La automatización SEO real no es solo programar una tarea — es eliminarte del bucle de ejecución por completo. Los posts se publican sin que nadie haga clic en publicar. Las citaciones se monitorean sin que nadie ejecute la auditoría. Los informes se entregan sin que nadie exporte un CSV. Eso es lo que hace Stacc: completa el trabajo, no solo lo identifica.</p>
            <p class="font-semibold text-[#111827]">Los negocios que están ganando en búsqueda local ahora mismo no están haciendo más trabajo. Automatizaron el trabajo, y están multiplicando los resultados cada día mientras sus competidores siguen haciendo clic en paneles.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lo que se automatiza</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarea SEO local que se repite.<br />Cada una automatizada.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Publicación de posts en GBP', body: '30 posts optimizados por ubicación al mes, publicados automáticamente según calendario. Los perfiles se mantienen activos todos los días sin trabajo manual.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreo diario de posiciones', body: 'Posicionamientos actualizados diariamente para todas las palabras clave y ubicaciones. Las alertas se activan ante cambios significativos. Sin revisiones manuales de posicionamiento requeridas.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoreo de citaciones', body: 'Monitorea continuamente la precisión de los datos NAP en más de 50 directorios. Señala inconsistencias. Correcciones masivas en múltiples ubicaciones con una sola acción.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Automatización de alertas de reseñas', body: 'Las nuevas reseñas generan alertas instantáneas. Monitorea la reputación de cada ubicación en tiempo real sin revisar cada plataforma por separado.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Generación y entrega de informes', body: 'Los informes se generan según calendario y se entregan automáticamente. Sin exportaciones, sin formateo, sin envíos manuales. Los informes llegan a las bandejas de entrada sin que nadie de tu equipo los toque.' },
            { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Sincronización de palabras clave y citaciones', body: 'Los conjuntos de palabras clave y las fuentes de citaciones permanecen sincronizados entre ubicaciones. Al añadir nuevas palabras clave o sedes, la automatización se extiende automáticamente.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades clave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada palanca SEO local automatizada.<br />Cada resultado visible.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicación Automatizada de GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 publicaciones GBP al mes. Programadas, redactadas y publicadas automáticamente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                La automatización de GBP no es solo programar — es eliminar el trabajo creativo y operativo. Stacc redacta cada post según las palabras clave de tu ubicación, lo formatea siguiendo las mejores prácticas del paquete local y lo publica según calendario. El resultado: 30 publicaciones por ubicación al mes, sin que nadie escriba ni programe manualmente.
              </p>
              <a href="/es/modulos/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el módulo SEO Local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario automatizado de GBP</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 22 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Publicado automáticamente</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">22 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:73%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">8 más programadas · Cero clics manuales</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Alertas automáticas de cambios de posición</p>
              {[
                { kw: 'fontanero urgencias [ciudad]', pack: 1, change: '+3', trend: 'up' },
                { kw: 'reparación de fugas cerca de mí', pack: 2, change: '+2', trend: 'up' },
                { kw: 'cambio de caldera [ciudad]', pack: 4, change: '-1', trend: 'down' },
                { kw: 'fontanería 24 horas', pack: 6, change: '+1', trend: 'up' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#ef4444]'}`}>{r.trend === 'up' ? '↑' : '↓'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Verificadas diariamente · Alertas automáticas ante cambios</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreo de Posiciones Automatizado</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Verificación diaria de posiciones. Sin que tú abras el panel.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Las posiciones se verifican cada mañana en cada palabra clave en cada ubicación. Cuando algo cambia significativamente — un drop de 5 posiciones, una entrada en el top 3, un movimiento del competidor — Stacc te alerta antes de que abras el panel. La automatización significa que no hay que recordar revisar; las cosas que importan llegan a ti.
              </p>
              <a href="/es/funciones/rastreo-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver rastreo de posiciones
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informes Automatizados de Marca Blanca</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                El informe se genera, se formatea y se entrega solo. Cada semana. Cada cliente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                La automatización de informes es donde la inversión paga sola. Configura la plantilla y el calendario una vez por cliente. Stacc compila los datos, los formatea con la marca de tu agencia y los entrega en la bandeja del cliente — sin exportaciones, sin formateo, sin envíos manuales. La hora que antes pasabas en el ritual del viernes ahora la pasas vendiendo o entregando estrategia.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Tu Agencia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Informe Semanal Automatizado</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Entregado</span>
              </div>
              {[
                { label: 'Tareas SEO ejecutadas', val: '142 esta semana' },
                { label: 'Posts GBP publicados', val: '30 sin trabajo manual' },
                { label: 'Ahorro de tiempo total', val: '8.4 horas' },
                { label: 'Informes entregados', val: '100% a tiempo' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generado y entregado automáticamente · Sin trabajo manual</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 8, suffix: ' hrs', label: 'Ahorradas por ubicación al mes', sub: 'La automatización reemplaza la ejecución manual' },
            { to: 89, suffix: '%', label: 'Mejora de posicionamiento en GBP en 90 días', sub: 'Frente a base de referencia inactiva' },
            { to: 100, suffix: '%', label: 'Entrega de informes puntual', sub: 'Sin pasos manuales, sin retrasos' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF ─── -->
