---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué es el SEO local white label?", a: "El SEO local white label es la práctica de las agencias de ofrecer servicios de optimización en búsqueda local a clientes usando una plataforma con la identidad propia de la agencia — su logo, dominio y colores — en lugar de la del proveedor del software. Los clientes interactúan con la marca de la agencia en todos los paneles, informes y comunicaciones." },
  { q: "¿Qué tareas de SEO local automatiza Stacc bajo white label?", a: "Todas: publicación de posts en GBP (30/mes por ubicación), rastreo diario de posiciones, monitoreo de citaciones en 50+ directorios, alertas de reseñas en tiempo real, y generación y entrega automatizada de informes. Todo está completamente automatizado y se entrega bajo la marca de tu agencia." },
  { q: "¿Puedo vender los servicios de SEO local de Stacc como propios?", a: "Sí. Stacc está diseñado específicamente para este caso de uso. Entregas resultados de SEO local a través de una plataforma que lleva tu marca. Los clientes nunca ven el nombre de Stacc. Tú estableces tus propios precios a los clientes y te quedas con el margen entre lo que cobras y lo que cuesta Stacc." },
  { q: "¿Puedo tener diferentes plantillas de informes para distintos clientes?", a: "Sí. Cada cliente puede tener una configuración de informe personalizada — métricas diferentes, calendarios de entrega diferentes, logos diferentes si gestionas submarcas. Los informes se generan y se entregan automáticamente para cada cliente según su configuración." },
  { q: "¿Hay un mínimo de clientes para usar el white label?", a: "No hay mínimo. Puedes configurar el white label con un solo cliente y escalar desde ahí. El precio se basa en las ubicaciones gestionadas, no en el número de clientes." },
  { q: "¿Ofrece Stacc soporte a agencias para la configuración white label?", a: "Sí. El equipo de Stacc proporciona soporte en la configuración white label y la incorporación inicial de clientes. La mayoría de las agencias completan su primera configuración white label de forma independiente en unas 2 horas." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO Local White Label", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "es", "description": "Plataforma de SEO local white label para agencias. Entrega gestión de GBP, rastreo de posiciones, monitoreo de citaciones e informes bajo tu propia marca.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "SEO Local White Label", "item": "https://thestacc.com/es/seo-local-white-label/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="SEO Local White Label para Agencias — Entrega Resultados Bajo Tu Marca | theStacc"
  description="Plataforma de SEO local white label para agencias. Gestión de GBP, rastreo de posiciones, citaciones e informes — automatizados y entregados bajo la marca de tu agencia a cada cliente."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Local White Label · Para Agencias · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local white label que tus clientes<br />
            <span style="color:#4f39f6;">experimentan como tu propia plataforma.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc ofrece automatización completa de SEO local — GBP, posiciones, citaciones, reseñas, informes — a través de una plataforma completamente identificada con tu marca. Los clientes ven tu logo, tu dominio, tus informes.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empezar por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#features" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver funciones para agencias
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito · Cancela cuando quieras</p>

          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">+400 agencias white label</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuración en 2 horas</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Qué entrega realmente el SEO local white label</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Los clientes ven tu marca. Tú entregas<br />resultados reales de SEO local. Automáticamente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>El SEO local white label no consiste simplemente en poner tu logo en el panel de otro. Se trata de poder ofrecer ejecución de SEO local de alta calidad y automatizada bajo tu propia marca — para que puedas escalar tu base de clientes sin escalar tu equipo en la misma proporción.</p>
            <p>Stacc automatiza cada tarea continua de SEO local: 30 posts de GBP al mes, rastreo diario de posiciones, monitoreo de citaciones en 50+ directorios, alertas de reseñas en tiempo real e informes automatizados para clientes. Todo sucede bajo tu marca. Configuras los clientes una vez y la plataforma ejecuta el trabajo de forma automática — lo que te da la capacidad de atender a tres veces más clientes de SEO local sin tres veces más personal.</p>
            <p class="font-semibold text-[#111827]">El resultado: un servicio de SEO local que tus clientes perciben como una plataforma propia de tu agencia, con márgenes más altos y menos horas facturables que se evaporan en trabajo manual.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Qué está incluido</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            SEO local completo bajo tu marca.<br />Cada tarea. Cada cliente.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automatización de posts en GBP', body: 'Stacc publica 30 posts al mes por ubicación dirigidos a la intención de búsqueda local. Los perfiles permanecen activos cada día — sin trabajo del cliente, sin trabajo de la agencia.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreo diario de posiciones', body: 'Cada palabra clave actualizada diariamente para cada ubicación de cliente. Posiciones visibles en paneles de clientes con tu marca, con datos de tendencias y alertas de cambios.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitoreo de citaciones', body: 'Monitoreo continuo de la precisión NAP en 50+ directorios para cada cliente. Las inconsistencias se detectan y corrigen automáticamente.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestión de reseñas', body: 'Alertas de reseñas en tiempo real para cada ubicación de cliente. Responde desde el panel de tu agencia. Rastrea tasas de respuesta y puntuaciones de reputación por cliente.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Informes automatizados con tu marca', body: 'Informes generados según calendario, formateados con tu logo y entregados desde tu dominio. Cero pasos manuales por cliente al mes.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Dominio personalizado + marca', body: 'Los clientes acceden a los paneles en tu subdominio. Tu logo y colores en cada pantalla. $0 por acceso de cliente. El nombre de Stacc nunca es visible.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades clave para agencias</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Todo lo que tus clientes ven<br />lleva tu marca, no la nuestra.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicaciones GBP bajo tu marca</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 publicaciones GBP al mes por ubicación. Aprobadas en tu panel. Atribuidas a tu agencia.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El algoritmo del pack local de Google premia la actividad consistente en GBP. Stacc redacta 30 posts optimizados al mes para cada ubicación de cliente — orientados a combinaciones servicio + ciudad, búsquedas "cerca de mí" y campañas estacionales — y los publica en calendario. Tú revisas el flujo desde el panel con tu marca; los clientes ven los resultados pero nunca el motor.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Publicaciones GBP — Cliente: Dental Vega</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 22 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Publicaciones de este mes</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">22 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:73%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Entregado bajo tu marca · Sin trabajo del cliente · Sin trabajo de tu equipo</p>
            </div>
          </div>

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Panel del cliente — seo.tuagencia.com</p>
              {[
                { kw: 'fontanero urgencias [ciudad]', pack: 1, change: '+3', trend: 'up' },
                { kw: 'reparación caldera cerca de mí', pack: 2, change: '+1', trend: 'up' },
                { kw: 'instalador de calderas [barrio]', pack: 3, change: '+2', trend: 'up' },
                { kw: 'desatasco cerca de mí', pack: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Logo y dominio de tu agencia · Datos diarios · Acceso de cliente $0</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreo de posiciones multi-cliente</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Cada cliente, cada ubicación, cada palabra clave — actualizado a diario en tu propia plataforma.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Tus clientes ven sus posiciones en el pack local, en Maps y en orgánico desde un panel que se carga en tu subdominio. Tu equipo gestiona todas las cuentas desde una vista de administrador, con filtros por cliente, ubicación o palabra clave. Las alertas de cambios se envían desde tu dominio, con tu logo, y se atribuyen mentalmente a tu trabajo.
              </p>
              <a href="/es/funciones/rastreo-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el rastreo de posiciones en detalle
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informes white label automatizados</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes que se construyen, se marcan y se envían solos. Cada cliente. Cada semana. Bajo tu marca.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configura la plantilla una vez por cliente — métricas, calendario, frecuencia. Stacc genera el PDF con tu logo, lo envía desde tu dominio y aterriza en la bandeja de entrada del cliente con tu firma. Nadie de tu equipo lo toca. Tus clientes asumen que tienes una plataforma propia. Tú escalas la base de clientes sin escalar al equipo de cuenta.
              </p>
              <a href="/es/reportes-white-label/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver reportes white label
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Tu Agencia</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Informe Semanal — Dental Vega</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Enviado</span>
              </div>
              {[
                { label: 'Posiciones en top 3 (pack local)', val: '+5 palabras clave' },
                { label: 'Publicaciones GBP entregadas', val: '7 esta semana' },
                { label: 'Reseñas nuevas', val: '3 ⭐ media 4.9' },
                { label: 'Citaciones corregidas', val: '4 directorios' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Enviado desde reports@tuagencia.com · Sin marca de Stacc</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que el SEO local white label<br />hace a la economía de tu agencia.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Promedios de agencias que sustituyeron el trabajo manual de SEO local por la automatización white label de Stacc.
