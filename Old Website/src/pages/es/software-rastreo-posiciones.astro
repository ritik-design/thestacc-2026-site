---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué es el software de rastreo de posiciones?", a: "El software de rastreo de posiciones monitorea dónde aparece tu sitio web y tu Perfil de Empresa de Google en los resultados de búsqueda para tus palabras clave objetivo. El rastreo de posiciones locales rastrea específicamente tu posición en el paquete local de Google, Google Maps y los resultados orgánicos — las tres superficies de posicionamiento separadas que importan para los negocios locales." },
  { q: "¿Con qué frecuencia actualiza Stacc los posicionamientos?", a: "Diariamente. Los posicionamientos se actualizan cada día en todas las palabras clave rastreadas de cada ubicación. Siempre ves los datos de posición del día actual, no una instantánea semanal o mensual." },
  { q: "¿Rastrea Stacc las posiciones del paquete local por separado de las orgánicas?", a: "Sí. Para los negocios locales, el paquete local y el orgánico son superficies de posicionamiento separadas con algoritmos diferentes. Stacc rastrea ambas de forma independiente para que puedas ver tu posición en Maps/paquete y tu posición orgánica para la misma palabra clave — porque a menudo se comportan de manera diferente." },
  { q: "¿Puedo rastrear posicionamientos para múltiples ubicaciones?", a: "Sí. Cada ubicación tiene su propio conjunto de palabras clave rastreado de forma independiente. El panel de portafolio compara todas las sedes en paralelo. Puedes ordenar por cualquier métrica para ver al instante qué ubicaciones están ganando y cuáles tienen bajo rendimiento." },
  { q: "¿Cómo me alerta Stacc cuando cambian los posicionamientos?", a: "Puedes configurar alertas de cambio de posicionamiento que se activan cuando cualquier palabra clave rastreada cruza un umbral — por ejemplo, cuando una palabra clave sale del top 3 o cuando entra en el top 3 por primera vez. Las alertas llegan por correo electrónico o notificación en el panel." },
  { q: "¿Los datos de rastreo de posiciones se incluyen en los informes para clientes?", a: "Sí. Los datos de posicionamiento se incluyen en los informes automáticos para clientes. Los informes se generan según tu calendario y se entregan automáticamente — sin necesidad de exportación manual. Las agencias pueden añadir su marca blanca a todos los informes." },
  { q: "¿Cuánto cuesta el software de rastreo de posiciones?", a: "El rastreo de posiciones está incluido en el módulo SEO local de Stacc desde $49/mes. El rastreo diario de palabras clave ilimitadas por ubicación está incluido." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "inLanguage": "es", "name": "theStacc — Software de Rastreo de Posiciones", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Software de rastreo de posiciones locales con actualizaciones diarias para cada palabra clave en cada ubicación. Rastrea posicionamientos en paquete local, Maps y orgánico — todo en un panel.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Software de Rastreo de Posiciones", "item": "https://thestacc.com/es/software-rastreo-posiciones/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de Rastreo de Posiciones Locales — Posicionamientos Diarios para Cada Ubicación | theStacc"
  description="Rastrea posicionamientos en paquete local, Maps y orgánico diariamente para cada palabra clave en cada ubicación. El software de rastreo de posiciones de theStacc se actualiza automáticamente — sin revisiones manuales."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de Rastreo de Posiciones · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Posicionamientos actualizados diariamente.<br />
            <span style="color:#4f39f6;">Cada palabra clave. Cada ubicación. Automáticamente.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc rastrea posicionamientos en paquete local, Maps y orgánico para cada palabra clave en cada ubicación — actualizado diariamente, comparado entre sedes y alertándote en el momento en que algo cambia.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/funciones/seguimiento-posiciones/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver detalles del rastreo de posiciones
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito · Cancela cuando quieras</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas y agencias</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ ubicaciones gestionadas</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué importan los datos de posicionamiento diarios</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Una caída de posición que detectas hoy<br />cuesta una fracción de la que detectas en 30 días.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Una palabra clave que baja de la posición 3 a la 7 pierde más del 50% de su tasa de clics de la noche a la mañana. Si tu herramienta de rastreo se actualiza semanal o mensualmente, esa caída puede costarte cuatro semanas de tráfico perdido antes de que te enteres. Para cuando diagnostiques la causa y tomes acción, estás recuperándote de un déficit de un mes — no de un día.</p>
            <p>El rastreo diario de posiciones cambia el tiempo de respuesta. Un cambio de posición que ocurrió ayer puede atenderse hoy. Detectas cambios algorítmicos, movimientos de la competencia y caídas de posicionamiento en el día 1 — no en el día 30.</p>
            <p class="font-semibold text-[#111827]">Y para los negocios locales específicamente, el posicionamiento en el paquete local y Maps es una señal diferente a la orgánica — y requiere un monitoreo diferente. Stacc rastrea ambas por separado para que siempre sepas exactamente dónde estás en cada tipo de resultado.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de rastreo de posiciones</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada dato de posicionamiento que necesitas.<br />Todo actualizado diariamente.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreo de paquete local + Maps', body: 'Rastrea tu posición en el paquete local de 3 resultados de Google y Maps por separado del orgánico. Para los negocios locales, la posición en el paquete genera los clics de mayor intención.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Actualizaciones diarias, sin revisiones manuales', body: 'Los posicionamientos se actualizan automáticamente cada 24 horas. Abre tu panel cada mañana y ve dónde está cada palabra clave — sin rastreo manual requerido.' },
            { icon: 'M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2', title: 'Comparación multi-ubicación', body: 'Ve todas las sedes comparadas en paralelo para cualquier palabra clave. Identifica en qué mercados estás ganando y cuáles necesitan atención desde una vista de portafolio única.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Alertas de cambio de posicionamiento', body: 'Configura alertas para movimientos significativos — palabras clave entrando o saliendo del top 3, caídas de 3+ posiciones, nuevas palabras clave irrumpiendo en la primera página.' },
            { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Análisis de tendencias', body: 'Vistas de tendencia de posicionamiento de 30, 60 y 90 días por palabra clave y ubicación. Identifica el impulso y detecta señales de advertencia tempranas del impacto algorítmico.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Datos de posicionamiento en informes para clientes', body: 'Los datos de posicionamiento se incluyen directamente en los informes automáticos para clientes. Los informes se generan y entregan según tu calendario — con tu marca blanca.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreo en detalle</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cómo funciona el rastreo de<br />posiciones de Stacc.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Actualizaciones diarias automáticas</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Posiciones actualizadas cada día, sin iniciar sesión.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc actualiza todas tus posiciones rastreadas cada 24 horas — paquete local, Maps y orgánico — para cada palabra clave en cada ubicación. Sin inicios de sesión manuales, sin exportaciones, sin esperas semanales. Cada mañana tienes los datos actuales del día anterior.
              </p>
              <a href="/es/funciones/seguimiento-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver función de rastreo de posiciones
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posiciones — actualizado hoy</p>
              {[
                { kw: 'fontanero urgente madrid', pack: 2, org: 4, delta: '+1' },
                { kw: 'reparación caldera madrid', pack: 1, org: 3, delta: '+2' },
                { kw: 'instalación calefacción madrid', pack: 3, org: 6, delta: '=' },
                { kw: 'fontanero 24h madrid centro', pack: 4, org: 8, delta: '+3' },
              ].map(r => (
                <div class="grid grid-cols-4 items-center gap-2 border-t border-[#f5f3ff] py-3">
                  <p class="font-mono text-[10px] text-[#57534e] col-span-2 truncate">{r.kw}</p>
                  <div class="flex items-center gap-1">
                    <span class="font-mono text-[12px] font-bold text-[#4f39f6]">#{r.pack}</span>
                    <span class="font-mono text-[9px] text-[#79716b]">Pack</span>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] text-right">{r.delta}</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Actualizado cada 24h · Sin trabajo manual</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Comparativa Maps / Pack local / Orgánico</p>
              {[
                { kw: 'fontanero madrid', maps: 2, pack: 2, org: 4 },
                { kw: 'reparación caldera', maps: 1, pack: 1, org: 3 },
                { kw: 'instalación calefacción', maps: 3, pack: 4, org: 7 },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <p class="font-mono text-[10px] text-[#57534e] mb-2">{r.kw}</p>
                  <div class="grid grid-cols-3 gap-2">
                    <div class="text-center rounded-lg bg-[#f5f3ff] px-2 py-1">
                      <p class="font-mono text-[9px] text-[#79716b]">Maps</p>
                      <p class="font-mono text-[13px] font-bold text-[#4f39f6]">#{r.maps}</p>
                    </div>
                    <div class="text-center rounded-lg bg-[#f5f3ff] px-2 py-1">
                      <p class="font-mono text-[9px] text-[#79716b]">Pack</p>
                      <p class="font-mono text-[13px] font-bold text-[#4f39f6]">#{r.pack}</p>
                    </div>
                    <div class="text-center rounded-lg bg-[#fafaf9] px-2 py-1">
                      <p class="font-mono text-[9px] text-[#79716b]">Orgánico</p>
                      <p class="font-mono text-[13px] font-bold text-[#79716b]">#{r.org}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rastreo completo en las 3 superficies</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Rastreo de Maps, pack local y orgánico.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Para los negocios locales, el paquete local, Maps y el orgánico son tres superficies de posicionamiento independientes con señales diferentes. Una palabra clave puede estar en el top 3 del pack y en el puesto 8 del orgánico. Stacc rastrea las tres por separado para cada palabra clave — para que nunca confundas posicionamiento en Maps con posicionamiento orgánico.
              </p>
              <a href="/es/posicionamiento-google-maps/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver posicionamiento en Google Maps
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alertas de movimientos de posición</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Alertas automáticas de movimientos.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configura alertas para los movimientos que importan — una keyword que entra al top 3, una caída de 5+ posiciones, una nueva keyword que aparece en primera página. Stacc te notifica en el momento en que ocurre el cambio, no una semana después cuando ya has perdido tráfico.
              </p>
              <a href="/es/funciones/seguimiento-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver sistema de alertas
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Alerta de movimiento de posición</p>
              <div class="rounded-xl border border-[#c7c0fc] bg-[#f5f3ff] p-4 mb-4">
                <div class="flex items-start gap-3">
                  <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">Movimiento detectado — Madrid</p>
                    <p class="font-mono text-[10px] text-[#57534e] mt-1">"fontanero urgente madrid" ha subido al <strong>puesto #1</strong> en el paquete local</p>
                    <p class="font-mono text-[10px] text-[#79716b] mt-1">Era #4 · Ahora #1 · Cambio: +3 posiciones</p>
                  </div>
                </div>
              </div>
              <p class="font-mono text-[10px] text-[#79716b]">Alerta enviada · hace 14 minutos · por email y panel</p>
              <div class="mt-3 border-t border-[#f5f3ff] pt-3">
                <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-[#79716b]">Umbral configurado: entrar en top 3 → alerta inmediata</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
