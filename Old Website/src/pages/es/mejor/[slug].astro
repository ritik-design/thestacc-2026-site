---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import { getCollection, render } from 'astro:content';
import { SITE_URL, organizationSchema, publisherRef, authorRef, websiteSchema, buildBreadcrumbs, resolveImage } from '../../../utils/schema';

export async function getStaticPaths() {
  const langPosts = await getCollection('best_es');
  return langPosts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const esUrl = `${SITE_URL}/es/mejor/${post.data.slug}/`;
const enUrl = `${SITE_URL}/best/${post.data.slug}/`;

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${esUrl}#article`,
      headline: post.data.title,
      description: post.data.description,
      url: esUrl,
      datePublished: post.data.date,
      dateModified: post.data.date,
      author: authorRef,
      publisher: publisherRef,
      image: resolveImage(post.data.image),
      mainEntityOfPage: { '@type': 'WebPage', '@id': esUrl },
      articleSection: 'Mejores Herramientas SEO',
      inLanguage: 'es',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(esUrl, [
      { name: 'Inicio', url: `${SITE_URL}/es/` },
      { name: 'Mejores Herramientas', url: `${SITE_URL}/es/mejor/` },
      { name: post.data.title, url: esUrl },
    ]),
    organizationSchema,
    websiteSchema,
  ],
};
---

<BaseLayout
  title={`${post.data.title} | theStacc`}
  description={post.data.description}
  ogImage={post.data.image}
  lang="es"
>
  <Fragment slot="head">
  </Fragment>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    <article>

      <!-- HERO -->
      <div class="mx-auto max-w-[1320px] px-6 pt-12 pb-8">
        <div class="max-w-[820px]">
          <div class="min-w-0">
            <nav aria-label="Migas de pan">
              <ol class="flex items-center gap-1.5 font-mono text-[11px] text-[#79716b]">
                <li><a href="/es/" class="hover:text-[#4f39f6] transition-colors">Inicio</a></li>
                <li class="before:content-['/'] before:mx-1.5"><a href="/es/mejor/" class="hover:text-[#4f39f6] transition-colors">Mejores Herramientas</a></li>
                <li class="before:content-['/'] before:mx-1.5 text-[#292524] line-clamp-1">{post.data.title}</li>
              </ol>
            </nav>

            <div class="mt-3 flex items-center gap-2">
              <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Mejor Lista</span>
              <span class="h-3 w-px bg-[#e7e5e4]"></span>
              <a href={enUrl} class="font-mono text-[10px] text-[#79716b] hover:text-[#4f39f6] transition-colors">Read in English →</a>
            </div>

            <h1 class="mt-4 font-sans text-[28px] leading-[36px] md:text-[36px] md:leading-[44px] font-bold text-[#292524]">
              {post.data.title}
            </h1>
            <p class="mt-4 font-sans text-[16px] leading-[26px] text-[#79716b] max-w-xl">{post.data.description}</p>
            <p class="mt-4 font-mono text-sm uppercase text-[#79716b]">
              {post.data.author} · {post.data.date}
            </p>
          </div>
        </div>
      </div>

      <!-- CONTENT -->
      <div class="mx-auto max-w-[1320px] px-6 pb-10 lg:flex lg:items-start lg:gap-12">
        <div class="min-w-0 flex-1">
          <div class="review-content blog-content overflow-x-hidden">
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="hidden lg:block w-[272px] shrink-0">
          <div class="sticky top-20 flex flex-col gap-4">
            <div class="overflow-hidden rounded-2xl" style="background:#0d1117;border:1px solid rgba(79,57,246,0.25);">
              <div class="p-5" style="background:linear-gradient(135deg,rgba(79,57,246,0.18) 0%,transparent 65%);">
                <h4 class="font-sans text-[15px] font-bold leading-[1.3] text-white">Deja de investigar. Empieza a rankear.</h4>
                <p class="mt-1.5 font-sans text-[12px] leading-[1.6] text-[#94a3b8]">30 artículos SEO publicados en tu sitio cada mes. Automáticamente.</p>
              </div>
              <div class="px-5 pb-5 pt-4" style="border-top:1px solid rgba(255,255,255,0.07);">
                <a href="/es/demo/" class="block rounded-xl py-3 text-center font-mono text-[12px] font-bold uppercase tracking-[0.08em] text-white" style="background:#4f39f6;">
                  Comenzar por $1 →
                </a>
                <p class="mt-2 text-center font-mono text-[10px] text-[#4b5563]">30 días · Cancela cuando quieras</p>
              </div>
            </div>
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-4">
              <a href="/es/mejor/" class="font-sans text-[13px] font-medium text-[#292524] hover:text-[#4f39f6] transition-colors">← Ver todas las listas</a>
            </div>
          </div>
        </aside>
      </div>

      <!-- FOOTER CTA -->
      <section class="relative overflow-hidden" style="background:#ffffff;">
        <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
        <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
        <div class="container-x relative z-10 py-14 text-center">
          <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">Deja de investigar. Empieza a rankear.</h3>
          <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#57534e]">30 artículos SEO publicados en tu sitio cada mes. Automáticamente. Sin escritores, sin flujo de trabajo.</p>
          <a href="/es/demo/" class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
            Comenzar por $1
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">$1 por 30 días · Cancela cuando quieras</p>
        </div>
      </section>

    </article>
  </main>
  <Footer />
</BaseLayout>
