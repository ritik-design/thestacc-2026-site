---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const toc = [
  { id: 'intro',       label: 'Acerca de' },
  { id: 'frontend',    label: 'Tecnologías Frontend' },
  { id: 'fuentes',     label: 'Fuentes' },
  { id: 'herramientas', label: 'Herramientas de Desarrollo' },
];

const legalPages = [
  { label: 'Política de Privacidad',         href: '/es/privacidad/' },
  { label: 'Términos y Condiciones',         href: '/es/terminos/' },
  { label: 'Política de Cookies',            href: '/es/cookies/' },
  { label: 'Acuerdo de Procesamiento',       href: '/es/procesamiento-datos/' },
  { label: 'Licencias',                      href: '/es/licencias/' },
];

const currentPath = '/es/licencias/';

const frontendLibraries = [
  { name: 'Astro',        licence: 'MIT License',           url: 'https://astro.build' },
  { name: 'Tailwind CSS', licence: 'MIT License',           url: 'https://tailwindcss.com' },
  { name: 'Three.js',     licence: 'MIT License',           url: 'https://threejs.org' },
];

const fonts = [
  { name: 'Geist Sans',  licence: 'SIL Open Font License',  url: 'https://fonts.google.com/specimen/Geist' },
  { name: 'Geist Mono',  licence: 'SIL Open Font License',  url: 'https://fonts.google.com/specimen/Geist+Mono' },
];

const devTools = [
  { name: 'TypeScript',  licence: 'Apache License 2.0',     url: 'https://typescriptlang.org' },
];
---

<BaseLayout
  title="Licencias | theStacc"
  description="Software de código abierto y licencias de fuentes utilizadas en theStacc. Atribución completa y detalles de licencia para todos los componentes de terceros."
  lang="es"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="min-h-screen bg-[#fafaf9]">

    <div class="relative overflow-hidden border-b border-white/10" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.5) 0%, transparent 62%);" aria-hidden="true"></div>
      <div class="container-x relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#818cf8]">Legal · Atribución</span>
        <h1 class="mt-2 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.5rem]">Licencias</h1>
        <p class="mt-2 font-mono text-[12px] text-white/40">Última actualización: Abril 2026</p>
      </div>
    </div>

    <div class="container-x py-12 md:py-16">
      <div class="mx-auto max-w-5xl lg:grid lg:grid-cols-[220px_1fr] lg:gap-12 xl:grid-cols-[240px_1fr]">

        <aside class="mb-10 lg:mb-0">
          <div class="lg:sticky lg:top-8 flex flex-col gap-6">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#79716b]">En esta página</p>
              <nav class="flex flex-col gap-0.5">
                {toc.map(item => (
                  <a href={`#${item.id}`} class="toc-link rounded-lg px-3 py-2 font-sans text-[13px] text-[#79716b] transition-colors hover:bg-[#f5f3ff] hover:text-[#4f39f6]" data-toc={item.id}>
                    {item.label}
                  </a>
                ))}
              </nav>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#79716b]">Documentos legales</p>
              <nav class="flex flex-col gap-0.5">
                {legalPages.map(page => (
                  <a href={page.href} class={`rounded-lg px-3 py-2 font-sans text-[13px] transition-colors ${currentPath === page.href ? 'bg-[#f5f3ff] font-semibold text-[#4f39f6]' : 'text-[#79716b] hover:bg-[#fafaf9] hover:text-[#374151]'}`}>
                    {page.label}
                  </a>
                ))}
              </nav>
            </div>
            <a href="mailto:hello@thestacc.com" class="flex items-center gap-2.5 rounded-2xl border border-[#e7e5e4] bg-white px-5 py-4 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span class="font-sans text-[13px] text-[#4f39f6] font-medium">hello@thestacc.com</span>
            </a>
          </div>
        </aside>

        <div class="rounded-2xl border border-[#e7e5e4] bg-white px-8 py-10 md:px-12 md:py-12">
          <div class="flex flex-col gap-10">

            <section id="intro" class="scroll-mt-6">
              <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                theStacc se construye utilizando una variedad de software de código abierto y fuentes tipográficas. Estamos agradecidos a los desarrolladores y comunidades que han puesto su trabajo a disposición del público. A continuación encontrarás una lista de las principales bibliotecas de código abierto y recursos que usamos, junto con sus respectivas licencias.
              </p>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="frontend" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-5">
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Tecnologías Frontend</h2>
              </div>
              <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
                <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Biblioteca</span>
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Licencia</span>
                </div>
                {frontendLibraries.map((item, i) => (
                  <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < frontendLibraries.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]">
                      {item.name}
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                    <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
                  </div>
                ))}
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="fuentes" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-5">
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Fuentes</h2>
              </div>
              <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
                <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Fuente</span>
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Licencia</span>
                </div>
                {fonts.map((item, i) => (
                  <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < fonts.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]">
                      {item.name}
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                    <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
                  </div>
                ))}
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="herramientas" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-5">
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Herramientas de Desarrollo</h2>
              </div>
              <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
                <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Herramienta</span>
                  <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Licencia</span>
                </div>
                {devTools.map((item, i) => (
                  <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < devTools.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]">
                      {item.name}
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                    <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
                  </div>
                ))}
              </div>
              <p class="mt-5 font-sans text-[13px] text-[#79716b]">
                Para la lista completa de dependencias y sus licencias, consulta nuestro <code class="rounded bg-[#f5f3ff] px-1.5 py-0.5 font-mono text-[12px] text-[#4f39f6]">package.json</code> o contáctanos en <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
              </p>
              <p class="mt-4 font-sans text-[13px] text-[#79716b]">
                <strong class="font-semibold text-[#111827]">Nombre legal:</strong> SOLARTREK VENTURES LLP<br/>
                <strong class="font-semibold text-[#111827]">Dirección:</strong> Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India
              </p>
            </section>

          </div>
        </div>

      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const sections = Array.from(links).map(l => document.getElementById(l.dataset.toc || ''));
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        links.forEach(l => {
          const isActive = l.dataset.toc === entry.target.id;
          l.style.backgroundColor = isActive ? '#f5f3ff' : '';
          l.style.color = isActive ? '#4f39f6' : '';
          l.style.fontWeight = isActive ? '600' : '';
        });
      }
    });
  }, { rootMargin: '-10% 0px -80% 0px' });
  sections.forEach(s => s && obs.observe(s));
</script>
