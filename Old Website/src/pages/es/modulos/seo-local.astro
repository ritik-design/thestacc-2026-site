---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const faqs = [
  {
    q: "¿Google penaliza las publicaciones automáticas en GBP?",
    a: "No. Las propias directrices de Google fomentan la actividad regular en Google Business Profile. Publicaciones, actualizaciones, fotos y respuestas. Stacc publica contenido que sigue las mejores prácticas de GBP: relevante, local y variado. Nuestros clientes publican 30 veces al mes sin una sola suspensión de perfil ni penalización de posicionamiento.",
  },
  {
    q: "¿Cuánto tiempo hasta posicionar más alto en Maps?",
    a: "La mayoría de los clientes ven movimiento significativo en Maps dentro de 60–90 días de actividad constante en GBP. El algoritmo local de Google premia la frecuencia, relevancia y participación. Los tres los proporciona Stacc automáticamente cada mes. Los negocios que lo ven más rápido son los que antes publicaban cero.",
  },
  {
    q: "¿Qué pasa si tengo varias ubicaciones?",
    a: "Cada ubicación recibe su propio contenido personalizado. Publicaciones dirigidas a la ciudad, servicios y palabras clave específicas de esa ubicación. Todo gestionado desde un solo panel. Agrega tantas ubicaciones como tengas y Stacc trata cada una como una entidad local independiente.",
  },
  {
    q: "¿Puedo revisar las publicaciones antes de que se activen?",
    a: "Sí. Cada publicación está disponible en una cola de revisión antes de publicarse. Aprueba, edita o activa la publicación automática. La mayoría de los clientes revisan los primeros lotes y luego cambian a publicación automática cuando comprueban la calidad del contenido. Después, las publicaciones simplemente aparecen en tu perfil GBP según el calendario.",
  },
  {
    q: "¿Qué incluye el monitoreo de reseñas?",
    a: "Alertas instantáneas en el momento en que aparece una nueva reseña en tu Google Business Profile. Positiva o negativa. Seguimiento de la tendencia de calificación semana a semana. Plantillas de respuesta para tipos comunes de reseñas para que puedas responder en menos de un minuto. Todas las reseñas visibles en un solo panel en todas tus ubicaciones.",
  },
  {
    q: "¿En qué se diferencia esto de Birdeye o Yext?",
    a: "Birdeye y Yext son herramientas empresariales creadas para grandes cadenas. Empiezan en $300–$500/mes y requieren llamadas de incorporación y contratos largos. Stacc está construido para negocios locales: $49/mes, configuración en minutos, sin contratos. Además, generamos tu contenido de GBP automáticamente. Birdeye y Yext requieren que escribas tus propias publicaciones.",
  },
];
---

<BaseLayout
  title="Módulo SEO Local | theStacc | Domina Google Maps por $49/mes"
  description="Stacc publica en tu Google Business Profile cada día, gestiona tus reseñas y rastrea tu posición en Maps. Todo automáticamente. Empieza por $1."
  lang="es"
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Módulo SEO Local · $49/mes</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Alguien acaba de buscar "[servicio] cerca de mí".<br />
            <span style="color:#4f39f6;">Tu competidor apareció.<br />Tú no.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc publica en tu Google Business Profile cada día, monitorea tus reseñas y rastrea tu posición en Maps. Todo automáticamente. Más actividad significa mayor visibilidad. Mayor visibilidad significa más llamadas.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/es/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Ver cómo funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 días de garantía · Sin tarjeta de crédito · Publicaciones en tu GBP para siempre
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '2,800+', num: 2800, prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Publicaciones de GBP al mes' },
              { value: '340+',   num: 340,  prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Negocios locales' },
              { value: '4.7×',   num: 4.7,  prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Mejora promedio de posición en Maps' },
              { value: '0',      num: 0,    prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Reseñas perdidas' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negocios locales posicionados con Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 reseñas</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            "Cerca de mí" es la búsqueda local más valiosa.<br />Eres invisible para ella.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Google premia los perfiles activos. Tú publicaste dos veces el mes pasado.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">El algoritmo de Maps favorece a los negocios que publican de forma constante, responden reseñas y se mantienen activos. Cada semana que desapareces, un competidor que publica a diario gana terreno que tardarás meses en recuperar.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Una mala reseña sin respuesta puede costarte clientes durante meses.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">El 88% de los clientes locales lee reseñas antes de llamar. Una reseña de 1 estrella que queda sin respuesta una semana le indica a todos los demás que no te importa. Tu calificación es tu reputación en la calle. Merece atención diaria.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">No tienes idea de dónde apareces en las búsquedas "cerca de mí".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Tu posición en Maps para "fontanero cerca de mí" en un barrio es completamente diferente de otra a dos kilómetros. Sin seguimiento, vuelas a ciegas. Y probablemente estás perdiendo llamadas que ni siquiera sabes que estás perdiendo.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conéctate una vez. Stacc gestiona tu presencia<br />en Maps desde ese día.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sin iniciar sesión en GBP. Sin escribir publicaciones. Sin revisar reseñas manualmente. Configúralo una vez y tu Google Business Profile se gestiona solo. Cada día.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Conecta tu Google Business Profile</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Busca tu negocio por nombre y ubicación. Stacc obtiene tus datos actuales de GBP, historial de reseñas y posición de posicionamiento. E identifica exactamente para qué palabras clave no estás apareciendo.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">La IA construye tu plan de contenido local</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 publicaciones optimizadas por ubicación al mes. Dirigidas a tus palabras clave de servicio + ciudad, intención "cerca de mí", temas de temporada y ofertas que coinciden con tu tipo de negocio. Todo escrito para potenciar las señales de Maps.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Las publicaciones se activan. Los rankings suben. Tú no haces nada.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">El contenido se publica en tu GBP según el calendario cada mes. Las alertas de reseñas llegan en el instante en que aparece una nueva. Tu informe de posicionamiento en Maps se actualiza mensualmente. Tu perfil se fortalece mientras tú gestionas tu negocio.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── WHY STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La única opción que hace todo el trabajo.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Posicionar en Maps requiere actividad constante en GBP, respuestas rápidas a reseñas y contenido dirigido por palabras clave. Cada mes, sin falta. Ninguna otra opción entrega los tres sin tu tiempo ni un gran presupuesto.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-4 bg-[#f5f3ff] px-0">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Agencia SEO Local</div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Por tu cuenta</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Stacc</div>
          </div>
          {[
            { label: 'Costo mensual',                         agency: '$800+',       diy: 'Tu tiempo', stacc: '$49'    },
            { label: 'Publicaciones de GBP al mes',           agency: '8–12',        diy: '2–3',        stacc: '30'     },
            { label: 'Segmentación por palabras clave locales',agency: '✓',           diy: '✗',          stacc: '✓'      },
            { label: 'Monitoreo de reseñas',                  agency: '✓',           diy: 'Manual',     stacc: '✓'      },
            { label: 'Seguimiento de posición local',         agency: '✓',           diy: '✗',          stacc: '✓'      },
            { label: 'Tiempo requerido de tu parte',          agency: 'Algo',        diy: 'Alto',       stacc: 'Ninguno'},
          ].map((row, i) => (
            <div class={`grid grid-cols-4 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.agency}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.diy}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.stacc}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/es/demo/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
          >
            Empieza por $1 hoy
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>


    <!-- ─── FEATURE 1: GBP POSTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
          <div>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicación en GBP</span>
            <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.1rem]">
              30 publicaciones de GBP al mes. Dirigidas a las búsquedas que generan llamadas.
            </h2>
            <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
