---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const platforms = [
  {
    name: 'Instagram',
    color: '#E1306C',
    bg: '#fdf2f7',
    iconUrl: '/icons/instagram-gradient.svg',
    path: '',
  },
  {
    name: 'LinkedIn',
    color: '#0A66C2',
    bg: '#f0f6ff',
    iconUrl: '',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    name: 'X',
    color: '#000000',
    bg: '#f5f5f5',
    iconUrl: '',
    path: 'M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z',
  },
  {
    name: 'Facebook',
    color: '#1877F2',
    bg: '#f0f5ff',
    iconUrl: '',
    path: 'M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z',
  },
];

const faqs = [
  {
    q: "¿Las publicaciones parecerán contenido genérico de IA?",
    a: "No. Y esto es lo que más preocupa a la gente. Stacc aprende tu voz de marca, tu industria, tu audiencia y tus pilares de contenido antes de escribir una sola publicación. El resultado es nativo de cada plataforma (los pies de foto de Instagram no suenan como publicaciones de LinkedIn), específico para tu tipo de negocio y escrito en el tono que tú estableces. Puedes revisar cada publicación antes de que se publique. La mayoría de los clientes dice que las publicaciones suenan más consistentes que lo que ellos mismos escriben.",
  },
  {
    q: "¿Cuántas publicaciones publica Stacc al mes?",
    a: "30+ publicaciones al mes por defecto, distribuidas entre las plataformas que conectes. Tú controlas la frecuencia de publicación por plataforma. Algunos negocios publican diariamente en Instagram y 3 veces por semana en LinkedIn. Stacc adapta el volumen de contenido a cualquier cadencia que establezcas. Más publicaciones = más superficie algorítmica = más alcance.",
  },
  {
    q: "¿Puedo revisar o aprobar las publicaciones antes de que se activen?",
    a: "Sí. Cada publicación entra primero en una cola de revisión. Puedes aprobar, editar, regenerar o reprogramar cualquier cosa. La mayoría de los clientes revisan las primeras semanas de publicaciones y luego activan la publicación automática cuando comprueban la calidad del contenido. Después, las publicaciones simplemente aparecen en tus perfiles según el calendario. No tienes que pensar en ello.",
  },
  {
    q: "¿Puedo usar mis propias fotos e imágenes?",
    a: "Sí. Puedes subir tus propias fotos y Stacc las usará para las publicaciones. Si no tienes imágenes, Stacc genera visuales con IA en el estilo que elijas. Fotorrealista, Ilustración plana o Cinematográfico. Con tus colores de marca y logo aplicados automáticamente. La mayoría de los negocios usa una combinación de ambos.",
  },
  {
    q: "¿Stacc publica en idiomas distintos del inglés?",
    a: "Sí. Stacc admite más de 30 idiomas, incluyendo español, francés, portugués, hindi, japonés, alemán, árabe y más. Establece el idioma de tu contenido una vez durante la configuración y cada publicación desde ese momento se genera en ese idioma. Las cuentas multilingüe pueden establecer diferentes idiomas por plataforma o por ubicación.",
  },
  {
    q: "¿En qué se diferencia esto de Buffer o Hootsuite?",
    a: "Buffer y Hootsuite son herramientas de programación. Publican el contenido que tú creas. Stacc crea el contenido Y lo publica. Obtienes un gestor de redes sociales, no solo un calendario. Para los negocios que no tienen tiempo de escribir publicaciones, Stacc hace el trabajo completo por $49/mes. El plan de pago más económico de Buffer es $18/mes. Pero todavía tienes que escribirlo todo tú.",
  },
];
---

<BaseLayout
  title="Módulo Redes Sociales | theStacc | Redes Sociales con IA desde $49/mes"
  description="Stacc escribe y programa publicaciones de marca para Instagram, LinkedIn, X y Facebook cada día. Automáticamente. Más de 30 publicaciones al mes. Empieza por $1."
  lang="es"
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[900px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Módulo Redes Sociales · $49/mes</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Publicaste dos veces el mes pasado.<br />
            <span style="color:#4f39f6;">Tu competidor publica cada día.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            El algoritmo premia la consistencia. Los negocios que publican a diario obtienen más alcance, más seguidores, más clientes. Stacc escribe y publica más de 30 publicaciones de marca al mes en Instagram, LinkedIn, X y Facebook. Automáticamente, cada día.
          </p>

          <!-- Platform icon strip -->
          <div class="mt-7 flex flex-wrap items-center justify-center gap-2.5">
            {platforms.map((p) => (
              <div
                class="flex h-9 w-9 items-center justify-center rounded-xl"
                style={`background-color:${p.bg};`}
                title={p.name}
              >
                {p.iconUrl ? (
                  <img src={p.iconUrl} alt={p.name} width="18" height="18" />
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill={p.color} aria-label={p.name}>
                    <path d={p.path} />
                  </svg>
                )}
              </div>
            ))}
          </div>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/es/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Ver cómo funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 días de garantía · Sin tarjeta de crédito · Cancela cuando quieras
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '30+',   num: 30,  prefix: '',  suffix: '+',    decimals: 0, from: 0, label: 'Publicaciones al mes' },
              { value: '340+',  num: 340, prefix: '',  suffix: '+',    decimals: 0, from: 0, label: 'Negocios en piloto automático' },
              { value: '0 hrs', num: 0,   prefix: '',  suffix: ' hrs', decimals: 0, from: 0, label: 'De tu tiempo requerido' },
              { value: '4',     num: 4,   prefix: '',  suffix: '',     decimals: 0, from: 0, label: 'Plataformas cubiertas' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Negocios haciendo crecer sus redes en piloto automático</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 de 127 reseñas</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Las redes sociales ya no son opcionales.<br />Pero publicar consistentemente es agotador.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Publicas en ráfagas y luego desapareces semanas.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">El algoritmo penaliza la inconsistencia. Cada brecha en tu historial de publicaciones hunde tu alcance. Y lleva semanas de actividad constante recuperarlo. Las publicaciones esporádicas son casi peor que no publicar en absoluto.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Contratar un gestor de redes cuesta mínimo $2,500/mes.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Un buen gestor de redes sociales cuesta $2,500–$5,000 al mes. Un freelance entregará resultados inconsistentes y desaparecerá. Una agencia de redes quiere un contrato de 3 meses y una sesión de estrategia de marca antes de escribir una sola publicación.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Estás gestionando un negocio. No tienes 5 horas a la semana para contenido.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Escribir publicaciones, buscar imágenes, redimensionar para cada plataforma, programar en el momento adecuado. Se acumulan horas que no tienes. Así que lo saltas. Luego te sientes culpable. Luego publicas una vez y sientes que estás al día. No lo estás.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Configúralo una vez. Las publicaciones salen cada día. Para siempre.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sin calendario de contenido. Sin sesiones de redacción. Sin buscar a última hora qué publicar. Cuéntale a Stacc sobre tu marca una vez y se encarga de todo lo demás.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Define tu voz de marca y conecta tus cuentas</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Dile a Stacc tu tono, industria, audiencia y pilares de contenido. Conecta Instagram, LinkedIn, X y Facebook con OAuth seguro. Tarda unos 10 minutos. No necesita volver a tocarse.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">La IA escribe tu plan de contenido mensual</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30+ publicaciones generadas. Cada una adaptada para su plataforma. Pies de foto de Instagram con hashtags. Contenido de liderazgo de opinión en LinkedIn. Hilos en X. Actualizaciones en Facebook. Con imágenes generadas por IA en el estilo de tu marca. Todo listo para revisar antes de que se publique nada.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Las publicaciones salen según el horario. Tú creces en piloto automático.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Aprueba la cola o activa la publicación automática y desentiéndete. Las publicaciones salen en los horarios pico de cada plataforma, cada día. Publicación consistente, alcance creciente, sin esfuerzo de tu parte. Cada mes.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── WHY STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Un gestor de redes sociales, no solo un programador.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            La mayoría de las herramientas te ayudan a programar contenido que ya escribiste. Stacc escribe el contenido, genera las imágenes y lo publica. Por un 98% menos que un gestor humano.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
