---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const toc = [
  { id: 'responsable',   label: '1. Responsable del Tratamiento' },
  { id: 'tipos',         label: '2. Tipos de Datos Tratados' },
  { id: 'base-legal',    label: '3. Base Legal del Tratamiento' },
  { id: 'retencion',     label: '4. Retención de Datos' },
  { id: 'procesadores',  label: '5. Terceros Encargados' },
  { id: 'transferencias', label: '6. Transferencias Internacionales' },
  { id: 'derechos',      label: '7. Tus Derechos (RGPD)' },
  { id: 'contacto',      label: '8. Contacto' },
];

const legalPages = [
  { label: 'Política de Privacidad',         href: '/es/privacidad/' },
  { label: 'Términos y Condiciones',         href: '/es/terminos/' },
  { label: 'Política de Cookies',            href: '/es/cookies/' },
  { label: 'Acuerdo de Procesamiento',       href: '/es/procesamiento-datos/' },
  { label: 'Licencias',                      href: '/es/licencias/' },
];

const currentPath = '/es/procesamiento-datos/';

const dataTypes = [
  { label: 'Datos de cuenta',    body: 'Nombre, dirección de correo electrónico, nombre de empresa, dirección de facturación.' },
  { label: 'Datos de uso',       body: 'Interacciones con el servicio, historial de generación de contenido, patrones de uso de funciones.' },
  { label: 'Datos empresariales', body: 'URLs de sitios web, palabras clave, descripciones de negocio que proporcionas para configurar nuestros servicios.' },
  { label: 'Datos técnicos',     body: 'Direcciones IP, tipo de navegador, identificadores de dispositivo y otros datos de registro.' },
];

const gdprRights = [
  { label: 'Derecho de acceso',         body: 'Solicitar una copia de los datos que conservamos sobre ti.' },
  { label: 'Derecho de rectificación',  body: 'Solicitar la corrección de datos inexactos o incompletos.' },
  { label: 'Derecho de supresión',      body: 'Solicitar la eliminación de tus datos personales en determinadas circunstancias.' },
  { label: 'Derecho de limitación',     body: 'Solicitar que limitemos el uso que hacemos de tus datos.' },
  { label: 'Derecho de portabilidad',   body: 'Recibir tus datos en un formato estructurado y legible por máquinas.' },
  { label: 'Derecho de oposición',      body: 'Oponerte al tratamiento basado en intereses legítimos.' },
];
---

<BaseLayout
  title="Acuerdo de Procesamiento de Datos | theStacc"
  description="Cómo theStacc procesa tus datos bajo el RGPD. Cubre la base legal, períodos de retención de datos, subencargados y tus derechos como interesado."
  lang="es"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="min-h-screen bg-[#fafaf9]">

    <div class="relative overflow-hidden border-b border-white/10" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.5) 0%, transparent 62%);" aria-hidden="true"></div>
      <div class="container-x relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#818cf8]">Legal · Cumplimiento</span>
        <h1 class="mt-2 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.5rem]">Acuerdo de Procesamiento de Datos</h1>
        <p class="mt-2 font-mono text-[12px] text-white/40">Última actualización: Abril 2026</p>
      </div>
    </div>

    <div class="container-x py-12 md:py-16">
      <div class="mx-auto max-w-5xl lg:grid lg:grid-cols-[220px_1fr] lg:gap-12 xl:grid-cols-[240px_1fr]">

        <aside class="mb-10 lg:mb-0">
          <div class="lg:sticky lg:top-8 flex flex-col gap-6">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#79716b]">En esta página</p>
              <nav class="flex flex-col gap-0.5">
                {toc.map(item => (
                  <a href={`#${item.id}`} class="toc-link rounded-lg px-3 py-2 font-sans text-[13px] text-[#79716b] transition-colors hover:bg-[#f5f3ff] hover:text-[#4f39f6]" data-toc={item.id}>
                    {item.label}
                  </a>
                ))}
              </nav>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#79716b]">Documentos legales</p>
              <nav class="flex flex-col gap-0.5">
                {legalPages.map(page => (
                  <a href={page.href} class={`rounded-lg px-3 py-2 font-sans text-[13px] transition-colors ${currentPath === page.href ? 'bg-[#f5f3ff] font-semibold text-[#4f39f6]' : 'text-[#79716b] hover:bg-[#fafaf9] hover:text-[#374151]'}`}>
                    {page.label}
                  </a>
                ))}
              </nav>
            </div>
            <a href="mailto:hello@thestacc.com" class="flex items-center gap-2.5 rounded-2xl border border-[#e7e5e4] bg-white px-5 py-4 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span class="font-sans text-[13px] text-[#4f39f6] font-medium">hello@thestacc.com</span>
            </a>
          </div>
        </aside>

        <div class="rounded-2xl border border-[#e7e5e4] bg-white px-8 py-10 md:px-12 md:py-12">
          <div class="flex flex-col gap-10">

            <section id="responsable" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Responsable del Tratamiento</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  SOLARTREK VENTURES LLP actúa como responsable del tratamiento de los datos personales procesados a través de nuestra plataforma. Determinamos los fines y los medios del tratamiento de tus datos personales de conformidad con las leyes de protección de datos aplicables, incluyendo el Reglamento General de Protección de Datos (RGPD) donde sea aplicable.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="tipos" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Tipos de Datos Tratados</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">En el curso de la prestación de nuestros servicios, tratamos las siguientes categorías de datos:</p>
                <div class="flex flex-col gap-3">
                  {dataTypes.map(item => (
                    <div class="flex items-start gap-3">
                      <span class="mt-[5px] h-1.5 w-1.5 shrink-0 rounded-full bg-[#4f39f6]"></span>
                      <p class="font-sans text-[15px] leading-[1.7] text-[#57534e]">
                        <strong class="font-semibold text-[#111827]">{item.label}:</strong> {item.body}
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="base-legal" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Base Legal del Tratamiento</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">Tratamos tus datos personales sobre las siguientes bases legales:</p>
                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                  {[
                    { label: 'Necesidad contractual',   body: 'Tratamiento necesario para prestar los servicios a los que te has suscrito.' },
                    { label: 'Intereses legítimos',     body: 'Mejora de nuestra plataforma, prevención de fraude y seguridad.' },
                    { label: 'Obligación legal',        body: 'Cumplimiento de las leyes y regulaciones aplicables.' },
                    { label: 'Consentimiento',          body: 'Para comunicaciones opcionales y cookies no esenciales donde sea requerido.' },
                  ].map(item => (
                    <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-4">
                      <p class="font-sans text-[13px] font-semibold text-[#111827] mb-1">{item.label}</p>
                      <p class="font-sans text-[13px] leading-[1.65] text-[#79716b]">{item.body}</p>
                    </div>
                  ))}
                </div>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="retencion" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Retención de Datos</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Conservamos tus datos personales mientras tu cuenta esté activa o sea necesario para prestar nuestros servicios. Tras la cancelación de la cuenta, eliminaremos o anonimizaremos tus datos personales en un plazo de 90 días, salvo que estemos obligados a conservarlos por más tiempo para cumplir con obligaciones legales, resolver disputas o hacer cumplir nuestros acuerdos.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="procesadores" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">5</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Terceros Encargados del Tratamiento</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Contamos con subencargados terceros de confianza para ayudar a prestar nuestros servicios, incluyendo proveedores de infraestructura en la nube, procesadores de pago y proveedores de modelos de IA. Todos los subencargados están vinculados por acuerdos de procesamiento de datos y deben implementar medidas de seguridad apropiadas. Puede solicitarse una lista actualizada de subencargados bajo petición.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="transferencias" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">6</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Transferencias Internacionales de Datos</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Tus datos pueden ser transferidos a y tratados en países distintos al de tu residencia, incluyendo los Estados Unidos. Cuando transferimos datos desde el Espacio Económico Europeo, nos basamos en Cláusulas Contractuales Tipo u otras salvaguardias apropiadas reconocidas bajo el RGPD para garantizar un nivel adecuado de protección.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="derechos" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">7</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Tus Derechos (RGPD)</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">
                  Si estás ubicado en el Espacio Económico Europeo, tienes los siguientes derechos respecto a tus datos personales:
                </p>
                <div class="flex flex-col gap-3">
                  {gdprRights.map(item => (
                    <div class="flex items-start gap-3">
                      <svg class="mt-[3px] shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                      <p class="font-sans text-[15px] leading-[1.7] text-[#57534e]">
                        <strong class="font-semibold text-[#111827]">{item.label}</strong> — {item.body}
                      </p>
                    </div>
                  ))}
                </div>
                <p class="mt-5 font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Para ejercer cualquiera de estos derechos, contáctanos en <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>. Responderemos en un plazo de 30 días.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="contacto" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">8</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Contacto</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Para consultas sobre protección de datos, contáctanos en <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
                </p>
                <p class="mt-4 font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  <strong class="font-semibold text-[#111827]">Nombre legal:</strong> SOLARTREK VENTURES LLP<br/>
                  <strong class="font-semibold text-[#111827]">Dirección:</strong> Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India
                </p>
              </div>
            </section>

          </div>
        </div>

      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const sections = Array.from(links).map(l => document.getElementById(l.dataset.toc || ''));
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        links.forEach(l => {
          const isActive = l.dataset.toc === entry.target.id;
          l.style.backgroundColor = isActive ? '#f5f3ff' : '';
          l.style.color = isActive ? '#4f39f6' : '';
          l.style.fontWeight = isActive ? '600' : '';
        });
      }
    });
  }, { rootMargin: '-10% 0px -80% 0px' });
  sections.forEach(s => s && obs.observe(s));
</script>
