---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué es el software de Google Business Profile?", a: "El software de Google Business Profile ayuda a las empresas a gestionar sus fichas de GBP de forma más eficiente — publicando posts, respondiendo a reseñas, actualizando horarios y atributos, y monitorizando el rendimiento — especialmente en múltiples ubicaciones donde la gestión manual se vuelve poco práctica." },
  { q: "¿Cómo ayuda Stacc con la gestión de Google Business Profile?", a: "Stacc automatiza la publicación de posts en GBP (30 publicaciones por mes y ubicación), monitoriza reseñas en tiempo real, marca las ediciones sugeridas antes de que se apliquen y rastrea las señales de rendimiento de GBP. Para empresas con múltiples ubicaciones, todo esto ocurre en todas las ubicaciones simultáneamente desde un único panel de control." },
  { q: "¿Publicar en GBP mejora realmente el posicionamiento en Google Maps?", a: "Sí. La actividad regular de publicación en GBP es una señal de posicionamiento local documentada. Google trata la publicación constante como indicador de un negocio activo y legítimo — lo que se correlaciona con mayor visibilidad en el paquete local y en Maps. Las empresas que publican de forma consistente observan mejoras de posicionamiento medibles en comparación con su línea base de perfiles inactivos." },
  { q: "¿Puedo publicar posts de GBP en masa para varias ubicaciones?", a: "Sí. Escribe un post, selecciona todas las ubicaciones o un grupo específico y publícalos simultáneamente. Se pueden añadir personalizaciones por ubicación (dirección, teléfono, hashtags locales) antes de la publicación masiva." },
  { q: "¿Cómo gestiona Stacc las ediciones sugeridas de GBP?", a: "Stacc monitoriza tus fichas de GBP en busca de ediciones sugeridas por terceros y te avisa antes de que se apliquen. Puedes aprobar, rechazar o modificar las ediciones sugeridas desde el panel de control sin necesidad de iniciar sesión en cada GBP individualmente." },
  { q: "¿Puede Stacc gestionar GBP para empresas con más de 100 ubicaciones?", a: "Sí. No existe un límite práctico de ubicaciones. Las operaciones masivas funcionan de forma idéntica tanto si tienes 10 como 500 ubicaciones. Las mismas herramientas de gestión de GBP que funcionan para 10 ubicaciones funcionan a 500 — solo tienes que seleccionar más ubicaciones antes de aplicar la acción." },
  { q: "¿Cuánto cuesta el software de GBP?", a: "El módulo de SEO Local de Stacc — que incluye la gestión completa de GBP — comienza en $49/mes con una prueba gratuita de 14 días." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "inLanguage": "es", "name": "theStacc — Software de Google Business Profile", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Software de Google Business Profile que automatiza la publicación de posts, el seguimiento de reseñas y la gestión de fichas en todas las ubicaciones simultáneamente.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Software de Google Business Profile", "item": "https://thestacc.com/es/software-google-business-profile/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Software de Google Business Profile — Automatiza GBP en Cada Ubicación | theStacc"
  description="Automatiza la gestión de Google Business Profile en todas tus ubicaciones. theStacc publica 30 posts de GBP al mes, monitoriza reseñas y gestiona fichas — sin inicios de sesión manuales."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de Google Business Profile · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            GBP gestionado automáticamente.<br />
            <span style="color:#4f39f6;">Cada ubicación. Cada día.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc publica 30 posts de GBP al mes y por ubicación, monitoriza reseñas en tiempo real y gestiona tus fichas en todas las ubicaciones — sin un solo inicio de sesión manual.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/integraciones/google-business-profile/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver integración con GBP
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito para empezar · 30 días de garantía · Cancela en cualquier momento</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ empresas y agencias</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ ubicaciones gestionadas</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué la gestión de GBP necesita software</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Los perfiles de GBP inactivos pierden posicionamiento.<br />La gestión manual no está a la altura.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>El algoritmo de posicionamiento local de Google premia los perfiles de GBP activos. La publicación regular de posts, las respuestas rápidas a reseñas y la información de ficha actualizada contribuyen a la visibilidad en el paquete local y en Maps. Deja de publicar durante tres semanas y tu puntuación de actividad cae. Deja reseñas sin respuesta y tus señales de tasa de respuesta bajan. Deja un horario comercial desactualizado en tu ficha y crearás una inconsistencia de confianza que perjudica tu posicionamiento.</p>
            <p>Mantener un GBP activo para una sola ubicación supone entre 3 y 4 horas de trabajo a la semana. Para 20 ubicaciones, son 80 horas. El software de GBP elimina ese trabajo automatizando la ejecución — no solo mostrándote lo que hay que hacer, sino haciéndolo realmente.</p>
            <p class="font-semibold text-[#111827]">Stacc publica posts, monitoriza reseñas, vigila las ediciones no autorizadas y mantiene tus fichas de GBP activas de forma constante — para que tus perfiles nunca queden en silencio, incluso cuando no estás pendiente de ellos.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades de gestión de GBP</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarea de GBP automatizada.<br />Cada ubicación cubierta.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: '30 posts de GBP al mes, automatizados', body: 'Stacc redacta y publica 30 posts por ubicación y mes orientados a tus combinaciones de palabras clave de servicio + ubicación. Los perfiles se mantienen activos cada día, automáticamente.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitorización de reseñas en tiempo real', body: 'Las nuevas reseñas aparecen al instante en tu panel de control. Responde directamente sin iniciar sesión en GBP. Controla las tasas de respuesta y la puntuación media por ubicación.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Monitorización de ediciones no autorizadas', body: 'Las ediciones sugeridas por terceros en tus fichas se señalan antes de aplicarse. Apruébalas, recházalas o modifícalas desde el panel — nunca pierdas un cambio no autorizado.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Actualizaciones masivas de fichas', body: 'Actualiza horarios, descripciones, atributos y categorías en todas las ubicaciones simultáneamente. Sin necesidad de inicios de sesión en GBP por cada ubicación.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Seguimiento del rendimiento de GBP', body: 'Controla visualizaciones, clics, solicitudes de llamada y solicitudes de ruta por ubicación a lo largo del tiempo. Comprueba qué actividad de GBP se correlaciona con cambios en el rendimiento.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Gestión de preguntas y respuestas', body: 'Monitoriza y gestiona la sección de preguntas y respuestas de cada ficha de GBP. Asegúrate de que los buscadores vean respuestas precisas antes de encontrar información incorrecta.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP en detalle</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Lo que Stacc hace en tu GBP<br />todos los días.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicación automatizada de posts en GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 posts en GBP al mes, en piloto automático.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google evalúa la actividad del GBP todos los días. Los negocios que publican de forma consistente consiguen posiciones más altas en el paquete local — los que quedan en silencio caen. Stacc genera 30 posts por ubicación al mes, orientados a tus combinaciones de servicio + ciudad, y los publica automáticamente en el horario programado. Tu perfil está activo todos los días sin que nadie de tu equipo tenga que iniciar sesión.
              </p>
              <a href="/es/integraciones/google-business-profile/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver integración con GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario de posts GBP — abril</p>
              {[
                { day: 'Lun 1', post: 'Fontanería urgente Madrid · disponible ahora', ok: true },
                { day: 'Mar 2', post: 'Reparación caldera · presupuesto gratuito', ok: true },
                { day: 'Mié 3', post: 'Instalación calefacción · oferta primavera', ok: true },
                { day: 'Jue 4', post: 'Fontanero de confianza · más de 200 reseñas', ok: true },
                { day: 'Vie 5', post: 'Servicio rápido garantizado · llámanos hoy', ok: true },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-2.5">
                  <span class="font-mono text-[10px] text-[#79716b] shrink-0 w-14">{r.day}</span>
                  <p class="font-sans text-[12px] text-[#374151] flex-1 truncate">{r.post}</p>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 posts/mes · Publicados automáticamente</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Monitor de reseñas — todas las ubicaciones</p>
              {[
                { stars: 5, text: '"Servicio excepcional. El mejor fontanero de Madrid."', time: 'hace 1h', alerted: true },
                { stars: 5, text: '"Respuesta rápida y precio muy justo. Recomendado."', time: 'hace 3h', alerted: true },
                { stars: 3, text: '"Bien, aunque tardó más de lo previsto."', time: 'hace 1d', alerted: true },
                { stars: 5, text: '"Mejor empresa de climatización que he contratado."', time: 'hace 2d', alerted: true },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center gap-2 mb-1">
                    <div class="flex gap-0.5">
                      {Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
                    </div>
                    <span class="font-mono text-[10px] text-[#79716b]">Google · {r.time}</span>
                    {r.alerted && <span class="ml-auto font-mono text-[10px] text-[#059669]">✓ Alertado</span>}
                  </div>
                  <p class="font-sans text-[12px] text-[#57534e] italic">{r.text}</p>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Monitoreo de reseñas en tiempo real</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Monitoreo de reseñas en tiempo real.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Una reseña negativa sin respuesta durante 48 horas hace más daño que la propia reseña. Stacc monitoriza todas las plataformas de reseñas en todas tus ubicaciones en tiempo real y dispara alertas en el momento en que aparece una nueva reseña — para que puedas responder mientras todavía está fresca. Cada alerta incluye plantillas de respuesta sugeridas para acortar el tiempo de respuesta.
              </p>
              <a href="/es/funciones/monitoreo-resenas/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver monitoreo de reseñas
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestión de citaciones en 50+ directorios</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Consistencia de citaciones en 50+ directorios.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Las inconsistencias NAP entre Google, Yelp, TripAdvisor y 47 otros directorios perjudican el posicionamiento local. Stacc monitoriza todos los directorios de forma continua, detecta discrepancias y las señala para su corrección. Para muchos negocios, solucionar las inconsistencias de citaciones es la mejora de posicionamiento más rápida disponible.
              </p>
              <a href="/es/funciones/gestion-citaciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver gestión de citaciones
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Estado de citaciones — directorios clave</p>
              {[
                { dir: 'Google Business Profile', status: 'Consistente', ok: true },
                { dir: 'Yelp', status: 'Consistente', ok: true },
                { dir: 'TripAdvisor', status: 'Consistente', ok: true },
                { dir: 'Páginas Amarillas', status: 'Consistente', ok: true },
                { dir: 'Bing Places', status: 'Inconsistencia detectada', ok: false },
                { dir: 'Apple Maps', status: 'Consistente', ok: true },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <p class="font-sans text-[12px] text-[#374151]">{r.dir}</p>
                  <span class={`font-mono text-[11px] ${r.ok ? 'text-[#059669]' : 'text-[#dc2626]'}`}>{r.ok ? '✓' : '!'} {r.status}</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ directorios monitorizados</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRICS -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que consiguen los negocios<br />con gestión automatizada de GBP.
