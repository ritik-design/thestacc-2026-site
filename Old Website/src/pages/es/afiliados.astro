---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    question: "¿Cómo gano comisiones?",
    answer: "Comparte tu enlace de afiliado único. Cuando alguien hace clic en él y se registra en theStacc, ganas una comisión en cada pago que realice. Durante hasta 3 años. Si se registran directamente a través de tu enlace, ganas el 25%. Si nuestro equipo de ventas ayuda a cerrar el trato, ganas el 15%.",
  },
  {
    question: "¿Cuándo y cómo me pagan?",
    answer: "Los pagos son mensuales, a 30 días. Las comisiones de marzo se pagan el 15 de abril. El pago mínimo es de 50 $. Pagamos por PayPal, transferencia bancaria directa (ACH) o Wise para afiliados internacionales.",
  },
  {
    question: "¿Cuánto dura la cookie?",
    answer: "90 días. Si alguien hace clic en tu enlace y se registra en los 90 días siguientes, obtienes el crédito. Incluso si no compran inmediatamente. También tienes un código de cupón único que funciona sin cookies.",
  },
  {
    question: "¿Necesito ser cliente para ser afiliado?",
    answer: "No, pero ayuda. Los afiliados que usan el producto pueden hablar desde la experiencia, y su contenido convierte mejor. Proporcionamos una cuenta gratuita a todos los afiliados activos para que puedas probarlo todo de primera mano.",
  },
  {
    question: "¿Qué pasa si mi referido sube de plan más tarde?",
    answer: "Ganas más. Tu comisión es un porcentaje de lo que pague tu referido. Si empiezan en 99 $/mes y suben a 499 $/mes, tu comisión sube con ellos.",
  },
  {
    question: "¿Hay restricciones sobre cómo puedo promocionar?",
    answer: "Pedimos a los afiliados que no hagan spam, no pujen por nuestras palabras clave de marca en búsqueda de pago ni hagan afirmaciones engañosas. Más allá de eso, eres libre de promocionar a través de tu blog, YouTube, lista de correo, redes sociales, podcast o cualquier otro canal.",
  },
  {
    question: "¿Qué materiales de marketing proporcionáis?",
    answer: "Banners publicitarios, plantillas de correo, gráficos para redes sociales, hojas de comparación de datos, capturas de pantalla del producto, un kit de marca y más. Tras el registro, tienes acceso a nuestra biblioteca completa de recursos para afiliados.",
  },
  {
    question: "¿Hay un límite en cuánto puedo ganar?",
    answer: "Sin tope, sin límite. Algunos de nuestros afiliados ganan miles al mes. Con nuestro plan de 999 $/mes, una sola referencia te genera 249,75 $/mes. Recurrente, durante hasta 3 años.",
  },
];
---

<BaseLayout
  title="Programa de Afiliados — Gana Comisión Recurrente del 25% | theStacc"
  description="Únete al programa de afiliados de theStacc. Gana comisión recurrente del 25% durante 3 años promocionando el servicio SEO gestionado. Cookie de 90 días, pagos mensuales, soporte dedicado."
  lang="es"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <!-- ░░ DARK HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Programa de Afiliados</p>
        <h1 class="mx-auto mt-4 max-w-[620px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[44px]">
          Gana ingresos recurrentes promocionando el SEO que se gestiona solo.
        </h1>
        <p class="mx-auto mt-4 max-w-[480px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          Recomienda theStacc a tu audiencia y gana hasta el 25% de cada pago, durante hasta 3 años por referido. Sin límite de referidos.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="#solicitar"
            class="inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-7 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
            Hazte afiliado
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#como-funciona"
            class="inline-flex h-[46px] items-center gap-2 rounded-xl border border-[rgba(255,255,255,0.12)] px-7 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-[#94a3b8] transition-colors hover:border-[rgba(255,255,255,0.25)] hover:text-[#292524]">
            Ver cómo funciona
          </a>
        </div>
        <!-- Trust pills -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {['Comisión recurrente del 25%', 'Cookie de 90 días', '3 años por referido', 'Gratis unirse'].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ HEADLINE STATS ░░ -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x">
        <div class="grid grid-cols-2 divide-x divide-[#e7e5e4] md:grid-cols-4">
          <div class="px-6 py-8 text-center">
            <p class="font-mono text-[40px] font-bold leading-none text-[#4f39f6]">25%</p>
            <p class="mt-2 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">Comisión recurrente</p>
          </div>
          <div class="px-6 py-8 text-center">
            <p class="font-mono text-[40px] font-bold leading-none text-[#292524]">90</p>
            <p class="mt-2 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">Días de ventana de cookie</p>
          </div>
          <div class="px-6 py-8 text-center">
            <p class="font-mono text-[40px] font-bold leading-none text-[#292524]">3 años</p>
            <p class="mt-2 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">Pagos recurrentes</p>
          </div>
          <div class="px-6 py-8 text-center">
            <p class="font-mono text-[40px] font-bold leading-none text-[#4f39f6]">0 $</p>
            <p class="mt-2 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">Para unirse al programa</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Estructura de comisiones -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-14 md:py-20">
      <div class="mx-auto max-w-[780px]">
        <div class="text-center">
          <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Estructura de Comisiones</p>
          <h2 class="mt-4 font-sans text-[28px] leading-[36px] md:text-[32px] md:leading-[42px] font-normal text-[#292524]">
            Dos formas de ganar. Ambas pagan de forma recurrente.
          </h2>
        </div>

        <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-0 rounded-xl border border-[#e7e5e4] overflow-hidden">
          <!-- Venta directa -->
          <div class="border-b md:border-b-0 md:border-r border-[#e7e5e4] bg-[#fafaf9] p-6 md:p-8">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            </div>
            <p class="mt-5 font-mono text-[40px] font-bold text-[#292524]">25%</p>
            <p class="mt-1 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#4f39f6]">Venta Directa</p>
            <p class="mt-3 font-sans text-[15px] leading-[24px] text-[#79716b]">
              El cliente se registra y paga a través de tu enlace de afiliado sin intervención de nuestro equipo de ventas. Obtienes el 25% completo.
            </p>
            <div class="mt-5 space-y-2">
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Blog SEO (99 $/mes)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">24,75 $/mes</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Bundle (150 $/mes)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">37,50 $/mes</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Gestionado (999 $/mes)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">249,75 $/mes</span>
              </div>
            </div>
          </div>

          <!-- Con asistencia de ventas -->
          <div class="bg-[#fafaf9] p-6 md:p-8">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <p class="mt-5 font-mono text-[40px] font-bold text-[#292524]">15%</p>
            <p class="mt-1 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#4f39f6]">Con Asistencia de Ventas</p>
            <p class="mt-3 font-sans text-[15px] leading-[24px] text-[#79716b]">
              Generas el cliente potencial a través de tu enlace, pero nuestro equipo de ventas ayuda a cerrar el trato con una demo o seguimiento. Igualmente ganas el 15%.
            </p>
            <div class="mt-5 space-y-2">
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Blog SEO (99 $/mes)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">14,85 $/mes</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Bundle (150 $/mes)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">22,50 $/mes</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-white px-4 py-2.5 border border-[#e7e5e4]">
                <span class="font-sans text-[14px] text-[#57534e]">Gestionado (999 $/mes)</span>
                <span class="font-mono text-[14px] font-semibold text-[#292524]">149,85 $/mes</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Ejemplo de ganancias -->
        <div class="mt-6 rounded-xl border border-[#e7e5e4] bg-[#f5f3ff] px-6 py-5">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#4f39f6]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <p class="font-sans text-[15px] leading-[24px] text-[#292524]">
              <strong>Ejemplo:</strong> Refiere 20 clientes en el plan Blog SEO de 99 $/mes y gana <strong class="text-[#4f39f6]">495 $/mes</strong>. Cada mes, durante hasta 3 años.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cómo funciona -->
    <section id="como-funciona" class="border-b border-[#e7e5e4] bg-white">
      <div class="px-6 pt-8 pb-0 text-center">
        <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Cómo Funciona</p>
        <h2 class="mx-auto mt-4 max-w-[480px] font-sans text-[30px] leading-[38px] font-normal text-[#292524]">
          Empieza a ganar en tres pasos.
        </h2>
      </div>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 border-t border-b border-[#e7e5e4]">
        <div class="px-6 py-5 md:py-8 border-b md:border-b-0 md:border-r border-[#e7e5e4]">
          <div class="flex items-center justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
              </svg>
            </div>
            <span class="font-mono text-[32px] font-bold text-[#e7e5e4]">01</span>
          </div>
          <p class="mt-5 font-mono text-[14px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Solicita y Obtén Tu Enlace</p>
          <p class="mt-2 font-sans text-[14px] leading-[20px] text-[#79716b] hidden md:block">Rellena el formulario a continuación. Revisaremos tu solicitud y te enviaremos un enlace de afiliado único y un código de cupón en 24 horas.</p>
        </div>
        <div class="px-6 py-5 md:py-8 border-b md:border-b-0 md:border-r border-[#e7e5e4]">
          <div class="flex items-center justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
              </svg>
            </div>
            <span class="font-mono text-[32px] font-bold text-[#e7e5e4]">02</span>
          </div>
          <p class="mt-5 font-mono text-[14px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Comparte con Tu Audiencia</p>
          <p class="mt-2 font-sans text-[14px] leading-[20px] text-[#79716b] hidden md:block">Promociona theStacc a través de tu blog, canal de YouTube, lista de correo, redes sociales o podcast. Proporcionamos banners, plantillas y textos listos para usar.</p>
        </div>
        <div class="px-6 py-5 md:py-8">
          <div class="flex items-center justify-between">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <span class="font-mono text-[32px] font-bold text-[#e7e5e4]">03</span>
          </div>
          <p class="mt-5 font-mono text-[14px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Gana Ingresos Recurrentes</p>
          <p class="mt-2 font-sans text-[14px] leading-[20px] text-[#79716b] hidden md:block">Cada vez que alguien se registra a través de tu enlace, ganas una comisión en cada pago que realice. Durante hasta 3 años. Pagos mensuales, sin tope.</p>
        </div>
      </div>
    </section>

    <!-- Por qué promocionar theStacc -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-14 md:py-20">
      <div class="mx-auto max-w-[780px]">
        <div class="text-center">
          <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Por Qué Promocionar theStacc</p>
          <h2 class="mt-4 font-sans text-[28px] leading-[36px] md:text-[32px] md:leading-[42px] font-normal text-[#292524]">
            Un producto que se vende solo.
          </h2>
          <p class="mt-4 font-sans text-[16px] leading-[26px] text-[#57534e]">
            theStacc resuelve un problema real para negocios reales. Tu audiencia no necesita aprender SEO. Solo necesita registrarse.
          </p>
        </div>

        <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Precios Altos</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">Los planes van de 49 a 999 $/mes. Precios más altos significan comisiones más altas por referido que la mayoría de los programas SaaS.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Recurrente 3 Años</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">Sin pagos únicos. Ganas durante hasta 3 años por referido. Las comisiones se acumulan con el tiempo a medida que crece tu base de referidos.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Producto con Baja Rotación</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">theStacc es un servicio gestionado, no una herramienta que la gente olvida. Los clientes se quedan porque su SEO sigue funcionando automáticamente.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <p class="mt-4 font-mono text-[13px] font-semibold uppercase tracking-[0.56px] text-[#292524]">Fácil de Explicar</p>
            <p class="mt-1.5 font-sans text-[14px] leading-[20px] text-[#79716b]">"Regístrate y nosotros gestionamos tu SEO" es más sencillo que "aquí tienes una herramienta, aprende a usarla." El enfoque gestionado convierte mejor que las demos de software.</p>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#fafaf9]">
