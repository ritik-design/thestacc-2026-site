---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué es el software de construcción de citaciones?",
    a: "El software de construcción de citaciones automatiza el proceso de listar tu negocio en directorios locales — Google, Yelp, Apple Maps, Bing Places y más de 50 directorios adicionales — con datos NAP (Nombre, Dirección, Teléfono) consistentes. Stacc audita tus citaciones existentes, encuentra inconsistencias, las corrige y construye nuevas citaciones automáticamente.",
  },
  {
    q: "¿Por qué son importantes las citaciones para el SEO local?",
    a: "Google utiliza la consistencia de las citaciones como señal de confianza. Cuando el nombre, la dirección y el teléfono de tu negocio coinciden en decenas de directorios, Google tiene mayor confianza en que tu listado es legítimo y está actualizado — lo que se correlaciona directamente con posicionamientos más altos en el paquete local y Maps. Las citaciones inconsistentes generan confusión y suprimen los posicionamientos.",
  },
  {
    q: "¿Qué ocurre si mis citaciones tienen información incorrecta?",
    a: "Los datos NAP incorrectos en los directorios perjudican activamente tu posicionamiento local. Google detecta señales contradictorias y reduce la confianza en tu listado. Los clientes encuentran un número o dirección erróneos. Stacc audita los más de 50 directorios, señala las inconsistencias y las corrige automáticamente — para que tus datos sean precisos en todas partes.",
  },
  {
    q: "¿Cuántos directorios cubre Stacc?",
    a: "Stacc gestiona citaciones en más de 50 directorios locales, incluyendo Google Business Profile, Yelp, Bing Places, Apple Maps, Facebook, Foursquare, YellowPages, Angi, HomeAdvisor, BBB, Nextdoor y docenas más de directorios específicos por sector. Todo incluido a $49/mes — sin cargos por directorio.",
  },
  {
    q: "¿Funciona Stacc para negocios con múltiples ubicaciones?",
    a: "Sí. La gestión de citaciones para múltiples ubicaciones es una de las fortalezas principales de Stacc. Cada sede tiene su propio perfil de citaciones, monitoreado y corregido de forma independiente. Todo se gestiona desde un solo panel. Añade una nueva ubicación y Stacc comienza a construir citaciones para ella de inmediato.",
  },
  {
    q: "¿Cuánto tiempo lleva ver resultados con las citaciones?",
    a: "Las auditorías iniciales de citaciones se completan en 48 horas después de conectar tu negocio. Las correcciones y nuevos listados se despliegan en las siguientes 1–2 semanas a medida que los directorios procesan las actualizaciones. La mayoría de los negocios ven mejoras medibles en la precisión del NAP en 30 días.",
  },
  {
    q: "¿Puedo usar Stacc para construir citaciones como agencia?",
    a: "Sí. Las agencias gestionan todas las citaciones de sus clientes desde un solo panel. Los informes de citaciones están incluidos en los informes mensuales de marca blanca de Stacc — entregados bajo tu marca, automáticamente. Pareces tener un equipo dedicado a las citaciones. Tienes Stacc.",
  },
  {
    q: "¿La construcción de citaciones es una tarea puntual o continua?",
    a: "Continua. Surgen nuevos directorios. Los directorios existentes permiten ediciones enviadas por usuarios que pueden corromper tus datos. La información del negocio cambia. Stacc monitorea continuamente y corrige automáticamente — para que tus citaciones permanezcan precisas sin ningún esfuerzo manual después de la configuración inicial.",
  },
  {
    q: "¿Stacc reemplaza las herramientas manuales de envío de citaciones como BrightLocal o Yext?",
    a: "Stacc incluye la gestión de citaciones como parte de una plataforma completa de automatización SEO local — junto con rastreo de posiciones, publicación en GBP, monitoreo de reseñas e informes automatizados. Obtienes gestión completa de citaciones más todo lo demás por $49/mes, en comparación con pagar por separado por una herramienta solo de citaciones.",
  },
  {
    q: "¿Cuánto cuesta Stacc para la construcción de citaciones?",
    a: "La gestión de citaciones está incluida en el módulo SEO local a $49/mes. Sin cargos por directorio. Sin recargos por ubicación. Todo incluido — auditoría, corrección, nuevos listados, monitoreo continuo y datos de citaciones en tus informes de marca blanca.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "inLanguage": "es",
      "name": "theStacc — Software de Construcción de Citaciones",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automatiza la construcción de citaciones en más de 50 directorios locales. theStacc audita las citaciones existentes, corrige las inconsistencias del NAP y construye nuevas citaciones que mejoran tu posicionamiento local.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Módulo SEO local con gestión de citaciones incluida — prueba de 14 días"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Software de Construcción de Citaciones", "item": "https://thestacc.com/es/software-construccion-citaciones/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Software de Construcción de Citaciones — Crea y Sincroniza Citaciones en más de 50 Directorios | theStacc"
  description="Automatiza la construcción de citaciones en más de 50 directorios locales. theStacc audita las citaciones existentes, corrige las inconsistencias del NAP y construye nuevas citaciones que mejoran tu posicionamiento local."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Software de Construcción de Citaciones · Desde $49/mes</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Tus citaciones son incorrectas en algún lugar.<br />
            <span style="color:#4f39f6;">Stacc las encuentra y las corrige.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            La inconsistencia del NAP es el asesino invisible del posicionamiento local. Número de teléfono incorrecto en Yelp. Dirección antigua en Apple Maps. Listado duplicado en Foursquare. Stacc audita más de 50 directorios, corrige cada inconsistencia y mantiene tus datos precisos automáticamente.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Inicia tu auditoría de citaciones gratuita
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver precios
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Prueba gratuita de 14 días · Sin tarjeta de crédito · Cancela cuando quieras
          </p>

          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Más de 50 directorios sincronizados</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Más de 400 agencias confían en Stacc</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN NARRATIVE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué las citaciones están destruyendo silenciosamente tus posicionamientos</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tienes información incorrecta publicada<br />en algún lugar ahora mismo. Solo que no sabes dónde.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Eres la persona que se mudó de oficina hace dos años, actualizó Google, actualizó la web y lo dejó por terminado. O cambió su número de teléfono al cambiar de proveedor. O tenía una franquicia que envió su propio listado de Yelp con un nombre de negocio ligeramente diferente. Cada uno de esos eventos es una inconsistencia de citación — y las inconsistencias de citación se acumulan silenciosamente, a escala, en más de 50 directorios en los que nunca piensas.
            </p>
            <p>
              El algoritmo de posicionamiento local de Google trata la consistencia del NAP como señal de confianza. Cuando tu nombre, dirección y teléfono coinciden en docenas de directorios, Google tiene mayor confianza en que tu negocio es legítimo, está actualizado y merece aparecer. Cuando no coinciden — incluso sutilmente, como "C/" frente a "Calle" — esa confianza se erosiona. Tus competidores con perfiles de citación más limpios te superan en posicionamiento no porque sean mejores negocios, sino porque sus datos son más consistentes.
            </p>
            <p>
              Las agencias que ocupan los primeros puestos de Google Maps no revisan manualmente 50 directorios. Lo automatizaron. Tienen software que monitorea cada directorio, alerta sobre cada inconsistencia y la corrige antes del próximo rastreo de Google. Puedes tener el mismo sistema por $49/mes — y el ROI del primer posicionamiento recuperado lo paga de inmediato.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Qué hace Stacc con las citaciones</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Auditar. Corregir. Construir. Monitorear.<br />Todo automatizado, todo incluido.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            {
              title: 'Auditoría de citaciones',
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              features: ['Escanea más de 50 directorios al instante', 'Señala cada inconsistencia del NAP', 'Identifica listados faltantes', 'Detecta entradas duplicadas'],
              href: '/es/funciones/seguimiento-posiciones/',
            },
            {
              title: 'Corrección de citaciones',
              icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
              features: ['Corrige direcciones erróneas automáticamente', 'Actualiza números de teléfono obsoletos', 'Elimina listados duplicados', 'Estandariza el formato del nombre del negocio'],
              href: '/es/modulos/seo-local/',
            },
            {
              title: 'Monitoreo de citaciones',
              icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
              features: ['Monitoreo continuo de directorios', 'Alerta ante cualquier cambio de datos', 'Corrección automática de ediciones de usuarios', 'Informe mensual de salud de citaciones'],
              href: '/es/soluciones/agencias/',
            },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Ver más</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo gestiona Stacc las citaciones</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Desde la auditoría hasta la corrección y el monitoreo.<br />Cero trabajo manual después de la configuración.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Audit -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Auditoría Instantánea de Citaciones</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Conoce tu puntuación de salud de citaciones en más de 50 directorios en 48 horas.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Cuando conectas tu negocio, Stacc escanea inmediatamente cada directorio local principal en busca de tus listados existentes. Verifica cada uno para comprobar la precisión del NAP, señala duplicados, identifica listados faltantes y calcula una puntuación general de salud de citaciones. Ves exactamente dónde estás — qué directorios tienen información incorrecta, cuáles faltan por completo y cuáles son correctos — en una sola vista del panel.
              </p>
              <a href="/es/modulos/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el módulo SEO local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Auditoría de citaciones — tus ubicaciones</p>
              {[
                { dir: 'Google Business Profile', status: '✓ Correcto', color: 'text-[#059669]' },
                { dir: 'Yelp', status: '⚠ Teléfono incorrecto', color: 'text-[#d97706]' },
                { dir: 'Apple Maps', status: '⚠ Dirección antigua', color: 'text-[#d97706]' },
                { dir: 'Bing Places', status: '✓ Correcto', color: 'text-[#059669]' },
                { dir: 'Foursquare', status: '✗ Faltante', color: 'text-[#dc2626]' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{r.dir}</span>
                  <span class={`font-mono text-[11px] font-semibold ${r.color}`}>{r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Stacc corrige todos los problemas automáticamente · Sin trabajo manual</p>
            </div>
          </div>

          <!-- Correction -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Puntuación de precisión del NAP</p>
              <div class="flex items-center justify-between mb-3">
                <span class="font-sans text-[13px] text-[#57534e]">Antes de Stacc</span>
                <span class="font-mono text-[12px] font-semibold text-[#dc2626]">61% preciso</span>
              </div>
              <div class="h-2 w-full rounded-full bg-[#f5f3ff] mb-6">
                <div class="h-2 rounded-full bg-[#dc2626]" style="width:61%"></div>
              </div>
              <div class="flex items-center justify-between mb-3">
                <span class="font-sans text-[13px] text-[#57534e]">Después de 30 días</span>
                <span class="font-mono text-[12px] font-semibold text-[#059669]">94% preciso</span>
              </div>
              <div class="h-2 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-2 rounded-full bg-[#059669]" style="width:94%"></div>
              </div>
              <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Media entre clientes de Stacc · Más de 50 directorios</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Corrección Automática del NAP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Cada inconsistencia corregida. Cada directorio actualizado. Sin que muevas un dedo.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Tras la auditoría, Stacc envía automáticamente correcciones a cada directorio que permite actualizaciones por API. Para los directorios que requieren intervención manual, Stacc pone en cola las correcciones y las gestiona a través de sus alianzas con directorios. El cliente promedio de Stacc pasa del 61% de precisión del NAP al 94% en 30 días — sin tocar manualmente ni un solo directorio.
              </p>
              <a href="/es/funciones/seguimiento-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver cómo mejoran los posicionamientos
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Monitoring -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Monitoreo Continuo de Citaciones</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Las citaciones se degradan. Stacc lo detecta antes que Google.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Los directorios permiten ediciones públicas. Los agregadores insertan datos obsoletos. Tu información puede volver a ser incorrecta en el momento en que dejas de vigilarla. Stacc monitorea cada directorio de forma continua y te alerta en el momento en que cualquier dato de citación cambia. La autocorrección se activa de inmediato para los directorios compatibles. Tu NAP permanece preciso incluso cuando los directorios cambian a tu alrededor.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
