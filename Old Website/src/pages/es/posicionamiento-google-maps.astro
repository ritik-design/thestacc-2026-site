---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  { q: "¿Qué factores determinan el posicionamiento en Google Maps?", a: "El posicionamiento en Google Maps (el paquete local) está determinado principalmente por tres factores: relevancia (qué tan bien coincide tu ficha con la búsqueda), distancia (proximidad al buscador) y prominencia (qué tan conocido es tu negocio en línea, incluyendo cantidad y calidad de reseñas, consistencia de citaciones y señales de actividad de GBP)." },
  { q: "¿Publicar en GBP mejora el posicionamiento en Google Maps?", a: "Sí. La actividad regular de publicación en GBP es una señal de posicionamiento documentada para la visibilidad en el paquete local y en Maps. Google trata la publicación constante como indicador de un negocio activo y legítimo — lo que se correlaciona positivamente con la posición en el paquete local. Las empresas que publican de forma consistente típicamente superan a los perfiles inactivos en una ventana de 90 días." },
  { q: "¿Cómo afectan las citaciones al posicionamiento en Google Maps?", a: "La consistencia de las citaciones es un factor clave de posicionamiento en Maps. Google contrasta la información de tu negocio (nombre, dirección, teléfono) en toda la web. Cuando tus datos NAP son consistentes en más de 50 directorios, esto señala precisión de datos — lo que mejora tu puntuación de confianza en Maps. Las citaciones inconsistentes generan confusión que deprime el posicionamiento." },
  { q: "¿Cómo afectan las reseñas al posicionamiento en Google Maps?", a: "La cantidad de reseñas, la recencia, la puntuación media y la tasa de respuesta a reseñas contribuyen a tu puntuación de prominencia en Maps. Las empresas con un mayor volumen de reseñas recientes y positivas con respuestas del propietario superan a empresas con menos reseñas o más antiguas en mercados locales competitivos." },
  { q: "¿Cuánto tiempo tarda en mejorar el posicionamiento en Google Maps?", a: "La mayoría de los negocios ven mejoras medibles en 60-90 días de actividad consistente en GBP y limpieza de citaciones. Los mercados con mayor competencia tardan más. Las mejoras de posicionamiento se acumulan: la actividad consistente durante 6 meses produce resultados significativamente más duraderos que los esfuerzos esporádicos." },
  { q: "¿Ayuda Stacc específicamente con el posicionamiento en Google Maps?", a: "Sí. Stacc automatiza las tres actividades de mayor impacto para el posicionamiento en Maps: publicación consistente de posts en GBP (30/mes por ubicación), monitorización de precisión de citaciones y corrección en más de 50 directorios, y monitorización de reseñas para asegurar respuestas oportunas. Los tres funcionan automáticamente — no tienes que acordarte de hacerlos." },
  { q: "¿Puede Stacc mejorar el posicionamiento en Maps para múltiples ubicaciones?", a: "Sí. Stacc gestiona posts de GBP, citaciones y monitorización de reseñas en todas las ubicaciones simultáneamente. Cada ubicación recibe la misma actividad SEO consistente — que es la clave para escalar el posicionamiento en Maps sin escalar tu equipo." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "inLanguage": "es", "name": "theStacc — Posicionamiento en Google Maps", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Automatiza las actividades que mejoran el posicionamiento en Google Maps: publicación de posts en GBP, monitorización de citaciones y gestión de reseñas — en cada ubicación, cada día.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Posicionamiento en Google Maps", "item": "https://thestacc.com/es/posicionamiento-google-maps/" }] },
    { "@type": "FAQPage", "inLanguage": "es", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Posicionamiento en Google Maps — Automatiza las Señales que Mejoran tu Posición Local | theStacc"
  description="Mejora tu posicionamiento en Google Maps automatizando la publicación en GBP, la gestión de citaciones y la monitorización de reseñas. theStacc ejecuta los tres de forma consistente en cada ubicación."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Posicionamiento en Google Maps · Desde $49/mes</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Automatiza las señales que mejoran<br />
            <span style="color:#4f39f6;">tu posicionamiento en Google Maps.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            El posicionamiento en Google Maps responde a la actividad consistente en GBP, la precisión de las citaciones y las señales de reseñas. Stacc automatiza los tres — cada ubicación, cada día — para que tus mejoras de posicionamiento se acumulen sin esfuerzo manual.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza por $1 hoy
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/software-seo-local/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver la plataforma
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Sin tarjeta de crédito para empezar · 30 días de garantía · Cancela en cualquier momento</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Automatización de posts en GBP</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Monitorización de citaciones</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Gestión de reseñas</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Rastreo diario de posiciones</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo funciona realmente el posicionamiento en Google Maps</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Los negocios que ganan en Maps<br />hacen tres cosas de forma consistente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>El posicionamiento en Google Maps en el paquete local de 3 resultados está determinado por relevancia, distancia y prominencia. No puedes cambiar tu ubicación física (distancia), y la relevancia proviene de la categoría y el contenido de tu GBP. Lo que realmente puedes influir es la prominencia — y la prominencia es función de tres cosas que controlas: tu actividad en GBP, la consistencia de tus citaciones y tu perfil de reseñas.</p>
            <p>Los negocios que aparecen consistentemente en el paquete local de 3 están publicando en GBP varias veces por semana, manteniendo datos NAP precisos en todos los directorios principales y respondiendo activamente a las reseñas. No de forma ocasional — de forma consistente, durante meses. El efecto acumulativo de la actividad constante es lo que separa a los negocios en posiciones 1-3 de los que están en posiciones 4-10.</p>
            <p class="font-semibold text-[#111827]">Stacc automatiza los tres. Cada día. Para cada ubicación. Sin recordatorios, sin trabajo manual, sin semanas saltadas. Solo señales de posicionamiento consistentes acumulándose mes tras mes hasta que la posición en Maps que quieres se convierte en la posición que tienes.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Qué automatiza Stacc para el posicionamiento en Maps</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada señal de posicionamiento de alto impacto en Maps.<br />Toda automatizada. Toda consistente.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: '30 posts de GBP al mes', body: 'Stacc publica 30 posts por ubicación al mes orientados a palabras clave locales. La actividad consistente es una de las señales de posicionamiento en GBP más fuertes para la posición en Maps.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Monitorización de citaciones', body: 'Los datos NAP precisos en más de 50 directorios son una señal core de prominencia en Maps. Stacc monitoriza inconsistencias y las señala para corrección — previniendo la pérdida de posicionamiento por conflictos de datos.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitorización de reseñas y alertas', body: 'Las nuevas reseñas generan alertas en tiempo real. Las respuestas oportunas a reseñas contribuyen a tu tasa de respuesta en GBP — una señal de posicionamiento en Maps. Responde directamente desde el panel sin iniciar sesión en GBP.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rastreo diario de posiciones en Maps', body: 'Controla tu posición en el paquete local y en Maps para cada palabra clave diariamente. Comprueba exactamente dónde estás cada mañana y detecta cambios de posicionamiento en el día uno — no en el día treinta.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Protección contra ediciones no autorizadas', body: 'Las ediciones de terceros a tu ficha de GBP se detectan antes de que se apliquen. Los datos de ficha incorrectos son una de las formas más rápidas de caer en el posicionamiento de Maps — Stacc lo previene.' },
            { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Análisis de tendencias de posicionamiento', body: 'Vistas de tendencias de posicionamiento a 30, 60 y 90 días por ubicación y palabra clave. Comprueba el efecto acumulativo de la actividad SEO consistente en la posición de Maps a lo largo del tiempo.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacidades clave</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada señal que mueve tu posición en Maps.<br />Automatizada y consistente.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Actividad GBP que mueve la posición</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 publicaciones de GBP al mes orientadas a búsquedas que generan llamadas en Maps.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El algoritmo de Maps recompensa la consistencia de actividad de GBP con mayor visibilidad en el paquete local. Stacc redacta 30 publicaciones por ubicación al mes, orientadas a tus combinaciones de servicio + ciudad y a búsquedas de alta intención "cerca de mí". Las publicaciones se programan y publican automáticamente — la prominencia que necesitas para escalar en Maps se acumula sin que toques nada.
              </p>
              <a href="/es/modulos/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver el módulo SEO Local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendario de actividad GBP</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 21 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Publicaciones realizadas este mes</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">21 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:70%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Actividad consistente · Señal de prominencia activa</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posición en el paquete local — hoy</p>
              {[
                { kw: 'restaurante italiano cerca de mí', pack: 1, change: '+2', trend: 'up' },
                { kw: 'mejor pizza [ciudad]', pack: 2, change: '+1', trend: 'up' },
                { kw: 'pasta fresca [ciudad]', pack: 3, change: '+3', trend: 'up' },
                { kw: 'restaurante familiar', pack: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Verificado diariamente · Pack local + Maps</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Verificación diaria de posición en Maps</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sabe exactamente dónde posicionas en Maps cada mañana.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Las posiciones del pack local y de Maps se verifican diariamente para cada palabra clave en cada ubicación. Cuando las posiciones cambian — sea una entrada al top 3 o una caída — recibes una alerta automática. Detectas movimientos en el día uno, no en el día treinta cuando ya perdiste un mes de tráfico de alta intención.
              </p>
              <a href="/es/funciones/rastreo-posiciones/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver rastreo de posiciones
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informe de posicionamiento Maps</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes de progreso en Maps que se entregan solos. Cada semana.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configura tu plantilla de informe una vez. Stacc compila las mejoras de posicionamiento, la actividad GBP, las correcciones de citaciones y las nuevas reseñas — todo orientado a explicar el progreso del posicionamiento en Maps — y entrega el informe en la bandeja del cliente o stakeholder según calendario. Sin exportaciones, sin formateo manual.
              </p>
              <a href="/es/soluciones/agencias/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver Stacc para agencias
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">M</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Informe de Maps · Esta semana</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Resumen de posicionamiento</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Entregado</span>
              </div>
              {[
                { label: 'Palabras clave en top 3 Maps', val: '+5 esta semana' },
                { label: 'Posts GBP publicados', val: '7 esta semana' },
                { label: 'Citaciones corregidas', val: '3 inconsistencias' },
                { label: 'Reseñas respondidas', val: '4 / media 4.8 ⭐' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Generado y enviado automáticamente</p>
            </div>
          </div>
        </div>
