---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué datos se sincronizan entre Stacc y WordPress?",
    a: "El nombre del negocio, la dirección, el número de teléfono, el horario y las descripciones de los servicios se sincronizan automáticamente con los campos de información de negocio de tu sitio WordPress. Cualquier actualización realizada en Stacc, incluidos los cambios obtenidos de Google Business Profile, se envía a los campos correspondientes de WordPress sin necesidad de actualizaciones manuales.",
  },
  {
    q: "¿Stacc inyecta marcado schema en WordPress automáticamente?",
    a: "Sí. Stacc envía automáticamente el marcado de schema LocalBusiness a tus páginas de WordPress. Estos datos estructurados indican a Google exactamente qué es tu negocio, dónde está ubicado y cuándo abre, lo que ayuda a que tus páginas locales posicionen mejor en los resultados de búsqueda local.",
  },
  {
    q: "¿Puedo mostrar reseñas en mi sitio WordPress?",
    a: "Sí. Stacc proporciona un widget de reseñas que añades a las páginas de WordPress mediante un shortcode o bloque. Obtiene dinámicamente tus últimas reseñas de Google y Facebook, de modo que el widget siempre muestra prueba social actualizada sin necesidad de actualizaciones manuales.",
  },
  {
    q: "¿Funciona con constructores de páginas como Elementor o Divi?",
    a: "Sí. El widget de reseñas de Stacc y los campos de datos locales funcionan con constructores de páginas de WordPress, incluidos Elementor, Divi y Beaver Builder. El shortcode se puede insertar en cualquier lugar donde funcione un shortcode estándar de WordPress.",
  },
  {
    q: "¿Cuántos sitios WordPress puedo conectar?",
    a: "Puedes conectar un sitio WordPress por ubicación de negocio. Las agencias pueden conectar varios sitios WordPress de clientes en distintas cuentas de Stacc o dentro de una única cuenta de agencia, según el plan contratado.",
  },
  {
    q: "¿Es necesario un plugin de WordPress?",
    a: "Sí. El plugin de Stacc para WordPress es gratuito y está disponible en el directorio de plugins de WordPress. Instálalo, añade tu clave API de Stacc desde la página de configuración y la conexión quedará establecida. La configuración lleva menos de 3 minutos.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integración con WordPress",
      "inLanguage": "es",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Conecta WordPress a theStacc. Sincroniza datos de negocio local, inyecta schema automáticamente e integra widgets de reseñas en tiempo real en tu sitio.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Integraciones", "item": "https://thestacc.com/es/integraciones/" },
        { "@type": "ListItem", "position": 3, "name": "WordPress", "item": "https://thestacc.com/es/integraciones/wordpress/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integración con WordPress — Sincroniza los Datos de Negocio Local con tu Sitio WordPress | theStacc"
  description="Mantén tu sitio WordPress sincronizado con Google Business Profile. Actualiza el horario, los servicios y los datos NAP en Stacc y se envían a WordPress automáticamente con schema local."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integración · WordPress</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="#21759B" aria-label="WordPress" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zM3.5 12c0-1.232.254-2.406.706-3.474L7.942 19.25A8.507 8.507 0 013.5 12zm8.5 8.5a8.498 8.498 0 01-2.416-.35l2.565-7.453 2.629 7.198a.764.764 0 00.058.112A8.496 8.496 0 0112 20.5zm1.172-11.217c.512-.027.972-.08.972-.08.457-.054.403-.726-.054-.699 0 0-1.374.108-2.263.108-.833 0-2.234-.107-2.234-.107-.458-.027-.512.672-.054.699 0 0 .433.053.891.08l1.323 3.623-1.858 5.574-3.094-9.197c.512-.027.972-.08.972-.08.457-.054.403-.726-.054-.699 0 0-1.374.108-2.263.108-.159 0-.347-.004-.546-.01A8.5 8.5 0 0120.398 9.3c-.044.001-.087.005-.131.005-.833 0-1.585.726-1.585 1.504 0 .699.403 1.29.833 1.989.322.565.699 1.29.699 2.343 0 .726-.28 1.569-.646 2.747l-.847 2.829L15.45 9.283zm2.64 10.375l2.61-7.542c.487-1.219.648-2.194.648-3.063 0-.315-.021-.607-.059-.886A8.5 8.5 0 0120.5 12a8.5 8.5 0 01-4.688 7.658z"/>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + WordPress.<br />
            <span style="color:#4f39f6;">Tu sitio, siempre sincronizado.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Mantén los datos de negocio local de tu sitio WordPress precisos en todos los lugares que importan. Actualiza la información de tu negocio en Stacc una sola vez y se sincroniza con WordPress, inyecta schema local automáticamente y mantiene tu widget de reseñas siempre actualizado.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conecta WordPress gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver cómo funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Plugin gratuito · Configuración en 3 minutos · Funciona con cualquier tema WordPress
          </p>
        </div>
      </div>
    </section>


    <!-- ─── LO QUE OBTIENES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lo que obtienes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Los datos de SEO local fluyen de Stacc<br />a WordPress automáticamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Sincronización NAP automática', body: 'El nombre, la dirección y el teléfono del negocio se mantienen coherentes entre Stacc, Google y tu sitio WordPress. Un cambio en Stacc actualiza todo.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Inyección de schema local', body: 'El schema JSON-LD de LocalBusiness se envía automáticamente a tus páginas de WordPress. Indica a Google tu ubicación exacta, horario y categoría sin necesidad de tocar el código del tema.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Widget de reseñas en tiempo real', body: 'Integra un feed de reseñas dinámico en cualquier página de WordPress. Tus últimas reseñas de Google y Facebook se actualizan automáticamente, mostrando siempre prueba social fresca.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Sincronización de horario', body: 'El horario actualizado en Stacc o extraído de Google se envía a WordPress automáticamente. Los cambios de horario en festivos se propagan a todas partes en 30 segundos.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Sincronización de servicios y descripción', body: 'Los listados de servicios y las descripciones del negocio de tu GBP se envían a WordPress. Descripciones coherentes y precisas en todos los lugares donde te buscan clientes y motores de búsqueda.' },
            { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', title: 'Automatización de páginas de ubicación', body: 'Para negocios con múltiples ubicaciones, Stacc puede rellenar páginas de ubicación individuales en WordPress con los datos correctos de cada dirección, de forma automática.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CÓMO CONECTAR ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres pasos. Menos de tres minutos.<br />WordPress conectado.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Instala el plugin de Stacc para WordPress', body: 'Busca "theStacc" en el directorio de plugins de WordPress, instálalo y actívalo. El plugin es gratuito y no requiere programación: añade una página de configuración al panel de administración de WordPress.' },
            { step: '02', title: 'Introduce tu clave API de Stacc', body: 'Copia tu clave API de la configuración de Stacc (en Integraciones → WordPress) y pégala en la página de configuración del plugin. Esto conecta tu sitio WordPress con tu cuenta de Stacc.' },
            { step: '03', title: 'Elige qué sincronizar', body: 'Selecciona qué datos sincronizar: NAP, horario, servicios, marcado schema y widgets de reseñas. Activa la sincronización automática y Stacc mantendrá WordPress actualizado automáticamente cada vez que cambien los datos de tu negocio.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── ANTES / DESPUÉS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. después</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Qué cambia cuando WordPress<br />se conecta a Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarea</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sin Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Con Stacc</div>
          </div>
          {[
            ['Actualizar el horario en el sitio', 'Entrar en WordPress, buscar el campo, actualizar manualmente', 'Actualiza en Stacc, se envía a WP automáticamente'],
            ['Añadir schema a páginas de ubicación', 'Contratar desarrollador o instalar plugin de schema', 'Inyectado automáticamente por Stacc al conectar'],
            ['Mostrar reseñas en el sitio web', 'Captura de pantalla y actualización manual de la página de testimonios', 'Widget en tiempo real, siempre muestra las últimas reseñas'],
            ['Mantener NAP coherente', 'Actualizar GBP, luego WP, luego 50 sitios más por separado', 'Un cambio en Stacc sincroniza en todas partes'],
            ['Mudarse a una nueva dirección', 'Actualizar 8+ lugares manualmente', 'Actualiza una vez, Stacc envía a todas las plataformas'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUIÉN LO USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quién lo usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres flujos de trabajo que esta<br />integración activa de inmediato.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Negocios locales de servicios', title: 'Sitio siempre preciso sin actualizaciones manuales', body: 'El horario cambia, los teléfonos cambian, las direcciones cambian. Con Stacc, tu sitio WordPress se actualiza automáticamente cuando algo cambia en tu GBP sin necesitar un desarrollador web.' },
            { label: 'Agencias de SEO', title: 'Automatiza el schema local para todos los sitios WordPress de clientes', body: 'Conecta todos los sitios WordPress de clientes a Stacc. El marcado schema se instala solo. Los sitios de clientes permanecen precisos. Horas de configuración por cliente reducidas a un clic.' },
            { label: 'Negocios multi-ubicación', title: 'Páginas de ubicación que siempre muestran los datos correctos', body: 'Cada página de ubicación en WordPress muestra el horario, la dirección y las reseñas correctas para esa ubicación específica, sincronizado automáticamente desde Stacc.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── INTEGRACIONES RELACIONADAS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Se usan juntas con frecuencia</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            WordPress funciona mejor<br />junto a estas.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'La fuente de verdad para tus datos locales. Los cambios en GBP se sincronizan con Stacc y luego se envían automáticamente a WordPress.', href: '/es/integraciones/google-business-profile/' },
            { title: 'Gestión de Citas', desc: 'Coherencia NAP en más de 50 directorios, incluido tu sitio WordPress, todo gestionado desde un solo lugar.', href: '/es/funciones/gestion-citas/' },
            { title: 'Monitoreo de Reseñas', desc: 'Monitorea reseñas en Google y Facebook, luego muéstralas en tu sitio WordPress con el widget de reseñas en tiempo real.', href: '/es/funciones/monitoreo-resenas/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre la<br />integración con WordPress
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
