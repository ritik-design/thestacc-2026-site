---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué datos se sincronizan entre Stacc y mi sitio Wix?",
    a: "El nombre del negocio, la dirección, el número de teléfono, el horario y las descripciones de los servicios se sincronizan desde Stacc a los campos de información de negocio de tu sitio Wix. Cualquier actualización realizada en Stacc, incluyendo los cambios obtenidos de Google Business Profile, se envía automáticamente a Wix.",
  },
  {
    q: "¿Stacc inyecta schema local en Wix?",
    a: "Sí. Stacc añade el schema JSON-LD de LocalBusiness a tu sitio Wix mediante el código personalizado o la sección de Metaetiquetas de Wix. Estos datos estructurados indican a Google tu ubicación exacta, horario y categoría de negocio, mejorando tu visibilidad en búsqueda local sin necesidad de programar nada.",
  },
  {
    q: "¿Puedo integrar un widget de reseñas en mi sitio Wix?",
    a: "Sí. Stacc proporciona un código HTML de integración que añades a cualquier página de Wix mediante el widget de HTML integrado. Tus últimas reseñas de Google y Facebook se muestran dinámicamente, actualizándose automáticamente a medida que llegan nuevas reseñas.",
  },
  {
    q: "¿Stacc funciona con los planes de Wix Business y eCommerce?",
    a: "Sí. La integración de Stacc funciona con todos los planes de Wix Business. Las funciones de integración de HTML y código personalizado necesarias para la integración están disponibles en los planes de pago de Wix (Business Basic y superiores).",
  },
  {
    q: "¿Necesito un desarrollador de Wix para configurar esto?",
    a: "No. La integración utiliza el widget de HTML integrado de Wix y la configuración de código personalizado, sin necesidad de programación en Velo ni acceso de desarrollador a Wix. Si puedes añadir una sección a tu sitio Wix, puedes configurar esto.",
  },
  {
    q: "¿Las páginas de ubicación en Wix pueden usar datos específicos de cada ubicación de Stacc?",
    a: "Sí. Para negocios multi-ubicación que usan Wix, Stacc puede suministrar datos de negocio específicos por ubicación: dirección, horario y teléfono únicos por ubicación, a páginas individuales de Wix. Esto mantiene cada página de ubicación precisa sin gestión manual.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integración con Wix",
      "inLanguage": "es",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Conecta Wix a theStacc. Sincroniza datos de negocio local, inyecta schema local automáticamente e integra feeds de reseñas en tiempo real en tu sitio de negocio Wix.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Integraciones", "item": "https://thestacc.com/es/integraciones/" },
        { "@type": "ListItem", "position": 3, "name": "Wix", "item": "https://thestacc.com/es/integraciones/wix/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integración con Wix — Automatiza el SEO Local en tu Sitio de Negocio Wix | theStacc"
  description="Sincroniza tu sitio web Wix con theStacc para mantener los datos de ubicación, horario y reseñas coherentes en todas partes. Automatización de SEO local para sitios de negocio Wix."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integración · Wix</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" aria-label="Wix" aria-hidden="true">
                <rect x="2" y="8" width="20" height="8" rx="2" fill="#FAAD00"/>
                <text x="12" y="15" font-size="9" font-weight="bold" fill="#000" text-anchor="middle" font-family="sans-serif">Wix</text>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Wix.<br />
            <span style="color:#4f39f6;">SEO local en piloto automático.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Conecta tu sitio de negocio Wix a Stacc y mantén los datos de negocio local precisos automáticamente. Schema inyectado, NAP sincronizado, reseñas mostradas, sin tocar tu diseño Wix ni contratar un desarrollador.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conecta Wix gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver cómo funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sin Velo · Configuración en 3 minutos · Funciona con cualquier plantilla Wix
          </p>
        </div>
      </div>
    </section>


    <!-- ─── LO QUE OBTIENES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lo que obtienes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tu sitio Wix se mantiene preciso<br />sin actualizaciones manuales.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Sincronización de datos NAP', body: 'El nombre, la dirección y el teléfono del negocio se mantienen coherentes entre Stacc, Google y tu sitio Wix. Un cambio en Stacc actualiza todo automáticamente.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Inyección de schema local', body: 'El schema JSON-LD de LocalBusiness se inyecta automáticamente en el código personalizado de tu sitio Wix. Datos estructurados limpios para Google, sin edición manual de JSON.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Widget de reseñas en tiempo real', body: 'Añade la integración de reseñas de Stacc a cualquier página de Wix. Tus últimas reseñas de Google y Facebook se muestran automáticamente, siempre actualizadas.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Sincronización de horario', body: 'El horario modificado en Stacc se envía automáticamente a tu sitio Wix. Cambios de temporada, horarios festivos: los clientes siempre ven la información correcta.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Sincronización del mapa de Google integrado', body: 'Tu mapa de Google integrado se actualiza automáticamente cuando tu dirección o área de servicio cambia en Stacc, sin necesidad de actualizar el iframe.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Automatización de páginas de ubicación', body: 'Para negocios Wix con múltiples ubicaciones, Stacc rellena las páginas de ubicación individuales con los datos correctos de cada dirección, manteniéndolas precisas automáticamente.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CÓMO CONECTAR ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres pasos. Sin desarrollador.<br />Wix conectado.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Añade la URL de tu sitio Wix a Stacc', body: 'En la configuración de Stacc, en Integraciones → Wix, introduce la URL de tu sitio Wix. Stacc generará un token de conexión y los fragmentos de código de schema e integración para tu sitio.' },
            { step: '02', title: 'Añade el código de schema al código personalizado de Wix', body: 'En tu panel de Wix, ve a Configuración → Código Personalizado → Encabezado. Pega el fragmento de schema que proporciona Stacc. Esto activa la inyección automática de schema local y la sincronización de datos.' },
            { step: '03', title: 'Integra el widget de reseñas donde sea necesario', body: 'Copia la integración del widget de reseñas de Stacc. En el editor de Wix, añade un widget de HTML a cualquier página y pega el código. Las reseñas se muestran inmediatamente y se actualizan automáticamente.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── ANTES / DESPUÉS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. después</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Qué cambia cuando Wix<br />se conecta a Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarea</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sin Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Con Stacc</div>
          </div>
          {[
            ['Añadir schema local a Wix', 'JSON-LD manual o contratar desarrollador', 'Inyectado automáticamente en la sección de código personalizado'],
            ['Actualizar el horario en el sitio', 'Editar la página de Wix manualmente', 'Actualiza en Stacc, se sincroniza con Wix automáticamente'],
            ['Mostrar reseñas en Wix', 'Captura de pantalla y pegar testimonios manualmente', 'Integración en tiempo real, se actualiza automáticamente con nuevas reseñas'],
            ['Mantener NAP coherente', 'Actualizar Wix, GBP y 50 directorios por separado', 'Un cambio en Stacc actualiza en todas partes'],
            ['Cambiar dirección', 'Entrar en Wix y actualizar todas las páginas individualmente', 'Actualiza una vez, Stacc sincroniza en todas las plataformas'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUIÉN LO USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quién lo usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres flujos de trabajo que esta<br />integración activa de inmediato.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Negocios locales de servicios', title: 'Sitio Wix que siempre muestra información precisa', body: 'Sin más horarios desactualizados ni números de teléfono incorrectos en tu sitio Wix. Stacc mantiene todo sincronizado automáticamente sin tener que entrar en Wix cada vez que algo cambia.' },
            { label: 'Restaurantes en Wix', title: 'Horario, menú y reseñas siempre actualizados', body: 'Actualiza el horario de tu negocio en Stacc una vez y se envía a Google, Wix y más de 50 directorios simultáneamente. Tus clientes siempre ven la información correcta.' },
            { label: 'Agencias de SEO', title: 'Despliega SEO local en todos los sitios Wix de clientes', body: 'Conecta todos los sitios Wix de los clientes a Stacc y añade marcado schema, sincronización NAP y widgets de reseñas a cada sitio en minutos en lugar de horas por cliente.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── INTEGRACIONES RELACIONADAS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Se usan juntas con frecuencia</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Wix funciona mejor<br />junto a estas.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'GBP es la fuente de verdad. Los cambios en GBP se sincronizan con Stacc y luego se envían automáticamente a tu sitio Wix.', href: '/es/integraciones/google-business-profile/' },
            { title: 'Gestión de Citas', desc: 'Mantén la coherencia NAP en más de 50 directorios, incluido tu sitio Wix, desde un único panel.', href: '/es/funciones/gestion-citas/' },
            { title: 'Monitoreo de Reseñas', desc: 'Monitorea nuevas reseñas de Google y Facebook, luego muéstralas en Wix con la integración de reseñas en tiempo real.', href: '/es/funciones/monitoreo-resenas/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre la<br />integración con Wix
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA FINAL ─── -->
    <section class="relative overflow-hidden py-24" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Conecta en minutos</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">
            Tu sitio Wix.<br />Siempre preciso, automáticamente.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
