---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué datos se sincronizan entre Stacc y Ghost?",
    a: "El nombre del negocio, la dirección, el número de teléfono, el horario y las descripciones de los servicios se sincronizan desde Stacc a tu sitio Ghost. Cualquier actualización realizada en Stacc, incluyendo los cambios obtenidos automáticamente desde Google Business Profile, puede enviarse al contenido de Ghost sin necesidad de ediciones manuales.",
  },
  {
    q: "¿Stacc inyecta schema local en Ghost?",
    a: "Sí. Stacc envía el schema JSON-LD de LocalBusiness a la sección de encabezado de tu sitio Ghost mediante la función de Inyección de Código. Estos datos estructurados ayudan a Google a comprender la ubicación, el horario y la categoría de tu negocio para el posicionamiento en búsqueda local.",
  },
  {
    q: "¿Puedo integrar un widget de reseñas en Ghost?",
    a: "Sí. Stacc proporciona un feed de reseñas insertable que puedes añadir a cualquier página o publicación de Ghost mediante una tarjeta HTML personalizada. Tus últimas reseñas de Google y Facebook se muestran dinámicamente, sin necesidad de actualizaciones manuales.",
  },
  {
    q: "¿La integración con Ghost requiere un desarrollador?",
    a: "No. La integración utiliza las funciones integradas de Inyección de Código e Integraciones Personalizadas de Ghost, sin necesidad de modificar el tema ni escribir código personalizado. Si puedes pegar texto en la configuración de Ghost, puedes configurar esto.",
  },
  {
    q: "¿Qué planes de Ghost son compatibles?",
    a: "La integración de Stacc funciona con Ghost Pro (planes Starter, Creator, Team y Business) y con instalaciones de Ghost autoalojadas. La función de Inyección de Código de Ghost, necesaria para la inyección de schema, está disponible en todos los planes de pago de Ghost Pro.",
  },
  {
    q: "¿Puedo usar esto para un sitio Ghost con múltiples ubicaciones?",
    a: "Sí. Para negocios con múltiples ubicaciones, Stacc puede rellenar datos específicos de cada ubicación en distintas páginas o secciones de Ghost. Los datos de cada ubicación, dirección, horario y reseñas, se mantienen precisos y sincronizados en todo tu sitio Ghost.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integración con Ghost",
      "inLanguage": "es",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Conecta Ghost a theStacc. Sincroniza datos de negocio local, inyecta schema local automáticamente e integra feeds de reseñas en tiempo real en tu sitio con Ghost.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Integraciones", "item": "https://thestacc.com/es/integraciones/" },
        { "@type": "ListItem", "position": 3, "name": "Ghost", "item": "https://thestacc.com/es/integraciones/ghost/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integración con Ghost — Sincroniza Datos de SEO Local con tu Sitio Ghost | theStacc"
  description="Conecta Ghost con theStacc para mantener los datos de negocio local coherentes en tu sitio con Ghost. Automatiza el schema local y la sincronización NAP sin tocar el código."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integración · Ghost</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" aria-label="Ghost" aria-hidden="true">
                <circle cx="12" cy="12" r="10" fill="#15212A"/>
                <text x="12" y="17" font-size="14" font-weight="bold" fill="white" text-anchor="middle" font-family="sans-serif">G</text>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Ghost.<br />
            <span style="color:#4f39f6;">SEO local, integrado.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Conecta tu sitio Ghost a Stacc y mantén todos los datos de negocio local precisos automáticamente. NAP sincronizado, schema local inyectado y feed de reseñas en tiempo real integrado, sin tocar tu tema ni escribir ningún código.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conecta Ghost gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver cómo funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sin código · Configuración en 3 minutos · Ghost Pro + autoalojado
          </p>
        </div>
      </div>
    </section>


    <!-- ─── LO QUE OBTIENES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lo que obtienes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Las señales de SEO local fluyen de Stacc<br />a tu sitio Ghost automáticamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Sincronización de datos NAP', body: 'El nombre, la dirección y el teléfono del negocio se mantienen precisos entre Stacc, Google y tu sitio Ghost. Una actualización en Stacc lo corrige todo.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Inyección de schema local', body: 'El schema JSON-LD de LocalBusiness se envía automáticamente a la sección de Inyección de Código de tu sitio Ghost. Datos estructurados limpios para Google sin ningún trabajo manual.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Feed de reseñas dinámico', body: 'Integra tus últimas reseñas de Google y Facebook en cualquier página de Ghost. El feed se actualiza automáticamente a medida que llegan nuevas reseñas, mostrando siempre prueba social fresca.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Sincronización de horario', body: 'El horario actualizado en Stacc se envía automáticamente a tu sitio Ghost. Cambios de temporada, horarios festivos: los clientes siempre ven la información correcta.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Sincronización de servicios y descripción', body: 'Las descripciones de servicios de tu perfil de GBP se sincronizan con las páginas de Ghost. Descripciones precisas y coherentes donde quiera que te busquen clientes y motores de búsqueda.' },
            { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', title: 'Compatibilidad multi-ubicación', body: 'Conecta múltiples sitios Ghost, uno por ubicación, y sincroniza datos específicos de cada ubicación en cada uno. Cada sitio se mantiene preciso sin gestión manual.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CÓMO CONECTAR ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres pasos. Sin desarrollador.<br />Ghost conectado.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Genera una clave API en Ghost', body: 'En el panel de administración de Ghost, ve a Configuración → Integraciones → Añadir Integración Personalizada. Dale un nombre (por ejemplo, "Stacc") y copia la Clave API de administrador generada. Esto es lo que usa Stacc para enviar datos a tu sitio.' },
            { step: '02', title: 'Añade la clave API a Stacc', body: 'En la configuración de Stacc, en Integraciones → Ghost, pega tu Clave API de administrador y la URL de tu sitio Ghost. Stacc verifica la conexión y confirma a qué ubicación está vinculada.' },
            { step: '03', title: 'Activa la sincronización e integra el widget de reseñas', body: 'Activa la sincronización NAP, la inyección de schema y la sincronización del horario. Obtén el código de integración del widget de reseñas de Stacc y añádelo a cualquier página de Ghost mediante una tarjeta HTML personalizada. Listo.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── ANTES / DESPUÉS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. después</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Qué cambia cuando Ghost<br />se conecta a Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarea</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sin Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Con Stacc</div>
          </div>
          {[
            ['Añadir schema local a Ghost', 'Contratar desarrollador o añadir JSON-LD manualmente al tema', 'Inyectado automáticamente mediante Inyección de Código'],
            ['Actualizar el horario en el sitio', 'Editar el contenido de la página de Ghost manualmente', 'Actualiza en Stacc, se envía automáticamente'],
            ['Mostrar reseñas en el sitio Ghost', 'Captura de pantalla y pegar reseñas manualmente', 'Integración en tiempo real, siempre muestra las últimas reseñas'],
            ['Mantener NAP coherente', 'Actualizar Ghost, GBP y directorios por separado', 'Un cambio en Stacc sincroniza en todas partes'],
            ['Cambiar dirección del negocio', 'Actualizar 6+ plataformas manualmente', 'Actualiza una vez, Stacc envía a todas las plataformas conectadas'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUIÉN LO USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quién lo usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres flujos de trabajo que esta<br />integración activa de inmediato.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Negocios locales en Ghost', title: 'Datos locales siempre precisos sin ayuda de desarrollador', body: 'Tu sitio Ghost se mantiene sincronizado con los datos reales de tu negocio automáticamente. Horario, dirección, teléfono y reseñas: precisos en todas partes sin actualizaciones manuales.' },
            { label: 'Negocios locales enfocados en contenido', title: 'Páginas locales optimizadas para SEO con schema correcto', body: 'Ghost está hecho para el contenido. Stacc añade la capa de SEO local: marcado schema, coherencia NAP y señales de reseñas, para que tu contenido posicione localmente.' },
            { label: 'Agencias de SEO', title: 'Automatiza el SEO local para clientes en Ghost', body: 'Conecta los sitios Ghost de los clientes a Stacc y despliega schema local, sincronización NAP y feeds de reseñas en todos los sitios de clientes en minutos en lugar de horas.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── INTEGRACIONES RELACIONADAS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Se usan juntas con frecuencia</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ghost funciona mejor<br />junto a estas.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'La fuente de verdad. Los cambios en GBP se sincronizan con Stacc y luego se envían automáticamente a tu sitio Ghost.', href: '/es/integraciones/google-business-profile/' },
            { title: 'Gestión de Citas', desc: 'Mantén la coherencia NAP en más de 50 directorios, incluido tu sitio Ghost, desde un único panel.', href: '/es/funciones/gestion-citas/' },
            { title: 'Monitoreo de Reseñas', desc: 'Monitorea reseñas en todas las plataformas y muestra las más recientes en Ghost con la integración de reseñas en tiempo real.', href: '/es/funciones/monitoreo-resenas/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre la<br />integración con Ghost
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA FINAL ─── -->
    <section class="relative overflow-hidden py-24" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Conecta en minutos</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">
            Tu sitio Ghost.<br />SEO local gestionado automáticamente.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
