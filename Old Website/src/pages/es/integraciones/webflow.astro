---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Cómo se conecta Stacc con Webflow?",
    a: "Stacc se conecta a Webflow mediante la API de Webflow y un script ligero añadido a la configuración de código personalizado de tu sitio Webflow. No se requiere el plan Developer de Webflow: la integración funciona con planes Business y superiores.",
  },
  {
    q: "¿Puede Stacc sincronizar datos con los campos del CMS de Webflow?",
    a: "Sí. Stacc puede enviar datos de negocio, nombre, dirección, horario, teléfono y descripciones de servicios, a campos de colección del CMS de Webflow designados. Esto mantiene las páginas de ubicación precisas sin actualizaciones manuales del CMS.",
  },
  {
    q: "¿Stacc inyecta schema local en Webflow?",
    a: "Sí. Stacc añade el schema JSON-LD de LocalBusiness a la sección de código personalizado del encabezado de tu sitio Webflow. Estos datos estructurados indican a Google tu ubicación exacta, horario y servicios, sin necesidad de editar JSON-LD manualmente.",
  },
  {
    q: "¿Puedo integrar un widget de reseñas en Webflow?",
    a: "Sí. Stacc proporciona un HTML de integración que añades a cualquier página de Webflow mediante un componente HTML Embed. Tus últimas reseñas de Google y Facebook se muestran dinámicamente, actualizándose automáticamente a medida que llegan nuevas reseñas, sin ningún cambio manual en tu sitio.",
  },
  {
    q: "¿Funciona esto para sitios Webflow creados por agencias?",
    a: "Sí. Las agencias pueden conectar los sitios Webflow de sus clientes a Stacc y desplegar schema local, sincronización NAP y feeds de reseñas en múltiples proyectos de clientes desde una única cuenta de Stacc. Cada sitio de cliente se conecta de forma independiente y se sincroniza con los datos de ubicación correspondientes.",
  },
  {
    q: "¿Necesito modificar el tema o los componentes de Webflow?",
    a: "No. La integración de Stacc añade datos mediante la configuración de código personalizado de Webflow y la API CMS, sin necesidad de modificar ningún componente de diseño existente. Tu diseño Webflow permanece exactamente como está.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integración con Webflow",
      "inLanguage": "es",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Conecta Webflow a theStacc. Sincroniza datos de negocio local con campos del CMS, inyecta schema local automáticamente e integra feeds de reseñas en tiempo real en sitios Webflow.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Integraciones", "item": "https://thestacc.com/es/integraciones/" },
        { "@type": "ListItem", "position": 3, "name": "Webflow", "item": "https://thestacc.com/es/integraciones/webflow/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integración con Webflow — Automatización de SEO Local para Sitios Webflow | theStacc"
  description="Mantén los datos de negocio local de tu sitio Webflow sincronizados con Google Business Profile y más de 50 directorios. Automatiza el schema local y el NAP sin código personalizado."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integración · Webflow</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="#4353FF" aria-label="Webflow" aria-hidden="true">
                <path d="M17.44 7.636C16.26 9.87 15.42 11.54 14.65 13.03c-.17-.96-.27-2.04-.4-3.44l-.05-.61H10.8L8.56 16.36 7.34 9H4L6.56 21h3.37l2.3-7.3c.14 1.06.29 2.11.54 3.07l.56 2.23h3l4.67-11.36h-3.04z"/>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Webflow.<br />
            <span style="color:#4f39f6;">SEO local, siempre sincronizado.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Conecta tu sitio Webflow a Stacc y mantén todos los datos de negocio local precisos automáticamente. Campos del CMS sincronizados, schema local inyectado, feeds de reseñas integrados, sin modificar tu diseño ni escribir código personalizado.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conecta Webflow gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver cómo funciona
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sin código personalizado · Sincronización API CMS · Para agencias y multi-ubicación
          </p>
        </div>
      </div>
    </section>


    <!-- ─── LO QUE OBTIENES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lo que obtienes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Los datos de SEO local fluyen de Stacc<br />al CMS de Webflow automáticamente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Sincronización de campos del CMS', body: 'Los datos de negocio, nombre, dirección, horario, teléfono, servicios, se envían automáticamente a los campos de colección del CMS de Webflow. Las páginas de ubicación se mantienen precisas sin ediciones manuales.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Inyección de schema local', body: 'El schema JSON-LD de LocalBusiness se inyecta automáticamente mediante la configuración de código personalizado de Webflow. Datos estructurados limpios para Google, sin editar JSON-LD ni necesitar un desarrollador.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Feed de reseñas dinámico', body: 'Integra un feed de reseñas en tiempo real en cualquier página de Webflow mediante un componente HTML Embed. Las últimas reseñas de Google y Facebook se muestran automáticamente, siempre actualizadas.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Sincronización de horario', body: 'El horario actualizado en Stacc se envía automáticamente a los campos del CMS de Webflow. Los clientes en tu sitio Webflow siempre ven el horario correcto, sin actualizaciones manuales.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Puente de datos de servicios', body: 'Los nombres y descripciones de servicios se sincronizan desde tu GBP a través de Stacc a Webflow. Información de servicios coherente en todos los lugares donde te buscan clientes y motores de búsqueda.' },
            { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', title: 'Compatibilidad CMS multi-ubicación', body: 'Para builds Webflow con múltiples ubicaciones, Stacc sincroniza datos específicos de cada ubicación a elementos CMS individuales, manteniendo cada página de ubicación precisa sin gestión manual del CMS.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CÓMO CONECTAR ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres pasos. Sin cambios en el diseño.<br />Webflow conectado.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Genera un token API de Webflow', body: 'En Webflow, ve a Configuración de cuenta → Integraciones → Acceso API → Generar token API. Copia el token y pégalo en Stacc en Integraciones → Webflow. Stacc se conecta a tu proyecto inmediatamente.' },
            { step: '02', title: 'Mapea los campos del CMS con los datos de Stacc', body: 'Stacc muestra las colecciones CMS de tu sitio Webflow. Mapea los campos de ubicación (dirección, horario, teléfono) con los datos correspondientes de Stacc. Stacc mantendrá esos campos actualizados automáticamente.' },
            { step: '03', title: 'Añade el código de schema y la integración de reseñas', body: 'Copia el fragmento de schema de Stacc y pégalo en la sección de código personalizado del encabezado de tu sitio Webflow. Añade el HTML del widget de reseñas a cualquier página mediante un componente Embed. Listo: todo funciona automáticamente desde aquí.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── ANTES / DESPUÉS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. después</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Qué cambia cuando Webflow<br />se conecta a Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarea</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sin Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Con Stacc</div>
          </div>
          {[
            ['Añadir schema local a Webflow', 'Editar código personalizado manualmente o contratar desarrollador', 'Inyectado automáticamente por Stacc al conectar'],
            ['Actualizar el horario de la página de ubicación', 'Entrar en el CMS de Webflow, buscar el elemento, editar', 'Actualiza en Stacc, se sincroniza con el CMS automáticamente'],
            ['Mostrar reseñas en Webflow', 'Captura de pantalla + pegar testimonios en el CMS', 'Integración en tiempo real, siempre muestra las últimas reseñas'],
            ['Lanzar nueva página de ubicación', 'Introducir manualmente todos los datos en la colección CMS', 'Stacc envía automáticamente los datos de la nueva ubicación'],
            ['Mantener NAP coherente', 'Actualizar Webflow, GBP y directorios por separado', 'Un cambio en Stacc sincroniza en todas las plataformas'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── QUIÉN LO USA ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Quién lo usa</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres flujos de trabajo que esta<br />integración activa de inmediato.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Agencias Webflow', title: 'Automatización de SEO local en todos los sitios de clientes', body: 'Conecta todos los sitios Webflow de clientes a Stacc y despliega marcado schema, sincronización NAP y feeds de reseñas en cada proyecto desde un único panel, en minutos, no horas por cliente.' },
            { label: 'Builds Webflow multi-ubicación', title: 'Páginas de ubicación que siempre muestran los datos correctos', body: 'Cada página de ubicación en Webflow muestra la dirección, el horario y las reseñas correctas para esa ubicación, sincronizado automáticamente desde Stacc sin tocar el CMS.' },
            { label: 'Negocios locales en Webflow', title: 'Un sitio Webflow que se mantiene solo', body: 'Tu diseño Webflow permanece exactamente como está. Stacc añade la capa de SEO local por debajo: schema, NAP, reseñas, todo mantenido con precisión automáticamente.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── INTEGRACIONES RELACIONADAS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Se usan juntas con frecuencia</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Webflow funciona mejor<br />junto a estas.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'Los cambios en GBP se sincronizan con Stacc y luego se envían automáticamente a los campos del CMS de Webflow. El bucle completo de datos, cerrado.', href: '/es/integraciones/google-business-profile/' },
            { title: 'Gestión de Citas', desc: 'Mantén la coherencia NAP en más de 50 directorios, incluido tu sitio Webflow, todo gestionado desde un solo lugar.', href: '/es/funciones/gestion-citas/' },
            { title: 'Panel de Marca Blanca', desc: 'Las agencias que entregan sitios Webflow pueden presentar a los clientes un panel de Stacc con marca personalizada junto con la entrega del sitio.', href: '/es/funciones/panel-marca-blanca/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre la<br />integración con Webflow
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA FINAL ─── -->
    <section class="relative overflow-hidden py-24" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative">
