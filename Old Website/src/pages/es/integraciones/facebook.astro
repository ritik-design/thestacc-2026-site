---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Con qué tipos de cuentas de Facebook se conecta Stacc?",
    a: "Stacc se conecta con Páginas de Empresa de Facebook, las páginas vinculadas a tus ubicaciones de negocio. Los perfiles personales no son compatibles. Puedes conectar una página por ubicación y gestionar todas las páginas conectadas desde un único panel de Stacc.",
  },
  {
    q: "¿Puedo publicar el mismo contenido en todas las páginas de ubicación a la vez?",
    a: "Sí. Escribe una publicación y publícala en una sola página o en todas las páginas conectadas simultáneamente. La publicación masiva está disponible en todos los planes. También puedes añadir detalles específicos de cada ubicación antes de enviar si lo necesitas.",
  },
  {
    q: "¿Stacc monitorea las reseñas de Facebook?",
    a: "Sí. Las recomendaciones de Facebook (el equivalente a las reseñas de 5 estrellas) se incorporan al panel de reseñas de Stacc en tiempo real. Recibirás una alerta instantánea cuando llegue una nueva recomendación, con el nombre del revisor, la puntuación y el contenido, sin necesidad de iniciar sesión en Facebook.",
  },
  {
    q: "¿Puedo responder a las reseñas de Facebook desde Stacc?",
    a: "Las plantillas de respuesta están disponibles en Stacc para redactar respuestas. Para la publicación final de las respuestas, la API de Facebook requiere confirmación directa. Stacc prepara la respuesta y te lleva directamente a la reseña para que puedas publicar con un solo clic.",
  },
  {
    q: "¿Cuántas páginas de Facebook puedo conectar?",
    a: "Puedes conectar tantas páginas como ubicaciones tengas. No hay un límite estricto de páginas conectadas en Stacc. Si gestionas 50 ubicaciones, conecta las 50 páginas y gestiónalo todo desde un mismo lugar.",
  },
  {
    q: "¿Es segura la conexión con Facebook?",
    a: "Stacc utiliza el flujo OAuth oficial de Facebook. La autenticación se realiza a través de Facebook: Stacc nunca almacena tu contraseña. Puedes revocar el acceso en cualquier momento desde la configuración de tu empresa en Facebook.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Integración con Facebook",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Conecta las Páginas de Empresa de Facebook a theStacc. Gestiona publicaciones, monitorea reseñas y rastrea el engagement de todas las páginas de ubicación desde un único panel.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Integraciones", "item": "https://thestacc.com/es/integraciones/" },
        { "@type": "ListItem", "position": 3, "name": "Facebook", "item": "https://thestacc.com/es/integraciones/facebook/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Integración con Facebook — Gestiona Páginas de Empresa y Publica en Todas las Ubicaciones | theStacc"
  description="Conecta la página de Facebook de cada ubicación a theStacc. Programa publicaciones, monitorea reseñas y rastrea el engagement de todas las páginas desde un panel unificado."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integración · Facebook</span>
          </div>
          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/><path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </div>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Facebook.<br />
            <span style="color:#4f39f6;">Todas las páginas, un solo lugar.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Conecta la página de Facebook de cada ubicación a Stacc. Programa publicaciones en todas las páginas a la vez, monitorea las reseñas en tiempo real y rastrea el engagement sin iniciar sesión en Facebook ni una sola vez.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Conectar Facebook gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#como-conectar" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">Cómo funciona</a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">OAuth seguro · Configuración en 2 minutos · Para 1 o 100 páginas</p>
        </div>
      </div>
    </section>


    <!-- ─── WHAT YOU GET ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lo que obtienes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecta una vez. Todas las páginas<br />de ubicación gestionadas desde aquí.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z', title: 'Publicación masiva en todas las páginas', body: 'Escribe una publicación y publícala en una página o en todas las páginas de ubicación conectadas a la vez. Sin inicios de sesión. Sin copiar y pegar. Sin ubicaciones olvidadas.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Monitoreo de reseñas en tiempo real', body: 'Las nuevas recomendaciones de Facebook aparecen en Stacc en minutos. Las alertas instantáneas incluyen nombre del revisor, puntuación y texto completo, sin acceder a Facebook.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Calendario de programación de contenido', body: 'Planifica publicaciones con semanas de antelación. Establece un calendario de publicación por página o para todas las ubicaciones. Stacc publica automáticamente en los horarios que especifiques.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Panel de seguimiento de engagement', body: 'Alcance, engagement de publicaciones y tendencias de seguidores en todas las páginas conectadas en una sola vista. Ve qué ubicaciones ganan tracción y cuáles necesitan atención.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Plantillas de respuesta a reseñas', body: 'Stacc prepara plantillas de respuesta para cada nueva reseña. Edita y envía con un clic, o deja que Stacc redacte y enrute para aprobación antes de publicar.' },
            { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', title: 'Gestión multipágina', body: 'Gestiona todas las páginas de ubicación bajo un solo acceso. Añade nuevas páginas cuando abras nuevas ubicaciones. Elimina o pausa páginas sin afectar a las demás.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── SETUP STEPS ─── -->
    <section id="como-conectar" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo conectar</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tres pasos. Menos de cinco minutos.<br />Todas las páginas conectadas.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Conecta mediante Facebook OAuth', body: 'Haz clic en "Conectar Facebook" en la configuración de Stacc. Se te redirigirá al inicio de sesión de Facebook: no se almacenan contraseñas en Stacc. Selecciona las páginas que quieres conectar y autoriza el acceso.' },
            { step: '02', title: 'Selecciona tus páginas de ubicación', body: 'Stacc muestra todas las Páginas de Empresa de Facebook que gestiona tu cuenta. Marca las que quieres rastrear y en las que publicar. Puedes añadir o eliminar páginas en cualquier momento desde la configuración de integraciones.' },
            { step: '03', title: 'Empieza a publicar y monitorear', body: 'Las páginas conectadas aparecen inmediatamente en el panel social de Stacc. Programa tu primera publicación, revisa las reseñas pendientes y consulta los datos de engagement, todo sin abrir Facebook.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BEFORE / AFTER ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Antes vs. después</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Qué cambia cuando Facebook<br />funciona a través de Stacc.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Tarea</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Sin Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Con Stacc</div>
          </div>
          {[
            ['Publicar en 10 páginas de ubicación', 'Iniciar sesión 10 veces, copiar y pegar, 40 min', 'Una publicación, publicación masiva, 2 min'],
            ['Revisar nuevas reseñas', 'Acceder a cada página por separado', 'Alerta instantánea en el panel de Stacc'],
            ['Ver el engagement entre ubicaciones', 'Descargar CSV de cada página y fusionar', 'Una vista unificada, siempre en directo'],
            ['Responder a una mala reseña', 'Encontrarla, acceder, escribir respuesta, publicar', 'Plantilla lista, un clic'],
            ['Programar una publicación de temporada', 'Poner recordatorios, acceder el día en cuestión', 'Programado una vez, se publica automáticamente'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── RELATED ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">A menudo conectado junto con</p>
        <div class="mt-8 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'Publica en GBP y Facebook simultáneamente. Una acción cubre ambos canales para cada ubicación.', href: '/es/integraciones/google-business-profile/' },
            { title: 'Instagram', desc: 'Amplía tu flujo de publicación masiva a Instagram. Mismo contenido, tres plataformas, un clic.', href: '/es/integraciones/instagram/' },
            { title: 'Monitoreo de Reseñas', desc: 'Las reseñas de Facebook van directamente al panel de reseñas unificado de Stacc junto con Google.', href: '/es/funciones/monitoreo-resenas/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-white p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre la integración con Facebook
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-24" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Conecta en minutos</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">
            Todas las páginas de ubicación.<br />Un lugar para gestionarlas.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Deja de acceder a una docena de cuentas de Facebook para gestionar las páginas de tu negocio. Conéctalas todas a Stacc y gestiona todo —publicaciones, monitoreo de reseñas, seguimiento de engagement— desde un panel.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Empieza gratis — sin tarjeta de crédito
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <p class="mt-5 font-mono text-[10px] uppercase tracking-[0.18em] text-[#292524]/20">Prueba gratuita 14 días · Sin tarjeta de crédito · Cancela cuando quieras</p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const plus = btn.querySelector('.faq-icon-plus');
      const minus = btn.querySelector('.faq-icon-minus');
      if (!answer) return;
      const isOpen = !answer.classList.contains('hidden');
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
      document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
      if (!isOpen) {
        answer.classList.remove('hidden');
        plus?.classList.add('hidden');
        minus?.classList.remove('hidden');
      }
    });
  });
</script>
