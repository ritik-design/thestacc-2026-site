---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import { getCollection } from 'astro:content';
import { POSTS_PER_PAGE } from '../../../data/constants';

const enPosts = await getCollection('blog');
const langPosts = await getCollection('blog_es');
const langBySlug = new Map(langPosts.map(p => [p.data.slug, p]));
const posts = enPosts
  .filter(enPost => langBySlug.has(enPost.data.slug))
  .map(enPost => {
    const lp = langBySlug.get(enPost.data.slug)!;
    return { ...enPost, data: { ...enPost.data, title: lp.data.title, description: lp.data.description } };
  });
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const visiblePosts = sortedPosts.filter(p => p.data.image);
const totalPages = Math.ceil(visiblePosts.length / POSTS_PER_PAGE);
const pagePosts = visiblePosts.slice(0, POSTS_PER_PAGE);

function getReadTime(post: any): number {
  const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const allCategoryCounts = visiblePosts.reduce<Record<string, number>>((acc, p) => {
  acc[p.data.category] = (acc[p.data.category] || 0) + 1;
  return acc;
}, {});
const allCategories = Object.entries(allCategoryCounts).sort((a, b) => b[1] - a[1]);

const pageCategoryCounts = pagePosts.reduce<Record<string, number>>((acc, p) => {
  acc[p.data.category] = (acc[p.data.category] || 0) + 1;
  return acc;
}, {});
const pageCategories = Object.entries(pageCategoryCounts).sort((a, b) => b[1] - a[1]);

const featuredPosts = pagePosts.slice(0, 3);
const featuredLabels = ['Más Popular', 'Tendencia', 'Selección del Editor'];

const tools = [
  { name: 'Auditoría SEO', href: '/es/herramientas/auditoria-seo/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>` },
  { name: 'Puntuación SEO', href: '/es/herramientas/puntuacion-seo-sitio/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>` },
  { name: 'Meta Tags', href: '/es/herramientas/analizador-meta-tags/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>` },
  { name: 'SEO On-Page', href: '/es/herramientas/verificador-seo-on-page/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>` },
  { name: 'Schema Markup', href: '/es/herramientas/generador-schema-markup/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>` },
  { name: 'Analizador Títulos', href: '/es/herramientas/analizador-titulos/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h7"/></svg>` },
];

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      '@id': 'https://thestacc.com/es/blog/',
      name: 'Blog SEO | theStacc',
      description: `${visiblePosts.length}+ guías, tutoriales y estrategias SEO para posicionarte más alto y convertir más tráfico.`,
      url: 'https://thestacc.com/es/blog/',
      inLanguage: 'es',
      publisher: { '@id': 'https://thestacc.com/#organization' },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://thestacc.com/es/' },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://thestacc.com/es/blog/' },
      ],
    },
  ],
};
---

<BaseLayout
  title="Blog SEO | theStacc — Guías y Estrategias SEO en Español"
  description={`${visiblePosts.length}+ guías, tutoriales y estrategias SEO para posicionarte más alto y convertir más tráfico. SEO Local, contenido, IA y crecimiento de agencias.`}
  lang="es"
>
  <Fragment slot="head">
    {totalPages > 1 && <link rel="next" href="/es/blog/page/2/" />}
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  <main class="flex-1">

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-8 pb-10">
        <nav aria-label="Migas de pan">
          <ol class="flex items-center gap-1.5 font-mono text-[11px] text-[#a8a29e]">
            <li><a href="/es/" class="hover:text-[#57534e] transition-colors">Inicio</a></li>
            <li class="before:content-['/'] before:mx-1.5 text-[#79716b]">Blog</li>
          </ol>
        </nav>
        <p class="mt-4 font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Blog SEO</p>
        <h1 class="mt-3 max-w-[600px] font-sans text-[28px] font-bold leading-[1.15] tracking-[-0.025em] text-[#292524] md:text-[38px]">
          Biblioteca de Recursos SEO
        </h1>
        <p class="mt-3 max-w-[500px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          {visiblePosts.length}+ guías, tutoriales y estrategias para posicionarte más alto y convertir más tráfico.
        </p>

        <!-- Search -->
        <div class="mt-5 max-w-[520px]">
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <input
              id="blog-search"
              type="search"
              placeholder={`Buscar en ${visiblePosts.length}+ guías y estrategias SEO...`}
              style="background:#f5f5f4;color:#292524;"
              class="w-full rounded-xl border border-[#e7e5e4] py-3 pl-11 pr-4 font-sans text-[14px] placeholder-[#4b5563] outline-none ring-0 transition-all focus:border-[#4f39f6]"
            />
          </div>
        </div>

        <!-- Trust pills -->
        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            {visiblePosts.length}+ Artículos
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            {allCategories.length} Temas
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Actualizado semanalmente
          </span>
        </div>
      </div>
    </section>

    <!-- BROWSE BY TOPIC -->
    <section class="border-b border-[#e7e5e4] bg-white py-8">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-5 flex items-center justify-between">
          <h2 class="font-sans text-[17px] font-bold text-[#111827]">Explorar por Tema</h2>
          <span class="font-mono text-[11px] text-[#79716b]">{allCategories.length} categorías · {visiblePosts.length} artículos</span>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {allCategories.map(([cat, count]) => (
            <button
              class="topic-btn group flex cursor-pointer flex-col items-start gap-1 rounded-xl border border-[#e7e5e4] bg-white p-4 text-left transition-all hover:border-[#c4b5fd] hover:shadow-sm"
              data-topic={cat}
            >
              <span class="font-sans text-[12px] font-semibold leading-[1.4] text-[#292524] transition-colors group-hover:text-[#4f39f6]">{cat}</span>
              <span class="font-mono text-[10px] text-[#79716b]">{count} artículos</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- POPULAR THIS MONTH -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] py-8">
      <div class="mx-auto max-w-6xl px-6">
        <p class="mb-5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Popular Este Mes</p>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
          {featuredPosts.map((post, i) => (
            <a
              href={`/es/blog/${post.data.slug}/`}
              class="group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-md"
            >
              <div class="flex flex-1 flex-col p-5">
                <div class="mb-2.5 flex items-center justify-between gap-2">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                  <span class="shrink-0 rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[9px] font-bold uppercase tracking-[0.06em] text-[#7c3aed]">{featuredLabels[i]}</span>
                </div>
                <h3 class="flex-1 font-sans text-[15px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                  {post.data.title}
                </h3>
                <div class="mt-3 flex items-center gap-2">
                  <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min lectura</span>
                  <span class="text-[#d6d3d1]">·</span>
                  <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- STICKY FILTER BAR -->
    <div id="article-grid-top" class="sticky top-0 z-30 border-b border-[#e7e5e4] bg-white/95 backdrop-blur-sm">
      <div class="mx-auto max-w-6xl px-6 py-3.5">
        <div class="flex flex-wrap items-center gap-1.5">
          <button
            data-category="all"
            class="blog-cat-btn cursor-pointer rounded-lg border border-[#4f39f6] bg-[#4f39f6] px-3 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-white transition-colors"
          >Todos <span class="font-normal opacity-70">{pagePosts.length}</span></button>
          {pageCategories.map(([cat, count]) => (
            <button
              data-category={cat}
              class="blog-cat-btn cursor-pointer rounded-lg border border-[#e7e5e4] bg-white px-3 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]"
            >{cat} <span class="font-normal opacity-70">{count}</span></button>
          ))}
        </div>
      </div>
    </div>

    <!-- GRID -->
    <section class="bg-[#fafaf9] px-6 py-8">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {pagePosts.slice(0, 9).map((post) => (
            <a
              href={`/es/blog/${post.data.slug}/`}
              class="blog-card group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm"
              data-category={post.data.category}
              data-title={post.data.title.toLowerCase()}
              data-desc={(post.data.description ?? '').toLowerCase()}
            >
              <div class="flex flex-1 flex-col p-5">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                <h3 class="mt-2 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                  {post.data.title}
                </h3>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                    <span class="text-[#e7e5e4]">·</span>
                    <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min</span>
                  </div>
                  <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Newsletter CTA -->
        <div class="newsletter-row my-6 rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
          <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
            <div class="max-w-[480px]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">SEO Semanal</p>
              <h3 class="mt-1.5 font-sans text-[20px] font-bold leading-[1.2] text-[#111827]">Las estrategias que realmente mueven rankings</h3>
              <p class="mt-2 font-sans text-[14px] leading-[1.6] text-[#57534e]">Un email semanal: tácticas, actualizaciones y casos de estudio que valen tu tiempo.</p>
            </div>
            <div class="shrink-0">
              <div class="flex flex-col gap-2 sm:flex-row">
                <input
                  type="email"
                  placeholder="tu@email.com"
                  class="h-10 rounded-lg border border-[#e7e5e4] px-4 font-sans text-[14px] text-[#292524] placeholder-[#a8a29e] outline-none focus:border-[#4f39f6] sm:w-[220px]"
                />
                <a
                  href="/es/demo/"
                  class="inline-flex h-10 items-center justify-center rounded-lg bg-[#4f39f6] px-5 font-mono text-[12px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#615fff] whitespace-nowrap"
                >
                  Suscribirse Gratis
                </a>
              </div>
              <p class="mt-1.5 font-mono text-[10px] text-[#79716b]">Sin spam · Cancelar en cualquier momento</p>
            </div>
          </div>
        </div>

        {pagePosts.length > 9 && (
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {pagePosts.slice(9).map((post) => (
              <a
                href={`/es/blog/${post.data.slug}/`}
                class="blog-card group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm"
                data-category={post.data.category}
                data-title={post.data.title.toLowerCase()}
                data-desc={(post.data.description ?? '').toLowerCase()}
              >
                <div class="flex flex-1 flex-col p-5">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                  <h3 class="mt-2 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                    {post.data.title}
                  </h3>
                  <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                  <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                    <div class="flex items-center gap-2">
                      <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                      <span class="text-[#e7e5e4]">·</span>
                      <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min</span>
                    </div>
                    <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}

        <div id="no-results" class="hidden py-16 text-center">
          <p class="font-sans text-[16px] text-[#79716b]">
            No se encontraron artículos.
            <button id="clear-search" class="cursor-pointer text-[#4f39f6] underline">Limpiar búsqueda</button>
          </p>
        </div>

        {totalPages > 1 && (
          <nav class="mt-10 flex items-center justify-center gap-2" aria-label="Paginación del blog">
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-[#4f39f6] font-mono text-[13px] font-semibold text-white">1</span>
            {Array.from({ length: Math.min(totalPages - 1, 4) }, (_, i) => i + 2).map(num => (
              <a href={`/es/blog/page/${num}/`} class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] font-mono text-[13px] font-semibold text-[#79716b] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">{num}</a>
            ))}
            {totalPages > 5 && <span class="font-mono text-sm text-[#79716b]">…</span>}
            {totalPages > 5 && (
              <a href={`/es/blog/page/${totalPages}/`} class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] font-mono text-[13px] font-semibold text-[#79716b] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">{totalPages}</a>
            )}
            <a href="/es/blog/page/2/" class="ml-1 inline-flex items-center gap-1.5 rounded-lg border border-[#e7e5e4] px-4 py-2 font-mono text-[12px] font-semibold text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              Siguiente
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </nav>
        )}
      </div>
    </section>

    <!-- FREE TOOLS -->
    <section class="border-t border-b border-[#e7e5e4] bg-white py-10">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Herramientas SEO Gratuitas</p>
            <h2 class="mt-1 font-sans text-[20px] font-bold text-[#111827]">Audita y optimiza. Gratis</h2>
          </div>
          <a href="/es/herramientas/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6] transition-opacity hover:opacity-70">
            Ver todas →
          </a>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
          {tools.map(tool => (
            <a
              href={tool.href}
              class="group flex flex-col items-center gap-2.5 rounded-xl border border-[#e7e5e4] bg-white p-4 text-center transition-all hover:border-[#c4b5fd] hover:shadow-sm"
            >
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#f5f3ff] transition-colors group-hover:bg-[#ede9fe]" set:html={tool.svg}></div>
              <span class="font-sans text-[12px] font-semibold leading-[1.3] text-[#292524] transition-colors group-hover:text-[#4f39f6]">{tool.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FOOTER CTA -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
