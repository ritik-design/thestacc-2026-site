          ],
          footer: 'tu sitio: enterrado',
        },
        {
          q: 'asesoría top valorada para autónomos',
          rows: [
            { domain: 'asesoriaprecisa.com',   title: 'Asesoría para Autónomos. Top Valorada en [Ciudad]', snip: '47 reseñas de cinco estrellas. Gestoría online. Consulta gratis.', pos: 1,    yours: false },
            { domain: 'numerosclaros.com',     title: 'Asesoría para Autónomos ,  [Ciudad]',                snip: 'Especializada en pymes y servicios. Reserva ahora.',                pos: 2,    yours: false },
            { domain: 'tunegocio.com',         title: 'Nuestros Servicios de Asesoría',                     snip: 'Contáctanos para conocer nuestros servicios de asesoría.',          pos: 'p.3', yours: true  },
          ],
          footer: 'tu sitio: página 3',
        },
      ];

      let idx = 0;
      const resultsEl = document.getElementById('serp-results');
      const queryEl   = document.getElementById('serp-query');
      const footerEl  = document.getElementById('serp-footer-status');

      function render(data: typeof QUERIES[number]) {
        if (!resultsEl) return;
        resultsEl.innerHTML = '';
        data.rows.forEach((r) => {
          const isFirst = r.pos === 1;
          const wrap = document.createElement('div');
          wrap.style.cssText = [
            'display:flex;align-items:flex-start;gap:12px;padding:12px 16px;border-bottom:1px solid #f9fafb;',
            r.yours  ? 'background:#fff1f2;' : '',
            isFirst  ? 'background:#fefce8;' : '',
          ].join('');

          const rankBg    = isFirst ? 'background:#4f39f6;color:white;'  : r.pos === 2 ? 'background:#e5e7eb;color:#374151;' : 'background:#fff1f2;color:#ef4444;';
          const domainClr = isFirst ? '#10b981' : r.yours ? '#ef4444' : '#6b7280';
          const deltaText = isFirst ? '↑ #1' : r.pos === 2 ? '→ #2' : `↓ ${r.pos}`;
          const deltaBg   = isFirst ? 'background:#dcfce7;color:#166534;' : r.pos === 2 ? 'background:#f3f4f6;color:#6b7280;' : 'background:#fff1f2;color:#be123c;';

          wrap.innerHTML = `
            <div style="flex-shrink:0;width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-family:monospace;font-size:11px;font-weight:800;margin-top:2px;${rankBg}">${r.pos}</div>
            <div style="flex:1;min-width:0;">
              <p style="font-family:monospace;font-size:10px;color:${domainClr};margin-bottom:2px;">${r.domain}${r.yours ? ' ← tú' : ''}</p>
              <p style="font-size:14px;color:#1a0dab;margin-bottom:3px;line-height:1.3;">${r.title}</p>
              <p style="font-size:11px;color:#4d5156;line-height:1.45;">${r.snip}</p>
            </div>
            <div style="flex-shrink:0;align-self:center;padding:2px 8px;font-family:monospace;font-size:10px;font-weight:700;${deltaBg}">${deltaText}</div>
          `;
          resultsEl.appendChild(wrap);
        });
        if (footerEl) footerEl.textContent = data.footer;
      }

      function cycle() {
        if (!resultsEl || !queryEl) return;
        resultsEl.style.cssText += 'opacity:0;transition:opacity .25s;';
        queryEl.style.cssText   += 'opacity:0;transition:opacity .25s;';
        setTimeout(() => {
          const data = QUERIES[idx % QUERIES.length];
          if (queryEl) queryEl.textContent = data.q;
          render(data);
          resultsEl.style.opacity = '1';
          if (queryEl) queryEl.style.opacity = '1';
          idx++;
        }, 280);
      }

      render(QUERIES[0]);
      idx = 1;
      setInterval(cycle, 3800);
    })();
  </script>

