        { score:85, type:'tile-queue',   scoreColor:'#9ca3af', label:'COLA',   labelColor:'#9ca3af', title:'La guía completa de [servicio]' },
      ];

      const grid    = document.getElementById('article-grid');
      const countEl = document.getElementById('grid-count');
      if (!grid) return;

      TILES.forEach((t) => {
        const el = document.createElement('div');
        el.className = `article-tile ${t.type}`;
        el.innerHTML = `
          <span style="font-family:monospace;font-size:11px;font-weight:800;line-height:1;color:${t.scoreColor}">${t.score}</span>
          <span style="font-family:monospace;font-size:7px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;line-height:1;color:${t.labelColor}">${t.label}</span>
          <div class="tile-tooltip">${t.title}</div>
        `;
        grid.appendChild(el);
      });

      let cascadeTimer: ReturnType<typeof setTimeout> | null = null;

      function animateIn(delay = 0) {
        const tiles = grid.querySelectorAll('.article-tile');
        let count = 0;
        tiles.forEach((tile, i) => {
          setTimeout(() => {
            tile.classList.add('tile-visible');
            count++;
            if (countEl) countEl.textContent = count + ' artículos en cola';
          }, delay + i * 72);
        });
      }

      function resetAndAnimate() {
        if (cascadeTimer) clearTimeout(cascadeTimer);
        const tiles = grid.querySelectorAll<HTMLElement>('.article-tile');
        tiles.forEach((t) => {
          t.style.transition = 'none';
          t.classList.remove('tile-visible');
        });
        grid.getBoundingClientRect();
        tiles.forEach((t) => { t.style.transition = ''; });
        if (countEl) countEl.textContent = '0 artículos en cola';
        cascadeTimer = setTimeout(() => animateIn(0), 80);
      }

      // Month tab switching
      document.querySelectorAll<HTMLElement>('.grid-month-tab').forEach((tab) => {
        tab.addEventListener('click', () => {
          document.querySelectorAll<HTMLElement>('.grid-month-tab').forEach((t) => {
            t.style.color = '#374151';
            t.style.borderBottomColor = 'transparent';
          });
          tab.style.color = '#818cf8';
          tab.style.borderBottomColor = '#4f39f6';
          resetAndAnimate();
        });
      });

      // Scroll-triggered first run
      const obs = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) { obs.disconnect(); animateIn(300); }
        },
        { threshold: 0.2 }
      );
      obs.observe(grid);
    })();
  </script>

  <!-- Count-up animation -->
  <script>
    (function () {
      const els = document.querySelectorAll<HTMLElement>('[data-count-up]');
      if (!els.length) return;

      function animate(el: HTMLElement) {
        const target = parseFloat(el.dataset.target || '0');
        const from = parseFloat(el.dataset.from || '0');
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        const decimals = parseInt(el.dataset.decimals || '0', 10);
        const duration = 1400;
        const start = performance.now();

        function step(now: number) {
          const t = Math.min(1, (now - start) / duration);
          const eased = 1 - Math.pow(1 - t, 3);
          const v = from + (target - from) * eased;
          el.textContent = prefix + v.toFixed(decimals) + suffix;
          if (t < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              animate(e.target as HTMLElement);
              obs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.4 }
      );
      els.forEach((el) => obs.observe(el));
    })();
  </script>
</BaseLayout>
