const homepageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL, width: 512, height: 512 },
      description: 'Plataforma de automatización SEO con IA que publica 30 artículos al mes, gestiona Google Business Profiles y automatiza las redes sociales para negocios locales.',
