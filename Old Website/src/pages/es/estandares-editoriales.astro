---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { SITE_URL, buildBreadcrumbs, organizationSchema } from '../../utils/schema';

const editorialSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `https://thestacc.com/es/estandares-editoriales/`,
      name: 'Estándares Editoriales | theStacc',
      url: `https://thestacc.com/es/estandares-editoriales/`,
      inLanguage: 'es',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://thestacc.com/es/' },
        { '@type': 'ListItem', position: 2, name: 'Estándares Editoriales', item: 'https://thestacc.com/es/estandares-editoriales/' },
      ],
    },
    organizationSchema,
  ],
};

const standards = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: 'Cómo Creamos Contenido',
    body: 'Cada artículo en theStacc se planifica en torno a la investigación de palabras clave y el análisis de la intención de búsqueda. Identificamos temas donde las empresas necesitan orientación clara y práctica, y luego creamos contenido exhaustivo que responde al alcance completo de la consulta.',
    detail: 'Nuestro contenido utiliza flujos de trabajo asistidos por IA para la investigación y el borrador inicial. Cada pieza es revisada, editada y verificada por nuestro equipo editorial antes de la publicación. Usamos la IA como herramienta para aumentar la producción, no como sustituta del juicio editorial.',
    note: `Todo el contenido se atribuye a <a href="/es/autor/siddharth-gangal/" class="text-[#4f39f6] hover:underline">Siddharth Gangal</a>, fundador de theStacc, quien supervisa la dirección editorial y la revisión final.`,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
    title: 'Proceso de Verificación de Hechos',
    body: 'Las estadísticas, los datos de precios, las afirmaciones sobre funciones y la información de productos referenciada en nuestro contenido se verifican con fuentes primarias antes de la publicación. Enlazamos directamente a la fuente siempre que sea posible.',
    checks: [
      'Datos de precios verificados en las páginas de precios oficiales de cada producto',
      'Estadísticas obtenidas de estudios identificados, informes del sector o datos oficiales de empresas',
      'Comparaciones de funciones basadas en documentación pública disponible y pruebas directas',
      'Fechas de publicación y última actualización mostradas en todos los artículos',
    ],
    note: `Si encuentras un error en alguno de nuestros contenidos, <a href="/es/contacto/" class="text-[#4f39f6] hover:underline">contáctanos</a> y lo corregiremos de inmediato.`,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: 'Divulgación de Reseñas y Comparativas',
    body: 'theStacc es un producto comercial que compite con varias herramientas que reseñamos y comparamos. Lo revelamos claramente en cada página de reseña y alternativas.',
    quote: 'Esta reseña fue escrita y publicada por Stacc, un producto competidor. Tenemos un interés comercial como alternativa. Todos los datos de precios y funciones han sido verificados con fuentes públicas.',
    detail: 'No aceptamos pago de ninguna empresa a cambio de reseñas favorables. Nuestras valoraciones reflejan una evaluación editorial genuina. Probamos los productos de primera mano donde es posible y contrastamos con reseñas de usuarios públicamente disponibles en plataformas como G2, Capterra y TrustRadius.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: 'Actualidad y Actualizaciones del Contenido',
    body: 'El SEO y la tecnología de marketing evolucionan rápidamente. Mantenemos nuestro contenido a través de un proceso de actualización sistemático.',
    checks: [
      'Fechas de publicación y última actualización mostradas en todos los artículos',
      'Revisiones trimestrales de datos de precios y funciones en reseñas de software',
      'Contenido estadístico actualizado cuando hay nuevos datos disponibles',
      'Contenido desactualizado eliminado o redirigido cuando ya no es preciso o relevante',
    ],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    title: 'Estándares del Glosario',
    body: `Nuestro <a href="/es/glosario/" class="text-[#4f39f6] hover:underline">glosario de más de 690 términos</a> sigue un formato consistente: una definición concisa, explicación contextual, relevancia práctica y términos relacionados. Las definiciones están redactadas para ser precisas, accesibles y útiles tanto para principiantes como para profesionales del marketing con experiencia.`,
  },
];
---

<BaseLayout
  title="Estándares Editoriales | theStacc"
  description="Cómo theStacc crea, revisa y publica contenido. Nuestro proceso editorial, metodología de verificación de hechos, política de divulgación de reseñas y estándares de calidad de contenido."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(editorialSchema)} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ░░ DARK HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Estándares Editoriales</p>
        <h1 class="mx-auto mt-4 max-w-[600px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[44px]">
          Cómo creamos y respaldamos nuestro contenido.
        </h1>
        <p class="mx-auto mt-4 max-w-[500px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          theStacc publica guías de SEO, reseñas de software, comparativas de herramientas y contenido del sector. Así es como creamos, verificamos y mantenemos ese contenido.
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {[
            'Sin colocaciones pagadas',
            'Precios verificados trimestralmente',
            'Divulgación en cada reseña',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ SECCIONES DE ESTÁNDARES ░░ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mx-auto max-w-[760px] space-y-5">

          {standards.map(s => (
            <div class="overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
              <div class="flex items-center gap-3 border-b border-[#f5f5f4] px-6 py-4">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#f5f3ff]" set:html={s.icon}></div>
                <h2 class="font-sans text-[16px] font-bold text-[#292524]">{s.title}</h2>
              </div>
              <div class="px-6 py-5 space-y-4">
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]" set:html={s.body}></p>
                {s.detail && <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{s.detail}</p>}
                {s.quote && (
                  <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-5 py-4" style="border-left: 3px solid #4f39f6;">
                    <p class="font-sans text-[13px] leading-[1.7] text-[#57534e] italic">"{s.quote}"</p>
                  </div>
                )}
                {s.checks && (
                  <ul class="space-y-2">
                    {s.checks.map(c => (
                      <li class="flex items-start gap-2.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">
                        <svg class="mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        {c}
                      </li>
                    ))}
                  </ul>
                )}
                {s.note && <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]" set:html={s.note}></p>}
              </div>
            </div>
          ))}

          <!-- Preguntas o correcciones -->
          <div class="rounded-2xl border border-[#4f39f6] p-6 text-center" style="background:linear-gradient(135deg,#f5f3ff 0%,#fafaf9 100%);">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Preguntas o correcciones</p>
            <p class="mt-2 font-sans text-[15px] font-semibold text-[#292524]">¿Has encontrado un error? Queremos saberlo.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.7] text-[#57534e]">
              Si detectas un precio desactualizado, una afirmación sobre funciones incorrecta o algo que no cuadra, escríbenos a <a href="/es/contacto/" class="text-[#4f39f6] hover:underline">thestacc.com/es/contacto</a>. Corregimos los problemas en menos de 48 horas.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ░░ DARK FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Contenido creado para generar confianza.
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Los mismos estándares que nos aplicamos a nosotros mismos están integrados en cada artículo que theStacc publica para tu negocio.
        </p>
        <a href="/es/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Empieza tu prueba por 1 $
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">1 $ durante 30 días · Cancela cuando quieras</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
