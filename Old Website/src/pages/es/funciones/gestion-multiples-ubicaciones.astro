---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Cuántas ubicaciones puedo gestionar a la vez?",
    a: "No existe un límite práctico. Stacc está construido para gestionar carteras a escala empresarial — los clientes gestionan 500+ ubicaciones desde una sola cuenta. Las operaciones masivas funcionan igual con 10 ubicaciones que con 500.",
  },
  {
    q: "¿Qué puedo actualizar en masa en todas las ubicaciones?",
    a: "Horarios comerciales, horarios festivos, números de teléfono, direcciones, URLs de sitio web, descripciones del negocio y categorías. Para Google Business Profile específicamente: también puedes actualizar atributos, menús de servicios e imágenes de portada en todas las ubicaciones simultáneamente.",
  },
  {
    q: "¿Cuánto tiempo se tarda en añadir una nueva ubicación?",
    a: "Aproximadamente 2 minutos. Introduces la información básica del negocio una vez, conectas el perfil GBP y otras plataformas, y Stacc propaga la configuración automáticamente por tu red de citaciones. No hay entrada manual directorio por directorio.",
  },
  {
    q: "¿Puedo hacer diferentes actualizaciones a diferentes subconjuntos de ubicaciones?",
    a: "Sí. Puedes agrupar ubicaciones por región, marca, propietario de franquicia o cualquier etiqueta personalizada. Las actualizaciones masivas pueden aplicarse a toda la cartera, a un grupo específico o a ubicaciones individuales seleccionadas. Tienes control completo sobre el alcance.",
  },
  {
    q: "¿Qué ocurre si una ubicación tiene una dirección o teléfono únicos?",
    a: "Las actualizaciones masivas gestionan los campos compartidos. Para campos específicos de ubicación como dirección o teléfono directo, Stacc mantiene los datos únicos de cada sede y no los sobreescribe con una actualización masiva a menos que lo elijas explícitamente. Los datos compartidos se actualizan en masa; los únicos permanecen únicos.",
  },
  {
    q: "¿Puedo usar importación CSV para añadir o actualizar ubicaciones en masa?",
    a: "Sí. Stacc admite importación CSV para creación y actualización masiva de ubicaciones. Sube una hoja de cálculo con tus datos de ubicación y Stacc mapea los campos automáticamente. Útil para la configuración inicial de grandes carteras o la sincronización periódica de datos desde tus propios sistemas.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Gestión Masiva de Ubicaciones",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Actualiza cientos de ubicaciones simultáneamente. Cambia horarios, direcciones, descripciones y categorías en toda tu cartera en minutos — no en días.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Funciones", "item": "https://thestacc.com/es/funciones/" },
        { "@type": "ListItem", "position": 3, "name": "Gestión de Múltiples Ubicaciones", "item": "https://thestacc.com/es/funciones/gestion-multiples-ubicaciones/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Gestión Masiva de Ubicaciones — Actualiza 500+ Sedes en Minutos | theStacc"
  description="Deja de actualizar ubicaciones una a una. La gestión masiva de Stacc te permite cambiar horarios, direcciones e información en toda tu cartera con una sola acción."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Gestión Masiva de Ubicaciones · Módulo SEO Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Cambiar el horario en 50 ubicaciones<br />
            <span style="color:#4f39f6;">debería llevar 2 minutos, no 2 días.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc te permite actualizar horarios, direcciones, descripciones y más en todas tus ubicaciones con una sola acción. Gestiona toda la cartera desde un panel centralizado — sin entrar en cada GBP por separado.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver precios
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mes · Prueba gratuita 14 días · Sin tarjeta de crédito
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '500+', label: 'Ubicaciones actualizables en 1 acción' },
              { value: '2 min', label: 'Para añadir una nueva ubicación' },
              { value: 'CSV', label: 'Importación masiva para configuración inicial' },
              { value: '4.9★', label: 'Valoración media de Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada cambio de datos multiplica tu trabajo<br />por el número de ubicaciones.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Cambias de teléfono en tu sede central. Ahora tienes que actualizar GBP para cada una de las 30 ubicaciones. Y Yelp. Y Apple Maps. Y Bing Places. Y todos los directorios sectoriales. Un cambio de dato de 30 segundos se convierte en un proyecto de dos días porque el sistema está diseñado para que lo hagas uno a uno. Eso no es gestión — es trabajo de entrada de datos que no debería existir.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Los cambios de horario consumen tardes enteras.',
              body: 'Semana Santa. Vacaciones de verano. Un nuevo horario extendido para toda la cadena. Cada cambio de horarios en GBP requiere entrar en cada perfil por separado. En 30 ubicaciones, son 30 inicios de sesión, 30 actualizaciones, y entre 2 y 4 horas de trabajo para un dato que debería cambiar en segundos.',
            },
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Algunos perfiles siempre se quedan sin actualizar.',
              body: 'Cuando actualizar es tan tedioso, inevitablemente algunas ubicaciones se saltan. El horario de Navidad sigue apareciendo en febrero. La dirección antigua de la sede que se mudó hace seis meses todavía está en tres directorios. Esos errores los ven los clientes — y Google también.',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Añadir nuevas ubicaciones tarda demasiado.',
              body: 'Abres una nueva sede. Tienes que crear el perfil GBP, verificarlo, rellenar toda la información, publicarlo en todos los directorios relevantes... uno a uno. En la mayoría de negocios, una nueva ubicación tarda días en estar completamente configurada. Con Stacc, 2 minutos.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Todo incluido</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Gestión masiva de ubicaciones sin<br />trabajo manual repetitivo.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Actualización Masiva de Horarios', body: 'Cambia horarios comerciales y festivos en todas las ubicaciones simultáneamente. Define horarios especiales por temporada y aplícalos a toda la cartera en un clic.', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { title: 'Edición Masiva de Datos', body: 'Actualiza teléfonos, direcciones, URLs de sitio web, descripciones del negocio y categorías en grupos de ubicaciones o en toda la cartera con una sola acción.', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
            { title: 'Grupos de Ubicaciones', body: 'Organiza ubicaciones por región, marca, franquiciado o cualquier etiqueta personalizada. Aplica actualizaciones a grupos específicos sin afectar al resto de la cartera.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
            { title: 'Importación CSV', body: 'Importa datos de ubicaciones en masa desde una hoja de cálculo. Útil para el setup inicial de carteras grandes o para sincronización periódica desde tus sistemas internos.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
            { title: 'Sincronización con Directorios', body: 'Cada cambio de datos en Stacc se propaga automáticamente a 50+ directorios para las ubicaciones afectadas — Google, Apple Maps, Yelp y todos los demás. Un cambio, propagación completa.', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
            { title: 'Control de Acceso por Rol', body: 'Asigna permisos granulares por ubicación o grupo. Un gerente regional ve y edita solo sus sedes. Tu equipo central gestiona toda la cartera. Sin accesos indeseados ni cambios accidentales.', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que recuperas cuando dejas de<br />actualizar ubicaciones una a una.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '2 min', label: 'Para añadir una nueva ubicación', sub: 'vs. horas de configuración manual' },
            { value: '8hrs', label: 'Ahorradas por semana por operador', sub: 'previamente en actualizaciones manuales' },
            { value: '500+', label: 'Ubicaciones actualizables en 1 acción', sub: 'sin límite máximo de cartera' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Tenemos 65 tiendas y antes de Stacc, actualizar los horarios de Navidad era el proyecto que todos temíamos en diciembre. Dos personas pasaban tres días enteros actualizando perfiles uno a uno. El año pasado con Stacc lo hicimos en 20 minutos. Actualicé las 65 tiendas en GBP, Facebook y todos los directorios desde un solo panel. Todavía no me lo creo."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">BT</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Beatriz T.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Responsable de Operaciones · Cadena de tiendas de moda, 65 sedes</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">3 días de trabajo → 20 minutos</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre gestión masiva de ubicaciones
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Deja de actualizar ubicaciones una a una</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Tu tiempo es demasiado valioso para<br />gastar horas en entrada de datos.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Cada hora actualizando perfiles uno a uno es una hora que no estás generando resultados. Stacc convierte tareas de días en acciones de minutos para que tu equipo se dedique al trabajo que realmente mueve el negocio. Empieza tu prueba gratuita hoy.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Gestiona todas tus ubicaciones
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
