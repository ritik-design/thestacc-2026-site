---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿A qué plataformas puedo programar publicaciones?",
    a: "Stacc permite publicar en Google Business Profile, páginas de Facebook Business y cuentas de Instagram Business. Los posts pueden publicarse en una plataforma o en las tres simultáneamente desde un único flujo de trabajo.",
  },
  {
    q: "¿Puedo publicar el mismo post en múltiples ubicaciones a la vez?",
    a: "Sí. La publicación masiva es una función central. Escribe un post y selecciona múltiples ubicaciones — Stacc publica en todos los perfiles de ubicación seleccionados simultáneamente. Para 20 ubicaciones, es una acción en vez de 20.",
  },
  {
    q: "¿Puedo añadir detalles específicos por ubicación a los posts masivos?",
    a: "Sí. Antes de publicar masivamente, puedes añadir ajustes específicos por ubicación — diferentes direcciones, diferentes teléfonos en el cuerpo del post, hashtags específicos por ubicación. El contenido principal del post se mantiene consistente; los detalles locales se personalizan por cuenta.",
  },
  {
    q: "¿Publicar en GBP mejora realmente mi posición en Google Maps?",
    a: "Sí. La actividad en Google Business Profile — incluyendo publicaciones regulares — es una señal de ranking local documentada. Los negocios que publican de forma consistente en GBP mejoran su visibilidad en el paquete local respecto a perfiles inactivos. La automatización de publicaciones en GBP de Stacc está diseñada específicamente para mantener tu perfil activo con la frecuencia que influye en los rankings.",
  },
  {
    q: "¿Puedo programar publicaciones con semanas o meses de antelación?",
    a: "Sí. El calendario de contenido te permite planificar y programar posts con toda la antelación que necesites. También puedes establecer un calendario de publicación recurrente y Stacc publicará en tu cadencia elegida automáticamente — diaria, semanal o con un horario personalizado.",
  },
  {
    q: "¿Qué pasa con un post programado si una cuenta se desconecta?",
    a: "Stacc señala la cuenta desconectada inmediatamente y pone el post en cola en lugar de fallar silenciosamente. Recibes una alerta para reconectar la cuenta, y el post en cola puede publicarse una vez restaurada la conexión.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Programación de Redes Sociales",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Programa publicaciones en Google Business Profile, Facebook e Instagram en todas tus ubicaciones simultáneamente. Un post, publicado en todas partes, automáticamente.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Funciones", "item": "https://thestacc.com/es/funciones/" },
        { "@type": "ListItem", "position": 3, "name": "Programación Social", "item": "https://thestacc.com/es/funciones/programacion-social/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Programación de Redes Sociales para Negocios Locales — Publica en Todas tus Ubicaciones | theStacc"
  description="Programa publicaciones en todas tus ubicaciones en minutos. theStacc publica en Google Business Profile, Facebook e Instagram simultáneamente — con personalización por ubicación."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Programación Social · Módulo SEO Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Publica en todas tus ubicaciones<br />
            <span style="color:#4f39f6;">a la vez. No una a una.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc publica en Google Business Profile, Facebook e Instagram en todas tus ubicaciones simultáneamente. Escribe una vez, selecciona todas, programa — cada ubicación permanece activa sin copiar, pegar ni iniciar sesión 20 veces.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver precios
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mes · Prueba gratuita 14 días · Sin tarjeta de crédito
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '3 plat.', label: 'GBP, Facebook e Instagram en un flujo' },
              { value: '500+', label: 'Ubicaciones publicables en 1 clic' },
              { value: '8 seg.', label: 'Para publicar en 47 ubicaciones simultáneas' },
              { value: '4.9★', label: 'Valoración media de Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tus perfiles en Google llevan tres meses<br />sin una sola publicación.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sabes que deberías publicar en Google Business Profile regularmente. Sabes que afecta al ranking. Pero entre gestionar las ubicaciones, responder reseñas y servir a tus clientes, termina siendo lo que se pospone cada semana. Y mientras tanto, tu competidor — el que publica dos veces por semana — aparece en el paquete de mapas cuando tus clientes buscan exactamente lo que tú ofreces.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Publicar en cada perfil por separado consume horas.',
              body: 'Para una sola campaña en 10 ubicaciones: inicia sesión en GBP ubicación 1, publica, sale, entra en ubicación 2, publica, sale... 10 inicios de sesión, 10 publicaciones, 45 minutos de trabajo para un post que debería llevar 3 minutos. Y eso es solo Google — ni Facebook ni Instagram.',
            },
            {
              icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
              title: 'Los perfiles inactivos penalizan en ranking.',
              body: 'Google premia la actividad. Un perfil GBP con posts regulares gana señales de ranking que uno inactivo no tiene. Cada semana que pasa sin publicar es una semana en que tu competidor activo gana ventaja en el paquete de mapas. La inactividad tiene un coste invisible que se acumula.',
            },
            {
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              title: 'La consistencia es imposible sin un sistema.',
              body: 'Algunas ubicaciones publican, otras no. Algunas tienen contenido de calidad, otras tienen el mínimo. Sin un sistema centralizado, la consistencia — que es exactamente lo que Google y los clientes valoran — es imposible de mantener cuando tienes más de 3 ubicaciones.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Escribe una vez.<br />Publica en todas partes automáticamente.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1', title: 'Conecta tus perfiles y páginas', body: 'Vincula tus perfiles de Google Business, páginas de Facebook e Instagram Business. Para múltiples ubicaciones, conecta todas las cuentas a la vez. Configuración en menos de 10 minutos, sin necesidad de programador.' },
            { n: '02', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Escribe tu post y selecciona ubicaciones', body: 'Crea tu contenido una sola vez. Selecciona las ubicaciones en las que quieres publicar — todas, un grupo regional o ubicaciones específicas. Añade personalizaciones por ubicación si las necesitas. Un flujo, cero repetición.' },
            { n: '03', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Publica ahora o programa con antelación', body: 'Publica inmediatamente o programa para cualquier fecha y hora. Establece calendarios de publicación recurrentes y Stacc publicará automáticamente en tu cadencia elegida. Tu contenido siempre en hora, sin recordatorios manuales.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── MOCK UI + DEEP DIVE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl">
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Publicación Masiva · Campaña de Verano</p>
              <div class="rounded-xl bg-[#fafaf9] p-4 mb-4">
                <p class="font-sans text-[13px] text-[#374151]">"¡Horario especial de verano! Abiertos de 9h a 22h de lunes a domingo. ¡Te esperamos!"</p>
              </div>
              <div class="space-y-2 mb-5">
                {[
                  { ch: 'Google Business Profile', locs: '47 ubicaciones' },
                  { ch: 'Facebook Business Pages', locs: '47 ubicaciones' },
                  { ch: 'Instagram Business', locs: '47 ubicaciones' },
                ].map(row => (
                  <div class="flex items-center gap-3 rounded-lg border border-[#e7e5e4] px-3 py-2">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[12px] text-[#374151] flex-1">{row.ch}</span>
                    <span class="font-mono text-[10px] text-[#059669]">{row.locs}</span>
                  </div>
                ))}
              </div>
              <button class="w-full rounded-xl bg-[#4f39f6] py-3 font-sans text-[13px] font-semibold text-white">Publicar en las 47 ubicaciones</button>
              <p class="mt-3 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">141 publicaciones · Tiempo estimado: 8 segundos</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publicación Masiva con Personalización</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Un post. Publicado en todas tus ubicaciones. Con los detalles locales correctos.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Las plantillas dinámicas de Stacc personalizan cada publicación con el nombre de la ubicación, la ciudad, la dirección o los datos de contacto locales — automáticamente. Publicas una campaña y cada perfil recibe una versión personalizada para su mercado local. Presencia local auténtica, a escala.
              </p>
              <ul class="mt-6 space-y-3">
                {['Publica en GBP, Facebook e Instagram en un solo flujo', 'Plantillas dinámicas auto-personalizan el contenido por ubicación', 'Programa con semanas de antelación en todas las ubicaciones', 'Actualiza horarios, descripciones y fichas de servicios en masa'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Qué consiguen los negocios que<br />publican de forma consistente.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '3×', label: 'Más actividad GBP', sub: 'comparado con publicación manual' },
            { value: '45min', label: 'Ahorrados por campaña', sub: 'en negocios con 10+ ubicaciones' },
            { value: '100%', label: 'Consistencia de publicación', sub: 'todas las ubicaciones, todas las semanas' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Gestionamos 23 tiendas y antes de Stacc publicar en GBP era algo que 'intentábamos hacer'. Ahora cada tienda tiene posts semanales en Google, Facebook e Instagram — y ni siquiera pienso en ello. Lo configuré una vez, establecí el calendario y Stacc lo gestiona. En 90 días subimos del puesto 6 al puesto 2 en el paquete de mapas en 17 de nuestras ubicaciones."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">MG</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Miguel G.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Director de Marketing · Cadena retail, 23 tiendas</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">Top 2 en Maps en 17 ubicaciones</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre programación de redes sociales
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Deja de publicar una ubicación a la vez</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Cada semana sin publicar en GBP<br />es una semana que tu competidor gana.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            La publicación consistente en Google Business Profile es una de las señales de ranking local más directas que puedes controlar. No requiere más presupuesto ni más equipo — solo un sistema. Stacc es ese sistema. Empieza tu prueba gratuita hoy.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Empieza a publicar en todas las ubicaciones
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Ver planes
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Prueba gratuita 14 días · Sin tarjeta de crédito · Cancela cuando quieras</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
