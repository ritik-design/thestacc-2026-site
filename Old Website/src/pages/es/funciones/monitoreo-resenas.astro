---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué plataformas de reseñas monitorea Stacc?",
    a: "Stacc monitorea Google Business Profile, Facebook y Yelp — las tres plataformas con más peso para el SEO local y las decisiones de los clientes. Todas las reseñas de estas plataformas se agregan en un único panel. Las nuevas reseñas generan alertas instantáneas independientemente de la plataforma donde aparezcan.",
  },
  {
    q: "¿Qué tan rápido me alerta Stacc cuando llega una nueva reseña?",
    a: "Stacc comprueba nuevas reseñas de forma continua durante el día. En el momento en que se detecta una nueva reseña en cualquier plataforma, recibes una alerta — por email, en la app, o ambas según tu configuración de notificaciones. Para agencias que gestionan múltiples clientes, las alertas van etiquetadas por cliente para que sepas inmediatamente qué ubicación y qué cliente necesita atención.",
  },
  {
    q: "¿El tiempo de respuesta afecta realmente al posicionamiento en SEO local?",
    a: "Sí. Google usa el engagement con las reseñas como señal de ranking local. Los negocios que responden reseñas — especialmente de forma rápida — le indican a Google que están activos, comprometidos y que se preocupan por sus clientes. No responder es una señal perdida. Además, responder rápido a las reseñas negativas evita que el daño se amplifique con clientes que escalan sus quejas al sentirse ignorados.",
  },
  {
    q: "¿Cómo gestiono las reseñas negativas?",
    a: "Stacc no elimina reseñas negativas — ninguna herramienta puede hacer eso de forma ética. Lo que hace Stacc es asegurarte de que nunca pierdas una reseña negativa (alertas instantáneas), darte plantillas de respuesta calibradas para el control de daños, y hacer seguimiento de cómo evoluciona tu puntuación media para que veas el impacto de tu estrategia de respuesta. Las respuestas profesionales y consistentes a reseñas negativas a menudo convierten mejor que una media perfecta de 5 estrellas.",
  },
  {
    q: "¿Puedo gestionar reseñas de múltiples ubicaciones desde un solo panel?",
    a: "Sí. Todas las ubicaciones se agregan en un único panel de reseñas. Puedes filtrar por ubicación, plataforma, puntuación de estrellas o rango de fechas. Si gestionas 20 ubicaciones, no estás iniciando sesión en 20 cuentas de GBP diferentes — todo llega a través de Stacc. Los planes de agencia permiten gestionar reseñas de múltiples clientes desde la misma interfaz.",
  },
  {
    q: "¿Qué muestra el análisis de sentimiento?",
    a: "El análisis de sentimiento lee el texto de cada reseña para identificar temas recurrentes — qué alaban los clientes, de qué se quejan y cómo evoluciona el sentimiento con el tiempo. Si tres nuevas reseñas de 3 estrellas mencionan 'tiempo de espera largo', ese es un patrón que Stacc detecta para que puedas abordarlo antes de que se convierta en un problema de reputación sistemático.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Monitoreo de Reseñas",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Monitorea reseñas en Google, Facebook y Yelp desde un solo panel. Alertas instantáneas con cada nueva reseña. Responde más rápido. Protege tu reputación automáticamente.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Funciones", "item": "https://thestacc.com/es/funciones/" },
        { "@type": "ListItem", "position": 3, "name": "Monitoreo de Reseñas", "item": "https://thestacc.com/es/funciones/monitoreo-resenas/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Monitoreo de Reseñas Online — Controla y Responde Cada Reseña desde un Panel | theStacc"
  description="Monitorea reseñas en Google, Facebook y Yelp desde un solo panel. Alertas instantáneas con cada nueva reseña. Responde más rápido y protege tu reputación automáticamente."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Monitoreo de Reseñas · Módulo SEO Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Acaba de aparecer una reseña de 1 estrella.<br />
            <span style="color:#4f39f6;">No te enterarás hasta la semana que viene.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc monitorea cada reseña en Google, Facebook y Yelp desde un solo panel. Alertas instantáneas cuando llega una nueva. Plantillas de respuesta listas para usar. Tu reputación nunca vuelve a quedar sin gestionar.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Monitorea cada reseña
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver precios
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Prueba gratuita 14 días · Sin tarjeta de crédito · Todas las plataformas en una vista
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '4.2hrs', label: 'Ahorradas por semana en gestión de reseñas' },
              { value: '73%', label: 'Más rápido en tiempo de respuesta' },
              { value: '0.4★', label: 'Mejora media en puntuación de estrellas' },
              { value: '4.9★', label: 'Valoración media de Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Entrar en seis plataformas para revisar<br />reseñas no es una estrategia de reputación.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            El enfoque estándar: acuérdate de revisar Google, acuérdate de revisar Yelp, acuérdate de revisar Facebook, recuerda revisar las páginas de cada una de tus 15 ubicaciones de cliente. Cada semana. Sin fallar. Y cuando una reseña de 1 estrella aparece un martes por la tarde mientras estás en una reunión, permanece sin respuesta cinco días — siendo leída por cada cliente potencial que investiga ese negocio antes de decidir si llama o pasa de largo.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Te enteras de las malas reseñas cuando los clientes te lo dicen.',
              body: 'Una reseña de 1 estrella puede estar sin respuesta durante semanas. Cada persona que busca tu negocio durante ese período ve la queja sin atender como la última palabra. Pierdes clientes que nunca tuviste oportunidad de recuperar — porque no te enteraste a tiempo.',
            },
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'La revisión manual de reseñas consume tiempo no facturable.',
              body: 'En 10 clientes y 3 plataformas, revisar reseñas manualmente toma más de 4 horas semanales. Son 16+ horas al mes en una tarea que debería llevar cero minutos. Cada hora que pasas revisando es una hora que no estás moviendo posiciones.',
            },
            {
              icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
              title: 'Responder tarde le dice a Google que no te importa — y a tus clientes también.',
              body: 'Google premia a los negocios activos y que responden. Un negocio que responde reseñas en horas supera en señales de ranking local a uno que responde en semanas. Y el cliente que lee tus reseñas toma la decisión de llamar o no en 30 segundos — tu velocidad de respuesta forma parte de ese juicio.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conecta una vez. Cada reseña<br />llega a ti automáticamente.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1', title: 'Conecta tus plataformas de reseñas', body: 'Vincula tu Google Business Profile, páginas de Facebook y cuentas de Yelp. Para negocios multi-ubicación, conecta todas las sedes a la vez. La configuración lleva menos de 5 minutos sin necesidad de un desarrollador.' },
            { n: '02', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Alertas instantáneas con cada nueva reseña', body: 'En el momento en que aparece una nueva reseña en cualquier plataforma, recibes una notificación — con el texto de la reseña, puntuación, plataforma y ubicación. Sin revisiones manuales. Sin reseñas negativas sin respuesta.' },
            { n: '03', icon: 'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z', title: 'Responde desde el panel — en segundos', body: 'Las plantillas de respuesta están listas para cada tipo de reseña — agradecimiento a 5 estrellas, control de daños a 1 estrella, recuperación a 3 estrellas. Selecciona una plantilla, personalízala en 20 segundos y publica sin salir de Stacc.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Todo incluido</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Gestión completa de reseñas<br />sin cambiar de plataforma.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Agregación Multi-Plataforma', body: 'Reseñas de Google, Facebook y Yelp unificadas en una sola bandeja de entrada. Filtra por plataforma, ubicación, estrellas o fecha — todo en una vista.', icon: 'M4 6h16M4 10h16M4 14h16M4 18h16' },
            { title: 'Alertas de Nueva Reseña', body: 'Notificación en tiempo real en el momento en que se detecta una nueva reseña. Alertas por email y en la app, etiquetadas por cliente y ubicación.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Plantillas de Respuesta', body: 'Plantillas pre-construidas para cada escenario: agradecimiento a 5 estrellas, recuperación a 1 estrella, seguimiento a 3 estrellas. Personaliza en 20 segundos y publica sin salir de Stacc.', icon: 'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z' },
            { title: 'Análisis de Sentimiento', body: '¿Qué alaban tus clientes? ¿De qué se quejan? Stacc lee el texto de las reseñas para identificar temas recurrentes — positivos y negativos.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Tendencia de Puntuación', body: 'Sigue la evolución de la puntuación media por ubicación y plataforma. Detecta cuándo las valoraciones empiezan a bajar antes de que el daño se acumule.', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
            { title: 'Comparativa con Competidores', body: 'Ve cómo tu puntuación y volumen de reseñas se compara con los principales competidores locales. Sabe cuándo estás perdiendo terreno antes de que lo noten tus clientes.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Qué pasa cuando dejas de<br />perder reseñas.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '4.2hrs', label: 'Ahorradas por semana', sub: 'vs. revisión manual de plataformas' },
            { value: '73%', label: 'Más rápido en respuesta', sub: 'de días a horas de media' },
            { value: '0.4★', label: 'Mejora en puntuación', sub: 'media en ubicaciones tras 90 días' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Un cliente de restaurante recibió una reseña de 1 estrella un viernes por la noche que yo habría perdido hasta el lunes. Con Stacc vi la alerta en menos de una hora, respondí antes de las 10 de la noche, y el cliente la actualizó a 4 estrellas el sábado por la mañana. Eso es gestión de reputación que funciona de verdad — y solo funciona si te enteras a tiempo."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">AL</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Ana L.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Agencia de Marketing Digital · Clientes de restauración y hostelería</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">De 1 a 4 estrellas la misma tarde</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre monitoreo de reseñas
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Nunca vuelvas a perder una reseña.</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Responde cada reseña<br />antes de que te cueste un cliente.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Ahora mismo hay reseñas en Google, Yelp y Facebook que no has visto todavía. Algunas son victorias de 5 estrellas que deberías amplificar. Otras son problemas de 1 estrella que están alejando clientes activamente. Empieza tu prueba gratuita y vélo todo en un lugar — hoy.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Empieza a monitorear reseñas
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Comparar planes
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Prueba gratuita 14 días · Sin tarjeta de crédito · Cancela cuando quieras</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
