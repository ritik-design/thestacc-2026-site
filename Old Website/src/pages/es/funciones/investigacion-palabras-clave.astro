---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿En qué se diferencia esto del Planificador de Palabras Clave de Google?",
    a: "El Planificador de Palabras Clave de Google muestra volúmenes de búsqueda nacionales amplios — está diseñado para anuncios de pago, no para SEO local. Stacc identifica palabras clave por ciudad, barrio y área de servicio con puntuación de intención de búsqueda local. Encontrarás 'mejor fontanero en el centro de [ciudad]' antes que tu competidor. El Planificador de Google no te mostrará eso.",
  },
  {
    q: "¿Cómo funciona el mapeo de palabras clave por ubicación?",
    a: "Conectas tus ubicaciones y Stacc sugiere conjuntos de palabras clave para cada una en función del tipo de negocio, la ciudad y la densidad competitiva. Cada palabra clave se mapea a las ubicaciones donde tiene mayor volumen de búsqueda local. No estás adivinando qué términos importan en cada lugar — Stacc te lo dice.",
  },
  {
    q: "¿Puedo hacer investigación de palabras clave en múltiples ubicaciones a la vez?",
    a: "Sí. La investigación de palabras clave multi-ubicación es una función central. Stacc muestra oportunidades de palabras clave por ubicación, identifica palabras clave para las que rankean tus competidores y tú no, y te permite asignar clusters de palabras clave a grupos de ubicaciones en masa. Un flujo para 5 ubicaciones o 500.",
  },
  {
    q: "¿Qué significa 'puntuación de intención de búsqueda'?",
    a: "No todas las palabras clave locales tienen la misma intención. 'Fontanero cerca de mí' es una emergencia — alta intención, necesita respuesta rápida. '¿Cómo arreglar una tubería con goteras?' es informacional. Stacc puntúa las palabras clave por intención de compra para que sepas cuáles priorizar para Google Maps y el paquete local frente a contenido de blog.",
  },
  {
    q: "¿Puedo ver para qué palabras clave posicionan mis competidores?",
    a: "Sí. El análisis de brecha de palabras clave con competidores te muestra qué palabras clave tienen tus 3 principales competidores locales en las que tú no apareces en absoluto. Estas son tus oportunidades de victoria rápida — términos con demanda local comprobada donde actualmente no tienes presencia.",
  },
  {
    q: "¿Con qué frecuencia se actualizan los datos de palabras clave?",
    a: "Los datos de volumen de búsqueda local se actualizan mensualmente. Los datos de ranking de competidores se comprueban semanalmente para que captures nuevas oportunidades antes de que se vuelvan competitivas. Cuando aparece una nueva palabra clave en el análisis de brecha, recibes una alerta inmediatamente.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Investigación de Palabras Clave Locales",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Descubre las palabras clave exactas que buscan tus clientes locales. theStacc mapea palabras clave de alta intención local a cada ubicación para que posiciones en las búsquedas que generan visitas.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Funciones", "item": "https://thestacc.com/es/funciones/" },
        { "@type": "ListItem", "position": 3, "name": "Investigación de Palabras Clave", "item": "https://thestacc.com/es/funciones/investigacion-palabras-clave/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Investigación de Palabras Clave Locales — Encuentra los Términos que Ganan el Paquete Local | theStacc"
  description="Descubre las palabras clave exactas que buscan tus clientes locales. theStacc mapea palabras clave de alta intención a cada ubicación para que posiciones en las búsquedas que generan clientes."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Investigación de Palabras Clave · Módulo SEO Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Estás atacando palabras clave que tus<br />clientes locales
            <span style="color:#4f39f6;"> nunca buscan realmente.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc encuentra las palabras clave locales de alta intención vinculadas a cada ubicación — las que tienen volumen de búsqueda real, intención de compra clara y margen para posicionar. Deja de adivinar. Empieza con datos específicos de tu ciudad, tu servicio y tus clientes.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza gratis
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver precios
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mes · Prueba gratuita 14 días · Sin tarjeta de crédito
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'Local', label: 'Datos de búsqueda por ciudad y barrio' },
              { value: 'Alta', label: 'Intención de compra en cada sugerencia' },
              { value: 'Semanal', label: 'Actualización de datos de competidores' },
              { value: '500+', label: 'Ubicaciones analizables simultáneamente' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Las herramientas genéricas no ven<br />las búsquedas locales reales.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            El Planificador de Palabras Clave de Google te da volúmenes nacionales. SEMrush te da visibilidad orgánica general. Ninguna herramienta estándar te dice que en tu barrio la gente busca 'fontanero urgente 24 horas [nombre del barrio]' y no 'fontanero'. Esa diferencia — entre palabras clave genéricas y términos locales de alta intención — es la diferencia entre el puesto 12 y el Top 3 del paquete de mapas.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Atacas palabras clave que no convierten localmente.',
              body: 'Un volumen de búsqueda alto no significa clientes locales. Muchas búsquedas de alto volumen son nacionales, informacionales o de bajo interés de compra. Sin intención local explícita y datos geográficos, optimizas para tráfico que nunca entra por tu puerta.',
            },
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Tus competidores rankeando términos que tú ni conoces.',
              body: 'Mientras optimizas para términos genéricos, tu competidor del mismo barrio posiciona para "emergencia de fontanería [barrio]" y "fontanero sin cuota de visita". Términos que tú no estás atacando. Clientes que deberían ser tuyos eligiendo a otro.',
            },
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Sin datos locales, cada ubicación necesita investigación manual.',
              body: 'Lo que funciona en Madrid no funciona en Sevilla. Los términos de alta intención varían por ciudad, por barrio, incluso por estación. Sin una herramienta que mapee palabras clave a ubicaciones específicas, la investigación para cada sede es un proyecto separado que nunca terminas.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Cómo funciona</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Palabras clave de alta intención,<br />mapeadas a cada ubicación.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Conecta tus ubicaciones', body: 'Vincula cada ubicación con su mercado geográfico específico. Stacc identifica la ciudad, los barrios y el área de servicio de cada sede para contextualizar la búsqueda local correctamente.' },
            { n: '02', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', title: 'Descubre palabras clave de alta intención local', body: 'Stacc sugiere términos de búsqueda con volumen real en tu mercado local, puntuación de intención de compra y análisis de competencia. No términos genéricos — términos que tus clientes locales usan cuando están listos para contratar.' },
            { n: '03', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Rastrea rankings y actúa con datos', body: 'Asigna palabras clave a ubicaciones y rastrea tu posición diariamente. Cuando aparece una nueva oportunidad de competidor o una brecha en tu cobertura, Stacc te lo notifica para que puedas actuar antes que la competencia.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Todo incluido</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Investigación de palabras clave local completa<br />sin herramientas adicionales.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Datos de Búsqueda Locales', body: 'Volúmenes de búsqueda segmentados por ciudad, barrio y área de servicio — no datos nacionales que no te dicen qué pasa en tu mercado local.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Puntuación de Intención de Compra', body: 'Cada palabra clave puntuada por nivel de intención: transaccional (listo para comprar), de investigación o informacional. Prioriza donde el ROI es máximo.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
            { title: 'Análisis de Brecha de Competidores', body: '¿Qué palabras clave tienen tus competidores que tú no? Identifica las victorias rápidas con demanda local comprobada donde actualmente no apareces.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Mapeo por Ubicación', body: 'Cada palabra clave asignada a las ubicaciones donde tiene mayor demanda local. No aplicas la misma estrategia a todas las sedes — cada una recibe lo que su mercado necesita.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
            { title: 'Alertas de Nueva Oportunidad', body: 'Cuando aparece una nueva brecha de competidor o un término de alta intención en tu mercado, Stacc te notifica inmediatamente para que puedas actuar antes que la competencia.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Actualización Mensual de Datos', body: 'Los datos de volumen de búsqueda local se actualizan mensualmente. Los datos de competidores, semanalmente. Tu estrategia de palabras clave siempre refleja el estado actual del mercado.', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Qué pasa cuando atacas<br />las palabras clave correctas.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '3×', label: 'Más tráfico local de alta intención', sub: 'con palabras clave locales vs. genéricas' },
            { value: '60 días', label: 'Para ver primeras mejoras de ranking', sub: 'con estrategia de palabras clave localizada' },
            { value: 'Top 3', label: 'Objetivo alcanzable en Google Maps', sub: 'para términos locales de baja-media competencia' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Estábamos optimizando para 'clínica dental' cuando nuestros pacientes buscaban 'dentista urgencias [barrio]' y 'blanqueamiento dental sin cita'. Stacc nos lo mostró en el primer análisis. En 45 días de atacar esos términos pasamos de la página 2 a aparecer en el paquete de mapas. Ese cambio de palabras clave fue más efectivo que 6 meses de trabajo anterior."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">LV</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Laura V.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Responsable SEO · Cadena de clínicas dentales, 8 centros</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">En el paquete Maps en 45 días</span>
