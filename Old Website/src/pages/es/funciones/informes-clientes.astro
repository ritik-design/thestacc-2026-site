---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué datos incluyen los informes automáticos de clientes?",
    a: "Cada informe incluye cambios en ranking de palabras clave (orgánico, paquete local y Maps), recuento y puntuación media de reseñas, estado de salud de citaciones, resumen de actividad GBP (posts publicados, vistas, clics) y un resumen de tendencias periodo a periodo. Puedes elegir qué secciones aparecen en el informe de cada cliente.",
  },
  {
    q: "¿Puedo personalizar los informes con la marca de mi agencia?",
    a: "Sí. Todos los informes usan el logotipo, los colores corporativos y el dominio personalizado de tu agencia. Los clientes reciben el informe bajo tu marca — el logotipo de Stacc ni el nombre de la plataforma aparecen en ningún lugar del informe. Configura tu marca una vez y se aplica a todos los informes de clientes.",
  },
  {
    q: "¿Cómo funciona la entrega automática de informes?",
    a: "Tú estableces la frecuencia (semanal o mensual) y las direcciones de email de los destinatarios. Stacc ensambla el informe automáticamente con datos en tiempo real y lo entrega por email en la fecha que hayas elegido. Si tienes 30 clientes, 30 informes salen en el plazo programado sin que construyas ninguno manualmente.",
  },
  {
    q: "¿Pueden los clientes tener su propio acceso para ver informes?",
    a: "Sí. El acceso al portal de cliente se puede conceder por separado de la entrega de informes. Los clientes con acceso al portal inician sesión en un panel con tu marca y ven sus propios datos — rankings, reseñas, actividad GBP — sin acceder a la cuenta de ningún otro cliente.",
  },
  {
    q: "¿Puedo personalizar lo que ve cada cliente en su informe?",
    a: "Sí. El constructor de informes te permite elegir qué secciones incluir o excluir por cliente. Algunos clientes quieren solo datos de ranking. Otros quieren el paquete completo. Lo configuras una vez por cliente y Stacc lo recuerda.",
  },
  {
    q: "¿Están disponibles los informes en PDF y como enlace compartible?",
    a: "Sí. Cada informe se genera como descarga PDF y como URL compartible. Envía a los clientes un enlace directo que puedan guardar en favoritos, o adjunta el PDF a tu propio email si prefieres añadir una nota personal antes de la entrega.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Informes de Clientes",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Informes de clientes con marca blanca que se crean y entregan solos. Rankings, reseñas, citaciones y actividad GBP — con tu marca de agencia, enviados automáticamente.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Funciones", "item": "https://thestacc.com/es/funciones/" },
        { "@type": "ListItem", "position": 3, "name": "Informes de Clientes", "item": "https://thestacc.com/es/funciones/informes-clientes/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Informes SEO Automáticos para Clientes — Informes con Marca Blanca que se Envían Solos | theStacc"
  description="Deja de construir informes de clientes a mano. theStacc ensambla datos de ranking, reseñas, citaciones y actividad GBP en informes con tu marca que se entregan automáticamente."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Informes de Clientes · Módulo SEO Local</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Llevas horas construyendo informes<br />
            <span style="color:#4f39f6;">que podrían crearse solos.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc recopila los datos de ranking, reseñas, citaciones y actividad GBP de cada cliente y los ensambla en un informe con tu marca automáticamente. Configura una vez. Entrega automática semanal o mensual. Sin horas desperdiciadas en formateo.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Automatiza tus informes
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver precios
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mes · Prueba gratuita 14 días · Sin tarjeta de crédito
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '0h', label: 'Tiempo en crear informes cada mes' },
              { value: '100%', label: 'Con tu marca — sin mencionar Stacc' },
              { value: '30+', label: 'Clientes con informes automáticos simultáneos' },
              { value: '4.9★', label: 'Valoración media de Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Los informes manuales son tu<br />mayor ladrón de tiempo facturable.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Fin de mes. Veinte clientes esperando su informe. Entras en cada herramienta por separado — rastreo de ranking, panel de reseñas, auditoría de citaciones, actividad GBP — copias y pegas los datos en una plantilla de PowerPoint o Google Slides que se rompe cada vez que la abres, le cambias los colores para que coincidan con la marca del cliente, y llevas tres horas para producir un informe que el cliente mirará dos minutos. Multiplica eso por 20. Son 60 horas al mes en informes. Eso es un empleado a tiempo parcial dedicado exclusivamente a construir documentos.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Los informes manuales consumen días de trabajo facturable.',
              body: 'En una agencia con 20 clientes, construir informes mensuales manualmente toma entre 40 y 80 horas. Eso es tiempo que no facturarás — y que, de facturarlo, justificaría el precio de Stacc muchas veces.',
            },
            {
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              title: 'Los datos inconsistentes erosionan la confianza del cliente.',
              body: 'Cuando los informes se construyen manualmente, las métricas son inconsistentes entre meses — diferentes rangos de fechas, diferentes términos para las mismas métricas, datos que no cuadran. Los clientes lo notan. La inconsistencia hace que el trabajo parezca menos profesional del que es.',
            },
            {
              icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
              title: 'Los informes retrasados dañan la percepción de resultados.',
              body: 'Cuando el informe llega tarde — o cuando un cliente pregunta por los resultados y no tienes datos actualizados — la percepción de tu valor baja. Los informes puntuales y automáticos son parte de la experiencia de servicio, no solo documentos administrativos.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Todo incluido</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Informes completos que se crean solos<br />y llegan con tu marca.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Datos de Ranking Automáticos', body: 'Rankings en paquete local, Maps y orgánico local para cada cliente — actualizados diariamente e incluidos automáticamente en cada informe sin importación manual.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
            { title: 'Reseñas y Sentimiento', body: 'Recuento de nuevas reseñas, evolución de puntuación media, tasa de respuesta y temas de sentimiento positivo/negativo por plataforma y periodo.', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
            { title: 'Marca Blanca Completa', body: 'Tu logotipo, colores corporativos y dominio personalizado en cada informe. Los clientes no ven ninguna referencia a Stacc — el informe es tuyo.', icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01' },
            { title: 'Entrega Automática Programada', body: 'Define el día del mes y los destinatarios. Stacc ensambla y entrega todos los informes automáticamente en la fecha programada — sin que toques nada.', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { title: 'Portal de Cliente con Acceso Propio', body: 'Los clientes pueden iniciar sesión en su portal personalizado y ver sus datos en tiempo real — sin esperar al informe mensual y sin acceder a datos de otros clientes.', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
            { title: 'PDF y Enlace Compartible', body: 'Cada informe disponible como PDF descargable y como URL compartible. Envía el enlace por email o adjunta el PDF — el cliente puede verlo cuando quiera.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que ganan las agencias cuando<br />los informes se crean solos.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '80%', label: 'Reducción en tiempo de informes', sub: 'de 3h por cliente a 15min de revisión' },
            { value: '100%', label: 'Tasa de entrega puntual', sub: 'informes enviados en la fecha programada' },
            { value: '0', label: 'Informes construidos manualmente', sub: 'después de la configuración inicial' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Los informes de clientes me consumían un día entero a fin de mes. Con Stacc, lo configuro una vez por cliente, defino la fecha de envío y se acabó. Los 25 informes de este mes salieron solos. Un cliente me escribió para preguntarme si habíamos cambiado de sistema porque el informe 'se veía más profesional'. No le dije que yo no había tocado nada."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">RM</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Rafael M.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Director de Agencia · SEO local para negocios físicos, 25 clientes</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">1 día/mes recuperado</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre informes de clientes
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Deja de construir informes a mano</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Cada hora construyendo informes<br />es una hora que no generas resultados.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Los informes manuales consumen tiempo que podría ir a trabajo real — optimizar rankings, gestionar reseñas, crecer la cartera. Stacc automatiza lo administrativo para que tu equipo haga el trabajo que los clientes valoran. Empieza tu prueba gratuita hoy.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
