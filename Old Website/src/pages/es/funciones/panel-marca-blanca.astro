---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué se personaliza exactamente con la marca blanca?",
    a: "Todo lo que ve el cliente: la URL del panel (tu dominio), el logotipo, el nombre de tu agencia, los PDF de informes, los emails de informes automáticos y las notificaciones que recibe el cliente. El nombre de Stacc y su marca no aparecen en ningún lugar de la experiencia del cliente.",
  },
  {
    q: "¿Puede cada cliente tener su propio acceso?",
    a: "Sí. Creas accesos individuales de cliente con alcance a sus ubicaciones específicas. Cada cliente ve solo sus propios datos — nunca los de tus otros clientes. Tú mantienes acceso de administrador completo a todos los clientes desde tu cuenta de agencia.",
  },
  {
    q: "¿Cuánto tiempo lleva configurar la marca blanca?",
    a: "Aproximadamente 2 horas. Subes tu logotipo, configuras el nombre de tu agencia y el dominio (registro CNAME), estableces tu esquema de colores y listo. No se requiere trabajo de desarrollador — todo se configura desde el panel.",
  },
  {
    q: "¿Hay que pagar por cada acceso de cliente?",
    a: "No. Los accesos de cliente están incluidos a $0 por cliente independientemente de cuántos clientes añadas. Tu coste se basa en el número de ubicaciones gestionadas — no en el número de accesos de cliente. Puedes dar a cada cliente su propio acceso sin que afecte a tu factura.",
  },
  {
    q: "¿Puedo usar un dominio personalizado para los paneles de clientes?",
    a: "Sí. Apunta un subdominio (por ejemplo, seo.tuagencia.com) a Stacc mediante un registro CNAME y todos los paneles de cliente se cargan en tu dominio. Los clientes nunca ven thestacc.com en la URL.",
  },
  {
    q: "¿Pueden enviarse los informes con marca blanca automáticamente a los clientes?",
    a: "Sí. Configura la entrega automática de informes para cada cliente — semanal o mensual. Los informes se generan con tu marca y se envían desde tu dominio automáticamente. Puedes revisar los informes antes de que salgan o dejar que se envíen en piloto automático completo.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Panel de Marca Blanca para Agencias",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "es",
      "description": "Entrega resultados de SEO local bajo la marca de tu agencia. Paneles, informes y accesos de cliente con marca blanca — tu logotipo, tu dominio, tu marca en todo lo que ven los clientes.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/es/" },
        { "@type": "ListItem", "position": 2, "name": "Funciones", "item": "https://thestacc.com/es/funciones/" },
        { "@type": "ListItem", "position": 3, "name": "Panel de Marca Blanca", "item": "https://thestacc.com/es/funciones/panel-marca-blanca/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Panel SEO con Marca Blanca para Agencias — Tu Marca en Todo lo que Ven los Clientes | theStacc"
  description="Ofrece a los clientes un panel de SEO local con tu logotipo y dominio. Paneles, informes y accesos de cliente con marca blanca — ninguna referencia a Stacc visible."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Panel de Marca Blanca · Para Agencias</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Tus clientes ven tu marca.<br />
            <span style="color:#4f39f6;">No la nuestra.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Todo lo que ven tus clientes lleva tu logotipo, tu dominio y tus colores. El panel SEO, los informes, los emails automáticos, los accesos de cliente — todo bajo tu marca. Stacc es la infraestructura. Tú eres la agencia.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Configura tu marca blanca
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver precios
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $49/mes · Configuración en 2 horas · Sin mencionar Stacc
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '2hrs', label: 'Configuración completa de marca blanca' },
              { value: '$0', label: 'Coste adicional por acceso de cliente' },
              { value: '100%', label: 'Marca blanca — sin rastro de Stacc' },
              { value: 'CNAME', label: 'Dominio personalizado para paneles' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">El problema</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cuando el cliente ve el nombre de la herramienta,<br />tú dejas de ser el experto.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Trabajas durante semanas para construir una relación de confianza con un cliente. Eres el experto en SEO local. Eres quien sabe lo que funciona. Y entonces el cliente abre el informe, ve el logo de otra plataforma en el encabezado, busca el nombre en Google, y empieza a preguntarse si podría contratarla directamente. La marca blanca no es un lujo — es protección de la relación que has construido.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
              title: 'El cliente ve la herramienta, no tu valor.',
              body: 'Cuando el informe lleva el logo de Stacc, el cliente puede pensar "¿por qué le pago a la agencia si la herramienta hace todo el trabajo?". La marca blanca mantiene el foco en tus resultados y tu estrategia — no en la infraestructura que usas para entregarlos.',
            },
            {
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
              title: 'Los clientes que conocen la herramienta pueden buscarla directamente.',
              body: 'Una vez que el cliente sabe que usas Stacc, puede explorar si puede contratarlo directamente sin intermediario. La marca blanca elimina ese riesgo — el cliente solo ve tu agencia como la fuente de los resultados.',
            },
            {
              icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
              title: 'Los informes genéricos no refuerzan tu posicionamiento.',
              body: 'Un informe que lleva tu marca, con tus colores y tu estilo visual, refuerza la percepción de profesionalidad y consistencia. Un informe genérico de herramienta no dice nada sobre quién eres. Cada punto de contacto con el cliente es una oportunidad de posicionarte — o de desaprovecharlo.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Todo incluido</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Marca blanca completa en cada<br />punto de contacto con el cliente.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Dominio Personalizado', body: 'Apunta un subdominio (seo.tuagencia.com) a Stacc mediante CNAME. Los paneles de cliente se cargan en tu URL — thestacc.com nunca aparece en el navegador del cliente.', icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9' },
            { title: 'Logotipo y Colores', body: 'Sube tu logotipo y define tu paleta de colores corporativos una vez. Se aplican automáticamente a paneles, informes PDF y emails de entrega.', icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01' },
            { title: 'Informes PDF con Marca', body: 'Cada informe generado lleva tu logotipo, encabezado y pie de página personalizados. El cliente recibe un documento profesional que refuerza tu marca en cada página.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
            { title: 'Emails de Informe Personalizados', body: 'Los emails de entrega de informes se envían desde tu dominio con tu firma. El cliente recibe el email como si lo hubieras enviado tú — no un email automático de plataforma.', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z' },
            { title: 'Accesos de Cliente Incluidos', body: 'Crea accesos de cliente ilimitados sin coste adicional. Cada cliente ve solo sus datos. Tú mantienes acceso de administrador completo a todos desde tu cuenta.', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
            { title: 'Configuración en 2 Horas', body: 'Sin desarrollador. Sin código. Todo el setup de marca blanca — dominio, logo, colores, configuración de email — se hace desde el panel de administración en menos de 2 horas.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Resultados</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Lo que gana tu agencia cuando<br />todo lleva tu marca.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '2hrs', label: 'Setup completo de marca blanca', sub: 'sin programador, sin código' },
            { value: '$0', label: 'Coste por acceso de cliente', sub: 'ilimitados sin afectar tu factura' },
            { value: '100%', label: 'Experiencia de cliente bajo tu marca', sub: 'panel, informes, emails, URL' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Mis clientes acceden a 'seo.miagencia.com', ven mi logotipo, reciben informes en PDF con mi membrete y reciben los emails desde mi dominio. Para ellos, todo es mi plataforma. Eso me posiciona como agencia tecnológica aunque sea una operación de dos personas — y me diferencia de los freelancers que entregan capturas de pantalla de herramientas genéricas."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">IS</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Irene S.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Consultora SEO Local · 18 clientes, operación individual</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">100% marca de agencia</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Preguntas frecuentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Preguntas sobre el panel de marca blanca
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Tu tecnología. Tu marca.</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Entrega SEO local de nivel enterprise<br />con el nombre de tu agencia en todo.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Stacc te da la infraestructura tecnológica que necesitas para competir con agencias mucho más grandes — y la marca blanca asegura que todo el valor percibido va a tu agencia. Configura en 2 horas. Empieza tu prueba gratuita hoy.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/es/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Configura tu marca blanca
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/es/precios/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Ver planes de agencia
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Prueba gratuita 14 días · Sin tarjeta de crédito · Cancela cuando quieras</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
