---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import { getCollection, render } from 'astro:content';
import CrossLinks from '../../../components/common/CrossLinks.astro';
import { glossaryCategoryLinks } from '../../../data/internal-links';
import { isNoindexed } from '../../../data/noindex-list';
import { SITE_URL, organizationSchema, websiteSchema, buildBreadcrumbs } from '../../../utils/schema';

export async function getStaticPaths() {
  const langTerms = await getCollection('glossary_es');
  return langTerms.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allTerms = await getCollection('glossary_es');
const relatedSlugs = entry.data.relatedTerms || [];
const relatedTerms = allTerms.filter((t) => relatedSlugs.includes(t.data.slug));

const categoryTerms = allTerms
  .filter((t) => t.data.category === entry.data.category && t.data.slug !== entry.data.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 6);

const categoryCrossLinks = glossaryCategoryLinks[entry.data.category] || [];

const categoryColors: Record<string, string> = {
  'Marketing': '#4f39f6',
  'SEO': '#16a34a',
  'Local SEO': '#ea580c',
  'Social Media': '#db2777',
  'AI & Emerging': '#7c3aed',
};

const difficultyLabels: Record<string, string> = {
  'Beginner': 'Principiante',
  'Intermediate': 'Intermedio',
  'Advanced': 'Avanzado',
};

const difficultyColors: Record<string, string> = {
  'Beginner': '#16a34a',
  'Intermediate': '#d97706',
  'Advanced': '#dc2626',
};

const catColor = categoryColors[entry.data.category] || '#4f39f6';
const t = entry.data.term;

const esUrl = `${SITE_URL}/es/glosario/${entry.data.slug}/`;
const enUrl = `${SITE_URL}/glossary/${entry.data.slug}/`;

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTerm',
      '@id': `${esUrl}#term`,
      name: t,
      description: entry.data.definition,
      url: esUrl,
      inLanguage: 'es',
      inDefinedTermSet: `${SITE_URL}/es/glosario/`,
    },
    buildBreadcrumbs(esUrl, [
      { name: 'Inicio', url: `${SITE_URL}/es/` },
      { name: 'Glosario', url: `${SITE_URL}/es/glosario/` },
      { name: t, url: esUrl },
    ]),
    organizationSchema,
    websiteSchema,
  ],
};
---

<BaseLayout
  title={`${t}: Definición y Guía Completa | theStacc`}
  description={`¿Qué es ${t}? Definición completa, ejemplos y cómo aplicarlo para mejorar tu SEO y estrategia de contenidos.`}
  lang="es"
  noindex={isNoindexed(`/es/glosario/${entry.data.slug}/`)}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  <main class="flex-1">

    <!-- HERO -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-8">

        <!-- Breadcrumb -->
        <nav aria-label="Migas de pan">
          <ol class="flex flex-wrap items-center gap-1 font-mono text-[11px] text-[#79716b]">
            <li><a href="/es/" class="hover:text-[#4f39f6] transition-colors">Inicio</a></li>
            <li class="before:content-['/'] before:mx-1.5"><a href="/es/glosario/" class="hover:text-[#4f39f6] transition-colors">Glosario</a></li>
            <li class="before:content-['/'] before:mx-1.5 text-[#292524]">{t}</li>
          </ol>
        </nav>

        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="rounded-md px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.08em]"
            style={`color:${catColor};background:${catColor}18`}>{entry.data.category}</span>
          <span class="rounded-md px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.08em]"
            style={`color:${difficultyColors[entry.data.difficulty] || '#57534e'};background:${difficultyColors[entry.data.difficulty] || '#57534e'}18`}>
            {difficultyLabels[entry.data.difficulty] || entry.data.difficulty}
          </span>
          <a href={enUrl} class="rounded-md border border-[#e7e5e4] px-2 py-0.5 font-mono text-[10px] text-[#79716b] hover:text-[#4f39f6] hover:border-[#4f39f6] transition-colors">Read in English →</a>
        </div>

        <h1 class="mt-4 font-sans text-[28px] font-bold leading-[1.15] tracking-[-0.025em] text-[#111827] md:text-[36px]">{t}</h1>
        <p class="mt-3 max-w-[640px] font-sans text-[17px] leading-[1.65] text-[#57534e]">{entry.data.definition}</p>
      </div>
    </div>

    <!-- CONTENT + SIDEBAR -->
    <div class="mx-auto max-w-[1320px] px-6 py-10 lg:flex lg:items-start lg:gap-12">

      <!-- Main -->
      <div class="min-w-0 flex-1">
        <div class="review-content blog-content overflow-x-hidden">
          <Content />
        </div>

        <CrossLinks
          heading="Explora Más de theStacc"
          moduleLinks={categoryCrossLinks.modules || []}
          toolLinks={categoryCrossLinks.tools || []}
          bestLinks={[{ url: '/es/mejor/', label: 'Mejores Herramientas SEO' }]}
          homepageAnchor="plataforma de automatización SEO con IA"
        />

        <!-- Related Terms -->
        {categoryTerms.length > 0 && (
          <div class="mt-10 border-t border-[#e7e5e4] pt-8">
            <h3 class="font-sans text-[18px] font-bold text-[#111827]">Términos Relacionados</h3>
            <div class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
              {categoryTerms.map((term) => (
                <a
                  href={`/es/glosario/${term.data.slug}/`}
                  class="group block rounded-xl border border-[#e7e5e4] bg-white px-4 py-3.5 transition-all hover:border-[#c4b5fd] hover:shadow-sm"
                >
                  <p class="font-sans text-[14px] font-semibold text-[#292524] transition-colors group-hover:text-[#4f39f6]">{term.data.term}</p>
                  <p class="mt-1 line-clamp-2 font-sans text-[12px] leading-[18px] text-[#79716b]">{term.data.definition}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block w-[272px] shrink-0">
        <div class="flex flex-col gap-4 pt-2">
          <div class="overflow-hidden rounded-2xl" style="background:#0d1117;border:1px solid rgba(79,57,246,0.25);">
            <div class="p-5" style="background:linear-gradient(135deg,rgba(79,57,246,0.18) 0%,transparent 65%);">
              <h4 class="font-sans text-[15px] font-bold leading-[1.3] text-white">¿Quieres rankear para más términos como "{t}"?</h4>
              <p class="mt-1.5 font-sans text-[12px] leading-[1.6] text-[#94a3b8]">theStacc publica 30 artículos SEO optimizados en tu sitio cada mes. Automáticamente.</p>
            </div>
            <div class="px-5 pb-5 pt-4" style="border-top:1px solid rgba(255,255,255,0.07);">
              <a href="/es/demo/" class="block rounded-xl py-3 text-center font-mono text-[12px] font-bold uppercase tracking-[0.08em] text-white transition-colors hover:opacity-90" style="background:#4f39f6;">
                Comenzar por $1 →
              </a>
              <p class="mt-2 text-center font-mono text-[10px] text-[#4b5563]">30 días de prueba · Cancela cuando quieras</p>
            </div>
          </div>

          <div class="rounded-xl border border-[#e7e5e4] bg-white p-4">
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6]">Glosario</p>
            <a href="/es/glosario/" class="mt-2 block font-sans text-[13px] font-medium text-[#292524] hover:text-[#4f39f6] transition-colors">← Ver todos los términos</a>
          </div>
        </div>
      </aside>
    </div>

    <!-- FOOTER CTA -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-14 text-center">
        <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          ¿Listo para automatizar tu SEO?
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          30 publicaciones GBP, 30 artículos de blog, redes sociales. Todo en piloto automático.
        </p>
        <a href="/es/demo/" class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Comenzar por $1
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">$1 por 30 días · Cancela cuando quieras</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
