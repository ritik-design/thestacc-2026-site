---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const toc = [
  { id: 'aceptacion',    label: '1. Aceptación de los Términos' },
  { id: 'servicio',      label: '2. Descripción del Servicio' },
  { id: 'cuentas',       label: '3. Cuentas de Usuario' },
  { id: 'pago',          label: '4. Condiciones de Pago' },
  { id: 'uso-aceptable', label: '5. Uso Aceptable' },
  { id: 'propiedad',     label: '6. Propiedad Intelectual' },
  { id: 'responsabilidad', label: '7. Limitación de Responsabilidad' },
  { id: 'rescision',     label: '8. Rescisión' },
  { id: 'contacto',      label: '9. Contacto' },
];

const legalPages = [
  { label: 'Política de Privacidad',         href: '/es/privacidad/' },
  { label: 'Términos y Condiciones',         href: '/es/terminos/' },
  { label: 'Política de Cookies',            href: '/es/cookies/' },
  { label: 'Acuerdo de Procesamiento',       href: '/es/procesamiento-datos/' },
  { label: 'Licencias',                      href: '/es/licencias/' },
];

const currentPath = '/es/terminos/';
---

<BaseLayout
  title="Términos y Condiciones | theStacc"
  description="Los términos y condiciones que rigen el uso de los servicios de theStacc. Léelos antes de usar theStacc para conocer tus derechos y responsabilidades."
  lang="es"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="min-h-screen bg-[#fafaf9]">

    <div class="relative overflow-hidden border-b border-white/10" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.5) 0%, transparent 62%);" aria-hidden="true"></div>
      <div class="container-x relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#818cf8]">Legal · Términos</span>
        <h1 class="mt-2 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.5rem]">Términos y Condiciones</h1>
        <p class="mt-2 font-mono text-[12px] text-white/40">Última actualización: Abril 2026</p>
      </div>
    </div>

    <div class="container-x py-12 md:py-16">
      <div class="mx-auto max-w-5xl lg:grid lg:grid-cols-[220px_1fr] lg:gap-12 xl:grid-cols-[240px_1fr]">

        <aside class="mb-10 lg:mb-0">
          <div class="lg:sticky lg:top-8 flex flex-col gap-6">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#79716b]">En esta página</p>
              <nav class="flex flex-col gap-0.5">
                {toc.map(item => (
                  <a href={`#${item.id}`} class="toc-link rounded-lg px-3 py-2 font-sans text-[13px] text-[#79716b] transition-colors hover:bg-[#f5f3ff] hover:text-[#4f39f6]" data-toc={item.id}>
                    {item.label}
                  </a>
                ))}
              </nav>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#79716b]">Documentos legales</p>
              <nav class="flex flex-col gap-0.5">
                {legalPages.map(page => (
                  <a href={page.href} class={`rounded-lg px-3 py-2 font-sans text-[13px] transition-colors ${currentPath === page.href ? 'bg-[#f5f3ff] font-semibold text-[#4f39f6]' : 'text-[#79716b] hover:bg-[#fafaf9] hover:text-[#374151]'}`}>
                    {page.label}
                  </a>
                ))}
              </nav>
            </div>
            <a href="mailto:hello@thestacc.com" class="flex items-center gap-2.5 rounded-2xl border border-[#e7e5e4] bg-white px-5 py-4 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span class="font-sans text-[13px] text-[#4f39f6] font-medium">hello@thestacc.com</span>
            </a>
          </div>
        </aside>

        <div class="rounded-2xl border border-[#e7e5e4] bg-white px-8 py-10 md:px-12 md:py-12">
          <div class="flex flex-col gap-10">

            <section id="aceptacion" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Aceptación de los Términos</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Al acceder o usar los servicios de theStacc, aceptas quedar vinculado por estos Términos y Condiciones. Si no estás de acuerdo con estos términos, no uses nuestros servicios.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="servicio" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Descripción del Servicio</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  theStacc proporciona herramientas de automatización SEO que incluyen generación de contenido, investigación de palabras clave, optimización de SEO local y analítica. Nuestros servicios están diseñados para ayudar a las empresas a mejorar su visibilidad en búsqueda.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="cuentas" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Cuentas de Usuario</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Eres responsable de mantener la confidencialidad de las credenciales de tu cuenta y de todas las actividades que ocurran bajo tu cuenta. Aceptas notificarnos de inmediato ante cualquier uso no autorizado.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="pago" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Condiciones de Pago</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Las cuotas de suscripción se facturan por adelantado de forma mensual o anual. Todos los cargos no son reembolsables excepto según se establezca expresamente en estos términos. Nos reservamos el derecho a modificar nuestros precios con un preaviso de 30 días.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="uso-aceptable" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">5</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Uso Aceptable</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Aceptas no usar nuestros servicios para ningún propósito ilegal ni de ninguna manera que pueda dañar, deshabilitar o deteriorar nuestros servicios. No puedes usar nuestras herramientas para generar contenido engañoso, dañino o spam. Consulta nuestra <a href="/es/uso-aceptable/" class="text-[#4f39f6] hover:underline">Política de Uso Aceptable</a> para más detalles.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="propiedad" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">6</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Propiedad Intelectual</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  El contenido que creas con nuestras herramientas sigue siendo de tu propiedad. Sin embargo, nos otorgas una licencia para usar datos anonimizados con el fin de mejorar nuestros servicios. Nuestra plataforma, marca y tecnología siguen siendo de nuestra propiedad exclusiva.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="responsabilidad" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">7</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Limitación de Responsabilidad</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  theStacc no será responsable de ningún daño indirecto, incidental, especial o consecuente derivado del uso de nuestros servicios. Nuestra responsabilidad total no superará el importe pagado por ti en los doce meses anteriores a la reclamación.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="rescision" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">8</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Rescisión</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Cualquiera de las partes puede rescindir este acuerdo en cualquier momento. Tras la rescisión, tu derecho a usar nuestros servicios cesará de inmediato. Podemos conservar tus datos según lo exija la ley o para fines empresariales legítimos.
                </p>
              </div>
            </section>

            <div class="border-t border-[#e7e5e4]"></div>

            <section id="contacto" class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">9</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Contacto</h2>
              </div>
              <div class="pl-9">
                <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  Para preguntas sobre estos términos, contáctanos en <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
                </p>
                <p class="mt-4 font-sans text-[15px] leading-[1.75] text-[#57534e]">
                  <strong class="font-semibold text-[#111827]">Nombre legal:</strong> SOLARTREK VENTURES LLP<br/>
                  <strong class="font-semibold text-[#111827]">Dirección:</strong> Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India
                </p>
              </div>
            </section>

          </div>
        </div>

      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const sections = Array.from(links).map(l => document.getElementById(l.dataset.toc || ''));
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        links.forEach(l => {
          const isActive = l.dataset.toc === entry.target.id;
          l.style.backgroundColor = isActive ? '#f5f3ff' : '';
          l.style.color = isActive ? '#4f39f6' : '';
          l.style.fontWeight = isActive ? '600' : '';
        });
      }
    });
  }, { rootMargin: '-10% 0px -80% 0px' });
  sections.forEach(s => s && obs.observe(s));
</script>
