---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "¿Qué es la automatización de SEO local?",
    a: "La automatización de SEO local es la práctica de usar software para gestionar las tareas repetitivas y laboriosas que impulsan el posicionamiento en búsquedas locales — publicación de posts en GBP, monitorización de citaciones, alertas de reseñas, rastreo de posiciones y generación de informes — sin requerir esfuerzo manual cada vez. En lugar de iniciar sesión a diario para revisar y actualizar las cosas, configuras las reglas una vez y el software las ejecuta de forma continua.",
  },
  {
    q: "¿Qué tareas de SEO local automatiza Stacc?",
    a: "Stacc automatiza la publicación de posts en GBP (30 posts/mes por ubicación), el rastreo diario de posiciones en paquete local y orgánico, la monitorización de reseñas en tiempo real con alertas, la monitorización de precisión de citaciones en más de 50 directorios y la generación y entrega de informes de clientes con marca blanca. Estas son las cinco tareas manuales de mayor volumen en el SEO local — y Stacc las gestiona todas automáticamente.",
  },
  {
    q: "¿Cuántas horas ahorra la automatización de SEO local?",
    a: "Las empresas y agencias que usan Stacc reportan ahorrar un promedio de 8 horas por cliente al mes en comparación con gestionar el mismo trabajo manualmente. Para una agencia con 20 clientes, eso son 160 horas al mes — aproximadamente un empleado a tiempo completo — recuperadas sin reducir la calidad.",
  },
  {
    q: "¿La automatización de SEO local mejora realmente el posicionamiento?",
    a: "Sí, cuando se ejecuta de forma consistente. El algoritmo de Maps de Google premia los perfiles de GBP activos y consistentes con datos de citaciones precisos. El problema del SEO local manual es la inconsistencia — pasan semanas sin posts de GBP, las citaciones se deterioran y las respuestas a reseñas se ralentizan. La automatización garantiza que las señales que Google busca se envíen de forma consistente, cada día, para cada ubicación.",
  },
  {
    q: "¿Puede Stacc automatizar el SEO local para múltiples ubicaciones a la vez?",
    a: "Sí. Stacc está diseñado para la gestión de múltiples ubicaciones. Puedes publicar posts de GBP en todas las ubicaciones simultáneamente (o programar contenido específico por ubicación), rastrear posiciones para cada ubicación de forma independiente, monitorizar reseñas en todos los GBP en un único feed y generar informes separados o agregados por ubicación.",
  },
  {
    q: "¿Es la automatización de SEO local adecuada para agencias?",
    a: "La automatización de SEO local es especialmente poderosa para las agencias porque el ahorro de tiempo se multiplica en cada cliente. Stacc ofrece a las agencias informes con marca blanca (entregados bajo tu marca), gestión de cuentas de múltiples clientes y la capacidad de gestionar docenas de clientes al mismo nivel de calidad que antes requería un miembro del equipo dedicado por cada 5-10 clientes.",
  },
  {
    q: "¿La automatización reemplaza la necesidad de estrategia de SEO?",
    a: "No — la automatización gestiona la ejecución, no la estrategia. Tú sigues decidiendo qué palabras clave apuntar, qué servicios promocionar y cómo posicionar cada ubicación. Stacc entonces ejecuta esa estrategia de forma consistente — publicando el contenido correcto, rastreando las palabras clave correctas, monitorizando las señales correctas — para que la estrategia realmente se implemente en lugar de quedarse en un documento.",
  },
  {
    q: "¿Cuánto tiempo tarda en ver resultados de la automatización de SEO local?",
    a: "La mayoría de los negocios ven movimientos iniciales en el posicionamiento dentro de los 30-60 días de publicación consistente en GBP y limpieza de citaciones. El impacto completo se suele ver en 90 días. El factor clave es la consistencia: Stacc publica cada día, monitoriza cada día y corrige problemas cada día — algo que la gestión manual casi nunca logra a escala.",
  },
  {
    q: "¿Cuánto cuesta Stacc?",
    a: "El módulo de SEO Local comienza en $49/mes. Esto incluye publicación de posts en GBP, rastreo diario de posiciones, monitorización de reseñas, gestión de citaciones e informes automatizados. Hay una prueba gratuita de 14 días disponible sin necesidad de tarjeta de crédito.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "inLanguage": "es",
      "name": "theStacc — Automatización de SEO Local",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Plataforma de automatización de SEO local que gestiona el rastreo de posiciones, la sincronización de citaciones, la monitorización de reseñas y la publicación en GBP automáticamente — ahorrando 8 horas por cliente al mes.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Módulo de SEO Local — 14 días de prueba gratuita"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Automatización de SEO Local", "item": "https://thestacc.com/es/automatizacion-seo-local/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "es",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Automatización de SEO Local — Automatiza Posiciones, Citaciones y Reseñas | theStacc"
  description="Automatiza el trabajo diario de SEO local. theStacc gestiona el rastreo de posiciones, la sincronización de citaciones, la monitorización de reseñas y la publicación en GBP — 8 horas ahorradas a la semana."
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex flex-wrap items-center justify-center gap-3">
            {['Totalmente automatizado', '8 hrs ahorradas/mes', 'GBP + citaciones + reseñas', 'Sin tarjeta de crédito', '$49/mes'].map(chip => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>{chip}
              </span>
            ))}
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Automatización de SEO local que<br />funciona sin ti.
            <span style="color:#4f39f6;"> Cada día. Cada ubicación.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            El SEO local manual es un trabajo a tiempo completo que estás haciendo a tiempo parcial. Stacc automatiza el trabajo de ejecución diaria — posts en GBP, monitorización de posiciones, sincronización de citaciones, alertas de reseñas e informes de clientes — para que puedas dedicar tu tiempo a la estrategia, no a las hojas de cálculo.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Empieza a automatizar por $1
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#caracteristicas"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Ver qué está automatizado
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sin tarjeta de crédito para empezar · 30 días de garantía · Cancela en cualquier momento
          </p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ agencias usan Stacc</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuración en menos de 5 minutos</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Por qué el SEO local manual no escala</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            El SEO local es un trabajo diario.<br />Tú lo haces mensualmente.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              El algoritmo local de Google no te juzga mensualmente. Lo hace cada día. ¿Está tu GBP publicando de forma consistente? ¿Coinciden tus citaciones en todos los directorios? ¿Estás respondiendo a las reseñas con rapidez? ¿Se mantiene tu posicionamiento en el paquete local? Estas no son preguntas para auditorías mensuales — son condiciones operativas diarias. Y si las gestionas manualmente, te estás perdiendo la mayoría de ellas la mayor parte del tiempo.
            </p>
            <p>
              Las agencias y negocios que aparecen en lo alto de Google Maps no inician sesión cada mañana para revisar su GBP y publicar manualmente. <strong class="text-[#111827]">Lo automatizaron.</strong> Construyeron un sistema que ejecuta el trabajo SEO diario sin que nadie tenga que hacerlo. La consistencia — no el talento — es lo que impulsa el posicionamiento local. Y la consistencia a escala solo es posible con la automatización.
            </p>
            <p>
              Piensa en lo que realmente estás dedicando tu tiempo: revisar posiciones que podrían alertarte automáticamente, redactar posts de GBP que el software puede generar, construir informes que deberían entregarse solos, monitorizar plataformas de reseñas una pestaña a la vez. Súmalo en 10 clientes y estás mirando más de 80 horas de trabajo manual al mes que no debería ser manual en absoluto.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc fue construido para reemplazar esas 80 horas con un sistema automatizado. Tú defines la estrategia. Stacc gestiona la ejecución — cada día, para cada ubicación, sin que nadie de tu equipo lo toque.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Qué automatiza Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cada tarea de SEO local que ha estado<br />consumiendo el tiempo de tu equipo.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { title: 'SEO Local', price: '$49/mes', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', features: ['Publicación de posts en GBP — 30/mes', 'Rastreo diario de posiciones — paquete local + orgánico', 'Monitorización de reseñas — alertas en tiempo real', 'Gestión de citaciones — más de 50 directorios'], href: '/es/modulos/seo-local/' },
            { title: 'SEO de Blog', price: '$99/mes', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', features: ['30 posts de blog SEO/mes', 'Publicados directamente en tu sitio', 'Investigación de palabras clave incluida', 'Enlazado interno optimizado'], href: '/es/modulos/seo-contenido/' },
            { title: 'Redes Sociales', price: '$49/mes', icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', features: ['Posts diarios con imágenes', 'Instagram, LinkedIn, Facebook, X', 'Redactados y programados automáticamente', 'Contenido coherente con la marca'], href: '/es/modulos/redes-sociales/' },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
                </div>
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">{m.price}</span>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Saber más</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="caracteristicas" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatización en detalle</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Lo que Stacc está haciendo<br />mientras tú te concentras en otra cosa.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP Automation -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatización de Posts en GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 posts en Google Business Profile al mes. Redactados y publicados automáticamente.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                El algoritmo local de Google puntúa activamente la actividad en GBP. Los negocios que publican de forma consistente obtienen posiciones más altas en el paquete local — y los que se quedan en silencio caen. Stacc genera 30 posts específicos por ubicación al mes orientados a tus combinaciones de palabras clave de servicio + ciudad, temas de temporada y búsquedas de alta intención. Se publican de forma programada. Tu perfil se mantiene activo cada día sin que nadie de tu equipo tenga que iniciar sesión.
              </p>
              <a href="/es/modulos/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver automatización de GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Registro de actividad de automatización</p>
              {[
                { time: '7:02 AM', action: 'Post en GBP publicado', loc: 'Ubicación Austin', ok: true },
                { time: '7:02 AM', action: 'Post en GBP publicado', loc: 'Ubicación Dallas', ok: true },
                { time: '6:45 AM', action: 'Verificación de posiciones completada', loc: '14 palabras clave rastreadas', ok: true },
                { time: '6:30 AM', action: 'Auditoría de citaciones realizada', loc: '50 directorios verificados', ok: true },
                { time: '2:14 AM', action: 'Alerta de nueva reseña', loc: 'Reseña de 5 estrellas recibida', ok: true },
              ].map(log => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <span class="font-mono text-[10px] text-[#79716b] shrink-0 mt-0.5">{log.time}</span>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{log.action}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{log.loc}</p>
                  </div>
                  <span class="font-mono text-[11px] text-[#059669] shrink-0">✓</span>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Todo automatizado · Sin activaciones manuales</p>
            </div>
          </div>

          <!-- Review Monitoring -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Monitorización de reseñas — todas las ubicaciones</p>
              {[
                { stars: 5, text: '"Servicio increíble. El mejor fontanero en Austin."', platform: 'Google', time: 'hace 2h', alerted: true },
                { stars: 5, text: '"Respuesta rápida, precio justo. Muy recomendable."', platform: 'Google', time: 'hace 1d', alerted: true },
                { stars: 3, text: '"Decente pero tardó más de lo presupuestado."', platform: 'Yelp', time: 'hace 2d', alerted: true },
                { stars: 5, text: '"La mejor empresa de climatización de la ciudad. Sin duda."', platform: 'Google', time: 'hace 3d', alerted: true },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center gap-2 mb-1">
                    <div class="flex gap-0.5">
                      {Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
                    </div>
                    <span class="font-mono text-[10px] text-[#79716b]">{r.platform} · {r.time}</span>
                    {r.alerted && <span class="ml-auto font-mono text-[10px] text-[#059669]">✓ Alertado</span>}
                  </div>
                  <p class="font-sans text-[12px] text-[#57534e] italic">{r.text}</p>
                </div>
              ))}
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatización de Monitorización de Reseñas</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sé al instante de cada reseña en cuanto llega. Responde antes de que te afecte.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Una reseña negativa sin respuesta durante 48 horas causa más daño que la propia reseña. Stacc monitoriza todas las plataformas de reseñas en todas tus ubicaciones en tiempo real y envía alertas en el momento en que aparece una nueva reseña — para que puedas responder mientras aún está fresca. Para las agencias, el feed unificado de reseñas significa que ves cada reseña de cada cliente sin tener que iniciar sesión en 20 cuentas de Google diferentes.
              </p>
              <a href="/es/modulos/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Ver monitorización de reseñas
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Automated Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Informes Automatizados</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Informes que se generan, personalizan y entregan solos. Cada cliente. Cada semana.
