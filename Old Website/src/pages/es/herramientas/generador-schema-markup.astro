---
import ToolLayout from '../../../components/tools/ToolLayout.astro';

const pageTitle = 'Generador de Schema Markup Gratuito para Negocios Locales | theStacc';
const pageDescription = 'Genera schema markup LocalBusiness, FAQ y Service en JSON-LD. Pre-relleno para dentistas, plomeros, abogados. Copia al portapapeles, valida con Google. Gratis.';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Generador de Schema Markup Gratuito',
  description: 'Genera schema markup LocalBusiness, FAQ y Service en JSON-LD con presets de industria para más de 23 tipos de negocio. Copia al portapapeles o descarga.',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Organization', name: 'theStacc', url: 'https://thestacc.com' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Qué es el schema markup?', acceptedAnswer: { '@type': 'Answer', text: 'El schema markup es código de datos estructurados (normalmente JSON-LD) que agregas a tu sitio web para ayudar a los motores de búsqueda a entender tu contenido. Para los negocios locales, le indica a Google tu nombre comercial, dirección, teléfono, servicios, horarios y reseñas en un formato legible por máquinas. Esto puede dar lugar a resultados enriquecidos como valoraciones de estrellas, desplegables de FAQ y paneles de empresa en los resultados de búsqueda.' } },
    { '@type': 'Question', name: '¿Cómo agrego el schema markup a mi sitio web?', acceptedAnswer: { '@type': 'Answer', text: 'Copia el código JSON-LD y pégalo en tu HTML antes de la etiqueta de cierre </head>. En WordPress, usa el plugin "Insert Headers and Footers". En Webflow, ve a Configuración de página > Código personalizado > Código de encabezado. En Squarespace, ve a Configuración > Avanzado > Inyección de código > Encabezado. Luego valida con la Prueba de resultados enriquecidos de Google.' } },
    { '@type': 'Question', name: '¿Necesito schema markup para el SEO local?', acceptedAnswer: { '@type': 'Answer', text: 'Sí. El schema markup ayuda a Google a entender los detalles de tu negocio y puede mejorar tu visibilidad en los resultados de búsqueda local. Los negocios con schema markup correcto tienen más probabilidades de aparecer en el paquete local, paneles de conocimiento y resultados enriquecidos. Es especialmente importante para los tipos de schema LocalBusiness, FAQ y Service.' } },
    { '@type': 'Question', name: '¿Qué tipos de schema debe usar un negocio local?', acceptedAnswer: { '@type': 'Answer', text: 'Todo negocio local debería tener schema LocalBusiness (con tu tipo específico como Dentist o Plumber), schema FAQPage para preguntas comunes, schema Service para cada servicio que ofreces, y schema BreadcrumbList para la navegación. Combinarlos en un único @graph le da a los motores de búsqueda la imagen más completa de tu negocio.' } },
    { '@type': 'Question', name: '¿Este generador de schema markup es gratuito?', acceptedAnswer: { '@type': 'Answer', text: 'Sí, 100% gratuito. No se requiere registro. Selecciona tu industria para auto-rellenar los campos, personaliza los detalles de tu negocio y copia el código JSON-LD válido al instante. Todo se ejecuta en tu navegador. No se envían datos a ningún servidor.' } },
  ],
};
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Generador de Schema Markup Gratuito"
  toolDescription="Genera schema LocalBusiness, FAQ y Service en JSON-LD. Los presets de industria auto-rellenan tu tipo de negocio, servicios y sugerencias de FAQ. Copia o descarga."
  wide={true}
  lang="es"
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <Fragment slot="head">
  </Fragment>

  <!-- ==================== TOOL ==================== -->
  <Fragment slot="tool">
    <div class="flex flex-col lg:flex-row gap-6">
      <!-- LEFT: Form Column -->
      <div class="lg:w-[60%] space-y-6" id="form-column">

        <!-- Section 1: Schema Type Checkboxes -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-3">Tipos de Schema</p>
          <div class="space-y-3">
            <label class="flex items-start gap-3 rounded-xl border-2 border-[#4f39f6] bg-[#f5f3ff] p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-local" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" checked />
              <div class="flex-1">
                <span class="text-[14px] font-semibold text-[#292524]">LocalBusiness</span>
                <p class="text-[12px] text-[#79716b] mt-0.5">Nombre, dirección, teléfono, horarios, reseñas, coordenadas geográficas</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-faq" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <span class="text-[14px] font-semibold text-[#292524]">FAQPage</span>
                <p class="text-[12px] text-[#79716b] mt-0.5">Pares de preguntas y respuestas. Aparecen como desplegables en los resultados de búsqueda</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-service" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="text-[14px] font-semibold text-[#292524]">Service</span>
                  <span class="rounded-full bg-[#fef3c7] px-2 py-0.5 text-[10px] font-bold uppercase text-[#92400e]">Único</span>
                </div>
                <p class="text-[12px] text-[#79716b] mt-0.5">Entradas de servicio individuales con información del proveedor. Raramente generado por otras herramientas</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-breadcrumb" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <span class="text-[14px] font-semibold text-[#292524]">BreadcrumbList</span>
                <p class="text-[12px] text-[#79716b] mt-0.5">Ruta de navegación. Ayuda a Google a entender la estructura del sitio</p>
              </div>
            </label>
          </div>
        </div>

        <!-- Section 2: Industry Selector -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="industry-select">Industria</label>
          <select id="industry-select" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors cursor-pointer">
            <option value="">Selecciona tu industria (auto-rellena los campos)</option>
            <option value="dentist">Dentista</option>
            <option value="chiropractor">Quiropráctico</option>
            <option value="orthodontist">Ortodoncista</option>
            <option value="optometrist">Optometrista</option>
            <option value="dermatologist">Dermatólogo</option>
            <option value="plumber">Plomero</option>
            <option value="hvac">HVAC / Climatización</option>
            <option value="electrician">Electricista</option>
            <option value="roofing">Techado</option>
            <option value="landscaping">Jardinería</option>
            <option value="pest_control">Control de Plagas</option>
            <option value="auto_repair">Reparación de Autos</option>
            <option value="lawyer">Abogado</option>
            <option value="accountant">Contador</option>
            <option value="realtor">Agente Inmobiliario</option>
            <option value="insurance">Agencia de Seguros</option>
            <option value="financial_advisor">Asesor Financiero</option>
            <option value="restaurant">Restaurante</option>
            <option value="salon">Salón / Spa</option>
            <option value="gym">Gimnasio / Fitness</option>
            <option value="veterinarian">Veterinario</option>
            <option value="cleaning">Servicio de Limpieza</option>
            <option value="moving">Empresa de Mudanzas</option>
            <option value="other">Otro / General</option>
          </select>
          <p class="mt-1 text-[11px] text-[#79716b]">Establece tu tipo de schema y pre-rellena los servicios y sugerencias de FAQ.</p>
        </div>

        <!-- Section 3: LocalBusiness Fields -->
        <div id="section-local" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 space-y-4">
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1">Detalles del Negocio</p>

          <!-- Core Info -->
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-name">Nombre del Negocio <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obligatorio</span></label>
            <input type="text" id="f-name" placeholder="ej., Odontología Familia García" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-description">Descripción <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
            <textarea id="f-description" rows="2" placeholder="Breve descripción de tu negocio..." class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors resize-none"></textarea>
          </div>

          <!-- Contact -->
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-phone">Teléfono <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obligatorio</span></label>
              <input type="tel" id="f-phone" placeholder="(55) 1234-5678" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-email">Correo electrónico <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
              <input type="email" id="f-email" placeholder="info@ejemplo.com" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-url">URL del Sitio Web <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obligatorio</span></label>
            <input type="url" id="f-url" placeholder="https://www.ejemplo.com" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>

          <!-- Address -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Dirección</p>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-street">Calle y Número <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obligatorio</span></label>
            <input type="text" id="f-street" placeholder="Av. Principal 123, Piso 2" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-city">Ciudad <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Obligatorio</span></label>
              <input type="text" id="f-city" placeholder="Ciudad de México" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-state">Estado / Provincia <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
              <input type="text" id="f-state" placeholder="CDMX" maxlength="2" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-zip">Código Postal <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
              <input type="text" id="f-zip" placeholder="06600" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-country">País <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
            <input type="text" id="f-country" placeholder="MX" value="MX" maxlength="2" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>

          <!-- Media & Rating -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Multimedia y Valoración</p>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-logo">URL del Logo <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
              <input type="url" id="f-logo" placeholder="https://ejemplo.com/logo.png" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-image">URL de Imagen <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></label>
              <input type="url" id="f-image" placeholder="https://ejemplo.com/foto.jpg" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-price">Rango de Precios <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
            <select id="f-price" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors cursor-pointer">
              <option value="">Selecciona el rango de precios...</option>
              <option value="$">$. Económico</option>
              <option value="$$">$$. Moderado</option>
              <option value="$$$">$$$. Premium</option>
              <option value="$$$$">$$$$. Lujo</option>
            </select>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-rating">Valoración <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
              <input type="number" id="f-rating" placeholder="4.8" min="1" max="5" step="0.1" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-reviewcount">Número de Reseñas <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></label>
              <input type="number" id="f-reviewcount" placeholder="127" min="0" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>

          <!-- Opening Hours -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Horario de Apertura <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recomendado</span></p>
          <div id="hours-container" class="space-y-2"></div>
          <button type="button" id="btn-copy-hours" class="mt-2 cursor-pointer rounded-lg border border-[#e7e5e4] px-3 py-1.5 text-[12px] font-medium text-[#57534e] hover:border-[#c4b5fd] hover:text-[#4f39f6] transition-colors">Copiar horario del lunes a los días de semana</button>

          <!-- Geo -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Coordenadas Geográficas <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></p>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-lat">Latitud</label>
              <input type="text" id="f-lat" placeholder="19.4326" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-lng">Longitud</label>
              <input type="text" id="f-lng" placeholder="-99.1332" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>

          <!-- Social Profiles -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Perfiles Sociales <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Opcional</span></p>
          <div class="space-y-2" id="social-container">
            <input type="url" class="social-url w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" placeholder="https://facebook.com/tunegocio" />
            <input type="url" class="social-url w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" placeholder="https://instagram.com/tunegocio" />
            <input type="url" class="social-url w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" placeholder="https://linkedin.com/company/tunegocio" />
          </div>
        </div>

        <!-- Section 4: FAQ Fields -->
        <div id="section-faq" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 hidden">
          <div class="flex items-center justify-between mb-4">
            <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Entradas de FAQ</p>
            <button type="button" id="btn-add-faq" class="cursor-pointer rounded-lg bg-[#f5f3ff] px-3 py-1.5 text-[12px] font-semibold text-[#4f39f6] hover:bg-[#ede9fe] transition-colors">+ Añadir FAQ</button>
          </div>
          <div id="faq-list" class="space-y-4"></div>
