---
import ToolLayout from '../../../components/tools/ToolLayout.astro';

const pageTitle = 'Herramienta de Auditoría SEO Gratuita (Lite) | theStacc';
const pageDescription = 'Obtén un informe rápido de SEO para tu sitio web. 10 verificaciones críticas con calificación aprobado/reprobado e instrucciones de corrección en español simple. Gratis, instantáneo, sin registro.';

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Herramienta de Auditoría SEO Gratuita (Lite)',
  description: 'Obtén un informe rápido de SEO para tu sitio web. 10 verificaciones críticas con calificación por letra, resultados aprobado/reprobado e instrucciones de corrección en lenguaje simple para negocios locales.',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Organization', name: 'theStacc', url: 'https://thestacc.com' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Qué verifica esta auditoría SEO?', acceptedAnswer: { '@type': 'Answer', text: 'Esta herramienta realiza 10 verificaciones SEO críticas: etiqueta de título, meta descripción, etiqueta H1, velocidad de página, compatibilidad móvil, seguridad HTTPS, texto alternativo de imágenes, enlaces internos, schema markup y longitud del contenido. Cada verificación se puntúa individualmente y se combina en una calificación de letra de A a F.' } },
    { '@type': 'Question', name: '¿Por qué solo 10 verificaciones en lugar de 200?', acceptedAnswer: { '@type': 'Answer', text: 'La mayoría de las herramientas de auditoría SEO te abruman con cientos de advertencias técnicas, la mayoría de las cuales tienen un impacto mínimo en los rankings. Estas 10 verificaciones cubren los fundamentos que realmente marcan la diferencia para los negocios locales. Corrígelos primero y verás mejoras reales en tus posiciones de búsqueda.' } },
    { '@type': 'Question', name: '¿Qué significan las calificaciones de letra?', acceptedAnswer: { '@type': 'Answer', text: 'A (90-100) significa que tus fundamentos SEO son excelentes. B (75-89) significa que está bien con pequeñas mejoras necesarias. C (60-74) significa que tu sitio necesita trabajo en varias áreas. D (40-59) significa que la salud SEO es deficiente con múltiples problemas. F (menos de 40) significa problemas críticos que probablemente están afectando tus rankings.' } },
    { '@type': 'Question', name: '¿Esta herramienta de auditoría SEO es gratuita?', acceptedAnswer: { '@type': 'Answer', text: 'Sí, 100% gratuita. Sin registro, sin correo electrónico requerido, sin límites. Ingresa tu URL, obtén tu informe en segundos. Todo se ejecuta en tu navegador. No se almacenan datos en nuestros servidores.' } },
    { '@type': 'Question', name: '¿En qué se diferencia de la herramienta de Puntuación SEO del Sitio Web?', acceptedAnswer: { '@type': 'Answer', text: 'La herramienta de Puntuación SEO del Sitio Web realiza más de 30 verificaciones en 6 categorías que incluyen SEO local, reseñas y preparación para IA. Esta Auditoría SEO (Lite) se enfoca en solo las 10 verificaciones más críticas para un resumen ejecutivo rápido. Usa esta herramienta para una comprobación rápida de salud, y la Puntuación SEO completa para un análisis profundo.' } },
    { '@type': 'Question', name: '¿Qué debo hacer después de obtener mis resultados de auditoría?', acceptedAnswer: { '@type': 'Answer', text: 'Comienza con la sección de Top 3 Prioridades. Están clasificadas por impacto, por lo que corregirlas primero ofrece la mayor mejora. Cada verificación fallida incluye una instrucción de corrección en lenguaje simple. Para una mejora SEO continua, considera ejecutar el verificador completo de Puntuación SEO del Sitio Web y usar nuestras otras herramientas gratuitas.' } },
  ],
};
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Auditoría SEO Gratuita, Informe de 10 Puntos"
  toolDescription="Verifica las 10 cosas que realmente importan para tus rankings. Obtén una calificación de letra, correcciones específicas y ve cómo aparece tu página en los resultados de búsqueda."
  lang="es"
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <Fragment slot="head">
  </Fragment>

  <!-- ==================== TOOL ==================== -->
  <Fragment slot="tool">
    <!-- URL Input -->
    <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
      <div class="space-y-4">
        <div>
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">URL del Sitio Web <span class="text-red-500">*</span></label>
          <input
            type="url"
            id="url-input"
            required
            placeholder="ej., familiadental.com"
            class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors"
          />
        </div>
        <details>
          <summary class="cursor-pointer text-[13px] font-medium text-[#615fff]">+ Añadir una palabra clave objetivo (opcional)</summary>
          <div class="mt-2">
            <input type="text" id="keyword-input" maxlength="100" placeholder="ej., dentista en Madrid, plomero cerca de mí" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            <p class="mt-1 text-[11px] text-[#79716b]">Añadir una palabra clave verifica si tu título, descripción y H1 la contienen</p>
          </div>
        </details>
        <button id="audit-btn" class="w-full rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3.5 font-mono text-sm font-bold uppercase text-white hover:bg-[#4f39f6] cursor-pointer disabled:opacity-50 transition-colors">
          Ejecutar Auditoría SEO
        </button>
      </div>
      <p id="url-error" class="mt-2 hidden text-xs text-red-500"></p>
    </div>

    <!-- Loading State -->
    <div id="loading-section" class="mt-6 hidden rounded-2xl border border-[#e7e5e4] bg-white p-6">
      <div class="space-y-3">
        <div class="flex items-center gap-3 step" data-step="fetch">
          <span class="step-icon w-5 h-5 text-[#79716b]"><svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg></span>
          <span class="text-[14px] text-[#57534e]">Obteniendo tu sitio web&hellip;</span>
        </div>
        <div class="flex items-center gap-3 step" data-step="audit">
          <span class="step-icon w-5 h-5 text-[#79716b]"><svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg></span>
          <span class="text-[14px] text-[#57534e]">Ejecutando auditoría de 10 puntos&hellip;</span>
        </div>
        <div class="flex items-center gap-3 step" data-step="report">
          <span class="step-icon w-5 h-5 text-[#79716b]"><svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg></span>
          <span class="text-[14px] text-[#57534e]">Generando tu informe&hellip;</span>
        </div>
      </div>
    </div>

    <!-- Error State -->
    <div id="error-section" class="mt-6 hidden rounded-2xl border border-red-200 bg-red-50 p-6 text-center">
      <svg class="mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
      <p class="text-[15px] text-red-700 font-medium">Algo salió mal</p>
      <p id="error-message" class="mt-1 text-[13px] text-red-600">Verifica la URL e inténtalo de nuevo. Asegúrate de que el sitio web sea accesible públicamente.</p>
    </div>

    <!-- Results Section -->
    <div id="results-section" class="mt-6 hidden space-y-6">
      <!-- Grade Circle -->
      <div id="grade-hero" class="rounded-2xl border border-[#e7e5e4] bg-white p-8 flex flex-col items-center text-center"></div>

      <!-- Top 3 Priorities -->
      <div id="priorities-section" class="hidden rounded-2xl border-2 border-[#615fff] bg-[#f5f3ff] p-6">
        <h3 class="font-sans text-[17px] font-semibold text-[#292524] mb-4">Corrige Estas 3 Cosas Primero</h3>
        <div id="priorities-list" class="space-y-4"></div>
      </div>

      <!-- Keyword Analysis -->
      <div id="keyword-section" class="hidden rounded-2xl border border-[#e7e5e4] bg-white p-6">
        <h3 class="font-sans text-[17px] font-semibold text-[#292524] mb-4">Análisis de Palabras Clave</h3>
        <div id="keyword-grid" class="grid grid-cols-2 md:grid-cols-4 gap-3"></div>
      </div>

      <!-- 10 Checks -->
      <div id="checks-section" class="space-y-3"></div>

      <!-- SERP Preview -->
      <div id="serp-section" class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
        <h3 class="font-sans text-[17px] font-semibold text-[#292524] mb-4">Vista Previa en Google</h3>
        <div id="serp-preview" class="max-w-xl"></div>
      </div>
    </div>
    </div>
  </Fragment>

  <!-- ==================== CTA ==================== -->
  <Fragment slot="cta">
    <section id="cta-banner" class="hidden relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.45) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center"><div class="mx-auto max-w-lg">
        <p id="cta-headline" class="font-sans text-[22px] font-bold leading-tight text-white"></p>
        <p id="cta-subtext" class="mt-3 font-sans text-[15px] leading-relaxed text-[#94a3b8]"></p>
        <a href="/es/demo/" class="mt-6 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">Inicia tu Prueba por $1 &rarr;</a>
        <p class="mt-3 font-mono text-xs text-[#64748b]">$1 por 30 días · Cancela cuando quieras</p></div>
      </div>
    </section>
  </Fragment>

  <!-- ==================== SEO CONTENT ==================== -->
  <Fragment slot="content">
    <h2 class="text-xl font-semibold text-[#292524] mb-3">¿Qué Verifica Esta Auditoría SEO?</h2>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Esta herramienta evalúa los 10 elementos SEO más importantes de cualquier página web. Cada verificación se puntúa individualmente y se combina en una calificación de letra de A a F. Esto es lo que se verifica y por qué cada uno importa para tus posiciones en búsqueda.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Etiqueta de título</strong> es el enlace azul en los resultados de Google. Debe existir, tener la longitud correcta (10-60 caracteres) e idealmente contener tu palabra clave objetivo. <strong class="text-[#292524]">Meta descripción</strong> es el fragmento debajo de ese enlace. Google la usa para decidir si tu página coincide con la intención de un buscador. <strong class="text-[#292524]">Etiqueta H1</strong> es tu titular principal y le dice a Google de qué trata tu página. Deberías tener exactamente un H1 por página.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Velocidad de página</strong> afecta directamente los rankings y si los visitantes se quedan o rebotan. <strong class="text-[#292524]">Compatibilidad móvil</strong> importa porque más del 60% de las búsquedas ocurren en teléfonos. <strong class="text-[#292524]">HTTPS</strong> es un requisito de seguridad básico por el que Google te penaliza si lo incumples.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Texto alternativo de imágenes</strong> ayuda a Google a entender tus imágenes y mejora la accesibilidad. <strong class="text-[#292524]">Enlaces internos</strong> ayudan a los motores de búsqueda a descubrir y entender las relaciones entre tus páginas. <strong class="text-[#292524]">Schema markup</strong> le da a Google datos estructurados sobre tu negocio. <strong class="text-[#292524]">Longitud del contenido</strong> indica profundidad y autoridad. Las páginas delgadas con menos de 100 palabras raramente se posicionan bien.</p>

    <h2 class="text-xl font-semibold text-[#292524] mt-8 mb-3">¿Por Qué Solo 10 Verificaciones? (Y Por Qué Eso Es Mejor)</h2>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">La mayoría de las herramientas de auditoría SEO te abruman con más de 200 advertencias técnicas. Etiquetas hreflang faltantes. CSS que bloquea el renderizado. Violaciones de jerarquía de encabezados de cuarto nivel. El resultado es un PDF de 47 páginas que se queda sin leer en tu carpeta de descargas para siempre.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">La verdad es que para la mayoría de los negocios locales, <strong class="text-[#292524]">10 verificaciones cubren el 80% de lo que importa</strong>. Estos son los fundamentos que Google pondera más cuando decide si mostrar tu sitio web o el de tu competidor. Un dentista en Madrid no necesita preocuparse por el SEO internacional o las cadenas de etiquetas canónicas. Necesitan una etiqueta de título adecuada, una página móvil rápida, HTTPS y datos estructurados.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Esta herramienta te da señales, no ruido. Cada verificación que falla viene con una instrucción de corrección específica y accionable escrita en lenguaje simple. Sin jerga. Sin "consulta a tu desarrollador". Solo "esto es lo que está mal y así es como lo corriges". Esa es la diferencia entre una auditoría que lees y una que implementas.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Si quieres el análisis profundo con más de 30 verificaciones en SEO local, preparación para IA, reseñas y velocidad de contenido, usa nuestra herramienta de <a href="/es/herramientas/puntuacion-seo-sitio/" class="text-[#615fff] hover:underline">Puntuación SEO del Sitio Web</a>. Pero comienza aquí primero.</p>

    <h2 class="text-xl font-semibold text-[#292524] mt-8 mb-3">Cómo Leer Tu Informe de Auditoría SEO</h2>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Tu calificación de letra se calcula a partir de una puntuación de 100 puntos. Cada una de las 10 verificaciones contribuye con un número específico de puntos, ponderado por importancia. La velocidad de página y el HTTPS tienen más peso que el recuento de enlaces internos porque tienen un mayor impacto en los rankings.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Calificación A (90-100):</strong> Tus fundamentos SEO son excelentes. Sigue haciendo lo que haces y enfócate en la creación de contenido y la generación de reseñas. <strong class="text-[#292524]">Calificación B (75-89):</strong> Buena base con algunas áreas a mejorar. Revisa las Top 3 Prioridades para victorias rápidas. <strong class="text-[#292524]">Calificación C (60-74):</strong> Tu sitio necesita trabajo. Varias verificaciones importantes están fallando y probablemente te están costando posiciones.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Calificación D (40-59):</strong> Salud SEO deficiente. Múltiples problemas fundamentales necesitan atención. Comienza con la prioridad máxima y trabaja hacia abajo. <strong class="text-[#292524]">Calificación F (menos de 40):</strong> Problemas críticos. Tu sitio probablemente es invisible para los motores de búsqueda en consultas competitivas. La buena noticia es que corregir los aspectos básicos puede producir mejoras dramáticas rápidamente.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Siempre comienza con la sección de <strong class="text-[#292524]">Top 3 Prioridades</strong>. Estas son las correcciones de mayor impacto clasificadas por puntos potenciales ganados. Corregir las tres a menudo puede hacerte subir toda una calificación de letra.</p>

    <h2 class="text-xl font-semibold text-[#292524] mt-8 mb-3">Auditoría SEO vs Puntuación SEO Completa</h2>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Esta Auditoría SEO (Lite) y nuestra herramienta de <a href="/es/herramientas/puntuacion-seo-sitio/" class="text-[#615fff] hover:underline">Puntuación SEO del Sitio Web</a> sirven diferentes propósitos. La auditoría es tu resumen ejecutivo: 10 verificaciones críticas, una calificación de letra e instrucciones de corrección claras. Se ejecuta más rápido y te da un sí-o-no rápido sobre los fundamentos.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">La Puntuación SEO completa realiza más de 30 verificaciones en 6 categorías: SEO en la página, salud técnica, señales de contenido, SEO local, salud de reseñas y preparación para IA. Evalúa tu Google Business Profile, verifica archivos llms.txt, analiza la frescura de tu contenido y puntúa tu presencia de reseñas. Si te tomas en serio posicionarte en tu mercado local, ejecuta la puntuación completa después de pasar esta auditoría.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Piénsalo así: esta auditoría te dice si tu casa tiene techo, paredes y cimientos. La puntuación completa verifica la plomería, la electricidad, el aislamiento y el paisajismo también. Ambas importan. Comienza con lo básico.</p>

    <h2 class="text-xl font-semibold text-[#292524] mt-8 mb-3">Problemas SEO Comunes para Negocios Locales</h2>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Consultorios dentales</strong> comúnmente tienen páginas de servicios con menos de 100 palabras y omiten el schema markup por completo. La mayoría de los sitios web dentales usan etiquetas de título genéricas como "Inicio - Dental García" en lugar de títulos ricos en palabras clave como "Dentista Familiar en Madrid | Dental García". Corregir la etiqueta de título por sí solo puede mejorar las tasas de clics entre un 20-30%.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Bufetes de abogados</strong> tienden a tener una buena longitud de contenido pero bases técnicas débiles. HTTPS faltante, velocidades de página lentas por imágenes no optimizadas y sin datos estructurados son los problemas más comunes. Dado que un solo cliente nuevo puede valer miles de euros, incluso pequeñas mejoras en el ranking ofrecen retornos desproporcionados.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Negocios de servicios del hogar</strong> (plomeros, climatización, electricistas) típicamente obtienen las puntuaciones más bajas porque dependen de sitios web de una sola página o plantillas básicas. La corrección más impactante es crear páginas de servicio individuales con etiquetas H1 adecuadas, meta descripciones únicas y más de 300 palabras de contenido para cada servicio ofrecido.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3"><strong class="text-[#292524]">Restaurantes</strong> a menudo tienen menús como PDFs o imágenes que Google no puede leer, texto alternativo faltante en fotografías de comida y sin schema markup. Agregar schema Restaurant y convertir tu menú a texto HTML son dos correcciones que pueden mejorar dramáticamente tu visibilidad en las búsquedas locales de comida.</p>

    <h2 class="mt-10 font-sans text-[20px] font-bold tracking-[-0.02em] text-[#292524]">Preguntas Frecuentes</h2>
    <div class="overflow-hidden rounded-2xl border border-[#e5e7eb] bg-white shadow-sm">
    <div class="border-b border-[#f3f4f6]">
      <button class="tool-faq-btn flex w-full cursor-pointer items-start justify-between gap-4 px-6 py-5 text-left transition-colors hover:bg-[#fafafa]" aria-expanded="false">
        <span class="font-sans text-[15px] font-semibold text-[#111827]">¿Qué verifica esta auditoría SEO?</span>
        <svg class="tool-faq-plus mt-0.5 shrink-0 text-[#9ca3af]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <svg class="tool-faq-minus hidden mt-0.5 shrink-0 text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <div class="tool-faq-answer hidden px-6 pb-5">
        <p class="font-sans text-[14px] leading-[1.7] text-[#4b5563]">Esta herramienta realiza 10 verificaciones SEO críticas: etiqueta de título, meta descripción, etiqueta H1, velocidad de página, compatibilidad móvil, seguridad HTTPS, texto alternativo de imágenes, enlaces internos, schema markup y longitud del contenido. Cada verificación se puntúa individualmente y se combina en una calificación de letra de A a F.</p>
      </div>
    </div>
    <div class="border-b border-[#f3f4f6]">
      <button class="tool-faq-btn flex w-full cursor-pointer items-start justify-between gap-4 px-6 py-5 text-left transition-colors hover:bg-[#fafafa]" aria-expanded="false">
        <span class="font-sans text-[15px] font-semibold text-[#111827]">¿Por qué solo 10 verificaciones en lugar de 200?</span>
        <svg class="tool-faq-plus mt-0.5 shrink-0 text-[#9ca3af]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        <svg class="tool-faq-minus hidden mt-0.5 shrink-0 text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <div class="tool-faq-answer hidden px-6 pb-5">
