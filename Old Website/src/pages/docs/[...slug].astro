---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocsHeader from '../../components/docs/DocsHeader.astro';
import DocsSidebar from '../../components/docs/DocsSidebar.astro';
import { getAllDocPaths, getNextDoc, getPrevDoc } from '../../data/docs';
import type { DocsCategory, DocsPage } from '../../data/docs';
import { renderDocsMarkdown, extractHeadings } from '../../utils/docsMarkdown';

export async function getStaticPaths() {
  return getAllDocPaths();
}

interface Props {
  category: DocsCategory;
  page: DocsPage;
}

const { category, page } = Astro.props;
const htmlContent = await renderDocsMarkdown(page.content);
const headings = extractHeadings(page.content);
const nextDoc = getNextDoc(category.slug, page.slug);
const prevDoc = getPrevDoc(category.slug, page.slug);

const breadcrumbs = [
  { label: category.name, href: '/docs' },
  { label: page.title },
];
---

<BaseLayout
  title={`${page.title} - theStacc Docs`}
  description={page.description}
  noBorders
>
  <DocsHeader breadcrumbs={breadcrumbs} showCopyPage />
  <div class="min-h-[calc(100vh-56px)] pt-14 lg:pl-[256px]">
    <DocsSidebar currentCategorySlug={category.slug} currentPageSlug={page.slug} />

    <!-- Main content area -->
    <main class="min-w-0">
      <div class="flex">
        <!-- Article -->
        <article class="flex-1 min-w-0 px-6 pt-8 pb-16 md:px-12 lg:pr-8">
          <!-- Title -->
          <h1 class="font-sans text-[36px] leading-[44px] font-semibold text-[#292524]">
            {page.title}
          </h1>
          <p class="mt-3 font-sans text-[16px] leading-[26px] text-[#79716b] max-w-[640px]">
            {page.description}
          </p>

          <!-- Content -->
          <div class="docs-content mt-8 max-w-[680px]">
            <Fragment set:html={htmlContent} />
          </div>

          <!-- Prev / Next navigation -->
          <div class="mt-14 flex items-stretch gap-4 max-w-[680px]">
            {prevDoc ? (
              <a
                href={`/docs/${prevDoc.category.slug}/${prevDoc.page.slug}`}
                class="group flex flex-1 items-center gap-3 rounded-xl border border-[#e7e5e4] px-5 py-4 transition-colors hover:bg-[#fafaf9]"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-[#79716b] group-hover:text-[#4f39f6] transition-colors"><path d="m15 18-6-6 6-6"/></svg>
                <div class="flex flex-col">
                  <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.6px] text-[#79716b]">Previous</span>
                  <span class="mt-1 font-sans text-[14px] font-medium text-[#292524] group-hover:text-[#4f39f6] transition-colors">
                    {prevDoc.page.title}
                  </span>
                </div>
              </a>
            ) : <div class="flex-1" />}
            {nextDoc ? (
              <a
                href={`/docs/${nextDoc.category.slug}/${nextDoc.page.slug}`}
                class="group flex flex-1 items-center justify-end gap-3 rounded-xl border border-[#e7e5e4] px-5 py-4 transition-colors hover:bg-[#fafaf9]"
              >
                <div class="flex flex-col items-end">
                  <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.6px] text-[#79716b]">Next</span>
                  <span class="mt-1 font-sans text-[14px] font-medium text-[#292524] group-hover:text-[#4f39f6] transition-colors">
                    {nextDoc.page.title}
                  </span>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-[#79716b] group-hover:text-[#4f39f6] transition-colors"><path d="m9 18 6-6-6-6"/></svg>
              </a>
            ) : <div class="flex-1" />}
          </div>
        </article>

        <!-- Table of Contents (right sidebar) -->
        {headings.length > 0 && (
          <aside class="hidden xl:block w-[220px] shrink-0 pt-8 pr-6 overflow-visible">
            <div class="sticky top-20">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.6px] text-[#79716b] mb-3">
                On this page
              </p>
              <nav id="docs-toc" class="space-y-0.5">
                {headings.map((heading) => (
                  <a
                    href={`#${heading.id}`}
                    class={`docs-toc-link block py-1 text-[13px] leading-[18px] transition-colors border-l-2 border-transparent ${
                      heading.level === 3 ? 'pl-5' : 'pl-3'
                    } text-[#79716b] hover:text-[#4f39f6] hover:border-l-[#4f39f6]`}
                    data-heading-id={heading.id}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )}
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  // Copy-to-clipboard for code blocks
  document.querySelectorAll('.docs-code .docs-code-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const block = btn.closest('.docs-code');
      const code = block?.querySelector('pre code');
      if (!code) return;
      const text = (code as HTMLElement).innerText.replace(/\n$/, '');
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      btn.classList.add('copied');
      const label = btn.querySelector('.docs-code-copy-label');
      if (label) label.textContent = 'Copied';
      setTimeout(() => {
        btn.classList.remove('copied');
        if (label) label.textContent = 'Copy';
      }, 1600);
    });
  });

  // Click any heading anchor (#) → copy that section's full URL to clipboard
  document.querySelectorAll('.docs-content .heading-anchor').forEach((anchor) => {
    anchor.addEventListener('click', async (e) => {
      e.preventDefault();
      const id = anchor.getAttribute('href')?.slice(1);
      if (!id) return;
      const url = `${window.location.origin}${window.location.pathname}#${id}`;
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = url;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      history.replaceState(null, '', `#${id}`);
      document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
      anchor.classList.add('copied');
      setTimeout(() => anchor.classList.remove('copied'), 1500);
    });
  });

  // Active ToC tracking on scroll
  const tocLinks = document.querySelectorAll('.docs-toc-link');
  if (tocLinks.length > 0) {
    const headingEls = Array.from(tocLinks).map((link) => {
      const id = link.getAttribute('data-heading-id');
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    function updateActiveToc() {
      let activeIndex = 0;

      // If scrolled to bottom, highlight last heading
      if (window.innerHeight + window.scrollY >= document.body.scrollHeight - 50) {
        activeIndex = headingEls.length - 1;
      } else {
        const scrollY = window.scrollY + 100;
        for (let i = headingEls.length - 1; i >= 0; i--) {
          if (headingEls[i].offsetTop <= scrollY) {
            activeIndex = i;
            break;
          }
        }
      }

      tocLinks.forEach((link, i) => {
        if (i === activeIndex) {
          link.classList.add('text-[#4f39f6]', 'border-l-[#4f39f6]', 'font-medium');
          link.classList.remove('text-[#79716b]', 'border-transparent');
        } else {
          link.classList.remove('text-[#4f39f6]', 'border-l-[#4f39f6]', 'font-medium');
          link.classList.add('text-[#79716b]', 'border-transparent');
        }
      });
    }

    window.addEventListener('scroll', updateActiveToc, { passive: true });
    updateActiveToc();
  }
</script>
