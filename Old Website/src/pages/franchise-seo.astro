---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  { q: "What is franchise SEO?", a: "Franchise SEO is the practice of optimizing local search visibility for franchise businesses across multiple locations. Each franchise location needs its own Google Business Profile managed, its own local citations maintained, and its own local keyword rankings tracked — while the brand's consistency is maintained across all." },
  { q: "What's the biggest SEO challenge unique to franchises?", a: "Consistency at scale. Every location needs the same baseline SEO work done correctly — accurate citations, active GBP, strong review profiles. But with 50 or 500 locations, you can't do it manually. The locations that get attention rank. The ones that don't, don't. Automation is the only way to apply consistent SEO effort across your entire network." },
  { q: "How does Stacc handle the franchisor vs. franchisee dynamic?", a: "Stacc supports tiered access. Franchisors get a portfolio view of all locations with performance comparison. Franchisees can access their own location's dashboard. Centralized management and individual visibility can coexist in the same platform." },
  { q: "Can Stacc manage GBP for 200 franchise locations?", a: "Yes. Stacc publishes GBP posts to all locations simultaneously. Bulk updates to hours, descriptions, and attributes apply across all locations in a single action. There's no practical limit on location count." },
  { q: "How do I maintain brand consistency in GBP posts across locations?", a: "Stacc's bulk publishing lets you write one post and publish it to all locations simultaneously. You can add location-specific customizations (address, local phone, local hashtags) before bulk-publishing. Core brand messaging stays consistent; local details get localized." },
  { q: "How quickly can I onboard a new franchise location?", a: "About 2 minutes. Enter the core business data, connect the GBP listing, and Stacc propagates setup across your citation network automatically. No manual directory-by-directory entry." },
  { q: "What does franchise SEO software cost?", a: "Stacc's Local SEO module starts at $49/month and includes all multi-location and franchise management features." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Franchise SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Franchise SEO automation that manages GBP, citations, rankings, and reporting across every franchise location simultaneously.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Franchise SEO", "item": "https://thestacc.com/franchise-seo/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Franchise SEO — Automate Local SEO Across Every Franchise Location | theStacc"
  description="Franchise SEO at scale requires automation. theStacc manages GBP, citations, rank tracking, and reporting for every franchise location simultaneously — consistent brand, local performance."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Franchise SEO · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Franchise SEO that runs<br />
            <span style="color:#4f39f6;">across your whole network.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Every franchise location needs consistent, daily local SEO work to rank in its market. Stacc automates that work across your entire network — so every location competes at full strength, not just the ones someone remembered to update.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/solutions/franchises/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See franchise features
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The franchise SEO problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Some locations rank. Most don't.<br />Because most don't get consistent SEO.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>In every franchise network, there's a familiar pattern: a handful of top-performing locations that rank consistently, and a long tail of underperformers that are invisible in local search. The difference almost always isn't quality of service — it's quality of local SEO execution. The ranking locations have active GBP profiles, consistent citations, and recent reviews. The invisible ones have stale listings, NAP discrepancies, and profiles that haven't been touched in months.</p>
            <p>The reason isn't neglect — it's capacity. There's no way to manually maintain proper local SEO across 50 or 500 locations. Something always gets skipped. Stacc ensures nothing gets skipped by automating every ongoing SEO task for every location automatically.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Franchise SEO capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every location. Every task.<br />All automated.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Bulk GBP management', body: 'Publish posts to all franchise locations simultaneously. Bulk-update hours, descriptions, and attributes across the entire network in one action.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Per-location rank tracking', body: 'Daily rankings for each location in local pack, Maps, and organic. Compare all locations side by side to identify which markets need attention.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Citation consistency monitoring', body: 'Detect and flag NAP inconsistencies across 50+ directories for every location. Consistent citations are a core local ranking factor.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Review monitoring by location', body: 'Real-time review alerts for every franchise location. Respond from a central dashboard. Track review performance per location.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Network performance reporting', body: 'Portfolio dashboard compares all locations. Identify top and bottom performers instantly. Generate automated reports for the whole network or individual locations.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Tiered access for franchisees', body: 'Franchisors see the full network. Franchisees see their own locations. Centralized management with individual accountability.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 500, suffix: '+', label: 'Franchise locations in one account', sub: 'No per-location staff required' },
            { to: 2, suffix: ' min', label: 'To onboard a new location', sub: 'From zero to fully managed' },
            { to: 89, suffix: '%', label: 'GBP ranking lift in 90 days', sub: 'Consistent activity vs inactive baseline' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Franchise SEO:<br />common questions answered.
          </h2>
          <div class="mt-10 divide-y divide-[#e7e5e4]">
            {faqs.map((f, i) => (
              <div class="py-5">
                <button class="faq-btn flex w-full items-start justify-between gap-4 text-left" aria-expanded="false">
                  <span class="font-sans text-[1rem] font-semibold text-[#111827]">{f.q}</span>
                  <span class="mt-0.5 flex-shrink-0">
                    <svg class="faq-icon-plus h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    <svg class="faq-icon-minus hidden h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                  </span>
                </button>
                <div class="faq-answer hidden pt-3">
                  <p class="font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Related resources</p>
        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {[
            { href: '/franchise-seo-software/', label: 'Franchise SEO Software' },
            { href: '/solutions/franchises/', label: 'Stacc for Franchises' },
            { href: '/multi-location-seo/', label: 'Multi-Location SEO' },
            { href: '/features/bulk-location-management/', label: 'Bulk Location Management' },
            { href: '/features/multi-location-reporting/', label: 'Multi-Location Reporting' },
            { href: '/local-seo-software/', label: 'Local SEO Software' },
            { href: '/features/citation-management/', label: 'Citation Management' },
            { href: '/features/rank-tracking/', label: 'Rank Tracking' },
          ].map(l => (
            <a href={l.href} class="flex items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 font-sans text-[13px] font-medium text-[#374151] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              {l.label}
            </a>
          ))}
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.35) 0%,transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-24 text-center">
        <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.8rem]">
          Every franchise location competing<br />at full strength in local search.
        </h2>
        <p class="mx-auto mt-5 max-w-[520px] font-sans text-[1rem] leading-[1.7]" style="color:#9ca3af;">Start your $1 trial today and get your entire network managed from day one.</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-12 items-center gap-2 rounded-xl bg-[#4f39f6] px-7 font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
            Start free — no credit card
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/pricing/" class="inline-flex h-12 items-center rounded-xl border border-white/15 bg-white/5 px-7 font-sans text-[15px] font-medium text-white/80 transition-colors hover:bg-white/10">See pricing</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      if (answer) answer.classList.toggle('hidden', expanded);
      btn.querySelector('.faq-icon-plus')?.classList.toggle('hidden', !expanded);
      btn.querySelector('.faq-icon-minus')?.classList.toggle('hidden', expanded);
    });
  });
  document.querySelectorAll<HTMLElement>('[data-count-up]').forEach(el => {
    const from = parseFloat(el.dataset.from || '0'), to = parseFloat(el.dataset.to || '0'), suffix = el.dataset.suffix || '', duration = 1800; let start: number | null = null;
    const obs = new IntersectionObserver(entries => {
      if (!entries[0].isIntersecting) return; obs.disconnect();
      const step = (ts: number) => { if (!start) start = ts; const p = Math.min((ts - start) / duration, 1); el.textContent = (from + (to - from) * (1 - Math.pow(1 - p, 3))).toFixed(0) + suffix; if (p < 1) requestAnimationFrame(step); };
      requestAnimationFrame(step);
    }, { threshold: 0.3 }); obs.observe(el);
  });
</script>
