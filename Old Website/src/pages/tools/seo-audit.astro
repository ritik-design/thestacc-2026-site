    <noscript><div class="mx-auto max-w-2xl px-6 py-12 text-center"><p class="text-[15px] text-[#79716b]">This tool requires JavaScript. Please enable it in your browser.</p></div></noscript>
    <script is:inline src="/js/audit-engine.js"></script>
    <script>
      (function() {
        const urlInput = document.getElementById('url-input');
        const auditBtn = document.getElementById('audit-btn');
        const urlError = document.getElementById('url-error');

        // Quick example buttons
        document.querySelectorAll('.quick-audit-example').forEach(btn => {
          btn.addEventListener('click', function() {
            const url = this.dataset.url;
            if (urlInput) urlInput.value = url;
            if (window.auditEngine) window.auditEngine.start(url);
          });
        });

        // Check for ?url= query param and auto-start
        const params = new URLSearchParams(window.location.search);
        const prefillUrl = params.get('url');
        if (prefillUrl && urlInput) {
          urlInput.value = prefillUrl;
          if (window.auditEngine) {
            window.auditEngine.start(prefillUrl);
          }
        }

        if (auditBtn) {
          auditBtn.addEventListener('click', function() {
            const url = urlInput?.value.trim();
            if (!url) {
              urlInput?.focus();
              return;
            }
            urlError?.classList.add('hidden');
            if (window.auditEngine) {
              window.auditEngine.start(url);
            }
          });
        }

        if (urlInput) {
          urlInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') { e.preventDefault(); auditBtn?.click(); }
          });
        }
      })();
    </script>
