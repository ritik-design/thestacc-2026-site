---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../lib/schema-builders';

const pageTitle = 'Free SEO Audit Tool — Real DR + Backlinks + 11 Categories | theStacc';
const pageDescription = 'Run a comprehensive SEO audit in 10 seconds. Real Domain Rating, live backlink count, organic traffic estimate, and 55+ checks across 11 categories. Free preview — no signup required.';
const pageUrl = 'https://thestacc.com/tools/seo-audit/';
const lastUpdated = '2026-05-11';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free SEO Audit Tool',
  description: 'Comprehensive SEO audit analyzing technical SEO, on-page optimization, content quality, performance, authority/backlinks, schema markup, AI readiness, GEO/AIO, images, security, and analytics. Pulls real DR, backlink, and organic traffic data from live SEO databases.',
  url: pageUrl,
});

const faqs = [
  { q: 'What does this SEO audit tool check?', a: 'This tool runs 55+ checks across 11 categories: Technical SEO (HTTPS, robots.txt, sitemap, viewport, canonical, redirects, mixed content, soft 404s, hreflang), On-Page SEO (title tags, meta descriptions, H1 structure, headings, internal links, Open Graph, Twitter Cards), Content Quality (word count, readability, duplication, blog presence, passage structure), Performance (LCP, CLS, INP, TTFB via Google PageSpeed API), Authority & Backlinks (real DR, backlink count, referring domains, organic traffic, top keywords from DataForSEO), Schema Markup (JSON-LD, LocalBusiness, BreadcrumbList, WebSite, Person, VideoObject), AI Search Readiness (FAQ structure, AI crawler access, Q&A patterns), GEO/AIO (llms.txt, passage structure, freshness), Images (alt text, optimization), Security (headers, HTTPS), and Analytics (GA4, GTM, Meta Pixel, LinkedIn).' },
  { q: 'How is this different from other free SEO audit tools?', a: 'Most free tools run 10-15 basic checks client-side using unreliable CORS proxies. Our audit runs server-side for reliable results, covers 55+ checks across 11 categories, crawls up to 50 pages, pulls real Domain Rating and backlink data from a live SEO database (same data source enterprise tools use), calls the Google PageSpeed Insights API for real Core Web Vitals including INP, audits GEO/AIO readiness for AI search engines, and uses AI analysis to assess content quality and generate personalized recommendations. The authority data alone — DR, backlinks, referring domains, organic traffic — is something no other free audit tool provides.' },
  { q: 'What is a good SEO audit score?', a: 'A score of 90-100 is excellent (Grade A) with strong SEO fundamentals across all categories. 75-89 is good (Grade B) — solid foundation with specific quick wins remaining. 60-74 is average (Grade C) — focused work in several categories could move you up significantly. 40-59 is poor (Grade D) — multiple critical gaps are likely holding your rankings back. Below 40 is failing (Grade F) — fundamental problems may be making your site nearly invisible in search. Most small business websites score 35-55 on their first audit.' },
  { q: 'What is Domain Rating (DR) and why does it matter?', a: 'Domain Rating is a 0-100 score that measures the strength of your backlink profile. It is calculated from the number of unique referring domains linking to your site, the authority of those domains, and the topical relevance of the links. Sites with DR 60+ can rank for competitive head terms. DR 40-60 typically ranks for medium-competition keywords. DR 20-40 ranks for long-tail keywords. Below DR 20, you are in the building phase. DR is not a Google metric — it is an industry-standard proxy used by Ahrefs, Semrush, and DataForSEO. Building DR takes months of consistent link-building through guest posts, PR, partnerships, and creating link-worthy content.' },
  { q: 'How do I improve my SEO audit score?', a: 'Start with the Top Priorities section — they are ranked by impact-to-effort ratio. Common quick wins (under 30 minutes): fix title tag length, write a meta description, add LocalBusiness schema, enable HTTPS, add a viewport meta tag, fix broken pages. Medium-effort fixes (1-3 hours): add FAQ schema, create an llms.txt file, add heading structure (exactly 1 H1 per page, 3+ H2s), improve internal linking, add alt text to images. High-effort (ongoing): build quality backlinks to improve DR, publish 800+ word service pages, optimize Core Web Vitals, create consistent blog content. The authority category (DR + backlinks) usually has the biggest long-term impact on rankings.' },
  { q: 'How accurate is the backlink and traffic data?', a: 'The Domain Rating, backlink count, referring domains, and organic traffic estimates are pulled live from DataForSEO — the same type of database used by enterprise SEO platforms. The DR uses a 0-100 scale that aligns with industry-standard metrics. Traffic estimates are based on observed rankings multiplied by keyword volume multiplied by position-specific CTR curves. Actual traffic varies by season, competition, and SERP feature changes, but the relative magnitude and competitive comparison are reliable. Very new sites (under 6 months) or sites with minimal crawl footprint may show limited data.' },
  { q: 'Is this SEO audit tool really free?', a: 'Yes. The audit preview is 100% free — you get your overall score, grade, top 2 priority issues, summary metrics, and a preview of all 11 category scores instantly. No credit card required. To unlock the full detailed report with all category breakdowns, step-by-step fix instructions, real DR/backlink data, top ranking keywords, and personalized recommendations, you enter your name, email, and phone. We never sell or share contact information.' },
  { q: 'How does theStacc help after the audit?', a: 'Every issue identified in your audit maps directly to a Stacc feature. Missing or weak title tags? Stacc auto-optimizes every title for search. No meta descriptions? Stacc writes click-worthy descriptions for every page. Thin content? Stacc publishes 30+ in-depth articles monthly in your brand voice. Low DR? Stacc places you in relevant articles and builds contextual links. Missing schema markup? Stacc auto-generates LocalBusiness and FAQ schema. No blog section? Stacc builds your entire content calendar from keyword research through publishing. Slow page speed? Stacc optimizes images and content delivery. No GBP activity? Stacc posts to your Google Business Profile daily.' },
  { q: 'How often should I run an SEO audit?', a: 'Run a comprehensive audit monthly if you are actively working on SEO, or quarterly for maintenance monitoring. Run an audit immediately after any major site change: redesign, CMS migration, URL restructuring, or bulk content publishing. Track your score over time — a 10-point improvement typically correlates with 15-25% organic traffic growth within 3-6 months. Set a baseline, fix the top 3 priorities, re-audit in 30 days, and repeat.' },
  { q: 'What is AI search readiness and why is it in my audit?', a: 'AI search readiness measures how well your website is structured to be cited by AI-powered search engines: ChatGPT, Perplexity, Google AI Overviews, Gemini, and Claude. We check four signals: FAQ schema or question-format H2 headings (AI Overviews pull from these first), whether your robots.txt blocks AI crawlers (GPTBot, ClaudeBot, PerplexityBot), the presence of an /llms.txt file (emerging standard for AI guidance), and whether content is structured with clear question-and-answer formatting that AI can extract. AI search is the fastest-growing discovery channel — sites optimized for it gain visibility as traditional search evolves.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free SEO Audit Tool"
  toolDescription="Comprehensive 11-category SEO audit with real Domain Rating, backlink data, and organic traffic estimates. 55+ checks, AI-powered analysis, free preview."
  hideHero={true}
  bleed={true}
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <!-- ==================== TOOL ==================== -->
  <Fragment slot="tool">
    <!-- ── HERO ── -->
    <div class="relative overflow-hidden" style="background: #0d1117;">
      <!-- Animated gradient orbs -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute -top-40 left-1/2 h-80 w-80 -translate-x-1/2 rounded-full opacity-20 blur-3xl" style="background: radial-gradient(circle, #4f39f6 0%, transparent 70%);"></div>
        <div class="absolute top-20 -right-20 h-60 w-60 rounded-full opacity-10 blur-3xl" style="background: radial-gradient(circle, #818cf8 0%, transparent 70%);"></div>
        <div class="absolute -bottom-20 -left-20 h-60 w-60 rounded-full opacity-10 blur-3xl" style="background: radial-gradient(circle, #c4b5fd 0%, transparent 70%);"></div>
      </div>
      <!-- Grid overlay -->
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 40px 40px;"></div>

      <div class="relative z-10 px-6 pt-10 pb-8 md:pt-14 md:pb-10">
        <div class="mx-auto max-w-2xl text-center">
          <!-- Eyebrow -->
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 backdrop-blur-sm">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-white/60">Free Instant Audit</span>
          </div>

          <!-- Headline -->
          <h1 class="font-sans text-[2rem] font-bold leading-[1.1] tracking-[-0.03em] text-white md:text-[2.75rem] lg:text-[3.25rem]">
            What's hurting your
            <span class="bg-gradient-to-r from-[#818cf8] via-[#a78bfa] to-[#c4b5fd] bg-clip-text text-transparent">Google rankings?</span>
          </h1>
          <p class="mx-auto mt-4 max-w-lg font-sans text-[15px] leading-[1.7] text-white/50 md:text-[16px]">
            Run a comprehensive 11-category SEO audit in seconds. Get your score, real Domain Rating, backlink data, and see exactly how to fix it.
          </p>

          <!-- Stats -->
          <div class="mt-6 flex items-center justify-center gap-6 md:gap-8">
            {[
              { num: '11', label: 'Categories' },
              { num: '55+', label: 'Checks' },
              { num: '10s', label: 'To complete' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[18px] font-bold text-white md:text-[20px]">{s.num}</p>
                <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-white/40">{s.label}</p>
              </div>
            ))}
          </div>

          <!-- Trust badges -->
          <div class="mt-5 flex flex-wrap items-center justify-center gap-2">
            {['Free forever', 'No signup', 'Real DR data', 'AI-powered'].map(b => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 font-mono text-[10px] font-medium uppercase tracking-[0.1em] text-white/50">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {b}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- ── URL INPUT ── -->
      <div class="relative z-10 px-6 pb-10">
        <div class="mx-auto max-w-2xl">
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-2 backdrop-blur-sm">
            <div class="flex items-center gap-2 rounded-xl bg-[#0d1117] px-4 py-3 ring-1 ring-white/10 transition-shadow focus-within:ring-[#4f39f6]/50" id="input-wrapper">
              <svg class="shrink-0 text-white/30" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
              <input
                type="url"
                id="url-input"
                required
                placeholder="yourwebsite.com"
                class="min-w-0 flex-1 bg-transparent font-sans text-[16px] text-white placeholder:text-white/30 outline-none"
              />
              <button
                id="audit-btn"
                class="inline-flex shrink-0 items-center gap-2 rounded-lg bg-[#4f39f6] px-5 py-2.5 font-sans text-[14px] font-semibold text-white transition-all hover:bg-[#615fff] hover:shadow-[0_0_20px_rgba(79,57,246,0.4)] active:scale-[0.98]"
              >
                Run Audit
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
            </div>
          </div>
          <p id="url-error" class="mt-2 hidden text-center text-[13px] text-red-400"></p>

          <!-- Quick examples -->
          <div class="mt-3 flex flex-wrap items-center justify-center gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-white/30">Try:</span>
            {['example.com', 'dentist.com', 'plumber.com'].map(ex => (
              <button class="quick-audit-example rounded-full border border-white/10 bg-white/5 px-3 py-1 font-mono text-[11px] text-white/50 transition-all hover:border-[#4f39f6]/50 hover:text-white/80 hover:bg-[#4f39f6]/10" data-url={ex}>
                {ex}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- ── LOADING STATE ── -->
    <div id="loading-section" class="hidden px-6 py-10">
      <div class="mx-auto max-w-xl">
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
          <!-- Scanning header -->
          <div class="mb-6 flex items-center gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#f5f3ff]">
              <svg class="animate-pulse text-[#4f39f6]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <p class="font-sans text-[15px] font-semibold text-[#292524]">Scanning <span id="scanning-domain" class="text-[#4f39f6]">...</span></p>
              <p class="font-mono text-[11px] text-[#a8a29e]">This takes about 5-10 seconds</p>
            </div>
          </div>

          <!-- Progress steps -->
          <div class="relative flex items-start justify-between">
            <!-- Connecting line -->
            <div class="absolute left-0 right-0 top-[18px] h-px bg-[#e7e5e4]"></div>
            <div id="progress-line-fill" class="absolute left-0 top-[18px] h-px bg-[#4f39f6] transition-all duration-700" style="width: 0%"></div>

            {[
              { step: 'fetch', label: 'Fetch', desc: 'Homepage + sitemap' },
              { step: 'analyze', label: 'Analyze', desc: 'SEO + authority data' },
              { step: 'score', label: 'Score', desc: '11 categories' },
            ].map((s, i) => (
              <div class="step-item relative z-10 flex flex-col items-center" data-step={s.step}>
                <div class={`step-circle flex h-9 w-9 items-center justify-center rounded-full border-2 bg-white transition-all duration-500 ${i === 0 ? 'border-[#4f39f6] text-[#4f39f6]' : 'border-[#e7e5e4] text-[#a8a29e]'}`}>
                  {i === 0 ? (
                    <svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
                  ) : (
                    <span class="font-mono text-[11px] font-bold">{i + 1}</span>
                  )}
                </div>
                <p class="mt-2 font-sans text-[12px] font-semibold text-[#292524]">{s.label}</p>
                <p class="font-mono text-[10px] text-[#a8a29e]">{s.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- ── ERROR STATE ── -->
    <div id="error-section" class="hidden px-6 py-10">
      <div class="mx-auto max-w-xl">
        <div class="rounded-2xl border border-red-200 bg-red-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-red-100">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
          </div>
          <p class="font-sans text-[16px] font-semibold text-red-700">Couldn't analyze that website</p>
          <p id="error-message" class="mt-1 font-sans text-[14px] text-red-600">Check the URL and try again. Make sure the website is publicly accessible.</p>
          <button onclick="document.getElementById('url-input')?.focus(); document.getElementById('error-section')?.classList.add('hidden');" class="mt-4 inline-flex h-10 items-center gap-2 rounded-lg bg-red-600 px-5 font-sans text-[14px] font-semibold text-white hover:bg-red-700 transition-colors">
            Try Again
          </button>
        </div>
      </div>
    </div>

    <!-- ── RESULTS SECTION ── -->
    <div id="results-section" class="hidden px-6 py-10">
      <div class="mx-auto max-w-3xl space-y-6">
        <!-- Score Card -->
        <div id="score-card" class="overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white shadow-sm">
          <div class="p-6 md:p-8">
            <div id="score-gauge"></div>
          </div>
        </div>

        <!-- Partial Preview -->
        <div id="partial-preview"></div>

        <!-- Lead Capture Gate -->
        <div id="lead-gate-section" class="hidden overflow-hidden rounded-2xl">
          <div class="relative bg-gradient-to-br from-[#4f39f6] via-[#5b4bff] to-[#615fff] p-8 md:p-10">
            <!-- Background pattern -->
            <div class="pointer-events-none absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>

            <div class="relative z-10">
              <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              </div>
              <h3 class="text-center font-sans text-[22px] font-bold text-white md:text-[26px]">Unlock Your Full Report</h3>
              <p class="mx-auto mt-2 max-w-md text-center font-sans text-[15px] text-white/70">See all 11 category scores, detailed fixes, live DR + backlink data, top keywords, and personalized recommendations for your site.</p>

              <!-- Benefits -->
              <div class="mx-auto mt-6 flex max-w-lg flex-wrap justify-center gap-3">
                {['Full 11 category breakdown', 'Live DR + backlink data', 'Priority fix list', 'Stacc recommendations', 'Shareable report link'].map(b => (
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1.5 font-sans text-[12px] text-white/90 backdrop-blur-sm">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {b}
                  </span>
                ))}
              </div>

              <!-- Form -->
              <form id="lead-form" class="mx-auto mt-8 max-w-md">
                <div class="grid grid-cols-2 gap-3">
                  <div>
                    <label class="mb-1 block font-sans text-[12px] font-medium text-white/80">First name</label>
                    <input name="first_name" type="text" required class="h-11 w-full rounded-xl border border-white/20 bg-white/10 px-4 font-sans text-[14px] text-white placeholder:text-white/40 outline-none backdrop-blur-sm transition-all focus:border-white/40 focus:bg-white/15" placeholder="Jane" />
                  </div>
                  <div>
                    <label class="mb-1 block font-sans text-[12px] font-medium text-white/80">Last name</label>
                    <input name="last_name" type="text" required class="h-11 w-full rounded-xl border border-white/20 bg-white/10 px-4 font-sans text-[14px] text-white placeholder:text-white/40 outline-none backdrop-blur-sm transition-all focus:border-white/40 focus:bg-white/15" placeholder="Smith" />
                  </div>
                </div>
                <div class="mt-3">
                  <label class="mb-1 block font-sans text-[12px] font-medium text-white/80">Work email</label>
                  <input name="email" type="email" required class="h-11 w-full rounded-xl border border-white/20 bg-white/10 px-4 font-sans text-[14px] text-white placeholder:text-white/40 outline-none backdrop-blur-sm transition-all focus:border-white/40 focus:bg-white/15" placeholder="jane@company.com" />
                </div>
                <div class="mt-3">
                  <label class="mb-1 block font-sans text-[12px] font-medium text-white/80">Phone</label>
                  <input name="phone" type="tel" required class="h-11 w-full rounded-xl border border-white/20 bg-white/10 px-4 font-sans text-[14px] text-white placeholder:text-white/40 outline-none backdrop-blur-sm transition-all focus:border-white/40 focus:bg-white/15" placeholder="+1 (555) 000-0000" />
                </div>
                <button type="submit" id="lead-submit" class="mt-4 flex h-12 w-full items-center justify-center gap-2 rounded-xl bg-white font-sans text-[15px] font-semibold text-[#4f39f6] transition-all hover:bg-white/90 hover:shadow-lg active:scale-[0.98]">
                  Unlock Full Report
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </button>
                <p class="mt-3 text-center font-mono text-[10px] text-white/50">No spam. Unsubscribe anytime.</p>
              </form>
            </div>
          </div>
        </div>

        <!-- Summary Bar (always shown) -->
        <div id="summary-bar" class="hidden"></div>

        <!-- Full Report (post-unlock) -->
        <div id="full-report-section" class="hidden space-y-6">
          <div id="priorities-section" class="hidden"></div>
          <div id="categories-section" class="space-y-3"></div>
          <div id="authority-section" class="hidden"></div>
          <div id="technical-section" class="hidden"></div>
          <div id="pagespeed-section" class="hidden"></div>
          <div id="social-tags-section" class="hidden"></div>
          <div id="geo-aio-section" class="hidden"></div>
          <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
            <h3 class="mb-4 font-sans text-[17px] font-semibold text-[#292524]">Google Search Preview</h3>
            <div id="serp-preview"></div>
          </div>
          <div id="stacc-recommendations" class="hidden"></div>
        </div>
      </div>
    </div>

    <!-- Share Link -->
    <div class="px-6">
      <div id="share-link" class="mx-auto max-w-3xl"></div>
    </div>

    <!-- WebPage with speakable schema -->
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  </Fragment>

  <!-- ==================== CTA ==================== -->
  <Fragment slot="cta">
    <section id="cta-banner" class="hidden relative overflow-hidden" style="background: linear-gradient(135deg, #0d1117 0%, #1a103c 50%, #0d1117 100%);">
      <div class="pointer-events-none absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
      <div class="pointer-events-none absolute -top-20 left-1/2 h-60 w-60 -translate-x-1/2 rounded-full opacity-20 blur-3xl" style="background: radial-gradient(circle, #4f39f6 0%, transparent 70%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <div class="mx-auto max-w-lg">
          <p id="cta-headline" class="font-sans text-[22px] font-bold leading-tight text-white"></p>
          <p id="cta-subtext" class="mt-3 font-sans text-[15px] leading-relaxed text-white/60"></p>
          <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
            <a href="https://cal.com/sid-gangal-zfdhkv/30min" target="_blank" rel="noopener" class="inline-flex h-[48px] items-center gap-2 rounded-xl bg-[#4f39f6] px-8 font-sans text-[15px] font-semibold text-white transition-all hover:bg-[#615fff] hover:shadow-[0_0_30px_rgba(79,57,246,0.3)]">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Book a Free Strategy Call
            </a>
            <a href="/demo/" class="inline-flex h-[48px] items-center gap-2 rounded-xl border border-white/20 px-6 font-sans text-[15px] font-semibold text-white transition-all hover:bg-white/10">
