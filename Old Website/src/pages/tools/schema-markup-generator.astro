---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
  buildBreadcrumbSchema,
} from '../../lib/schema-builders';

const pageTitle = 'Free Schema Markup Generator — Real PAA FAQ + JSON-LD | theStacc';
const pageDescription = 'Generate LocalBusiness, FAQ, Service, and Breadcrumb schema markup in JSON-LD. Fetch real People Also Ask questions from Google, auto-write answers with AI. 23 industry presets. Free, no signup.';
const pageUrl = 'https://thestacc.com/tools/schema-markup-generator/';
const lastUpdated = '2026-05-11';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Schema Markup Generator',
  description: 'Generate LocalBusiness, FAQPage, Service, and BreadcrumbList schema markup in JSON-LD. Fetch real People Also Ask questions from Google with AI-written answers. 23 industry presets for local businesses.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is schema markup and why does it matter for SEO?', a: 'Schema markup is structured data code (usually JSON-LD) that you add to your website to help search engines understand your content. For local businesses, it tells Google your business name, address, phone number, services, hours, and reviews in a machine-readable format. According to Google, pages with proper structured data are eligible for rich results like star ratings, FAQ dropdowns, and business panels in search results. A 2025 Search Engine Journal study found that rich results can increase click-through rates by up to 30%.' },
  { q: 'How do I add schema markup to my website?', a: 'Copy the JSON-LD code from this generator and paste it in your HTML before the closing </head> tag. In WordPress, use the "Insert Headers and Footers" plugin. In Webflow, go to Page Settings > Custom Code > Head Code. In Squarespace, go to Settings > Advanced > Code Injection > Header. In Wix, go to Settings > Custom Code. After adding the code, validate it using Google\'s Rich Results Test to confirm it works.' },
  { q: 'What schema types should a local business use?', a: 'Every local business should have four core schema types: (1) LocalBusiness schema with your specific subtype (Dentist, Plumber, Attorney, etc.), (2) FAQPage schema for common customer questions, (3) Service schema for each service you offer, and (4) BreadcrumbList schema for navigation. Combining these in a single @graph gives Google the most complete picture of your business. Most businesses only have LocalBusiness — adding all four gives you a competitive advantage.' },
  { q: 'What is the People Also Ask feature and how does this tool use it?', a: 'People Also Ask (PAA) is a Google SERP feature that shows expandable question-and-answer boxes based on real user searches. This tool fetches live PAA questions for your industry and uses AI to write professional answers. Using real PAA questions in your FAQ schema means you are answering questions that actual customers are actively searching for — dramatically increasing your chances of appearing in both PAA boxes and rich results.' },
  { q: 'Do I need schema markup for local SEO?', a: 'Yes. Schema markup is one of the strongest local SEO signals. Businesses with proper LocalBusiness schema are more likely to appear in the local pack, knowledge panels, and rich results. Google explicitly recommends JSON-LD format. According to a 2024 Whitespark study, structured data is among the top 10 ranking factors for local pack results. Without schema, Google has to guess your business details from page text.' },
  { q: 'What are rich results and how does schema trigger them?', a: 'Rich results are enhanced search listings that include extra visual elements like star ratings, FAQ dropdowns, breadcrumbs, images, and business information panels. Schema markup is the trigger — Google uses your structured data to generate these enhanced listings. FAQPage schema creates expandable Q&A boxes below your listing. AggregateRating in LocalBusiness schema shows star ratings. BreadcrumbList replaces plain URLs with clean navigation paths.' },
  { q: 'Is this schema markup generator free?', a: 'Yes, 100% free. No signup required for basic schema generation. Select your industry to auto-fill fields, customize your business details, and copy valid JSON-LD code instantly. The real People Also Ask fetch feature is also free — it uses live Google search data and AI to pre-fill your FAQ section with questions real customers are asking. Everything runs server-side; your business data is not stored.' },
  { q: 'How is this different from other schema generators?', a: 'Most schema generators give you empty templates or static preset questions. This tool fetches live People Also Ask questions from Google for your specific industry, then uses AI to write complete, professional answers. It also generates Service schema (most tools skip this), supports 23 industry-specific LocalBusiness subtypes, and includes a completeness score that shows you exactly what information you are missing. No other free tool combines real PAA data with AI answer generation.' },
  { q: 'Can I use this schema for multiple pages?', a: 'Yes, but each page should have page-specific schema. Your homepage should have your full LocalBusiness schema. Service pages should have Service schema for that specific service. FAQ pages should have FAQPage schema with relevant questions. Contact pages should include your address and geo coordinates. This tool lets you generate each type individually or combine them in a single @graph.' },
  { q: 'How long does it take for schema to appear in search results?', a: 'Google typically processes and displays schema within 3-14 days after you add it to your site. Use Google\'s Rich Results Test to validate your markup immediately. Then submit your page URL to Google Search Console for indexing. Not all schema triggers rich results — Google decides which enhancements to show based on relevance, quality, and user intent. The best way to improve your chances is to ensure your schema is complete, accurate, and matches your page content exactly.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://thestacc.com/' },
  { name: 'Free SEO Tools', url: 'https://thestacc.com/tools/' },
  { name: 'Schema Markup Generator', url: pageUrl },
]);

const industries = [
  { value: '', label: 'Select your industry (auto-fills fields)' },
  { value: 'dentist', label: 'Dentist' },
  { value: 'chiropractor', label: 'Chiropractor' },
  { value: 'orthodontist', label: 'Orthodontist' },
  { value: 'optometrist', label: 'Optometrist' },
  { value: 'dermatologist', label: 'Dermatologist' },
  { value: 'plumber', label: 'Plumber' },
  { value: 'hvac', label: 'HVAC' },
  { value: 'electrician', label: 'Electrician' },
  { value: 'roofing', label: 'Roofing' },
  { value: 'landscaping', label: 'Landscaping' },
  { value: 'pest_control', label: 'Pest Control' },
  { value: 'auto_repair', label: 'Auto Repair' },
  { value: 'lawyer', label: 'Lawyer' },
  { value: 'accountant', label: 'Accountant' },
  { value: 'realtor', label: 'Real Estate Agent' },
  { value: 'insurance', label: 'Insurance Agency' },
  { value: 'financial_advisor', label: 'Financial Advisor' },
  { value: 'restaurant', label: 'Restaurant' },
  { value: 'salon', label: 'Salon / Spa' },
  { value: 'gym', label: 'Gym / Fitness' },
  { value: 'veterinarian', label: 'Veterinarian' },
  { value: 'cleaning', label: 'Cleaning Service' },
  { value: 'moving', label: 'Moving Company' },
  { value: 'other', label: 'Other / General' },
];
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free Schema Markup Generator"
  toolDescription="Generate LocalBusiness, FAQ, Service, and Breadcrumb schema in JSON-LD. Fetch real People Also Ask questions from Google, auto-write answers with AI. 23 industry presets."
  wide={true}
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <!-- ==================== SCHEMA ==================== -->
  <Fragment slot="tool">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

    <div class="flex flex-col lg:flex-row gap-6">
      <!-- LEFT: Form Column -->
      <div class="lg:w-[60%] space-y-6" id="form-column">

        <!-- Section 1: Schema Type Checkboxes -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-3">Schema Types</p>
          <div class="space-y-3">
            <label class="flex items-start gap-3 rounded-xl border-2 border-[#4f39f6] bg-[#f5f3ff] p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-local" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" checked />
              <div class="flex-1">
                <span class="text-[14px] font-semibold text-[#292524]">LocalBusiness</span>
                <p class="text-[12px] text-[#79716b] mt-0.5">Name, address, phone, hours, reviews, geo coordinates</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-faq" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="text-[14px] font-semibold text-[#292524]">FAQPage</span>
                  <span class="rounded-full bg-[#f0fdf4] px-2 py-0.5 text-[10px] font-bold uppercase text-[#16a34a]">+ Real PAA</span>
                </div>
                <p class="text-[12px] text-[#79716b] mt-0.5">Question and answer pairs. Fetch real Google People Also Ask questions with AI-written answers</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-service" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="text-[14px] font-semibold text-[#292524]">Service</span>
                  <span class="rounded-full bg-[#fef3c7] px-2 py-0.5 text-[10px] font-bold uppercase text-[#92400e]">Unique</span>
                </div>
                <p class="text-[12px] text-[#79716b] mt-0.5">Individual service entries with provider info. Rarely generated by other tools</p>
              </div>
            </label>
            <label class="flex items-start gap-3 rounded-xl border border-[#e7e5e4] bg-white p-3.5 cursor-pointer transition-all has-[:checked]:border-[#4f39f6] has-[:checked]:bg-[#f5f3ff]">
              <input type="checkbox" id="type-breadcrumb" class="schema-type-cb mt-0.5 h-4 w-4 accent-[#4f39f6] cursor-pointer" />
              <div class="flex-1">
                <span class="text-[14px] font-semibold text-[#292524]">BreadcrumbList</span>
                <p class="text-[12px] text-[#79716b] mt-0.5">Navigation path. Helps Google understand site structure</p>
              </div>
            </label>
          </div>
        </div>

        <!-- Section 2: Industry Selector -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="industry-select">Industry</label>
          <select id="industry-select" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors cursor-pointer">
            {industries.map(ind => (
              <option value={ind.value}>{ind.label}</option>
            ))}
          </select>
          <p class="mt-1 text-[11px] text-[#79716b]">Sets your schema type and pre-fills services and FAQ suggestions.</p>
        </div>

        <!-- Section 3: LocalBusiness Fields -->
        <div id="section-local" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 space-y-4">
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1">Business Details</p>

          <!-- Core Info -->
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-name">Business Name <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Required</span></label>
            <input type="text" id="f-name" placeholder="e.g., Austin Family Dentistry" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-description">Description <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recommended</span></label>
            <textarea id="f-description" rows="2" placeholder="Brief description of your business..." class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors resize-none"></textarea>
          </div>

          <!-- Contact -->
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-phone">Phone <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Required</span></label>
              <input type="tel" id="f-phone" placeholder="(512) 555-0123" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-email">Email <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Optional</span></label>
              <input type="email" id="f-email" placeholder="info@example.com" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-url">Website URL <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Required</span></label>
            <input type="url" id="f-url" placeholder="https://www.example.com" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>

          <!-- Address -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Address</p>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-street">Street Address <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Required</span></label>
            <input type="text" id="f-street" placeholder="123 Main St, Suite 100" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-city">City <span class="rounded bg-[#fef2f2] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#dc2626]">Required</span></label>
              <input type="text" id="f-city" placeholder="Austin" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-state">State <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recommended</span></label>
              <input type="text" id="f-state" placeholder="TX" maxlength="2" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-zip">ZIP <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recommended</span></label>
              <input type="text" id="f-zip" placeholder="78701" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-country">Country <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Optional</span></label>
            <input type="text" id="f-country" placeholder="US" value="US" maxlength="2" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>

          <!-- Media & Rating -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Media &amp; Rating</p>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-logo">Logo URL <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recommended</span></label>
              <input type="url" id="f-logo" placeholder="https://example.com/logo.png" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-image">Image URL <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recommended</span></label>
              <input type="url" id="f-image" placeholder="https://example.com/photo.jpg" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-price">Price Range <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Optional</span></label>
            <select id="f-price" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors cursor-pointer">
              <option value="">Select price range...</option>
              <option value="$">$. Budget</option>
              <option value="$$">$$. Moderate</option>
              <option value="$$$">$$$. Premium</option>
              <option value="$$$$">$$$$. Luxury</option>
            </select>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-rating">Rating Value <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Optional</span></label>
              <input type="number" id="f-rating" placeholder="4.8" min="1" max="5" step="0.1" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-reviewcount">Review Count <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Optional</span></label>
              <input type="number" id="f-reviewcount" placeholder="127" min="0" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>

          <!-- Opening Hours -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Opening Hours <span class="rounded bg-[#fffbeb] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#d97706]">Recommended</span></p>
          <div id="hours-container" class="space-y-2"></div>
          <button type="button" id="btn-copy-hours" class="mt-2 cursor-pointer rounded-lg border border-[#e7e5e4] px-3 py-1.5 text-[12px] font-medium text-[#57534e] hover:border-[#c4b5fd] hover:text-[#4f39f6] transition-colors">Copy Mon hours to weekdays</button>

          <!-- Geo -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Geo Coordinates <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Optional</span></p>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-lat">Latitude</label>
              <input type="text" id="f-lat" placeholder="30.2672" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#292524] mb-1" for="f-lng">Longitude</label>
              <input type="text" id="f-lng" placeholder="-97.7431" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>

          <!-- Social Profiles -->
          <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] pt-2">Social Profiles <span class="rounded bg-[#f5f5f4] px-1.5 py-0.5 text-[10px] font-bold uppercase text-[#78716c]">Optional</span></p>
          <div class="space-y-2" id="social-container">
            <input type="url" class="social-url w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" placeholder="https://facebook.com/yourbusiness" />
