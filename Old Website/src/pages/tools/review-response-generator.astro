---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../lib/schema-builders';

const pageTitle = 'Free Google Review Response Generator (3 Replies in 8s) | theStacc';
const pageDescription = 'Generate 3 ready-to-post Google review responses in 8 seconds. Industry-aware (HIPAA + legal-safe). Reads the actual review text. No signup, no email gate.';
const pageUrl = 'https://thestacc.com/tools/review-response-generator/';
const lastUpdated = '2026-05-10';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Google Review Response Generator',
  description: 'Generates 3 ready-to-post responses to any Google review in 8 seconds. Reads your actual review text. Industry-aware safety rules for dental, medical, legal, and financial services. Includes a 100-point quality scorer.',
  url: pageUrl,
});

const faqs = [
  { q: 'How should I respond to a negative Google review?', a: 'Acknowledge the specific experience the reviewer described, take quiet ownership ("we should have done better") without admitting legal fault, and move the conversation off-platform — give a phone number or ask them to email the manager. Never argue, list excuses, or contradict the review publicly. Keep it under 150 words. Always respond within 4 hours of a 1-2 star review.' },
  { q: 'Do Google review responses help with local SEO?', a: 'Yes. Google has confirmed that response rate is a local ranking factor. Businesses that respond to reviews regularly rank higher in the Google Map Pack than those that don\'t. Responses are also indexed text — naturally including your business name and city in replies adds local-relevance signals.' },
  { q: 'How quickly should I respond to Google reviews?', a: 'Within 4 hours for 1-2 star reviews — every hour after a negative review publishes, your response carries less weight because more potential customers have already read it. Within 24 hours for 3-4 star reviews. Within 48 hours for 5-star reviews. Speed itself is a ranking signal.' },
  { q: 'Should I respond to every Google review?', a: 'Yes. Aim for a 100% response rate. Positive reviews get a 2-3 sentence thank-you. Negative reviews get a 100-150 word acknowledgement with an offline path. The act of responding signals to Google that your business is active, and signals to potential customers that you actually care. Businesses that respond consistently to reviews tend to outperform those that ignore them on both rankings and conversion.' },
  { q: 'Can I use AI to write Google review responses?', a: 'Yes — but only if the AI reads the actual review and references specific details. Generic AI responses (the "we appreciate your business" template kind) hurt more than they help — readers can spot them in seconds and the keyword stuffing patterns can violate Google\'s spam policies. This tool reads the review text and references concrete details from it, so each response feels genuinely written.' },
  { q: 'What should I never say in a Google review response?', a: 'Never admit legal fault ("you\'re right, we were negligent"). Never reference specific medical treatments (HIPAA violation). Never confirm someone is a client of your law firm (privilege violation). Never promise compensation publicly. Never argue with the reviewer or "but actually" their account. Never respond when emotional — wait at least an hour after reading a tough review before drafting a reply.' },
  { q: 'How long should a Google review response be?', a: '40-80 words for positive reviews. 100-150 words for negative or mixed reviews. Long enough to acknowledge specifics. Short enough that mobile users will read it (the "Read more" cutoff on Google mobile is around 80 characters). Skip padding phrases like "thank you for taking the time to leave us your valuable feedback" — that\'s 14 wasted words.' },
  { q: 'Is responding to fake or unfair reviews worth it?', a: 'Yes — but for the next 100 readers, not for the reviewer. Stay calm, present your side neutrally without arguing, mention you\'ve also flagged the review with Google for verification, and offer a path to discuss off-platform. If the review violates Google\'s policies (hate speech, conflict of interest, off-topic), report it to Google through the Business Profile manager — they remove a meaningful percentage of reported reviews.' },
  { q: 'Can responding to reviews actually win new customers?', a: 'Yes. The majority of consumers read business responses before deciding where to spend money. A thoughtful, accountable response to a 1-star review can convert more new customers than three 5-star reviews — it shows future customers exactly how you handle problems, which is what they actually need to know. Quick, empathetic responses to negatives consistently lift review-page conversion rates.' },
  { q: 'Is this Google review response generator really free?', a: 'Yes. No credit card. No email required to use the tool. We make money when local businesses upgrade to Stacc, our automated SEO platform that handles review responses, GBP posts, and blog content on autopilot — but the tool itself is free forever. Daily limit: 15 responses per IP, which resets every 24 hours.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const industries = [
  'Dental / Orthodontics','Legal / Law Firm','Plumbing / HVAC','Electrical',
  'Roofing / Construction','Real Estate','Accounting / Tax','Restaurant / Cafe',
  'Salon / Spa / Beauty','Auto Repair / Detailing','Cleaning Services','Landscaping / Lawn Care',
  'Veterinary / Pet Services','Chiropractic / Physical Therapy','IT Services / Consulting',
  'Fitness / Gym / Yoga','Photography / Videography','Insurance / Financial Services',
  'Home Staging / Interior Design','Tutoring / Education','Pet Grooming / Boarding',
  'Moving / Storage','Pest Control','Medical Practice','Mental Health / Therapy',
];
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free Google Review Response Generator"
  toolDescription="Generate 3 ready-to-post responses in 8 seconds. Industry-aware (HIPAA + legal-safe). Reads the actual review text. No signup, no email gate."
  trustCount=""
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <!-- ==================== TOOL ==================== -->
  <Fragment slot="tool">
    <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
      <form id="form" novalidate>
        <!-- Review Text -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="review-text">The Review <span class="text-red-500">*</span></label>
          <textarea id="review-text" required minlength="10" maxlength="2000" rows="5" placeholder="Paste the Google review here, exactly as it appears..." class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] leading-[1.6] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors resize-y"></textarea>
          <div class="mt-1 flex items-center justify-between">
            <p class="hidden text-xs text-red-500" id="err-review-text">Paste the review text (at least 10 characters)</p>
            <p class="ml-auto font-mono text-xs text-[#79716b]"><span id="char-count">0</span> / 2,000</p>
          </div>
        </div>

        <!-- Star Rating -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-2">Star Rating <span class="text-red-500">*</span></label>
          <input type="hidden" id="rating-val" value="" />
          <div class="flex gap-1.5">
            {[1,2,3,4,5].map(star => (
              <button type="button" class="star-btn cursor-pointer p-1 transition-transform hover:scale-110" data-star={star} aria-label={`${star} star${star > 1 ? 's' : ''}`}>
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#d6d3d1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
              </button>
            ))}
          </div>
          <p class="mt-1.5 hidden text-[13px] font-medium" id="rating-hint"></p>
          <p class="mt-1 hidden text-xs text-red-500" id="err-rating">Please select a star rating</p>
        </div>

        <!-- Business + Industry side-by-side on md+ -->
        <div class="mb-5 grid gap-5 md:grid-cols-2">
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="biz">Business Name <span class="text-red-500">*</span></label>
            <input type="text" id="biz" required maxlength="100" placeholder="e.g., Smith Family Dental" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            <p class="mt-1 hidden text-xs text-red-500" id="err-biz">Please enter your business name</p>
          </div>
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="city">City / Location <span class="text-red-500">*</span></label>
            <input type="text" id="city" required maxlength="80" placeholder="e.g., Austin, TX" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            <p class="mt-1 hidden text-xs text-red-500" id="err-city">Please enter your city</p>
          </div>
        </div>

        <!-- Industry -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="ind">Industry <span class="text-red-500">*</span></label>
          <select id="ind" required class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2379716b%22%20stroke-width%3D%222.5%22%3E%3Cpath%20d%3D%22m6%209%206%206%206-6%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_16px_center] bg-no-repeat">
            <option value="" disabled selected>Select your industry</option>
            {industries.map(ind => <option>{ind}</option>)}
            <option value="__other__">Other (type your own)</option>
          </select>
          <p class="mt-1 hidden text-xs text-red-500" id="err-ind">Please select your industry</p>
          <input type="text" id="ind-other" placeholder="e.g., Wedding planning, Pool cleaning, Tattoo studio" maxlength="60" class="mt-1.5 hidden w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          <p class="mt-1.5 font-mono text-[11px] text-[#79716b]">Why we ask: certain industries (medical, legal, financial) need extra response rules — we apply them automatically.</p>
        </div>

        <!-- Reviewer Name -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="reviewer-name">Reviewer's First Name <span class="font-normal normal-case tracking-normal text-[#79716b]">. Optional</span></label>
          <input type="text" id="reviewer-name" maxlength="50" placeholder="e.g., Sarah (leave blank if anonymous)" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
        </div>

        <!-- Response Tone -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-2">Response Tone</label>
          <div class="grid grid-cols-2 gap-2 md:grid-cols-4">
            {[
              { val: 'professional', label: 'Professional', desc: 'Restrained, polished' },
              { val: 'friendly', label: 'Friendly', desc: 'Warm, conversational' },
              { val: 'empathetic', label: 'Empathetic', desc: 'Validating, accountable' },
              { val: 'brief', label: 'Brief', desc: 'Direct, no padding' },
            ].map((t, i) => (
              <label class="cursor-pointer">
                <input type="radio" name="tone" value={t.val} checked={i === 0} class="peer sr-only" />
                <span class="block rounded-[10px] border border-[#e7e5e4] p-3 text-center transition-all peer-checked:border-[#4f39f6] peer-checked:bg-[#f5f3ff]">
                  <span class="block text-[14px] font-semibold text-[#292524]">{t.label}</span>
                  <span class="mt-0.5 block text-[11px] text-[#79716b]">{t.desc}</span>
                </span>
              </label>
            ))}
          </div>
        </div>

        <!-- Compliance Note -->
        <div class="mb-5 flex items-start gap-2 rounded-lg bg-[#fffbeb] border border-[#fde68a] p-3">
          <span class="mt-0.5 shrink-0"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></span>
          <p class="text-[13px] text-[#92400e] leading-relaxed"><strong>Industry-safe by default.</strong> We never reference specific treatments (HIPAA), case details (privilege), or financial specifics — even if the reviewer mentioned them. Each response is screened for compliance before you see it.</p>
        </div>

        <button type="submit" id="gen-btn" class="w-full cursor-pointer rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3.5 font-mono text-sm font-bold uppercase tracking-wide text-white transition-all hover:bg-[#4f39f6] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
          Generate 3 Response Variations
        </button>

        <p class="mt-2.5 text-center font-mono text-[11px] text-[#79716b]">Free · No signup · 15 generations per day</p>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 hidden">
      <div class="mb-4 flex items-center justify-center gap-3 rounded-lg bg-[#fafaf9] border border-[#e7e5e4] px-4 py-2 font-mono text-xs text-[#79716b]">
        <span>Generated this session: <strong class="text-[#6d28d9]" id="gen-count">0</strong></span>
        <span class="hidden sm:inline">·</span>
        <span id="avg-score" class="hidden sm:inline"></span>
      </div>

      <!-- Top-level flag banner (HIPAA / legal warnings) -->
      <div id="flag-banner" class="hidden mb-4 rounded-lg border border-[#fca5a5] bg-[#fef2f2] p-3"></div>

      <!-- Industry safety notes -->
      <div id="safety-notes" class="hidden mb-4 rounded-xl border border-[#fecaca] bg-[#fef2f2] p-4"></div>

      <!-- Variation 1 — Concise -->
      <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6 mb-4">
        <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]" id="lbl1">Concise</span>
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs" id="st1"></span>
            <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="1">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span>Copy</span>
            </button>
          </div>
        </div>
        <div class="mt-3" id="pt1"></div>
        <div id="seo1" class="mt-3 hidden inline-flex items-center gap-1.5 rounded-md bg-[#f0fdf4] border border-[#bbf7d0] px-2.5 py-1 font-mono text-[11px] font-medium text-[#16a34a]"></div>
        <div id="tip1" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
      </div>

      <!-- Variation 2 — Balanced -->
      <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6 mb-4">
        <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]" id="lbl2">Balanced</span>
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs" id="st2"></span>
            <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="2">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span>Copy</span>
            </button>
          </div>
        </div>
        <div class="mt-3" id="pt2"></div>
        <div id="seo2" class="mt-3 hidden inline-flex items-center gap-1.5 rounded-md bg-[#f0fdf4] border border-[#bbf7d0] px-2.5 py-1 font-mono text-[11px] font-medium text-[#16a34a]"></div>
        <div id="tip2" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
      </div>

      <!-- Variation 3 — Detailed -->
      <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6 mb-4">
        <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]" id="lbl3">Detailed</span>
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs" id="st3"></span>
            <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="3">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span>Copy</span>
            </button>
          </div>
        </div>
        <div class="mt-3" id="pt3"></div>
        <div id="seo3" class="mt-3 hidden inline-flex items-center gap-1.5 rounded-md bg-[#f0fdf4] border border-[#bbf7d0] px-2.5 py-1 font-mono text-[11px] font-medium text-[#16a34a]"></div>
        <div id="tip3" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
      </div>

      <!-- Google Response Preview -->
      <div class="mt-6">
        <p class="mb-2 font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Preview on Google (Concise variation)</p>
        <div class="rounded-xl border border-[#dadce0] bg-white p-4 shadow-sm">
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#4f39f6]">
              <span id="pav" class="font-sans text-sm font-bold text-white">Y</span>
            </div>
            <div>
              <p class="font-sans text-[13px] font-medium text-[#202124]">Response from the owner</p>
              <p class="font-sans text-[12px] text-[#70757a]">Just now</p>
            </div>
          </div>
          <p id="pbd" class="font-sans text-[14px] leading-[1.6] text-[#3c4043]"><span class="text-[#79716b] italic">Your response preview will appear here...</span></p>
        </div>
      </div>

      <!-- Response time hint -->
      <div id="response-time" class="hidden mt-4 rounded-lg border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-mono text-xs text-[#57534e]"></div>

      <!-- Actions -->
      <div class="mt-4 flex flex-wrap gap-3">
        <button id="regen" class="cursor-pointer inline-flex items-center gap-2 rounded-lg border border-[#e7e5e4] bg-white px-5 py-2.5 font-mono text-sm font-medium text-[#292524] hover:bg-[#fafaf9] transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
          Generate Different Variations
        </button>
        <a href="https://business.google.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[#e7e5e4] bg-white px-5 py-2.5 font-mono text-sm font-medium text-[#292524] hover:bg-[#fafaf9] transition-colors">
          Open Google Business Profile <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>
    </div>
  </Fragment>

  <!-- ==================== CTA ==================== -->
  <Fragment slot="cta">
    <section id="cta-b" class="hidden relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.45) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center"><div class="mx-auto max-w-lg">
        <p class="font-sans text-[22px] font-bold leading-tight text-white">You wrote 3 replies in 8 seconds.<br/>Stacc replies to every review for you — automatically.</p>
        <p class="mt-3 font-sans text-[15px] leading-relaxed text-[#94a3b8]">Hands-off review responses, GBP posts, and blog content. The 100% response rate Google rewards, without the hour every Monday.</p>
        <a href="/demo/?source=review-response-tool-results" class="mt-6 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">Start your $1 trial &rarr;</a>
        <p class="mt-3 font-mono text-xs text-[#64748b]">$1 for 3 days · Cancel anytime · Rank higher in the Map Pack on autopilot</p></div>
      </div>
    </section>
  </Fragment>

  <!-- ==================== SEO CONTENT ==================== -->
  <Fragment slot="content">
    <!-- ░░ TL;DR / SPEAKABLE ░░ -->
    <div class="speakable mb-8 rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-5">
      <p class="font-mono text-[10px] font-bold uppercase tracking-[0.16em] text-[#4f39f6] mb-2">Summary · Last updated {lastUpdated}</p>
      <p class="font-sans text-[16px] leading-[1.8] text-[#292524]">
        The Free Google Review Response Generator drafts 3 ready-to-post replies to any Google review in under 8 seconds. Paste the review, pick the star rating and tone, and get one concise reply (40-80 words), one balanced reply (90-150 words), and one detailed reply (160-220 words). The tool reads the actual review text and references specific details from it, so each response sounds genuinely written — not template-copied. Industry safety rules protect dental, medical, legal, and financial businesses from HIPAA and privilege violations. Best for local service businesses managing 10-200 reviews per month. Free, no signup, no email gate.
      </p>
    </div>

