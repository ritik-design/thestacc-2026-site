---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
  buildBreadcrumbSchema,
} from '../../lib/schema-builders';

const pageTitle = 'Free Keyword Difficulty Checker — SEO Competition Analysis | theStacc';
const pageDescription = 'Free keyword difficulty checker. Enter any keyword and get a realistic difficulty score with breakdown by competition, SERP features, content quality, backlinks, and domain authority.';
const pageUrl = 'https://thestacc.com/tools/keyword-difficulty-checker/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Keyword Difficulty Checker',
  description: 'Check how hard it is to rank for any keyword. Get a difficulty score with factor breakdown and actionable tips.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is keyword difficulty?', a: 'Keyword difficulty (KD) is an SEO metric that estimates how hard it would be to rank on the first page of Google for a specific keyword. It factors in the strength of competing pages, SERP feature density, content quality requirements, and backlink profiles of top-ranking results.' },
  { q: 'How is the difficulty score calculated?', a: 'Our AI analyzes the keyword across five factors: Competition (how many strong pages target this term), SERP Features (presence of featured snippets, PAA boxes, local packs), Content Quality (depth and expertise required), Backlinks Needed (link profile strength of top results), and Domain Authority (strength of competing domains). Each factor is scored 0-100 and combined into an overall score.' },
  { q: 'What is a good keyword difficulty score?', a: 'For new sites: target keywords under 30 (Easy). For established sites with some authority: 30-55 (Medium) is manageable. For strong domains: 56-75 (Hard) is achievable with effort. Only the strongest sites should target 76-100 (Very Hard) keywords directly — consider long-tail variations instead.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Check any keyword instantly. You can run up to 15 checks per day.' },
  { q: 'How accurate is the difficulty estimate?', a: 'The analysis is AI-generated based on search intent patterns, keyword characteristics, and SEO best practices. While not pulled from live backlink databases, the difficulty assessment closely mirrors real-world ranking challenges. For high-stakes decisions, supplement with a dedicated SEO platform.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://thestacc.com/' },
  { name: 'Free SEO Tools', url: 'https://thestacc.com/tools/' },
  { name: 'Keyword Difficulty Checker', url: pageUrl },
]);
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free Keyword Difficulty Checker"
  toolDescription="Check how hard it is to rank for any keyword. Get a difficulty score with factor breakdown and actionable tips."
  wide={true}
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <Fragment slot="tool">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

    <div class="mx-auto max-w-4xl">
      <!-- Input Form -->
      <div id="kdc-step-1" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <div class="flex items-center gap-2 mb-6">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[12px] font-bold text-white">1</span>
          <span class="font-sans text-[16px] font-semibold text-[#292524]">Enter a Keyword</span>
        </div>

        <div class="flex gap-3">
          <input
            type="text"
            id="kdc-keyword"
            required
            placeholder="e.g., best CRM software, content marketing strategy"
            class="flex-1 rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#a8a29e] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors"
          />
          <button
            id="kdc-submit"
            class="shrink-0 rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3 font-mono text-sm font-bold uppercase text-white hover:bg-[#4f39f6] cursor-pointer disabled:opacity-50 transition-colors"
          >
            Check
          </button>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-[12px] text-[#a8a29e]">Try:</span>
          {['SEO tools', 'local SEO', 'content strategy', 'backlink building', 'SERP features'].map((example) => (
            <button class="kdc-example-btn text-[12px] text-[#4f39f6] hover:underline cursor-pointer" data-keyword={example}>
              {example}
            </button>
          ))}
        </div>
      </div>

      <!-- Loading -->
      <div id="kdc-loading" class="mt-6 hidden rounded-2xl border border-[#e7e5e4] bg-white p-6 text-center">
        <svg class="animate-spin mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="#4f39f6" stroke-width="3" opacity="0.25"/>
          <path d="M12 2a10 10 0 019.8 8" stroke="#4f39f6" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <p class="text-[15px] text-[#57534e]">Analyzing competition...</p>
        <p class="text-[13px] text-[#a8a29e] mt-1">This takes about 5-10 seconds</p>
      </div>

      <!-- Error -->
      <div id="kdc-error-panel" class="mt-6 hidden rounded-2xl border border-red-200 bg-red-50 p-6 text-center">
        <svg class="mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        <p class="text-[15px] text-red-700 font-medium">Could not analyze keyword</p>
        <p id="kdc-error-msg" class="mt-1 text-[13px] text-red-600">Try a different keyword.</p>
        <button id="kdc-retry-btn" class="mt-3 rounded-lg border border-red-300 bg-white px-4 py-2 text-[13px] font-medium text-red-700 hover:bg-red-100 cursor-pointer transition-colors">
          Try Again
        </button>
      </div>

      <!-- Results -->
      <div id="kdc-results" class="mt-6 hidden space-y-4">
        <!-- Score Card -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
          <div class="flex flex-col md:flex-row items-center gap-6">
            <div class="shrink-0">
              <div id="kdc-score-circle" class="inline-flex items-center justify-center h-28 w-28 rounded-full border-4">
                <div class="text-center">
                  <span id="kdc-score-value" class="text-[36px] font-bold block leading-none"></span>
                  <span class="text-[11px] text-[#79716b] uppercase tracking-wide">Difficulty</span>
                </div>
              </div>
            </div>
            <div class="flex-1 text-center md:text-left">
              <p class="font-mono text-[11px] uppercase tracking-wide text-[#79716b] mb-1">Keyword</p>
              <p id="kdc-keyword-display" class="text-[20px] font-semibold text-[#292524] mb-3"></p>
              <span id="kdc-level-badge" class="inline-block rounded-full px-3 py-1 text-[13px] font-semibold"></span>
            </div>
          </div>

          <!-- Quick Stats -->
          <div class="mt-6 grid grid-cols-3 gap-4 border-t border-[#f5f5f4] pt-6">
            <div class="text-center">
              <p class="font-mono text-[11px] uppercase tracking-wide text-[#79716b] mb-1">Est. Volume</p>
              <p id="kdc-volume" class="text-[16px] font-semibold text-[#292524]"></p>
            </div>
            <div class="text-center border-x border-[#f5f5f4]">
              <p class="font-mono text-[11px] uppercase tracking-wide text-[#79716b] mb-1">Time to Rank</p>
              <p id="kdc-time" class="text-[16px] font-semibold text-[#292524]"></p>
            </div>
            <div class="text-center">
              <p class="font-mono text-[11px] uppercase tracking-wide text-[#79716b] mb-1">Content Depth</p>
              <p id="kdc-depth" class="text-[16px] font-semibold text-[#292524]"></p>
            </div>
          </div>
        </div>

        <!-- Factor Breakdown -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <h3 class="font-sans text-[16px] font-semibold text-[#292524] mb-4">Factor Breakdown</h3>
          <div id="kdc-factors" class="space-y-4">
          </div>
        </div>

        <!-- Tips -->
        <div class="rounded-2xl border border-[#4f39f6] bg-[#f5f3ff] p-6">
          <h3 class="font-sans text-[16px] font-semibold text-[#292524] mb-3">Tips to Rank</h3>
          <ol id="kdc-tips" class="space-y-2 text-[14px] text-[#57534e]"></ol>
        </div>

        <!-- Start Over -->
        <div class="text-center">
          <button id="kdc-start-over" class="rounded-lg border border-[#e7e5e4] bg-white px-5 py-2.5 text-[14px] font-medium text-[#57534e] hover:border-[#4f39f6] hover:text-[#4f39f6] cursor-pointer transition-colors">
            Check Another Keyword
          </button>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable mx-auto max-w-3xl">
      <div class="mb-12 rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-3">What Is Keyword Difficulty?</h2>
        <p class="text-[15px] text-[#57534e] leading-relaxed">
          Keyword difficulty measures how hard it is to rank on page one of Google for a given keyword. It combines competition strength, SERP feature density, content requirements, and backlink needs into a single score you can act on.
        </p>
      </div>

      <div class="mb-12">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-4">How It Works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { step: '1', title: 'Enter a Keyword', desc: 'Type any keyword you are considering targeting.' },
            { step: '2', title: 'AI Analyzes Competition', desc: 'Our AI evaluates five ranking factors that determine difficulty.' },
            { step: '3', title: 'Get Your Score', desc: 'See an overall difficulty score plus a breakdown by factor.' },
            { step: '4', title: 'Follow the Tips', desc: 'Actionable recommendations show you exactly what it takes to rank.' },
          ].map((item) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-[#f5f3ff] font-mono text-[14px] font-bold text-[#4f39f6]">{item.step}</span>
              <h3 class="mt-3 font-sans text-[15px] font-semibold text-[#292524]">{item.title}</h3>
              <p class="mt-1 text-[14px] text-[#57534e] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mb-12">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-4">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="rounded-xl border border-[#e7e5e4] bg-white group">
              <summary class="flex cursor-pointer items-center justify-between p-5 font-sans text-[15px] font-semibold text-[#292524] list-none">
                {faq.q}
                <svg class="h-5 w-5 shrink-0 text-[#79716b] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-[14px] text-[#57534e] leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>

      <div class="rounded-2xl border border-[#4f39f6] bg-[#f5f3ff] p-6 md:p-8 text-center">
        <h2 class="font-sans text-[18px] font-semibold text-[#292524]">Want real-time keyword difficulty tracking?</h2>
        <p class="mt-2 text-[14px] text-[#57534e]">
          theStacc monitors keyword difficulty, search volume, and ranking changes across your entire keyword portfolio.
        </p>
        <a href="/" class="mt-4 inline-block rounded-xl bg-[#615fff] px-6 py-3 font-mono text-[13px] font-bold uppercase text-white hover:bg-[#4f39f6] transition-colors">
          Start Your $1 Trial
        </a>
      </div>
    </div>
  </Fragment>
</ToolLayout>

<script src="/js/keyword-difficulty-engine.js" defer></script>
