---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
  buildBreadcrumbSchema,
} from '../../lib/schema-builders';

const pageTitle = 'Free SEO ROI Calculator — Real Keyword Volume by City | theStacc';
const pageDescription = 'Calculate your SEO return on investment with real keyword volume data for your city and industry. Compare DIY vs agency vs Stacc. 12-month compound growth projections. Free, no signup.';
const pageUrl = 'https://thestacc.com/tools/seo-roi-calculator/';
const lastUpdated = '2026-05-13';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free SEO ROI Calculator',
  description: 'Calculate SEO return on investment with real keyword volume data by city and industry. Compare DIY vs agency vs automated tool with compound growth projections.',
  url: pageUrl,
});

const faqs = [
  { q: 'How do you calculate SEO ROI?', a: 'SEO ROI = (Revenue from organic traffic - SEO investment) / SEO investment x 100. For local businesses, track new customers from organic search, multiply by customer lifetime value, and subtract your monthly SEO cost. Most local businesses see positive ROI within 4-8 months. This calculator uses real keyword volume data from DataForSEO when you enter your city, so your projections are based on actual search demand, not guesswork.' },
  { q: 'Is SEO worth it for local businesses?', a: 'Yes. Local SEO delivers 3-10x ROI for most service businesses. A dentist investing $99/mo in SEO can expect 5-15 new patient inquiries per month by month 6-8, with each patient worth $1,000+ in lifetime value. The key variables are customer lifetime value, local search volume, and conversion rate — all of which this calculator factors in using industry benchmarks and real data.' },
  { q: 'How long does SEO take to show results?', a: 'SEO follows an S-curve: minimal results in months 1-3 (foundation building), noticeable improvement in months 4-6 (acceleration), and strong compounding returns from month 7 onward. Most local businesses break even between months 4-8. The biggest mistake is quitting during months 2-4 when the foundation work has not yet produced visible rankings. This calculator models realistic S-curve growth, not linear projections.' },
  { q: 'SEO vs Google Ads. Which is better for local businesses?', a: 'Google Ads delivers instant traffic but stops when you stop paying. SEO takes longer but compounds over time. For most local businesses, SEO becomes more cost-effective around month 6-8 and dramatically outperforms ads by month 12. A personal injury lawyer paying $80/click would spend $4,000/month for 50 clicks from ads. The same 50 clicks from SEO cost $0 after the initial investment — and keep growing.' },
  { q: 'Is this calculator free?', a: 'Yes, 100% free. No signup or credit card needed. Select your industry, enter your city to get real keyword volume data, adjust the sliders, and see real-time projections instantly. The keyword volume data comes from DataForSEO, the same API used by enterprise SEO platforms.' },
  { q: 'Where does the keyword volume data come from?', a: 'When you enter your city, the calculator queries DataForSEO — the same data provider used by Ahrefs, SEMrush, and other enterprise SEO platforms — for real monthly search volume, CPC, and keyword difficulty for your industry + city combination. If the API does not have data for your specific city, it falls back to national industry averages.' },
  { q: 'What is customer lifetime value (LTV) and why does it matter?', a: 'Customer lifetime value is the total revenue you expect from one customer over their entire relationship with your business. A dental patient might return twice a year for 5 years = $1,200 LTV. A personal injury client might be a one-time $15,000 case. Higher LTV means SEO ROI scales dramatically because each new customer is worth more. This calculator uses industry-specific LTV benchmarks that you can adjust.' },
  { q: 'How accurate are the projections?', a: 'The projections are estimates based on industry benchmarks and real keyword data. They assume consistent SEO effort (content publishing, technical optimization, authority building). Actual results vary by competition level, starting domain authority, and execution quality. The S-curve growth model is conservative — many businesses outperform these projections. The calculator is designed to show realistic ranges, not promises.' },
  { q: 'What is the difference between DIY, agency, and Stacc in the comparison?', a: 'DIY assumes you spend $200/month on tools and 10+ hours/week doing the work yourself, with slower growth (0.5x multiplier) due to inconsistent execution. Agency assumes $2,000-4,000/month with professional execution (1.2x multiplier) but high cost. Stacc assumes $99/month for automated content + GBP posts + social media (1.0x multiplier) — professional volume at a fraction of agency cost.' },
  { q: 'Should I hire an SEO agency or use a tool like Stacc?', a: 'Hire an agency if you have a $3,000+/month budget and need custom strategy for a complex, competitive market. Use Stacc if you are a local business that needs consistent content, GBP optimization, and review management at $99/month — the same volume an agency delivers for 5-10x less. Many businesses start with Stacc, see results, and then decide whether to scale up with an agency.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://thestacc.com/' },
  { name: 'Free SEO Tools', url: 'https://thestacc.com/tools/' },
  { name: 'SEO ROI Calculator', url: pageUrl },
]);

const industries = [
  { key: 'dentist', label: 'Dentist', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`, ltv: 1200 },
  { key: 'plumber', label: 'Plumber / HVAC', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`, ltv: 2500 },
  { key: 'lawyer', label: 'Lawyer', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m16 16 3-8 3 8c-.87.55-1.92.85-3 .85s-2.13-.3-3-.85z"/><path d="m2 16 3-8 3 8c-.87.55-1.92.85-3 .85s-2.13-.3-3-.85z"/><path d="M7 21h10"/><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>`, ltv: 5000 },
  { key: 'realtor', label: 'Real Estate', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, ltv: 8000 },
  { key: 'restaurant', label: 'Restaurant', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>`, ltv: 300 },
  { key: 'auto', label: 'Auto Repair', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="8" rx="2"/><path d="M7 8V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/><path d="M5 20v2"/><path d="M19 20v2"/><circle cx="7.5" cy="14" r="1.5"/><circle cx="16.5" cy="14" r="1.5"/></svg>`, ltv: 800 },
  { key: 'chiro', label: 'Chiropractor', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`, ltv: 1500 },
  { key: 'salon', label: 'Salon / Spa', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`, ltv: 600 },
  { key: 'custom', label: 'Custom', icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`, ltv: 0 },
];
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free SEO ROI Calculator"
  toolDescription="Calculate your SEO return on investment with real keyword volume data for your city and industry. Compare DIY vs agency vs Stacc. No signup."
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <!-- ==================== TOOL ==================== -->
  <Fragment slot="tool">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

    <div class="mx-auto max-w-2xl">
      <!-- Industry Selector -->
      <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-3">Select Your Industry</label>
        <div class="grid grid-cols-3 gap-2 sm:grid-cols-3 md:grid-cols-3">
          {industries.map(ind => (
            <button
              type="button"
              class="ind-card cursor-pointer flex flex-col items-center gap-1.5 rounded-xl border border-[#e7e5e4] p-3 md:p-4 text-center transition-all hover:border-[#c4b5fd] hover:shadow-md"
              data-industry={ind.key}
            >
              <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#f5f3ff] mb-0.5" set:html={ind.icon}></span>
              <span class="text-[12px] md:text-[13px] font-semibold text-[#292524]">{ind.label}</span>
              {ind.ltv > 0 && (
                <span class="text-[10px] text-[#79716b] font-mono">Avg LTV: ${ind.ltv.toLocaleString()}</span>
              )}
            </button>
          ))}
        </div>

        <!-- City Input -->
        <div class="mt-5">
          <label for="city-input" class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">Your City (optional — for real keyword volume)</label>
          <input
            type="text"
            id="city-input"
            placeholder="e.g., Austin, Miami, Chicago"
            class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#a8a29e] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none"
          />
          <p class="mt-1 text-[11px] text-[#79716b]">Enter your city to fetch real monthly search volume from DataForSEO. Leave blank to use industry averages.</p>
        </div>
      </div>

      <!-- Sliders -->
      <div id="sliders-section" class="mt-6 hidden rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <div class="flex items-center justify-between mb-4">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Adjust Your Numbers</label>
          <span id="volume-badge" class="hidden inline-flex items-center gap-1 rounded-full bg-[#f5f5f4] px-2 py-0.5 text-[10px] font-bold uppercase text-[#79716b]">Preset value</span>
        </div>

        <!-- Customer Lifetime Value -->
        <div class="mb-5">
          <div class="flex items-center justify-between mb-1.5">
            <label class="text-[13px] font-medium text-[#292524]" for="sl-ltv">Customer Lifetime Value</label>
            <span id="val-ltv" class="font-mono text-[13px] font-semibold text-[#6d28d9]">$1,200</span>
          </div>
          <input type="range" id="sl-ltv" min="100" max="100000" step="50" value="1200" class="w-full h-2 rounded-lg appearance-none cursor-pointer accent-[#615fff] bg-[#e7e5e4]" />
          <p class="mt-1 text-[11px] text-[#79716b]">How much is one customer worth over their lifetime?</p>
        </div>

        <!-- Conversion Rate -->
        <div class="mb-5">
          <div class="flex items-center justify-between mb-1.5">
            <label class="text-[13px] font-medium text-[#292524]" for="sl-conv">Conversion Rate</label>
            <span id="val-conv" class="font-mono text-[13px] font-semibold text-[#6d28d9]">8.0%</span>
          </div>
          <input type="range" id="sl-conv" min="1" max="30" step="0.5" value="8" class="w-full h-2 rounded-lg appearance-none cursor-pointer accent-[#615fff] bg-[#e7e5e4]" />
          <p class="mt-1 text-[11px] text-[#79716b]">What % of website visitors become customers?</p>
        </div>

        <!-- Monthly Search Volume -->
        <div class="mb-5">
          <div class="flex items-center justify-between mb-1.5">
            <label class="text-[13px] font-medium text-[#292524]" for="sl-searches">Monthly Local Searches</label>
            <span id="val-searches" class="font-mono text-[13px] font-semibold text-[#6d28d9]">1,200</span>
          </div>
          <input type="range" id="sl-searches" min="100" max="50000" step="50" value="1200" class="w-full h-2 rounded-lg appearance-none cursor-pointer accent-[#615fff] bg-[#e7e5e4]" />
          <p class="mt-1 text-[11px] text-[#79716b]">Monthly local searches for your services</p>
        </div>

        <!-- Monthly SEO Investment -->
        <div class="mb-5">
          <div class="flex items-center justify-between mb-1.5">
            <label class="text-[13px] font-medium text-[#292524]" for="sl-seo-cost">Monthly SEO Investment</label>
            <span id="val-seo-cost" class="font-mono text-[13px] font-semibold text-[#6d28d9]">$99</span>
          </div>
          <input type="range" id="sl-seo-cost" min="49" max="10000" step="10" value="99" class="w-full h-2 rounded-lg appearance-none cursor-pointer accent-[#615fff] bg-[#e7e5e4]" />
          <p class="mt-1 text-[11px] text-[#79716b]">Your monthly SEO budget</p>
        </div>

        <!-- Projection Period -->
        <div class="mb-2">
          <label class="block text-[13px] font-medium text-[#292524] mb-2">Projection Period</label>
          <div class="flex gap-2">
            {[
              { val: '6', label: '6 months' },
              { val: '12', label: '12 months' },
              { val: '24', label: '24 months' },
            ].map((p, i) => (
              <label class="cursor-pointer">
                <input type="radio" name="period" value={p.val} checked={i === 1} class="peer sr-only" />
                <span class="inline-block rounded-lg border border-[#e7e5e4] px-4 py-2 text-[13px] font-medium text-[#57534e] transition-all peer-checked:border-[#4f39f6] peer-checked:bg-[#f5f3ff] peer-checked:text-[#4f39f6]">{p.label}</span>
              </label>
            ))}
          </div>
        </div>
      </div>

      <!-- Results Dashboard -->
      <div id="results" class="mt-8 hidden">
        <!-- Headline Metrics -->
        <div class="grid grid-cols-2 gap-3 md:grid-cols-4 mb-6">
          <div class="rounded-2xl border border-[#bbf7d0] bg-[#f0fdf4] p-5 text-center" id="card-revenue">
            <p id="metric-revenue" class="font-sans text-[28px] font-bold text-[#292524]">$0</p>
            <p id="metric-revenue-sub" class="mt-1 font-mono text-[11px] text-[#79716b]">Over 12 months</p>
          </div>
          <div class="rounded-2xl border border-[#bbf7d0] bg-[#f0fdf4] p-5 text-center" id="card-roi">
            <p id="metric-roi" class="font-sans text-[28px] font-bold text-[#292524]">0%</p>
            <p id="metric-roi-sub" class="mt-1 font-mono text-[11px] text-[#79716b]">Return on investment</p>
          </div>
          <div class="rounded-2xl border border-[#bbf7d0] bg-[#f0fdf4] p-5 text-center" id="card-breakeven">
            <p id="metric-breakeven" class="font-sans text-[28px] font-bold text-[#292524]">—</p>
            <p id="metric-breakeven-sub" class="mt-1 font-mono text-[11px] text-[#79716b]">When revenue exceeds cost</p>
          </div>
          <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5 text-center">
            <p id="metric-cpl" class="font-sans text-[28px] font-bold text-[#292524]">$0</p>
            <p id="metric-cpl-sub" class="mt-1 font-mono text-[11px] text-[#79716b]">Cost per lead</p>
          </div>
        </div>

        <!-- Growth Chart -->
        <div class="mb-6">
          <p class="mb-2 font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Projected Growth</p>
          <div class="relative rounded-2xl border border-[#e7e5e4] bg-white p-4">
            <canvas id="roi-chart" class="w-full" style="max-width:700px;margin:0 auto;display:block"></canvas>
            <div id="chart-tooltip" class="absolute hidden pointer-events-none z-10 rounded-lg bg-[#292524] px-3 py-2 text-[12px] text-white font-mono shadow-lg" style="max-width:200px"></div>
          </div>
        </div>

        <!-- 3-Way Comparison Table -->
        <div class="mb-6">
          <p class="mb-2 font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">DIY vs Stacc vs Agency</p>
          <div class="rounded-2xl border border-[#e7e5e4] bg-white overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-[13px]">
                <thead>
                  <tr class="border-b border-[#e7e5e4]">
                    <th class="px-4 py-3 text-left font-mono text-[11px] uppercase text-[#79716b] font-medium">Metric</th>
                    <th class="px-4 py-3 text-center font-mono text-[11px] uppercase text-[#79716b] font-medium">DIY ($200/mo)</th>
                    <th class="px-4 py-3 text-center font-mono text-[11px] uppercase text-[#6d28d9] font-semibold bg-[#f5f3ff] border-x border-[#ddd6fe]">Stacc</th>
                    <th class="px-4 py-3 text-center font-mono text-[11px] uppercase text-[#79716b] font-medium">Agency</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="border-b border-[#f5f5f4]">
                    <td class="px-4 py-3 font-medium text-[#292524]">Total cost</td>
                    <td id="cmp-cost-diy" class="px-4 py-3 text-center text-[#57534e]">—</td>
                    <td id="cmp-cost-stacc" class="px-4 py-3 text-center font-semibold text-[#292524] bg-[#f5f3ff] border-x border-[#ddd6fe]">—</td>
                    <td id="cmp-cost-agency" class="px-4 py-3 text-center text-[#57534e]">—</td>
                  </tr>
                  <tr class="border-b border-[#f5f5f4]">
                    <td class="px-4 py-3 font-medium text-[#292524]">Projected revenue</td>
                    <td id="cmp-rev-diy" class="px-4 py-3 text-center text-[#57534e]">—</td>
                    <td id="cmp-rev-stacc" class="px-4 py-3 text-center font-semibold text-[#292524] bg-[#f5f3ff] border-x border-[#ddd6fe]">—</td>
                    <td id="cmp-rev-agency" class="px-4 py-3 text-center text-[#57534e]">—</td>
                  </tr>
                  <tr class="border-b border-[#f5f5f4]">
                    <td class="px-4 py-3 font-medium text-[#292524]">ROI</td>
                    <td id="cmp-roi-diy" class="px-4 py-3 text-center text-[#57534e]">—</td>
                    <td id="cmp-roi-stacc" class="px-4 py-3 text-center font-semibold text-[#16a34a] bg-[#f5f3ff] border-x border-[#ddd6fe]">—</td>
                    <td id="cmp-roi-agency" class="px-4 py-3 text-center text-[#57534e]">—</td>
                  </tr>
                  <tr class="border-b border-[#f5f5f4]">
                    <td class="px-4 py-3 font-medium text-[#292524]">Break-even</td>
                    <td id="cmp-be-diy" class="px-4 py-3 text-center text-[#57534e]">—</td>
                    <td id="cmp-be-stacc" class="px-4 py-3 text-center font-semibold text-[#292524] bg-[#f5f3ff] border-x border-[#ddd6fe]">—</td>
                    <td id="cmp-be-agency" class="px-4 py-3 text-center text-[#57534e]">—</td>
                  </tr>
                  <tr>
                    <td class="px-4 py-3 font-medium text-[#292524]">Content volume</td>
                    <td id="cmp-content-diy" class="px-4 py-3 text-center text-[#57534e]">—</td>
                    <td id="cmp-content-stacc" class="px-4 py-3 text-center font-semibold text-[#292524] bg-[#f5f3ff] border-x border-[#ddd6fe]">—</td>
                    <td id="cmp-content-agency" class="px-4 py-3 text-center text-[#57534e]">—</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Google Ads Comparison -->
        <div class="mb-6 rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5">
          <div class="flex items-start gap-2">
            <span class="mt-0.5 shrink-0"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></span>
            <div>
              <p class="font-sans text-[13px] font-semibold text-[#292524] mb-1">SEO vs Google Ads</p>
              <p id="ads-comparison" class="font-sans text-[13px] leading-relaxed text-[#57534e]">Select an industry above to see how SEO compares to Google Ads for your business.</p>
            </div>
          </div>
        </div>

        <!-- Shareable Results Card -->
        <div id="share-card" class="hidden mb-6">
          <p class="mb-2 font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Share Your Results</p>
          <div id="share-card-inner" class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
            <div class="flex items-center gap-2 mb-4">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#f5f3ff]"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
