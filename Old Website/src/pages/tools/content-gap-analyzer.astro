---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
  buildBreadcrumbSchema,
} from '../../lib/schema-builders';

const pageTitle = 'Free Content Gap Analyzer — Find Missing Topics Competitors Skip | theStacc';
const pageDescription = 'Free content gap analyzer. Enter any keyword and discover subtopics and angles your competitors are missing. Get prioritized content gaps with format suggestions and word count estimates.';
const pageUrl = 'https://thestacc.com/tools/content-gap-analyzer/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Content Gap Analyzer',
  description: 'Discover content gaps for any keyword. Find missing subtopics, angles, and formats your competitors overlook.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is a content gap?', a: 'A content gap is a subtopic, angle, or format that searchers want but existing content does not adequately cover. Finding and filling these gaps is one of the fastest ways to outrank competitors — you target what they missed.' },
  { q: 'How does this content gap tool work?', a: 'Enter a keyword and optionally a competitor URL. Our AI analyzes search intent patterns, competitor coverage, and content depth to identify specific subtopics that are underrepresented. Each gap includes priority level, recommended format, and estimated word count.' },
  { q: 'What do I do with the gaps this tool finds?', a: 'Each gap is a content brief waiting to happen. Use them to: expand thin existing content, create new pages that target long-tail queries, build topic clusters around your pillar content, or update old posts with missing sections.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Analyze any keyword and get instant content gaps. You can run up to 15 analyses per day.' },
  { q: 'How accurate are the content gaps?', a: 'The gaps are AI-generated based on semantic analysis, search intent patterns, and content coverage models. While not scraped from live SERP data, the analysis closely mirrors real gaps that SEOs find through manual research. The topics are specific enough to act on immediately.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://thestacc.com/' },
  { name: 'Free SEO Tools', url: 'https://thestacc.com/tools/' },
  { name: 'Content Gap Analyzer', url: pageUrl },
]);
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free Content Gap Analyzer"
  toolDescription="Discover content gaps for any keyword. Find missing subtopics, angles, and formats your competitors overlook."
  wide={true}
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <Fragment slot="tool">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

    <div class="mx-auto max-w-4xl">
      <!-- Input Form -->
      <div id="cga-step-1" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <div class="flex items-center gap-2 mb-6">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[12px] font-bold text-white">1</span>
          <span class="font-sans text-[16px] font-semibold text-[#292524]">Enter a Keyword</span>
        </div>

        <div class="space-y-3">
          <div>
            <label class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="cga-keyword">
              Target Keyword <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="cga-keyword"
              required
              placeholder="e.g., content marketing strategy, best CRM software"
              class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#a8a29e] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors"
            />
          </div>
          <div>
            <label class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="cga-competitor">
              Competitor URL (optional)
            </label>
            <input
              type="url"
              id="cga-competitor"
              placeholder="e.g., competitor.com/blog/seo-guide/"
              class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#a8a29e] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors"
            />
          </div>
        </div>

        <button
          id="cga-submit"
          class="mt-4 w-full rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3.5 font-mono text-sm font-bold uppercase text-white hover:bg-[#4f39f6] cursor-pointer disabled:opacity-50 transition-colors"
        >
          Find Content Gaps
        </button>

        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-[12px] text-[#a8a29e]">Try:</span>
          {['SEO content', 'local SEO', 'email marketing', 'SaaS pricing', 'content strategy'].map((example) => (
            <button class="cga-example-btn text-[12px] text-[#4f39f6] hover:underline cursor-pointer" data-keyword={example}>
              {example}
            </button>
          ))}
        </div>
      </div>

      <!-- Loading -->
      <div id="cga-loading" class="mt-6 hidden rounded-2xl border border-[#e7e5e4] bg-white p-6 text-center">
        <svg class="animate-spin mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="#4f39f6" stroke-width="3" opacity="0.25"/>
          <path d="M12 2a10 10 0 019.8 8" stroke="#4f39f6" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <p class="text-[15px] text-[#57534e]">Analyzing content coverage...</p>
        <p class="text-[13px] text-[#a8a29e] mt-1">This takes about 5-10 seconds</p>
      </div>

      <!-- Error -->
      <div id="cga-error-panel" class="mt-6 hidden rounded-2xl border border-red-200 bg-red-50 p-6 text-center">
        <svg class="mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        <p class="text-[15px] text-red-700 font-medium">Could not analyze content gaps</p>
        <p id="cga-error-msg" class="mt-1 text-[13px] text-red-600">Try a different keyword.</p>
        <button id="cga-retry-btn" class="mt-3 rounded-lg border border-red-300 bg-white px-4 py-2 text-[13px] font-medium text-red-700 hover:bg-red-100 cursor-pointer transition-colors">
          Try Again
        </button>
      </div>

      <!-- Results -->
      <div id="cga-results" class="mt-6 hidden space-y-4">
        <!-- Summary -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5">
          <div class="flex items-center justify-between flex-wrap gap-3 mb-3">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-wide text-[#79716b] mb-1">Keyword</p>
              <p id="cga-keyword-display" class="text-[18px] font-semibold text-[#292524]"></p>
            </div>
            <div class="flex gap-2">
              <span id="cga-high-badge" class="rounded-full px-2.5 py-1 text-[12px] font-medium bg-red-50 text-red-700 border border-red-200"></span>
              <span id="cga-medium-badge" class="rounded-full px-2.5 py-1 text-[12px] font-medium bg-amber-50 text-amber-700 border border-amber-200"></span>
              <span id="cga-low-badge" class="rounded-full px-2.5 py-1 text-[12px] font-medium bg-blue-50 text-blue-700 border border-blue-200"></span>
            </div>
          </div>
          <p id="cga-summary" class="text-[14px] text-[#57534e] leading-relaxed"></p>
        </div>

        <!-- Priority Filter -->
        <div class="flex flex-wrap gap-2" id="cga-priority-filters">
          <button class="priority-filter active rounded-full px-3 py-1 text-[12px] font-medium border border-[#4f39f6] bg-[#4f39f6] text-white cursor-pointer transition-colors" data-filter="all">All</button>
          <button class="priority-filter rounded-full px-3 py-1 text-[12px] font-medium border border-red-200 bg-red-50 text-red-700 hover:border-red-400 cursor-pointer transition-colors" data-filter="High">High</button>
          <button class="priority-filter rounded-full px-3 py-1 text-[12px] font-medium border border-amber-200 bg-amber-50 text-amber-700 hover:border-amber-400 cursor-pointer transition-colors" data-filter="Medium">Medium</button>
          <button class="priority-filter rounded-full px-3 py-1 text-[12px] font-medium border border-blue-200 bg-blue-50 text-blue-700 hover:border-blue-400 cursor-pointer transition-colors" data-filter="Low">Low</button>
        </div>

        <!-- Gaps List -->
        <div id="cga-gaps-list" class="space-y-3"></div>

        <!-- Start Over -->
        <div class="text-center">
          <button id="cga-start-over" class="rounded-lg border border-[#e7e5e4] bg-white px-5 py-2.5 text-[14px] font-medium text-[#57534e] hover:border-[#4f39f6] hover:text-[#4f39f6] cursor-pointer transition-colors">
            Analyze Another Keyword
          </button>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable mx-auto max-w-3xl">
      <div class="mb-12 rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-3">What Is a Content Gap?</h2>
        <p class="text-[15px] text-[#57534e] leading-relaxed">
          A content gap is a subtopic, question, or angle that your target audience cares about but existing content does not cover well. Finding these gaps lets you create content that ranks faster because you are filling a hole — not fighting for the same ground.
        </p>
      </div>

      <div class="mb-12">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-4">How It Works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { step: '1', title: 'Enter a Keyword', desc: 'Type the main keyword you want to rank for.' },
            { step: '2', title: 'AI Analyzes Coverage', desc: 'Our AI evaluates what subtopics are covered vs. missing in existing content.' },
            { step: '3', title: 'Get Prioritized Gaps', desc: 'Receive a list of content gaps sorted by priority with format and length suggestions.' },
            { step: '4', title: 'Create the Content', desc: 'Each gap is a content brief. Create new pages or expand existing ones to fill them.' },
          ].map((item) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-[#f5f3ff] font-mono text-[14px] font-bold text-[#4f39f6]">{item.step}</span>
              <h3 class="mt-3 font-sans text-[15px] font-semibold text-[#292524]">{item.title}</h3>
              <p class="mt-1 text-[14px] text-[#57534e] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mb-12">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-4">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="rounded-xl border border-[#e7e5e4] bg-white group">
              <summary class="flex cursor-pointer items-center justify-between p-5 font-sans text-[15px] font-semibold text-[#292524] list-none">
                {faq.q}
                <svg class="h-5 w-5 shrink-0 text-[#79716b] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-[14px] text-[#57534e] leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>

      <div class="rounded-2xl border border-[#4f39f6] bg-[#f5f3ff] p-6 md:p-8 text-center">
        <h2 class="font-sans text-[18px] font-semibold text-[#292524]">Want automated content gap monitoring?</h2>
        <p class="mt-2 text-[14px] text-[#57534e]">
          theStacc tracks competitor content updates and alerts you when new gaps appear in your keyword space.
        </p>
        <a href="/" class="mt-4 inline-block rounded-xl bg-[#615fff] px-6 py-3 font-mono text-[13px] font-bold uppercase text-white hover:bg-[#4f39f6] transition-colors">
          Start Your $1 Trial
        </a>
      </div>
    </div>
  </Fragment>
</ToolLayout>

<script src="/js/content-gap-analyzer-engine.js" defer></script>
