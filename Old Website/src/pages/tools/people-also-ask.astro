---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
  buildBreadcrumbSchema,
} from '../../lib/schema-builders';

const pageTitle = 'Free People Also Ask Tool — Find PAA Questions for Any Keyword | theStacc';
const pageDescription = 'Free People Also Ask tool. Enter any keyword and discover the PAA questions Google shows, organized by search intent. Use them for content ideas, FAQ sections, and blog outlines.';
const pageUrl = 'https://thestacc.com/tools/people-also-ask/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free People Also Ask Tool',
  description: 'Discover People Also Ask questions for any keyword. Generate PAA-style questions with answers organized by search intent.',
  url: pageUrl,
});

const faqs = [
  { q: 'What are People Also Ask questions?', a: 'People Also Ask (PAA) are question boxes that appear in Google search results. When a user clicks one question, it expands to show a short answer and reveals more related questions. They represent real searcher intent and are a goldmine for content ideas.' },
  { q: 'How does this PAA tool work?', a: 'Enter any keyword or topic. Our AI analyzes search intent patterns and generates realistic PAA-style questions with concise answers, organized by intent category (informational, how-to, comparison, etc.).' },
  { q: 'Why should I use PAA questions in my content?', a: 'PAA questions directly reflect what your audience is searching for. Using them in your content: improves relevance signals to Google, helps you rank for long-tail queries, gives you FAQ section content, and reveals content gaps your competitors missed.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Enter any keyword and get instant PAA questions. You can run up to 15 searches per day.' },
  { q: 'How accurate are the PAA questions?', a: 'The questions are AI-generated based on real search intent patterns and semantic analysis. While not scraped directly from Google, they closely mirror the types of questions that appear in PAA boxes for similar keywords. They are highly usable for content planning and SEO strategy.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://thestacc.com/' },
  { name: 'Free SEO Tools', url: 'https://thestacc.com/tools/' },
  { name: 'People Also Ask Tool', url: pageUrl },
]);

const intentColors: Record<string, string> = {
  informational: 'bg-blue-50 text-blue-700 border-blue-200',
  comparison: 'bg-purple-50 text-purple-700 border-purple-200',
  'how-to': 'bg-green-50 text-green-700 border-green-200',
  transactional: 'bg-amber-50 text-amber-700 border-amber-200',
  navigational: 'bg-slate-50 text-slate-700 border-slate-200',
};

const intentLabels: Record<string, string> = {
  informational: 'Informational',
  comparison: 'Comparison',
  'how-to': 'How-To',
  transactional: 'Transactional',
  navigational: 'Navigational',
};
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free People Also Ask Tool"
  toolDescription="Discover People Also Ask questions for any keyword. Generate PAA-style questions with answers organized by search intent."
  wide={true}
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <Fragment slot="tool">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

    <div class="mx-auto max-w-4xl">
      <!-- Input Form -->
      <div id="paa-step-1" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <div class="flex items-center gap-2 mb-6">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[12px] font-bold text-white">1</span>
          <span class="font-sans text-[16px] font-semibold text-[#292524]">Enter a Keyword or Topic</span>
        </div>

        <div class="flex gap-3">
          <input
            type="text"
            id="paa-keyword"
            required
            placeholder="e.g., SEO content optimization, best CRM software, how to rank on Google"
            class="flex-1 rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#a8a29e] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors"
          />
          <button
            id="paa-submit"
            class="shrink-0 rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3 font-mono text-sm font-bold uppercase text-white hover:bg-[#4f39f6] cursor-pointer disabled:opacity-50 transition-colors"
          >
            Find PAA
          </button>
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          <span class="text-[12px] text-[#a8a29e]">Try:</span>
          {['content marketing', 'local SEO', 'backlink building', 'SERP features', 'technical SEO'].map((example) => (
            <button class="paa-example-btn text-[12px] text-[#4f39f6] hover:underline cursor-pointer" data-keyword={example}>
              {example}
            </button>
          ))}
        </div>
      </div>

      <!-- Loading -->
      <div id="paa-loading" class="mt-6 hidden rounded-2xl border border-[#e7e5e4] bg-white p-6 text-center">
        <svg class="animate-spin mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="#4f39f6" stroke-width="3" opacity="0.25"/>
          <path d="M12 2a10 10 0 019.8 8" stroke="#4f39f6" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <p class="text-[15px] text-[#57534e]">Analyzing search intent patterns...</p>
        <p class="text-[13px] text-[#a8a29e] mt-1">This takes about 5-10 seconds</p>
      </div>

      <!-- Error -->
      <div id="paa-error-panel" class="mt-6 hidden rounded-2xl border border-red-200 bg-red-50 p-6 text-center">
        <svg class="mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        <p class="text-[15px] text-red-700 font-medium">Could not generate PAA questions</p>
        <p id="paa-error-msg" class="mt-1 text-[13px] text-red-600">Try a different keyword.</p>
        <button id="paa-retry-btn" class="mt-3 rounded-lg border border-red-300 bg-white px-4 py-2 text-[13px] font-medium text-red-700 hover:bg-red-100 cursor-pointer transition-colors">
          Try Again
        </button>
      </div>

      <!-- Results -->
      <div id="paa-results" class="mt-6 hidden">
        <!-- Header -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-5 mb-4">
          <div class="flex items-center justify-between flex-wrap gap-3">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-wide text-[#79716b]">Keyword</p>
              <p id="paa-keyword-display" class="text-[18px] font-semibold text-[#292524]"></p>
            </div>
            <div class="flex gap-2">
              <button id="paa-copy-all" class="rounded-lg border border-[#e7e5e4] bg-white px-4 py-2 text-[13px] font-medium text-[#57534e] hover:border-[#4f39f6] hover:text-[#4f39f6] cursor-pointer transition-colors">
                Copy All
              </button>
              <button id="paa-download" class="rounded-lg border border-[#4f39f6] bg-[#f5f3ff] px-4 py-2 text-[13px] font-medium text-[#4f39f6] hover:bg-[#ebe7fe] cursor-pointer transition-colors">
                Download CSV
              </button>
            </div>
          </div>

          <!-- Intent filter -->
          <div class="mt-4 flex flex-wrap gap-2" id="paa-intent-filters">
            <button class="intent-filter active rounded-full px-3 py-1 text-[12px] font-medium border border-[#4f39f6] bg-[#4f39f6] text-white cursor-pointer transition-colors" data-filter="all">All</button>
            {Object.entries(intentLabels).map(([key, label]) => (
              <button class="intent-filter rounded-full px-3 py-1 text-[12px] font-medium border border-[#e7e5e4] bg-white text-[#57534e] hover:border-[#4f39f6] cursor-pointer transition-colors" data-filter={key}>
                {label}
              </button>
            ))}
          </div>
        </div>

        <!-- PAA List -->
        <div id="paa-list" class="space-y-3">
        </div>

        <!-- Start Over -->
        <div class="text-center mt-6">
          <button id="paa-start-over" class="rounded-lg border border-[#e7e5e4] bg-white px-5 py-2.5 text-[14px] font-medium text-[#57534e] hover:border-[#4f39f6] hover:text-[#4f39f6] cursor-pointer transition-colors">
            Search Another Keyword
          </button>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable mx-auto max-w-3xl">
      <div class="mb-12 rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-3">What Are People Also Ask Questions?</h2>
        <p class="text-[15px] text-[#57534e] leading-relaxed">
          People Also Ask (PAA) are expandable question boxes in Google's search results. They reveal what real searchers want to know about a topic — making them one of the best sources of content ideas and SEO opportunities.
        </p>
      </div>

      <div class="mb-12">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-4">How It Works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { step: '1', title: 'Enter a Keyword', desc: 'Type any topic, product, or question into the search box above.' },
            { step: '2', title: 'AI Analyzes Intent', desc: 'Our AI models search behavior patterns to identify the questions people actually ask.' },
            { step: '3', title: 'Get PAA Questions', desc: 'Receive 10+ questions organized by intent type, each with a concise answer.' },
            { step: '4', title: 'Use in Your Content', desc: 'Add them to FAQ sections, blog outlines, or content briefs to capture more search traffic.' },
          ].map((item) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-[#f5f3ff] font-mono text-[14px] font-bold text-[#4f39f6]">{item.step}</span>
              <h3 class="mt-3 font-sans text-[15px] font-semibold text-[#292524]">{item.title}</h3>
              <p class="mt-1 text-[14px] text-[#57534e] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mb-12">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-4">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="rounded-xl border border-[#e7e5e4] bg-white group">
              <summary class="flex cursor-pointer items-center justify-between p-5 font-sans text-[15px] font-semibold text-[#292524] list-none">
                {faq.q}
                <svg class="h-5 w-5 shrink-0 text-[#79716b] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-[14px] text-[#57534e] leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>

      <div class="rounded-2xl border border-[#4f39f6] bg-[#f5f3ff] p-6 md:p-8 text-center">
        <h2 class="font-sans text-[18px] font-semibold text-[#292524]">Want to track PAA rankings for your keywords?</h2>
        <p class="mt-2 text-[14px] text-[#57534e]">
          theStacc monitors SERP features — including PAA, featured snippets, and rich results — across all your target keywords.
        </p>
        <a href="/" class="mt-4 inline-block rounded-xl bg-[#615fff] px-6 py-3 font-mono text-[13px] font-bold uppercase text-white hover:bg-[#4f39f6] transition-colors">
          Start Your $1 Trial
        </a>
      </div>
    </div>
  </Fragment>
</ToolLayout>

<script src="/js/people-also-ask-engine.js" defer></script>
