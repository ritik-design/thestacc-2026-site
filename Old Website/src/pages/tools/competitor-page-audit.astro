---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
  buildBreadcrumbSchema,
} from '../../lib/schema-builders';

const pageTitle = 'Free Competitor Page Audit — Side-by-Side SEO Comparison | theStacc';
const pageDescription = 'Free competitor page audit tool. Compare any two pages side-by-side for titles, meta descriptions, headings, content, schema markup, and more. Get scored comparisons and AI recommendations.';
const pageUrl = 'https://thestacc.com/tools/competitor-page-audit/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Competitor Page Audit',
  description: 'Compare any two web pages side-by-side for SEO elements including titles, meta descriptions, headings, content depth, images, links, and schema markup.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is a competitor page audit?', a: 'A competitor page audit compares two web pages side-by-side across key SEO elements like title tags, meta descriptions, headings, content length, images, internal links, and schema markup. It helps you understand why a competitor page might outrank yours and identifies specific areas for improvement.' },
  { q: 'How does this competitor audit tool work?', a: 'Enter your page URL and a competitor page URL. Our tool fetches both pages, analyzes their on-page SEO elements, scores each category (0-100), and shows a side-by-side comparison. You also get AI-generated recommendations for the weaker page.' },
  { q: 'What elements does the audit compare?', a: 'The audit compares: title tags, meta descriptions, H1/H2 heading structure, content word count, image count and alt text coverage, internal and external links, schema markup types, canonical tags, and Open Graph social tags.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Enter any two URLs and get an instant comparison. You can run up to 10 audits per day.' },
  { q: 'Can I compare any two pages?', a: 'Yes, you can compare any two publicly accessible web pages. Both pages must be reachable without login. The tool respects robots.txt and will not crawl pages that block crawlers.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://thestacc.com/' },
  { name: 'Free SEO Tools', url: 'https://thestacc.com/tools/' },
  { name: 'Competitor Page Audit', url: pageUrl },
]);
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free Competitor Page Audit"
  toolDescription="Compare any two web pages side-by-side for SEO elements and get scored comparisons with AI recommendations."
  wide={true}
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <Fragment slot="tool">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

    <div class="mx-auto max-w-5xl">
      <!-- Input Form -->
      <div id="cpa-step-1" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <div class="flex items-center gap-2 mb-6">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[12px] font-bold text-white">1</span>
          <span class="font-sans text-[16px] font-semibold text-[#292524]">Enter Two Pages to Compare</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="cpa-url-a">
              Your Page URL <span class="text-red-500">*</span>
            </label>
            <input type="url" id="cpa-url-a" required placeholder="e.g., thestacc.com/blog/seo-guide/"
              class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#a8a29e] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors"
            />
          </div>
          <div>
            <label class="block font-mono text-[11px] font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="cpa-url-b">
              Competitor Page URL <span class="text-red-500">*</span>
            </label>
            <input type="url" id="cpa-url-b" required placeholder="e.g., competitor.com/blog/seo-guide/"
              class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#a8a29e] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors"
            />
          </div>
        </div>

        <button id="cpa-submit" class="mt-4 w-full rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3.5 font-mono text-sm font-bold uppercase text-white hover:bg-[#4f39f6] cursor-pointer disabled:opacity-50 transition-colors">
          Compare Pages
        </button>
      </div>

      <!-- Loading -->
      <div id="cpa-loading" class="mt-6 hidden rounded-2xl border border-[#e7e5e4] bg-white p-6 text-center">
        <svg class="animate-spin mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="10" stroke="#4f39f6" stroke-width="3" opacity="0.25"/>
          <path d="M12 2a10 10 0 019.8 8" stroke="#4f39f6" stroke-width="3" stroke-linecap="round"/>
        </svg>
        <p class="text-[15px] text-[#57534e]">Analyzing both pages...</p>
        <p class="text-[13px] text-[#a8a29e] mt-1">This takes about 5-10 seconds</p>
      </div>

      <!-- Error -->
      <div id="cpa-error-panel" class="mt-6 hidden rounded-2xl border border-red-200 bg-red-50 p-6 text-center">
        <svg class="mx-auto mb-3" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        <p class="text-[15px] text-red-700 font-medium">Could not complete audit</p>
        <p id="cpa-error-msg" class="mt-1 text-[13px] text-red-600">Check both URLs and try again.</p>
        <button id="cpa-retry-btn" class="mt-3 rounded-lg border border-red-300 bg-white px-4 py-2 text-[13px] font-medium text-red-700 hover:bg-red-100 cursor-pointer transition-colors">
          Try Again
        </button>
      </div>

      <!-- Results -->
      <div id="cpa-results" class="mt-6 hidden space-y-6">
        <!-- Overall Scores -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div id="cpa-score-a" class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <p class="font-mono text-[11px] uppercase tracking-wide text-[#79716b] mb-1">Your Page</p>
            <p id="cpa-url-a-display" class="text-[13px] text-[#57534e] truncate mb-3"></p>
            <div class="flex items-end gap-2">
              <span id="cpa-score-a-value" class="text-[36px] font-bold text-[#292524]">0</span>
              <span class="text-[14px] text-[#79716b] mb-1.5">/ 100</span>
            </div>
          </div>
          <div id="cpa-score-b" class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <p class="font-mono text-[11px] uppercase tracking-wide text-[#79716b] mb-1">Competitor</p>
            <p id="cpa-url-b-display" class="text-[13px] text-[#57534e] truncate mb-3"></p>
            <div class="flex items-end gap-2">
              <span id="cpa-score-b-value" class="text-[36px] font-bold text-[#292524]">0</span>
              <span class="text-[14px] text-[#79716b] mb-1.5">/ 100</span>
            </div>
          </div>
        </div>

        <!-- Comparison Table -->
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <h3 class="font-sans text-[16px] font-semibold text-[#292524] mb-4">Side-by-Side Comparison</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-[14px]">
              <thead>
                <tr class="border-b-2 border-[#e7e5e4] bg-[#fafaf9]">
                  <th class="py-3 px-4 text-left font-semibold text-[#292524]">Category</th>
                  <th class="py-3 px-4 text-center font-semibold text-[#292524]">Your Page</th>
                  <th class="py-3 px-4 text-center font-semibold text-[#292524]">Competitor</th>
                  <th class="py-3 px-4 text-center font-semibold text-[#292524]">Winner</th>
                </tr>
              </thead>
              <tbody id="cpa-comparison-body" class="text-[#57534e]">
              </tbody>
            </table>
          </div>
        </div>

        <!-- Details Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div id="cpa-details-a" class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <h4 class="font-sans text-[14px] font-semibold text-[#292524] mb-3">Your Page Details</h4>
            <div id="cpa-details-a-content" class="space-y-2 text-[13px]"></div>
          </div>
          <div id="cpa-details-b" class="rounded-xl border border-[#e7e5e4] bg-white p-5">
            <h4 class="font-sans text-[14px] font-semibold text-[#292524] mb-3">Competitor Details</h4>
            <div id="cpa-details-b-content" class="space-y-2 text-[13px]"></div>
          </div>
        </div>

        <!-- Recommendations -->
        <div id="cpa-recommendations" class="rounded-2xl border border-[#4f39f6] bg-[#f5f3ff] p-6">
          <h3 class="font-sans text-[16px] font-semibold text-[#292524] mb-3">AI Recommendations</h3>
          <ol id="cpa-recommendations-list" class="space-y-2 text-[14px] text-[#57534e]"></ol>
        </div>

        <!-- Start Over -->
        <div class="text-center">
          <button id="cpa-start-over" class="rounded-lg border border-[#e7e5e4] bg-white px-5 py-2.5 text-[14px] font-medium text-[#57534e] hover:border-[#4f39f6] hover:text-[#4f39f6] cursor-pointer transition-colors">
            Compare Another Pair
          </button>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable mx-auto max-w-3xl">
      <div class="mb-12 rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-3">What is a Competitor Page Audit?</h2>
        <p class="text-[15px] text-[#57534e] leading-relaxed">
          A competitor page audit compares two web pages side-by-side across key SEO elements. Enter your page and a competitor page above to see exactly where you stand — and what to improve.
        </p>
      </div>

      <div class="mb-12">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-4">How It Works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { step: '1', title: 'Enter Two URLs', desc: 'Paste your page URL and a competitor page URL you want to compare against.' },
            { step: '2', title: 'Fetch & Analyze', desc: 'We fetch both pages and extract titles, meta descriptions, headings, content, images, links, and schema.' },
            { step: '3', title: 'Score & Compare', desc: 'Each SEO element is scored 0-100 and compared side-by-side with a clear winner.' },
            { step: '4', title: 'Get Recommendations', desc: 'AI-generated actionable recommendations help you close the gap.' },
          ].map((item) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-[#f5f3ff] font-mono text-[14px] font-bold text-[#4f39f6]">{item.step}</span>
              <h3 class="mt-3 font-sans text-[15px] font-semibold text-[#292524]">{item.title}</h3>
              <p class="mt-1 text-[14px] text-[#57534e] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mb-12">
        <h2 class="font-sans text-[20px] font-semibold text-[#292524] mb-4">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((faq, i) => (
            <details class="rounded-xl border border-[#e7e5e4] bg-white group">
              <summary class="flex cursor-pointer items-center justify-between p-5 font-sans text-[15px] font-semibold text-[#292524] list-none">
                {faq.q}
                <svg class="h-5 w-5 shrink-0 text-[#79716b] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-[14px] text-[#57534e] leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>

      <div class="rounded-2xl border border-[#4f39f6] bg-[#f5f3ff] p-6 md:p-8 text-center">
        <h2 class="font-sans text-[18px] font-semibold text-[#292524]">Want deeper competitive analysis?</h2>
        <p class="mt-2 text-[14px] text-[#57534e]">
          theStacc tracks competitor rankings, content gaps, and backlink opportunities automatically.
        </p>
        <a href="/" class="mt-4 inline-block rounded-xl bg-[#615fff] px-6 py-3 font-mono text-[13px] font-bold uppercase text-white hover:bg-[#4f39f6] transition-colors">
          Start Your $1 Trial
        </a>
      </div>
    </div>
  </Fragment>
</ToolLayout>

<script src="/js/competitor-page-audit-engine.js" defer></script>
