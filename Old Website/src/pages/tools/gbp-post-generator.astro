---
import ToolLayout from '../../components/tools/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../lib/schema-builders';

const pageTitle = 'Free Google Business Profile Post Generator (3 Posts in 8s) | theStacc';
const pageDescription = 'Generate 3 ready-to-publish GBP posts in 8 seconds. Industry-specific. Locally relevant. With the right CTA button. No signup.';
const pageUrl = 'https://thestacc.com/tools/gbp-post-generator/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Google Business Profile Post Generator',
  description: 'Generates 3 ready-to-post GBP updates with industry-specific language, local keywords, and the right CTA button. Includes a 100-point quality scorer.',
  url: pageUrl,
});

const faqs = [
  { q: 'What should I post on my Google Business Profile?', a: 'Customer stories, seasonal offers, FAQ answers, behind-the-scenes content, industry tips, and event announcements. Skip generic promotional copy — Google\'s algorithm and your customers both reward specificity.' },
  { q: 'How often should I post on Google Business Profile?', a: 'At least once per week. Active profiles see up to 2x more discovery searches. Posts last 7 days for standard updates, or through expiry for offer/event posts.' },
  { q: 'Do GBP posts help with local SEO?', a: 'Yes. GBP posts are a confirmed local ranking signal. Active profiles with regular posts, photos, and review responses rank higher in the Google Map Pack.' },
  { q: 'What size should images be on Google Business Profile?', a: '1200×900 pixels is ideal. Google supports up to 10MB. Use real photos of your business, work, or team — stock images underperform.' },
  { q: 'Why are my Google Business Profile posts getting rejected?', a: 'Common reasons: phone numbers in the post body (use the CTA instead), prohibited content (alcohol, pharmacy, gambling), pricing without local context, or violating Google\'s content policies. The tool above generates compliant posts by default.' },
  { q: 'What is a good CTA button for a GBP post?', a: 'Match it to your conversion goal. "Book" works for appointments. "Call now" for emergencies. "Learn more" for educational content. "Get offer" for promotions. The tool maps your post type to the optimal button.' },
  { q: 'Can I schedule GBP posts in advance?', a: 'Google Business Profile doesn\'t natively schedule posts, but tools like Stacc, Localo, and Hootsuite can. The free tool above generates the posts — for automated scheduling and unlimited generation, try Stacc.' },
  { q: 'What words attract customers in GBP posts?', a: 'Specific numbers ("$49 tune-up"), customer names ("Maria saved $1,200"), urgency ("Before March 31"), and concrete outcomes ("AC fixed in 90 minutes"). Avoid: "industry-leading", "tailored to your needs", "state-of-the-art".' },
  { q: 'What is the 7-11-4 Google strategy?', a: 'A small-business marketing principle: 7 hours of brand interaction, 11 touchpoints, across 4 locations builds trust. Applied to GBP: post weekly for 7+ weeks, across 4+ Google surfaces (posts, photos, reviews, Q&A) to build local authority.' },
  { q: 'Is this GBP post generator really free?', a: 'Yes. No credit card. No email required to use the tool. We make money when local businesses upgrade to Stacc, our automated SEO platform — but the tool itself is free forever.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const industries = [
  'Dental / Orthodontics','Legal / Law Firm','Plumbing / HVAC','Electrical',
  'Roofing / Construction','Real Estate','Accounting / Tax','Restaurant / Cafe',
  'Salon / Spa / Beauty','Auto Repair / Detailing','Cleaning Services','Landscaping / Lawn Care',
  'Veterinary / Pet Services','Chiropractic / Physical Therapy','IT Services / Consulting',
  'Fitness / Gym / Yoga','Photography / Videography','Insurance / Financial Services',
  'Home Staging / Interior Design','Tutoring / Education','Pet Grooming / Boarding',
  'Moving / Storage','Pest Control',
];

const lastUpdated = '2026-05-10';
---

<ToolLayout
  title={pageTitle}
  description={pageDescription}
  toolName="Free Google Business Profile Post Generator"
  toolDescription="Generate 3 ready-to-post GBP updates in 8 seconds. AI-powered with a 100-point quality scorer. Industry-specific. Locally relevant. No signup."
  schema={softwareSchema}
  faqSchema={faqSchema}
>
  <!-- ==================== TOOL ==================== -->
  <Fragment slot="tool">
    <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
      <form id="form" novalidate>
        <!-- Business Name -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="biz">Business Name <span class="text-red-500">*</span></label>
          <input type="text" id="biz" required maxlength="100" placeholder="e.g., Smith Family Dental" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          <p class="mt-1 hidden text-xs text-red-500" id="err-biz">Please enter your business name</p>
        </div>

        <!-- City -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="city">City / Location <span class="text-red-500">*</span></label>
          <input type="text" id="city" required maxlength="60" placeholder="e.g., Austin, TX" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          <p class="mt-1 hidden text-xs text-red-500" id="err-city">Please enter your city or location</p>
        </div>

        <!-- Industry -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="ind">Industry <span class="text-red-500">*</span></label>
          <select id="ind" required class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2379716b%22%20stroke-width%3D%222.5%22%3E%3Cpath%20d%3D%22m6%209%206%206%206-6%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_16px_center] bg-no-repeat">
            <option value="" disabled selected>Select your industry</option>
            {industries.map(ind => <option>{ind}</option>)}
            <option value="__other__">Other (type your own)</option>
          </select>
          <p class="mt-1 hidden text-xs text-red-500" id="err-ind">Please select your industry</p>
          <input type="text" id="ind-other" placeholder="e.g., Wedding planning, Pool cleaning, Tattoo studio" maxlength="60" class="mt-1.5 hidden w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
        </div>

        <!-- Post Angle -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-2">Post Angle <span class="text-red-500">*</span></label>
          <div class="grid grid-cols-3 gap-2 sm:grid-cols-3">
            {[
              { val: 'tip', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`, label: 'Tip / Advice' },
              { val: 'seasonal', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`, label: 'Seasonal' },
              { val: 'story', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`, label: 'Customer Story' },
              { val: 'offer', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`, label: 'Offer / Promo' },
              { val: 'bts', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`, label: 'Behind the Scenes' },
              { val: 'faq', icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`, label: 'FAQ / Myth-Bust' },
            ].map((a, i) => (
              <label class="cursor-pointer">
                <input type="radio" name="angle" value={a.val} checked={i === 0} class="peer sr-only" />
                <span class="flex flex-col items-center gap-1 rounded-[10px] border border-[#e7e5e4] p-3 text-center transition-all peer-checked:border-[#4f39f6] peer-checked:bg-[#f5f3ff]">
                  <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-[#f5f3ff]" set:html={a.icon}></span>
                  <span class="text-[12px] font-semibold text-[#57534e] peer-checked:text-[#4f39f6]">{a.label}</span>
                </span>
              </label>
            ))}
          </div>
        </div>

        <!-- Tone -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-2">Tone</label>
          <div class="flex gap-2">
            {['Professional', 'Friendly', 'Casual'].map((t, i) => (
              <label class="cursor-pointer">
                <input type="radio" name="tone" value={t.toLowerCase()} checked={i === 0} class="peer sr-only" />
                <span class="inline-block rounded-lg border border-[#e7e5e4] px-4 py-2 text-[13px] font-medium text-[#57534e] transition-all peer-checked:border-[#4f39f6] peer-checked:bg-[#f5f3ff] peer-checked:text-[#4f39f6]">{t}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- Offer Fields (conditional) -->
        <div id="offer-f" class="mb-5 hidden rounded-xl border border-dashed border-[#ddd6fe] bg-[#faf5ff]/50 p-4 space-y-4">
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="offer-t">Offer Title <span class="text-red-500">*</span></label>
            <input type="text" id="offer-t" placeholder="e.g., 20% Off Spring AC Tune-Up" maxlength="80" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="coupon">Coupon Code</label>
              <input type="text" id="coupon" placeholder="e.g., SPRING20" maxlength="20" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
            <div>
              <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="terms">Offer Terms</label>
              <input type="text" id="terms" placeholder="e.g., Valid through April 30" maxlength="100" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
            </div>
          </div>
        </div>

        <!-- Key Message -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="topic">Key Message <span class="font-normal normal-case tracking-normal text-[#79716b]">. Optional</span></label>
          <textarea id="topic" maxlength="300" rows="2" placeholder="e.g., New patient special, weekend hours, we just hired a new technician" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors resize-none"></textarea>
          <p class="mt-1 text-right font-mono text-xs text-[#79716b]"><span id="tc">0</span> / 300</p>
          <div id="idea-chips" class="mt-2 hidden flex-wrap gap-1.5"></div>
        </div>

        <!-- No-Hashtag Note -->
        <div class="mb-5 flex items-start gap-2 rounded-lg bg-[#fffbeb] border border-[#fde68a] p-3">
          <span class="mt-0.5 shrink-0"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg></span>
          <p class="text-[13px] text-[#92400e] leading-relaxed"><strong>GBP is not Instagram.</strong> Hashtags do nothing on Google Business Profile. We generate clean, hashtag-free posts with local keywords that actually help you rank.</p>
        </div>

        <!-- CTA Button -->
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="cta">CTA Button</label>
          <select id="cta" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 font-sans text-[15px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2379716b%22%20stroke-width%3D%222.5%22%3E%3Cpath%20d%3D%22m6%209%206%206%206-6%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_16px_center] bg-no-repeat">
            <option value="Book">Book</option>
            <option value="Order online">Order Online</option>
            <option value="Learn more" selected>Learn More</option>
            <option value="Call now">Call Now</option>
            <option value="Sign up">Sign Up</option>
            <option value="Get offer">Get Offer</option>
          </select>
        </div>

        <button type="submit" id="gen-btn" class="w-full cursor-pointer rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3.5 font-mono text-sm font-bold uppercase tracking-wide text-white transition-all hover:bg-[#4f39f6] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
          Generate 3 Post Variations
        </button>
      </form>
    </div>

    <!-- Results -->
    <div id="results" class="mt-8 hidden">
      <div class="mb-4 flex items-center justify-center gap-1.5 rounded-lg bg-[#fafaf9] border border-[#e7e5e4] px-4 py-2 font-mono text-xs text-[#79716b]">
        Posts generated this session: <strong class="text-[#6d28d9]" id="gen-count">0</strong> &middot; Regenerate anytime for different results
      </div>

      <!-- Post 1 -->
      <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6 mb-4">
        <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]">Short &middot; Direct</span>
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs text-[#79716b]" id="st1"></span>
            <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="1">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              <span>Copy</span>
            </button>
          </div>
        </div>
        <div class="mt-3 whitespace-pre-wrap font-sans text-[16px] leading-[1.8] text-[#292524]" id="pt1"></div>
        <div id="tr1" class="mt-3 hidden"><hr class="border-t border-dashed border-[#c4b5fd]" /><p class="mt-1 font-mono text-[10px] text-[#8b5cf6]">↑ Visible before "Read more" on mobile</p></div>
        <div id="hs1" class="mt-2 inline-flex items-center gap-1 rounded-md px-2.5 py-1 font-mono text-[11px] font-semibold"></div>
        <div id="tip1" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
      </div>

      <!-- Email Gate REMOVED — Tier 3 tool, full output shown free -->

      <!-- All 3 Posts (always visible after generation) -->
      <div id="gated" class="space-y-4">
        <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6">
          <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]">Medium &middot; Detailed</span>
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-[#79716b]" id="st2"></span>
              <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="2"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg><span>Copy</span></button>
            </div>
          </div>
          <div class="mt-3 whitespace-pre-wrap font-sans text-[16px] leading-[1.8] text-[#292524]" id="pt2"></div>
          <div id="tip2" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
        </div>
        <div class="rounded-2xl border border-[#ddd6fe] bg-[#f5f3ff] p-5 md:p-6">
          <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#ede9fe] px-2.5 py-0.5 font-mono text-[11px] font-semibold uppercase text-[#6d28d9]">Long &middot; Story-driven</span>
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-[#79716b]" id="st3"></span>
              <button class="btn-cp inline-flex items-center gap-1.5 rounded-lg border border-[#ddd6fe] bg-white px-3 py-1.5 font-mono text-xs font-medium text-[#57534e] cursor-pointer transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]" data-c="3"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg><span>Copy</span></button>
            </div>
          </div>
          <div class="mt-3 whitespace-pre-wrap font-sans text-[16px] leading-[1.8] text-[#292524]" id="pt3"></div>
          <div id="tip3" class="mt-2.5 rounded-lg bg-white border border-[#e7e5e4] px-3.5 py-2.5 text-[13px] text-[#79716b] leading-relaxed"></div>
        </div>
      </div>

      <!-- GBP Preview -->
      <div class="mt-6">
        <p class="mb-2 font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Preview on Google</p>
        <div class="rounded-xl border border-[#dadce0] bg-white p-4 shadow-sm">
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#4f39f6]"><span id="pav" class="font-sans text-sm font-bold text-white">S</span></div>
            <div><p id="pnm" class="font-sans text-[14px] font-semibold text-[#1f1f1f]">Your Business</p><p class="font-sans text-[12px] text-[#70757a]">Just now</p></div>
          </div>
          <p id="pbd" class="mt-3 font-sans text-[14px] leading-[1.5] text-[#3c4043]"><span class="text-[#79716b] italic">Your post preview will appear here...</span></p>
          <div id="pcta-w" class="mt-3 hidden"><span class="inline-block rounded-full border border-[#1a73e8] px-4 py-1.5 font-sans text-[13px] font-medium text-[#1a73e8]" id="pcta-l">Learn more</span></div>
          <div class="mt-3 flex items-center gap-2 rounded-lg border border-dashed border-[#dadce0] bg-[#f8f9fa] px-3 py-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#70757a" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
