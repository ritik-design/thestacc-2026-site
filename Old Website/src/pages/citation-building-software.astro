---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  {
    q: "What is citation building software?",
    a: "Citation building software automates the process of listing your business across local directories — Google, Yelp, Apple Maps, Bing Places, and 50+ more — with consistent NAP (Name, Address, Phone) data. Stacc audits your existing citations, finds inconsistencies, corrects them, and builds new citations automatically.",
  },
  {
    q: "Why do citations matter for local SEO?",
    a: "Google uses citation consistency as a trust signal. When your business name, address, and phone number are identical across dozens of directories, Google is more confident your listing is legitimate and current — which correlates directly with higher local pack and Maps rankings. Inconsistent citations create confusion and suppress rankings.",
  },
  {
    q: "What happens if my citations have wrong information?",
    a: "Wrong NAP data across directories actively hurts your local rankings. Google sees conflicting signals and reduces confidence in your listing. Customers find the wrong number or address. Stacc audits all 50+ directories, flags inconsistencies, and corrects them automatically — so your data is accurate everywhere.",
  },
  {
    q: "How many directories does Stacc cover?",
    a: "Stacc manages citations across 50+ local directories including Google Business Profile, Yelp, Bing Places, Apple Maps, Facebook, Foursquare, YellowPages, Angi, HomeAdvisor, BBB, Nextdoor, and dozens more industry-specific directories. All included at $49/month — no per-directory fees.",
  },
  {
    q: "Does Stacc work for businesses with multiple locations?",
    a: "Yes. Multi-location citation management is one of Stacc's core strengths. Each location gets its own citation profile, monitored and corrected independently. You manage everything from one dashboard. Add a new location and Stacc begins building citations for it immediately.",
  },
  {
    q: "How long does it take to see citation results?",
    a: "Initial citation audits complete within 48 hours of connecting your business. Corrections and new listings deploy over the following 1–2 weeks as directories process updates. Most businesses see measurable NAP consistency improvements within 30 days.",
  },
  {
    q: "Can I use Stacc for citation building as an agency?",
    a: "Yes. Agencies manage all client citations from one dashboard. Citation reports are included in Stacc's white-label monthly reports — delivered under your brand, automatically. You look like you have a dedicated citation team. You have Stacc.",
  },
  {
    q: "Is citation building a one-time task or ongoing?",
    a: "Ongoing. New directories emerge. Existing directories allow user-submitted edits that can corrupt your data. Business information changes. Stacc monitors continuously and corrects automatically — so your citations stay accurate without any manual effort after initial setup.",
  },
  {
    q: "Does Stacc replace manual citation submission tools like BrightLocal or Yext?",
    a: "Stacc includes citation management as part of a complete local SEO automation platform — alongside rank tracking, GBP posting, review monitoring, and automated reporting. You get full citation management plus everything else for $49/month, compared to paying separately for a citation-only tool.",
  },
  {
    q: "What does Stacc cost for citation building?",
    a: "Citation management is included in the Local SEO module at $49/month. No per-directory fees. No per-location upcharges. Everything is included — audit, correction, new listings, ongoing monitoring, and citation data in your white-label reports.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Citation Building Software",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automate citation building across 50+ local directories. theStacc audits existing citations, fixes NAP inconsistencies, and builds new citations that boost your local rankings.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "USD",
        "description": "Local SEO module including citation management — $1 for 3 days"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Citation Building Software", "item": "https://thestacc.com/citation-building-software/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Citation Building Software — Build & Sync Citations Across 50+ Directories | theStacc"
  description="Automate citation building across 50+ local directories. theStacc audits existing citations, fixes NAP inconsistencies, and builds new citations that boost your local rankings."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Citation Building Software · From $49/month</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Your citations are wrong somewhere.<br />
            <span style="color:#4f39f6;">Stacc finds and fixes them.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            NAP inconsistency is the invisible killer of local rankings. Wrong phone number on Yelp. Old address on Apple Maps. Duplicate listing on Foursquare. Stacc audits 50+ directories, corrects every inconsistency, and keeps your data accurate automatically.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start your free citation audit
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See pricing
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            $1 for 3 days · No credit card · Cancel anytime
          </p>

          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">50+ directories synced</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">400+ agencies trust Stacc</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN NARRATIVE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Why citations are silently killing your rankings</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            You have wrong information published<br />somewhere right now. You just don't know where.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              You're the person who moved offices two years ago, updated Google, updated the website, and called it done. Or changed your phone number when you switched providers. Or had a franchise that submitted its own Yelp listing with a slightly different business name. Every one of those events is a citation inconsistency — and citation inconsistencies compound quietly, at scale, across 50+ directories you never think about.
            </p>
            <p>
              Google's local ranking algorithm treats NAP consistency as a trust signal. When your name, address, and phone match across dozens of directories, Google is more confident your business is legitimate, current, and worth surfacing. When they don't match — even subtly, like "St." vs "Street" — that trust erodes. Your competitors with cleaner citation profiles outrank you not because they're better businesses, but because their data is more consistent.
            </p>
            <p>
              The agencies ranking at the top of Google Maps aren't manually checking 50 directories. They automated it. They have software that monitors every directory, alerts on every inconsistency, and corrects it before Google's next crawl. You can have the same system for $49/month — and the ROI on the first recovered ranking pays for it immediately.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does for citations</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Audit. Fix. Build. Monitor.<br />All automated, all included.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            {
              title: 'Citation Audit',
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              features: ['Scan 50+ directories instantly', 'Flag every NAP inconsistency', 'Identify missing listings', 'Detect duplicate entries'],
              href: '/features/rank-tracking/',
            },
            {
              title: 'Citation Correction',
              icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
              features: ['Fix wrong addresses automatically', 'Correct outdated phone numbers', 'Remove duplicate listings', 'Standardize business name format'],
              href: '/modules/local-seo/',
            },
            {
              title: 'Citation Monitoring',
              icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
              features: ['Ongoing directory monitoring', 'Alert on any data change', 'Auto-correct user-submitted edits', 'Monthly citation health report'],
              href: '/solutions/agencies/',
            },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Learn more</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How Stacc handles citations</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            From audit to correction to monitoring.<br />Zero manual work after setup.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Audit -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Instant Citation Audit</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Know your citation health score across 50+ directories within 48 hours.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                When you connect your business, Stacc immediately scans every major local directory for your existing listings. It checks each one for NAP accuracy, flags duplicates, identifies missing listings, and calculates an overall citation health score. You see exactly where you stand — which directories have wrong information, which are missing entirely, and which are correct — in one dashboard view.
              </p>
              <a href="/modules/local-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See the Local SEO module
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Citation audit — your locations</p>
              {[
                { dir: 'Google Business Profile', status: '✓ Accurate', color: 'text-[#059669]' },
                { dir: 'Yelp', status: '⚠ Wrong phone', color: 'text-[#d97706]' },
                { dir: 'Apple Maps', status: '⚠ Old address', color: 'text-[#d97706]' },
                { dir: 'Bing Places', status: '✓ Accurate', color: 'text-[#059669]' },
                { dir: 'Foursquare', status: '✗ Missing', color: 'text-[#dc2626]' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{r.dir}</span>
                  <span class={`font-mono text-[11px] font-semibold ${r.color}`}>{r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Stacc auto-fixes all issues · No manual work</p>
            </div>
          </div>

          <!-- Correction -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">NAP accuracy score</p>
              <div class="flex items-center justify-between mb-3">
                <span class="font-sans text-[13px] text-[#57534e]">Before Stacc</span>
                <span class="font-mono text-[12px] font-semibold text-[#dc2626]">61% accurate</span>
              </div>
              <div class="h-2 w-full rounded-full bg-[#f5f3ff] mb-6">
                <div class="h-2 rounded-full bg-[#dc2626]" style="width:61%"></div>
              </div>
              <div class="flex items-center justify-between mb-3">
                <span class="font-sans text-[13px] text-[#57534e]">After 30 days</span>
                <span class="font-mono text-[12px] font-semibold text-[#059669]">94% accurate</span>
              </div>
              <div class="h-2 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-2 rounded-full bg-[#059669]" style="width:94%"></div>
              </div>
              <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Average across Stacc customers · 50+ directories</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatic NAP Correction</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Every inconsistency corrected. Every directory updated. You don't lift a finger.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                After the audit, Stacc automatically submits corrections to every directory that allows API updates. For directories that require manual intervention, Stacc queues the corrections and handles them through its directory partnerships. The average Stacc customer goes from 61% NAP accuracy to 94% within 30 days — without touching a single directory manually.
              </p>
              <a href="/features/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See how rankings improve
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Monitoring -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ongoing Citation Monitoring</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Citations drift. Stacc catches it before Google does.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Directories allow public edits. Aggregators push outdated data. Your information can drift back to wrong the moment you stop watching. Stacc monitors every directory continuously and alerts you the moment any citation data changes. Auto-correction kicks in immediately for supported directories. Your NAP stays accurate even as the directories change around you.
              </p>
              <a href="/solutions/agencies/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See Stacc for agencies
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Citation monitoring — this week</p>
              {[
                { event: 'Yelp listing edited by user', action: 'Auto-corrected', time: '2 hrs ago' },
                { event: 'YellowPages phone updated', action: 'Verified accurate', time: '1 day ago' },
                { event: 'New BBB listing detected', action: 'Claimed & synced', time: '3 days ago' },
                { event: 'Foursquare address synced', action: 'Published', time: '4 days ago' },
              ].map(row => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center justify-between">
                    <span class="font-sans text-[13px] text-[#374151]">{row.event}</span>
                    <span class="font-mono text-[10px] text-[#79716b]">{row.time}</span>
                  </div>
                  <span class="font-mono text-[10px] font-semibold text-[#059669]">{row.action}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Continuous monitoring · Zero manual checks</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#0d1117]/10" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Citation results</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What automated citation management<br />does to your local rankings.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Averages from businesses using Stacc for citation management.
          </p>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(15,23,42,0.04);">
          {[
            { value: '50+', num: 50, prefix: '', suffix: '+', decimals: 0, from: 0, label: 'Directories synced automatically', sub: 'all included at $49/month — no per-directory fees' },
            { value: '94%', num: 94, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Average NAP accuracy after 30 days', sub: 'up from an average of 61% before Stacc' },
            { value: '3hrs', num: 3, prefix: '', suffix: 'hrs', decimals: 0, from: 0, label: 'Saved per location per week', sub: 'on manual citation checking and correction' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/80">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIALS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
