---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';
import { getCollection, render } from 'astro:content';
import { SITE_URL, organizationSchema, websiteSchema, buildBreadcrumbs } from '../../../utils/schema';

export async function getStaticPaths() {
  const langTerms = await getCollection('glossary_fr');
  return langTerms.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const t = entry.data.term;
const termUrl = `${SITE_URL}/fr/glossaire/${entry.data.slug}/`;
const enUrl = `${SITE_URL}/glossary/${entry.data.slug}/`;

const categoryColors: Record<string, string> = {
  'Marketing': '#4f39f6',
  'SEO': '#16a34a',
  'Local SEO': '#ea580c',
  'Social Media': '#db2777',
  'AI & Emerging': '#7c3aed',
};

const difficultyLabels: Record<string, string> = {
  'Beginner': 'Débutant',
  'Intermediate': 'Intermédiaire',
  'Advanced': 'Avancé',
};

const difficultyColors: Record<string, string> = {
  'Beginner': '#16a34a',
  'Intermediate': '#d97706',
  'Advanced': '#dc2626',
};

const catColor = categoryColors[entry.data.category] || '#4f39f6';

const allTerms = await getCollection('glossary_fr');
const relatedSlugs = entry.data.relatedTerms || [];
const relatedTerms = allTerms.filter((t) => relatedSlugs.includes(t.data.slug));
const categoryTerms = allTerms
  .filter((t) => t.data.category === entry.data.category && t.data.slug !== entry.data.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 6);

const faqItems: { question: string; answer: string }[] = [];
const bodyText = entry.body || '';
const faqSectionMatch = bodyText.split(/^## Frequently Asked Questions/m)[1];
if (faqSectionMatch) {
  const faqBlock = faqSectionMatch.split(/^## /m)[0];
  const faqParts = faqBlock.split(/^### /m).filter(Boolean);
  for (const part of faqParts) {
    const lines = part.trim().split('\n');
    const question = lines[0].replace(/\??\s*$/, '?').trim();
    const answer = lines.slice(1).join(' ').replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\*\*/g, '').trim();
    if (question && answer) faqItems.push({ question, answer });
  }
}

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTerm',
      '@id': `${termUrl}#term`,
      name: t,
      description: entry.data.definition,
      url: termUrl,
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        '@id': `${SITE_URL}/fr/glossaire/`,
        name: 'Glossaire SEO & Marketing',
        url: `${SITE_URL}/fr/glossaire/`,
      },
      termCode: entry.data.category,
    },
    {
      '@type': 'Article',
      '@id': `${termUrl}#article`,
      headline: `Qu'est-ce que ${t} ? Définition & guide`,
      description: entry.data.definition,
      url: termUrl,
      datePublished: entry.data.date,
      dateModified: entry.data.lastUpdated || entry.data.date,
      mainEntityOfPage: { '@type': 'WebPage', '@id': termUrl },
      author: { '@type': 'Organization', '@id': `${SITE_URL}/#organization`, name: 'theStacc' },
      publisher: { '@type': 'Organization', '@id': `${SITE_URL}/#organization`, name: 'theStacc', url: SITE_URL },
      inLanguage: 'fr',
      isPartOf: { '@id': `${SITE_URL}/fr/glossaire/` },
    },
    buildBreadcrumbs(termUrl, [
      { name: 'Accueil', url: `${SITE_URL}/fr/` },
      { name: 'Glossaire', url: `${SITE_URL}/fr/glossaire/` },
      { name: t, url: termUrl },
    ]),
    organizationSchema,
    websiteSchema,
    ...(faqItems.length > 0 ? [{
      '@type': 'FAQPage',
      '@id': `${termUrl}#faq`,
      mainEntity: faqItems.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    }] : []),
  ],
};
---

<BaseLayout
  title={`${t} — Définition SEO | Glossaire theStacc`}
  description={entry.data.definition}
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <!-- HERO -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="mx-auto max-w-[1320px] px-6 pt-8 pb-10">

        <!-- Breadcrumb -->
        <nav class="flex items-center gap-1.5 mb-4" aria-label="Fil d'Ariane">
          <a href="/fr/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#79716b] transition-colors hover:text-[#4f39f6]">Accueil</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#d6d3d1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <a href="/fr/glossaire/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#79716b] transition-colors hover:text-[#4f39f6]">Glossaire</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#d6d3d1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6]">{t}</span>
        </nav>

        <!-- Pills -->
        <div class="flex flex-wrap items-center gap-2 mb-5">
          <span class="rounded-md px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.1em]" style={`background:${catColor}18;color:${catColor};`}>{entry.data.category}</span>
          {entry.data.difficulty && (
            <span class="rounded-md px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.1em]" style={`color:${difficultyColors[entry.data.difficulty] || '#57534e'};background:${difficultyColors[entry.data.difficulty] || '#57534e'}18;`}>
              {difficultyLabels[entry.data.difficulty] || entry.data.difficulty}
            </span>
          )}
          <a href={enUrl} class="font-mono text-[11px] text-[#4f39f6] hover:underline">Version anglaise →</a>
        </div>

        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.02em] text-[#111827] md:text-[36px]">
          Qu'est-ce que {t} ?
        </h1>
        <p class="mt-4 font-sans text-[16px] leading-[1.7] text-[#57534e] max-w-[760px]">{entry.data.definition}</p>
      </div>
    </div>

    <!-- TWO-COLUMN LAYOUT -->
    <div class="mx-auto max-w-[1320px] px-6 py-10 lg:flex lg:items-start lg:gap-12">

      <!-- Main Content -->
      <div class="min-w-0 flex-1">
        <div class="glossary-content overflow-x-hidden">
          <Content />
        </div>

        <!-- Related Terms -->
        {categoryTerms.length > 0 && (
          <div class="mt-12">
            <h2 class="font-sans text-[18px] font-bold text-[#111827]">Termes associés dans {entry.data.category}</h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
              {categoryTerms.map((term) => (
                <a href={`/fr/glossaire/${term.data.slug}/`} class="rounded-xl border border-[#e7e5e4] bg-white p-4 transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                  <p class="font-sans text-[14px] font-semibold text-[#111827]">{term.data.term}</p>
                  <p class="mt-1 font-sans text-[12px] text-[#79716b] line-clamp-2">{term.data.definition}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block w-[280px] shrink-0">
        <div class="sticky top-20 space-y-6">
          <div class="overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white p-6">
            <p class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Automatisez votre SEO</p>
            <p class="mt-3 font-sans text-[15px] font-bold leading-[1.35] text-[#111827]">30 articles SEO publiés chaque mois. Sans effort.</p>
            <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#57534e]">Contenu optimisé pour les mots-clés, structuré et publié automatiquement sur votre site.</p>
            <a href="/fr/demo/" class="mt-5 flex h-10 w-full items-center justify-center rounded-lg border border-[#4f39f6] bg-[#615fff] font-mono text-[12px] font-semibold uppercase tracking-[0.06em] text-white transition-colors hover:bg-[#4f39f6]">
              Voir la démo
            </a>
          </div>

          {relatedTerms.length > 0 && (
            <div class="overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white p-5">
              <p class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Termes liés</p>
              <div class="mt-3 flex flex-col gap-2">
                {relatedTerms.map((term) => (
                  <a href={`/fr/glossaire/${term.data.slug}/`} class="font-sans text-[13px] text-[#57534e] transition-colors hover:text-[#4f39f6]">
                    {term.data.term}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>

    </div>

    <!-- Footer CTA -->
    <div class="border-t border-[#e7e5e4] bg-[#fafaf9] px-6 py-12">
      <div class="mx-auto max-w-[640px] text-center">
        <h2 class="font-sans text-[22px] font-bold text-[#111827]">Automatisez votre SEO. Publiez plus. Classez-vous plus haut.</h2>
        <p class="mt-3 font-sans text-[15px] leading-[1.7] text-[#57534e]">30 articles de blog SEO, 30 publications GBP, et du contenu sur les réseaux sociaux chaque mois. Tout sur le pilote automatique.</p>
        <a href="/fr/demo/" class="mt-6 inline-flex items-center justify-center rounded-lg border border-[#4f39f6] bg-[#615fff] px-6 py-2.5 font-mono text-[13px] font-semibold uppercase tracking-[0.06em] text-white transition-colors hover:bg-[#4f39f6]">
          Réserver une démo
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
