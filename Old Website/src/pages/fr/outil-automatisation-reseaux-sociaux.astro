---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Quelles plateformes sociales Stacc supporte-t-il ?", a: "Stacc publie automatiquement sur Google Business Profile, Facebook et Instagram. Pour les entreprises multi-établissements, les posts peuvent être publiés simultanément sur tous les profils de tous les établissements en une seule action." },
  { q: "Pourquoi la gestion manuelle des réseaux sociaux ne fonctionne-t-elle pas pour plusieurs établissements ?", a: "Avec un seul établissement, c'est gérable. Avec 5, 10 ou 20 établissements, la gestion manuelle des réseaux sociaux signifie se connecter à des dizaines de comptes différents, créer du contenu personnalisé pour chaque établissement et publier manuellement plusieurs fois par semaine sur chaque profil. Le résultat : certains établissements reçoivent de l'attention et d'autres sont délaissés pendant des semaines." },
  { q: "Comment fonctionne la publication en masse sur plusieurs établissements ?", a: "Vous rédigez un post une seule fois — texte, image, CTA — et sélectionnez les établissements sur lesquels le publier. Stacc publie le post sur le GBP, Facebook et Instagram de chaque établissement sélectionné simultanément. Vous pouvez ajouter des personnalisations locales (adresse, téléphone local) avant de publier si nécessaire." },
  { q: "Le contenu est-il créé automatiquement ?", a: "Oui. Stacc génère le texte des posts automatiquement en se basant sur les services, l'emplacement et les thèmes de chaque établissement. Les posts sont optimisés pour les recherches locales et le type de plateforme. Vous pouvez réviser et approuver avant publication ou laisser publier automatiquement selon le calendrier configuré." },
  { q: "Comment sont gérés les établissements qui n'arrivent pas à publier ?", a: "Stacc surveille le statut de chaque publication et envoie des alertes immédiates si un post ne parvient pas à se publier sur un établissement spécifique (problème d'autorisation ou de connexion par exemple). Aucun post manqué ne passe inaperçu." },
  { q: "Combien coûte-t-il ?", a: "Le module réseaux sociaux de Stacc commence à 49 $/mois et inclut la publication automatique sur GBP, Facebook et Instagram pour tous les établissements, avec calendrier de contenu et rapports de performance." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Outil Automatisation Réseaux Sociaux",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Publiez sur GBP, Facebook et Instagram pour chaque établissement simultanément. Automatisation des réseaux sociaux pour entreprises multi-établissements avec contenu automatique et calendrier programmé.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Outil Automatisation Réseaux Sociaux", "item": "https://thestacc.com/fr/outil-automatisation-reseaux-sociaux/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Outil Automatisation Réseaux Sociaux — Publiez sur Chaque Établissement en Automatique | theStacc"
  description="Publiez sur GBP, Facebook et Instagram pour tous vos établissements simultanément. theStacc automatise la création et la publication de contenu social pour entreprises multi-établissements."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Automatisation Sociale · GBP + Facebook + Instagram</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Publiez sur chaque établissement en automatique.<br />
            <span style="color:#4f39f6;">GBP, Facebook, Instagram. Simultanément.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Gérer les réseaux sociaux pour plusieurs établissements manuellement signifie des dizaines de comptes, des heures de travail répétitif et inévitablement certains établissements qui se retrouvent à la traîne. Stacc publie sur tous les établissements automatiquement — même qualité pour chaque établissement, zéro travail manuel.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Comment ça fonctionne
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte bancaire · Résiliez quand vous voulez
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">GBP + Facebook + Instagram</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuration &lt; 5 min</span>
          </div>
        </div>
      </div>
    </section>


    <!-- NARRATIF -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème de la gestion sociale à grande échelle</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La gestion manuelle des réseaux sociaux<br />ne passe pas à l'échelle au-delà de 2-3 établissements.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Avec un seul établissement, vous pouvez publier manuellement 3-4 fois par semaine sur GBP, Facebook et Instagram — peut-être. Avec 10 établissements, cela se transforme en 30-40 posts par semaine sur des dizaines de comptes différents. Avec 50 établissements, c'est physiquement impossible sans une équipe dédiée. Le résultat est toujours le même : certains établissements reçoivent une attention constante et les autres disparaissent du radar.
            </p>
            <p>
              Les établissements qui publient régulièrement sur GBP obtiennent de meilleurs classements sur Google Maps. Les établissements inactifs descendent. Quand la gestion est manuelle, les performances deviennent une loterie qui dépend de qui a le plus de temps cette semaine-là, pas de qui a la meilleure stratégie.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc élimine cet écart. Vous configurez une stratégie de contenu une fois, définissez les établissements et le calendrier, et Stacc publie automatiquement sur GBP, Facebook et Instagram de chaque établissement chaque jour — avec la même qualité et cohérence pour tous les établissements, peu importe leur nombre.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités d'automatisation sociale</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Publication sociale automatique<br />pour chaque établissement, chaque jour.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', title: 'GBP, Facebook et Instagram', body: 'Publication simultanée sur les trois plateformes pour chaque établissement. Une seule action couvre tous les canaux de tous les établissements.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Publication en masse multi-établissements', body: 'Rédigez un post une fois et publiez-le sur 10, 50 ou 200 établissements en même temps. Avec personnalisations locales optionnelles pour chaque établissement.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Calendrier de contenu', body: "Planifiez le contenu des semaines à l'avance. Le calendrier automatique gère la fréquence et les horaires de publication pour chaque établissement." },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Personnalisation locale', body: "Ajoutez des détails spécifiques à l'établissement — adresse locale, numéro de téléphone, hashtags locaux — avant la publication en masse. Marque cohérente, détails localisés." },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Alertes sur posts échoués', body: 'Notification immédiate si un post ne parvient pas à se publier sur un établissement spécifique. Aucun établissement ne reste sans contenu sans que vous le sachiez.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Rapports de performance', body: "Métriques d'engagement pour chaque post et chaque établissement. Voyez ce qui fonctionne, où et quand — tout inclus dans le rapport mensuel automatique." },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '8h', label: 'Économisées chaque semaine par établissement', sub: 'Comparé à la gestion sociale manuelle' },
            { value: '3×', label: 'Plus de cohérence de publication', sub: 'Automatisation vs gestion manuelle' },
            { value: '89%', label: 'Amélioration du classement GBP', sub: 'Avec une activité constante dans les 90 premiers jours' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisation sociale en détail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Publication en masse, calendrier, performance —<br />tout géré automatiquement.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publication simultanée multi-plateformes</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Un post rédigé. GBP, Facebook et Instagram couverts. Pour chaque établissement en même temps.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                La publication manuelle sur trois plateformes pour chaque établissement signifie des dizaines de connexions différentes, des dizaines de publications individuelles, des dizaines de points de défaillance potentiels. Avec Stacc, vous rédigez le contenu une fois, sélectionnez les établissements, et la publication se fait simultanément sur GBP, Facebook et Instagram de chaque établissement sélectionné. Les personnalisations locales — adresse, téléphone, hashtags de ville — s'ajoutent avant publication si besoin.
              </p>
              <a href="/fr/outil-automatisation-reseaux-sociaux/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le module réseaux sociaux
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Publication en masse — état en direct</p>
              {[
                { loc: 'Paris 11e', gbp: true, fb: true, ig: true },
                { loc: 'Lyon Centre', gbp: true, fb: true, ig: true },
                { loc: 'Bordeaux', gbp: true, fb: false, ig: true },
                { loc: 'Marseille', gbp: true, fb: true, ig: true },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <span class="font-sans text-[12px] text-[#374151] w-28">{r.loc}</span>
                  <div class="flex gap-2">
                    <span class={`rounded px-1.5 py-0.5 font-mono text-[9px] font-semibold ${r.gbp ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#fee2e2] text-[#dc2626]'}`}>GBP</span>
                    <span class={`rounded px-1.5 py-0.5 font-mono text-[9px] font-semibold ${r.fb ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#fef9c3] text-[#d97706]'}`}>FB</span>
                    <span class={`rounded px-1.5 py-0.5 font-mono text-[9px] font-semibold ${r.ig ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#fee2e2] text-[#dc2626]'}`}>IG</span>
                  </div>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">11/12 publications réussies · 1 alerte envoyée</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendrier de contenu — semaine en cours</p>
              <div class="grid grid-cols-7 gap-1 mb-3">
                {['L', 'M', 'M', 'J', 'V', 'S', 'D'].map(d => (
                  <div class="text-center font-mono text-[9px] text-[#79716b]">{d}</div>
                ))}
              </div>
              <div class="grid grid-cols-7 gap-1">
                {[
                  { done: true }, { done: true }, { done: true }, { done: false, today: true },
                  { done: false }, { done: false }, { done: false }
                ].map(d => (
                  <div class={`h-8 rounded-lg flex items-center justify-center ${d.done ? 'bg-[#4f39f6]' : d.today ? 'border-2 border-[#4f39f6] bg-[#f5f3ff]' : 'bg-[#f5f3ff]'}`}>
                    {d.done && <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>}
                    {d.today && <span class="font-mono text-[8px] font-bold text-[#4f39f6]">Auj</span>}
                  </div>
                ))}
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">3 publiés · 1 planifié aujourd'hui · 3 à venir</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Calendrier de contenu automatique</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Configurez la stratégie une fois. Stacc publie chaque jour selon le calendrier.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                La cohérence de publication est un facteur direct de classement GBP. Les profils qui publient régulièrement surpassent ceux dont l'activité est sporadique. Stacc génère automatiquement le contenu de chaque post en se basant sur les services, l'emplacement et les sujets saisonniers, puis les programme sur le calendrier configuré. Pas de connexion manuelle. Pas d'oubli. Pas d'établissement délaissé parce que personne n'a eu le temps ce jour-là.
              </p>
              <a href="/fr/modules/reseaux-sociaux/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le module réseaux sociaux
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rapports de performance par établissement</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Voyez quels posts et quels établissements performent le mieux. Sans sortir un seul rapport manuellement.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc compile automatiquement les métriques d'engagement pour chaque post publié sur chaque plateforme pour chaque établissement. Les vues, clics, interactions et l'impact sur le classement GBP sont tous centralisés dans le tableau de bord. Les rapports mensuels automatiques incluent la performance sociale — en marque blanche pour les agences — sans que votre équipe ait à assembler quoi que ce soit manuellement.
              </p>
              <a href="/fr/pour/restaurants/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir pour les restaurants
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Performance sociale — ce mois</p>
              {[
                { label: 'Vues totales (GBP)', value: '4 820', change: '+32%' },
                { label: 'Engagement Facebook', value: '1 240', change: '+18%' },
                { label: 'Clics Instagram', value: '896', change: '+45%' },
              ].map(r => (
