---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const sections = [
  { id: 'responsable', num: '1', title: 'Responsable du traitement', body: 'SOLARTREK VENTURES LLP est le responsable du traitement de vos données personnelles. Nous traitons vos données conformément au Règlement Général sur la Protection des Données (RGPD) et aux lois nationales applicables en matière de protection des données. Adresse : Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India.' },
  { id: 'base-legale', num: '2', title: 'Base légale du traitement', body: 'Nous traitons vos données sur la base de votre consentement, de l\'exécution d\'un contrat (votre abonnement), du respect d\'obligations légales, et de nos intérêts légitimes (amélioration du service, prévention de la fraude).' },
  { id: 'categories', num: '3', title: 'Catégories de données traitées', body: 'Nous traitons les données d\'identification (nom, e-mail), les données de connexion (adresse IP, logs), les données de paiement (via Stripe, tokenisées), les données de contenu (URLs de sites, contenus générés) et les données d\'usage (statistiques d\'utilisation du service).' },
  { id: 'duree', num: '4', title: 'Durée de conservation', body: 'Nous conservons vos données personnelles pendant la durée de votre abonnement et jusqu\'à 3 ans après sa résiliation pour les obligations légales et comptables. Les données de contenu généré sont conservées jusqu\'à suppression de votre compte.' },
  { id: 'transferts', num: '5', title: 'Transferts de données', body: 'Certaines de nos données peuvent être transférées vers des pays tiers (notamment les États-Unis) via nos sous-traitants. Ces transferts sont encadrés par des clauses contractuelles types approuvées par la Commission européenne.' },
  { id: 'sous-traitants', num: '6', title: 'Sous-traitants', body: 'Nous faisons appel à des sous-traitants de confiance pour l\'hébergement (services cloud), le paiement (Stripe), l\'analyse (Google Analytics) et le support client. Chaque sous-traitant est lié par un accord de traitement des données conforme au RGPD.' },
  { id: 'droits', num: '7', title: 'Vos droits RGPD', body: 'Vous disposez des droits d\'accès, de rectification, d\'effacement, de limitation du traitement, de portabilité et d\'opposition. Pour exercer ces droits, contactez-nous via notre page Contact. Vous pouvez également déposer une réclamation auprès de votre autorité de protection des données nationale.' },
];
---

<BaseLayout
  title="Traitement des Données — theStacc"
  description="Accord de traitement des données de theStacc. Informations RGPD sur la collecte, l'utilisation et la protection de vos données personnelles."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Légal · Données</span>
        <h1 class="mt-2 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.5rem]">Traitement des Données</h1>
        <p class="mt-2 font-mono text-[12px] text-[#79716b]">Dernière mise à jour : Avril 2026</p>
      </div>
    </section>
    <div class="min-h-screen bg-[#fafaf9]">
      <div class="container-x py-12 md:py-16">
        <div class="mx-auto max-w-3xl space-y-10">
          {sections.map(s => (
            <section id={s.id} class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">{s.num}</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">{s.title}</h2>
              </div>
              <div class="pl-9"><p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">{s.body}</p></div>
              <div class="mt-6 border-t border-[#e7e5e4]"></div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
