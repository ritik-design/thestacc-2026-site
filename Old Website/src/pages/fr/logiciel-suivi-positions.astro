---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce qu'un logiciel de suivi de positions ?", a: "Un logiciel de suivi de positions surveille où votre site web se classe sur Google pour des mots-clés spécifiques. Pour le SEO local, cela inclut le local pack (les 3 résultats Maps), les résultats Google Maps et les résultats organiques — trois emplacements distincts qui peuvent avoir des positions très différentes pour les mêmes mots-clés." },
  { q: "Quelle est la différence entre le suivi de positions local et national ?", a: "Le suivi de positions local surveille les classements depuis des emplacements géographiques spécifiques — ville, quartier ou même adresse. Les résultats locaux varient considérablement selon l'emplacement du chercheur. Un restaurant peut être #1 dans son quartier et #8 à 5 km de là. Le suivi local capture ces nuances." },
  { q: "À quelle fréquence Stacc met-il à jour les données de classement ?", a: "Stacc met à jour les classements quotidiennement pour tous les mots-clés suivis sur tous vos établissements. Vous voyez vos positions chaque matin sans avoir à lancer de vérifications manuelles. Les alertes automatiques se déclenchent lorsque les positions changent significativement." },
  { q: "Stacc suit-il les classements dans le local pack Maps ?", a: "Oui. Stacc suit spécifiquement les positions dans le local pack (3-pack Google), Google Maps et les résultats organiques séparément. Pour les entreprises locales, le local pack est là où atterrent la plupart des clics à forte intention — sa surveillance est prioritaire." },
  { q: "Puis-je suivre les positions pour plusieurs établissements simultanément ?", a: "Oui. Stacc gère le suivi de positions pour tous vos établissements depuis un seul tableau de bord. Chaque établissement a ses propres mots-clés suivis et ses propres données de classement. Vous pouvez comparer les performances entre établissements ou voir un rapport portfolio agrégé." },
  { q: "Le suivi de positions est-il inclus dans tous les plans ?", a: "Oui. Le suivi de positions quotidien est inclus dans le module SEO Local à 49 $/mois. Pas de frais supplémentaires par mot-clé suivi ou par établissement." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Logiciel de Suivi de Positions",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Logiciel de suivi de positions local pour surveiller vos classements dans le local pack, Google Maps et les résultats organiques — quotidiennement, pour tous vos établissements.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Logiciel Suivi de Positions", "item": "https://thestacc.com/fr/logiciel-suivi-positions/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Logiciel Suivi de Positions — Classements Locaux Mis à Jour Chaque Jour | theStacc"
  description="Suivi de positions local quotidien pour le local pack, Google Maps et l'organique. theStacc surveille vos classements pour chaque établissement et envoie des alertes automatiques."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Suivi de Positions · À partir de 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Sachez où vous vous classez —<br />
            <span style="color:#4f39f6;">local pack, Maps et organique — chaque matin.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Les classements se mettent à jour chaque jour pour chaque mot-clé suivi sur chaque établissement. Vous vous réveillez en sachant où vous êtes — sans ouvrir un seul tableau de bord. Alertes automatiques lorsque les positions changent significativement.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/logiciel-seo-local/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Voir le logiciel SEO local
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte de crédit · Résiliable à tout moment
          </p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Mises à jour quotidiennes pour 1 200+ établissements</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">3 surfaces de classement suivies</span>
          </div>
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacités de suivi</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque position suivie.<br />Chaque variation alertée.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi quotidien', body: 'Classements mis à jour chaque jour sans intervention manuelle. Vous commencez chaque matinée avec des données fraîches.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Local pack + Maps + organique', body: "Surveillance des 3 types de résultats séparément. Pour les entreprises locales, le local pack est l'essentiel." },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Alertes automatiques', body: 'Notifications immédiates lorsque vos positions changent significativement — hausse ou baisse. Soyez toujours informé avant votre client.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Multi-établissements', body: "Tous vos établissements suivis depuis un seul tableau de bord. Comparez les performances entre sites, identifiez les opportunités d'amélioration." },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Historique des tendances', body: 'Visualisez l\'évolution de vos classements dans le temps. Identifiez les patterns saisonniers et l\'impact de vos actions SEO.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Inclus dans les rapports', body: 'Les données de classement sont automatiquement incluses dans vos rapports clients marque blanche. Pas de saisie manuelle.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '365×', label: 'Vérifications annuelles automatisées', sub: 'Vs. vérifications manuelles hebdomadaires' },
            { value: '<1 min', label: 'Pour voir les classements de tous vos sites', sub: "Dashboard portfolio unifié" },
            { value: '4,7×', label: "Amélioration moyenne Maps en 90 jours", sub: 'Avec une activité GBP constante' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnement détaillé</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Données quotidiennes, comparaison multi-sites,<br />et alertes automatiques — tout au même endroit.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dashboard de Classement Quotidien</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Chaque position de mot-clé mise à jour chaque matin. Local pack, Maps et organique — séparément.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Ouvrez Stacc chaque matin et chaque mot-clé suivi affiche sa position actuelle — dans le local 3-pack, dans Maps et dans les résultats organiques. Trois chiffres distincts, car pour les entreprises locales ils peuvent évoluer indépendamment. Une position 1 en organique avec une position 7 dans Maps est une situation très différente de l'inverse. Stacc vous montre les deux pour que vous sachiez toujours où se trouve l'opportunité.
              </p>
              <a href="/fr/fonctionnalites/suivi-positions/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le suivi de positions en détail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Mise à jour du jour</p>
              {[
                { kw: 'dentiste près de moi', pack: 1, org: 3, change: '+2', trend: 'up' },
                { kw: 'dentiste urgence [ville]', pack: 2, org: 5, change: '+1', trend: 'up' },
                { kw: 'blanchiment dents près de moi', pack: 3, org: 4, change: '+4', trend: 'up' },
                { kw: 'implants dentaires [ville]', pack: 5, org: 8, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[12px] text-[#374151] truncate">{r.kw}</span>
                  <div class="flex gap-1.5">
                    <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-[10px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] text-[10px] font-bold text-[#79716b]">#{r.org}</div>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <div class="mt-3 flex items-center justify-between">
                <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Pack · Organique · Mis à jour quotidiennement</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-1 font-mono text-[9px] font-semibold text-[#4f39f6]">AUTO</span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Comparaison multi-établissements</p>
              {[
                { name: 'Paris Centre', rank: 1, score: 94, trend: '↑' },
                { name: 'Lyon Part-Dieu', rank: 2, score: 89, trend: '↑' },
                { name: 'Marseille Vieux-Port', rank: 3, score: 85, trend: '→' },
                { name: 'Bordeaux Lac', rank: 8, score: 52, trend: '↓' },
              ].map(loc => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[11px] font-bold ${loc.rank <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#fff1f2] text-[#ef4444]'}`}>#{loc.rank}</div>
                  <span class="flex-1 font-sans text-[13px] text-[#374151]">{loc.name}</span>
                  <div class="h-1.5 w-16 rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${loc.score}%`}></div></div>
                  <span class={`font-mono text-[11px] font-semibold ${loc.trend === '↑' ? 'text-[#059669]' : loc.trend === '↓' ? 'text-[#ef4444]' : 'text-[#79716b]'}`}>{loc.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tous les établissements comparés · Mis à jour quotidiennement</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Vue Portfolio des Classements</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Tous les établissements classés côte à côte. Les sous-performeurs apparaissent immédiatement.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Gérer plusieurs établissements signifie savoir lesquels gagnent et lesquels nécessitent de l'attention — en un coup d'œil. La vue portfolio montre la position de chaque établissement pour chaque mot-clé suivi, triée selon n'importe quelle métrique. Vous ne vérifiez pas chaque établissement séparément. Vous voyez l'ensemble du tableau en une vue et agissez sur ce qui compte.
              </p>
              <a href="/fr/solutions/agences/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir Stacc pour les agences
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alertes de Variation de Classement</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sachez quand les classements bougent — avant votre client.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configurez des alertes basées sur des seuils pour n'importe quel mot-clé suivi : notification quand un mot-clé sort du top 3, entre dans le top 3 pour la première fois, ou se déplace de 3+ positions dans un sens ou l'autre. Les alertes se déclenchent instantanément par e-mail. Pour les agences, cela signifie que vous êtes toujours le premier informé — pour réagir, communiquer et démontrer votre valeur avant que le client remarque quoi que ce soit.
              </p>
              <a href="/fr/solutions/agences/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir Stacc pour les agences
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Alertes de classement — cette semaine</p>
              {[
                { type: 'up', kw: '"plombier près de moi" — entré top 3', time: 'il y a 2h', loc: 'Vincennes' },
                { type: 'down', kw: '"plombier urgence" — tombé à #6', time: 'il y a 1j', loc: 'Montreuil' },
                { type: 'up', kw: '"réparation chauffe-eau" — #1', time: 'il y a 2j', loc: 'Vincennes' },
                { type: 'up', kw: '"débouchage canalisation" — top 3', time: 'il y a 3j', loc: 'Créteil' },
              ].map(a => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[10px] ${a.type === 'up' ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#fff1f2] text-[#ef4444]'}`}>{a.type === 'up' ? '↑' : '↓'}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-medium text-[#111827] truncate">{a.kw}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{a.loc} · {a.time}</p>
                  </div>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Livraison e-mail instantanée · Aucune vérification manuelle</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- TÉMOIGNAGES -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que disent nos clients</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Résultats concrets d'entreprises<br />et d'agences qui utilisent Stacc.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-2">
          {[
