---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce que le SEO franchise ?", a: "Le SEO franchise est l'optimisation de la visibilité en recherche locale pour les entreprises en franchise sur plusieurs établissements. Chaque point de franchise a besoin de son propre profil Google Business géré, de ses citations locales maintenues et de ses classements suivis — tout en maintenant la cohérence de la marque sur tout le réseau." },
  { q: "Quel est le principal défi SEO pour les franchises ?", a: "La cohérence à grande échelle. Chaque établissement a besoin du même travail SEO de base exécuté correctement — citations précises, GBP actif, profil d'avis solide. Avec 50 ou 500 établissements, c'est impossible à faire manuellement. Les établissements qui reçoivent de l'attention se classent. Ceux qui sont négligés non. L'automatisation est la seule façon d'appliquer un engagement SEO constant sur tout le réseau." },
  { q: "Comment Stacc gère-t-il la relation franchiseur/franchisé ?", a: "Stacc supporte les accès à plusieurs niveaux. Les franchiseurs ont une vue portefeuille de tous les établissements avec comparaison des performances. Les franchisés peuvent accéder au tableau de bord de leur propre établissement. Gestion centralisée et visibilité individuelle coexistent dans la même plateforme." },
  { q: "Stacc peut-il gérer le GBP pour 200 établissements en franchise ?", a: "Oui. Stacc publie des posts GBP sur tous les établissements simultanément. Les mises à jour en masse des horaires, descriptions et attributs s'appliquent à tout le réseau en une seule action. Il n'y a pas de limite pratique au nombre d'établissements." },
  { q: "Comment maintenir la cohérence de la marque dans les posts GBP sur plusieurs établissements ?", a: "La publication en masse de Stacc permet de rédiger un post une fois et de le publier sur tous les établissements simultanément. Vous pouvez ajouter des personnalisations locales (adresse, téléphone local, hashtags locaux) avant la publication en masse. La marque reste cohérente ; les détails sont localisés." },
  { q: "Combien de temps faut-il pour ajouter un nouvel établissement ?", a: "Environ 2 minutes. Vous entrez les données de base de l'entreprise, connectez le profil GBP et Stacc propage automatiquement la configuration sur tout le réseau de citations. Aucune inscription manuelle annuaire par annuaire." },
  { q: "Combien coûte le logiciel SEO pour franchise ?", a: "Le module SEO local de Stacc commence à 49 $/mois et inclut toutes les fonctionnalités de gestion de franchise et multi-sites." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO Franchise",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automatisation SEO pour franchises : GBP, citations, classements et rapports sur chaque établissement du réseau simultanément. Gestion centralisée avec accès franchisé individuel.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "SEO Franchise", "item": "https://thestacc.com/fr/seo-franchise/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="SEO Franchise — Automatisez le SEO Local sur Tout le Réseau | theStacc"
  description="Le SEO franchise à grande échelle nécessite l'automatisation. theStacc gère GBP, citations, suivi de positions et rapports pour chaque établissement du réseau — marque cohérente, performance locale."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Franchise · Dès 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO franchise qui fonctionne<br />
            <span style="color:#4f39f6;">sur tout le réseau.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Chaque établissement en franchise a besoin d'un travail SEO local constant et quotidien pour se classer dans son marché. Stacc automatise ce travail sur tout le réseau — pour que chaque établissement soit compétitif, pas seulement ceux dont quelqu'un s'est souvenu de mettre à jour.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Découvrir les fonctionnalités
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte bancaire · Résiliez quand vous voulez
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ entreprises et agences</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1 200+ établissements gérés</span>
          </div>
        </div>
      </div>
    </section>


    <!-- NARRATIF -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème du SEO franchise</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Certains établissements se classent. La plupart non.<br />La différence est l'exécution SEO constante.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Dans chaque réseau franchise, il y a un pattern récurrent : un groupe d'établissements top performers qui se classent constamment et une longue traîne d'établissements sous-performeurs invisibles en recherche locale. La différence est presque jamais la qualité du service — c'est la qualité de l'exécution SEO locale. Les établissements qui se classent ont des profils GBP actifs, des citations cohérentes et des avis récents. Les invisibles ont des fiches GBP non mises à jour, des données NAP incohérentes et des profils abandonnés.
            </p>
            <p>
              La raison n'est pas la négligence — c'est la capacité. Il n'y a aucun moyen de maintenir manuellement un SEO local correct sur 50 ou 500 établissements. Quelque chose est toujours oublié. Stacc garantit que rien n'est oublié en automatisant chaque tâche SEO récurrente pour chaque établissement chaque jour.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- CE QUE FAIT STACC — FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que fait Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            SEO local automatisé pour chaque<br />établissement du réseau.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'SEO local automatisé par établissement', body: '30 posts GBP/mois localisés par franchise — aucune intervention manuelle. Pertinence locale garantie pour chaque territoire.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positionnement centralisé', body: 'Positions Google Maps et organiques pour tous les établissements. Identifiez immédiatement les franchises sous-performantes.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Surveillance des citations', body: 'Cohérence NAP dans 50+ annuaires sur l\'ensemble du réseau. Corrections automatiques pour chaque établissement.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitoring des avis', body: 'Alertes instantanées + modèles de réponse pour chaque établissement. Gérez la réputation du réseau entier depuis un seul endroit.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Rapports automatiques', body: 'Livrés automatiquement par établissement ou pour l\'ensemble du réseau. Aucun travail de mise en forme requis.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Tableau de bord réseau', body: 'Vue globale + détail par établissement en quelques clics. Franchiseurs et franchisés ont leurs propres niveaux d\'accès.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS SEO FRANCHISE -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités SEO franchise</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque établissement. Chaque tâche.<br />Tout automatisé.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Gestion GBP en masse', body: 'Publiez des posts sur tous les établissements franchise simultanément. Mettez à jour les horaires, descriptions et attributs pour tout le réseau en une seule action.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positions par établissement', body: 'Classements quotidiens pour chaque établissement en local pack, Maps et organique. Comparez tous les établissements côte à côte pour identifier les marchés à renforcer.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Surveillance cohérence NAP', body: 'Détectez et corrigez les incohérences NAP sur 50+ annuaires pour chaque établissement. La cohérence des citations est un facteur de classement fondamental pour le SEO local.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Surveillance avis par établissement', body: 'Alertes avis en temps réel pour chaque établissement. Répondez depuis un tableau de bord centralisé. Suivez la note moyenne et le volume par établissement.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Rapports de performance réseau', body: 'Tableau de bord portefeuille compare tous les établissements. Identifiez instantanément les meilleurs et les moins bons. Rapports automatiques pour tout le réseau ou les établissements individuels.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Accès franchiseur et franchisé', body: 'Les franchiseurs voient tout le réseau. Les franchisés voient leurs propres établissements. Gestion centralisée avec responsabilité individuelle.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités en détail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Une marque. Des dizaines de territoires.<br />Une seule plateforme automatisée.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Cohérence de marque + pertinence locale -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Contenu Local par Franchise</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Cohérence de marque. Pertinence locale.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque franchisé reçoit des posts GBP qui reflètent la marque mais mentionnent sa ville, son quartier et ses services locaux. La cohérence de marque est maintenue sur tout le réseau. La pertinence locale est assurée pour chaque territoire. Aucun compromis entre les deux — les deux sont automatisés simultanément.
              </p>
              <a href="/fr/logiciel-google-business-profile/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir la gestion GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posts GBP — Même marque, villes différentes</p>
              {[
                { location: 'Franchise Toulouse', post: 'Service disponible à Toulouse — rive gauche', badge: 'Local' },
                { location: 'Franchise Nantes', post: 'Service disponible à Nantes et sa périphérie', badge: 'Local' },
                { location: 'Franchise Strasbourg', post: 'Service disponible à Strasbourg centre', badge: 'Local' },
                { location: 'Franchise Lille', post: 'Service disponible à Lille et métropole', badge: 'Local' },
              ].map(r => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#4f39f6] text-white">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.location}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.post}</p>
                  </div>
                  <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6] shrink-0">{r.badge}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 posts/mois · Localisés par établissement · Branding uniforme</p>
            </div>
          </div>

          <!-- Suivi centralisé -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Positions — Tableau de bord réseau franchise</p>
              {[
                { franchise: 'Toulouse Rive Gauche', pos: 1, change: '+3', trend: 'up' },
                { franchise: 'Nantes Centre', pos: 2, change: '+4', trend: 'up' },
                { franchise: 'Strasbourg', pos: 2, change: '+2', trend: 'up' },
                { franchise: 'Lille Métropole', pos: 6, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.franchise}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">Local Pack · Google Maps</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Mis à jour quotidiennement · Tous les franchisés</p>
            </div>
