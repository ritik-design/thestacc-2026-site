---
import ToolLayoutFr from '../../../components/tools/ToolLayoutFr.astro';
---

<ToolLayoutFr
  title="Score SEO de votre site (30+ vérifications) | theStacc"
  description="Analyse SEO complète de votre site web : SEO on-page, technique, SEO local, avis, signaux IA. Note globale sur 100 avec corrections prioritaires. Gratuit, sans inscription."
  toolName="Score SEO de votre site"
  toolDescription="Analyse complète en 30+ points : SEO on-page, technique, local SEO, avis et préparation IA. Obtenez une note sur 100 et un plan d'action prioritaire."
  enUrl="https://thestacc.com/tools/website-seo-score/"
>
  <Fragment slot="tool">
    <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
      <div class="space-y-4">
        <div>
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">URL du site <span class="text-red-500">*</span></label>
          <input type="url" id="url-input" required placeholder="ex. : monentreprise.fr" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-3 text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
        </div>
        <div>
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">Mot-clé cible <span class="text-red-500">*</span></label>
          <input type="text" id="keyword-input" required maxlength="150" placeholder="ex. : dentiste à Paris, plombier urgence Lyon" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
        </div>
        <button id="score-btn" class="w-full rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3.5 font-mono text-sm font-bold uppercase text-white hover:bg-[#4f39f6] cursor-pointer disabled:opacity-50 transition-colors">
          Analyser mon site
        </button>
      </div>
      <p id="url-error" class="mt-2 hidden text-xs text-red-500"></p>
    </div>

    <div id="loading-section" class="mt-6 hidden rounded-2xl border border-[#e7e5e4] bg-white p-6">
      <div class="space-y-3">
        <div class="flex items-center gap-3"><span class="w-5 h-5 text-[#79716b]"><svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg></span><span class="text-[14px] text-[#57534e]">Analyse de votre site en cours&hellip;</span></div>
      </div>
    </div>

    <div id="error-section" class="mt-6 hidden rounded-2xl border border-red-200 bg-red-50 p-6 text-center">
      <p class="text-[15px] text-red-700 font-medium">Une erreur s'est produite</p>
      <p id="error-message" class="mt-1 text-[13px] text-red-600">Vérifiez l'URL et réessayez.</p>
    </div>

    <div id="results-section" class="mt-6 hidden space-y-6">
      <div id="score-hero" class="rounded-2xl border border-[#e7e5e4] bg-white p-8"></div>
      <div id="categories-section" class="space-y-4"></div>
      <div id="checks-section" class="space-y-3"></div>
    </div>

    <noscript><div class="py-12 text-center"><p class="text-[15px] text-[#79716b]">Cet outil nécessite JavaScript.</p></div></noscript>
    <script is:inline src="/js/seo-score-engine.js"></script>
  </Fragment>

  <Fragment slot="content">
    <h2 class="text-xl font-semibold text-[#292524] mb-3">Que couvre cette analyse SEO ?</h2>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Cet outil effectue plus de 30 vérifications réparties en 6 catégories : SEO on-page, santé technique, signaux de contenu, SEO local, santé des avis et préparation IA. C'est l'analyse SEO la plus complète disponible gratuitement.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Pour un bilan rapide en 10 points, utilisez notre <a href="/fr/outils/audit-seo/" class="text-[#615fff] hover:underline">Audit SEO (version lite)</a>. Pour une optimisation de mots-clés sur une page spécifique, utilisez le <a href="/fr/outils/verification-seo-on-page/" class="text-[#615fff] hover:underline">Vérificateur SEO on-page</a>.</p>

    <h2 class="text-xl font-semibold text-[#292524] mt-8 mb-3">Questions fréquentes</h2>
    <div class="overflow-hidden rounded-2xl border border-[#e5e7eb] bg-white shadow-sm">
      {[
        { q: "Combien de vérifications cet outil effectue-t-il ?", a: "Plus de 30 vérifications réparties en 6 catégories : SEO on-page, technique, contenu, SEO local, avis et préparation IA." },
        { q: "Quelle est la différence avec l'Audit SEO lite ?", a: "L'Audit SEO lite effectue 10 vérifications critiques pour un bilan rapide. Ce Score SEO va beaucoup plus loin avec 30+ vérifications incluant le SEO local, les avis et les signaux IA." },
        { q: "Cet outil est-il gratuit ?", a: "Oui, 100% gratuit. Sans inscription ni email requis. Tout s'exécute dans votre navigateur." },
      ].map((faq, i) => (
        <div class={i < 2 ? "border-b border-[#f3f4f6]" : ""}>
          <button class="tool-faq-btn flex w-full cursor-pointer items-start justify-between gap-4 px-6 py-5 text-left hover:bg-[#fafafa]" aria-expanded="false">
            <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
            <svg class="tool-faq-plus mt-0.5 shrink-0 text-[#9ca3af]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <svg class="tool-faq-minus hidden mt-0.5 shrink-0 text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <div class="tool-faq-answer hidden px-6 pb-5">
            <p class="font-sans text-[14px] leading-[1.7] text-[#4b5563]">{faq.a}</p>
          </div>
        </div>
      ))}
    </div>
  </Fragment>
</ToolLayoutFr>
