---
import ToolLayoutFr from '../../../components/tools/ToolLayoutFr.astro';
---

<ToolLayoutFr
  title="Générateur de demandes d'avis Google gratuit | theStacc"
  description="Générez des messages de demande d'avis personnalisés pour vos clients. SMS, e-mail ou message en face à face. Adapté à votre secteur. Gratuit, sans inscription."
  toolName="Générateur de demandes d'avis"
  toolDescription="Créez des messages de demande d'avis Google qui fonctionnent. SMS, e-mail ou message verbal. Personnalisés selon votre secteur et le type de client."
  enUrl="https://thestacc.com/tools/review-request-generator/"
>
  <Fragment slot="tool">
    <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
      <form id="form" novalidate>
        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="biz">Nom de l'entreprise <span class="text-red-500">*</span></label>
          <input type="text" id="biz" required maxlength="100" placeholder="ex. : Plomberie Martin" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[15px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
        </div>

        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="service">Service fourni <span class="text-red-500">*</span></label>
          <input type="text" id="service" required maxlength="150" placeholder="ex. : débouchage de canalisation, détartrage dentaire" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
        </div>

        <div class="mb-5">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-2">Canal de communication <span class="text-red-500">*</span></label>
          <div class="grid grid-cols-3 gap-2">
            {['SMS', 'E-mail', 'En personne'].map(channel => (
              <label class="channel-label flex cursor-pointer items-center justify-center gap-2 rounded-lg border border-[#e7e5e4] bg-white px-3 py-2.5 text-[13px] font-medium text-[#57534e] transition-all hover:border-[#4f39f6]">
                <input type="radio" name="channel" value={channel} class="sr-only" />
                {channel}
              </label>
            ))}
          </div>
          <p class="mt-1 hidden text-xs text-red-500" id="err-channel">Veuillez sélectionner un canal</p>
        </div>

        <div class="mb-6">
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5" for="customer-name">Prénom du client (facultatif)</label>
          <input type="text" id="customer-name" maxlength="50" placeholder="ex. : Marie" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none transition-colors" />
        </div>

        <button type="submit" id="generate-btn" class="w-full rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3.5 font-mono text-sm font-bold uppercase text-white hover:bg-[#4f39f6] cursor-pointer disabled:opacity-50 transition-colors">
          Générer les messages
        </button>
      </form>
    </div>

    <div id="loading-section" class="mt-6 hidden rounded-2xl border border-[#e7e5e4] bg-white p-6">
      <div class="flex items-center gap-3"><span class="w-5 h-5 text-[#79716b]"><svg class="animate-spin" width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg></span><span class="text-[14px] text-[#57534e]">Rédaction de vos demandes d'avis&hellip;</span></div>
    </div>

    <div id="error-section" class="mt-6 hidden rounded-2xl border border-red-200 bg-red-50 p-6 text-center">
      <p class="text-[15px] text-red-700 font-medium">Une erreur s'est produite</p>
      <p id="error-message" class="mt-1 text-[13px] text-red-600">Veuillez réessayer.</p>
    </div>

    <div id="results-section" class="mt-6 hidden space-y-4">
      <div id="messages-list" class="space-y-4"></div>
    </div>

    <noscript><div class="py-12 text-center"><p class="text-[15px] text-[#79716b]">Cet outil nécessite JavaScript.</p></div></noscript>
    <script is:inline src="/js/review-request-engine.js"></script>
  </Fragment>

  <Fragment slot="content">
    <h2 class="text-xl font-semibold text-[#292524] mb-3">Comment obtenir plus d'avis Google ?</h2>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">70 % des clients laissent un avis quand on le leur demande. Le problème n'est pas la volonté des clients — c'est que la plupart des entreprises n'ont pas de processus systématique pour le demander. Ce générateur crée des messages qui fonctionnent : directs, personnalisés et adaptés au canal de communication.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Le meilleur moment pour demander un avis est dans les 24 heures suivant la prestation, quand l'expérience est encore fraîche. Le SMS a un taux d'ouverture de 98 % — c'est le canal le plus efficace pour les demandes d'avis.</p>
  </Fragment>
</ToolLayoutFr>
