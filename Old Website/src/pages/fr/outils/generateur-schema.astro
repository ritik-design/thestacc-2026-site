---
import ToolLayoutFr from '../../../components/tools/ToolLayoutFr.astro';

const schemaTypes = [
  { value: 'LocalBusiness',    label: 'Entreprise locale' },
  { value: 'Restaurant',       label: 'Restaurant' },
  { value: 'MedicalBusiness',  label: 'Médical / Santé' },
  { value: 'LegalService',     label: 'Service juridique' },
  { value: 'HomeAndConstructionBusiness', label: 'Artisan / BTP' },
  { value: 'FinancialService', label: 'Service financier' },
  { value: 'AutomotiveBusiness', label: 'Automobile' },
  { value: 'SportsActivityLocation', label: 'Sport / Fitness' },
  { value: 'HairSalon',        label: 'Salon de coiffure / Beauté' },
  { value: 'RealEstateAgent',  label: 'Agent immobilier' },
  { value: 'Article',          label: 'Article / Blog' },
  { value: 'FAQPage',          label: 'Page FAQ' },
  { value: 'Product',          label: 'Produit' },
  { value: 'Organization',     label: 'Organisation' },
  { value: 'Person',           label: 'Personne / Auteur' },
];
---

<ToolLayoutFr
  title="Générateur de Schema markup JSON-LD gratuit | theStacc"
  description="Générez du Schema markup JSON-LD pour votre site : entreprise locale, restaurant, article, FAQ, produit et plus. Code prêt à copier-coller. Gratuit, sans inscription."
  toolName="Générateur de Schema markup"
  toolDescription="Générez du Schema markup JSON-LD valide pour n'importe quel type d'entité. Copiez-collez le code dans votre site pour améliorer votre visibilité dans Google."
  enUrl="https://thestacc.com/tools/schema-markup-generator/"
  wide={true}
>
  <Fragment slot="tool">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
      <!-- Form -->
      <div class="space-y-5">
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6">
          <h3 class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b] mb-4">Type de Schema</h3>
          <select id="schema-type" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none">
            {schemaTypes.map(t => <option value={t.value}>{t.label}</option>)}
          </select>
        </div>

        <div id="form-fields" class="rounded-2xl border border-[#e7e5e4] bg-white p-6 space-y-4">
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">Nom <span class="text-red-500">*</span></label>
            <input type="text" id="field-name" maxlength="200" placeholder="Nom de votre entreprise ou entité" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none" />
          </div>
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">URL du site</label>
            <input type="url" id="field-url" placeholder="https://monentreprise.fr" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none" />
          </div>
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">Téléphone</label>
            <input type="tel" id="field-phone" placeholder="+33 1 23 45 67 89" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none" />
          </div>
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">Adresse</label>
            <input type="text" id="field-address" placeholder="123 rue de la Paix" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">Ville</label>
              <input type="text" id="field-city" placeholder="Paris" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none" />
            </div>
            <div>
              <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">Code postal</label>
              <input type="text" id="field-postal" placeholder="75001" class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none" />
            </div>
          </div>
          <div>
            <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b] mb-1.5">Description</label>
            <textarea id="field-description" rows="3" maxlength="500" placeholder="Description courte de votre entreprise..." class="w-full rounded-lg border border-[#e7e5e4] bg-white px-4 py-2.5 text-[14px] text-[#292524] placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] outline-none resize-none"></textarea>
          </div>

          <button id="generate-btn" class="w-full rounded-xl border border-[#4f39f6] bg-[#615fff] px-6 py-3 font-mono text-sm font-bold uppercase text-white hover:bg-[#4f39f6] cursor-pointer transition-colors">
            Générer le Schema
          </button>
        </div>
      </div>

      <!-- Output -->
      <div>
        <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 h-full">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">JSON-LD généré</h3>
            <button id="copy-btn" class="inline-flex items-center gap-1.5 rounded-lg border border-[#e7e5e4] px-3 py-1.5 font-mono text-[11px] font-semibold text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              Copier
            </button>
          </div>
          <pre id="schema-output" class="overflow-auto rounded-lg bg-[#0d1117] p-4 font-mono text-[12px] leading-[1.6] text-[#e2e8f0] min-h-[300px]"><code class="text-[#818cf8]">// Le schema JSON-LD apparaîtra ici après génération</code></pre>
          <div class="mt-4">
            <p class="font-mono text-[10px] text-[#79716b]">Copiez ce code et collez-le dans la section &lt;head&gt; de votre page HTML ou dans les paramètres de scripts de votre CMS.</p>
          </div>
        </div>
      </div>
    </div>

    <noscript><div class="py-12 text-center"><p class="text-[15px] text-[#79716b]">Cet outil nécessite JavaScript.</p></div></noscript>
    <script is:inline src="/js/schema-generator-engine.js"></script>
  </Fragment>

  <Fragment slot="content">
    <h2 class="text-xl font-semibold text-[#292524] mb-3">Qu'est-ce que le Schema markup ?</h2>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Le Schema markup (ou données structurées) est un code que vous ajoutez à votre site web pour aider les moteurs de recherche à comprendre précisément ce que votre page représente. Google utilise ces données pour afficher des rich snippets — étoiles d'avis, horaires, FAQ, prix — directement dans les résultats de recherche.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Le format JSON-LD est recommandé par Google car il s'intègre facilement dans le &lt;head&gt; de n'importe quelle page sans modifier le HTML existant. C'est le format le plus simple à implémenter et à maintenir.</p>
    <p class="text-[15px] text-[#57534e] leading-relaxed mb-3">Pour les entreprises locales, le Schema LocalBusiness est particulièrement important car il indique à Google votre nom, adresse, téléphone et horaires — les informations que Google utilise pour valider votre fiche GBP et améliorer votre classement local.</p>
  </Fragment>
</ToolLayoutFr>
