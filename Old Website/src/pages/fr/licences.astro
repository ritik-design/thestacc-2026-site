---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const licenses = [
  { name: 'Astro', version: '5.x', license: 'MIT', description: 'Framework web modern pour les sites à contenu statique et dynamique.' },
  { name: 'Tailwind CSS', version: '4.x', license: 'MIT', description: 'Framework CSS utilitaire pour la construction d\'interfaces personnalisées.' },
  { name: 'Three.js', version: '0.x', license: 'MIT', description: 'Bibliothèque JavaScript 3D utilisée pour les animations du tableau de bord.' },
  { name: 'Lucide Icons', version: '0.x', license: 'ISC', description: 'Bibliothèque d\'icônes SVG open-source.' },
  { name: 'Geist Font', version: '1.x', license: 'OFL-1.1', description: 'Police de caractères conçue par Vercel, utilisée pour le texte de l\'interface.' },
];
---

<BaseLayout
  title="Licences — theStacc"
  description="Licences des logiciels open-source utilisés par theStacc. Attributions et notices de copyright pour nos dépendances tierces."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Légal · Licences</span>
        <h1 class="mt-2 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.5rem]">Licences</h1>
        <p class="mt-2 font-mono text-[12px] text-[#79716b]">Dernière mise à jour : Avril 2026</p>
      </div>
    </section>
    <div class="min-h-screen bg-[#fafaf9]">
      <div class="container-x py-12 md:py-16">
        <div class="mx-auto max-w-3xl">
          <p class="mb-8 font-sans text-[15px] leading-[1.75] text-[#57534e]">
            theStacc utilise les bibliothèques et ressources open-source suivantes. Nous remercions leurs auteurs et contributeurs.
          </p>

          <div class="space-y-4">
            {licenses.map(lib => (
              <div class="rounded-xl border border-[#e7e5e4] bg-white p-6">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h2 class="font-sans text-[16px] font-semibold text-[#292524]">{lib.name} <span class="font-mono text-[12px] font-normal text-[#79716b]">v{lib.version}</span></h2>
                    <p class="mt-1 font-sans text-[13px] text-[#79716b]">{lib.description}</p>
                  </div>
                  <span class="shrink-0 rounded-full bg-[#f5f3ff] px-3 py-1 font-mono text-[11px] font-semibold text-[#7c3aed]">{lib.license}</span>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-10 rounded-xl border border-[#e7e5e4] bg-white p-6">
            <h2 class="font-sans text-[16px] font-semibold text-[#111827]">Licence du contenu theStacc</h2>
            <p class="mt-2 font-sans text-[14px] leading-[1.7] text-[#57534e]">
              Tout le contenu original publié sur thestacc.com — articles de blog, guides, comparatifs, avis — est protégé par le droit d'auteur de SOLARTREK VENTURES LLP. Sauf mention contraire, aucune reproduction sans autorisation écrite préalable n'est autorisée.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
