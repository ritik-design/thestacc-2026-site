---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';
import { SITE_URL, LOGO_URL, buildBreadcrumbs } from '../../utils/schema';

const plans = [
  {
    name: 'Croissance Locale',
    tagline: 'Blog + SEO Local, entièrement géré.',
    price: 749,
    annualPrice: 625,
    popular: false,
    features: [
      '30 articles publiés/mois',
      '30 publications Google Business/mois',
      'Surveillance quotidienne des avis et réponses',
      'Rapports de performance hebdomadaires',
      'Appel stratégique mensuel en visio',
      '1 emplacement inclus (+150 $/emplacement supplémentaire)',
    ],
  },
  {
    name: 'Croissance Pro',
    tagline: 'Blog + SEO Local + Réseaux Sociaux.',
    price: 999,
    annualPrice: 835,
    popular: true,
    features: [
      'Tout de Croissance Locale',
      '60 publications sociales/mois sur 6 plateformes',
      'Contenu et hashtags spécifiques par plateforme',
      'Calendrier de publication optimisé',
      'Surveillance quotidienne des interactions',
      'Analytique mensuelle + appel stratégique',
    ],
  },
  {
    name: 'Croissance Complète',
    tagline: 'Tout : blog, local, social et site web.',
    price: 1299,
    annualPrice: 999,
    popular: false,
    features: [
      'Tout de Croissance Pro',
      'Site web IA, hébergé et géré',
      'Mises à jour mensuelles et ajustements SEO',
      'Surveillance de la vitesse et correctifs de sécurité',
      'Rapports hebdomadaires + appel stratégique mensuel',
      'Équipe opérationnelle basée aux États-Unis',
    ],
  },
];

const steps = [
  {
    n: '01',
    title: 'Réservez un appel de 30 minutes',
    body: 'Parlez-nous de votre secteur, de vos objectifs et de là où vous bloquez. Pas de pression, pas de présentation. Une vraie conversation.',
  },
  {
    n: '02',
    title: 'Nous créons votre plan sur 90 jours',
    body: 'Notre équipe définit les objectifs de mots-clés, les améliorations Google Business et la stratégie réseaux sociaux spécifiques à votre entreprise et votre localisation.',
  },
  {
    n: '03',
    title: 'Nous gérons tout',
    body: 'Le contenu est publié, les avis sont traités, les posts sortent chaque jour. Vous vérifiez mensuellement. C\'est tout.',
  },
];

const callDeliverables = [
  'Un plan personnalisé de contenu + SEO local sur 90 jours',
  'Analyse des lacunes de mots-clés pour votre secteur et localisation',
  'Évaluation honnête de votre Google Business Profile actuel',
  'Une recommandation de plan claire sans surprises tarifaires',
];

const objections = [
  {
    q: "Pourquoi parler à une personne si c'est géré par IA ?",
    a: "L'IA gère l'exécution : la rédaction, la planification et les réponses. Notre équipe gère la stratégie : quels mots-clés cibler, comment doit sonner la voix de votre marque et quoi corriger en premier. L'appel est là pour aligner votre entreprise à un plan qui correspond vraiment. Un résultat générique IA est facile. Un résultat précis, avec votre marque et localisé, nécessite un brief humain.",
  },
  {
    q: "En quoi est-ce différent d'une agence classique ?",
    a: "Une agence typique facture 3 000–10 000 €/mois parce qu'elle facture des heures humaines. Nous facturons 749–1 299 €/mois parce que l'IA gère la production. Vous avez quand même un manager dédié, un appel stratégique et des rapports hebdomadaires. Juste sans la surfacturation agence. Les mêmes résultats. Une fraction du coût.",
  },
  {
    q: "Et si je ne suis pas satisfait après 30 jours ?",
    a: "Écrivez-nous et nous remboursons intégralement. Pas d'entretien de sortie, pas de frais d'annulation. Le contenu que nous avons publié reste sur votre site et continue de se positionner. Vous gardez tout ce que nous avons construit, même si vous partez.",
  },
];

const testimonials = [
  {
    quote: "Nous sommes passés de 0 à 47 leads mensuels en 4 mois. Stacc a remplacé notre agence à 3 000 €/mois et les résultats sont encore meilleurs.",
    role: "Propriétaire, Cabinet Dentaire · Lyon",
    metric: "47 leads/mois",
    init: "DP",
  },
  {
    quote: "Top 3 sur Maps pour 'plombier urgence près de moi' en 90 jours. Les publications Google Business sortent chaque jour sans que je touche à quoi que ce soit. Pour 749 €/mois, rien ne se compare.",
    role: "Propriétaire, Entreprise de Plomberie · Marseille",
    metric: "Top 3 Maps en 90 jours",
    init: "SD",
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/fr/demo/`,
      name: 'Réservez un Appel Stratégique | theStacc Services Gérés',
      description: 'Réservez un appel stratégique gratuit de 30 minutes. Nous créerons un plan SEO et réseaux sociaux de 90 jours pour votre entreprise. Services gérés à partir de 749 €/mois.',
      url: `${SITE_URL}/fr/demo/`,
      inLanguage: 'fr',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(`${SITE_URL}/fr/demo/`, [
      { name: 'Accueil', url: `${SITE_URL}/fr/` },
      { name: 'Réserver un Appel', url: `${SITE_URL}/fr/demo/` },
    ]),
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL },
    },
  ],
};
---

<BaseLayout
  title="Réservez un Appel Stratégique | theStacc Services Gérés"
  description="Réservez un appel stratégique gratuit de 30 minutes. Nous créerons un plan SEO et réseaux sociaux de 90 jours pour votre entreprise. Services gérés à partir de 749 €/mois."
  lang="fr"
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.4) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[680px] text-center">

          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4ade80]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Appel stratégique gratuit de 30 minutes</span>
          </div>

          <h1 class="font-sans text-[2.6rem] font-semibold leading-[1.1] tracking-[-0.04em] text-[#292524] md:text-[3.25rem]">
            Résultats d'agence.<br />
            <span style="color:#4f39f6;">Sans le budget agence.</span>
          </h1>

          <p class="mx-auto mt-5 max-w-[520px] font-sans text-[1.05rem] leading-[1.7]" style="color:#9ca3af;">
            Nous gérons votre SEO, votre référencement local et vos réseaux sociaux. Entièrement. L'IA exécute. Notre équipe pilote la stratégie. Vous vérifiez les résultats une fois par mois.
          </p>

          <div class="mt-4 flex items-center justify-center gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#79716b]">
              Dès 749 €/mois
            </span>
            <span class="font-mono text-[11px] text-[#79716b]">vs.</span>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#79716b] line-through decoration-white/30">
              3 000–10 000 €/mois agence
            </span>
          </div>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="#book"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-[#4f39f6] px-7 font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Réservez votre appel stratégique gratuit
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans engagement · 30 minutes · Nous arrivons préparés
          </p>
        </div>
      </div>
    </section>


    <!-- ─── WHAT YOU GET FROM THE CALL ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-5xl">
          <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:items-center">

            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce qui se passe lors de l'appel</span>
              <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2rem]">
                Vous repartez avec un plan, pas une proposition commerciale.
              </h2>
              <p class="mt-4 font-sans text-[15px] leading-[1.7] text-[#57534e]">
                La plupart des agences utilisent le premier appel pour leur pitch. Nous l'utilisons pour auditer. En 30 minutes, vous saurez exactement ce qui manque à votre présence en ligne et quoi faire à ce sujet.
              </p>
              <div class="mt-7 flex flex-col gap-4">
                {callDeliverables.map(d => (
                  <div class="flex items-start gap-3">
                    <div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#4f39f6]">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    </div>
                    <span class="font-sans text-[15px] text-[#374151]">{d}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#4f39f6]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <div>
                  <p class="font-sans text-[14px] font-semibold text-[#111827]">Appel Stratégique Gratuit</p>
                  <p class="font-mono text-[11px] text-[#79716b]">30 minutes · Vidéo ou téléphone</p>
                </div>
              </div>
              <div class="space-y-4">
                {[
                  { icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>', label: 'Sans engagement' },
                  { icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>', label: 'Nous nous préparons avant l\'appel' },
                  { icon: '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>', label: 'Vous parlez à un vrai stratège' },
                  { icon: '<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.82 19.79 19.79 0 01.02 1.22 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.27 7.11a16 16 0 006.61 6.61l.97-.97a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>', label: 'Équipe disponible cette semaine' },
                ].map(item => (
                  <div class="flex items-center gap-3">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
                    <span class="font-sans text-[14px] text-[#374151]">{item.label}</span>
                  </div>
                ))}
              </div>
              <a href="#book" class="mt-7 flex h-11 w-full items-center justify-center rounded-xl bg-[#4f39f6] font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
                Réserver mon appel gratuit →
              </a>
            </div>

          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça fonctionne</span>
          <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2rem]">
            De zéro à entièrement géré en une semaine.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl grid grid-cols-1 gap-6 md:grid-cols-3">
          {steps.map((step) => (
            <div class="relative rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <span class="font-mono text-[2.5rem] font-bold leading-none text-[#f0effe]">{step.n}</span>
              <h3 class="mt-3 font-sans text-[16px] font-semibold text-[#111827]">{step.title}</h3>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── PLANS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Services Gérés</span>
          <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2rem]">
            Nous gérons tout votre marketing.
          </h2>
          <p class="mx-auto mt-4 font-sans text-[15px] leading-relaxed text-[#57534e]">
            L'IA fait le travail. Un manager dédié assure le contrôle qualité, la stratégie et votre revue mensuelle. Vous participez et examinez les résultats.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {plans.map((plan) => (
            <div class={`relative flex flex-col rounded-2xl border p-8 ${plan.popular ? 'border-[#4f39f6]/40 shadow-[0_8px_40px_rgba(79,57,246,0.1)]' : 'border-[#e7e5e4]'} bg-white`}>
              {plan.popular && (
                <span class="absolute -top-3.5 left-6 inline-flex items-center rounded-full bg-[#4f39f6] px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-white">
                  Le Plus Populaire
                </span>
              )}
              <h3 class="font-sans text-[17px] font-semibold text-[#111827]">{plan.name}</h3>
              <p class="mt-1 font-sans text-[13px] text-[#79716b]">{plan.tagline}</p>
              <div class="mt-5 flex items-baseline gap-1">
                <span class="font-sans text-[2.6rem] font-bold tracking-tight text-[#111827]">{plan.price} €</span>
                <span class="font-sans text-[13px] text-[#9ca3af]">/mois</span>
              </div>
              <p class="mt-1 font-sans text-[12px] text-[#79716b]">ou {plan.annualPrice} €/mois facturé annuellement</p>
              <div class="mt-6 flex flex-1 flex-col gap-3 border-t border-[#e7e5e4] pt-6">
                {plan.features.map(f => (
                  <div class="flex items-start gap-2.5">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#374151]">{f}</span>
                  </div>
                ))}
              </div>
              <a href="#book" class="mt-6 flex h-11 w-full items-center justify-center rounded-xl border border-[#4f39f6] bg-[#4f39f6] font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
                Parler à Notre Équipe
              </a>
            </div>
          ))}
        </div>

        <p class="mt-8 text-center font-sans text-[13px] text-[#79716b]">
          À titre de comparaison : un employé marketing à temps partiel coûte <strong class="text-[#57534e]">2 500–4 000 €/mois</strong>. Une agence facture <strong class="text-[#57534e]">3 000–10 000 €/mois</strong>.
        </p>
      </div>
    </section>


    <!-- ─── TESTIMONIALS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-2xl text-center mb-12">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Résultats réels</span>
          <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2rem]">
            Ce que disent nos clients en services gérés.
          </h2>
        </div>

        <div class="mx-auto max-w-4xl grid grid-cols-1 gap-5 sm:grid-cols-2">
          {testimonials.map(t => (
            <div class="flex flex-col rounded-2xl border border-[#e7e5e4] bg-white/5 p-8">
              <div class="flex gap-0.5 mb-5">
                {[1,2,3,4,5].map(() => (
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
              </div>
              <blockquote class="flex-1 font-sans text-[15px] leading-[1.7] text-white/85">"{t.quote}"</blockquote>
              <div class="mt-6 flex items-center gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#4f39f6]">
                  <span class="font-mono text-[11px] font-bold text-white">{t.init}</span>
                </div>
                <div>
                  <p class="font-mono text-[11px]" style="color:#6b7280;">{t.role}</p>
                </div>
                <div class="ml-auto rounded-full border border-[#e7e5e4] bg-white/5 px-3 py-1">
                  <span class="font-mono text-[10px] font-semibold text-[#4ade80]">{t.metric}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── OBJECTIONS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Avant de réserver</span>
          <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2rem]">
            Réponses honnêtes aux questions évidentes.
          </h2>
        </div>

        <div class="mx-auto mt-10 max-w-3xl flex flex-col gap-4">
          {objections.map((item, i) => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white">
              <button class="faq-btn flex w-full cursor-pointer items-start justify-between gap-4 px-7 py-5 text-left" type="button" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{item.q}</span>
                <svg class="faq-icon-plus mt-0.5 shrink-0 transition-transform" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus mt-0.5 shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.7] text-[#57534e]">{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BOOKING FORM ─── -->
    <section class="bg-white" id="book">
      <div class="container-x py-16 md:py-24">

        <div id="pricing-step-indicator" class="hidden mb-8 flex items-center gap-3">
          <div class="flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[11px] font-bold text-white">✓</span>
            <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">Choisir un plan</span>
          </div>
          <div class="h-px w-8 bg-[#4f39f6]"></div>
          <div class="flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[11px] font-bold text-white">✓</span>
            <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">Examiner le plan</span>
          </div>
