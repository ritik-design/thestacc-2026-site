  </main>
  <Footer />

  <script>
    // ─── PRICING FLOW CONTEXT ───
    (function () {
      const urlParams = new URLSearchParams(window.location.search);
      const billing = urlParams.get('billing') || 'annual';
      const tierMap: Record<string, { label: string; price: number }[]> = {
        blog:   [{ label: '30 articles', price: 99 }, { label: '50 articles', price: 149 }, { label: '80 articles', price: 199 }],
        local:  [{ label: '30 posts',    price: 49 }, { label: '60 posts',    price: 79  }, { label: '80 posts',    price: 99  }],
        social: [{ label: '30 posts',    price: 49 }, { label: '60 posts',    price: 79  }, { label: '120 posts',   price: 129 }],
      };
      const moduleNames: Record<string, string> = { blog: 'Blog SEO', local: 'Référencement Local', social: 'Réseaux Sociaux' };
      const selectedKeys = (['blog', 'local', 'social'] as const).filter(m => urlParams.has(m));

      if (selectedKeys.length === 0) return;

      document.getElementById('pricing-step-indicator')?.classList.remove('hidden');

      const parts = selectedKeys.map(mod => {
        const idx = Math.min(parseInt(urlParams.get(mod) || '0'), tierMap[mod].length - 1);
        const tier = tierMap[mod][idx];
        const price = billing === 'annual' ? Math.round(tier.price * 0.83) : tier.price;
        return `${moduleNames[mod]} · ${tier.label} · ${price} €/mois`;
      });
      const hasBundleDiscount = selectedKeys.length >= 2;
      const summaryText = parts.join('\n') + (hasBundleDiscount ? '\n15 % de remise bundle appliquée' : '');

      const banner = document.getElementById('plan-summary-banner');
      const summaryTextEl = document.getElementById('plan-summary-text');
      const backLink = document.getElementById('plan-back-link') as HTMLAnchorElement | null;
      if (banner && summaryTextEl) {
        summaryTextEl.style.whiteSpace = 'pre-line';
        summaryTextEl.textContent = summaryText;
        banner.classList.remove('hidden');
      }
      if (backLink) {
        backLink.href = '/review/?' + urlParams.toString();
      }

      const modulesInput = document.getElementById('demo-modules') as HTMLInputElement | null;
      if (modulesInput) {
        modulesInput.value = selectedKeys.join(',');
      }

      if (document.referrer.includes('/review')) {
        document.getElementById('book')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    })();

    // ─── FAQ ACCORDION ───
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });

    // ─── FORM SUBMISSION ───
    const form = document.getElementById('demo-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('demo-submit') as HTMLButtonElement | null;
    const successEl = document.getElementById('demo-success');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !successEl) return;

      const originalText = submitBtn.textContent ?? '';
      submitBtn.textContent = 'Envoi en cours...';
      submitBtn.disabled = true;

      try {
        const fd = new FormData(form);
        const data = {
          first_name: (fd.get('first_name') as string)?.trim(),
          last_name: (fd.get('last_name') as string)?.trim(),
          email: (fd.get('email') as string)?.trim(),
          phone: (fd.get('phone') as string)?.trim(),
          website: (fd.get('website') as string)?.trim() || undefined,
          business: (fd.get('business') as string)?.trim() || undefined,
          plan: (fd.get('plan') as string) || undefined,
          goal: (fd.get('goal') as string)?.trim() || undefined,
        };

        const res = await fetch('/api/demo/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.reset();
          successEl.classList.remove('hidden');
          submitBtn.classList.add('hidden');
        } else {
          const result = await res.json().catch(() => ({}));
          throw new Error(result.error || 'Erreur réseau');
        }
      } catch (err) {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        const msg = err instanceof Error ? err.message : 'Une erreur s\'est produite.';
        alert(`${msg} Écrivez-nous directement à sidgangal@gmail.com`);
      }
    });
  </script>
</BaseLayout>
