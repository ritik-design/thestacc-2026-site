              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="flex flex-col gap-1.5">
                  <label for="demo-fname" class="font-sans text-[12px] font-semibold text-[#374151]">Prénom <span class="text-[#ef4444]">*</span></label>
                  <input
                    id="demo-fname" name="first_name" type="text" required autocomplete="given-name"
                    placeholder="Sophie"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="demo-lname" class="font-sans text-[12px] font-semibold text-[#374151]">Nom <span class="text-[#ef4444]">*</span></label>
                  <input
                    id="demo-lname" name="last_name" type="text" required autocomplete="family-name"
                    placeholder="Martin"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="flex flex-col gap-1.5">
                  <label for="demo-email" class="font-sans text-[12px] font-semibold text-[#374151]">Email professionnel <span class="text-[#ef4444]">*</span></label>
                  <input
                    id="demo-email" name="email" type="email" required autocomplete="email"
                    placeholder="sophie@monentreprise.fr"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="demo-phone" class="font-sans text-[12px] font-semibold text-[#374151]">Numéro de téléphone <span class="text-[#ef4444]">*</span></label>
                  <input
                    id="demo-phone" name="phone" type="tel" required autocomplete="tel"
                    placeholder="+33 6 00 00 00 00"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                  />
                </div>
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="demo-website" class="font-sans text-[12px] font-semibold text-[#374151]">URL du site web</label>
                <input
                  id="demo-website" name="website" type="url" autocomplete="url"
                  placeholder="https://monentreprise.fr"
                  class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                />
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="demo-business" class="font-sans text-[12px] font-semibold text-[#374151]">Nom et secteur de l'entreprise</label>
                <input
                  id="demo-business" name="business" type="text" required
                  placeholder="Cabinet Martin · Dentisterie"
                  class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#111827] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10"
                />
              </div>

              <div class="flex flex-col gap-1.5">
                <label for="demo-plan" class="font-sans text-[12px] font-semibold text-[#374151]">Quel plan vous intéresse ?</label>
                <select
                  id="demo-plan" name="plan"
                  class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#374151] outline-none transition-colors focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/10 cursor-pointer"
                >
                  <option value="">Je ne sais pas encore</option>
                  <option value="local-growth">Croissance Locale · 749 €/mois</option>
                  <option value="growth-pro">Croissance Pro · 999 €/mois</option>
                  <option value="growth-complete">Croissance Complète · 1 299 €/mois</option>
                </select>
