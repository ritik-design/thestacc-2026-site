                <a id="plan-back-link" href="/review/" class="shrink-0 font-sans text-[12px] font-medium text-[#4f39f6] hover:underline">Modifier →</a>
              </div>
            </div>

            <p class="font-sans text-[15px] font-semibold text-[#111827]">Réservez votre appel stratégique gratuit</p>
            <p class="mt-1 font-sans text-[13px] text-[#79716b]">Confirmation sous 1 jour ouvrable.</p>

            <form
              id="demo-form"
              class="mt-6 flex flex-col gap-4"
