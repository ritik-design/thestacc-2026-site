---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  {
    q: "Comment est-ce que je gagne des commissions ?",
    a: "Partagez votre lien d'affiliation unique. Quand quelqu'un clique dessus et s'inscrit à theStacc, vous gagnez une commission sur chaque paiement qu'il effectue. Pendant jusqu'à 3 ans. Si la personne s'inscrit directement via votre lien, vous gagnez 25 %. Si notre équipe commerciale aide à conclure l'accord, vous gagnez 15 %.",
  },
  {
    q: "Quand et comment suis-je payé ?",
    a: "Les paiements sont mensuels, net-30. Les commissions de mars sont payées le 15 avril. Le paiement minimum est de 50 $. Nous payons via PayPal, virement bancaire direct (ACH), ou Wise pour les affiliés internationaux.",
  },
  {
    q: "Combien de temps dure le cookie ?",
    a: "90 jours. Si quelqu'un clique sur votre lien et s'inscrit dans les 90 jours, vous obtenez le crédit. Même s'il n'achète pas immédiatement. Vous disposez également d'un code coupon unique qui fonctionne sans cookies.",
  },
  {
    q: "Dois-je être client pour devenir affilié ?",
    a: "Non, mais cela aide. Les affiliés qui utilisent le produit peuvent parler d'expérience, et leur contenu convertit mieux. Nous fournissons un compte gratuit à tous les affiliés actifs pour que vous puissiez tout essayer.",
  },
  {
    q: "Et si mon filleul passe à un plan supérieur ?",
    a: "Vous gagnez plus. Votre commission est un pourcentage de ce que paie votre filleul. S'il commence à 99 $/mois et passe à 499 $/mois, votre commission augmente avec lui.",
  },
  {
    q: "Y a-t-il des restrictions sur la façon dont je peux promouvoir ?",
    a: "Nous demandons aux affiliés de ne pas spammer, d'enchérir sur nos mots-clés de marque en référencement payant, ni de faire des affirmations trompeuses. Par ailleurs, vous êtes libre de promouvoir via votre blog, YouTube, liste e-mail, réseaux sociaux, podcast ou tout autre canal.",
  },
  {
    q: "Quels matériaux marketing fournissez-vous ?",
    a: "Bannières publicitaires, modèles d'e-mail, visuels sociaux, fiches comparatives, captures d'écran produit, kit de marque et plus encore. Après l'inscription, vous accédez à notre bibliothèque complète de ressources affiliés.",
  },
  {
    q: "Y a-t-il un plafond sur ce que je peux gagner ?",
    a: "Aucun plafond, aucune limite. Certains de nos affiliés gagnent des milliers de dollars par mois. Avec notre plan à 999 $/mois, un seul filleul vous rapporte 249,75 $/mois. Récurrent, pendant jusqu'à 3 ans.",
  },
];
---

<BaseLayout
  title="Programme d'Affiliation — Gagnez 25 % de Commission Récurrente | theStacc"
  description="Rejoignez le programme d'affiliation theStacc. Gagnez 25 % de commission récurrente pendant 3 ans en promouvant le service SEO clé en main. Cookie 90 jours, paiements mensuels, support dédié."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Programme d'Affiliation</p>
        <h1 class="mx-auto mt-4 max-w-[620px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[44px]">
          Gagnez des revenus récurrents en promouvant un SEO qui tourne tout seul.
        </h1>
        <p class="mx-auto mt-4 max-w-[480px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          Recommandez theStacc à votre audience et gagnez jusqu'à 25 % de chaque paiement, pendant jusqu'à 3 ans par filleul. Aucune limite de filleuls.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="#postuler"
            class="inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-7 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
            Devenir Affilié
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#comment-ca-marche"
            class="inline-flex h-[46px] items-center gap-2 rounded-xl border border-[rgba(255,255,255,0.12)] px-7 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-[#94a3b8] transition-colors hover:border-[rgba(255,255,255,0.25)] hover:text-[#292524]">
            Comment ça marche
          </a>
        </div>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {['25 % commission récurrente', 'Cookie 90 jours', '3 ans par filleul', 'Gratuit pour rejoindre'].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- CHIFFRES CLÉS -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-14">
        <div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-4">
          {[
            { value: '25 %', label: 'Commission directe', sub: 'par filleul direct' },
            { value: '15 %', label: 'Commission assistée', sub: 'vente aidée par notre équipe' },
            { value: '90 j', label: 'Durée du cookie', sub: 'attribution garantie' },
            { value: '3 ans', label: 'Récurrence', sub: 'par filleul actif' },
          ].map(s => (
            <div class="bg-white px-8 py-10 text-center">
              <p class="font-sans text-[2.2rem] font-bold text-[#4f39f6]">{s.value}</p>
              <p class="mt-1 font-sans text-[14px] font-semibold text-[#292524]">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] text-[#79716b]">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COMMENT ÇA MARCHE -->
    <section id="comment-ca-marche" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mx-auto max-w-2xl text-center">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça marche</p>
          <h2 class="mt-3 font-sans text-[28px] font-bold leading-[1.2] tracking-[-0.025em] text-[#111827]">Trois étapes pour commencer à gagner</h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-4 md:grid-cols-3">
          {[
            { num: '01', title: 'Inscrivez-vous gratuitement', body: 'Rejoignez le programme en quelques minutes. Aucune carte bancaire requise. Obtenez immédiatement votre lien unique et votre code promo.' },
            { num: '02', title: 'Partagez theStacc', body: 'Publiez sur votre blog, vos réseaux, votre newsletter ou votre chaîne YouTube. Nous fournissons tous les visuels, modèles et données de comparaison.' },
            { num: '03', title: 'Encaissez vos commissions', body: 'Recevez 25 % sur chaque paiement de vos filleuls. Récurrent jusqu\'à 3 ans. Paiements mensuels net-30 via PayPal, virement ou Wise.' },
          ].map(s => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-bold text-[#e7e5e4]">{s.num}</span>
              <h3 class="mt-3 font-sans text-[16px] font-semibold text-[#292524]">{s.title}</h3>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mx-auto max-w-2xl text-center">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</p>
          <h2 class="mt-3 font-sans text-[28px] font-bold leading-[1.2] tracking-[-0.025em] text-[#111827]">Questions fréquentes sur le programme d'affiliation</h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus hidden shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer hidden px-7 pb-6"><p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- POSTULER -->
    <section id="postuler" class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-20 text-center">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Postuler</p>
        <h2 class="mt-4 font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[40px]">
          Prêt à commencer à gagner ?
        </h2>
        <p class="mx-auto mt-4 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Rejoignez le programme d'affiliation theStacc gratuitement. Accédez immédiatement à votre tableau de bord, vos liens et tous les matériaux marketing.
        </p>
        <a
          href="/affiliates/"
          class="mt-8 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Postuler Maintenant (EN)
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">Gratuit pour rejoindre · Pas de minimum de trafic · Paiements mensuels</p>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) { answer?.classList.remove('hidden'); iconPlus?.classList.add('hidden'); iconMinus?.classList.remove('hidden'); }
      });
    });
  </script>
</BaseLayout>
