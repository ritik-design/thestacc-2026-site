---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce que le SEO local marque blanche ?", a: "Le SEO local marque blanche signifie délivrer des services de référencement local à vos clients sous votre propre marque. Avec Stacc, toute la plateforme — tableaux de bord, rapports, accès clients, emails — apparaît avec le logo et les couleurs de votre agence. Les clients ne voient jamais Stacc." },
  { q: "Que comprend le module SEO local ?", a: "Le module SEO local de Stacc inclut : gestion automatisée du profil Google Business, suivi de positions quotidien, surveillance des avis en temps réel, gestion des citations sur 50+ annuaires et rapports automatisés marque blanche pour vos clients." },
  { q: "Comment se passe la configuration ?", a: "La configuration prend environ 2 heures : importez le logo de votre agence, définissez les couleurs de votre marque, configurez le domaine personnalisé pour le portail clients. Ensuite, l'onboarding de chaque nouveau client ne prend que quelques minutes. Aucune compétence technique requise." },
  { q: "Les clients peuvent-ils accéder à leur tableau de bord ?", a: "Oui. Chaque client reçoit des identifiants d'accès à un tableau de bord à votre marque. Ils peuvent consulter leurs métriques de positionnement, citations et avis en autonomie, réduisant ainsi les demandes de rapports à votre agence." },
  { q: "Comment gérer plusieurs clients simultanément ?", a: "Tous les clients sont visibles depuis un tableau de bord de gestion multi-clients unifié. Vous pouvez surveiller les performances de chaque compte, voir les alertes dans un fil unifié et gérer les tâches sans accéder à des dizaines de comptes séparés." },
  { q: "Combien coûte le module ?", a: "Le module SEO local commence à 49 $/mois et inclut toutes les fonctionnalités marque blanche. Aucun frais par client supplémentaire, aucun frais de configuration." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO Local Marque Blanche",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Logiciel SEO local marque blanche pour agences. Automatisation GBP, suivi de positions, citations et rapports — tout brandé avec votre logo.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "SEO Local Marque Blanche", "item": "https://thestacc.com/fr/seo-local-marque-blanche/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="SEO Local Marque Blanche — Automatisation SEO Local Sous Votre Marque | theStacc"
  description="Logiciel SEO local marque blanche pour agences. theStacc automatise GBP, suivi de positions, citations et rapports pour vos clients — tout brandé avec votre logo et domaine."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Local Marque Blanche · À partir de 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local marque blanche pour<br />
            <span style="color:#4f39f6;">votre agence. Votre marque.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc automatise GBP, suivi de positions, citations, surveillance des avis et rapports pour vos clients. Tout apparaît avec votre logo. Vos clients ne voient que votre agence.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Découvrir les fonctionnalités
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte de crédit · Résiliable à tout moment
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">3× plus de clients, même équipe</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuration &lt; 5 min</span>
          </div>
        </div>
      </div>
    </section>


    <!-- NARRATIF -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pourquoi le SEO local marque blanche est différent</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Les clients locaux ont besoin d'un SEO<br />qui s'exécute chaque jour, pas chaque mois.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Le SEO local n'est pas une activité mensuelle. L'algorithme de Google Maps évalue chaque jour si le profil GBP est actif, si les citations sont cohérentes et si les avis reçoivent une réponse. Les agences qui gèrent cela manuellement — pour 10, 20 ou 50 clients — ratent la plupart de ces opportunités simplement par manque de temps.
            </p>
            <p>
              Stacc résout le problème à la racine en automatisant l'exécution quotidienne : 30 posts GBP par mois pour chaque client, suivi de positions quotidien, alertes d'avis en temps réel, contrôle des citations sur plus de 50 annuaires. Tout se passe automatiquement, sans qu'un membre de votre équipe ait besoin de se connecter manuellement.
            </p>
            <p class="font-semibold text-[#111827]">
              Et tout cela — chaque tableau de bord, chaque rapport, chaque email envoyé aux clients — porte votre logo et votre marque. Vos clients voient une agence professionnelle qui délivre des résultats, pas une plateforme SaaS qu'ils ont appris à utiliser seuls.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce qu'inclut le module</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tout le SEO local de vos clients<br />géré automatiquement.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automatisation GBP', body: 'Publication automatique de 30 posts par mois pour chaque client sur Google Business Profile. Activité constante = signaux de classement constants.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positions quotidien', body: 'Surveillance des positions chaque jour pour chaque client — local pack, Maps et organique. Alertes automatiques sur les variations significatives.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Surveillance des citations', body: 'Contrôle de la cohérence NAP sur 50+ annuaires pour chaque client. Incohérences identifiées et corrigées automatiquement.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestion des avis', body: "Alertes en temps réel pour chaque nouvel avis sur tous les profils clients. Fil centralisé pour répondre sans accéder à des dizaines de comptes." },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Rapports brandés automatiques', body: 'Rapports générés, brandés avec votre logo et envoyés aux clients automatiquement chaque mois. Zéro travail manuel de reporting.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Domaine personnalisé', body: 'Le portail clients peut être hébergé sur un sous-domaine de votre agence. Expérience entièrement marque blanche de l\'URL à l\'écran de connexion.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '3×', label: 'Plus de clients par employé', sub: 'Par rapport à la gestion manuelle' },
            { value: '400+', label: "Agences utilisent Stacc", sub: 'Avec des clients SEO local actifs' },
            { value: '100%', label: 'Remplacement de marque', sub: 'Aucune référence à Stacc visible par les clients' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités clés</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            SEO local automatisé chaque jour.<br />Sous votre marque. Pour tous vos clients.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Automatisation GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisation GBP Quotidienne</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 posts GBP par mois pour chaque client. Sans que vous rédigiez une seule ligne.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                L'activité régulière sur Google Business Profile est l'un des signaux les plus importants pour le classement local. Stacc publie automatiquement 30 posts optimisés par mois pour chaque client — offres, actualités, événements, photos — sans que vous ayez à rédiger quoi que ce soit. Pour les agences gérant 20, 30 ou 50 clients, c'est la différence entre une stratégie locale sérieuse et une présence GBP abandonnée.
              </p>
              <a href="/fr/logiciel-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le logiciel SEO local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Activité GBP ce mois — tous les clients</p>
              {[
                { client: 'Boulangerie Centrale', posts: '30 publiés', views: '+340 vues' },
                { client: 'Plomberie Express', posts: '30 publiés', views: '+280 vues' },
                { client: 'Cabinet Martin', posts: '30 publiés', views: '+195 vues' },
                { client: 'Auto École Durand', posts: '30 publiés', views: '+410 vues' },
              ].map(c => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{c.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{c.posts}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">{c.views}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tous publiés automatiquement · Aucune intervention manuelle</p>
            </div>
          </div>

          <!-- Suivi de positions + alertes -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Suivi positions — portfolio agence</p>
              {[
                { client: 'Boulangerie Centrale', kw: 'boulangerie près de moi', pos: 1, trend: '↑ +2' },
                { client: 'Plomberie Express', kw: 'plombier urgence [ville]', pos: 2, trend: '↑ +4' },
                { client: 'Cabinet Martin', kw: 'avocat droit travail', pos: 3, trend: '↑ +1' },
                { client: 'Auto École Durand', kw: 'auto école [arrondissement]', pos: 2, trend: '↑ +3' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold shrink-0 text-[#059669]">{r.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Mis à jour quotidiennement · Pack local + Maps + organique</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Suivi de Positions Quotidien</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Chaque client, chaque mot-clé, chaque matin — sans vous connecter une seule fois.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc surveille quotidiennement les classements dans le local 3-pack, Google Maps et les résultats organiques pour tous vos clients et tous leurs mots-clés. Des alertes automatiques vous préviennent quand une position bouge significativement — hausse ou baisse. Vous avez une vue complète de la performance de votre portefeuille clients sans passer la journée à vérifier des dashboards.
              </p>
              <a href="/fr/logiciel-seo-multi-sites/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le SEO multi-sites
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Branding complet -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Branding 100% Agence</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Vos clients ne voient que votre agence. La technologie reste invisible.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque point de contact client — tableau de bord, rapport mensuel, email de notification, portail d'accès — est brandé avec votre logo, vos couleurs et votre domaine personnalisé. Aucune mention de Stacc nulle part. Vos clients perçoivent une agence qui a développé sa propre plateforme professionnelle, pas un revendeur de SaaS. Cette perception justifie votre tarification et renforce la fidélisation.
              </p>
              <a href="/fr/rapports-marque-blanche/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir les rapports marque blanche
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Expérience client — ce que votre client voit</p>
              {[
                { element: 'URL du portail', val: 'rapports.votreagence.fr' },
                { element: 'Logo affiché', val: 'Le vôtre ✓' },
                { element: 'Expéditeur email', val: 'noreply@votreagence.fr' },
                { element: 'Couleurs', val: 'Votre palette ✓' },
                { element: 'Mention Stacc', val: 'Aucune ✓' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{row.element}</span>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">100% votre marque · Zéro trace de Stacc</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- TÉMOIGNAGES -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que disent les agences</span>
