---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';
import { SITE_URL } from '../../../utils/schema';

const seoLocal = [
  { label: 'Comptables',              href: '/fr/pour/comptables/'           },
  { label: 'Concessionnaires auto',   href: '/fr/pour/concessionnaires-auto/' },
  { label: 'Chiropracteurs',          href: '/fr/pour/chiropracteurs/'        },
  { label: 'Services de nettoyage',   href: '/fr/pour/nettoyage/'             },
  { label: 'Entrepreneurs',           href: '/fr/pour/entrepreneurs/'         },
  { label: 'Dentistes',               href: '/fr/pour/dentistes/'             },
  { label: 'Électriciens',            href: '/fr/pour/electriciens/'          },
  { label: 'Conseillers financiers',  href: '/fr/pour/conseillers-financiers/'},
  { label: 'Salles de sport',         href: '/fr/pour/salles-de-sport/'       },
  { label: 'Santé',                   href: '/fr/pour/sante/'                 },
  { label: 'Inspecteurs immobiliers', href: '/fr/pour/inspecteurs-immobiliers/'},
  { label: 'Climatisation / Chauffage', href: '/fr/pour/cvc/'                },
  { label: 'Assurance',               href: '/fr/pour/assurance/'             },
  { label: 'Paysagistes',             href: '/fr/pour/paysagistes/'           },
  { label: 'Avocats',                 href: '/fr/pour/avocats/'               },
  { label: 'Déménageurs',             href: '/fr/pour/demenageurs/'           },
  { label: 'Services animaliers',     href: '/fr/pour/services-animaliers/'   },
  { label: 'Photographes',            href: '/fr/pour/photographes/'          },
  { label: 'Plombiers',               href: '/fr/pour/plombiers/'             },
  { label: 'Immobilier',              href: '/fr/pour/immobilier/'            },
  { label: 'Restaurants',             href: '/fr/pour/restaurants/'           },
  { label: 'Couvreurs',               href: '/fr/pour/couvreurs/'             },
  { label: 'Salons de coiffure',      href: '/fr/pour/salons/'                },
  { label: 'Thérapeutes',             href: '/fr/pour/therapeutes/'           },
  { label: 'Soutien scolaire',        href: '/fr/pour/soutien-scolaire/'      },
  { label: 'Vétérinaires',            href: '/fr/pour/veterinaires/'          },
  { label: 'Prestataires mariage',    href: '/fr/pour/mariage/'               },
];

const blogSEO = [
  { label: 'Cabinets de conseil',     href: '/fr/pour/conseil/'               },
  { label: 'E-commerce',              href: '/fr/pour/e-commerce/'            },
  { label: 'SaaS',                    href: '/fr/pour/saas/'                  },
];

const pageUrl = `${SITE_URL}/fr/pour/`;
---

<BaseLayout
  title="Stacc pour chaque secteur | Automatisation SEO par type d'entreprise | theStacc"
  description="Stacc automatise le SEO pour plus de 30 secteurs — des entreprises de services locaux aux entreprises SaaS. Trouvez votre secteur et découvrez comment Stacc fait croître votre trafic organique."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="mx-auto max-w-[1320px] px-6 py-16 md:py-20">
        <div class="mx-auto max-w-[680px] text-center">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">30 secteurs · SEO local &amp; SEO blog</span>
          </div>
          <h1 class="font-sans text-[2.2rem] font-semibold leading-[1.15] tracking-[-0.035em] text-[#111827] md:text-[3rem]">
            Un SEO conçu pour votre secteur.
          </h1>
          <p class="mx-auto mt-5 max-w-[540px] font-sans text-[1.05rem] leading-[1.7] text-[#57534e]">
            Chaque secteur a ses propres mots-clés, ses propres acheteurs et ses propres signaux de classement. Stacc est entraîné sur votre catégorie — les articles, publications et optimisations publiés chaque mois correspondent exactement à la façon dont vos clients recherchent.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/fr/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Commencer pour 1 €
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/fr/tarifs/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#292524] transition-colors hover:bg-[#fafaf9]"
            >
              Voir les tarifs
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- BLOG SEO -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="mx-auto max-w-[1320px] px-6 py-12">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6] mb-6">SEO Blog</p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
          {blogSEO.map(item => (
            <a
              href={item.href}
              class="flex items-center justify-between gap-2 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-5 py-4 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#a8a29e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- LOCAL SEO -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="mx-auto max-w-[1320px] px-6 py-12">
        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6] mb-6">SEO Local</p>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
          {seoLocal.map(item => (
            <a
              href={item.href}
              class="flex items-center justify-between gap-2 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <span class="font-sans text-[13px] font-medium text-[#292524]">{item.label}</span>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#a8a29e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FOOTER CTA -->
    <section class="relative overflow-hidden py-16" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.08) 0%, transparent 65%);"></div>
      <div class="mx-auto max-w-[680px] px-6 relative text-center">
        <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524]">
          Prêt à automatiser votre SEO ?
        </h2>
        <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
          30 articles de blog SEO, 30 publications GBP, et du contenu sur les réseaux sociaux chaque mois. Tout automatiquement.
        </p>
        <a href="/fr/demo/" class="mt-7 inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
          Commencer pour 1 €
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
