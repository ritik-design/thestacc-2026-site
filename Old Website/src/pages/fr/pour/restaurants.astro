---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const industry = 'Restaurants';
const industrySlug = 'restaurants';
const enSlug = 'restaurants';
const keyword = 'restaurant';
const keywordPlural = 'restaurants';

const faqs = [
  { q: "Le SEO local est-il vraiment important pour un restaurant ?", a: "C'est l'un des leviers les plus puissants. 93 % des consommateurs cherchent un restaurant en ligne avant de choisir. Les recherches comme 'restaurant [type] [ville]', 'restaurant près de chez moi' ou 'meilleur restaurant [ville]' génèrent des milliers de visites directes vers les établissements les mieux positionnés sur Maps." },
  { q: "Quels mots-clés Stacc cible-t-il pour les restaurants ?", a: "Stacc cible des combinaisons comme 'restaurant [type de cuisine] [ville]', 'restaurant près de chez moi', 'restaurant gastronomique [ville]', 'restaurant livraison [ville]', 'restaurant famille [ville]'. Calibrés sur votre type de cuisine et votre zone géographique." },
  { q: "Comment les avis influencent-ils le positionnement d'un restaurant ?", a: "Les avis sont critiques pour les restaurants. 84 % des consommateurs font autant confiance aux avis en ligne qu'aux recommandations personnelles. Répondre rapidement aux avis — positifs et négatifs — améliore votre score de pertinence Maps et rassure les clients potentiels." },
  { q: "Stacc peut-il gérer plusieurs restaurants ou franchises ?", a: "Oui. Chaque établissement reçoit sa propre stratégie, son propre calendrier de contenus GBP et son rapport de positionnement — tout depuis un seul tableau de bord. Idéal pour les groupes de restauration." },
  { q: "À quelle fréquence faut-il publier sur GBP pour un restaurant ?", a: "Stacc publie 30 fois par mois par établissement. Pour les restaurants, la régularité est essentielle — menu du jour, plats spéciaux, événements, photos de plats. Un GBP actif améliore directement le positionnement dans le Map Pack." },
  { q: "En quoi Stacc est-il différent des plateformes de réservation comme TheForge ?", a: "Les plateformes de réservation gèrent vos réservations en ligne. Stacc améliore votre visibilité organique sur Google Maps — pour que les clients vous trouvent avant même d'aller sur ces plateformes. Les deux sont complémentaires." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": `theStacc pour ${industry}`, "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "fr", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" }, { "@type": "ListItem", "position": 2, "name": "Secteurs", "item": "https://thestacc.com/fr/pour/" }, { "@type": "ListItem", "position": 3, "name": industry, "item": `https://thestacc.com/fr/pour/${industrySlug}/` } ] },
    { "@type": "FAQPage", "inLanguage": "fr", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout title={`SEO pour ${industry} | Plus de Clients depuis Google Maps | theStacc`} description={`Stacc automatise votre SEO local : posts GBP, gestion des avis, suivi de positions. Plus de couverts depuis Google à 49 $/mois.`} lang="fr">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO pour {industry} · Powered by Stacc</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Plus de couverts depuis Google.<br /><span style="color:#4f39f6;">Votre restaurant en tête de Maps.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            93 % des consommateurs cherchent un {keyword} en ligne avant de choisir. Stacc publie sur votre GBP chaque jour, gère vos avis et surveille votre positionnement — tout automatiquement.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">Commencer pour 1 $ aujourd'hui<svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="#faq" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e]">Voir la FAQ</a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Remboursement 30 jours · Aucun contrat · Publie sur votre GBP chaque jour</p>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que Stacc fait pour les {keywordPlural}</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Chaque levier qui remplit vos tables depuis Google. Géré.</h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Posts GBP Restaurant', body: '30 posts par mois — plats du jour, spécialités saisonnières, événements, nouveaux menus et actualités de votre restaurant. Publiés automatiquement pour maintenir votre GBP toujours actif.', icon: 'M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z' },
            { title: 'Mots-Clés Restauration', body: "Combinaisons type de cuisine + ville — restaurant français, pizza, sushi, burger, restaurant gastronomique, brunch, végétarien. Calibrés sur votre concept et votre zone.", icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
            { title: 'Gestion des Avis', body: 'Alertes instantanées pour chaque avis Google. Répondez rapidement à tous les avis — positifs et négatifs — avec des modèles adaptés à la restauration pour montrer votre soin envers les clients.', icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' },
            { title: 'Suivi de Positions', body: 'Rapports Maps pour chaque mot-clé restaurant dans votre zone. Suivez votre positionnement pour chaque type de recherche et chaque quartier.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10' },
            { title: 'Gestion Multi-Restaurants', body: 'Un groupe de restauration avec plusieurs établissements ? Chacun reçoit sa propre stratégie et son propre calendrier GBP — tout depuis un seul tableau de bord.', icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10' },
            { title: 'Contenus Saisonniers', body: "Stacc adapte automatiquement vos contenus aux saisons — menu de Noël, Saint-Valentin, terrasse d'été — pour capter les recherches au moment où elles sont les plus fortes.", icon: 'M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={f.icon}/></svg></div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="faq" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Questions que les {keywordPlural} posent avant de commencer</h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus hidden shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer hidden px-7 pb-6"><p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="relative overflow-hidden py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.08) 0%, transparent 65%);"></div>
      <div class="container-x relative text-center">
        <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">Des clients cherchent un {keyword} maintenant.<span style="color:#818cf8;"> Apparaissez-vous ?</span></h2>
        <p class="mt-5 mx-auto max-w-[480px] font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">Stacc gère votre présence Maps et votre SEO local à 49 $/mois. Aucun contrat, remboursement 30 jours.</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/fr/demo/" class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">Commencer pour 1 $<svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          <a href="/fr/tarifs/" class="inline-flex h-12 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e]">Voir les tarifs</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) { answer?.classList.remove('hidden'); iconPlus?.classList.add('hidden'); iconMinus?.classList.remove('hidden'); }
      });
    });
  </script>
</BaseLayout>
