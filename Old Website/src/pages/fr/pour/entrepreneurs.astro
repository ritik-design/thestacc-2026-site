---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const industry = 'Entrepreneurs du Bâtiment';
const industrySlug = 'entrepreneurs';
const enSlug = 'contractors';
const keyword = 'entrepreneur';
const keywordPlural = 'entrepreneurs du bâtiment';

const features = [
  { icon: '📍', title: 'Posts GBP Bâtiment', desc: 'Publiez automatiquement des posts Google Business Profile sur vos chantiers terminés, vos certifications et vos offres de saison.' },
  { icon: '🔍', title: 'Mots-Clés Locaux', desc: 'Optimisez votre fiche pour "entrepreneur général [ville]", "rénovation maison [département]" et les recherches à fort potentiel commercial.' },
  { icon: '⭐', title: 'Gestion des Avis', desc: 'Suivez chaque nouvel avis client en temps réel et répondez rapidement pour asseoir votre crédibilité dans votre bassin d\'activité.' },
  { icon: '📊', title: 'Suivi des Positions', desc: 'Contrôlez votre classement local semaine après semaine et identifiez les opportunités pour surpasser vos concurrents locaux.' },
  { icon: '🏢', title: 'Gestion Multi-Corps d\'État', desc: 'Gérez vos différentes activités (gros œuvre, second œuvre, rénovation) depuis un tableau de bord unique avec des statistiques séparées.' },
  { icon: '📅', title: 'Contenus Saisonniers', desc: 'Planifiez vos communications autour des pics d\'activité : fin d\'hiver (isolation), printemps (terrasses), automne (toitures, chauffage).' },
];

const steps = [
  { num: '1', title: 'Connectez votre fiche', desc: 'Liez votre Google Business Profile en 2 minutes. theStacc importe et analyse votre présence actuelle.' },
  { num: '2', title: 'Automatisez vos contenus', desc: 'L\'IA crée et publie des posts sur vos réalisations et services. Vous vous concentrez sur les chantiers.' },
  { num: '3', title: 'Mesurez vos leads', desc: 'Tableau de bord clair : appels entrants, demandes de devis, clics sur itinéraire. Calculez votre ROI directement.' },
];

const faqs = [
  { q: 'Est-ce que theStacc fonctionne pour tous les corps de métier ?', a: 'Oui. Que vous soyez maçon, charpentier, carreleur, électricien ou plombier, theStacc s\'adapte à votre activité et vos mots-clés spécifiques.' },
  { q: 'Combien de temps pour voir plus de demandes de devis ?', a: 'La plupart des entrepreneurs voient une amélioration de leur visibilité locale en 6 à 10 semaines. Les premiers leads supplémentaires arrivent souvent dès le premier mois.' },
  { q: 'Je suis artisan solo, est-ce adapté pour moi ?', a: 'Absolument. theStacc est conçu pour les indépendants comme pour les entreprises. La prise en main prend moins de 5 minutes.' },
  { q: 'Puis-je mettre en avant mes réalisations et chantiers ?', a: 'Oui. Vous pouvez publier des posts avec photos de vos chantiers, ce qui augmente la confiance des prospects et améliore votre classement.' },
  { q: 'theStacc aide-t-il à collecter plus d\'avis clients ?', a: 'Oui. Nous proposons des workflows d\'invitation à laisser un avis après chantier, ce qui booste rapidement votre note Google.' },
  { q: 'Puis-je annuler à tout moment ?', a: 'Oui. Aucun engagement à long terme. Annulez depuis votre espace client sans frais ni pénalité.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": `theStacc pour ${industry}`,
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "fr",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Pour", "item": "https://thestacc.com/fr/pour/" },
        { "@type": "ListItem", "position": 3, "name": industry, "item": `https://thestacc.com/fr/pour/${industrySlug}/` }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "fr",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title={`theStacc pour ${industry} — SEO Local Automatisé`}
  description={`Attirez plus de chantiers grâce au SEO local automatisé pour entrepreneurs. Gérez votre Google Business Profile, vos avis et vos positions sans effort.`}
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-[#4f39f6]/30 bg-[#4f39f6]/10 px-4 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">SEO Local · {industry}</span>
          <h1 class="mt-6 font-sans text-[2.25rem] font-semibold leading-[1.12] tracking-[-0.03em] text-[#292524] md:text-[3rem]">
            Plus de chantiers pour votre <span class="text-[#4f39f6]">entreprise de bâtiment</span>
          </h1>
          <p class="mt-5 font-sans text-[17px] leading-[1.7] text-[#79716b]">
            87 % des propriétaires cherchent un {keyword} en ligne avant de demander un devis. theStacc automatise votre SEO local pour être le premier trouvé dans votre zone — sans effort de votre part.
          </p>
          <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
            <a href="/fr/inscription/" class="inline-flex h-11 items-center gap-2 rounded-lg bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition hover:bg-[#4333d4]">Essai gratuit 14 jours</a>
            <a href="/fr/tarifs/" class="inline-flex h-11 items-center gap-2 rounded-lg border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition hover:border-[#e7e5e4]">Voir les tarifs →</a>
          </div>
          <p class="mt-4 font-mono text-[11px] text-[#79716b]">Sans carte bancaire · Résultats en 30 jours · Annulez à tout moment</p>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="bg-white py-16 md:py-20">
      <div class="container-x">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827] md:text-[2rem]">Tout ce dont votre entreprise a besoin pour dominer le SEO local</h2>
          <p class="mt-3 font-sans text-[15px] leading-[1.7] text-[#57534e]">Des outils pensés pour les {keywordPlural}, pas pour les agences.</p>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {features.map(f => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
              <span class="text-2xl">{f.icon}</span>
              <h3 class="mt-3 font-sans text-[15px] font-semibold text-[#111827]">{f.title}</h3>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#57534e]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="bg-[#fafaf9] py-16 md:py-20">
      <div class="container-x">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827] md:text-[2rem]">Comment ça marche</h2>
          <p class="mt-3 font-sans text-[15px] leading-[1.7] text-[#57534e]">Opérationnel en moins de 5 minutes.</p>
        </div>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          {steps.map(s => (
            <div class="text-center">
              <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-[#4f39f6]/10 font-mono text-[18px] font-bold text-[#4f39f6]">{s.num}</div>
              <h3 class="mt-4 font-sans text-[15px] font-semibold text-[#111827]">{s.title}</h3>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#57534e]">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-white py-16 md:py-20">
      <div class="container-x">
        <div class="mx-auto max-w-2xl">
          <h2 class="font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827] md:text-[2rem]">Questions fréquentes</h2>
          <div class="mt-8 divide-y divide-[#e7e5e4]">
            {faqs.map((faq, i) => (
              <div class="py-4">
                <button class="faq-btn flex w-full items-center justify-between gap-4 text-left">
                  <span class="font-sans text-[15px] font-medium text-[#111827]">{faq.q}</span>
                  <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                  <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
                </button>
                <div class="faq-answer hidden pt-3">
                  <p class="font-sans text-[14px] leading-[1.7] text-[#57534e]">{faq.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="relative overflow-hidden py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% 0%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="container-x relative text-center">
        <h2 class="font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[2.25rem]">Prêt à remplir votre carnet de chantiers ?</h2>
        <p class="mt-4 font-sans text-[16px] leading-[1.7] text-[#292524]/60">Rejoignez les {keywordPlural} qui font confiance à theStacc pour leur visibilité locale.</p>
        <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <a href="/fr/inscription/" class="inline-flex h-11 items-center gap-2 rounded-lg bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition hover:bg-[#4333d4]">Commencer gratuitement</a>
          <a href="/fr/contact/" class="inline-flex h-11 items-center gap-2 rounded-lg border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition hover:bg-[#f5f3ff]">Parler à un expert →</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
document.querySelectorAll('.faq-btn').forEach((btn) => {
  btn.addEventListener('click', () => {
    const parent = btn.parentElement;
    const answer = parent?.querySelector('.faq-answer');
    const iconPlus = btn.querySelector('.faq-icon-plus');
    const iconMinus = btn.querySelector('.faq-icon-minus');
    const isOpen = !answer?.classList.contains('hidden');
    document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
    document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
    document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
    if (!isOpen) {
      answer?.classList.remove('hidden');
      iconPlus?.classList.add('hidden');
      iconMinus?.classList.remove('hidden');
    }
  });
});
</script>
