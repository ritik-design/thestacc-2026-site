---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const industry = 'Dentistes';
const industrySlug = 'dentistes';
const enSlug = 'dentists';
const keyword = 'dentiste';
const keywordPlural = 'dentistes';

const faqs = [
  { q: "Combien de temps faut-il avant que mon cabinet dentaire monte sur Google Maps ?", a: "La plupart des cabinets dentaires voient des mouvements significatifs sur Maps dans les 60 à 90 jours d'activité GBP régulière. L'algorithme de Google récompense la fréquence, la pertinence et l'engagement — tous fournis automatiquement par Stacc chaque mois." },
  { q: "Publier sur GBP aide vraiment un cabinet dentaire à se positionner ?", a: "Oui. L'algorithme Maps prend en compte la fréquence de publication, la réactivité aux avis et la pertinence des mots-clés. Chaque jour sans activité est un jour où un concurrent qui publie régulièrement prend de l'avance." },
  { q: "Quels mots-clés Stacc utilise-t-il pour les dentistes ?", a: "Stacc cible les combinaisons service + ville — comme 'dentiste près de chez moi', 'dentiste de famille [ville]', 'implants dentaires [ville]', 'dentiste urgence [ville]', 'Invisalign [ville]' et 'blanchiment dents [ville]'. Tous les mots-clés sont calibrés sur votre type de cabinet et votre localisation." },
  { q: "Mon cabinet a déjà un Google Business Profile. Dois-je tout recommencer ?", a: "Il suffit de le connecter. Stacc récupère vos données GBP existantes — nom, services, photos, historique d'avis et positionnement actuel — et construit un plan de contenus. La configuration prend moins de cinq minutes." },
  { q: "Que se passe-t-il quand je reçois un avis négatif ?", a: "Stacc envoie une alerte immédiate dès qu'un nouvel avis apparaît. Vous recevez le texte, la note et un modèle de réponse pour répondre en moins d'une minute. Répondre rapidement aux avis négatifs est l'une des actions à plus fort ROI qu'un cabinet dentaire puisse effectuer." },
  { q: "Travaillez-vous avec des cabinets dentaires multi-sites ?", a: "Oui. Chaque établissement reçoit sa propre stratégie de mots-clés, calendrier de contenus, calendrier GBP et rapport de positionnement — tout depuis un seul tableau de bord." },
  { q: "En quoi Stacc se distingue-t-il d'une agence de marketing dentaire ?", a: "Une agence de marketing dentaire rédige manuellement vos posts GBP, facture 800–2 000 $/mois et exige des contrats longs. Stacc automatise chaque partie de ce processus pour 49 $/mois." },
  { q: "Stacc aide-t-il avec le blog dentaire ou seulement avec le GBP ?", a: "Le module SEO Local de Stacc gère les posts GBP, la surveillance des avis et le suivi des positions. Si vous voulez des articles de blog dentaires publiés chaque mois, c'est le module Blog SEO à 99 $/mois. Beaucoup de cabinets utilisent les deux." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc pour Dentistes", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "fr", "description": "Stacc publie chaque jour sur le GBP de votre cabinet dentaire, gère les avis et surveille le positionnement sur Maps — automatiquement. Plus de patients depuis Google à 49 $/mois.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" }, { "@type": "ListItem", "position": 2, "name": "Secteurs", "item": "https://thestacc.com/fr/pour/" }, { "@type": "ListItem", "position": 3, "name": industry, "item": `https://thestacc.com/fr/pour/${industrySlug}/` } ] },
    { "@type": "FAQPage", "inLanguage": "fr", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout title={`SEO pour ${industry} | Plus de Patients depuis Google | theStacc`} description={`Stacc publie chaque jour sur le GBP de votre cabinet dentaire, gère les avis et surveille le positionnement sur Maps — automatiquement. Plus de patients depuis Google à 49 $/mois.`} lang="fr">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO pour {industry} · Powered by Stacc</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Plus de patients depuis Google.<br /><span style="color:#4f39f6;">Sans payer pour chaque clic.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            1,2 million de personnes cherchent « dentiste près de chez moi » chaque mois. 71 % d'entre elles cherchent en ligne avant d'appeler. Stacc fait en sorte que votre cabinet apparaisse en premier — en publiant sur votre Google Business Profile chaque jour, en gérant vos avis et en surveillant votre positionnement sur Maps. Tout automatiquement.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">Commencer pour 1 $ aujourd'hui<svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            <a href="#comment-ca-marche" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">Découvrir comment ça marche</a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Remboursement 30 jours · Aucun contrat · Publie sur votre GBP chaque jour</p>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Des patients cherchent un {keyword} maintenant.<br />Ils réservent chez quelqu'un d'autre.</h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">71 % des patients cherchent en ligne avant d'appeler un dentiste. La position sur Maps détermine quel cabinet ils appellent en premier — et souvent c'est le seul qu'ils appellent.</p>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            { title: 'Votre GBP n\'est pas mis à jour depuis des mois — pendant que les patients choisissent maintenant.', body: 'Les patients évaluent les cabinets dentaires en fonction de l\'activité récente du profil GBP. Un profil avec des posts hebdomadaires et des réponses actives aux avis paraît plus fiable. Un cabinet silencieux perd face à un cabinet actif — même si la qualité clinique est supérieure.' },
            { title: 'Un avis négatif sans réponse vous coûte de nouveaux patients chaque semaine.', body: '68 % des patients vérifient les avis avant de choisir un dentiste. Un avis sur les longues attentes sans réponse est visible de chaque patient potentiel. Dans le secteur dentaire, l\'anxiété du patient est déjà élevée — chaque signal de confiance compte.' },
            { title: 'Vous vous positionnez pour le nom de votre cabinet. Pas pour « dentiste près de chez moi ».', body: 'Les nouveaux patients ne cherchent pas le nom de votre cabinet — ils cherchent « dentiste près de chez moi », « dentiste de famille [ville] » et « implants dentaires [ville] ». Si vous n\'êtes pas dans le Map Pack pour ces mots-clés, vos créneaux restent vides.' },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z M12 9v4 M12 17h.01"/></svg></div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que Stacc fait pour les {keywordPlural}</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Chaque levier qui apporte de nouveaux patients depuis Google. Géré.</h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Publication Posts GBP', body: '30 posts par mois — conseils d\'hygiène bucco-dentaire, mises à jour de services, promotions saisonnières et informations sur les traitements. Publiés automatiquement chaque mois.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Ciblage Mots-Clés Dentaires', body: 'Combinaisons service + ville — dentiste, hygiène dentaire, implants, orthodontie, Invisalign, blanchiment. Calibrées sur votre type de cabinet et votre localisation.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
            { title: 'Surveillance des Avis', body: 'Alertes instantanées pour chaque nouvel avis. Score d\'étoiles suivi dans le temps. Modèles de réponse pour répondre professionnellement en moins d\'une minute.', icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z' },
            { title: 'Suivi de Positions Local', body: 'Rapports de positionnement Maps basés sur grille pour chaque mot-clé dentaire dans votre zone. Suivi mois par mois pour voir l\'évolution de vos positions.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Gestion Multi-Établissements', body: 'Plusieurs cabinets ? Chacun reçoit sa propre stratégie de mots-clés, calendrier de contenus et rapport — tout depuis un seul tableau de bord.', icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10' },
            { title: 'Construction de Citations', body: 'Inscriptions dans les annuaires médicaux et dentaires, Yelp, Google et plus de 50 autres. Les signaux d\'autorité qui dépassent les cabinets concurrents dans votre marché.', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d={f.icon}/></svg></div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="comment-ca-marche" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça marche</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Connectez une fois. Stacc gère la présence Maps<br />de votre cabinet dès ce jour-là.</h2>
        </div>
        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            {[
              { num: '01', title: 'Connectez votre Google Business Profile', body: 'Cherchez votre cabinet dentaire. Stacc récupère vos données GBP actuelles et identifie les mots-clés dentaires pour lesquels vous ne vous positionnez pas dans votre marché.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
              { num: '02', title: 'L\'IA construit votre plan de contenus dentaires', body: '30 posts par mois ciblant vos services — implants, Invisalign, hygiène, blanchiment et contenus saisonniers qui maintiennent votre GBP toujours actif.', icon: 'M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z' },
              { num: '03', title: 'Posts publiés. Agenda rempli. Cabinet complet.', body: 'Les contenus sont publiés selon le calendrier. Les alertes d\'avis arrivent instantanément. Votre autorité Maps grandit — quand un patient cherche un dentiste, vous êtes parmi les 3 premiers.', icon: 'M20 6 9 17l-5-5' },
            ].map(s => (
              <div class="bg-white px-8 py-10">
                <div class="mb-6 flex items-center justify-between">
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={s.icon}/></svg></div>
                  <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.num}</span>
                </div>
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
                <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Les chiffres</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">Ce que disent les données sur les patients<br />et la recherche de {keywordPlural}.</h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-2 md:grid-cols-4" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '1,2M', label: 'Recherches mensuelles « dentiste près de chez moi »', sub: 'en France seule' },
            { value: '71 %', label: 'Patients cherchent en ligne avant d\'appeler', sub: 'le GBP est la première impression' },
            { value: '68 %', label: 'Vérifient les avis avant de réserver', sub: 'la confiance se construit en ligne' },
            { value: '4,7×', label: 'Augmentation moyenne du positionnement Maps avec Stacc', sub: 'en 90 jours' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[2.8rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[13px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">{[1,2,3,4,5].map(() => (<svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>))}</div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">"Nous avions un bon bouche-à-oreille mais notre présence en ligne était quasi inexistante. Après 3 mois avec Stacc, nous sommes parmi les 3 premiers pour 'dentiste près de chez moi' et 'Invisalign [ville]'. L'agenda s'est rempli — nous avons dû embaucher une autre hygiéniste. Les posts sont publiés automatiquement, les avis sont surveillés. Pour 49 $ par mois, c'est la meilleure dépense marketing que j'aie jamais faite."</blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0"><span class="font-mono text-[14px] font-bold text-white">DR</span></div>
              <div><p class="font-sans text-[14px] font-semibold text-[#111827]">Dr. G. Ricard</p><p class="font-mono text-[11px] text-[#79716b]">Titulaire, Cabinet Dentaire Ricard · Lyon</p></div>
              <div class="ml-auto flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5 shrink-0"><span class="font-mono text-[11px] font-semibold text-[#059669]">↑ Agenda rempli en 90 jours</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tarifs</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Moins qu'un rendez-vous manqué.<br/>Chaque mois.</h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Un seul nouveau patient vaut 500–5 000 $+ sur la durée de vie. Stacc apporte plus de patients depuis Google à 49 $/mois.</p>
        </div>
        <div class="mx-auto mt-8 max-w-lg">
          <div class="overflow-hidden rounded-2xl border-2 border-[#4f39f6] bg-white shadow-[0_8px_40px_rgba(79,57,246,0.12)]">
            <div class="bg-[#4f39f6] px-8 py-6">
              <div class="flex items-start justify-between">
                <div><p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-white/70">Module SEO Local · {industry}</p><div class="mt-2 flex items-baseline gap-1"><span class="font-sans text-[3rem] font-bold text-white leading-none">$49</span><span class="font-sans text-[16px] text-white/60">/mois</span></div></div>
                <div class="rounded-full bg-white/15 px-3 py-1"><span class="font-mono text-[11px] font-semibold text-white">Sans engagement</span></div>
              </div>
              <p class="mt-3 font-sans text-[14px] text-white/70">Posts GBP, surveillance des avis, suivi de positions. En automatique.</p>
            </div>
            <div class="px-8 py-7">
              <ul class="space-y-4">
                {['30 posts GBP dentaires par mois ciblant vos services et villes', 'Mots-clés pour dentiste, implants, Invisalign, hygiène, blanchiment', 'Alertes avis instantanées et suivi de la tendance des étoiles', 'Modèles de réponse pour avis positifs, neutres et négatifs', 'Suivi de positions local basé sur grille dans votre zone de service', 'Gestion multi-établissements depuis un seul tableau de bord', 'Rapport mensuel de performance SEO local'].map(item => (
                  <li class="flex items-start gap-3"><svg class="mt-0.5 shrink-0" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg><span class="font-sans text-[14px] text-[#374151]">{item}</span></li>
                ))}
              </ul>
              <div class="mt-8 space-y-3">
                <a href="/fr/demo/" class="flex h-12 w-full items-center justify-center gap-2 rounded-xl bg-[#4f39f6] font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">Commencer pour 1 $ — puis 49 $/mois<svg width="13" height="13" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
