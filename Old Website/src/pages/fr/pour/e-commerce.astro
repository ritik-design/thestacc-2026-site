---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';
import { SITE_URL } from '../../../utils/schema';

const faqs = [
  {
    q: "Stacc peut-il écrire sur les produits de mon catalogue e-commerce ?",
    a: "Oui. Lors de la configuration, vous partagez vos catégories de produits, vos marques et vos mots-clés prioritaires. Stacc construit un calendrier de contenu ciblant les recherches d'intention d'achat — guides d'achat, comparaisons de produits, articles 'meilleur X pour Y' — qui captent les acheteurs en phase de décision.",
  },
  {
    q: "Comment Stacc aide-t-il mon e-commerce à se positionner face aux grandes marketplaces ?",
    a: "Les grandes marketplaces dominent les pages de produits génériques. Mais elles ne publient pas de guides d'achat détaillés, de comparaisons approfondies ou de contenu 'comment utiliser' spécifique à votre niche. Ce contenu informatif est votre avantage concurrentiel — Stacc le crée et le publie automatiquement.",
  },
  {
    q: "Quel type de contenu Stacc publie-t-il pour l'e-commerce ?",
    a: "Guides d'achat ('meilleure cafetière pour usage professionnel'), comparaisons de produits, articles 'comment choisir', contenu saisonnier, guides cadeaux, et contenu ciblant les mots-clés de niche longue traîne que vos acheteurs utilisent vraiment.",
  },
  {
    q: "Le contenu Stacc sera-t-il différent du contenu dupliqué des fabricants ?",
    a: "Absolument. Stacc génère du contenu original basé sur l'intention de recherche et les spécificités de votre boutique. Aucun contenu de description produit copié. Chaque article est unique et optimisé pour un mot-clé et une intention spécifiques.",
  },
  {
    q: "Combien de temps pour voir des résultats SEO pour mon e-commerce ?",
    a: "Les e-commerces voient généralement les premières positions pour des mots-clés longue traîne dans les 2 à 4 mois. Les mots-clés plus compétitifs prennent 4 à 8 mois. L'effet cumulatif de 30 articles par mois produit des résultats exponentiels — chaque article renforce les autres.",
  },
  {
    q: "Quels CMS e-commerce Stacc prend-il en charge ?",
    a: "Shopify, WooCommerce, Magento, BigCommerce, PrestaShop et les plateformes personnalisées. Si votre CMS accepte du contenu via API ou publication planifiée, nous le supportons. La configuration prend moins de 10 minutes.",
  },
  {
    q: "Le contenu Stacc peut-il générer des ventes directes ?",
    a: "Les articles de blog ne remplacent pas les pages produits, mais ils nourrissent le pipeline. Un acheteur qui lit votre guide 'comment choisir un robot de cuisine' et clique sur vos liens internes vers vos produits a une intention d'achat élevée et un taux de conversion significativement plus élevé que le trafic publicité.",
  },
];

const pageUrl = `${SITE_URL}/fr/pour/e-commerce/`;
const enUrl = `${SITE_URL}/for/ecommerce/`;
---

<BaseLayout
  title="SEO pour E-commerce | Contenu qui attire des acheteurs et génère des ventes | theStacc"
  description="Stacc publie 30 articles SEO sur votre boutique en ligne chaque mois — guides d'achat, comparaisons de produits et contenu de niche qui attirent des acheteurs qualifiés. 99 €/mois."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="mx-auto max-w-[1320px] px-6 relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO E-commerce · Propulsé par Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            30 articles SEO qui attirent des acheteurs sur votre boutique.<br />
            <span style="color:#4f39f6;">Publiés chaque mois.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Les acheteurs en ligne cherchent des guides, des comparaisons et des avis avant d'acheter. Les boutiques qui publient du contenu SEO ciblant ces recherches capturent du trafic qualifié que les marketplaces ne peuvent pas toucher.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 €
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#comment-ca-marche" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Comment ça marche
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Remboursement 30 jours · Sans engagement · 30 articles publiés par mois
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '30',   label: 'Articles SEO publiés par mois' },
              { value: '49%',  label: 'Des acheteurs commencent par une recherche Google' },
              { value: '3 ans', label: 'Durée de vie moyenne d\'un article en position' },
              { value: '99 €', label: 'par mois, entièrement géré' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="mx-auto max-w-[1320px] px-6 py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que Stacc fait pour l'e-commerce</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Du contenu SEO e-commerce qui attire des acheteurs prêts à convertir.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Guides d\'achat', body: 'Articles "meilleur X pour Y" ciblant les acheteurs en phase de décision. Guides comparatifs qui positionnent vos produits comme la solution évidente.' },
            { title: 'Contenu longue traîne', body: 'Mots-clés très spécifiques avec forte intention d\'achat — les recherches que font vraiment vos acheteurs mais que les grandes marketplaces ignorent.' },
            { title: 'Comparaisons de produits', body: 'Articles "produit A vs produit B" qui captent les recherches de comparaison et guident les acheteurs vers vos produits avec des CTAs intégrés.' },
            { title: 'Contenu saisonnier', body: 'Guides cadeaux, contenu promotionnel saisonnier et articles de tendances publiés avant les pics de recherche pour un impact maximal.' },
            { title: 'Contenu "comment utiliser"', body: 'Articles pratiques qui éduquent les acheteurs potentiels et réduisent les retours en établissant des attentes claires sur vos produits.' },
            { title: 'Liens internes stratégiques', body: 'Chaque article contient des liens internes optimisés vers vos pages produits et catégories — transférant l\'autorité SEO là où ça compte.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <p class="font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COMMENT ÇA MARCHE -->
    <section id="comment-ca-marche" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="mx-auto max-w-[1320px] px-6 py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça marche</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connectez votre boutique. Stacc publie 30 articles par mois.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            {[
              { num: '01', title: 'Connectez votre CMS et partagez vos catégories', body: 'Stacc analyse vos catégories de produits, vos mots-clés actuels et les lacunes concurrentielles — les recherches d\'intention d\'achat que font vos clients mais que vous ne captez pas encore.' },
              { num: '02', title: 'L\'IA crée 30 articles ciblés par mois', body: 'Chaque article cible une intention d\'achat spécifique — guide d\'achat, comparaison, contenu "comment choisir". Tous formatés pour le classement et avec des liens internes vers vos produits.' },
              { num: '03', title: 'Articles publiés. Trafic qualifié. Ventes organiques.', body: '30 articles sont mis en ligne chaque mois. Votre boutique apparaît sur les recherches que font vos acheteurs idéaux. Le trafic organique qualifié augmente. Les ventes suivent.' },
            ].map(step => (
              <div class="bg-white px-8 py-10">
                <div class="mb-6 flex items-center justify-between">
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{step.num}</span>
                </div>
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{step.title}</p>
                <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{step.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="mx-auto max-w-[1320px] px-6 py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Questions des boutiques e-commerce avant de commencer
          </h2>
        </div>

        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.08) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="mx-auto max-w-[1320px] px-6 relative">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">
            Votre concurrent capte vos acheteurs avec du contenu.<br class="hidden md:block" />
            <span style="color:#818cf8;">Votre boutique le peut aussi.</span>
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            30 articles SEO e-commerce publiés sur votre boutique chaque mois. Guides d'achat, comparaisons, contenu de niche. Pour 99 €.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Commencer pour 1 €
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/tarifs/" class="inline-flex h-12 items-center gap-2 rounded-xl border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff] bg-white">
              Voir les tarifs
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
