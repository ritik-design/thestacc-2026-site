---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';
import { SITE_URL } from '../../../utils/schema';

const faqs = [
  {
    q: "Quel type de contenu Stacc publie-t-il pour les entreprises SaaS ?",
    a: "Stacc publie des articles ciblant toutes les étapes de l'entonnoir SaaS — contenu de prise de conscience ('comment améliorer la rétention client'), contenu de comparaison ('alternative à [concurrent]', '[votre produit] vs [concurrent]'), et contenu à haute intention ('meilleur logiciel de [catégorie] pour [ICP]'). Également des guides pratiques, des cas d'utilisation et des articles de thought leadership.",
  },
  {
    q: "Comment Stacc sait-il quels mots-clés cibler pour mon SaaS ?",
    a: "Lors de la configuration, Stacc analyse votre site, vos concurrents et votre ICP. Il identifie les mots-clés que vos concurrents obtiennent et que vous n'avez pas — les recherches que font vos clients idéaux à chaque étape de leur parcours d'achat. Le calendrier de contenu est construit pour combler ces lacunes en priorité.",
  },
  {
    q: "Les articles de Stacc seront-ils appropriés pour une audience technique ?",
    a: "Oui. Lors de la configuration, vous définissez votre ICP — développeurs, équipes marketing, ops, finance — et Stacc calibre le niveau de technicité, le vocabulaire et les angles de contenu en conséquence. Le contenu SaaS Stacc n'est pas générique : il correspond à la sophistication de vos acheteurs.",
  },
  {
    q: "Stacc peut-il cibler plusieurs segments de clients pour mon SaaS ?",
    a: "Oui. Si votre SaaS sert plusieurs segments — PME et grandes entreprises, par exemple — Stacc peut créer du contenu ciblant chaque segment simultanément, avec un mélange de sujets et de niveaux de sophistication adaptés à chaque ICP.",
  },
  {
    q: "Combien de temps pour voir des résultats SEO pour mon SaaS ?",
    a: "Les SaaS voient généralement les premières positions pour des mots-clés longue traîne et de comparaison dans les 3 à 5 mois. Les mots-clés de catégorie compétitifs prennent 6 à 12 mois. La clé est la constance — 30 articles par mois crée un effet cumulatif que les publications sporadiques ne peuvent pas reproduire.",
  },
  {
    q: "Stacc peut-il écrire des articles de comparaison '[mon produit] vs [concurrent]' ?",
    a: "Oui, et ce sont souvent les articles les plus performants pour les SaaS. Ces recherches captent des prospects en fin d'entonnoir qui ont déjà décidé d'acheter une solution et évaluent leurs options. Stacc peut créer du contenu de comparaison équitable mais favorable qui convertit.",
  },
];

const pageUrl = `${SITE_URL}/fr/pour/saas/`;
const enUrl = `${SITE_URL}/for/saas/`;
---

<BaseLayout
  title="SEO pour SaaS | Contenu qui génère du trafic pipeline et des trials | theStacc"
  description="Stacc publie 30 articles SEO sur votre site SaaS chaque mois — comparaisons de concurrents, contenu de cas d'utilisation et articles à haute intention qui génèrent des trials organiques. 99 €/mois."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="mx-auto max-w-[1320px] px-6 relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO SaaS · Propulsé par Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            30 articles SEO qui génèrent du pipeline SaaS.<br />
            <span style="color:#4f39f6;">Publiés chaque mois.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Les acheteurs SaaS cherchent sur Google avant de commencer un trial. Les entreprises SaaS qui publient du contenu ciblant chaque étape de l'entonnoir — de la prise de conscience à la comparaison — capturent un pipeline organique que les publicités ne peuvent pas reproduire à ce coût.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 €
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#comment-ca-marche" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Comment ça marche
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Remboursement 30 jours · Sans engagement · 30 articles publiés par mois
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '30',   label: 'Articles SEO publiés par mois' },
              { value: '75%',  label: 'Des acheteurs SaaS recherchent en ligne avant un trial' },
              { value: '6×',   label: 'Plus de contenu qu\'un SaaS moyen' },
              { value: '99 €', label: 'par mois, entièrement géré' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="mx-auto max-w-[1320px] px-6 py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que Stacc fait pour les SaaS</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Du contenu SEO SaaS pour chaque étape de l'entonnoir.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Contenu de prise de conscience', body: 'Articles ciblant les problèmes que résout votre SaaS — avant que vos acheteurs ne connaissent votre solution. Capturez-les en phase de recherche et nurturez-les vers le trial.' },
            { title: 'Articles de comparaison', body: '"Meilleure alternative à [concurrent]", "[votre produit] vs [concurrent]" — ces recherches captent des acheteurs en fin d\'entonnoir qui veulent changer de solution.' },
            { title: 'Contenu de cas d\'utilisation', body: 'Articles montrant comment votre SaaS résout des problèmes spécifiques pour des profils spécifiques — "comment [ICP] utilise [votre produit] pour [résultat]".' },
            { title: 'Guides de catégorie', body: '"Meilleur logiciel de [catégorie] pour [segment]" — positionnez-vous sur les recherches de catégorie que font les acheteurs en haut d\'entonnoir qui comparent des solutions.' },
            { title: 'Contenu d\'intégration', body: 'Articles ciblant les intégrations clés de votre écosystème — capturez le trafic des utilisateurs d\'outils complémentaires qui cherchent une solution qui s\'intègre à leur stack.' },
            { title: 'Thought leadership produit', body: 'Articles qui positionnent votre équipe comme des experts de votre domaine — construisant la confiance et l\'autorité qui convertissent les prospects à forte valeur.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <p class="font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- COMMENT ÇA MARCHE -->
    <section id="comment-ca-marche" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="mx-auto max-w-[1320px] px-6 py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça marche</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connectez votre CMS. Stacc publie 30 articles SaaS par mois.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            {[
              { num: '01', title: 'Définissez votre ICP et vos concurrents clés', body: 'Stacc analyse votre positionnement, votre ICP et vos lacunes concurrentielles — les recherches que font vos acheteurs idéaux à chaque étape de leur parcours d\'achat.' },
              { num: '02', title: 'L\'IA crée 30 articles ciblés par mois', body: 'Contenu de prise de conscience, comparaisons, cas d\'utilisation, guides de catégorie. Chaque article cible un mot-clé et une étape de l\'entonnoir spécifiques. Formaté pour le classement.' },
              { num: '03', title: 'Pipeline organique. Trials organiques. CAC réduit.', body: '30 articles publiés chaque mois. Votre SaaS apparaît sur les recherches que font vos ICP avant de commencer un trial. Le trafic qualifié augmente. Le coût d\'acquisition diminue.' },
            ].map(step => (
              <div class="bg-white px-8 py-10">
                <div class="mb-6 flex items-center justify-between">
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{step.num}</span>
                </div>
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{step.title}</p>
                <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{step.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="mx-auto max-w-[1320px] px-6 py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Questions des équipes SaaS avant de commencer
          </h2>
        </div>

        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.08) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="mx-auto max-w-[1320px] px-6 relative">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">
            Votre concurrent SaaS construit un moat SEO.<br class="hidden md:block" />
            <span style="color:#818cf8;">Rattrapez-le avec 30 articles/mois.</span>
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            30 articles SEO SaaS publiés sur votre site chaque mois. Comparaisons, cas d'utilisation, guides de catégorie. Pour 99 €.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Commencer pour 1 €
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/tarifs/" class="inline-flex h-12 items-center gap-2 rounded-xl border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff] bg-white">
              Voir les tarifs
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
