---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Comment fonctionne le classement sur Google Maps ?", a: "L'algorithme de Google Maps évalue trois facteurs principaux : la pertinence (dans quelle mesure votre profil correspond à la recherche), la distance (votre proximité avec l'internaute) et la notoriété (la réputation et l'activité en ligne de votre entreprise). La pertinence et la notoriété sont celles sur lesquelles vous pouvez travailler concrètement — avec des posts GBP réguliers, des citations cohérentes et des avis actifs." },
  { q: "Quels signaux améliorent le classement sur Google Maps ?", a: "Les signaux principaux sont : activité constante du profil GBP (posts réguliers, mise à jour des attributs), cohérence NAP (Nom, Adresse, Téléphone) sur tous les annuaires, volume et qualité des avis avec réponse active, précision des catégories et descriptions du profil. Stacc automatise tous ces signaux continus." },
  { q: "La publication sur GBP améliore-t-elle vraiment le classement sur Maps ?", a: "Oui. Google GBP Post est l'un des signaux d'activité les plus directs pour l'algorithme Maps. Les entreprises qui publient régulièrement montrent à Google que le profil est actif et géré de manière proactive. Stacc publie 30 posts par mois par établissement — environ un par jour — optimisés pour les combinaisons service + ville. L'effet est cumulatif dans le temps." },
  { q: "Combien de temps faut-il pour voir des améliorations de classement ?", a: "La plupart des entreprises voient les premiers mouvements de classement dans les 30-60 jours suivant le début d'une activité constante sur GBP et la correction des citations. L'impact complet se voit typiquement dans les 90 jours. La clé est la cohérence quotidienne — que l'automatisation garantit précisément." },
  { q: "Les citations influencent-elles le classement sur Maps ?", a: "De manière significative. Des citations incohérentes (NAP différent selon les annuaires) envoient des signaux contradictoires à Google sur les informations de l'entreprise. Cela fait baisser le score de notoriété et la confiance dans le profil. Stacc surveille la cohérence NAP sur 50+ annuaires et signale ou corrige automatiquement les incohérences." },
  { q: "Stacc peut-il améliorer le classement pour plusieurs établissements simultanément ?", a: "Oui. Stacc automatise les signaux de classement pour chaque établissement indépendamment — posts GBP, surveillance des citations, alertes avis — tous en exécution simultanée. Vous pouvez gérer 1 ou 500 établissements avec le même effort : vous configurez une fois et Stacc exécute pour tous." },
  { q: "Combien coûte-t-il ?", a: "Le module SEO local de Stacc, qui inclut toutes les fonctionnalités d'optimisation pour Google Maps, commence à 49 $/mois par établissement." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Classement Google Maps",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automatisez les signaux qui améliorent votre classement sur Google Maps. Automatisation GBP, citations, avis et suivi de positions — tous les signaux qui comptent, exécutés chaque jour.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Classement Google Maps", "item": "https://thestacc.com/fr/classement-google-maps/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Classement Google Maps — Automatisez les Signaux qui Améliorent votre Position | theStacc"
  description="Automatisez les signaux qui améliorent votre classement sur Google Maps. theStacc gère GBP, citations, avis et suivi de positions pour augmenter votre visibilité locale."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Classement Google Maps · Dès 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Automatisez les signaux qui améliorent<br />
            <span style="color:#4f39f6;">votre classement sur Google Maps.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Google Maps récompense la pertinence et la notoriété. Stacc automatise les signaux qui les améliorent — posts GBP quotidiens, citations cohérentes, surveillance des avis et suivi de positions — pour que chaque établissement envoie les bons signaux chaque jour.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Comment ça fonctionne
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte bancaire · Résiliez quand vous voulez
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ entreprises et agences</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1 200+ établissements gérés</span>
          </div>
        </div>
      </div>
    </section>


    <!-- NARRATIF -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment fonctionne le classement sur Google Maps</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Trois facteurs déterminent où vous apparaissez<br />sur Maps. Deux sont automatisables.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Google évalue trois facteurs pour le local pack et Maps : <strong class="text-[#111827]">la pertinence</strong> (dans quelle mesure votre profil correspond à la recherche), <strong class="text-[#111827]">la distance</strong> (votre proximité avec l'internaute) et <strong class="text-[#111827]">la notoriété</strong> (votre réputation et activité en ligne). La distance n'est pas contrôlable. La pertinence et la notoriété le sont complètement.
            </p>
            <p>
              La pertinence s'améliore avec des catégories GBP précises, des mots-clés dans les posts et les descriptions, et des posts qui couvrent les services et zones géographiques pertinents. La notoriété s'améliore avec l'activité constante du profil, les avis, les citations cohérentes et les backlinks. Rien de tout cela n'est une intervention unique — tout nécessite un travail continu chaque jour.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc automatise exactement ce travail continu. 30 posts par mois optimisés pour la pertinence, surveillance des citations sur 50+ annuaires pour la notoriété, alertes avis pour maintenir un profil actif. Chaque signal envoyé chaque jour sans intervention manuelle.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- CE QUE FAIT STACC — FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que fait Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tous les signaux Maps automatisés.<br />Chaque jour, sans effort.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi du classement Google Maps', body: 'Positions dans le Local Pack mises à jour quotidiennement. Suivez chaque mouvement et identifiez immédiatement les opportunités ou les baisses.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Automatisation des posts GBP', body: '30 posts/mois améliorent l\'engagement et les signaux Maps. Chaque post optimisé pour les combinaisons service + ville.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Cohérence des citations', body: 'NAP cohérent dans 50+ annuaires renforce la confiance Google. Surveillance continue et corrections automatiques.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Volume d\'avis', body: 'Plus d\'avis, plus vite — liens directs vers la page d\'avis. Les avis récents et les réponses actives renforcent votre notoriété Maps.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Suivi en grille', body: 'Analyse Maps par zone géographique autour de l\'établissement. Visualisez où vous êtes fort et où vous perdez des positions.' },
            { icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', title: 'Alertes de positionnement', body: 'Notification immédiate lors de changements significatifs de position. Réagissez rapidement aux baisses avant qu\'elles n\'impactent votre trafic.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Signaux automatisés pour Maps</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque signal de classement Maps<br />automatisé chaque jour.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: '30 posts GBP par mois', body: 'Posts optimisés pour service + ville, publiés automatiquement chaque jour. Profil toujours actif = signal positif pour l\'algorithme Maps.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Surveillance des citations', body: 'Citations NAP cohérentes sur 50+ annuaires renforcent la notoriété sur Maps. Stacc surveille et signale les incohérences automatiquement.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Surveillance des avis', body: 'Des avis fréquents avec réponse rapide sont un signal de notoriété. Alertes en temps réel pour chaque nouvel avis sur chaque plateforme.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positions quotidien', body: 'Surveillez votre position dans le local pack et sur Maps chaque jour. Voyez comment les classements évoluent dans le temps et identifiez immédiatement les baisses ou améliorations.' },
            { icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', title: 'Protection contre les modifications non autorisées', body: 'N\'importe qui peut suggérer des modifications à votre profil GBP. Stacc détecte immédiatement les modifications non autorisées sur l\'adresse, les horaires ou la catégorie.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Analyse des tendances', body: 'Graphiques historiques du positionnement sur Maps dans le temps. Identifiez l\'impact des activités SEO et les patterns saisonniers du classement local.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités en détail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Positions, signaux d'activité et citations.<br />Trois leviers Maps automatisés.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Classement chaque matin -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Suivi Quotidien des Positions</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Votre classement Maps, chaque matin
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque matin, Stacc met à jour vos positions dans le Local Pack et sur Google Maps pour tous vos mots-clés importants. Vous savez exactement où vous en êtes — sans ouvrir aucun outil. Quand une position change significativement à la hausse ou à la baisse, une alerte est déclenchée automatiquement pour que vous puissiez agir immédiatement.
              </p>
              <a href="/fr/logiciel-suivi-positions/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le suivi de positions
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Classements Maps — Aujourd'hui</p>
              {[
                { kw: 'plombier paris 15e', pos: 1, change: '+3', trend: 'up' },
                { kw: 'dépannage plomberie urgent', pos: 2, change: '+2', trend: 'up' },
                { kw: 'plombier pas cher paris', pos: 2, change: '+4', trend: 'up' },
                { kw: 'installation chauffe-eau paris', pos: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.kw}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">Local Pack · Google Maps</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Mis à jour quotidiennement · Local Pack + Maps + Organique</p>
            </div>
          </div>

          <!-- Signaux d'activité GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendrier des posts GBP — Avril 2026</p>
              <div class="grid grid-cols-7 gap-1 mb-3">
                {['L','M','M','J','V','S','D'].map(d => (
                  <div class="text-center font-mono text-[9px] text-[#79716b] pb-1">{d}</div>
                ))}
                {Array.from({length: 30}, (_, i) => i + 1).map(d => (
                  <div class={`aspect-square flex items-center justify-center rounded text-[10px] font-mono ${d <= 26 ? 'bg-[#4f39f6] text-white font-bold' : 'bg-[#f5f3ff] text-[#79716b]'}`}>
                    {d <= 26 ? '✓' : d}
                  </div>
                ))}
              </div>
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">26 posts publiés · 4 planifiés · 30/mois automatiques</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Activité GBP Continue</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
