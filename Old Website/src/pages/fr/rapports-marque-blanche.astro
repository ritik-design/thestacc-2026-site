---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce que la création de rapports marque blanche ?", a: "La création de rapports marque blanche signifie que les rapports sur les résultats SEO sont livrés à vos clients avec le logo, les couleurs et le domaine de votre agence — pas ceux de Stacc. Les clients ne voient que votre marque professionnelle, pas le logiciel que vous utilisez en coulisses." },
  { q: "Quelles données sont incluses dans les rapports ?", a: "Les rapports incluent : variations de positionnement pour tous les mots-clés suivis, nouveaux avis et note moyenne, état des citations et cohérence NAP, activité GBP (posts publiés, vues), et récapitulatif des actions effectuées sur la période. Tous les graphiques et tableaux sont brandés avec votre marque." },
  { q: "Les rapports sont-ils envoyés automatiquement ?", a: "Oui. Vous configurez le modèle une fois — métriques, logo, couleurs, fréquence (hebdomadaire ou mensuelle) — et Stacc génère et envoie les rapports automatiquement aux clients sans que votre équipe ait quoi que ce soit à faire. Zéro travail manuel de reporting chaque mois." },
  { q: "Comment apparaissent les rapports aux clients ?", a: "Les rapports arrivent par email avec votre logo en en-tête, votre domaine comme expéditeur (ex. noreply@votreagence.fr) et sont disponibles en PDF téléchargeable ou en tableau de bord interactif — le tout entièrement brandé." },
  { q: "Puis-je réviser les rapports avant qu'ils soient envoyés ?", a: "Oui. Vous pouvez configurer Stacc pour vous envoyer d'abord une copie de révision avec un délai d'approbation (ex. 24 heures) avant la livraison automatique aux clients. Ou vous pouvez régler la livraison entièrement automatique sans révision." },
  { q: "Les clients peuvent-ils avoir un tableau de bord en direct ?", a: "Oui. En plus des rapports périodiques, chaque client peut avoir accès à un tableau de bord en direct avec des données actualisées en temps réel — positions, avis, citations — le tout brandé avec votre marque." },
  { q: "Combien coûte le module ?", a: "Le module SEO local qui inclut la création de rapports marque blanche automatisée commence à 49 $/mois. Aucun frais par client pour la livraison des rapports." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Rapports Marque Blanche",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Rapports SEO marque blanche qui se génèrent et se livrent seuls. Brandés avec votre logo, envoyés automatiquement aux clients, zéro travail manuel.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Rapports Marque Blanche", "item": "https://thestacc.com/fr/rapports-marque-blanche/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Rapports Marque Blanche — Rapports SEO Qui S'Envoient Seuls. Avec Votre Marque | theStacc"
  description="Création de rapports SEO marque blanche automatisée. theStacc génère les rapports, les brande avec votre logo et les livre automatiquement aux clients — zéro heure de reporting manuel."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Rapports Marque Blanche · À partir de 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Rapports clients qui se génèrent<br />
            <span style="color:#4f39f6;">et s'envoient seuls. Avec votre marque.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            3 heures pour préparer un rapport × 15 clients = 45 heures par mois de reporting manuel. Stacc les élimine. Rapports générés, brandés avec votre logo et livrés automatiquement.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Comment ça fonctionne
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte de crédit · Résiliable à tout moment
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">0 € de coût par rapport livré</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuration &lt; 5 min</span>
          </div>
        </div>
      </div>
    </section>


    <!-- NARRATIF -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème du reporting manuel</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Le reporting est la partie la plus<br />coûteuse du SEO pour les agences.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              La plupart des agences SEO passent entre 2 et 4 heures à préparer chaque rapport client : extraire les données de plusieurs outils, les formatter dans un document, ajouter le logo, rédiger le résumé exécutif, envoyer par email. Multipliez par 15 clients et vous parlez de 30 à 60 heures par mois rien que pour le reporting. Des heures qui ne génèrent pas de valeur SEO — juste de la communication de résultats.
            </p>
            <p>
              Le problème n'est pas seulement le temps. C'est que ce processus est sujet aux erreurs : rapports en retard, données incorrectes, formatage incohérent. Chaque retard dans la livraison d'un rapport crée un doute dans l'esprit du client sur ce que l'agence fait vraiment.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc élimine entièrement cette activité. Vous configurez le modèle une fois — métriques, logo, couleurs, fréquence. Ensuite, Stacc collecte les données, formate le rapport, le brande avec votre logo et l'envoie au client automatiquement. Votre équipe ne touche plus jamais un rapport.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce qu'inclut la création de rapports marque blanche</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Des rapports qui se gèrent<br />complètement seuls.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Branding complet', body: 'Logo, couleurs, typographie et expéditeur email brandés avec la marque de votre agence. Les clients ne voient que votre marque professionnelle.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Livraison automatique programmée', body: 'Rapports envoyés hebdomadairement ou mensuellement en automatique, à la même heure. Les clients reçoivent toujours des mises à jour ponctuelles sans que vous y pensiez.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Données de positionnement', body: 'Variations de classement pour tous les mots-clés suivis — local pack, Maps et organique — visualisées avec des graphiques tendance brandés.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'État des citations et avis', body: 'Cohérence NAP sur 50+ annuaires, note moyenne des avis et nouveaux avis sur la période — tout inclus dans le rapport automatique.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Modèle personnalisable', body: 'Choisissez quelles métriques inclure, comment les ordonner et quel résumé exécutif ajouter. Modèle sauvegardé et réutilisé pour chaque client.' },
            { icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z', title: 'Tableau de bord live clients', body: 'En plus des rapports périodiques, les clients accèdent à un tableau de bord en direct avec des données actualisées en temps réel — brandé avec votre marque.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '3 h', label: 'Économisées par client chaque mois', sub: 'Par rapport au reporting manuel' },
            { value: '100%', label: 'Livraison ponctuelle garantie', sub: 'Rapports automatiques, jamais en retard' },
            { value: '0 €', label: 'Coût par livraison de rapport', sub: 'Inclus dans le module à partir de 49 $/mois' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça fonctionne</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            De la configuration unique<br />à la livraison entièrement automatique.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Configuration du modèle -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Configuration en Une Fois</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Importez votre logo. Définissez les couleurs. Configurez votre domaine. C'est fait.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                La configuration initiale de la marque blanche prend environ deux heures. Vous importez votre logo, définissez votre palette de couleurs, configurez votre domaine personnalisé et choisissez les métriques à inclure dans les rapports. À partir de là, vous n'avez plus rien à toucher. Chaque nouveau client hérite automatiquement du modèle de votre agence, avec juste ses données personnalisées.
              </p>
              <a href="/fr/seo-marque-blanche/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le SEO marque blanche complet
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Configuration marque blanche — checklist</p>
              {[
                { step: 'Logo importé', done: true },
                { step: 'Couleurs de marque définies', done: true },
                { step: 'Domaine personnalisé configuré', done: true },
                { step: 'Modèle de rapport sauvegardé', done: true },
                { step: 'Fréquence de livraison définie', done: true },
              ].map(s => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <span class="font-mono text-[12px] font-semibold text-[#059669]">✓</span>
                  <span class="font-sans text-[13px] text-[#374151]">{s.step}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Configuration complète · Durée : environ 2 heures</p>
            </div>
          </div>

          <!-- Contenu du rapport -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Votre Agence</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Rapport SEO mensuel — Mai 2026</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Envoyé</span>
              </div>
              {[
                { label: 'Classements améliorés', val: '+6 mots-clés top 3' },
                { label: 'Posts GBP publiés', val: '30 ce mois' },
                { label: 'Nouveaux avis', val: '9 · moy. 4,8 ⭐' },
                { label: 'Citations exactes', val: '100% sur 50+ annuaires' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Généré et livré automatiquement · Logo de votre agence</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Données Complètes Automatisées</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Classements, avis, citations, GBP — tout dans un rapport clair, sous votre marque.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque rapport automatique inclut les variations de classement pour tous les mots-clés suivis, le récapitulatif des nouveaux avis et de la note moyenne, l'état des citations sur 50+ annuaires et le résumé des posts GBP publiés dans le mois. Toutes les données sont agrégées depuis les différentes sources et présentées dans un format clair, avec vos graphiques brandés.
              </p>
              <a href="/fr/fonctionnalites/rapports-clients/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir la fonctionnalité rapports
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Livraison automatique -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Livraison Sans Intervention</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Le rapport part. Votre équipe n'a rien fait. Le client reçoit quelque chose de professionnel.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Les rapports sont envoyés automatiquement à la date et à l'heure que vous avez définies — hebdomadairement, mensuellement ou sur un calendrier personnalisé. Les clients reçoivent un email depuis votre domaine, avec votre logo en en-tête et un PDF téléchargeable brandé. Vous pouvez aussi activer une révision avant envoi si vous préférez valider chaque rapport d'abord.
              </p>
              <a href="/fr/solutions/agences/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir Stacc pour les agences
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Calendrier de livraison — ce mois</p>
              {[
                { client: 'Boulangerie Centrale', date: '1er mai · 09h00', status: '✓ Envoyé' },
                { client: 'Plomberie Express', date: '1er mai · 09h00', status: '✓ Envoyé' },
                { client: 'Cabinet Martin', date: '1er mai · 09h00', status: '✓ Envoyé' },
                { client: 'Auto École Durand', date: '1er mai · 09h00', status: '✓ Envoyé' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.date}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">{r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Zéro travail manuel · Tous livrés à l'heure</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- TÉMOIGNAGES -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
