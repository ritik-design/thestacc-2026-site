---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce qu'un revendeur SEO ?", a: "Devenir revendeur SEO signifie proposer des services SEO à vos clients en utilisant la plateforme Stacc — pour 49 $/mois — et facturer vos clients aux tarifs du marché (typiquement 300 à 1 500 €/mois). La marge entre votre coût et le prix que vous appliquez est le bénéfice de votre agence." },
  { q: "Comment fonctionne le modèle de revente ?", a: "Vous payez 49 $/mois par client pour la plateforme Stacc. Vous gérez la relation client, définissez la stratégie et fixez le prix que vous souhaitez. Stacc exécute le travail — automatisation GBP, suivi de positions, citations, rapports — avec votre marque. Les clients ne voient jamais Stacc." },
  { q: "Quelles marges puis-je obtenir ?", a: "Avec un coût de 49 $/mois par client et des tarifs de marché entre 300 et 1 500 €/mois pour les services SEO local, la marge brute par client est typiquement entre 85% et 97%. Une agence avec 20 clients à 500 €/mois génère 10 000 €/mois de revenus avec un coût Stacc d'environ 1 000 €/mois." },
  { q: "Les clients découvriront-ils que j'utilise Stacc ?", a: "Non. Toute la plateforme est entièrement marque blanche : tableaux de bord, rapports, emails et portail clients portent votre marque. Aucun client ne voit jamais Stacc dans son parcours." },
  { q: "Comment gérer plusieurs clients simultanément ?", a: "Stacc inclut un tableau de bord de gestion multi-clients. Vous pouvez voir tous vos clients dans un seul panneau, surveiller les performances, recevoir des alertes et gérer les tâches sans accéder à des dizaines de comptes séparés." },
  { q: "Combien de travail continu requiert chaque client ?", a: "Avec Stacc, le travail opérationnel continu par client est minimal. Les posts GBP, le suivi de positions, la gestion des citations et l'envoi de rapports sont tous automatisés. Votre équipe se concentre sur la stratégie et la relation client, pas sur l'exécution manuelle quotidienne." },
  { q: "Ai-je besoin d'experts SEO dans mon équipe ?", a: "Pas besoin d'une équipe SEO dédiée. Stacc gère l'exécution technique. Il est utile d'avoir quelqu'un qui comprend la stratégie SEO local pour bien définir les objectifs et les mots-clés pour chaque client — mais le travail opérationnel quotidien est automatisé." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Programme Revendeur SEO",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Programme revendeur SEO pour agences. Coût 49 $/mois par client, tarifs marché 300-1 500 €/mois. Plateforme entièrement marque blanche.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Revendeur SEO", "item": "https://thestacc.com/fr/revendeur-seo/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Revendeur SEO — Proposez des Services SEO Sous Votre Marque avec des Marges Élevées | theStacc"
  description="Devenez revendeur SEO avec theStacc. Coût à partir de 49 $/mois par client, tarifs marché 300-1 500 €. Plateforme entièrement marque blanche, automatisation incluse."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Programme Revendeur SEO · À partir de 49 $/mois par client</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Proposez du SEO local sous votre marque.<br />
            <span style="color:#4f39f6;">Marges jusqu'à 97%.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Coût 49 $/mois. Tarif marché 300-1 500 €/mois. Stacc exécute le travail SEO — automatisation GBP, suivi de positions, citations, rapports — avec votre marque. Vos clients ne voient que votre agence.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Comment fonctionne la revente
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte de crédit · Résiliable à tout moment
          </p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ entreprises et agences</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1 200+ établissements gérés</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ÉCONOMIE DU REVENDEUR -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">L'économie du revendeur SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            49 $ de coût. 300-1 500 €<br />de prix de vente. Le différentiel vous appartient.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Le modèle de revente SEO fonctionne parce qu'il existe un écart structurel entre le coût de la technologie et la valeur perçue par les clients finaux. Une agence paie 49 $/mois par client à Stacc. Ce même client paie typiquement entre 300 et 1 500 €/mois pour des services SEO local sur le marché. La marge — entre 85% et 97% — revient à l'agence.
            </p>
            <p>
              Mais l'avantage n'est pas uniquement financier. Il est opérationnel. Au lieu d'embaucher des spécialistes SEO pour chaque 5 à 10 clients, une agence avec Stacc peut gérer 30 à 40 clients avec une équipe bien plus réduite — parce que l'automatisation fait le travail qui nécessiterait normalement des heures d'exécution manuelle chaque semaine.
            </p>
            <p class="font-semibold text-[#111827]">
              Le résultat : vous pouvez acquérir plus de clients, les servir mieux et le faire avec une structure de coûts qui évolue sans recruter. C'est l'avantage concurrentiel du revendeur SEO moderne.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- GRILLE DE FONCTIONNALITÉS -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce qu'inclut le programme revendeur</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tout le nécessaire pour gérer<br />des clients SEO de manière scalable.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Marque blanche complète', body: 'Votre logo, votre domaine, vos couleurs — sur chaque dashboard et rapport. Aucun client ne voit jamais Stacc.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Gestion GBP pour vos clients', body: '30 posts/mois par établissement client, publiés automatiquement. Profils toujours actifs, aucun travail manuel.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positions clients', body: 'Positions quotidiennes pour tous les établissements et mots-clés de vos clients. Alertes automatiques sur les variations.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Gestion des citations', body: 'Cohérence NAP dans 50+ annuaires pour tous vos clients. Corrections automatisées et alertes sur les divergences.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Rapports automatiques', body: 'Rapports SEO mensuels marque blanche créés et livrés automatiquement. Votre équipe ne prépare plus jamais de rapports manuels.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Gestion multi-clients', body: 'Tous vos clients dans un seul dashboard avec accès individuel. Visualisez performances et alertes en un coup d\'œil.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités clés</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Votre agence. Votre marque.<br />Automatisation complète en arrière-plan.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1 : Marque blanche -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Expérience marque blanche</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Votre marque. Sur chaque écran.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque tableau de bord, rapport, email et portail client que votre client voit porte votre logo, vos couleurs et votre domaine. Stacc disparaît complètement derrière votre agence. Vos clients pensent que vous avez développé une plateforme enterprise sur mesure. En réalité, vous payez 49 $/mois et vous concentrez sur la croissance de votre portefeuille.
              </p>
              <a href="/fr/seo-marque-blanche/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Découvrir la marque blanche
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">V</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Votre Agence SEO</p>
                  <p class="font-mono text-[10px] text-[#79716b]">votre-agence.com · Dashboard client</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Marque blanche</span>
              </div>
              {[
                { label: 'Logo affiché', val: 'Votre logo uniquement' },
                { label: 'Domaine', val: 'votre-agence.com' },
                { label: 'Couleurs', val: 'Vos couleurs de marque' },
                { label: 'Branding Stacc', val: 'Invisible pour le client' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Dashboard · Rapports · Emails · Portail clients</p>
            </div>
          </div>

          <!-- Section 2 : Marges -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Modèle de marge revendeur</p>
              {[
                { client: 'Client PME', cost: '49 $/mois', price: '300 €/mois', margin: '84%' },
                { client: 'Restaurant local', cost: '49 $/mois', price: '500 €/mois', margin: '90%' },
                { client: 'Franchise (3 sites)', cost: '147 $/mois', price: '900 €/mois', margin: '84%' },
                { client: 'Réseau national', cost: '490 $/mois', price: '3 000 €/mois', margin: '84%' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">Coût Stacc : {r.cost}</p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{r.price}</p>
                    <p class="font-mono text-[11px] font-semibold text-[#059669]">Marge {r.margin}</p>
                  </div>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tarifs indicatifs · Vous fixez votre propre prix</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Flexibilité de prix revendeur</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                300–1 500 € de marge par client.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Vous définissez votre tarification. Stacc coûte 49 $/mois par client. Les prix de marché pour le SEO local tournent entre 300 et 1 500 €/mois. Le différentiel vous appartient entièrement. Une agence de 20 clients à 500 €/mois génère 10 000 €/mois de revenus avec moins de 1 000 $/mois de coût plateforme. Scalez sans augmenter vos charges opérationnelles.
              </p>
              <a href="/fr/tarifs/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir les tarifs revendeur
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3 : Scaler sans recruter -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Capacité automatisée</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Scaler sans recruter.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Avec le SEO manuel, chaque nouveau client ajoute des heures au planning de votre équipe. Avec Stacc, chaque nouveau client ajoute une ligne dans votre dashboard — l'automatisation s'en charge. Gérez 20 clients ou 200 avec la même infrastructure. Votre équipe se concentre sur l'acquisition et la relation client, pas sur la livraison opérationnelle quotidienne.
              </p>
              <a href="/fr/solutions/agences/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Stacc pour les agences
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Portefeuille clients — vue unifiée</p>
              {[
                { name: 'Boulangerie Martin', status: 'Actif', posts: '30/30', rank: '#1' },
                { name: 'Auto École Dupont', status: 'Actif', posts: '30/30', rank: '#2' },
                { name: 'Pharmacie Centrale', status: 'Actif', posts: '28/30', rank: '#1' },
                { name: 'Cabinet Dentaire Morel', status: 'Actif', posts: '30/30', rank: '#3' },
              ].map(c => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#4f39f6] text-white font-mono text-[10px] font-bold">{c.name[0]}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{c.name}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">Posts : {c.posts} · Position : {c.rank}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669] shrink-0">✓ {c.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">20 clients gérés · 1 seul dashboard · Tout automatisé</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Résultats</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Ce que les revendeurs obtiennent<br />en automatisant avec Stacc.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
