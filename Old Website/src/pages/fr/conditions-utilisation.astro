---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const sections = [
  { id: 'acceptation', num: '1', title: 'Acceptation des conditions', body: 'En accédant à theStacc ou en l\'utilisant, vous acceptez d\'être lié par ces Conditions d\'Utilisation. Si vous n\'acceptez pas toutes ces conditions, vous ne pouvez pas utiliser notre service.' },
  { id: 'service', num: '2', title: 'Description du service', body: 'theStacc fournit un service d\'automatisation SEO qui crée, optimise et publie du contenu sur les sites web des clients. Nous nous réservons le droit de modifier, suspendre ou interrompre le service à tout moment avec un préavis raisonnable.' },
  { id: 'compte', num: '3', title: 'Votre compte', body: 'Vous êtes responsable de la protection de votre mot de passe et de toutes les activités effectuées via votre compte. Informez-nous immédiatement de toute utilisation non autorisée de votre compte.' },
  { id: 'contenu', num: '4', title: 'Contenu et propriété intellectuelle', body: 'Le contenu généré par theStacc pour votre site vous appartient une fois publié. Vous accordez à theStacc une licence pour traiter et publier ce contenu dans le cadre de votre abonnement. theStacc conserve tous les droits sur son logiciel et sa technologie.' },
  { id: 'paiement', num: '5', title: 'Paiement et résiliation', body: 'Les abonnements sont facturés mensuellement. Vous pouvez annuler à tout moment. Après annulation, votre accès reste actif jusqu\'à la fin de la période de facturation en cours. Nous ne proposons pas de remboursement pour les périodes partielles, sauf dans le cadre de notre garantie de remboursement de 30 jours.' },
  { id: 'utilisation-acceptable', num: '6', title: 'Utilisation acceptable', body: 'Vous vous engagez à ne pas utiliser theStacc pour créer du contenu illégal, trompeur ou malveillant. Vous n\'utiliserez pas notre service pour spammer, violer des droits d\'auteur ou enfreindre les conditions d\'utilisation de services tiers.' },
  { id: 'limitation', num: '7', title: 'Limitation de responsabilité', body: 'theStacc ne peut être tenu responsable des dommages indirects, accessoires ou consécutifs découlant de l\'utilisation ou de l\'impossibilité d\'utiliser notre service. Notre responsabilité totale est limitée aux frais payés au cours des 3 derniers mois.' },
  { id: 'loi', num: '8', title: 'Loi applicable', body: 'Ces conditions sont régies par le droit applicable dans le pays d\'exploitation de SOLARTREK VENTURES LLP. Adresse : Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India. Pour toute question, contactez-nous via notre page Contact.' },
];
---

<BaseLayout
  title="Conditions d'Utilisation — theStacc"
  description="Conditions d'utilisation de theStacc. Lisez nos termes et conditions avant d'utiliser notre service d'automatisation SEO."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Légal · Conditions</span>
        <h1 class="mt-2 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.5rem]">Conditions d'Utilisation</h1>
        <p class="mt-2 font-mono text-[12px] text-[#79716b]">Dernière mise à jour : Avril 2026</p>
      </div>
    </section>
    <div class="min-h-screen bg-[#fafaf9]">
      <div class="container-x py-12 md:py-16">
        <div class="mx-auto max-w-3xl space-y-10">
          {sections.map(s => (
            <section id={s.id} class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">{s.num}</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">{s.title}</h2>
              </div>
              <div class="pl-9"><p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">{s.body}</p></div>
              <div class="mt-6 border-t border-[#e7e5e4]"></div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
