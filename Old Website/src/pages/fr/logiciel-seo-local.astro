---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce qu'un logiciel SEO local ?", a: "Un logiciel SEO local aide les entreprises à gérer les signaux qui déterminent leur positionnement dans la recherche locale — y compris l'activité sur Google Business Profile, les classements de mots-clés dans le local pack et sur Google Maps, la cohérence des citations dans les annuaires et les avis clients. Stacc automatise toutes ces tâches dans une seule plateforme." },
  { q: "Que fait Stacc qu'un simple suivi de positions ne fait pas ?", a: "La plupart des outils de suivi de positions ne font que ça — suivre. Stacc publie aussi sur votre Google Business Profile chaque jour, surveille les avis en temps réel, gère les citations sur 50+ annuaires et génère des rapports clients marque blanche qui se livrent seuls. C'est un système d'exploitation SEO local complet." },
  { q: "Stacc fonctionne-t-il pour les entreprises multi-sites ?", a: "Oui — la gestion multi-sites est l'une des capacités fondamentales de Stacc. Gérez tous vos établissements depuis un tableau de bord, publiez simultanément sur tous et générez des rapports individuels ou agrégés par établissement. Pas de limite pratique au nombre d'établissements." },
  { q: "Stacc est-il conçu pour les agences ou les équipes marketing internes ?", a: "Les deux. Les agences obtiennent des rapports marque blanche, la gestion multi-comptes et des portails clients brandés. Les équipes internes d'entreprises multi-sites obtiennent des outils de gestion en masse et des rapports automatiques pour les parties prenantes." },
  { q: "En quoi diffère Stacc de la gestion SEO manuelle ?", a: "Le SEO local manuel signifie accéder à des outils séparés pour les classements, GBP, citations et avis — puis créer des rapports à la main chaque mois. Stacc connecte tout dans un système automatisé. Les données circulent automatiquement. Les rapports se génèrent et s'envoient seuls." },
  { q: "Combien de temps faut-il pour configurer Stacc pour un nouvel établissement ?", a: "La plupart des configurations se font en moins de 5 minutes — établissements ajoutés, mots-clés configurés, GBP connecté et rapports automatiques programmés. Après la configuration, Stacc gère tout en continu sans intervention de votre équipe." },
  { q: "Stacc inclut-il des rapports marque blanche pour les agences ?", a: "Oui. Les rapports marque blanche — avec votre logo, couleurs de marque et domaine personnalisé — sont disponibles sur les plans Growth et Scale. Les rapports sont livrés avec votre marque. Vos clients ne voient jamais le branding Stacc." },
  { q: "Combien coûte Stacc ?", a: "Les plans commencent à 49 $/mois pour le module SEO Local, qui inclut la publication de posts GBP, le suivi de positions quotidien, la surveillance des avis et la gestion des citations. Le module Blog SEO est à 99 $/mois. Le module Réseaux Sociaux est à 49 $/mois." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Logiciel SEO Local",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "fr",
      "description": "Logiciel SEO local qui automatise la gestion GBP, le suivi de positions, la surveillance des citations, la gestion des avis et les rapports clients pour les entreprises locales et les agences.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Logiciel SEO Local", "item": "https://thestacc.com/fr/logiciel-seo-local/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Logiciel SEO Local — Automatisez le SEO Local sur Chaque Établissement | theStacc"
  description="theStacc est le logiciel SEO local qui fait le travail — pas seulement le suivi. Gestion GBP, suivi de positions, surveillance des citations et rapports automatiques en pilote automatique."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Logiciel SEO Local · À partir de 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local qui fait<br />le travail pour vous.
            <span style="color:#4f39f6;"> Pas seulement le suivi.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            La plupart des outils SEO locaux vous donnent des tableaux de bord. Stacc vous donne de l'automatisation. Google Business Profile, suivi de positions, gestion des citations, surveillance des avis et rapports marque blanche — tout fonctionne seul, sur chaque établissement.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Voir ce qui est inclus
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte de crédit · Résiliable à tout moment
          </p>

          <!-- Barre de confiance -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">1 200+ établissements gérés</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuration en moins de 5 min</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLÈME -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème avec la plupart des outils SEO locaux</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vous avez essayé les outils.<br />Vous faites encore le travail.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Peut-être avez-vous un outil de suivi de positions. Peut-être avez-vous un outil pour les citations. Peut-être avez-vous quelque chose pour les avis. Et peut-être avez-vous tout assemblé avec des feuilles de calcul et des messages Slack pour construire un rapport qui prend trois heures et ressemble à quelque chose fait en quinze minutes.
            </p>
            <p>
              C'est le secret inavoué de la plupart des logiciels SEO locaux : <strong class="text-[#111827]">ils suivent les choses. Ils ne les font pas.</strong> C'est vous qui faites encore le travail. Le logiciel vous donne juste une vue plus élégante de tout ce que vous avez à faire.
            </p>
            <p class="font-semibold text-[#111827]">
              Vos concurrents automatisent. Ils servent plus de clients, évoluent plus rapidement et semblent plus professionnels — pas parce qu'ils sont meilleurs, mais parce qu'ils ont arrêté de faire manuellement ce que le logiciel devrait faire automatiquement.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- CAPACITÉS -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que fait Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Une plateforme. Chaque levier SEO local.<br />Tout automatisé.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automatisation GBP', body: 'Publication automatique de 30 posts par mois pour chaque établissement sur Google Business Profile. Profil toujours actif = meilleurs signaux de classement.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positions quotidien', body: 'Surveillance des classements chaque jour pour chaque établissement — local pack, Maps et organique. Alertes automatiques sur les variations significatives.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Surveillance des avis', body: 'Alertes en temps réel pour chaque nouvel avis sur tous vos profils. Fil centralisé pour répondre sans accéder à de multiples comptes.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Gestion des citations', body: 'Contrôle de la cohérence NAP sur 50+ annuaires pour chaque établissement. Incohérences identifiées et corrigées automatiquement.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Rapports automatiques', body: 'Rapports générés, brandés avec votre logo et envoyés aux clients automatiquement. Zéro travail manuel de reporting.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Gestion multi-sites', body: 'Tableau de bord unifié pour tous vos établissements. Gérez les mises à jour en masse, surveillez les performances et recevez des alertes depuis un seul endroit.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '4,7×', label: "Amélioration moyenne du classement sur Maps", sub: 'Dans les 90 jours suivant une activité GBP régulière' },
            { value: '8 h', label: 'Économisées par client et par mois', sub: 'Sur les activités SEO manuelles et le reporting' },
            { value: '50+', label: 'Annuaires surveillés', sub: "Pour l'exactitude des citations — automatiquement" },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS EN PROFONDEUR -->
    <section id="fonctionnalites-detail" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités clés</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque tâche SEO local automatisée.<br />Chaque résultat visible.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Automatisation GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisation des Posts GBP</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 posts GBP par mois. Publiés automatiquement. Ciblant les recherches qui génèrent des appels.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                L'algorithme Maps de Google récompense les entreprises qui publient régulièrement avec une meilleure visibilité dans le local pack. Stacc rédige 30 posts optimisés par établissement chaque mois — ciblant vos combinaisons service + ville, l'intention "près de moi", les recherches d'urgence et les sujets saisonniers — puis les publie selon le calendrier. Votre profil reste actif chaque jour. Vous n'y touchez pas.
              </p>
              <a href="/fr/modules/seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le module SEO Local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posts GBP ce mois-ci</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 20 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Posts publiés jusqu'à présent</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">20 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:66%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">10 de plus planifiés · Tout automatisé · Zéro travail manuel</p>
            </div>
          </div>

          <!-- Suivi de positions -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Mise à jour des positions aujourd'hui</p>
              {[
                { kw: 'dentiste près de moi', pack: 1, change: '+2', trend: 'up' },
                { kw: 'dentiste urgence [ville]', pack: 2, change: '+1', trend: 'up' },
                { kw: 'blanchiment dents près de moi', pack: 3, change: '+4', trend: 'up' },
                { kw: 'implants dentaires [ville]', pack: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Mis à jour quotidiennement · Local pack + organique + Maps</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Suivi de Positions Quotidien</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Connaissez votre position — dans le local pack, sur Maps et en organique — chaque matin.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Les classements se mettent à jour quotidiennement pour chaque mot-clé suivi dans chaque établissement. Vous voyez séparément votre position en résultats organiques et dans le local 3-pack — car pour les entreprises locales, le 3-pack concentre presque tous les clics à forte intention. Les alertes se déclenchent automatiquement lorsque les classements changent significativement, vous permettant de toujours savoir avant votre client.
              </p>
              <a href="/fr/fonctionnalites/suivi-positions/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le suivi de positions en détail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Rapports White-Label -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rapports White-Label Automatisés</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Des rapports qui se construisent et s'envoient seuls. Chaque client. Chaque semaine. Sous votre marque.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Le moment où vous arrêtez de construire des rapports manuellement est le moment où vous pouvez vraiment scaler. Configurez votre template une fois par client. Stacc génère le rapport, le formate avec le branding de votre agence et le livre dans la boîte mail du client selon le calendrier. Personne dans votre équipe n'y touche. Ce n'est pas seulement un gain de temps — c'est ce qui vous permet de doubler votre portefeuille clients sans doubler vos effectifs.
              </p>
              <a href="/fr/solutions/agences/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir Stacc pour les agences
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Votre Agence</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Rapport SEO Local Hebdomadaire</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Envoyé</span>
              </div>
              {[
                { label: 'Améliorations de classement', val: '+6 mots-clés dans le top 3' },
                { label: 'Posts GBP publiés', val: '8 cette semaine' },
