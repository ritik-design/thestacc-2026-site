---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';
import { getCollection } from 'astro:content';

const enReviews = await getCollection('reviews');
const langReviews = await getCollection('reviews_fr');
const langBySlug = new Map(langReviews.map(r => [r.data.slug, r]));
const reviews = enReviews.filter(r => langBySlug.has(r.data.slug)).map(r => langBySlug.get(r.data.slug)!);
const byDate = [...reviews].sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const visibleByDate = byDate.filter(r => r.data.image);

function readTime(body: string): number {
  const words = (body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const howWeReview = [
  { icon: '💰', label: 'Prix réels', detail: 'Vérifiés sur les pages officielles' },
  { icon: '⚖️', label: 'Avantages/inconvénients honnêtes', detail: 'Même quand ça ne nous avantage pas' },
  { icon: '🏁', label: 'Verdict clair', detail: 'Pour qui c\'est, qui devrait passer' },
  { icon: '📊', label: 'Analyse des fonctions', detail: 'Comparaison côte à côte avec les alternatives' },
];
---

<BaseLayout
  title="Avis sur les Outils SEO 2026 — Notes & Verdicts Honnêtes — theStacc"
  description="Avis honnêtes et approfondis sur chaque grand outil SEO et de contenu IA. Prix réels, vrais avantages/inconvénients, vrais verdicts. Rédigés par des praticiens qui publient 30+ articles/mois."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-12 pb-12">

        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Avis</span>
          <span class="h-3 w-px bg-[#e7e5e4]"></span>
          <span class="font-mono text-[10px] text-[#79716b]">{visibleByDate.length} outils évalués</span>
        </div>

        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px]">
          Avis sur les Outils SEO
        </h1>
        <p class="mt-3 max-w-[560px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Lisez avant d'acheter. Avis honnêtes et approfondis sur chaque grand outil SEO et de contenu IA. Prix réels, vrais avantages et inconvénients, vrais verdicts. Rédigés par des praticiens.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {[
            `${visibleByDate.length} outils évalués`,
            'Mis à jour mars 2026',
            'Verdicts réels',
            'Concurrent déclaré (transparent)',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>

      </div>
    </section>

    <!-- COMMENT NOUS ÉVALUONS -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x">
        <div class="flex items-center gap-6 overflow-x-auto py-4">
          {howWeReview.map(item => (
            <div class="flex shrink-0 items-center gap-2.5">
              <span class="text-[16px]">{item.icon}</span>
              <div>
                <p class="font-mono text-[11px] font-bold text-[#292524]">{item.label}</p>
                <p class="font-mono text-[10px] text-[#79716b]">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- GRILLE CARTES -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-6xl">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="font-sans text-[20px] font-bold text-[#111827]">Tous les Avis</h2>
          <a href="/reviews/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6] transition-opacity hover:opacity-70">
            Version anglaise →
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {visibleByDate.map((review) => (
            <a href={`/fr/avis/${review.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
              <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center gap-2">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Avis</span>
                  <span class="ml-auto flex items-center gap-0.5">
                    {[1,2,3,4,5].map(s => (
                      <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill={s <= 4 ? '#f59e0b' : 'none'} stroke="#f59e0b" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    ))}
                  </span>
                </div>
                <h2 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{review.data.title}</h2>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{review.data.description}</p>
                <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                  <span class="font-mono text-[10px] text-[#79716b]">{review.data.date} · {readTime(review.body ?? '')} min</span>
                  <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#818cf8]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Passez à la vitesse supérieure. Obtenez le trafic.
        </h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          theStacc publie 30 articles SEO sur votre site chaque mois. Automatiquement. Aucun rédacteur. Aucun workflow.
        </p>
        <a
          href="/fr/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Essayer pour 1 $
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">1 $ pour 30 jours · Annulez quand vous voulez</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
