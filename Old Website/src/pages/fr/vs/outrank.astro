---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';
import CompareOutrank from '../../../components/compare/CompareOutrank.astro';
import { SITE_URL, organizationSchema, publisherRef, authorRef, websiteSchema, buildBreadcrumbs } from '../../../utils/schema';

const pageUrl = `${SITE_URL}/fr/vs/outrank/`;
const enUrl = `${SITE_URL}/compare/outrank/`;

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      '@id': `${pageUrl}#article`,
      headline: 'theStacc vs Outrank.so — Comparaison complète',
      description: 'Comparaison côte à côte de theStacc et Outrank.so : fonctionnalités, tarifs, SEO local, qualité du contenu et support.',
      url: pageUrl,
      author: authorRef,
      publisher: publisherRef,
      mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
      articleSection: 'Comparaisons',
      inLanguage: 'fr',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(pageUrl, [
      { name: 'Accueil', url: `${SITE_URL}/fr/` },
      { name: 'Comparatifs', url: `${SITE_URL}/fr/vs/` },
      { name: 'theStacc vs Outrank', url: pageUrl },
    ]),
    organizationSchema,
    websiteSchema,
  ],
};
---

<BaseLayout
  title="theStacc vs Outrank.so — Comparaison complète | theStacc"
  description="Comparaison côte à côte de theStacc et Outrank.so : fonctionnalités, tarifs, SEO local, qualité du contenu et support."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <!-- Breadcrumb -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="mx-auto max-w-[1320px] px-6 py-3">
        <nav class="flex items-center gap-1.5" aria-label="Fil d'Ariane">
          <a href="/fr/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#79716b] transition-colors hover:text-[#4f39f6]">Accueil</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#d6d3d1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <a href="/fr/vs/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#79716b] transition-colors hover:text-[#4f39f6]">Comparatifs</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#d6d3d1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6]">theStacc vs Outrank</span>
          <span class="ml-auto font-mono text-[11px] text-[#79716b]">
            <a href={enUrl} class="hover:text-[#4f39f6] transition-colors">Version anglaise →</a>
          </span>
        </nav>
      </div>
    </div>

    <CompareOutrank />

    <!-- FOOTER CTA -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.06) 0%, transparent 65%);"></div>
      <div class="mx-auto max-w-[1320px] px-6 relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524]">
          Fini de comparer. Il est temps de publier.
        </h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          theStacc rédige, optimise et publie 30 articles SEO sur votre site chaque mois. Automatiquement.
        </p>
        <a href="/fr/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">
          Voir la démo
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#79716b]">1 $ pour 30 jours · Annulez à tout moment</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
