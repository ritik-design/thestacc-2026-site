---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Pourquoi faut-il un logiciel pour gérer Google Business Profile ?", a: "La gestion manuelle du GBP n'est pas extensible. Publier régulièrement, répondre aux avis en temps réel, surveiller les modifications non autorisées, mettre à jour les informations sur plusieurs établissements et produire des rapports réguliers prennent des heures chaque semaine. Un logiciel automatise ces tâches pour que les profils restent actifs et optimisés sans travail manuel continu." },
  { q: "Combien de posts GBP Stacc publie-t-il chaque mois ?", a: "Stacc publie 30 posts par établissement par mois — environ un par jour. Les posts sont optimisés pour les combinaisons service + ville de l'établissement, les sujets saisonniers et les recherches à forte intention. Ils sont publiés automatiquement selon un calendrier sans que personne n'ait à se connecter manuellement au profil." },
  { q: "Stacc surveille-t-il les modifications non autorisées du GBP ?", a: "Oui. Stacc surveille en continu votre GBP pour détecter les modifications non autorisées — n'importe qui (y compris les utilisateurs Google) peut suggérer des modifications à un profil GBP. Quand une modification non autorisée est détectée sur l'adresse, le nom, les horaires ou la catégorie, vous recevez une alerte immédiate." },
  { q: "Puis-je gérer le GBP pour plusieurs établissements simultanément ?", a: "Oui. Stacc est conçu pour la gestion multi-établissements. Vous pouvez publier des posts sur tous les établissements simultanément, mettre à jour les horaires et attributs en masse et voir les performances de tous les établissements dans un tableau de bord unifié." },
  { q: "Comment la surveillance des avis est-elle gérée ?", a: "Stacc surveille votre profil GBP en temps réel et envoie des alertes immédiates quand un nouvel avis arrive. Vous pouvez répondre directement depuis le tableau de bord Stacc sans avoir à vous connecter à Google. Pour les agences, le flux centralisé affiche les avis de tous les clients en un seul endroit." },
  { q: "Le logiciel GBP est-il inclus dans le prix de base ?", a: "Oui. Toute la gestion GBP — 30 posts par mois, surveillance des avis, détection des modifications non autorisées, mises à jour en masse et suivi des performances — est incluse dans le module SEO local à 49 $/mois." },
  { q: "Combien coûte-t-il ?", a: "Le module SEO local de Stacc, qui inclut la gestion complète du GBP, commence à 49 $/mois. Il comprend l'automatisation GBP pour chaque établissement, la surveillance des avis, le suivi de positions et la génération automatique de rapports." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Logiciel Google Business Profile",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Logiciel de gestion automatisée de Google Business Profile. 30 posts par mois, surveillance des avis, détection des modifications non autorisées et mises à jour en masse.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Logiciel Google Business Profile", "item": "https://thestacc.com/fr/logiciel-google-business-profile/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Logiciel Google Business Profile — GBP Géré Automatiquement | theStacc"
  description="Logiciel de gestion automatisée de Google Business Profile. theStacc publie 30 posts par mois, surveille les avis et détecte les modifications non autorisées automatiquement."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Google Business Profile · Gestion Automatique</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            GBP géré automatiquement.<br />
            <span style="color:#4f39f6;">Chaque jour. Zéro intervention manuelle.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            30 posts par mois publiés automatiquement, surveillance des avis en temps réel, détection des modifications non autorisées, mises à jour en masse sur plusieurs établissements — tout cela sans que personne n'accède manuellement au profil.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Découvrir les fonctionnalités GBP
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte bancaire · Résiliez quand vous voulez
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">30 posts/mois par établissement</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuration &lt; 5 min</span>
          </div>
        </div>
      </div>
    </section>


    <!-- NARRATIF -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pourquoi le GBP a besoin d'un logiciel</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Google récompense les profils actifs.<br />La cohérence est impossible sans automatisation.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              L'algorithme de Google Maps évalue le degré d'activité et de cohérence d'un profil GBP. Les entreprises qui publient régulièrement, répondent rapidement aux avis et maintiennent des informations à jour obtiennent de meilleures positions. Le problème, c'est que cela demande un travail quotidien — et la plupart des entreprises n'ont pas le temps ni les ressources pour le faire de manière constante, surtout sur plusieurs établissements.
            </p>
            <p>
              Le résultat typique : un profil GBP bien optimisé au moment du lancement qui se dégrade ensuite. La publication s'arrête. Les avis restent sans réponse pendant des jours. Les horaires ne sont pas mis à jour pour les jours fériés. Chaque omission est un signal négatif pour Google.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc résout ce problème en automatisant chaque tâche GBP récurrente. Le profil reste actif chaque jour — même quand votre équipe est concentrée sur d'autres priorités. Google voit de la cohérence ; les clients voient une entreprise professionnelle et présente.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités de gestion GBP</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tout ce qu'il faut pour maintenir<br />votre GBP au maximum chaque jour.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: '30 posts/mois automatiques', body: 'Un post par jour publié automatiquement sur le GBP. Optimisés pour service + ville, sujets saisonniers et recherches à forte intention locale.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Surveillance des avis', body: 'Alertes en temps réel pour chaque nouvel avis. Répondez depuis le tableau de bord Stacc sans vous connecter à Google Business Manager.' },
            { icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', title: 'Détection des modifications non autorisées', body: "Surveillance continue du profil pour détecter les modifications non autorisées de l'adresse, du nom, des horaires ou de la catégorie. Alerte immédiate à chaque modification suspecte." },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Mises à jour en masse multi-établissements', body: 'Mettez à jour les horaires, descriptions, catégories et attributs sur tous les établissements en une seule action. Aucune modification répétée établissement par établissement.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi des performances', body: 'Suivez les vues du profil, les clics vers les itinéraires, les clics vers le site et les appels téléphoniques directement depuis le tableau de bord Stacc.' },
            { icon: 'M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Gestion Q&R', body: "Surveillance des questions-réponses sur le profil GBP. Alertes pour les nouvelles questions afin de répondre rapidement et montrer de l'activité au public." },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '30', label: 'Posts GBP par mois par établissement', sub: 'Publiés automatiquement, aucun accès manuel' },
            { value: '89%', label: 'Amélioration moyenne du classement', sub: "Dans les 90 premiers jours d'activité GBP constante" },
            { value: '1 200+', label: 'Établissements gérés avec Stacc', sub: 'Agences, franchises et multi-établissements' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisation GBP en détail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Posts, avis, modifications —<br />tout géré depuis un tableau de bord.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Publication GBP automatisée</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 posts par établissement chaque mois. Ciblant les recherches qui génèrent des appels.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                L'algorithme Maps de Google récompense les entreprises qui publient régulièrement avec une meilleure visibilité dans le local pack. Stacc rédige 30 posts optimisés par mois — ciblant vos combinaisons service + ville, l'intention "près de moi", les recherches d'urgence et les sujets saisonniers — puis les publie selon le calendrier. Votre profil reste actif chaque jour. Vous n'y touchez pas.
              </p>
              <a href="/fr/logiciel-seo-local/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le module SEO local
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posts GBP ce mois-ci</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 22 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Posts publiés jusqu'ici</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">22 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:73%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">8 planifiés · Tous automatisés · Zéro travail manuel</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Boîte de réception avis — tous établissements</p>
              {[
                { biz: 'Établissement Paris 11e', stars: 5, text: 'Meilleur service, je recommande vivement !', time: 'il y a 2h', responded: false },
                { biz: 'Établissement Lyon Centre', stars: 4, text: 'Très bonne expérience, rapide et professionnel.', time: 'il y a 1j', responded: true },
                { biz: 'Établissement Bordeaux', stars: 5, text: 'Recommande fortement — réponse rapide et excellents résultats.', time: 'il y a 2j', responded: true },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center justify-between mb-1">
                    <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">{r.biz}</span>
                    <div class="flex items-center gap-2">
                      <div class="flex">{Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}</div>
                      {r.responded ? <span class="font-mono text-[9px] text-[#059669]">✓ Répondu</span> : <span class="font-mono text-[9px] text-[#f59e0b]">À répondre</span>}
                    </div>
                  </div>
                  <p class="font-sans text-[12px] text-[#57534e] truncate">"{r.text}"</p>
                  <p class="font-mono text-[10px] text-[#79716b] mt-0.5">{r.time}</p>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tous établissements · Alertes en temps réel</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Surveillance unifiée des avis</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Chaque avis de chaque établissement dans une seule boîte. Répondez sans vous connecter au GBP.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Le taux de réponse aux avis est un signal de classement Maps. Les entreprises qui répondent rapidement surpassent systématiquement celles dont les avis restent sans réponse. Stacc centralise chaque avis dans une boîte unique, envoie des alertes instantanées et vous permet de répondre directement — sans vous connecter aux comptes GBP individuels.
              </p>
              <a href="/fr/fonctionnalites/surveillance-avis/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir la surveillance des avis
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestion en masse des fiches</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Mettez à jour chaque établissement en une seule fois. Horaires, descriptions, catégories — en quelques secondes.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Toute modification qui touche l'ensemble de votre portefeuille peut être appliquée à tous les établissements simultanément. Mettez à jour les horaires des fêtes pour 40 établissements en 2 secondes. Changez votre description d'entreprise sur toutes les fiches avant un rebranding. Ajoutez une nouvelle catégorie de service sur chaque établissement en une action. Ce qui prenait des heures de navigation d'onglet en onglet prend maintenant moins d'une minute — et Stacc surveille les modifications non autorisées de tiers entre-temps.
              </p>
              <a href="/fr/logiciel-google-business-profile/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir la gestion multi-établissements
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Mise à jour en masse — horaires fériés</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Appliquer à :</p>
