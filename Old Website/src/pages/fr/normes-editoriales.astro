---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const standards = [
  {
    id: 'independence',
    num: '1',
    title: 'Indépendance éditoriale',
    body: 'Nos avis et comparatifs sont rédigés indépendamment de nos intérêts commerciaux. Lorsque nous évaluons un concurrent, nous le faisons honnêtement — y compris lorsque cela ne nous avantage pas. Nous déclarons clairement notre position de concurrent sur chaque page d\'avis et de comparaison.',
  },
  {
    id: 'accuracy',
    num: '2',
    title: 'Exactitude des données',
    body: 'Tous les prix, fonctionnalités et données de comparaison sont vérifiés directement sur les pages officielles des produits avant publication. Nous mettons à jour le contenu dès que des changements de prix ou de fonctionnalités sont détectés. Chaque page indique la date de dernière vérification.',
  },
  {
    id: 'transparency',
    num: '3',
    title: 'Transparence sur les conflits d\'intérêts',
    body: 'theStacc est un concurrent direct de nombreux outils que nous évaluons. Cette relation est déclarée dans un encadré en haut de chaque page d\'avis et de comparaison. Nous pensons que vous méritez de savoir qui écrit ce contenu.',
  },
  {
    id: 'sponsored',
    num: '4',
    title: 'Aucun contenu sponsorisé non déclaré',
    body: 'Nous n\'acceptons pas de paiement pour des classements favorables, des placements dans des listes ou des modifications de notre évaluation éditoriale. Si un article est parrainé ou contient des liens affiliés, il est clairement indiqué comme tel.',
  },
  {
    id: 'corrections',
    num: '5',
    title: 'Corrections et mises à jour',
    body: 'Si une erreur factuelle est signalée, nous l\'enquêtons dans les 48 heures et corrigeons la page si elle est justifiée. Les corrections significatives sont notées dans l\'article avec la date de modification. Contactez-nous via la page Contact pour tout problème d\'exactitude.',
  },
  {
    id: 'methodology',
    num: '6',
    title: 'Méthodologie de test',
    body: 'Les outils présents dans nos comparatifs et meilleures listes sont évalués sur la base de tests réels, de données accessibles au public et d\'informations officielles sur les produits. Nous n\'évaluons pas les outils uniquement sur la base de données marketing fournies par le vendeur.',
  },
];
---

<BaseLayout
  title="Normes Éditoriales — theStacc"
  description="Comment theStacc maintient son intégrité éditoriale dans les avis, comparatifs et meilleures listes d'outils SEO. Normes de transparence, d'exactitude et d'indépendance."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Éditorial · Normes</span>
        <h1 class="mt-2 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.5rem]">Normes Éditoriales</h1>
        <p class="mt-2 font-mono text-[12px] text-[#79716b]">Dernière mise à jour : Avril 2026</p>
      </div>
    </section>

    <!-- CONTENU -->
    <div class="min-h-screen bg-[#fafaf9]">
      <div class="container-x py-12 md:py-16">
        <div class="mx-auto max-w-3xl">
          <p class="mb-10 font-sans text-[16px] leading-[1.75] text-[#57534e]">
            theStacc publie des avis, des comparatifs et des guides sur les outils SEO. Nous sommes nous-mêmes un outil SEO concurrent. Ces normes éditoriales expliquent comment nous gérons ce conflit et maintenons l'intégrité de notre contenu.
          </p>

          <div class="space-y-8">
            {standards.map(s => (
              <section id={s.id} class="scroll-mt-6">
                <div class="flex items-center gap-3 mb-4">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">{s.num}</span>
                  <h2 class="font-sans text-[18px] font-semibold text-[#111827]">{s.title}</h2>
                </div>
                <div class="pl-9">
                  <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">{s.body}</p>
                </div>
                <div class="mt-6 border-t border-[#e7e5e4]"></div>
              </section>
            ))}
          </div>

          <div class="mt-10 rounded-xl border border-[#e7e5e4] bg-white p-6">
            <h2 class="font-sans text-[16px] font-semibold text-[#111827]">Signaler un problème d'exactitude</h2>
            <p class="mt-2 font-sans text-[14px] leading-[1.7] text-[#57534e]">
              Si vous constatez une information incorrecte ou obsolète sur l'un de nos articles, contactez-nous via la <a href="/fr/contact/" class="text-[#4f39f6] underline hover:no-underline">page Contact</a>. Nous enquêtons sur tous les signalements dans les 48 heures.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
