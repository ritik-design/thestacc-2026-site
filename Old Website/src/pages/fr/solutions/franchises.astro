---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const faqs = [
  {
    q: "Puis-je donner aux franchisés accès à leurs propres données ?",
    a: "Oui. Chaque franchisé reçoit un accès à ses propres données uniquement — ses positions, ses avis, son activité GBP. Le siège ou la tête de réseau voit toutes les données de tous les franchisés. Les permissions sont granulaires et configurables par établissement.",
  },
  {
    q: "Les franchisés peuvent-ils modifier leur propre configuration ?",
    a: "Vous définissez exactement ce que chaque franchisé peut faire. En lecture seule ou avec la possibilité d'ajouter des mots-clés locaux spécifiques à leur marché. Le contrôle reste au siège pour les paramètres de marque et les configurations critiques.",
  },
  {
    q: "Comment gérez-vous l'onboarding de nouveaux franchisés ?",
    a: "Vous créez un template de franchise une fois — mots-clés communs, paramètres GBP, fréquence des rapports. Chaque nouveau franchisé est configuré à partir de ce template en ajoutant ses informations locales spécifiques. Un nouveau franchisé est opérationnel dans Stacc en moins de 30 minutes.",
  },
  {
    q: "Peut-on maintenir une cohérence de marque tout en permettant du contenu local ?",
    a: "C'est exactement ce que Stacc est conçu pour faire. Les publications GBP suivent vos guidelines de marque (ton, hashtags, types de contenu) tout en incluant des informations locales spécifiques à chaque franchisé (ville, promotions locales, événements locaux). Cohérence nationale, pertinence locale.",
  },
  {
    q: "Stacc peut-il gérer des réseaux de plus de 100 franchisés ?",
    a: "Oui. Il n'y a pas de limite technique au nombre d'établissements. Les réseaux de 200+ établissements utilisent Stacc en production. L'interface est conçue pour être aussi utile avec 5 franchisés qu'avec 500 — vue consolidée, filtres par région ou segment, et forage dans les données individuelles.",
  },
  {
    q: "Quel est le prix pour un réseau de franchise ?",
    a: "Le prix est basé sur le nombre d'établissements actifs. Les grands réseaux bénéficient de tarifs dégressifs. Contactez-nous pour un devis personnalisé pour votre réseau.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Solution pour Franchises",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "fr",
      "description": "Stacc aide les réseaux de franchise à maintenir la cohérence SEO locale sur chaque établissement tout en donnant aux franchisés une visibilité locale. Positions, GBP, avis et citations — centralisés.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Solutions", "item": "https://thestacc.com/fr/solutions/" },
        { "@type": "ListItem", "position": 3, "name": "Franchises", "item": "https://thestacc.com/fr/solutions/franchises/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "fr",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO Local pour Franchises — Gérez le SEO de Chaque Franchisé depuis un Seul Tableau de Bord | theStacc"
  description="Stacc aide les réseaux de franchise à maintenir la cohérence SEO locale sur chaque établissement tout en donnant aux franchisés une visibilité locale. Positions, GBP, avis et citations — centralisés."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Pour les Franchises · Gestion Multi-Établissements</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            50 franchisés. 50 profils Google Business.<br />
            <span style="color:#4f39f6;">Un seul tableau de bord.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Les réseaux de franchise ont un défi unique : maintenir la cohérence de marque tout en permettant la visibilité locale de chaque franchisé. Stacc gère le SEO local de chaque établissement — positions, GBP, avis, citations — depuis un tableau de bord central avec des vues granulaires par franchisé.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Voir une démo réseau
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/tarifs/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Voir les tarifs
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            49 $/mois · Essai gratuit 14 jours · Sans carte bancaire
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '500+', label: 'Établissements dans un tableau de bord' },
              { value: 'Cohérence', label: 'SEO uniforme sur tout le réseau' },
              { value: 'Local', label: 'Visibilité individuelle par franchisé' },
              { value: '4,9★', label: 'Note moyenne Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sans système central, le SEO local<br />de votre réseau est laissé au hasard.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Certains franchisés sont rigoureux. D'autres improvident. D'autres encore ne font rien. Le résultat : une présence locale incohérente qui affaiblit la marque globale et perd des clients locaux au profit de concurrents mieux positionnés.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Chaque franchisé gère son GBP différemment. Certains ne le gèrent pas du tout.',
              body: 'Sans système central, chaque franchisé improvise sa présence locale. Certains publient régulièrement sur GBP. D\'autres n\'ont pas mis à jour leur profil depuis 2 ans. La cohérence de marque s\'effondre et certains établissements perdent des clients locaux qu\'ils auraient dû capter.',
            },
            {
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
              title: 'Une information incorrecte chez un franchisé impacte toute la marque.',
              body: 'Un mauvais numéro de téléphone, une adresse obsolète, des horaires incorrects chez un franchisé envoient des clients dans un mur. Dans certains secteurs, une seule erreur de citation peut générer des avis négatifs — qui se retrouvent associés à la marque globale.',
            },
            {
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              title: 'Auditer le SEO local de 50 établissements manuellement n\'est pas scalable.',
              body: 'Vérifier les positions, les citations, les avis et le profil GBP de chaque franchisé individuellement prend des semaines. Pendant ce temps, des problèmes se développent silencieusement chez les franchisés qui n\'ont pas le SEO comme priorité.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça fonctionne</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Configurez le réseau une fois.<br />Chaque franchisé est géré automatiquement.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', title: 'Configurez le réseau une fois', body: 'Définissez votre template de configuration de franchise — mots-clés communs, paramètres de marque, fréquence de publication GBP. Ajoutez chaque franchisé avec ses informations locales spécifiques. Configuration en batch disponible pour les grands réseaux.' },
            { n: '02', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', title: 'Chaque franchisé bénéficie d\'une présence locale automatisée', body: 'Stacc publie automatiquement sur le GBP de chaque franchisé, surveille leurs avis et suit leurs positions locales. Les franchisés peuvent avoir accès à leurs propres données. Le siège voit tout.' },
            { n: '03', icon: 'M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2', title: 'Le siège pilote le SEO du réseau depuis un seul écran', body: 'Tableau de bord global du réseau : positions moyennes, performance des avis, activité GBP. Identifiez rapidement les franchisés en difficulté et intervenez de façon ciblée avant que les problèmes s\'accumulent.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tout inclus</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Contrôle central.<br />Visibilité locale pour chaque franchisé.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Vue réseau consolidée', body: 'Toutes les métriques de tous vos franchisés sur un seul écran. Positions, avis, activité GBP et cohérence des citations — agrégés et comparables par établissement.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
            { title: 'Accès franchisé individuel', body: 'Chaque franchisé peut accéder à ses propres données SEO sans voir celles des autres. Le siège voit le réseau complet.', icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z' },
            { title: 'Cohérence NAP sur tout le réseau', body: 'Audit et correction des informations NAP sur 80+ annuaires pour chaque établissement. La marque reste cohérente sur tout le web local.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
            { title: 'Publications GBP automatiques par franchisé', body: 'Stacc publie du contenu localisé sur le GBP de chaque franchisé selon un calendrier que vous définissez. Cohérence de marque + pertinence locale.', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { title: 'Alertes par franchisé', body: 'Soyez alerté immédiatement quand un franchisé spécifique perd des positions, reçoit un avis négatif ou que son profil GBP devient inactif.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Rapports réseau et rapports individuels', body: 'Générez des rapports consolidés pour la direction du réseau et des rapports individuels pour chaque franchisé — tous automatisés, tous planifiés.', icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Résultats</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Ce que Stacc fait<br />pour les réseaux de franchise.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '500+', label: 'Établissements gérables dans un seul tableau de bord', sub: 'sans limite technique' },
            { value: '2h', label: 'Pour configurer 20 franchisés dans Stacc', sub: 'puis tout est automatisé' },
            { value: '45 min', label: 'Pour ajouter un nouveau franchisé', sub: 'à partir du deuxième établissement' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "On a 34 franchisés et la gestion SEO était notre plus grand angle mort. Certains franchisés avaient des profils GBP à jour, d'autres pas de photos depuis 2019. Avec Stacc, chaque profil est actif, chaque avis reçoit une réponse, et on voit d'un coup d'œil quels franchisés ont besoin d'aide. Le SEO local est devenu un avantage réseau, pas un fardeau."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">ND</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Nicolas D.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Directeur Marketing, Réseau de Franchise · France</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">34 franchisés · SEO cohérent</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Questions fréquentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Questions sur Stacc pour les franchises
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Pour les réseaux de franchise</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Chaque franchisé mérite d'apparaître
            <span style="color:#818cf8;"> en premier dans sa ville.</span>
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Stacc donne à chaque franchisé la présence SEO locale qu'il mérite — sans que le siège perde le contrôle de la cohérence de marque. Gérez le réseau. Laissez Stacc gérer le SEO local.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Voir une démo réseau
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/tarifs/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Voir les tarifs
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Essai gratuit 14 jours · Sans carte bancaire · Annulez quand vous voulez</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
