---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const platforms = [
  {
    name: 'Instagram',
    color: '#E1306C',
    bg: '#fdf2f7',
    iconUrl: '/icons/instagram-gradient.svg',
    path: '',
  },
  {
    name: 'LinkedIn',
    color: '#0A66C2',
    bg: '#f0f6ff',
    iconUrl: '',
    path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    name: 'X',
    color: '#000000',
    bg: '#f5f5f5',
    iconUrl: '',
    path: 'M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z',
  },
  {
    name: 'Facebook',
    color: '#1877F2',
    bg: '#f0f5ff',
    iconUrl: '',
    path: 'M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z',
  },
];

const faqs = [
  {
    q: "Les publications ressembleront-elles à du contenu IA générique ?",
    a: "Non. C'est la préoccupation la plus courante. Stacc apprend votre voix de marque, votre secteur, votre audience et vos piliers de contenu avant d'écrire la moindre publication. Le résultat est natif à chaque plateforme — les légendes Instagram ne sonnent pas comme des posts LinkedIn — spécifique à votre type d'activité et écrit dans le ton que vous définissez. Vous pouvez réviser chaque publication avant publication. La plupart de nos clients disent que les publications sont plus cohérentes que ce qu'eux-mêmes rédigeraient.",
  },
  {
    q: "Combien de publications Stacc publie-t-il par mois ?",
    a: "30+ publications par mois par défaut, réparties sur les plateformes que vous connectez. Vous contrôlez la fréquence par plateforme. Certaines entreprises publient quotidiennement sur Instagram et 3 fois par semaine sur LinkedIn. Stacc adapte le volume à n'importe quelle cadence que vous définissez. Plus de publications = plus de surface algorithmique = plus de portée.",
  },
  {
    q: "Puis-je réviser ou approuver les publications avant qu'elles soient publiées ?",
    a: "Oui. Chaque publication passe d'abord par une file de révision. Vous pouvez approuver, modifier, régénérer ou reprogrammer n'importe quoi. La plupart des clients révisent les premières semaines de publications puis activent la publication automatique une fois convaincus de la qualité. Ensuite, les publications apparaissent simplement sur vos profils selon le calendrier. Vous n'avez plus à y penser.",
  },
  {
    q: "Puis-je utiliser mes propres photos et images ?",
    a: "Oui. Vous pouvez télécharger vos propres photos et Stacc les utilisera dans les publications. Si vous n'avez pas d'images, Stacc génère des visuels IA dans le style de votre choix — Photoréaliste, Illustration plate ou Cinématographique — avec vos couleurs de marque et logo appliqués automatiquement. La plupart des entreprises utilisent une combinaison des deux.",
  },
  {
    q: "Stacc publie-t-il en français et dans d'autres langues ?",
    a: "Oui. Stacc prend en charge plus de 30 langues, dont le français, l'espagnol, le portugais, l'hindi, le japonais, l'allemand, l'arabe et plus encore. Définissez la langue de votre contenu une fois lors de la configuration et chaque publication sera générée dans cette langue. Les comptes multilingues peuvent définir des langues différentes par plateforme ou par zone géographique.",
  },
  {
    q: "En quoi c'est différent de Buffer ou Hootsuite ?",
    a: "Buffer et Hootsuite sont des outils de programmation. Ils publient le contenu que vous créez. Stacc crée le contenu ET le publie. Vous obtenez un gestionnaire de réseaux sociaux complet, pas seulement un calendrier. Pour les entreprises qui n'ont pas le temps de rédiger des publications, Stacc fait tout le travail pour 49€/mois. Le forfait Buffer le moins cher est à 18$/mois. Mais vous devez encore tout écrire vous-même.",
  },
];

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://thestacc.com/fr/modules/reseaux-sociaux/",
      "url": "https://thestacc.com/fr/modules/reseaux-sociaux/",
      "name": "Module Réseaux Sociaux | theStacc | Gestion Réseaux Sociaux IA dès 49€/mois",
      "description": "Stacc rédige et programme des publications de marque pour Instagram, LinkedIn, X et Facebook chaque jour. Automatiquement. Plus de 30 publications par mois. Commencez pour 1€.",
      "inLanguage": "fr",
      "isPartOf": { "@id": "https://thestacc.com/" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
          { "@type": "ListItem", "position": 2, "name": "Modules", "item": "https://thestacc.com/fr/modules/" },
          { "@type": "ListItem", "position": 3, "name": "Réseaux Sociaux", "item": "https://thestacc.com/fr/modules/reseaux-sociaux/" },
        ],
      },
    },
    {
      "@type": "SoftwareApplication",
      "name": "theStacc – Module Réseaux Sociaux",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "fr",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "EUR",
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock",
      }
    },
    {
      "@type": "FAQPage",
      "inLanguage": "fr",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a },
      })),
    },
  ],
};
---

<BaseLayout
  title="Module Réseaux Sociaux | theStacc | Gestion Réseaux Sociaux IA dès 49€/mois"
  description="Stacc rédige et programme des publications de marque pour Instagram, LinkedIn, X et Facebook chaque jour. Automatiquement. Plus de 30 publications par mois. Commencez pour 1€."
  lang="fr"
>
  <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} slot="head" />
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[900px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Module Réseaux Sociaux · 49 €/mois</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Vous avez publié deux fois le mois dernier.<br />
            <span style="color:#4f39f6;">Votre concurrent publie chaque jour.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            L'algorithme récompense la régularité. Les entreprises qui publient quotidiennement obtiennent plus de portée, plus d'abonnés, plus de clients. Stacc rédige et publie plus de 30 publications de marque par mois sur Instagram, LinkedIn, X et Facebook. Automatiquement, chaque jour.
          </p>

          <!-- Platform icon strip -->
          <div class="mt-7 flex flex-wrap items-center justify-center gap-2.5">
            {platforms.map((p) => (
              <div
                class="flex h-9 w-9 items-center justify-center rounded-xl"
                style={`background-color:${p.bg};`}
                title={p.name}
              >
                {p.iconUrl ? (
                  <img src={p.iconUrl} alt={p.name} width="18" height="18" />
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill={p.color} aria-label={p.name}>
                    <path d={p.path} />
                  </svg>
                )}
              </div>
            ))}
          </div>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/fr/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Commencer pour 1 € aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#comment-ca-marche"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Voir comment ça marche
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 jours satisfait ou remboursé · Sans carte bancaire · Sans engagement
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '30+',   num: 30,  prefix: '',  suffix: '+',    decimals: 0, from: 0, label: 'Publications par mois' },
              { value: '340+',  num: 340, prefix: '',  suffix: '+',    decimals: 0, from: 0, label: 'Entreprises en pilote automatique' },
              { value: '0 h',   num: 0,   prefix: '',  suffix: ' h',   decimals: 0, from: 0, label: 'De votre temps requis' },
              { value: '4',     num: 4,   prefix: '',  suffix: '',     decimals: 0, from: 0, label: 'Plateformes couvertes' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Entreprises qui développent leurs réseaux en pilote automatique</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 sur 127 avis</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Les réseaux sociaux ne sont plus optionnels.<br />Mais publier régulièrement est épuisant.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Vous publiez en rafales, puis disparaissez pendant des semaines.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">L'algorithme pénalise l'incohérence. Chaque interruption dans votre historique de publications fait chuter votre portée. Et il faut des semaines d'activité constante pour la récupérer. Des publications sporadiques, c'est presque pire que ne pas publier du tout.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Embaucher un community manager coûte au minimum 2 500 €/mois.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Un bon gestionnaire de réseaux sociaux coûte entre 2 500 € et 5 000 € par mois. Un freelance livrera des résultats incohérents et disparaîtra. Une agence réclame un contrat de 3 mois et une session de stratégie de marque avant de rédiger la moindre publication.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Vous gérez une entreprise. Vous n'avez pas 5 heures par semaine pour le contenu.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Rédiger des publications, chercher des images, redimensionner pour chaque plateforme, programmer au bon moment. Les heures s'accumulent — des heures que vous n'avez pas. Alors vous sautez. Puis vous vous sentez coupable. Puis vous publiez une fois et vous croyez être à jour. Vous ne l'êtes pas.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="comment-ca-marche" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça marche</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Configurez une fois. Les publications sortent chaque jour. Pour toujours.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sans calendrier de contenu. Sans sessions de rédaction. Sans chercher en urgence quoi publier. Parlez de votre marque à Stacc une fois et il s'occupe du reste.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Définissez votre voix de marque et connectez vos comptes</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Indiquez à Stacc votre ton, votre secteur, votre audience et vos piliers de contenu. Connectez Instagram, LinkedIn, X et Facebook via OAuth sécurisé. Cela prend environ 10 minutes. Inutile d'y retoucher.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">L'IA rédige votre plan de contenu mensuel</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30+ publications générées. Chacune adaptée à sa plateforme. Légendes Instagram avec hashtags. Contenus de leadership d'opinion sur LinkedIn. Fils de discussion sur X. Mises à jour Facebook. Avec images générées par IA dans le style de votre marque. Tout prêt à réviser avant toute publication.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
