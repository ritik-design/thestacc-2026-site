---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const faqs = [
  {
    q: "Google pénalise-t-il le contenu généré par IA ?",
    a: "Les propres directives de Google le disent clairement : ce qui compte, c'est la qualité et la pertinence, pas la façon dont le contenu a été créé. Chaque article publié par Stacc est basé sur une vraie recherche de mots-clés, écrit pour répondre à de vraies requêtes de recherche et noté selon les standards SEO avant publication. Nos clients ont publié des millions de mots sans aucune pénalité manuelle ni baisse de positionnement.",
  },
  {
    q: "Combien de temps avant de voir des résultats ?",
    a: "La plupart des clients voient un mouvement significatif dans le positionnement dans les 60 à 90 jours. Certains le voient plus tôt. Le référencement est un actif qui se compose. Chaque article que vous publiez rend le suivant plus facile à positionner. Plus tôt vous commencez, plus grand est l'avantage que vous construisez sur les concurrents qui y réfléchissent encore.",
  },
  {
    q: "Quels CMS sont supportés ?",
    a: "WordPress, Webflow et Ghost sont entièrement intégrés. Publication directe, sans plugins. Tout CMS avec support REST API ou webhooks fonctionne aussi automatiquement. Et si vous utilisez quelque chose de personnalisé, vous pouvez exporter et coller. Le contenu vous appartient toujours.",
  },
  {
    q: "Puis-je modifier les articles avant leur publication ?",
    a: "Chaque article est dans une file d'attente de révision avant publication. Modifiez, approuvez ou activez la publication automatique. La plupart des clients révisent les premiers lots, puis passent à la publication automatique quand ils constatent que la qualité est au rendez-vous. Ensuite, le contenu apparaît simplement sur leur site.",
  },
  {
    q: "Que se passe-t-il si j'annule ? Je garde mon contenu ?",
    a: "Chaque article publié sur votre site vous appartient définitivement. Annulez aujourd'hui et ces pages continueront à se positionner, générer du trafic et capter des leads. Pour toujours. Vous êtes propriétaire à 100 % de tout ce qui est publié.",
  },
  {
    q: "En quoi est-ce différent d'utiliser ChatGPT ?",
    a: "ChatGPT écrit des mots. Stacc positionne des pages. La différence réside dans la couche SEO : recherche de mots-clés calibrée pour votre vrai marché, score d'optimisation, maillage interne, balises meta, balisage Schema. Et ensuite, publication directe dans votre CMS. ChatGPT vous donne un brouillon que personne ne trouvera. Stacc vous donne une page en ligne, indexée et positionnée.",
  },
];
---

<BaseLayout
  title="Module Blog SEO | theStacc | Transformez Votre Site en Machine à Leads"
  description="Stacc publie 30 articles optimisés pour le référencement sur votre site chaque mois, automatiquement. Plus d'articles = plus de positions = plus de clients. Commencez pour 1 $."
  lang="fr"
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Module Blog SEO · 99 $/mois</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Transformez votre site en<br class="hidden md:block" />
            <span style="color:#4f39f6;">machine SEO génératrice de leads.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc publie 30 articles optimisés pour le référencement sur votre site chaque mois. Automatiquement. Plus d'articles signifie plus de positions dans les moteurs de recherche. Plus de positions signifie plus de clients qui trouvent votre entreprise, sans que vous touchiez au moindre mot.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/fr/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Voir comment ça fonctionne
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 jours de garantie · Sans carte bancaire · Chaque article publié reste pour toujours
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '12 000+', num: 12000, prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Articles publiés' },
              { value: '340+',    num: 340,   prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Entreprises locales' },
              { value: '4,9★',   num: 4.9,   prefix: '',  suffix: '★', decimals: 1, from: 0, label: 'Note moyenne' },
              { value: '0',       num: 0,     prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Pénalités de référencement' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Entreprises positionnées avec Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 sur 127 avis</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vous savez que le contenu, c'est comme on vous trouve.<br />Mais les chiffres ne s'alignent jamais.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Vous avez besoin de 30 articles. Vous en avez publié 2 l'an dernier.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Google récompense les entreprises qui apparaissent de façon cohérente. Chaque semaine où vous ne publiez pas, votre concurrent le fait. Cet écart de positionnement s'accumule. Et chaque mois que vous attendez est plus difficile à rattraper.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Les rédacteurs SEO facturent 150–400 € par article. Par article.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">30 articles par mois avec un freelance coûte 4 500–12 000 €. Une agence facture 3 500 € et écrit peut-être 6 posts. Le ROI ne fonctionne jamais. Donc vous ne commencez pas. Et ils continuent à vous surclasser.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Écrire sans stratégie SEO ne génère pas de positions.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Recherche de mots-clés, liens internes, balises meta optimisées, balisage Schema. C'est 3 heures de plus par article. Si vous sautez une partie, vous avez publié quelque chose que personne ne trouvera. Vous avez besoin du système complet, pas seulement des mots.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça fonctionne</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Configurez en 5 minutes.<br />Ça fonctionne automatiquement ensuite.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Connectez votre site une fois. Stacc cartographie vos lacunes de mots-clés, apprend votre voix de marque et commence à publier. Sans que vous leviez le petit doigt. Vous verrez le trafic bouger avant même d'y penser à deux fois.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connectez votre site web</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Entrez votre URL. Stacc analyse votre site, lit le positionnement de vos concurrents, trouve les lacunes de mots-clés qu'ils ont laissées, et construit toute votre stratégie de contenu en moins de 2 minutes.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">L'IA rédige votre plan de contenu</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 articles entièrement optimisés écrits pour cibler les vrais termes de recherche qu'utilisent vos clients. Chaque article est noté selon les standards SEO avant publication. Rien ne sort en ligne s'il ne va pas se positionner.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Les articles se publient. Vous ne faites rien.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Le contenu est publié directement sur votre WordPress, Webflow ou Ghost selon le calendrier que vous définissez. Nouveau mois, 30 nouveaux articles frais. Votre site construit de l'autorité pendant que vous gérez votre entreprise.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── WHY STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Pourquoi Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La seule option qui fait tout le travail.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Se positionner nécessite une recherche de mots-clés, une rédaction de qualité, une optimisation et une publication cohérente. Chaque mois, sans exception. Aucune autre option ne délivre les quatre sans consommer votre temps ni votre budget.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-4 bg-[#f5f3ff] px-0">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Agence</div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Freelance</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Stacc</div>
          </div>
          {[
            { label: 'Coût mensuel',                    agency: '3 500 €+',  freelancer: '1 200 €+',  stacc: '99 €'      },
            { label: 'Articles par mois',               agency: '6–8',       freelancer: '4–6',       stacc: '30'        },
            { label: 'Recherche de mots-clés',          agency: '✓',         freelancer: '✗',         stacc: '✓'         },
            { label: 'Optimisation SEO',                agency: '✓',         freelancer: 'Parfois',   stacc: '✓'         },
            { label: 'Formation à la voix de marque',   agency: 'Parfois',   freelancer: 'Parfois',   stacc: '✓'         },
            { label: 'Publication automatique',         agency: '✗',         freelancer: '✗',         stacc: '✓'         },
            { label: 'Temps requis de votre part',      agency: 'Élevé',     freelancer: 'Moyen',     stacc: 'Aucun'     },
          ].map((row, i) => (
            <div class={`grid grid-cols-4 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.agency}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.freelancer}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.stacc}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/fr/demo/"
            class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
          >
            Commencer pour 1 $ aujourd'hui
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>


    <!-- ─── FEATURE 1: KEYWORD RESEARCH ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
          <div>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Recherche de mots-clés</span>
            <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.1rem]">
              Positionnez-vous sur ce que cherchent vos clients. Avant votre concurrence.
            </h2>
            <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
