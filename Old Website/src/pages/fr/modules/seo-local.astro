---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const faqs = [
  {
    q: "Combien de temps pour se retrouver dans le top 3 de Maps ?",
    a: "La plupart des clients voient leur positionnement Maps progresser significativement dans les 60 à 90 jours. Le référencement local répond plus vite que le SEO organique parce que Google Business Profile est directement mis à jour. Des publications quotidiennes, des réponses aux avis et des optimisations de profil cumulent rapidement une autorité locale. Les résultats dépendent de la compétitivité de votre marché, mais nous voyons régulièrement des entreprises entrer dans le top 3 en 3 mois.",
  },
  {
    q: "Que se passe-t-il avec mes avis Google existants ?",
    a: "Stacc surveille tous les nouveaux avis et génère des réponses personnalisées dans les 24 heures. Nous ne supprimons ni ne modifions les anciens avis — c'est contre les conditions d'utilisation de Google. Ce que nous faisons : répondre systématiquement, ce qui signale à Google que vous êtes un propriétaire actif. Google récompense les entreprises qui s'engagent avec leurs avis par un meilleur positionnement local.",
  },
  {
    q: "Puis-je gérer plusieurs emplacements ?",
    a: "Oui. Le plan de base inclut 1 emplacement. Chaque emplacement supplémentaire coûte 150 $/mois. Chaque emplacement obtient son propre calendrier de publications GBP, sa propre gestion des avis et son propre contenu SEO local optimisé pour ses mots-clés de localisation spécifiques. Les chaînes et les prestataires de services avec plusieurs zones peuvent tout gérer depuis un tableau de bord.",
  },
  {
    q: "Mon entreprise n'a pas de vitrine physique. Ça marche quand même ?",
    a: "Oui, pour les entreprises de type Zone de Service (ZS). Les plombiers, électriciens, paysagistes et autres prestataires sans adresse physique utilisent le référencement local différemment mais peuvent quand même se positionner pour des termes 'près de moi'. Nous optimisons votre GBP pour le service par zone et ciblons des mots-clés de localisation dans le contenu publié sur votre site.",
  },
  {
    q: "Qu'est-ce que Google publie réellement sur mon profil ?",
    a: "Stacc publie des mises à jour Google Business Profile (les 'Google Posts') — de courtes publications texte avec image qui apparaissent sur votre profil et dans les résultats de recherche locale. Elles restent visibles 7 jours avant de pivoter. Google Posts sont l'un des signaux de classement local les plus négligés. La plupart des entreprises n'en publient jamais. Vous en aurez 30 par mois.",
  },
  {
    q: "Et si je n'ai pas encore de profil Google Business ?",
    a: "Nous vous guidons dans la création et la vérification. La vérification prend généralement 1 à 2 semaines selon la méthode. Une fois vérifiée, Stacc prend le contrôle et commence à optimiser et publier immédiatement.",
  },
];
---

<BaseLayout
  title="Module Référencement Local | theStacc | Dominez Google Maps dans Votre Ville"
  description="Stacc publie 30 Google Business Posts par mois, gère vos avis et optimise votre présence locale pour que vous dominiez Maps. Commencez pour 49 €/mois."
  lang="fr"
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Module Référencement Local · 49 €/mois</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Votre concurrent apparaît en premier<br class="hidden md:block" />
            <span style="color:#4f39f6;">sur Maps. Pas vous. Changeons ça.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc publie 30 Google Business Posts par mois, répond à tous vos avis en 24 heures et optimise votre profil local pour le référencement. Automatiquement. Le résultat : votre entreprise dans le top 3 de Maps pour les recherches qui comptent.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/fr/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Voir comment ça fonctionne
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 jours de garantie · Sans carte bancaire · Annulez quand vous voulez
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '30/mois',  label: 'Google Posts publiés' },
              { value: '<24h',     label: 'Réponse aux avis' },
              { value: '340+',     label: 'Entreprises locales' },
              { value: 'Top 3',    label: 'Maps en 90 jours en moyenne' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Entreprises locales positionnées avec Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 sur 127 avis</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Google Maps envoie vos clients chez<br />votre concurrent. Pas chez vous.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Quand quelqu'un recherche "dentiste près de moi" ou "plombier d'urgence Paris", les trois premières entreprises qui apparaissent obtiennent 80 % des clics. Si vous n'êtes pas dans ce top 3, vous êtes invisible. Et vos concurrents prennent chaque client qui cherche ce que vous faites.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">80 % des clics vont aux 3 premiers résultats Maps.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Si vous êtes en position 4 ou plus bas, vous existez à peine. Les entreprises en position 1–3 obtiennent l'appel, la réservation, le client. Le reste attend. Chaque jour passé hors du top 3 est de l'argent qui va ailleurs.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Les avis sans réponse font fuir les clients.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">87 % des consommateurs lisent les avis avant de choisir une entreprise locale. Un avis sans réponse — surtout un avis négatif — envoie un signal : personne n'est aux commandes. Les entreprises qui répondent à tous leurs avis voient en moyenne 35 % de conversions en plus.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Les profils inactifs sont pénalisés par l'algorithme.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Google récompense les profils actifs. Des publications régulières, de nouvelles photos, des réponses aux avis — tout ça indique à l'algorithme que vous êtes une entreprise vivante. Un profil GBP qui ne bouge pas depuis des mois glisse dans le classement, peu importe vos étoiles.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça fonctionne</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connectez votre GBP une fois.<br />Tout le reste se gère automatiquement.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Stacc se connecte à votre Google Business Profile, apprend votre secteur d'activité et votre localisation, puis publie, surveille et optimise chaque jour — sans que vous ayez à vous connecter une seule fois.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connectez votre Google Business Profile</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Stacc lit votre secteur, votre localisation, vos services et vos avis actuels. Nous identifions vos lacunes de mots-clés locaux et les opportunités de positionnement Maps spécifiques à votre zone géographique.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Stacc publie 30 Google Posts par mois</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Des publications sur les offres, les services, les mises à jour saisonnières et les actualités de l'entreprise — toutes optimisées avec des mots-clés locaux et publiées selon un calendrier conçu pour maximiser la visibilité de votre profil.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Chaque avis reçoit une réponse en 24 heures</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Avis 5 étoiles, 3 étoiles, critique — tous traités. Des réponses personnalisées qui sonnent humain, s'adressent spécifiquement au commentaire du client et renforcent votre profil SEO local à chaque fois.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FEATURES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tout inclus</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque signal de référencement local. Géré.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Publications Google Business',
              body: '30 Google Posts par mois ciblant des mots-clés locaux à longue traîne. Chaque post est un signal que Google remarque et qui améliore votre visibilité locale au fil du temps.',
              icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
            },
            {
              title: 'Gestion des avis',
              body: 'Réponses personnalisées à tous les avis en moins de 24 heures. Les avis positifs sont reconnus. Les avis négatifs sont traités professionnellement sans aggraver la situation.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Optimisation du profil GBP',
              body: 'Attributs du profil, catégories de services, heures d\'ouverture et zones de service — tous optimisés pour correspondre à la façon dont vos clients locaux recherchent réellement.',
              icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
            },
            {
              title: 'Contenu SEO local',
              body: 'Des articles de blog publiés sur votre site ciblant des mots-clés spécifiques à votre ville, comme "meilleur dentiste [ville]" ou "urgence plombier [quartier]". Construit pour alimenter votre Maps et votre recherche organique.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Surveillance du classement',
              body: 'Suivez vos positions Maps et les classements de recherche locale semaine après semaine. Voyez exactement comment votre visibilité locale évolue au fil du temps.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Rapports mensuels',
              body: 'Un rapport clair sur les performances locales : impressions Maps, actions sur le profil, nouvelles demandes de direction, appels depuis Maps, et tendances de croissance des avis.',
              icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
