---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const sections = [
  { id: 'quest-ce', num: '1', title: 'Qu\'est-ce qu\'un cookie ?', body: 'Un cookie est un petit fichier texte placé sur votre appareil par un site web lorsque vous le visitez. Les cookies permettent au site de mémoriser vos actions et préférences sur une période donnée, afin de ne pas avoir à les ressaisir à chaque visite.' },
  { id: 'types', num: '2', title: 'Types de cookies que nous utilisons', body: 'Nous utilisons des cookies essentiels (nécessaires au fonctionnement du site), des cookies de performance (pour analyser l\'utilisation du site), des cookies de fonctionnalité (pour mémoriser vos préférences) et des cookies de marketing (pour vous proposer du contenu personnalisé).' },
  { id: 'liste', num: '3', title: 'Cookies spécifiques', body: 'Nous utilisons notamment les cookies de session pour maintenir votre connexion, les cookies d\'analyse Google Analytics pour comprendre comment vous utilisez notre site, et les cookies Stripe pour le traitement sécurisé des paiements. Chaque cookie a une durée de vie définie et un objectif précis.' },
  { id: 'controle', num: '4', title: 'Contrôle des cookies', body: 'Vous pouvez contrôler et/ou supprimer les cookies à votre guise. Vous pouvez supprimer tous les cookies déjà présents sur votre ordinateur et paramétrer la plupart des navigateurs pour en bloquer l\'installation. Dans ce cas, il se peut que vous deviez personnaliser manuellement certaines préférences à chaque visite.' },
  { id: 'tiers', num: '5', title: 'Cookies tiers', body: 'Certaines de nos pages peuvent inclure des contenus de tiers (vidéos, cartes, etc.) qui peuvent également déposer des cookies. Nous n\'avons aucun contrôle sur ces cookies. Consultez les politiques de confidentialité de ces tiers pour plus d\'informations.' },
  { id: 'contact', num: '6', title: 'Questions', body: 'Pour toute question concernant notre utilisation des cookies, contactez-nous via notre page Contact.' },
];
---

<BaseLayout
  title="Politique de Cookies — theStacc"
  description="Comment theStacc utilise les cookies sur son site. Types de cookies, contrôle et gestion de vos préférences."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative py-10 md:py-14">
        <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Légal · Cookies</span>
        <h1 class="mt-2 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.5rem]">Politique de Cookies</h1>
        <p class="mt-2 font-mono text-[12px] text-[#79716b]">Dernière mise à jour : Avril 2026</p>
      </div>
    </section>
    <div class="min-h-screen bg-[#fafaf9]">
      <div class="container-x py-12 md:py-16">
        <div class="mx-auto max-w-3xl space-y-10">
          {sections.map(s => (
            <section id={s.id} class="scroll-mt-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">{s.num}</span>
                <h2 class="font-sans text-[18px] font-semibold text-[#111827]">{s.title}</h2>
              </div>
              <div class="pl-9"><p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">{s.body}</p></div>
              <div class="mt-6 border-t border-[#e7e5e4]"></div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
