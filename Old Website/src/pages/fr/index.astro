import { SITE_URL, LOGO_URL } from '../../utils/schema';

const homepageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL, width: 512, height: 512 },
      description: 'Plateforme d\'automatisation SEO IA qui publie 30 articles par mois, gère vos profils Google Business et automatise les réseaux sociaux pour les entreprises locales.',
      founder: { '@type': 'Person', name: 'Siddharth Gangal', url: `${SITE_URL}/about/` },
      sameAs: ['https://www.linkedin.com/company/thestacc', 'https://x.com/thestacc'],
      contactPoint: { '@type': 'ContactPoint', contactType: 'customer support', url: `${SITE_URL}/contact/` },
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      name: 'theStacc',
      url: SITE_URL,
      publisher: { '@id': `${SITE_URL}/#organization` },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE_URL}/#software`,
      name: 'theStacc',
      description: 'Plateforme d\'automatisation SEO IA qui rédige 30 articles par mois, gère le SEO local et automatise la diffusion sur les réseaux sociaux.',
