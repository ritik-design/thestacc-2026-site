      screenshot: `${SITE_URL}/dashboard-preview.webp`,
      provider: { '@id': `${SITE_URL}/#organization` },
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/fr/`,
      name: 'theStacc | Automatisation SEO IA pour Entreprises Locales',
      url: `${SITE_URL}/fr/`,
      isPartOf: { '@id': `${SITE_URL}/#website` },
