        { score:84, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILE',    labelColor:'#9ca3af', title:'Après le [service] : ce qu\'il faut faire' },
        { score:91, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILE',    labelColor:'#9ca3af', title:'Entretien [service] : guide saisonnier' },
        { score:87, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILE',    labelColor:'#9ca3af', title:'FAQ [service] : vos questions, nos réponses' },
        { score:89, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILE',    labelColor:'#9ca3af', title:'Trouver la meilleure offre [service]' },
        { score:85, type:'tile-queue',   scoreColor:'#9ca3af', label:'FILE',    labelColor:'#9ca3af', title:'Le guide complet du [service]' },
      ];

      const grid    = document.getElementById('article-grid');
      const countEl = document.getElementById('grid-count');
      if (!grid) return;

      TILES.forEach((t) => {
        const el = document.createElement('div');
        el.className = `article-tile ${t.type}`;
        el.innerHTML = `
          <span style="font-family:monospace;font-size:11px;font-weight:800;line-height:1;color:${t.scoreColor}">${t.score}</span>
          <span style="font-family:monospace;font-size:7px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;line-height:1;color:${t.labelColor}">${t.label}</span>
          <div class="tile-tooltip">${t.title}</div>
        `;
        grid.appendChild(el);
      });

      let cascadeTimer: ReturnType<typeof setTimeout> | null = null;

      function animateIn(delay = 0) {
        const tiles = grid.querySelectorAll('.article-tile');
        let count = 0;
        tiles.forEach((tile, i) => {
          setTimeout(() => {
            tile.classList.add('tile-visible');
            count++;
            if (countEl) countEl.textContent = count + (count === 1 ? ' article en file' : ' articles en file');
          }, delay + i * 72);
        });
      }

      function resetAndAnimate() {
        if (cascadeTimer) clearTimeout(cascadeTimer);
        const tiles = grid.querySelectorAll<HTMLElement>('.article-tile');
        tiles.forEach((t) => {
          t.style.transition = 'none';
          t.classList.remove('tile-visible');
        });
        grid.getBoundingClientRect(); // force reflow
        tiles.forEach((t) => { t.style.transition = ''; });
        if (countEl) countEl.textContent = '0 article en file';
        cascadeTimer = setTimeout(() => animateIn(0), 80);
      }

      // Month tab switching
      document.querySelectorAll<HTMLElement>('.grid-month-tab').forEach((tab) => {
        tab.addEventListener('click', () => {
          document.querySelectorAll<HTMLElement>('.grid-month-tab').forEach((t) => {
            t.style.color = '#374151';
            t.style.borderBottomColor = 'transparent';
          });
          tab.style.color = '#818cf8';
          tab.style.borderBottomColor = '#4f39f6';
          resetAndAnimate();
        });
      });

      // Scroll-triggered first run
      const obs = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) { obs.disconnect(); animateIn(300); }
        },
        { threshold: 0.2 }
      );
      obs.observe(grid);
    })();
  </script>
</BaseLayout>
