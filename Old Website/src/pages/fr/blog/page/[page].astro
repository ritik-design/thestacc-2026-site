---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/fr/HeaderFr.astro';
import Footer from '../../../../components/fr/FooterFr.astro';
import { getCollection } from 'astro:content';
import { POSTS_PER_PAGE } from '../../../../data/constants';

export async function getStaticPaths() {
  const posts = await getCollection('blog_fr');
  const sortedPosts = posts.sort((a, b) => {
    const dateA = new Date(a.data.date);
    const dateB = new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  });
  const visiblePosts = sortedPosts.filter(p => p.data.image);
  const totalPages = Math.ceil(visiblePosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const pageNum = i + 2;
    const start = (pageNum - 1) * POSTS_PER_PAGE;
    return {
      params: { page: String(pageNum) },
      props: {
        posts: visiblePosts.slice(start, start + POSTS_PER_PAGE),
        currentPage: pageNum,
        totalPages,
        totalPosts: visiblePosts.length,
      },
    };
  });
}

const { posts: pagePosts, currentPage, totalPages, totalPosts } = Astro.props;
const prevPage = currentPage === 2 ? '/fr/blog/' : `/fr/blog/page/${currentPage - 1}/`;
const nextPage = currentPage < totalPages ? `/fr/blog/page/${currentPage + 1}/` : null;
---

<BaseLayout
  title={`Blog SEO — Page ${currentPage} sur ${totalPages} | theStacc`}
  description={`Page ${currentPage} sur ${totalPages}. Conseils SEO, recherche locale, stratégie de contenu et outils IA pour les entrepreneurs et marketeurs.`}
  lang="fr"
>
  <Fragment slot="head">
    <link rel="prev" href={prevPage} />
    {nextPage && <link rel="next" href={nextPage} />}
  </Fragment>
  <Header />
  <main class="flex-1">

    <!-- PAGE HEADER -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-8 pb-10">
        <a href="/fr/blog/" class="inline-flex items-center gap-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6] transition-opacity hover:opacity-70">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
          Blog SEO
        </a>
        <h1 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[32px]">
          Page {currentPage} sur {totalPages}
        </h1>
        <p class="mt-2 font-sans text-[14px] leading-[1.7] text-[#57534e]">
          {totalPosts} articles au total. Conseils SEO, recherche locale, stratégie de contenu et outils IA.
        </p>
      </div>
    </section>

    <!-- GRID -->
    <section class="bg-[#fafaf9] px-6 py-8">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {pagePosts.map((post: any) => (
            <a
              href={`/fr/blog/${post.data.slug}/`}
              class="group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm"
            >
              <div class="flex flex-1 flex-col p-5">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                <h2 class="mt-2 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                  {post.data.title}
                </h2>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                  <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                  <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Pagination -->
        <nav class="mt-10 flex items-center justify-center gap-2" aria-label="Navigation du blog">
          <a
            href={prevPage}
            class="mr-1 inline-flex items-center gap-1.5 rounded-lg border border-[#e7e5e4] px-4 py-2 font-mono text-[12px] font-semibold text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
            Précédent
          </a>

          <a
            href="/fr/blog/"
            class={`inline-flex h-9 w-9 items-center justify-center rounded-lg border font-mono text-[13px] font-semibold transition-colors ${1 === currentPage ? 'bg-[#4f39f6] text-white border-[#4f39f6]' : 'border-[#e7e5e4] text-[#79716b] hover:border-[#4f39f6] hover:text-[#4f39f6]'}`}
          >1</a>

          {currentPage > 3 && <span class="font-mono text-sm text-[#79716b]">…</span>}

          {Array.from({ length: totalPages }, (_, i) => i + 1)
            .filter(num => num !== 1 && num !== totalPages && Math.abs(num - currentPage) <= 1)
            .map(num => (
              <a
                href={`/fr/blog/page/${num}/`}
                class={`inline-flex h-9 w-9 items-center justify-center rounded-lg border font-mono text-[13px] font-semibold transition-colors ${num === currentPage ? 'bg-[#4f39f6] text-white border-[#4f39f6]' : 'border-[#e7e5e4] text-[#79716b] hover:border-[#4f39f6] hover:text-[#4f39f6]'}`}
              >{num}</a>
            ))}

          {currentPage < totalPages - 2 && <span class="font-mono text-sm text-[#79716b]">…</span>}

          {totalPages > 1 && (
            <a
              href={`/fr/blog/page/${totalPages}/`}
              class={`inline-flex h-9 w-9 items-center justify-center rounded-lg border font-mono text-[13px] font-semibold transition-colors ${totalPages === currentPage ? 'bg-[#4f39f6] text-white border-[#4f39f6]' : 'border-[#e7e5e4] text-[#79716b] hover:border-[#4f39f6] hover:text-[#4f39f6]'}`}
            >{totalPages}</a>
          )}

          {nextPage ? (
            <a
              href={nextPage}
              class="ml-1 inline-flex items-center gap-1.5 rounded-lg border border-[#e7e5e4] px-4 py-2 font-mono text-[12px] font-semibold text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]"
            >
              Suivant
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          ) : (
            <span class="ml-1 inline-flex items-center gap-1.5 rounded-lg border border-[#e7e5e4] px-4 py-2 font-mono text-[12px] font-semibold text-[#d6d3d1] cursor-not-allowed">
              Suivant
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          )}
        </nav>
      </div>
    </section>

    <!-- FOOTER CTA -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Arrêtez de rédiger du contenu SEO manuellement.
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          30 articles de blog, 30 posts GBP et contenus réseaux sociaux. Publiés sur votre site chaque mois. Automatiquement.
        </p>
        <a
          href="/fr/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Commencer pour 1 $
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">1 $ pendant 30 jours · Annulez quand vous voulez</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
