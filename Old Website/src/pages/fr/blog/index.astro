---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';
import { getCollection } from 'astro:content';

const enPosts = await getCollection('blog');
const langPosts = await getCollection('blog_fr');
const langBySlug = new Map(langPosts.map(p => [p.data.slug, p]));
const posts = enPosts
  .filter(enPost => langBySlug.has(enPost.data.slug))
  .map(enPost => {
    const lp = langBySlug.get(enPost.data.slug)!;
    return { ...enPost, data: { ...enPost.data, title: lp.data.title, description: lp.data.description } };
  });
const sortedPosts = posts
  .filter(p => p.data.image)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function getReadTime(post: any): number {
  const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const featuredPosts = sortedPosts.slice(0, 3);
const recentPosts = sortedPosts.slice(3);

const frLabels = ['Le Plus Lu', 'Tendance', 'Choix de la Rédaction'];

const tools = [
  { name: 'Audit SEO', href: '/fr/outils/audit-seo/', icon: '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>' },
  { name: 'Score SEO', href: '/fr/outils/score-seo-site/', icon: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>' },
  { name: 'Meta Tags', href: '/fr/outils/analyseur-meta-tags/', icon: '<path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>' },
  { name: 'SEO On-Page', href: '/fr/outils/verification-seo-on-page/', icon: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>' },
  { name: 'Analyseur Titres', href: '/fr/outils/analyseur-titres/', icon: '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>' },
  { name: 'ROI SEO', href: '/fr/outils/calculateur-roi-seo/', icon: '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>' },
];
---

<BaseLayout
  title="Blog SEO en Français | theStacc"
  description="Guides SEO, stratégies et tutoriels en français pour mieux vous positionner sur Google et attirer plus de clients locaux. Mis à jour chaque semaine."
  lang="fr"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-8 pb-10">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Blog SEO</p>
        <h1 class="mt-3 max-w-[600px] font-sans text-[28px] font-bold leading-[1.15] tracking-[-0.025em] text-[#292524] md:text-[38px]">
          Guides SEO en Français
        </h1>
        <p class="mt-3 max-w-[500px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          {sortedPosts.length}+ guides, tutoriels et stratégies pour mieux vous positionner sur Google et attirer plus de clients locaux.
        </p>
        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            {sortedPosts.length}+ Articles
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Mis à jour chaque semaine
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#57534e]">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            SEO Local
          </span>
        </div>
      </div>
    </section>

    <!-- ARTICLES EN VEDETTE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] py-8">
      <div class="mx-auto max-w-6xl px-6">
        <p class="mb-5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">À la Une</p>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
          {featuredPosts.map((post, i) => (
            <a
              href={`/fr/blog/${post.data.slug}/`}
              class="group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-md"
            >
              <div class="flex flex-1 flex-col p-5">
                <div class="mb-2.5 flex items-center justify-between gap-2">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                  <span class="shrink-0 rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[9px] font-bold uppercase tracking-[0.06em] text-[#7c3aed]">{frLabels[i]}</span>
                </div>
                <h3 class="flex-1 font-sans text-[15px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                  {post.data.title}
                </h3>
                <div class="mt-3 flex items-center gap-2">
                  <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min de lecture</span>
                  <span class="text-[#d6d3d1]">·</span>
                  <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- GRILLE ARTICLES -->
    <section class="bg-[#fafaf9] px-6 py-8">
      <div class="mx-auto max-w-6xl">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="font-sans text-[20px] font-bold text-[#111827]">Tous les Articles</h2>
          <a href="/blog/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6] transition-opacity hover:opacity-70">
            Version anglaise →
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {recentPosts.map((post) => (
            <a
              href={`/fr/blog/${post.data.slug}/`}
              class="group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm"
            >
              <div class="flex flex-1 flex-col p-5">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                <h3 class="mt-2 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                  {post.data.title}
                </h3>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                    <span class="text-[#e7e5e4]">·</span>
                    <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min</span>
                  </div>
                  <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/blog/"
            class="inline-flex h-[42px] items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-mono text-[12px] font-semibold uppercase tracking-[0.08em] text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]"
          >
            Voir tous les articles (EN)
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- OUTILS GRATUITS -->
    <section class="border-t border-b border-[#e7e5e4] bg-white py-10">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Outils SEO Gratuits</p>
            <h2 class="mt-1 font-sans text-[20px] font-bold text-[#111827]">Analysez et optimisez. Gratuitement.</h2>
          </div>
          <a href="/fr/outils/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6] transition-opacity hover:opacity-70">
            Tous les outils →
          </a>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
          {tools.map(tool => (
            <a
              href={tool.href}
              class="group flex flex-col items-center gap-2.5 rounded-xl border border-[#e7e5e4] bg-white p-4 text-center transition-all hover:border-[#c4b5fd] hover:shadow-sm"
            >
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#f5f3ff] transition-colors group-hover:bg-[#ede9fe]">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={tool.icon}></svg>
              </div>
              <span class="font-sans text-[12px] font-semibold leading-[1.3] text-[#292524] transition-colors group-hover:text-[#4f39f6]">{tool.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Arrêtez d'écrire du contenu SEO manuellement
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          30 articles de blog, 30 posts GBP et contenus sociaux. Publiés sur votre site chaque mois. Automatiquement.
        </p>
        <a
          href="/fr/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Essayer pour 1 $
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">1 $ pour 30 jours · Annulez quand vous voulez</p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
