---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce qu'un logiciel SEO pour franchise ?", a: "Un logiciel SEO pour franchise permet de gérer le référencement local de toutes les franchises d'un réseau depuis un seul système. Chaque franchisé obtient son propre profil Google Business Profile optimisé, son suivi de positions local et ses rapports — tout en permettant à l'enseigne de maintenir une cohérence de marque sur l'ensemble du réseau." },
  { q: "Comment Stacc gère-t-il les spécificités de chaque franchisé ?", a: "Chaque franchisé a son propre tableau de bord avec ses données locales. Le franchiseur voit un dashboard portfolio agrégé de toutes les franchises. Les mises à jour de marque (descriptions, catégories, visuels) peuvent être déployées sur tout le réseau en une action. Les données de performance restent individuelles par franchisé." },
  { q: "Puis-je déployer des mises à jour sur tout le réseau simultanément ?", a: "Oui. La gestion en masse permet de mettre à jour les informations de marque, les promotions saisonnières et les contenus GBP sur toutes les franchises en même temps. Les informations spécifiques à chaque franchisé (horaires, téléphone local) restent gérées par établissement." },
  { q: "Comment gérer les franchisés qui ne participent pas activement ?", a: "Stacc automatise l'exécution SEO même sans action des franchisés. Les posts GBP sont publiés automatiquement, les citations surveillées et les rapports envoyés. Le franchiseur peut aussi voir quels franchisés ont des performances insuffisantes pour intervenir en priorité." },
  { q: "Les rapports peuvent-ils être personnalisés par zone géographique ?", a: "Oui. Vous pouvez générer des rapports par franchisé, par région, par groupe ou pour l'ensemble du réseau. Les rapports marque blanche peuvent être envoyés automatiquement à chaque franchisé avec les données de son territoire." },
  { q: "Combien coûte le logiciel SEO franchise ?", a: "Le module SEO Local commence à 49 $/mois et inclut toutes les fonctionnalités multi-sites, la gestion en masse et les rapports agrégés. Pas de frais supplémentaires par franchisé ajouté." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Logiciel SEO Franchise",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Logiciel SEO pour réseaux de franchise. Gérez le référencement local de toutes vos franchises depuis un seul tableau de bord portfolio.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Logiciel SEO Franchise", "item": "https://thestacc.com/fr/logiciel-seo-franchise/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Logiciel SEO Franchise — Gérez le SEO de Toutes Vos Franchises Depuis Un Seul Dashboard | theStacc"
  description="Logiciel SEO pour réseaux de franchise. theStacc automatise GBP, suivi de positions et rapports pour chaque franchisé — cohérence de marque sur tout le réseau."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Logiciel SEO Franchise · À partir de 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO local pour votre réseau franchise.<br />
            <span style="color:#4f39f6;">Une marque cohérente. Chaque territoire optimisé.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Gérez le référencement local de toutes vos franchises depuis un seul tableau de bord. Déployez des mises à jour sur tout le réseau, suivez les performances par franchisé et générez des rapports automatiques — sans multiplier le travail par le nombre de franchises.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/seo-franchise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Voir le SEO Franchise
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte de crédit · Résiliable à tout moment
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ entreprises et agences</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1 200+ établissements gérés</span>
          </div>
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités franchise</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Cohérence de marque sur tout le réseau.<br />Performance locale par territoire.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Vue réseau complète', body: 'Dashboard portfolio avec les performances de toutes les franchises. Classements, avis et citations de chaque franchisé en un coup d\'œil.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Déploiement réseau en masse', body: 'Mettez à jour les informations de marque, promotions et contenus GBP sur toutes les franchises simultanément. Cohérence garantie.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'SEO local par territoire', body: 'Automatisation GBP, suivi de positions et gestion des citations adaptés à chaque territoire local. Chaque franchisé classé en local.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Rapports par franchisé', body: 'Rapports automatiques pour chaque franchisé et pour l\'enseigne. Envoyés selon le calendrier configuré sans travail manuel.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positions par zone', body: 'Classements suivis quotidiennement pour chaque franchisé sur ses mots-clés locaux. Identifiez les territoires sous-performants.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestion des avis réseau', body: 'Alertes centralisées pour tous les avis de toutes les franchises. Répondez depuis un seul endroit, gérez la réputation du réseau.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- CE QUE FAIT STACC — FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que fait Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque levier SEO franchise.<br />Tout automatisé en un seul outil.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Posts GBP spécifiques par établissement', body: '30 posts/mois par franchise avec mots-clés locaux ciblés. Contenu automatiquement adapté à chaque territoire.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi des positions pour toutes les franchises', body: 'Tous les établissements et mots-clés suivis quotidiennement. Comparez les performances de tout le réseau en un coup d\'œil.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Cohérence des citations', body: 'NAP cohérent dans 50+ annuaires pour tous les établissements. Surveillance continue et corrections automatiques.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Gestion des avis', body: 'Alertes en temps réel par établissement avec modèles de réponse. Ne manquez aucun avis sur l\'ensemble du réseau.' },
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Rapports marque blanche', body: 'Rapports mensuels par établissement avec branding franchise. Livrés automatiquement sans intervention manuelle.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Dashboard franchise', body: 'Gestion centralisée de tous les établissements depuis un seul tableau de bord. Vue globale et zoom par franchisé.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités en détail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Du contenu local à chaque franchisé.<br />Des rapports automatiques pour l'enseigne.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Posts localisés -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Contenu GBP Local</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Posts localisés pour chaque établissement
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque franchisé reçoit 30 posts GBP par mois, automatiquement personnalisés avec les mots-clés de sa ville et de sa zone de chalandise. Un contenu unique pour chaque territoire — sans multiplier le travail de rédaction par le nombre de franchises. La cohérence de marque est maintenue. La pertinence locale est garantie.
              </p>
              <a href="/fr/logiciel-google-business-profile/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir la gestion GBP
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Posts GBP — Réseau franchise</p>
              {[
                { location: 'Franchise Paris 11e', post: 'Service disponible dans le 11e arrondissement', status: 'Publié' },
                { location: 'Franchise Lyon Centre', post: 'Service disponible à Lyon — centre-ville', status: 'Publié' },
                { location: 'Franchise Bordeaux', post: 'Service disponible à Bordeaux et sa métropole', status: 'Publié' },
                { location: 'Franchise Marseille 6e', post: 'Service disponible dans le 6e à Marseille', status: 'Publié' },
              ].map(r => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#4f39f6] text-white">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.location}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.post}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669] shrink-0">{r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 posts/mois · Contenu localisé par établissement</p>
            </div>
          </div>

          <!-- Vue réseau -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Positions — Tableau de bord réseau</p>
              {[
                { franchise: 'Paris 11e', kw: 'service local paris', pos: 1, change: '+4', trend: 'up' },
                { franchise: 'Lyon Centre', kw: 'service local lyon', pos: 2, change: '+2', trend: 'up' },
                { franchise: 'Bordeaux', kw: 'service local bordeaux', pos: 3, change: '+3', trend: 'up' },
                { franchise: 'Marseille 6e', kw: 'service local marseille', pos: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.franchise}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Mis à jour quotidiennement · Tous les établissements</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Visibilité Centralisée</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Vue d'ensemble du réseau
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Suivez les positions de chaque franchisé depuis un seul tableau de bord. Identifiez immédiatement les territoires qui progressent et ceux qui nécessitent de l'attention. Aucune agence externe, aucun outil supplémentaire — tout centralisé dans Stacc pour l'ensemble du réseau franchise.
              </p>
              <a href="/fr/logiciel-suivi-positions/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le suivi de positions
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Rapports automatiques -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reporting Automatique</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Rapports automatiques par établissement
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque franchisé reçoit automatiquement son rapport mensuel de performance SEO. L'enseigne reçoit la vue agrégée du réseau. Les rapports incluent les positions, les avis, l'activité GBP et l'état des citations — livrés selon un calendrier fixe, sans intervention manuelle de votre équipe.
              </p>
              <a href="/fr/rapports-marque-blanche/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir les rapports marque blanche
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
