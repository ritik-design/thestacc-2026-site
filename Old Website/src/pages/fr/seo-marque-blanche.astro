---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce que le SEO marque blanche ?", a: "Le SEO marque blanche signifie fournir des services SEO à vos clients sous votre propre marque — pas celle du logiciel ou du prestataire. La plateforme de theStacc est présentée à vos clients avec votre logo, vos couleurs et votre nom de domaine, afin qu'ils voient uniquement votre marque et non Stacc." },
  { q: "Qu'est-ce qui est personnalisé avec le marque blanche ?", a: "Les rapports clients, le tableau de bord d'accès, les notifications par email et les PDF sont tous brandés avec votre logo et vos couleurs. Le domaine du portail client peut être votre domaine personnalisé (ex. rapports.votreagence.fr). Aucune référence à theStacc n'est visible par vos clients." },
  { q: "Combien de temps prend la configuration ?", a: "La configuration initiale prend environ 2 heures : importez votre logo, définissez les couleurs de votre marque, configurez le domaine personnalisé. Ensuite, l'ajout de nouveaux clients ne prend que quelques minutes chacun." },
  { q: "Les clients peuvent-ils accéder en autonomie ?", a: "Oui. Chaque client reçoit ses propres identifiants d'accès au portail marque blanche. Ils peuvent consulter les rapports de suivi de positions, les données de citations et les métriques d'avis à tout moment, sans avoir besoin de vous contacter." },
  { q: "Supportez-vous les domaines personnalisés ?", a: "Oui. Vous pouvez héberger le portail de rapport client sur un sous-domaine de votre site (ex. rapports.votreagence.fr) pour une expérience entièrement en marque blanche. La configuration DNS prend environ 15 minutes." },
  { q: "Combien ça coûte ?", a: "Le module SEO local commence à 49$/mois et inclut toutes les fonctionnalités marque blanche — tableau de bord brandé, rapports PDF avec votre logo, portail d'accès client et notifications email personnalisées. Aucun coût par client et aucune frais de configuration." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO Marque Blanche",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Plateforme SEO marque blanche pour agences. Tableau de bord brandé, rapports automatisés et accès clients — tout avec votre marque, zéro référence à Stacc.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "SEO Marque Blanche", "item": "https://thestacc.com/fr/seo-marque-blanche/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "fr",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="SEO Marque Blanche — Gérez le SEO de Vos Clients Sous Votre Marque | theStacc"
  description="Plateforme SEO marque blanche pour agences. theStacc gère le suivi de positions, les citations, les avis et les rapports — tout brandé avec votre logo, vos couleurs et votre domaine."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Marque Blanche · Pour les Agences</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO marque blanche qui fonctionne<br />
            <span style="color:#4f39f6;">sous votre marque.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Gérez le SEO de vos clients, livrez les rapports et offrez l'accès au tableau de bord — tout avec le logo et le domaine de votre agence. Vos clients ne voient que votre marque.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer gratuitement
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/tarifs/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Voir les tarifs
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            49 $/mois · Essai gratuit 14 jours · Sans carte bancaire
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ agences utilisent Stacc</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuration &lt; 5 min</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── VALUE SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">L'avantage du marque blanche</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vos clients voient votre agence,<br />pas la technologie que vous utilisez.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>La plupart des agences SEO utilisent des outils tiers pour gérer leur travail. Le problème est que ces plateformes apparaissent souvent dans les rapports, les emails et les tableaux de bord — et les clients commencent à se demander pourquoi ils paient l'agence au lieu d'utiliser directement l'outil. Le marque blanche élimine ce problème.</p>
            <p>Avec Stacc, tout ce que vos clients voient porte votre marque. Les rapports ont votre logo. Le tableau de bord d'accès est brandé avec vos couleurs. Les emails partent de votre domaine. Il n'y a aucune trace de Stacc dans l'expérience client — juste votre agence qui livre des résultats professionnels.</p>
            <p>Ce n'est pas qu'un avantage esthétique. <strong class="text-[#111827]">C'est la différence entre être perçu comme un revendeur de logiciel et être perçu comme une agence qui délivre un service premium.</strong> Le marque blanche vous permet de facturer au juste prix, de fidéliser les clients plus longtemps et de construire une marque qui a de la valeur.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce qu'inclut le marque blanche</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tout le nécessaire pour gérer vos clients<br />sous votre marque.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Plateforme entièrement en marque blanche', body: 'Tableau de bord, rapports PDF et portail clients brandés avec votre logo, vos couleurs et votre domaine personnalisé. Zéro référence à Stacc.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automatisation GBP + SEO local', body: '30 posts GBP par mois, suivi de positions quotidien, alertes avis et gestion de citations — tout automatisé pour chaque client.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positions en marque blanche', body: 'Les clients voient les graphiques de classement avec votre marque, pas celle de Stacc. Rapports de suivi de positions livrés automatiquement.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Gestion des citations', body: 'Surveillez et corrigez la précision NAP sur 50+ annuaires pour chaque client, avec des rapports brandés à votre marque.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Surveillance des avis', body: 'Alertes en temps réel pour chaque nouvel avis sur tous les profils clients — flux centralisé, tout brandé avec votre marque.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Livraison automatique des rapports', body: 'Les rapports sont générés, brandés avec votre logo et envoyés aux clients automatiquement. Zéro travail manuel de reporting chaque mois.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '400+', label: 'Agences utilisent Stacc', sub: 'Avec des clients actifs en marque blanche' },
            { value: '2h', label: 'Pour la configuration initiale', sub: 'Logo, couleurs, domaine personnalisé' },
            { value: '0€', label: 'Coût par client supplémentaire', sub: 'Ajoutez autant de clients que vous voulez' },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités clés</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Votre marque en avant.<br />La technologie de Stacc en coulisses.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Tableau de bord brandé -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tableau de Bord Entièrement Brandé</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Vos clients se connectent à votre plateforme, pas à Stacc.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Dès la première connexion, vos clients voient votre logo, vos couleurs et votre nom de domaine. Pas de mention de Stacc, nulle part. Le tableau de bord client affiche les classements, les avis, les citations et les posts GBP publiés — tout sous votre identité visuelle. Pour les agences qui veulent être perçues comme un prestataire premium et non comme un revendeur de SaaS, c'est l'expérience qui fait la différence.
              </p>
              <a href="/fr/seo-marque-blanche/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le tableau de bord marque blanche
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Votre Agence — Tableau de bord client</p>
                  <p class="font-mono text-[10px] text-[#79716b]">rapports.votreagence.fr</p>
                </div>
              </div>
              {[
                { label: 'Classement Maps', val: '#2 · +3 ce mois' },
                { label: 'Posts GBP publiés', val: '30 ce mois' },
                { label: 'Nouveaux avis', val: '8 · moy. 4,8 ⭐' },
                { label: 'Citations exactes', val: '100% sur 50+ annuaires' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Aucune référence à Stacc visible · 100% votre marque</p>
            </div>
          </div>

          <!-- Rapports automatiques -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Rapport mensuel — livraison automatique</p>
              {[
                { label: 'Expéditeur', val: 'noreply@votreagence.fr' },
                { label: 'Objet', val: 'Rapport SEO — Avril 2026' },
                { label: 'Logo en en-tête', val: 'Le vôtre ✓' },
                { label: 'Domaine du portail', val: 'rapports.votreagence.fr' },
                { label: 'Mention Stacc', val: 'Aucune ✓' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{row.label}</span>
                  <span class="font-mono text-[11px] font-semibold text-[#059669]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Généré et envoyé automatiquement · Zéro travail manuel</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rapports Automatiques Marque Blanche</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Configurez le modèle une fois. Les rapports partent seuls chaque mois.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Le reporting client est la charge la plus coûteuse du SEO en agence. Avec Stacc, vous configurez votre modèle une fois — métriques, logo, couleurs, fréquence — et la plateforme génère, brande et livre chaque rapport automatiquement. Les clients reçoivent un PDF professionnel à votre marque sans que vous ayez quoi que ce soit à faire.
              </p>
              <a href="/fr/rapports-marque-blanche/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir les rapports marque blanche
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Gestion multi-clients -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestion Multi-Clients</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Tous vos clients dans un seul tableau de bord. Zéro navigation entre comptes.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Le tableau de bord de gestion multi-clients de Stacc vous donne une vue d'ensemble de tous vos comptes en un seul endroit. Surveillez les performances de chaque client, voyez les alertes dans un fil unifié et gérez les tâches sans accéder à des dizaines de comptes séparés. Pour les agences qui gèrent 20, 50 ou 100 clients, cette consolidation représente plusieurs heures récupérées chaque semaine.
              </p>
              <a href="/fr/solutions/agences/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir Stacc pour les agences
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Vue portefeuille — tous les clients</p>
              {[
                { client: 'Boulangerie Centrale', status: 'Actif', trend: '↑ +2 positions' },
                { client: 'Plomberie Express', status: 'Actif', trend: '↑ +5 positions' },
                { client: 'Cabinet Martin', status: 'Actif', trend: '→ Stable' },
                { client: 'Auto École Durand', status: 'Actif', trend: '↑ +1 position' },
              ].map(c => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{c.client}</span>
                  <span class="font-mono text-[11px] text-[#059669]">{c.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Tous brandés avec votre marque · Aucun accès séparé</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── TÉMOIGNAGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que disent les agences</span>
