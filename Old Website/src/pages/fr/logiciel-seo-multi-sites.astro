---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce qu'un logiciel SEO multi-sites ?", a: "Un logiciel SEO multi-sites est conçu pour gérer le positionnement local d'une entreprise avec plusieurs points de vente ou établissements. Au lieu de gérer chaque établissement manuellement, le logiciel permet de publier des posts GBP, surveiller les positions, gérer les citations et générer des rapports pour tous les établissements simultanément, depuis un seul tableau de bord." },
  { q: "Quelle est la différence avec le SEO pour un seul établissement ?", a: "Avec un seul établissement, le travail est gérable manuellement. Avec 10, 20 ou 50 établissements, chaque tâche se multiplie par le nombre d'établissements. Le logiciel SEO multi-sites automatise l'exécution à l'échelle — le travail n'augmente donc pas proportionnellement au nombre d'établissements gérés." },
  { q: "Comment Stacc gère-t-il les établissements aux performances différentes ?", a: "Stacc fournit un tableau de bord portfolio qui affiche les performances de tous les établissements côte à côte. Vous identifiez immédiatement quels établissements progressent, lesquels régressent et où intervenir. Les rapports par établissement montrent classements, citations et avis en détail." },
  { q: "Puis-je mettre à jour tous les établissements simultanément ?", a: "Oui. La fonction de mise à jour en masse de Stacc permet de modifier les horaires, descriptions, catégories et attributs GBP sur tous les établissements en une seule action. Inutile d'accéder à chaque profil séparément." },
  { q: "Comment fonctionne le reporting multi-sites ?", a: "Stacc génère des rapports automatiques pour chaque établissement et des rapports portfolio agrégés montrant les performances de l'ensemble du réseau. Les rapports sont livrés automatiquement selon le calendrier configuré — hebdomadairement ou mensuellement — sans que votre équipe ait à les préparer manuellement." },
  { q: "Combien d'établissements Stacc peut-il gérer ?", a: "Pas de limite pratique. Stacc gère des portfolios de 1 à 500+ établissements. La plateforme est conçue pour évoluer sans nécessiter de personnel supplémentaire pour chaque établissement ajouté — l'automatisation gère le volume." },
  { q: "Combien de temps faut-il pour intégrer un nouvel établissement ?", a: "Environ 2 minutes. Entrez les données de l'établissement (nom, adresse, téléphone, catégories), connectez le profil GBP et Stacc propage automatiquement la configuration sur tout le réseau de citations." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Logiciel SEO Multi-Sites",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Logiciel SEO multi-sites pour gérer le suivi de positions, GBP, citations et rapports pour chaque établissement simultanément depuis un tableau de bord portfolio unifié.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Logiciel SEO Multi-Sites", "item": "https://thestacc.com/fr/logiciel-seo-multi-sites/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Logiciel SEO Multi-Sites — Gérez Tous Vos Établissements Depuis Un Tableau de Bord | theStacc"
  description="Logiciel SEO multi-sites pour entreprises et agences. theStacc automatise GBP, suivi de positions, citations et rapports pour chaque établissement — tableau de bord portfolio inclus."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Logiciel SEO Multi-Sites · À partir de 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Tous vos établissements gérés<br />
            <span style="color:#4f39f6;">depuis un tableau de bord. En automatique.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Avec 10 établissements, le travail SEO se multiplie par 10. Avec Stacc, non. Tableau de bord portfolio, gestion en masse, automatisation GBP, suivi de positions par établissement et rapports automatiques — tout à l'échelle sans ajouter de personnel.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#fonctionnalites"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Découvrir les fonctionnalités
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte de crédit · Résiliable à tout moment
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">500+ établissements gérés</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuration &lt; 5 min</span>
          </div>
        </div>
      </div>
    </section>


    <!-- NARRATIF -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème de la gestion SEO multi-sites</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque établissement a besoin du même travail.<br />Les équipes humaines ne peuvent en gérer que quelques-uns.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Pour un seul établissement, le SEO local est gérable : mettez à jour le GBP, surveillez les citations, répondez aux avis, suivez les classements. Peut-être 3-4 heures par semaine. Ça va pour un établissement.
            </p>
            <p>
              Multipliez par 20 établissements. Le travail est le même par établissement — il se produit juste 20 fois. En pratique, certains établissements reçoivent de l'attention et la plupart non. Les établissements soignés progressent dans les classements. Ceux négligés, non.
            </p>
            <p class="font-semibold text-[#111827]">
              Stacc brise cette contrainte. L'automatisation gère le travail quotidien répétitif pour chaque établissement simultanément — activité GBP, surveillance des citations, suivi de positions, alertes d'avis — ainsi votre effort humain va à la stratégie, pas à l'exécution.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- FONCTIONNALITÉS MULTI-SITES -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités multi-sites</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Conçu pour gérer<br />des portfolios de toute taille.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Tableau de bord portfolio', body: "Visualisez tous vos établissements dans un seul panneau avec classements, performances des avis et état des citations. Identifiez immédiatement ceux qui ont besoin d'attention." },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Gestion en masse', body: 'Mettez à jour les horaires, descriptions, catégories et attributs GBP sur tous les établissements en une seule action. Pas de modification répétée établissement par établissement.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Rapports portfolio agrégés', body: 'Rapports automatiques par établissement + vue agrégée de tout le réseau. Livrés en marque blanche selon le calendrier configuré.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Automatisation GBP par établissement', body: '30 posts GBP par mois pour chaque établissement — rédigés et publiés automatiquement. Profils toujours actifs sur tout le réseau.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi de positions par établissement', body: 'Classements mis à jour quotidiennement pour chaque établissement et chaque mot-clé suivi. Alertes automatiques sur les variations significatives.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Citations cohérentes réseau', body: 'Contrôle NAP sur 50+ annuaires pour chaque établissement. Corrections automatiques pour maintenir la cohérence sur tout le réseau.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '500+', label: 'Établissements gérés en portfolio', sub: 'Sans personnel dédié par établissement' },
            { value: '90%', label: 'Temps économisé sur les mises à jour', sub: 'Modification en masse vs établissement par établissement' },
            { value: '3×', label: "Plus d'établissements par employé", sub: "L'automatisation multiplie la capacité" },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">SEO multi-sites en détail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Portfolio, positions, rapports —<br />tout géré depuis un seul tableau de bord.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tableau de bord portfolio unifié</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Tous vos établissements côte à côte. Identifiez en un coup d'œil qui a besoin d'attention.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Avec 20 établissements gérés manuellement, vous ne savez jamais quel établissement est en train de décrocher jusqu'à ce que le classement ait déjà chuté. Stacc affiche classements, état des citations, performance des avis et activité GBP pour chaque établissement dans un tableau de bord portfolio unique. Vous voyez instantanément les établissements qui progressent, ceux qui stagnent et ceux qui ont besoin d'intervention — sans ouvrir un seul compte GBP manuellement.
              </p>
              <a href="/fr/logiciel-seo-multi-sites/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le SEO multi-sites
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Vue portfolio — tous établissements</p>
              {[
                { name: 'Paris 11e', rank: '#2', trend: '+3', status: 'ok' },
                { name: 'Lyon Centre', rank: '#5', trend: '-1', status: 'warn' },
                { name: 'Bordeaux', rank: '#1', trend: '+1', status: 'ok' },
                { name: 'Marseille', rank: '#8', trend: '-4', status: 'error' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-2.5">
                  <span class="font-sans text-[12px] text-[#374151] w-28">{r.name}</span>
                  <span class="font-mono text-[12px] font-semibold text-[#111827]">{r.rank}</span>
                  <span class={`rounded-full px-2 py-0.5 font-mono text-[9px] font-semibold ${r.status === 'ok' ? 'bg-[#dcfce7] text-[#059669]' : r.status === 'warn' ? 'bg-[#fef9c3] text-[#d97706]' : 'bg-[#fee2e2] text-[#dc2626]'}`}>{r.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Classements Maps · Mis à jour quotidiennement</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Mise à jour en masse — tous établissements</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Champ à modifier :</p>
                <div class="mt-2 flex flex-wrap gap-2">
                  {['Horaires', 'Description', 'Catégorie', 'Attributs'].map((opt, i) => (
                    <span class={`rounded-lg px-3 py-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] ${i === 0 ? 'bg-[#4f39f6] text-white' : 'border border-[#e7e5e4] text-[#79716b]'}`}>{opt}</span>
                  ))}
                </div>
              </div>
              <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-white p-4">
                <span class="font-sans text-[13px] text-[#57534e]">Appliquer à 47 établissements</span>
                <span class="rounded-lg bg-[#4f39f6] px-3 py-1 font-mono text-[10px] font-bold text-white">Confirmer</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">47 établissements mis à jour en 3 secondes</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestion en masse à l'échelle</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Une modification pour tous les établissements. Ce qui prenait des heures prend maintenant 3 secondes.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque fois que quelque chose change dans votre réseau — horaires de fêtes, nouvelle description, ajout d'une catégorie de service, mise à jour des attributs — vous n'avez pas à vous connecter à chaque profil GBP séparément. Sélectionnez le champ à modifier, entrez la nouvelle valeur, choisissez les établissements à mettre à jour, et Stacc propage la modification simultanément. Pour 5 établissements comme pour 500, le temps de mise à jour reste identique.
              </p>
              <a href="/fr/fonctionnalites/suivi-positions/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le suivi de positions
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rapports portfolio automatiques</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Rapports par établissement + vue réseau agrégée. Livrés automatiquement. En marque blanche.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque établissement reçoit son propre rapport avec classements, performances des avis et état des citations. Le rapport portfolio agrège tout le réseau pour une vue d'ensemble. Pour les agences, les rapports sont livrés en marque blanche aux clients — logo, couleurs, domaine personnalisable — selon le calendrier configuré. Pas de préparation manuelle de rapports. Pas de consolidation de données. Tout est automatique.
              </p>
              <a href="/fr/rapports-marque-blanche/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir les rapports marque blanche
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Rapport portfolio — aperçu mensuel</p>
              <div class="space-y-3">
                {[
                  { label: 'Établissements en progression', value: '34 / 47', color: 'text-[#059669]' },
                  { label: 'Positions gagnées ce mois', value: '+127', color: 'text-[#4f39f6]' },
                  { label: 'Précision NAP réseau', value: '96%', color: 'text-[#059669]' },
                  { label: 'Avis répondus (taux)', value: '98%', color: 'text-[#4f39f6]' },
                ].map(r => (
                  <div class="flex items-center justify-between border-t border-[#f5f3ff] pt-3">
                    <span class="font-sans text-[12px] text-[#57534e]">{r.label}</span>
                    <span class={`font-sans text-[13px] font-semibold ${r.color}`}>{r.value}</span>
                  </div>
                ))}
              </div>
              <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Généré automatiquement · Livré en marque blanche</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- SOCIAL PROOF -->
