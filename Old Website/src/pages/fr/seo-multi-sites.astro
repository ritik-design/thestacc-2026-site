---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce que le SEO multi-sites ?", a: "Le SEO multi-sites est l'optimisation de la présence en recherche locale pour une entreprise avec plusieurs établissements physiques. Cela comprend la gestion des profils Google Business, la création de citations cohérentes, le suivi des classements par mots-clés pour chaque établissement, la surveillance des avis et la publication de contenus ciblant l'intention de recherche locale de chaque marché." },
  { q: "Pourquoi le SEO multi-sites est-il plus difficile que le SEO pour un seul site ?", a: "Parce que chaque tâche se multiplie par le nombre d'établissements. Le suivi de positions, la gestion GBP, la construction de citations, la surveillance des avis et la génération de rapports doivent se faire indépendamment pour chaque établissement. Avec 20+ établissements, la gestion manuelle devient un travail à temps plein pour toute une équipe — c'est pourquoi l'automatisation est la seule approche extensible." },
  { q: "Quel est le facteur le plus important pour classer plusieurs établissements sur Google Maps ?", a: "Des données NAP (Nom, Adresse, Téléphone) cohérentes sur tous les annuaires, une gestion active du profil Google Business avec des posts et réponses réguliers, et un bon volume d'avis récents sont les trois facteurs à plus fort impact pour les classements Maps à grande échelle." },
  { q: "Comment Stacc aide-t-il avec le SEO multi-sites ?", a: "Stacc automatise la publication de posts GBP, la surveillance et la correction des citations, le suivi de positions quotidien et les alertes avis pour chaque établissement simultanément. Vous configurez chaque établissement une fois et la plateforme exécute les tâches SEO automatiquement — le maintien du classement ne nécessite plus de travail manuel quotidien par établissement." },
  { q: "Une personne peut-elle gérer le SEO pour 50+ établissements ?", a: "Avec la bonne automatisation, oui. Les clients de Stacc gèrent des portefeuilles de 500+ établissements sans personnel SEO dédié par établissement. La clé est d'automatiser le travail quotidien répétitif — activité GBP, surveillance des citations, suivi de positions, génération de rapports — pour que l'attention humaine aille à la stratégie, pas à l'exécution." },
  { q: "Combien de temps avant de voir des améliorations de classement ?", a: "Les corrections de citations et les améliorations de l'activité GBP montrent typiquement des mouvements de classement dans les 4 à 8 semaines. La publication constante sur GBP produit des effets cumulatifs en 3 à 6 mois. Le calendrier exact dépend de la baseline actuelle, de la compétitivité du marché et de la régularité de l'activité." },
  { q: "Combien coûte Stacc pour le SEO multi-sites ?", a: "Le module SEO local commence à 49 $/mois et couvre toutes les fonctionnalités multi-sites, dont la gestion en masse, les rapports de portefeuille et l'automatisation à grande échelle." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — SEO Multi-Sites",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Automatisez le SEO multi-sites pour chaque établissement. Suivi de positions, gestion GBP, surveillance des citations et rapports — tous en exécution simultanée pour tout le portefeuille.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "SEO Multi-Sites", "item": "https://thestacc.com/fr/seo-multi-sites/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="SEO Multi-Sites — Automatisez le SEO Local pour Chaque Établissement | theStacc"
  description="Le SEO multi-sites à grande échelle nécessite l'automatisation. theStacc gère GBP, suivi de positions, citations et rapports pour chaque établissement simultanément — sans agrandir l'équipe."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Multi-Sites · Dès 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO multi-sites qui monte en puissance<br />
            <span style="color:#4f39f6;">sans faire monter l'équipe.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Le SEO local pour 50 établissements demande le même travail quotidien que pour 1 — multiplié par 50. Stacc automatise chaque tâche pour chaque établissement de sorte que le travail ne se multiplie pas avec le nombre d'établissements.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/logiciel-seo-multi-sites/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Découvrir la plateforme
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte bancaire · Résiliez quand vous voulez
          </p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ entreprises et agences</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1 200+ établissements gérés</span>
          </div>
        </div>
      </div>
    </section>


    <!-- NARRATIF -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le calcul qui brise le SEO multi-sites</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque établissement nécessite le même travail.<br />La plupart des équipes n'en gèrent que quelques-uns.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Pour un seul établissement, le SEO local est gérable : mettez à jour la fiche GBP, corrigez les citations quand elles se dégradent, répondez aux avis, surveillez quelques mots-clés. Peut-être 3-4 heures par semaine. Ça fonctionne pour un établissement.</p>
            <p>Multipliez par 20 établissements. Le travail est identique par établissement — il se répète 20 fois. En pratique, certains établissements reçoivent de l'attention et la majorité n'en reçoit pas. Les établissements soignés se classent. Ceux négligés non. Les performances de votre portefeuille sont limitées par le nombre d'établissements que votre équipe peut gérer manuellement.</p>
            <p class="font-semibold text-[#111827]">Stacc supprime cette contrainte. L'automatisation gère le travail quotidien répétitif pour chaque établissement simultanément — activité GBP, surveillance des citations, suivi de positions, alertes avis — pour que votre effort humain aille à la stratégie, pas à l'exécution. Votre portefeuille de 50 établissements reçoit le même soin constant que votre concurrent avec un seul site donne à sa fiche unique.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- GRILLE DE FONCTIONNALITÉS -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce que Stacc automatise</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque tâche SEO multi-sites.<br />En exécution automatique.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP par établissement', body: '30 posts/mois localisés par site — créés et publiés automatiquement. Profils toujours actifs, aucun travail manuel.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Suivi centralisé des positions', body: 'Tous les sites et mots-clés suivis quotidiennement depuis un seul dashboard. Local Pack, Maps et organique.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Cohérence des citations', body: 'NAP maintenu à jour dans 50+ annuaires pour tous les sites. Corrections automatisées, alertes sur les divergences.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Monitoring des avis', body: 'Alertes en temps réel pour tous les sites + modèles de réponse. Répondez directement depuis le dashboard.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Rapports multi-sites', body: 'Rapports par site ou consolidés, créés et livrés automatiquement. Marque blanche pour livraison clients.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Vue portfolio', body: 'Tous vos sites en une vue avec drill-down par établissement. Identifiez les sous-performeurs en un coup d\'œil.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités clés</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque établissement optimisé.<br />Chaque jour. Automatiquement.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Section 1 : Chaque site optimisé chaque jour -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Exécution automatisée par établissement</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Chaque site optimisé chaque jour.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Chaque établissement de votre portefeuille reçoit la même attention quotidienne — 30 posts GBP localisés par mois, suivi de positions actualisé chaque matin, surveillance des citations en continu. L'automatisation ne se fatigue pas, ne saute pas un établissement, et ne prend pas de vacances. Votre portefeuille entier est traité comme si vous aviez un spécialiste SEO dédié pour chaque site.
              </p>
              <a href="/fr/logiciel-google-business-profile/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Gestion GBP par établissement
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Activité quotidienne — 3 établissements</p>
              {[
                { site: 'Paris 11e', post: 'Post publié', rank: '#1', change: '+2', trend: 'up' },
                { site: 'Lyon Centre', post: 'Post publié', rank: '#2', change: '+1', trend: 'up' },
                { site: 'Bordeaux Sud', post: 'Post publié', rank: '#3', change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#4f39f6] text-white font-mono text-[10px] font-bold">{r.site[0]}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.site}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{r.post} · Position {r.rank}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Mis à jour quotidiennement · Tous les établissements</p>
            </div>
          </div>

          <!-- Section 2 : Vue portfolio -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Vue portfolio — tous les établissements</p>
              {[
                { site: 'Paris 11e', kw: 'Restaurant gastronomique Paris', pos: 1, trend: 'up' },
                { site: 'Lyon Centre', kw: 'Restaurant Lyon centre', pos: 2, trend: 'up' },
                { site: 'Bordeaux Sud', kw: 'Restaurant Bordeaux', pos: 2, trend: 'up' },
                { site: 'Marseille Nord', kw: 'Restaurant Marseille', pos: 4, trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.site}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Suivi quotidien · Local Pack + Organique + Maps</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dashboard centralisé</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Visibilité portfolio en un coup d'œil.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Un dashboard unique regroupe tous vos établissements. Positions, activité GBP, état des citations, avis récents — tout visible en un coup d'œil. Drill-down sur n'importe quel établissement pour le détail complet. Identifiez les sous-performeurs avant qu'ils descendent davantage. Agissez sur la stratégie, pas sur la collecte de données.
              </p>
              <a href="/fr/logiciel-suivi-positions/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Suivi de positions multi-sites
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Section 3 : Rapports automatiques -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reporting automatisé</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Rapports qui s'envoient seuls.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Configurez le template une fois par établissement. Stacc collecte les données, formate le rapport et le livre automatiquement selon votre calendrier. Rapports par établissement ou consolidés pour l'ensemble du portefeuille. Votre équipe ne touche plus jamais un rapport — les clients reçoivent leurs données sans que personne n'y pense.
              </p>
              <a href="/fr/rapports-marque-blanche/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Rapports automatiques multi-sites
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Rapport mensuel portefeuille</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Livraison automatique planifiée</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Envoyé</span>
              </div>
              {[
                { label: 'Établissements couverts', val: '4 / 4 sites' },
                { label: 'Posts GBP publiés', val: '120 automatisés' },
                { label: 'Positions améliorées', val: '+14 ce mois' },
                { label: 'Livraison', val: '1er du mois, 9h00' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
