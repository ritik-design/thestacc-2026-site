---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/fr/HeaderFr.astro';
import Footer from '../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Qu'est-ce qu'un logiciel SEO ?", a: "Un logiciel SEO aide les entreprises à gérer les signaux qui déterminent leur positionnement sur les moteurs de recherche — y compris les classements de mots-clés, l'optimisation on-page, les citations, l'activité sur Google Business Profile et la génération d'avis. Le logiciel SEO moderne va au-delà des tableaux de bord pour automatiser le travail d'exécution réel." },
  { q: "En quoi theStacc diffère-t-il des autres logiciels SEO ?", a: "La plupart des outils SEO sont des outils de données. Ils suivent ce qui se passe mais vous laissent tout faire vous-même. Stacc fait réellement le travail — publie des posts GBP, synchronise les citations, surveille les avis en temps réel et livre des rapports marque blanche selon un calendrier. C'est une plateforme d'exécution, pas juste un tableau de bord." },
  { q: "Ai-je besoin de plusieurs outils SEO si j'utilise Stacc ?", a: "Pour le SEO local, non. Stacc remplace les outils de suivi de positions autonomes, les outils de gestion GBP, les services de citations, les outils de surveillance des avis et les logiciels de reporting. Les agences éliminent généralement 4 à 5 abonnements séparés lorsqu'elles passent à Stacc." },
  { q: "Stacc fonctionne-t-il pour les entreprises multi-sites ?", a: "Oui — la gestion multi-sites est une capacité fondamentale. Gérez chaque établissement depuis un tableau de bord, publiez des posts GBP sur tous les établissements simultanément et générez des rapports de performance individuels ou agrégés par établissement." },
  { q: "Stacc est-il conçu pour les agences ou les équipes internes ?", a: "Les deux. Les agences obtiennent des rapports marque blanche, la gestion multi-comptes et des portails clients brandés. Les équipes internes d'entreprises multi-sites obtiennent des outils de gestion en masse et des rapports automatiques pour les parties prenantes. La même plateforme sert les deux flux de travail sans compromis." },
  { q: "Stacc inclut-il des rapports marque blanche ?", a: "Oui. Les rapports marque blanche — avec votre logo, couleurs de marque et domaine personnalisé — sont disponibles sur les plans Growth et Scale. Les rapports se génèrent et se livrent avec votre marque. Vos clients ne voient jamais le branding Stacc." },
  { q: "Combien coûte Stacc ?", a: "Les plans commencent à 49 $/mois pour le module SEO Local, qui inclut la publication de posts GBP, le suivi de positions quotidien, la surveillance des avis et la gestion des citations. Le module Blog SEO est à 99 $/mois. Le module Réseaux Sociaux est à 49 $/mois. Tous les modules incluent un essai gratuit de 14 jours." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Logiciel SEO",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "fr",
      "description": "Logiciel SEO tout-en-un qui automatise les classements locaux, les citations, les avis, la gestion GBP et les rapports pour les entreprises et les agences.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Logiciel SEO", "item": "https://thestacc.com/fr/logiciel-seo/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Logiciel SEO — Automatisation SEO Local Tout-en-Un à 49 $/Mois | theStacc"
  description="Arrêtez de gérer 5 outils SEO. theStacc est le logiciel SEO tout-en-un qui automatise les classements locaux, les citations, les avis et les rapports pour les entreprises et les agences."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Logiciel SEO · À partir de 49 $/mois</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Logiciel SEO qui fait<br />le travail.
            <span style="color:#4f39f6;"> Pas seulement le suivi.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Vous cherchez un logiciel SEO parce que vous êtes fatigué de payer des outils qui vous donnent des données mais vous laissent tout le travail. Stacc est différent — automatise les posts GBP, le suivi de positions, la gestion des citations, la surveillance des avis et les rapports marque blanche. Une plateforme. Tout automatisé.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer pour 1 $ aujourd'hui
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/tarifs/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Voir les tarifs
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Sans carte de crédit · Résiliable à tout moment
          </p>
          <!-- TRUST BAR -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ entreprises et agences</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Configuration &lt; 5 min</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLÈME -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème avec la plupart des logiciels SEO</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vous payez cinq outils<br />et faites encore tout le travail.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Ça se passe généralement comme ça. Vous souscrivez à un outil de suivi de positions. Puis vous ajoutez un outil pour les citations. Puis vous achetez un outil de gestion GBP. Puis vous ajoutez une plateforme pour les avis. Puis vous construisez vos rapports mensuels dans une feuille de calcul parce qu'aucun de ces outils ne communique avec les autres.
            </p>
            <p>
              Maintenant vous avez cinq abonnements, cinq connexions, et vous passez plus de temps à gérer votre stack d'outils SEO qu'à réellement gérer le SEO. <strong class="text-[#111827]">Les outils sont devenus le travail.</strong>
            </p>
            <p class="font-semibold text-[#111827]">
              Les agences qui gagnent sur le SEO local maintenant ne travaillent pas plus. Elles ont consolidé tout dans une seule plateforme automatisée et laissé le logiciel gérer l'exécution. C'est Stacc.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- CAPACITÉS -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ce qu'inclut Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Une plateforme. Chaque levier SEO.<br />Tout automatisé.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'SEO Local — 49 $/mois', body: 'Publication GBP (30/mois), suivi de positions quotidien, surveillance des avis, gestion des citations sur 50+ annuaires.' },
            { icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Blog SEO — 99 $/mois', body: '30 articles SEO par mois publiés directement sur votre site. Recherche de mots-clés et liens internes optimisés inclus.' },
            { icon: 'M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z M12 8v8 M8 12h8', title: 'Réseaux Sociaux — 49 $/mois', body: 'Posts quotidiens avec images sur Instagram, LinkedIn, Facebook, X. Rédigés et programmés automatiquement.' },
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Rapports Marque Blanche', body: 'Rapports générés, brandés avec votre logo et livrés automatiquement. Plans Growth et Scale.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Gestion Multi-Sites', body: 'Dashboard portfolio pour toutes vos adresses. Mises à jour en masse, suivi de performance agrégé.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Intégrations', body: 'Google Business Profile, WordPress, Webflow, Ghost, Wix, Facebook, Instagram. Toutes incluses sans frais supplémentaires.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- MÉTRIQUES DARK -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { value: '5', label: 'Outils remplacés par un compte Stacc', sub: 'Suivi, citations, avis, GBP, reporting' },
            { value: '8 h', label: 'Économisées par client et par mois', sub: 'Sur les activités SEO manuelles' },
            { value: '4,7×', label: 'Amélioration moyenne du classement Maps', sub: "Dans les 90 jours suivant l'automatisation" },
          ].map(s => (
            <div class="text-center">
              <p class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{s.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="fonctionnalites" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Fonctionnalités clés</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Remplacez cinq outils par un seul.<br />Réduisez votre charge de travail de moitié.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Suivi de positions -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Suivi de Positions Automatisé</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Chaque mot-clé, chaque établissement, chaque matin — sans ouvrir un seul outil.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc suit vos classements dans le local 3-pack, Google Maps et les résultats organiques chaque jour pour tous vos mots-clés importants. Des alertes se déclenchent automatiquement quand les positions bougent significativement. Vous commencez la journée en sachant exactement où vous en êtes — sans ouvrir un seul tableau de bord. Pour les agences qui gèrent 20 clients, c'est la différence entre passer le mardi sur les vérifications de classement ou sur la stratégie.
              </p>
              <a href="/fr/fonctionnalites/suivi-positions/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir le suivi de positions en détail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Mise à jour des classements — tous les clients</p>
              {[
                { client: 'Plomberie Durand', kw: 'plombier près de moi', pos: 1, change: '+3', trend: 'up' },
                { client: 'Cabinet Dentaire Martin', kw: 'dentiste [ville]', pos: 2, change: '+2', trend: 'up' },
                { client: 'CVC Élite', kw: 'réparation chauffage près de moi', pos: 2, change: '+5', trend: 'up' },
                { client: 'Cabinet Juridique Métro', kw: 'avocat près de moi', pos: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Mis à jour quotidiennement · Pack local + organique + Maps</p>
            </div>
          </div>

          <!-- Gestion des citations -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Santé des citations — tous les annuaires</p>
              {[
                { dir: 'Google Business Profile', status: 'Correct', ok: true },
                { dir: 'Yelp', status: 'Correct', ok: true },
                { dir: 'Apple Plans', status: 'Correct', ok: true },
                { dir: 'Pages Jaunes', status: 'Incohérence corrigée', ok: true },
                { dir: 'Foursquare', status: 'Auto-corrigé', ok: true },
              ].map(c => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{c.dir}</span>
                  <span class={`flex items-center gap-1.5 font-mono text-[11px] font-semibold ${c.ok ? 'text-[#059669]' : 'text-[#dc2626]'}`}>
                    {c.ok ? '✓' : '✗'} {c.status}
                  </span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ annuaires surveillés · Corrections automatisées</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Gestion des Citations</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Les citations incohérentes pénalisent vos classements. Stacc les trouve et les corrige automatiquement.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google croise vos informations d'entreprise sur 50+ annuaires pour vérifier votre identité. Quand votre nom, adresse ou numéro de téléphone ne correspond pas, vos classements locaux en souffrent. Stacc surveille chaque annuaire en continu — et quand il trouve une incohérence, il la corrige automatiquement. Fini les audits de citations trimestriels. Fini les outils de soumission manuels.
              </p>
              <a href="/fr/logiciel-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir la gestion des citations
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Rapports clients -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rapports Clients Automatisés</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Des rapports qui se génèrent et s'envoient seuls. Sous votre marque. Chaque semaine.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Pour la plupart des agences, le reporting client est une charge qui ne disparaît jamais — des heures chaque mois que vous ne pouvez ni facturer ni éliminer. Stacc les élimine. Configurez votre modèle une fois par client. Stacc génère le rapport, le formate avec votre branding et le livre dans la boîte mail du client selon le calendrier. Le moment où le reporting devient automatique est le moment où vous pouvez scaler au-delà de votre plafond actuel.
              </p>
              <a href="/fr/solutions/agences/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Voir Stacc pour les agences
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Votre Agence</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Rapport SEO mensuel de performance</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Envoyé</span>
              </div>
              {[
                { label: 'Mots-clés passés dans le top 3', val: '+8 ce mois' },
