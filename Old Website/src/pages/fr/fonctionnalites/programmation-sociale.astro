---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const faqs = [
  {
    q: "Le contenu publié sonnera-t-il vraiment comme ma marque ?",
    a: "Oui. Lors de la configuration, Stacc analyse votre site web et vos publications sociales existantes pour apprendre votre ton de voix. Les publications générées correspondent à votre style — professionnel, accessible, technique ou décontracté. 94% des clients disent que le contenu leur ressemble après le premier mois.",
  },
  {
    q: "Puis-je choisir les sujets et thèmes des publications ?",
    a: "Oui. Vous définissez les thèmes prioritaires — vos services, vos valeurs, l'actualité de votre secteur, les saisons. Stacc utilise ces thèmes pour générer du contenu pertinent. Vous pouvez aussi suggérer des sujets spécifiques à tout moment.",
  },
  {
    q: "Les publications sur Instagram incluent-elles des images ?",
    a: "Oui. Stacc génère automatiquement des images pour les publications Instagram et Facebook qui le nécessitent. Les images sont créées dans votre palette de couleurs et le style de votre marque.",
  },
  {
    q: "Puis-je réviser les publications avant qu'elles soient publiées ?",
    a: "Oui. Vous pouvez activer un mode d'approbation où vous révisez chaque publication dans une file d'attente avant qu'elle parte. Ou activer la publication automatique complète si vous faites confiance au système. La plupart des clients commencent avec l'approbation et passent en automatique après 2 à 4 semaines.",
  },
  {
    q: "Les publications sont-elles adaptées à chaque réseau ou c'est le même contenu partout ?",
    a: "Du contenu natif pour chaque réseau. Un post LinkedIn est un article court avec un angle professionnel. Un post Instagram est visuel avec des hashtags. Un tweet X est concis et direct. Un post Facebook est conversationnel. Pas de copier-coller entre plateformes — chaque post est conçu pour son réseau.",
  },
  {
    q: "Que se passe-t-il si je veux supprimer une publication programée ?",
    a: "Vous pouvez voir, modifier ou supprimer n'importe quelle publication dans la file d'attente depuis votre tableau de bord Stacc, avant qu'elle soit publiée. Les modifications sont reflétées immédiatement.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Programmation des Réseaux Sociaux",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "fr",
      "description": "Stacc génère et publie du contenu natif sur vos réseaux sociaux chaque jour. Instagram, LinkedIn, X et Facebook — planifiés et publiés automatiquement. Sans community manager.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Fonctionnalités", "item": "https://thestacc.com/fr/fonctionnalites/" },
        { "@type": "ListItem", "position": 3, "name": "Programmation Sociale", "item": "https://thestacc.com/fr/fonctionnalites/programmation-sociale/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "fr",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Programmation des Réseaux Sociaux — Publications IA Automatiques sur Instagram, LinkedIn, X, Facebook | theStacc"
  description="Stacc génère et publie du contenu natif sur vos réseaux sociaux chaque jour. Instagram, LinkedIn, X et Facebook — planifiés et publiés automatiquement. Sans community manager."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Réseaux Sociaux · Module Automatisation</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            L'algorithme récompense la régularité.<br />
            <span style="color:#4f39f6;">Pas les bonnes intentions.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc génère du contenu natif pour Instagram, LinkedIn, X et Facebook chaque jour. Publications adaptées à chaque plateforme, images IA incluses, publiées automatiquement selon votre calendrier. Sans community manager. Sans nuits à programmer des posts.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Automatiser mes réseaux sociaux
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/tarifs/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Voir les tarifs
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            49 $/mois · Essai gratuit 14 jours · Sans carte bancaire
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '4 plateformes', label: 'Instagram · LinkedIn · X · Facebook' },
              { value: 'Quotidien', label: 'Publications générées et publiées' },
              { value: '98%', label: 'Moins cher qu\'un community manager' },
              { value: '4,9★', label: 'Note moyenne Stacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            La régularité sur les réseaux sociaux<br />est impossible à maintenir manuellement.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Tout le monde commence avec de bonnes intentions. Personne ne maintient. L'algorithme punit l'irrégularité. Et créer du contenu natif pour quatre plateformes différentes, chaque jour, n'est pas une tâche — c'est un poste à plein temps.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Vous commencez à publier régulièrement, puis vous arrêtez. L\'algorithme s\'en souvient.',
              body: 'Deux semaines de publication quotidienne, puis une semaine de silence. L\'algorithme punit les comptes irréguliers par une portée réduite. Recommencer depuis zéro coûte des semaines. Maintenir la cohérence manuellement est impossible quand vous gérez une vraie entreprise.',
            },
            {
              icon: 'M4 6h16M4 12h16M4 18h7',
              title: 'Créer du contenu différent pour 4 plateformes est un travail à plein temps.',
              body: 'Ce qui fonctionne sur LinkedIn (articles longs, insights professionnels) ne fonctionne pas sur Instagram (visuels, courts, émotionnel) ou X (concis, direct). Créer du contenu natif adapté à chaque plateforme pour chaque jour de la semaine, c\'est 15 à 20 heures par semaine — même pour une petite équipe.',
            },
            {
              icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Un community manager coûte 2 500 à 5 000 € par mois. Et ils prennent des vacances.',
              body: 'Pour couvrir 4 plateformes avec du contenu de qualité quotidien, un community manager expérimenté est le minimum. Sans budget pour ça, vous publiez quand vous trouvez le temps — ce qui veut dire rarement, et pas toujours bien.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça fonctionne</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connectez. Configurez. Publiez automatiquement.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1', title: 'Connectez vos comptes de réseaux sociaux', body: 'Liez votre Instagram Business, page LinkedIn, profil X et page Facebook à Stacc. Définissez votre ton de voix et les thèmes de votre activité. Configuration en moins de 15 minutes.' },
            { n: '02', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', title: 'L\'IA génère du contenu natif pour chaque plateforme', body: 'Chaque jour, Stacc crée des publications adaptées à chaque réseau — format, longueur, ton et hashtags différents selon la plateforme. Les articles de votre blog deviennent du contenu social. Votre activité génère des angles de publication. Des images IA sont créées pour les plateformes visuelles.' },
            { n: '03', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Le contenu se publie selon votre calendrier', body: 'Stacc publie automatiquement selon le calendrier optimal pour chaque plateforme. Vous pouvez réviser le contenu avant publication ou activer la publication automatique. Vos comptes restent actifs même quand vous ne pensez pas aux réseaux sociaux.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tout inclus</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Automatisation sociale complète<br />sans community manager.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Contenu natif par plateforme', body: 'Publications adaptées au format et au ton de chaque réseau. Ce que vous publiez sur LinkedIn n\'est pas la même chose que ce que vous publiez sur Instagram — ni la même longueur, ni le même style.', icon: 'M4 6h16M4 12h8m-8 6h16' },
            { title: 'Génération d\'images IA', body: 'Images créées automatiquement pour accompagner vos publications sur les plateformes visuelles. Pas de besoin d\'un designer ou d\'abonnement Canva supplémentaire.', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { title: 'Calendrier de publication optimisé', body: 'Stacc publie aux heures où votre audience est la plus active sur chaque plateforme. Maximisez la portée sans avoir à deviner les meilleurs moments.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
            { title: 'Recyclage du contenu blog', body: 'Chaque article de blog publié par Stacc devient automatiquement plusieurs publications sociales. Un article = 4 à 8 posts différents selon les plateformes.', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
            { title: 'Approbation ou publication automatique', body: 'Révisez chaque publication avant qu\'elle parte, ou activez la publication automatique complète. Votre choix selon votre niveau de contrôle préféré.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
            { title: 'Analytiques multi-plateformes', body: 'Suivez la portée, l\'engagement et la croissance de vos abonnés sur chaque plateforme depuis un seul tableau de bord. Identifiez ce qui résonne et ce qui ne fonctionne pas.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Résultats</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Ce que la régularité automatisée<br />fait à votre présence sociale.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '10×', label: 'Plus de publications vs. entreprise type', sub: 'avec une publication régulière automatisée' },
            { value: '98%', label: 'Moins cher qu\'un community manager', sub: 'pour le même volume de contenu quotidien' },
            { value: '5h+', label: 'Économisées par semaine', sub: 'sur la création et planification de contenu social' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "On avait essayé 3 fois de mettre en place une stratégie réseaux sociaux. On publiait 2 semaines, puis on s'arrêtait. Avec Stacc on publie chaque jour depuis 4 mois. Notre nombre d'abonnés LinkedIn a doublé. On reçoit des demandes directes depuis Instagram. C'est le premier outil qui a vraiment résolu le problème de régularité."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">IF</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Isabelle F.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Directrice, Cabinet de Conseils · Paris</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">2× abonnés LinkedIn en 4 mois</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Questions fréquentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Questions sur la programmation sociale
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
