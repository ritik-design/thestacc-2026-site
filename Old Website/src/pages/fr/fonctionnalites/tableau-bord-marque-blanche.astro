---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const faqs = [
  {
    q: "Les clients voient-ils vraiment seulement ma marque ?",
    a: "Oui, à 100%. Votre logo apparaît sur le portail, les emails de rapport viennent de votre domaine, le sous-domaine porte votre nom. Il n'y a aucune mention de Stacc visible pour vos clients — ni dans l'interface, ni dans les emails, ni dans les URLs.",
  },
  {
    q: "Le tableau de bord marque blanche est-il disponible sur tous les plans ?",
    a: "Le tableau de bord marque blanche complet — votre logo, vos couleurs, votre domaine — est disponible sur les plans Growth et Scale. Le plan Starter inclut des rapports avec la marque Stacc. Vous pouvez upgrader à tout moment et les configurations existantes sont transférées automatiquement.",
  },
  {
    q: "Puis-je avoir différentes configurations de marque pour différents clients ?",
    a: "La configuration de marque est au niveau de votre agence — un seul logo et une palette de couleurs. Si vous gérez plusieurs marques d'agences distinctes, contactez-nous pour une configuration multi-marques.",
  },
  {
    q: "Combien de temps prend la configuration initiale du portail ?",
    a: "La configuration de base du portail — logo, couleurs, sous-domaine — prend moins de 30 minutes. L'onboarding du premier client prend environ 45 minutes. Après ça, chaque nouveau client prend 5 à 15 minutes selon la complexité.",
  },
  {
    q: "Les clients peuvent-ils modifier leurs propres données ou paramètres ?",
    a: "Non, sauf si vous leur accordez explicitement cette permission. Par défaut, les clients ont un accès en lecture seule à leurs données. Vous décidez quels utilisateurs ont quels droits — consultation, ajout de mots-clés, ou accès administrateur complet.",
  },
  {
    q: "Puis-je revendre Stacc comme service à mes clients ?",
    a: "Oui. De nombreuses agences utilisent Stacc comme plateforme de base pour leurs retainers SEO local. Avec le portail marque blanche, vos clients interagissent avec votre marque à chaque point de contact. Nous ne restreignons pas la revente.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Tableau de Bord Marque Blanche",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "fr",
      "description": "Offrez à vos clients un portail SEO local complet sous votre marque. Votre logo, vos couleurs, votre domaine. Stacc est invisible — votre agence prend le mérite.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Fonctionnalités", "item": "https://thestacc.com/fr/fonctionnalites/" },
        { "@type": "ListItem", "position": 3, "name": "Tableau de Bord Marque Blanche", "item": "https://thestacc.com/fr/fonctionnalites/tableau-bord-marque-blanche/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "fr",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};

const trustStats = [
  { value: "100%", label: "Invisible pour vos clients" },
  { value: "Votre domaine", label: "Portail sur votre URL" },
  { value: "Illimité", label: "Comptes clients" },
  { value: "4,9★", label: "Note moyenne Stacc" },
];

const painPoints = [
  {
    title: "Donner accès à votre outil SaaS à vos clients révèle vos fournisseurs et érode votre valeur.",
    body: "Quand un client voit 'Powered by Stacc' ou 'Powered by [n'importe quel outil]', il commence à se demander pourquoi il vous paie pour ce qu'il pourrait acheter directement. La transparence sur vos outils est une invitation à vous court-circuiter.",
  },
  {
    title: "Des screenshots envoyés par email ne sont pas des rapports professionnels.",
    body: "Copier-coller des graphiques dans un email ou un PDF tous les mois n'est pas du reporting client. C'est du travail manuel qui ne scale pas et qui ne donne pas à vos clients l'expérience professionnelle qu'ils attendent d'une agence.",
  },
  {
    title: "Vos concurrents proposent des portails clients. Vous pas encore.",
    body: "Les agences qui gagnent de gros contrats en 2024 proposent des portails clients professionnels avec accès en temps réel. Si vos prospects comparent votre devis à celui d'un concurrent qui montre un dashboard brandé pendant la réunion de vente, vous partez perdant.",
  },
];

const steps = [
  {
    num: "01",
    title: "Configurez votre portail avec vos éléments de marque",
    body: "Uploadez votre logo, définissez vos couleurs, configurez votre sous-domaine (ex: rapports.votre-agence.fr). Configuration en moins de 30 minutes. Vos clients ne voient jamais Stacc.",
  },
  {
    num: "02",
    title: "Invitez vos clients sur leur portail dédié",
    body: "Chaque client reçoit un accès à son portail avec ses données uniquement. Vous contrôlez exactement ce qu'il peut voir — toutes les données, ou un résumé simplifié. La configuration par client prend 5 minutes.",
  },
  {
    num: "03",
    title: "Vos clients accèdent à leurs données quand ils veulent",
    body: "Positions en temps réel, avis récents, statistiques GBP, historique de progression. Disponible 24h/24 sur votre portail. En plus des rapports automatisés qu'ils reçoivent par email selon votre calendrier.",
  },
];

const capabilities = [
  {
    title: "Portail sur votre domaine",
    body: "Sous-domaine personnalisé (rapports.votre-agence.fr), votre logo, vos couleurs. Aucune mention de Stacc visible par vos clients.",
    icon: "M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9",
  },
  {
    title: "Contrôle granulaire de la visibilité",
    body: "Choisissez exactement quels modules et données chaque client peut voir. Vue complète ou résumé simplifié selon le niveau de sophistication du client.",
    icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z",
  },
  {
    title: "Clients illimités sur tous les plans",
    body: "Pas de limite sur le nombre de comptes clients. Le prix est basé sur le nombre d'établissements gérés, pas de clients.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  },
  {
    title: "Rapports automatisés sous votre marque",
    body: "Les rapports envoyés par email proviennent de votre domaine, portent votre logo. Le branding est cohérent à tous les points de contact client.",
    icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
  {
    title: "Tableau de bord agence global",
    body: "Vous voyez tous vos clients dans votre propre tableau de bord. Quels clients ont besoin d'attention. Quels établissements sous-performent. Vue complète pour votre équipe.",
    icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z",
  },
  {
    title: "Onboarding client en 45 minutes",
    body: "Un nouveau client entièrement configuré — établissements ajoutés, mots-clés définis, GBP connecté, rapports planifiés — en moins de 45 minutes.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
];

const metrics = [
  { value: "45 min", label: "Pour onboarder un nouveau client", sub: "incluant la configuration complète du portail" },
  { value: "60%", label: "De réduction du budget outils moyen", sub: "des agences qui consolident avec Stacc" },
  { value: "4,9★", label: "Note moyenne Stacc", sub: "parmi les agences utilisatrices du marque blanche" },
];
---

<BaseLayout
  title="Tableau de Bord Marque Blanche — Portail Client SEO avec Votre Marque | theStacc"
  description="Offrez à vos clients un portail SEO local complet sous votre marque. Votre logo, vos couleurs, votre domaine. Stacc est invisible — votre agence prend le mérite."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Tableau de Bord Marque Blanche · Pour les Agences</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Vos clients méritent un portail professionnel.<br class="hidden md:block" />
            <span style="color:#4f39f6;">Pas un accès partagé à votre outil.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc vous donne un portail client marque blanche complet — votre logo, vos couleurs, votre domaine. Vos clients se connectent à votre plateforme pour voir leurs positions, avis et performance GBP. Stacc est invisible. Vous récoltez la crédibilité.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/fr/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Configurer mon portail marque blanche
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/fr/tarifs/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              Voir les tarifs
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 jours de garantie · Sans carte bancaire · Annulez quand vous voulez
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {trustStats.map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sans portail brandé, votre agence<br />ressemble à un freelance avec un abonnement.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            La perception de votre agence se construit à chaque point de contact client. Un portail professionnel sous votre marque change la conversation — de prestataire à partenaire stratégique.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {painPoints.map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça fonctionne</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Votre portail configuré en 30 minutes.<br />Vos clients impressionnés à vie.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Une configuration unique pour votre agence. Ensuite, chaque nouveau client est opérationnel en 5 à 15 minutes. Votre marque à chaque point de contact — sans aucune mention de Stacc.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            {steps.map(s => (
              <div class="bg-white px-8 py-10">
                <div class="mb-6 flex items-center justify-between">
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
                  </div>
                  <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.num}</span>
                </div>
                <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
                <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tout inclus</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Chaque fonctionnalité pour positionner<br />votre agence comme un partenaire stratégique.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {capabilities.map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.06) 0%, transparent 70%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white/5 sm:grid-cols-3">
            {metrics.map(m => (
              <div class="px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
                <p class="font-sans text-[3rem] font-bold leading-none text-[#292524]">{m.value}</p>
                <p class="mt-3 font-mono text-[12px] font-semibold uppercase tracking-[0.1em]" style="color:#818cf8;">{m.label}</p>
                <p class="mt-2 font-sans text-[13px]" style="color:#4b5563;">{m.sub}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Le portail marque blanche a changé comment on se présente en réunion commerciale. On ouvre l'ordinateur, on montre le portail brandé à notre prospect, et la question 'qu'est-ce que vous faites pour nous ?' est répondue visuellement en 30 secondes. Notre taux de closing a augmenté de 30% depuis."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">AP</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Alexandre P.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Fondateur, Agence SEO Locale · Lyon</p>
              </div>
              <div class="ml-auto flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">30% de taux de closing en plus</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Questions fréquentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Les questions que tout le monde pose avant de commencer
          </h2>
        </div>

        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button
                class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left"
                aria-expanded={i === 0 ? 'true' : 'false'}
              >
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0 transition-transform" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>

      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Commencez aujourd'hui</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Vos clients méritent un portail à la hauteur
            <span style="color:#818cf8;"> de votre expertise.</span>
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Un portail marque blanche professionnel change la perception de votre agence. De prestataire à partenaire stratégique. Stacc vous donne l'infrastructure — vous prenez le mérite.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/fr/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]"
            >
              Configurer mon portail marque blanche
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/fr/tarifs/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5"
            >
              Voir les tarifs
            </a>
          </div>

          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Sans contrat · RGPD conforme</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
