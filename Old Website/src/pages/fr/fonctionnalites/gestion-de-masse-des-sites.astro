---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/fr/HeaderFr.astro';
import Footer from '../../../components/fr/FooterFr.astro';

const faqs = [
  { q: "Combien d'établissements puis-je gérer simultanément ?", a: "Il n'y a pas de limite pratique. Stacc est conçu pour gérer des portefeuilles à l'échelle entreprise — des clients gèrent 500+ établissements depuis un seul compte. Les opérations en masse fonctionnent de la même façon que vous ayez 10 ou 500 établissements." },
  { q: "Que puis-je mettre à jour en masse sur les établissements ?", a: "Les horaires d'ouverture, horaires des fêtes, numéros de téléphone, adresses, URLs de sites web, descriptions et catégories. Pour Google Business Profile : vous pouvez également mettre à jour en masse les attributs, menus de services et photos de couverture sur tous les établissements simultanément." },
  { q: "Combien de temps faut-il pour ajouter un nouvel établissement ?", a: "Environ 2 minutes. Vous saisissez les informations de base une fois, connectez le profil GBP et autres plateformes, et Stacc propage la configuration dans votre réseau de citations automatiquement. Pas de saisie manuelle annuaire par annuaire." },
  { q: "Puis-je faire des mises à jour différentes pour différents sous-ensembles d'établissements ?", a: "Oui. Vous pouvez regrouper les établissements par région, marque, franchisé ou toute étiquette personnalisée. Les mises à jour en masse peuvent être appliquées au portefeuille complet, à un groupe spécifique ou à des établissements individuels sélectionnés." },
  { q: "Que se passe-t-il si un établissement a une adresse ou un numéro de téléphone unique ?", a: "Les mises à jour en masse gèrent les champs partagés. Pour les champs spécifiques à un établissement comme l'adresse ou le numéro direct, Stacc maintient les données uniques et ne les écrasera pas avec une mise à jour en masse sauf si vous choisissez explicitement de le faire." },
  { q: "Puis-je utiliser une importation CSV pour ajouter des établissements en masse ?", a: "Oui. Stacc supporte l'importation CSV pour la création et les mises à jour d'établissements en masse. Importez une feuille de calcul avec vos données et Stacc mappe les champs automatiquement. Utile pour la configuration initiale de grands portefeuilles." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Gestion en Masse des Sites",
      "inLanguage": "fr",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Mettez à jour 500 établissements en 2 minutes. Modifiez les horaires, adresses, descriptions et données GBP sur l'ensemble de votre portefeuille en une seule action.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://thestacc.com/fr/" },
        { "@type": "ListItem", "position": 2, "name": "Fonctionnalités", "item": "https://thestacc.com/fr/fonctionnalites/" },
        { "@type": "ListItem", "position": 3, "name": "Gestion en Masse des Sites", "item": "https://thestacc.com/fr/fonctionnalites/gestion-de-masse-des-sites/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "fr",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Gestion en Masse des Sites — Mettez à Jour 500 Établissements en 2 Minutes | theStacc"
  description="Arrêtez de mettre à jour vos établissements un par un. La gestion en masse de theStacc vous permet de modifier les horaires, adresses et informations sur l'ensemble de votre portefeuille en une seule action."
  lang="fr"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Gestion en Masse · Module SEO Local</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mettez à jour 500 établissements en<br />
            <span style="color:#4f39f6;">2 minutes. Pas 2 jours.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            La gestion en masse de Stacc vous permet de modifier les horaires, adresses, descriptions et données GBP sur l'ensemble de votre portefeuille en une seule action. Une modification. Tous les établissements. Terminé.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/fr/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Commencer gratuitement
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/fr/tarifs/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Voir les tarifs
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            49 $/mois · Essai gratuit 14 jours · Sans carte bancaire
          </p>
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '500+', label: 'Établissements gérés par une personne' },
              { value: '95%', label: 'Moins de temps par mise à jour' },
              { value: '2 min', label: 'Pour configurer un nouvel établissement' },
              { value: '4,9★', label: 'Note moyenne theStacc' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PROBLEM ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Le problème</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Les mises à jour établissement par établissement<br />ne fonctionnent pas au-delà de cinq sites.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Horaires des fêtes. Nouveau numéro de téléphone. Adresse mise à jour. Chaque modification simple qui devrait prendre deux minutes en prend deux jours quand vous devez ouvrir chaque profil individuellement, faire la modification, la vérifier, puis passer au suivant.
          </p>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Chaque modification prend des heures.', body: 'Se connecter. Naviguer. Trouver l\'établissement. Faire la modification. Vérifier. Se déconnecter. Répéter 50 fois. Une mise à jour d\'horaires sur un portefeuille de 50 établissements est un projet d\'une demi-journée qui devrait prendre 30 secondes.' },
            { icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636', title: 'Les incohérences nuisent aux classements.', body: 'Quand certains établissements ont le nouveau numéro de téléphone et d\'autres encore l\'ancien, vous avez un problème d\'incohérence de citations. Google traite les incohérences NAP comme un signal de qualité négatif — et pénalise les classements locaux en conséquence.' },
            { icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', title: 'Les nouveaux établissements prennent trop de temps.', body: 'Configurer un nouvel établissement signifie saisir manuellement les mêmes données dans 40+ annuaires. La plupart des équipes abandonnent après les 10 premiers et laissent le reste vide — perdant des signaux de classement dès le premier jour.' },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Comment ça fonctionne</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sélectionnez les établissements. Faites la modification.<br />Chaque profil se met à jour instantanément.
          </h2>
        </div>
        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Ajoutez tous vos établissements à votre portefeuille', body: 'Importez via CSV ou ajoutez des établissements individuellement. Connectez le profil GBP et autres plateformes de chaque établissement. Votre portefeuille entier est visible et modifiable depuis un seul tableau de bord dès le premier jour.' },
            { n: '02', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Sélectionnez les établissements et modifiez les champs', body: 'Sélectionnez tous les établissements ou un groupe spécifique. Modifiez n\'importe quel champ dans l\'éditeur en masse — horaires, coordonnées, descriptions, catégories, attributs. Votre modification s\'applique à chaque établissement sélectionné simultanément.' },
            { n: '03', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Les modifications se propagent sur toutes les plateformes', body: 'Stacc pousse la mise à jour vers GBP, les annuaires de citations et toute autre plateforme connectée simultanément. Chaque établissement affiche des informations cohérentes et exactes en quelques minutes — pas en quelques jours.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tout inclus</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Toutes les capacités de gestion en masse.<br />Conçu pour les portefeuilles de toute taille.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Édition en masse des champs', body: 'Mettez à jour n\'importe quel champ — horaires, téléphone, adresse, description, catégories, attributs — sur n\'importe quelle sélection d\'établissements en une seule action.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Horaires des fêtes en masse', body: 'Définissez les horaires des fêtes sur l\'ensemble de votre portefeuille en une seule action avant les périodes de fermeture. Pas d\'établissements oubliés.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Import et export CSV', body: 'Importez une feuille de calcul pour créer ou mettre à jour des centaines d\'établissements à la fois. Exportez votre portefeuille complet en CSV à tout moment.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Groupes et étiquettes d\'établissements', body: 'Organisez les établissements par région, marque, franchisé ou étiquette personnalisée. Appliquez des mises à jour en masse à des groupes spécifiques quand les modifications sont régionales.' },
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Synchronisation GBP automatique', body: 'Les modifications sont poussées vers Google Business Profile instantanément et automatiquement. Pas de connexions GBP manuelles. Vos données GBP restent à jour à grande échelle.' },
            { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Surveillance de la cohérence des données', body: 'Stacc surveille les incohérences NAP introduites par des suggestions d\'utilisateurs ou des erreurs d\'annuaires. Les écarts sont signalés et corrigés en masse avant d\'affecter vos classements.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Résultats</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Ce que la gestion en masse fait<br />pour les équipes multi-établissements.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '500+', label: 'Établissements gérés par une seule personne', sub: 'Sans personnel supplémentaire' },
            { value: '95%', label: 'Moins de temps par mise à jour de portefeuille', sub: 'Édition en masse vs établissement par établissement' },
            { value: '2 min', label: 'Pour configurer un nouvel établissement', sub: 'De zéro à entièrement configuré' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "On ouvrait un nouvel établissement toutes les deux semaines l'an dernier. Avant Stacc, la configuration était un projet de deux jours par établissement. Maintenant c'est moins de 10 minutes depuis l'adresse jusqu'à ce qu'on soit en ligne dans tous les annuaires."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">MW</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Marc W.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Directeur des Opérations · Groupe de 60 restaurants</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Questions fréquentes</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Questions sur la gestion en masse des sites
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
