---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { SITE_URL } from '../../utils/schema';

const pageUrl = `${SITE_URL}/case-studies/solar-engineering-services/`;
const pageTitle = 'How the engineering firm Went From 0 to 20 Leads/Week With Automated SEO | theStacc';
const pageDesc = 'See how a solar engineering company automated its entire SEO workflow — from keyword research to publishing — and generated 20+ qualified leads per week in 4 months.';

const kpis = [
  { label: 'Weekly Leads', value: '20+', sub: 'from 0', icon: '' },
  { label: 'Blogs Published', value: '120+', sub: 'in 4 months', icon: '' },
  { label: 'Keywords Ranked', value: '340+', sub: 'page 1', icon: '' },
  { label: 'Time Saved', value: '85%', sub: 'per month', icon: '' },
];

const painPoints = [
  { title: 'Manual Everything', desc: 'Keyword research, writing, optimization, and publishing all done by hand. Every blog took 8+ hours from idea to live.' },
  { title: 'Inconsistent Publishing', desc: 'Content went live in bursts followed by weeks of silence. Search engines reward consistency — the team could not deliver it.' },
  { title: 'Quality vs. Scale Tradeoff', desc: 'When they tried to publish more, quality dropped. When they focused on quality, volume disappeared. No sustainable middle ground.' },
  { title: 'SEO Operations Too Heavy', desc: 'Engineers and project managers were pulled into content workflows. SEO became a distraction from core design and engineering work.' },
];

const auditFindings = [
  { num: '0', label: 'Organic Leads/Week', desc: 'Website traffic existed but converted poorly. No dedicated landing pages, no clear conversion paths, no lead magnets.' },
  { num: '12', label: 'Total Blog Posts', desc: 'Published sporadically over 2 years. Most were outdated, thin, or targeting low-intent keywords with no search volume.' },
  { num: '0%', label: 'Publishing Automation', desc: 'Every step was manual — from keyword research in spreadsheets to uploading in WordPress. Zero workflow automation.' },
  { num: '4', label: 'Competitors Outranking', desc: 'Four direct competitors dominated high-intent solar engineering keywords. the engineering firm was invisible for terms their buyers searched.' },
  { num: '3.8s', label: 'Avg Page Load', desc: 'Unoptimized images, no caching strategy, and bloated scripts hurt Core Web Vitals and rankings before content even had a chance.' },
  { num: '0', label: 'Internal Link Structure', desc: 'Blog posts existed in isolation. No topic clusters, no pillar pages, no strategic internal linking to distribute authority.' },
];

const automationStack = [
  { title: 'Keyword Research', desc: 'theStacc continuously discovers high-intent solar engineering keywords, maps search volume and competition, and surfaces opportunities automatically.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
  { title: 'Content Generation', desc: 'AI writes SEO-optimized articles with proper structure, internal links, meta tags, and brand voice — no manual drafting required.', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
  { title: 'Auto-Publishing', desc: 'Articles publish directly to the CMS on a set schedule. No manual uploads, no formatting fixes, no missed deadlines.', icon: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12' },
  { title: 'Internal Linking', desc: 'The system automatically builds intelligent internal links between related articles, creating topic clusters that strengthen domain authority.', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1' },
];

const phases = [
  { n: '01', title: 'Foundation + Audit', desc: 'Fixed technical issues, implemented schema markup, optimized page speed, and built a conversion-focused landing page structure.' },
  { n: '02', title: 'Content Engine Activation', desc: 'Deployed automated keyword research and began publishing 30+ SEO-optimized articles per month targeting solar engineering intent.' },
  { n: '03', title: 'Topic Cluster Build', desc: 'Organized content into pillar-cluster structures around core services: residential design, commercial engineering, permitting, and utility-scale PV.' },
  { n: '04', title: 'Conversion Optimization', desc: 'Added lead capture forms, service-specific CTAs, and consultation booking flows to convert rising traffic into qualified leads.' },
];

const beforeAfter = [
  { metric: 'Weekly Leads', before: '0', after: '20+' },
  { metric: 'Monthly Blogs', before: '0-1', after: '30+' },
  { metric: 'Page 1 Keywords', before: '12', after: '340+' },
  { metric: 'Indexed Pages', before: '18', after: '150+' },
  { metric: 'Organic Traffic', before: '120/mo', after: '4,800/mo' },
  { metric: 'SEO Time/Week', before: '25 hrs', after: '3 hrs' },
];

const faqs = [
  { q: 'How quickly did leads start coming in?', a: 'The first organic leads appeared in week 3 after publishing began. By week 8, the company was consistently seeing 10+ leads per week. The 20+ per week milestone was hit in month 4 as topic clusters matured and rankings stabilized.' },
  { q: 'What kind of content performed best?', a: 'Service-specific landing pages and comparison content drove the highest conversions. Articles like "commercial solar engineering vs in-house design" and "solar permit drawing standards by state" attracted qualified EPC decision-makers.' },
  { q: 'Did quality suffer from automation?', a: 'No. The the engineering firm team specifically noted that content quality remained strong while velocity increased 30x. Every article goes through theStacc\'s quality layer before publishing.' },
  { q: 'How much team time is required now?', a: 'Approximately 3 hours per week for review and light editing. Previously, the team spent 25+ hours per week on SEO-related tasks. The operational reduction is 85%.' },
  { q: 'What about technical SEO and site speed?', a: 'theStacc\'s audit identified and fixed load time issues, missing schema, and broken links in week 1. Core Web Vitals improved from "Poor" to "Good" within the first month.' },
  { q: 'Can this work for other service businesses?', a: 'Yes. The automation framework is industry-agnostic. Similar results have been achieved for HVAC contractors, dental practices, real estate agencies, legal services, and other B2B service companies.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDesc,
  image: `${SITE_URL}/blogs-preview-images/heaven-designs-case-study.webp`,
  datePublished: '2025-05-01',
  dateModified: '2025-05-01',
  author: { '@type': 'Organization', name: 'theStacc' },
  publisher: { '@type': 'Organization', name: 'theStacc', logo: { '@type': 'ImageObject', url: `${SITE_URL}/favicon.svg` } },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Case Studies', item: `${SITE_URL}/case-studies/` },
    { '@type': 'ListItem', position: 3, name: 'the engineering firm Case Study', item: pageUrl },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDesc} ogImage="/blogs-preview-images/heaven-designs-case-study.webp">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ═══════ DARK HERO ═══════ -->
    <section class="relative overflow-hidden border-b border-[#1e1e2e]" style="background:#0a0a0f;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(79,57,246,0.06) 1px,transparent 1px),linear-gradient(to bottom,rgba(79,57,246,0.06) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse at 50% 0%,black 30%,transparent 75%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -10%,rgba(79,57,246,0.22) 0%,transparent 60%);"></div>
      <div class="container-x relative z-10 pt-12 pb-10 md:pt-16 md:pb-12">
        <div class="mx-auto max-w-[860px] text-center">
          <div class="inline-flex items-center gap-2 rounded-full border border-[#22c55e]/30 bg-[#22c55e]/10 px-3 py-1.5">
            <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#22c55e] opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-[#22c55e]"></span></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#22c55e]">Live Case Study — May 2025</span>
          </div>
          <h1 class="mt-5 font-sans text-[34px] font-bold leading-[1.1] tracking-[-0.03em] text-white md:text-[52px]">
            From <span class="text-[#ef4444]">0</span> to <span class="text-[#22c55e]">20+</span> Leads/Week in 4 Months
          </h1>
          <p class="mx-auto mt-4 max-w-[600px] font-sans text-[16px] leading-[1.7] text-[#a1a1aa]">
            How the engineering firm automated its entire SEO content engine — keyword research, writing, optimization, and publishing — and turned organic search into a consistent lead channel.
          </p>
        </div>

        <!-- KPI Cards -->
        <div class="mx-auto mt-10 grid max-w-[960px] grid-cols-2 gap-3 md:grid-cols-4">
          {kpis.map((k) => (
            <div class="rounded-xl border border-[#1e1e2e] bg-[#111118] p-4 text-center transition-colors hover:border-[#4f39f6]/40">
              <p class="font-mono text-[24px] font-bold tracking-tight text-white md:text-[28px]">{k.value}</p>
              {k.sub && <p class="font-mono text-[11px] text-[#71717a]">{k.sub}</p>}
              <p class="mt-1 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">{k.label}</p>
            </div>
          ))}
        </div>

        <!-- Growth chart -->
        <div class="mx-auto mt-8 max-w-[720px]">
          <canvas id="leadsChart" width="720" height="240" class="w-full"></canvas>
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: SNAPSHOT ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-10">
      <div class="mx-auto max-w-[1200px]">
        <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">At a Glance</p>
            <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">Company Snapshot</h2>
          </div>
          <a href="#automation" class="inline-flex items-center gap-1.5 font-mono text-[12px] font-semibold uppercase tracking-[0.06em] text-[#4f39f6] transition-colors hover:text-[#615fff]">
            Jump to Automation
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
        </div>
        <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-4">
          {[
            { label: 'Industry', value: 'Solar Engineering & Design' },
            { label: 'Company Size', value: '50+ engineers' },
            { label: 'Location', value: 'Surat, Gujarat, India' },
            { label: 'Clients', value: 'EPCs globally' },
            { label: 'Campaign Start', value: 'January 2025' },
            { label: 'Campaign End', value: 'April 2025' },
            { label: 'Primary Module', value: 'Blog SEO' },
            { label: 'Publishing Rate', value: '30+ blogs/mo' },
          ].map((item) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.1em] text-[#a8a29e]">{item.label}</p>
              <p class="mt-1 font-sans text-[15px] font-semibold text-[#292524]">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: THE PROBLEM ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">The Challenge</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">SEO Was Operationally Unsustainable</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          the engineering firm understood the value of SEO. But every piece of content required 8+ hours of manual work across research, writing, optimization, and publishing. The team could not scale it.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
          {painPoints.map((card) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5 transition-shadow hover:shadow-sm">
              <div class="flex items-start gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#fef2f2]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </div>
                <div>
                  <h3 class="font-sans text-[15px] font-semibold text-[#292524]">{card.title}</h3>
                  <p class="mt-1 font-sans text-[14px] leading-[1.6] text-[#57534e]">{card.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 rounded-xl border border-[#fee2e2] bg-[#fef2f2] p-5">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#dc2626]">Starting Point — December 2024</p>
          <div class="mt-3 grid grid-cols-2 gap-4 md:grid-cols-4">
            {[
              { label: 'Weekly Leads', value: '0' },
              { label: 'Total Blog Posts', value: '12' },
              { label: 'SEO Time/Week', value: '25 hrs' },
              { label: 'Page 1 Keywords', value: '12' },
            ].map((s) => (
              <div>
                <p class="font-mono text-[20px] font-bold text-[#dc2626]">{s.value}</p>
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.08em] text-[#a8a29e]">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: AUTOMATION STACK ═══════ -->
    <section id="automation" class="border-b border-[#e7e5e4] bg-white px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">The Automation Layer</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">What Got Automated</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          theStacc replaced the entire manual SEO workflow with an automated system that runs continuously — from keyword discovery to published article.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
          {automationStack.map((item) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-5 transition-all hover:border-[#4f39f6]/30 hover:bg-white">
              <div class="flex items-start gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[#f5f3ff]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={item.icon}/></svg>
                </div>
                <div>
                  <h3 class="font-sans text-[15px] font-semibold text-[#292524]">{item.title}</h3>
                  <p class="mt-1 font-sans text-[14px] leading-[1.6] text-[#57534e]">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: AUDIT ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Discovery</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">What the SEO Audit Uncovered</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Before automation could work, the audit revealed why the site was not generating leads — and what needed to change.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {auditFindings.map((f) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5 transition-all hover:border-[#4f39f6]/30">
              <p class="font-mono text-[28px] font-bold tracking-tight text-[#dc2626]">{f.num}</p>
              <p class="mt-1 font-sans text-[14px] font-semibold text-[#292524]">{f.label}</p>
              <p class="mt-1 font-sans text-[13px] leading-[1.6] text-[#57534e]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: STRATEGY ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">The Plan</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">4-Phase Growth Strategy</h2>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
          {phases.map((p) => (
            <div class="relative rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-5">
              <div class="absolute -top-3 left-5 flex h-7 w-7 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[11px] font-bold text-white">
                {p.n}
              </div>
              <h3 class="mt-3 font-sans text-[16px] font-bold text-[#292524]">{p.title}</h3>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ DARK: RESULTS ═══════ -->
    <section class="relative overflow-hidden border-b border-[#1e1e2e]" style="background:#0a0a0f;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%,rgba(79,57,246,0.18) 0%,transparent 60%);"></div>
      <div class="container-x relative z-10 px-6 py-12">
        <div class="mx-auto max-w-[1200px]">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#71717a]">The Outcome</p>
          <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-white md:text-[28px]">Results After 4 Months</h2>
          <p class="mt-3 max-w-[600px] font-sans text-[15px] leading-[1.7] text-[#a1a1aa]">
            Every metric that matters moved in the right direction. The shift from manual execution to automated infrastructure created compounding growth.
          </p>

          <!-- Lead counter highlight -->
          <div class="mt-8 rounded-2xl border border-[#1e1e2e] bg-[#111118] p-8 text-center">
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#71717a]">Qualified Leads Per Week</p>
            <div class="mt-4 flex items-center justify-center gap-4">
              <div class="text-center">
                <p class="font-mono text-[48px] font-bold text-[#ef4444] md:text-[64px]">0</p>
                <p class="font-mono text-[11px] uppercase tracking-[0.1em] text-[#71717a]">Before</p>
              </div>
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[#4f39f6]/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
              <div class="text-center">
                <p class="font-mono text-[48px] font-bold text-[#22c55e] md:text-[64px]">20+</p>
                <p class="font-mono text-[11px] uppercase tracking-[0.1em] text-[#71717a]">After</p>
              </div>
            </div>
          </div>

          <!-- Before/After Table -->
          <div class="mt-6 overflow-hidden rounded-xl border border-[#1e1e2e]">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-[#1e1e2e] bg-[#111118]">
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Metric</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Before</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">After</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Change</th>
                </tr>
              </thead>
              <tbody>
                {beforeAfter.map((row, i) => (
                  <tr class={i < beforeAfter.length - 1 ? 'border-b border-[#1e1e2e]' : ''}>
                    <td class="px-5 py-3.5 font-sans text-[14px] text-[#a1a1aa]">{row.metric}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] text-[#71717a]">{row.before}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] font-semibold text-[#22c55e]">{row.after}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] font-semibold text-[#22c55e]">↑</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: TESTIMONIAL ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-12">
      <div class="mx-auto max-w-[800px] text-center">
