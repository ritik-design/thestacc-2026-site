<script>
  // Growth chart
  (function() {
    const canvas = document.getElementById('growthChart') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);

    const w = rect.width;
    const h = rect.height;
    const pad = { t: 20, r: 20, b: 30, l: 50 };
    const gw = w - pad.l - pad.r;
    const gh = h - pad.t - pad.b;

    const data = [2500, 2600, 2800, 3100, 3500, 4100, 4900, 5800, 7200, 8400, 8700, 8700];
    const labels = ['Dec', 'Jan W2', 'Jan W4', 'Feb W2', 'Feb W4', 'Mar W2', 'Mar W4', 'Apr W2', 'Apr W4', 'May W2', 'May W4', 'Current'];
    const max = 10000;

    ctx.clearRect(0, 0, w, h);

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    for (let i = 0; i <= 4; i++) {
      const y = pad.t + gh * (i / 4);
      ctx.beginPath();
      ctx.moveTo(pad.l, y);
      ctx.lineTo(w - pad.r, y);
      ctx.stroke();
    }

    // Area gradient
    const grad = ctx.createLinearGradient(0, pad.t, 0, h - pad.b);
    grad.addColorStop(0, 'rgba(79,57,246,0.25)');
    grad.addColorStop(1, 'rgba(79,57,246,0.0)');

    ctx.beginPath();
    ctx.moveTo(pad.l, h - pad.b);
    data.forEach((v, i) => {
      const x = pad.l + (i / (data.length - 1)) * gw;
      const y = pad.t + gh * (1 - v / max);
      if (i === 0) ctx.lineTo(x, y);
      else {
        const prevX = pad.l + ((i - 1) / (data.length - 1)) * gw;
        const prevY = pad.t + gh * (1 - data[i - 1] / max);
        const cpX = (prevX + x) / 2;
        ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
      }
    });
    ctx.lineTo(w - pad.r, h - pad.b);
    ctx.closePath();
    ctx.fillStyle = grad;
    ctx.fill();

    // Line
    ctx.beginPath();
    data.forEach((v, i) => {
      const x = pad.l + (i / (data.length - 1)) * gw;
      const y = pad.t + gh * (1 - v / max);
      if (i === 0) ctx.moveTo(x, y);
      else {
        const prevX = pad.l + ((i - 1) / (data.length - 1)) * gw;
        const prevY = pad.t + gh * (1 - data[i - 1] / max);
        const cpX = (prevX + x) / 2;
        ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
      }
    });
    ctx.strokeStyle = '#4f39f6';
    ctx.lineWidth = 2.5;
    ctx.stroke();

    // Points
    data.forEach((v, i) => {
      const x = pad.l + (i / (data.length - 1)) * gw;
      const y = pad.t + gh * (1 - v / max);
      ctx.beginPath();
      ctx.arc(x, y, 3, 0, Math.PI * 2);
      ctx.fillStyle = '#4f39f6';
      ctx.fill();
      ctx.beginPath();
      ctx.arc(x, y, 6, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(79,57,246,0.2)';
      ctx.fill();
    });

    // Labels
    ctx.fillStyle = '#71717a';
    ctx.font = '10px monospace';
    ctx.textAlign = 'center';
    labels.forEach((l, i) => {
      const x = pad.l + (i / (labels.length - 1)) * gw;
      ctx.fillText(l, x, h - 8);
    });

    ctx.textAlign = 'right';
    for (let i = 0; i <= 4; i++) {
      const val = Math.round(max * (1 - i / 4));
      const y = pad.t + gh * (i / 4) + 3;
      ctx.fillText(val.toLocaleString(), pad.l - 8, y);
    }
  })();

  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement | null;
      const icon = btn.querySelector('.faq-icon') as HTMLElement | null;
      if (!answer) return;
      const isOpen = !answer.classList.contains('hidden');
      document.querySelectorAll('.faq-answer').forEach((a) => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach((i) => i && (i.style.transform = ''));
      if (!isOpen) {
        answer.classList.remove('hidden');
        if (icon) icon.style.transform = 'rotate(45deg)';
      }
    });
  });
</script>
