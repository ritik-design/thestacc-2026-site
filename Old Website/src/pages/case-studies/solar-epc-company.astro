---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { SITE_URL } from '../../utils/schema';

const pageUrl = `${SITE_URL}/case-studies/solar-epc-company/`;
const pageTitle = 'How a Solar EPC Company 2.5x\'d Search Impressions in 4 Months With Automated SEO | theStacc';
const pageDesc = 'See how a Top 3 solar EPC company in Gujarat scaled from 2,500 to 8,700 daily impressions using theStacc\'s AI SEO automation. Full breakdown with Search Console data.';

const kpis = [
  { label: 'Impressions', value: '+248%', icon: 'M2 12h20M2 12l4-4m-4 4l4 4' },
  { label: 'Clicks', value: '+116%', icon: 'M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122' },
  { label: 'Avg Position', value: '6.5', sub: 'from 11.2', icon: 'M5 10l7-7m0 0l7 7m-7-7v18' },
  { label: 'Content Pieces', value: '120+', sub: 'published', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
];

const auditFindings = [
  { num: '847', label: 'Untapped Keywords', desc: 'High-intent solar keywords with low competition identified across Gujarat and Rajasthan markets.' },
  { num: '12', label: 'Content Gaps', desc: 'Key buyer-stage pages missing: solar subsidy guides, rooftop calculator, maintenance comparisons.' },
  { num: '0', label: 'Schema Markup', desc: 'No structured data on any page. Missed rich snippets for solar FAQs, reviews, and local business.' },
  { num: '3.2s', label: 'Avg Load Time', desc: 'Heavy unoptimized images and render-blocking scripts hurting Core Web Vitals and rankings.' },
  { num: '0%', label: 'AI Visibility', desc: 'Not cited by ChatGPT, Perplexity, or Gemini for any solar-related queries in the region.' },
  { num: '14', label: 'Broken Links', desc: 'Internal 404s and outdated external links diluting crawl budget and user experience.' },
];

const phases = [
  { n: '01', title: 'Technical Foundation', desc: 'Fixed Core Web Vitals, implemented schema markup, resolved broken links, and optimized image delivery across all property pages.' },
  { n: '02', title: 'Content Engine', desc: 'Deployed AI-generated location pages, solar guides, and comparison content targeting the 847 untapped keywords.' },
  { n: '03', title: 'Authority Build', desc: 'Published expert-led guest posts, earned backlinks from energy publications, and built topical authority in solar EPC.' },
  { n: '04', title: 'AI Optimization', desc: 'Restructured content for AI retrieval, added FAQ schema, and optimized for featured snippets and AI Overviews.' },
];

const platformFeatures = [
  { title: 'AI Keyword Research', desc: 'Identified 847 untapped solar keywords with search volume and competition scores in under 10 minutes.' },
  { title: 'AI Content Generation', desc: 'Published 120+ SEO-optimized articles, location pages, and guides with consistent brand voice.' },
  { title: 'Auto-Publishing', desc: 'Scheduled and published content directly to the CMS with proper formatting, images, and meta tags.' },
  { title: 'Internal Linking', desc: 'Built intelligent internal link structures to distribute authority across high-value pages.' },
  { title: 'Topic Clusters', desc: 'Organized content into topical clusters around solar installation, subsidies, and maintenance.' },
  { title: 'AI Visibility Monitor', desc: 'Tracked AI citation rates across ChatGPT, Perplexity, and Gemini with weekly reports.' },
];

const results = [
  { label: 'Impressions', value: '+248%', detail: '2,500 → 8,700 / day', color: '#22c55e' },
  { label: 'Clicks', value: '+116%', detail: '180 → 389 / day', color: '#22c55e' },
  { label: 'Total Impressions', value: '588K', detail: '4-month period', color: '#4f39f6' },
  { label: 'Avg Position', value: '6.5', detail: 'from 11.2', color: '#4f39f6' },
  { label: 'CTR', value: '4.1%', detail: 'from 2.8%', color: '#22c55e' },
  { label: 'Pages Indexed', value: '120+', detail: 'up from 34', color: '#4f39f6' },
];

const beforeAfter = [
  { metric: 'Daily Impressions', before: '2,500', after: '8,700' },
  { metric: 'Daily Clicks', before: '180', after: '389' },
  { metric: 'Avg Position', before: '11.2', after: '6.5' },
  { metric: 'CTR', before: '2.8%', after: '4.1%' },
  { metric: 'Indexed Pages', before: '34', after: '120+' },
  { metric: 'Schema Coverage', before: '0%', after: '100%' },
];

const faqs = [
  { q: 'How long did it take to see results?', a: 'The company saw measurable improvements within 6 weeks of launching the content engine. By week 12, daily impressions had doubled. Full results — including the 248% impression growth — were achieved by month 4.' },
  { q: 'What type of content performed best?', a: 'Location-specific solar installation guides and subsidy explainers drove the highest engagement. "Solar panel cost in Gujarat" and "PM Surya Ghar subsidy eligibility" were top-performing pages.' },
  { q: 'Was any paid advertising used alongside SEO?', a: 'No. All results shown are from organic search only. The company paused Google Ads during month 2 to isolate SEO impact, and organic traffic continued climbing.' },
  { q: 'How was the content quality maintained at scale?', a: 'theStacc\'s AI engine applies brand voice guidelines, fact-checks against live data, and surfaces content for human review before publishing. Every article is optimized for E-E-A-T signals.' },
  { q: 'What happened to AI visibility specifically?', a: 'Before the campaign, the brand was not cited by any AI search engine for solar queries. By month 4, it appeared in 34% of tested solar EPC prompts on ChatGPT and Perplexity.' },
  { q: 'Can these results be replicated for other industries?', a: 'Yes. theStacc\'s engine is industry-agnostic. Similar results have been achieved for HVAC companies, dental practices, real estate agencies, and B2B SaaS brands.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDesc,
  image: `${SITE_URL}/blogs-preview-images/heaven-green-energy-case-study.webp`,
  datePublished: '2025-04-15',
  dateModified: '2025-04-15',
  author: { '@type': 'Organization', name: 'theStacc' },
  publisher: { '@type': 'Organization', name: 'theStacc', logo: { '@type': 'ImageObject', url: `${SITE_URL}/favicon.svg` } },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Case Studies', item: `${SITE_URL}/case-studies/` },
    { '@type': 'ListItem', position: 3, name: 'Solar EPC Company Case Study', item: pageUrl },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDesc} ogImage="/blogs-preview-images/heaven-green-energy-case-study.webp">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ═══════ DARK HERO ═══════ -->
    <section class="relative overflow-hidden border-b border-[#1e1e2e]" style="background:#0a0a0f;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(79,57,246,0.06) 1px,transparent 1px),linear-gradient(to bottom,rgba(79,57,246,0.06) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse at 50% 0%,black 30%,transparent 75%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -10%,rgba(79,57,246,0.22) 0%,transparent 60%);"></div>
      <div class="container-x relative z-10 pt-12 pb-10 md:pt-16 md:pb-12">
        <div class="mx-auto max-w-[860px] text-center">
          <div class="inline-flex items-center gap-2 rounded-full border border-[#22c55e]/30 bg-[#22c55e]/10 px-3 py-1.5">
            <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#22c55e] opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-[#22c55e]"></span></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#22c55e]">Live Case Study — April 2025</span>
          </div>
          <h1 class="mt-5 font-sans text-[34px] font-bold leading-[1.1] tracking-[-0.03em] text-white md:text-[52px]">
            How a Solar EPC Company <span class="text-[#22c55e]">2.5x'd</span> Search Impressions in 4 Months
          </h1>
          <p class="mx-auto mt-4 max-w-[600px] font-sans text-[16px] leading-[1.7] text-[#a1a1aa]">
            A Top 3 Gujarat solar installer replaced manual content workflows with theStacc's AI automation — growing from 2,500 to 8,700 daily impressions while the team focused on closing deals.
          </p>
        </div>

        <!-- KPI Cards -->
        <div class="mx-auto mt-10 grid max-w-[960px] grid-cols-2 gap-3 md:grid-cols-4">
          {kpis.map((k) => (
            <div class="rounded-xl border border-[#1e1e2e] bg-[#111118] p-4 text-center transition-colors hover:border-[#4f39f6]/40">
              <p class="font-mono text-[24px] font-bold tracking-tight text-white md:text-[28px]">{k.value}</p>
              {k.sub && <p class="font-mono text-[11px] text-[#71717a]">{k.sub}</p>}
              <p class="mt-1 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">{k.label}</p>
            </div>
          ))}
        </div>

        <!-- Chart -->
        <div class="mx-auto mt-8 max-w-[720px]">
          <canvas id="growthChart" width="720" height="240" class="w-full"></canvas>
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: SNAPSHOT ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-10">
      <div class="mx-auto max-w-[1200px]">
        <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">At a Glance</p>
            <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">Company Snapshot</h2>
          </div>
          <a href="#strategy" class="inline-flex items-center gap-1.5 font-mono text-[12px] font-semibold uppercase tracking-[0.06em] text-[#4f39f6] transition-colors hover:text-[#615fff]">
            Jump to Strategy
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
        </div>
        <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-4">
          {[
            { label: 'Industry', value: 'Solar EPC' },
            { label: 'Company Size', value: '45 employees' },
            { label: 'Location', value: 'Gujarat, India' },
            { label: 'Services', value: 'Solar EPC & Maintenance' },
            { label: 'Campaign Start', value: 'Dec 2024' },
            { label: 'Campaign End', value: 'Apr 2025' },
            { label: 'Primary Module', value: 'Blog SEO + Local' },
            { label: 'Content Pieces', value: '120+ published' },
          ].map((item) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.1em] text-[#a8a29e]">{item.label}</p>
              <p class="mt-1 font-sans text-[15px] font-semibold text-[#292524]">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: THE PROBLEM ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">The Challenge</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">Why Growth Had Stalled</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Despite being a Top 3 solar EPC in Gujarat, the company was invisible online. Competitors with weaker track records dominated search results and captured the leads that should have been theirs.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
          {[
            { title: 'Publishing Bottleneck', desc: '1 blog post every 2 weeks. The marketing team spent 8+ hours per article on research, writing, and formatting.', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
            { title: 'Keyword Gaps', desc: 'Competitors ranked for 800+ solar keywords they had never targeted. High-intent terms like "solar subsidy Gujarat 2024" sent leads elsewhere.', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
            { title: 'Team Focus Split', desc: 'Engineers and project managers were pulled into content creation instead of focusing on site surveys and client meetings.', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
            { title: 'Inconsistent Quality', desc: 'Content quality varied wildly. Some posts were technical and dry; others were too generic to rank or convert.', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z' },
          ].map((card) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5 transition-shadow hover:shadow-sm">
              <div class="flex items-start gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#fef2f2]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={card.icon}/></svg>
                </div>
                <div>
                  <h3 class="font-sans text-[15px] font-semibold text-[#292524]">{card.title}</h3>
                  <p class="mt-1 font-sans text-[14px] leading-[1.6] text-[#57534e]">{card.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 rounded-xl border border-[#fee2e2] bg-[#fef2f2] p-5">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#dc2626]">Starting Point — December 2024</p>
          <div class="mt-3 grid grid-cols-2 gap-4 md:grid-cols-4">
            {[
              { label: 'Daily Impressions', value: '2,500' },
              { label: 'Daily Clicks', value: '180' },
              { label: 'Avg Position', value: '11.2' },
              { label: 'Indexed Pages', value: '34' },
            ].map((s) => (
              <div>
                <p class="font-mono text-[20px] font-bold text-[#dc2626]">{s.value}</p>
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.08em] text-[#a8a29e]">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: AUDIT ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Discovery</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">What the SEO Audit Uncovered</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          A full technical and content audit revealed why the site wasn't performing — and exactly what needed to change.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {auditFindings.map((f) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-5 transition-all hover:border-[#4f39f6]/30 hover:bg-white">
              <p class="font-mono text-[28px] font-bold tracking-tight text-[#dc2626]">{f.num}</p>
              <p class="mt-1 font-sans text-[14px] font-semibold text-[#292524]">{f.label}</p>
              <p class="mt-1 font-sans text-[13px] leading-[1.6] text-[#57534e]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: STRATEGY ═══════ -->
    <section id="strategy" class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">The Plan</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">4-Phase SEO Strategy</h2>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
          {phases.map((p, i) => (
            <div class="relative rounded-xl border border-[#e7e5e4] bg-white p-5">
              <div class="absolute -top-3 left-5 flex h-7 w-7 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[11px] font-bold text-white">
                {p.n}
              </div>
              <h3 class="mt-3 font-sans text-[16px] font-bold text-[#292524]">{p.title}</h3>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: PLATFORM ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Execution</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">How theStacc Powered the Work</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Every phase was executed through theStacc's integrated platform — no external tools, no manual coordination.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {platformFeatures.map((f) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-5 transition-all hover:border-[#4f39f6]/30 hover:bg-white">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-[#f5f3ff]">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="mt-3 font-sans text-[15px] font-semibold text-[#292524]">{f.title}</h3>
              <p class="mt-1 font-sans text-[13px] leading-[1.6] text-[#57534e]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ DARK: RESULTS ═══════ -->
    <section class="relative overflow-hidden border-b border-[#1e1e2e]" style="background:#0a0a0f;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%,rgba(79,57,246,0.18) 0%,transparent 60%);"></div>
      <div class="container-x relative z-10 px-6 py-12">
        <div class="mx-auto max-w-[1200px]">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#71717a]">The Outcome</p>
          <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-white md:text-[28px]">Results After 4 Months</h2>
          <p class="mt-3 max-w-[600px] font-sans text-[15px] leading-[1.7] text-[#a1a1aa]">
            Every metric moved in the right direction. The compounding effect of consistent publishing, technical fixes, and AI optimization created a self-reinforcing growth loop.
          </p>

          <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-3">
            {results.map((r) => (
              <div class="rounded-xl border border-[#1e1e2e] bg-[#111118] p-5 text-center transition-colors hover:border-[#4f39f6]/30">
                <p class="font-mono text-[28px] font-bold tracking-tight md:text-[32px]" style={`color:${r.color}`}>{r.value}</p>
                <p class="mt-1 font-sans text-[13px] text-[#a1a1aa]">{r.label}</p>
                <p class="font-mono text-[11px] text-[#71717a]">{r.detail}</p>
              </div>
            ))}
          </div>

          <!-- Before/After Table -->
          <div class="mt-8 overflow-hidden rounded-xl border border-[#1e1e2e]">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-[#1e1e2e] bg-[#111118]">
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Metric</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Before</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">After</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Change</th>
                </tr>
              </thead>
              <tbody>
                {beforeAfter.map((row, i) => (
                  <tr class={i < beforeAfter.length - 1 ? 'border-b border-[#1e1e2e]' : ''}>
                    <td class="px-5 py-3.5 font-sans text-[14px] text-[#a1a1aa]">{row.metric}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] text-[#71717a]">{row.before}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] font-semibold text-[#22c55e]">{row.after}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] font-semibold text-[#22c55e]">↑</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

