---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { SITE_URL } from '../../utils/schema';

const pageUrl = `${SITE_URL}/case-studies/vertical-saas-platform/`;
const pageTitle = 'How the SaaS platform Scaled From 5 to 70 Leads/Month With Strategic SEO | theStacc';
const pageDesc = 'See how an AI-powered solar design SaaS fixed content cannibalization, unblocked AI crawlers, and turned 5,500 dormant pages into a lead generation engine.';

const kpis = [
  { label: 'Leads/Month', value: '70+', sub: 'from 5', color: '#22c55e' },
  { label: 'Daily Clicks', value: '60', sub: 'from 10', color: '#22c55e' },
  { label: 'Daily Impressions', value: '12K', sub: 'from 1,157', color: '#4f39f6' },
  { label: 'Pages Driving Clicks', value: '850+', sub: 'from 120', color: '#4f39f6' },
];

const painPoints = [
  { title: 'Invisible in Search', desc: '5,500 pages indexed but only ~120 received any clicks. The vast majority of content was invisible to both users and search engines.' },
  { title: 'Content Cannibalization', desc: '51 high-value queries were split across multiple competing pages. The site was competing against itself, diluting ranking potential.' },
  { title: 'AI Crawlers Blocked', desc: 'GPTBot, ClaudeBot, PerplexityBot, and Google-Extended were all blocked in robots.txt — strategically incoherent for an AI-positioned SaaS.' },
  { title: 'Zero Backlink Profile', desc: '97% of pages had zero backlinks. No domain authority growth. Competitors like RatedPower (1,495 top-10 keywords) and PVcase (790) dominated.' },
];

const auditFindings = [
  { num: '5,500', label: 'Pages Indexed', desc: 'Massive content library but only ~120 pages drove any organic traffic. The rest were orphaned, thin, or cannibalized.' },
  { num: '51', label: 'Cannibalized Queries', desc: 'High-intent keywords split across multiple pages. Each query diluted its own ranking potential instead of concentrating authority.' },
  { num: '1', label: 'Keyword in Top 10', desc: 'Only "helioscope pricing" ranked page 1. Competitors had hundreds. the SaaS platform was functionally invisible for its core product terms.' },
  { num: '0.70%', label: 'Average CTR', desc: 'Far below the 3–5% healthy baseline. Titles and meta descriptions were not optimized for click-through rate.' },
  { num: '97%', label: 'Pages With Zero Backlinks', desc: 'No link building strategy. Content existed in isolation with no external signals of authority or trustworthiness.' },
  { num: '4', label: 'AI Crawlers Blocked', desc: 'GPTBot, ClaudeBot, PerplexityBot, and Google-Extended all denied access — cutting off AI search visibility entirely.' },
];

const phases = [
  { n: '01', title: 'SEO Audit & Triage', desc: 'Identified cannibalization clusters, mapped the 5,500-page inventory, fixed robots.txt crawler blocks, and prioritized highest-impact fixes.' },
  { n: '02', title: 'Cannibalization Cleanup', desc: 'Consolidated 51 competing query groups into single authoritative pages. Implemented 301 redirects, canonical tags, and internal link restructuring.' },
  { n: '03', title: 'Content Optimization at Scale', desc: 'Rewrote 280+ blog titles and meta descriptions for CTR. Rebuilt internal linking architecture. Optimized programmatic pages for local intent.' },
  { n: '04', title: 'AI Visibility & Authority', desc: 'Unblocked AI crawlers, implemented llms.txt, added FAQPage and Speakable schema. Built tool-based link magnets (calculators) for backlink growth.' },
];

const platformFeatures = [
  { title: 'Blog SEO Optimization', desc: 'Rewrote 280+ post titles, meta descriptions, and headers. Restructured content for featured snippets and AI Overviews.' },
  { title: 'Programmatic SEO', desc: 'Optimized /best-solar-software/ pages for 100+ countries and categories. Added localized intent targeting.' },
  { title: 'Local SEO Directory', desc: 'Built /solar-installers/[country]/[city] pages targeting local installer intent across global markets.' },
  { title: 'Review & Comparison SEO', desc: 'Restructured 35 software reviews and comparison pages — the highest-CTR content category on the site.' },
  { title: 'Tool-Based Link Magnets', desc: 'Promoted calculators (sun-angle, busbar-size) as linkable assets to earn natural backlinks and referral traffic.' },
  { title: 'International SEO', desc: 'Managed 8 language hubs with proper hreflang implementation: EN, ES, DE, FR, IT, PT, AR, TR.' },
];

const beforeAfter = [
  { metric: 'Leads/Month', before: '5', after: '70+' },
  { metric: 'Daily Clicks', before: '10', after: '60' },
  { metric: 'Daily Impressions', before: '1,157', after: '12,000' },
  { metric: 'Pages Driving Clicks', before: '120', after: '850+' },
  { metric: 'Top 10 Keywords', before: '1', after: '12+' },
  { metric: 'Avg Position', before: '60–75', after: '20.6' },
  { metric: 'AI Crawler Access', before: 'Blocked', after: 'Open' },
  { metric: 'CTR', before: '0.5%', after: '0.6%' },
];

const faqs = [
  { q: 'How did you fix the cannibalization problem?', a: 'We audited all 5,500 pages and identified 51 query clusters where multiple pages competed for the same keyword. Each cluster was consolidated into a single authoritative page with 301 redirects from weaker variants, canonical tags, and updated internal links to concentrate ranking signals.' },
  { q: 'Why were AI crawlers blocked, and what changed?', a: 'the SaaS platform\'s robots.txt blocked GPTBot, ClaudeBot, PerplexityBot, and Google-Extended — likely a legacy security decision. For an AI-positioned SaaS, this was strategically incoherent. We unblocked all major AI crawlers and implemented llms.txt to maximize AI search visibility.' },
  { q: 'What content drove the most leads?', a: 'Software reviews and comparison pages had the highest CTR and conversion rates. "the SaaS platform vs Helioscope" and "best solar design software India" were top performers. The /demo booking flow captured leads directly from these pages.' },
  { q: 'How important was the international SEO strategy?', a: 'Critical. the SaaS platform operates in 8 languages across India, US, UK, UAE, Europe, Africa, and LatAm. Proper hreflang implementation prevented duplicate content issues and ensured the right language version ranked in each market.' },
  { q: 'What role did the calculators play?', a: 'The sun-angle calculator and busbar-size calculator served as link magnets — earning natural backlinks from engineering forums and educational sites. They also ranked for high-volume informational queries, creating a top-of-funnel entry point.' },
  { q: 'How long until results appeared?', a: 'The SEO audit and cannibalization fixes showed measurable impact within 6–8 weeks. Lead growth accelerated in month 3 as consolidated pages gained authority and newly optimized content began ranking.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDesc,
  image: `${SITE_URL}/blogs-preview-images/surgepv-case-study.webp`,
  datePublished: '2026-05-01',
  dateModified: '2026-05-01',
  author: { '@type': 'Organization', name: 'theStacc' },
  publisher: { '@type': 'Organization', name: 'theStacc', logo: { '@type': 'ImageObject', url: `${SITE_URL}/favicon.svg` } },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Case Studies', item: `${SITE_URL}/case-studies/` },
    { '@type': 'ListItem', position: 3, name: 'the SaaS platform Case Study', item: pageUrl },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={pageTitle} description={pageDesc} ogImage="/blogs-preview-images/surgepv-case-study.webp">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- ═══════ DARK HERO ═══════ -->
    <section class="relative overflow-hidden border-b border-[#1e1e2e]" style="background:#0a0a0f;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(79,57,246,0.06) 1px,transparent 1px),linear-gradient(to bottom,rgba(79,57,246,0.06) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse at 50% 0%,black 30%,transparent 75%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -10%,rgba(79,57,246,0.22) 0%,transparent 60%);"></div>
      <div class="container-x relative z-10 pt-12 pb-10 md:pt-16 md:pb-12">
        <div class="mx-auto max-w-[860px] text-center">
          <div class="inline-flex items-center gap-2 rounded-full border border-[#22c55e]/30 bg-[#22c55e]/10 px-3 py-1.5">
            <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#22c55e] opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-[#22c55e]"></span></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#22c55e]">Live Case Study — May 2026</span>
          </div>
          <h1 class="mt-5 font-sans text-[34px] font-bold leading-[1.1] tracking-[-0.03em] text-white md:text-[52px]">
            From <span class="text-[#ef4444]">5</span> to <span class="text-[#22c55e]">70+</span> Leads/Month in 6 Months
          </h1>
          <p class="mx-auto mt-4 max-w-[600px] font-sans text-[16px] leading-[1.7] text-[#a1a1aa]">
            How the SaaS platform fixed content cannibalization, unblocked AI crawlers, and turned 5,500 dormant pages into a qualified lead engine for solar design software.
          </p>
        </div>

        <!-- KPI Cards -->
        <div class="mx-auto mt-10 grid max-w-[960px] grid-cols-2 gap-3 md:grid-cols-4">
          {kpis.map((k) => (
            <div class="rounded-xl border border-[#1e1e2e] bg-[#111118] p-4 text-center transition-colors hover:border-[#4f39f6]/40">
              <p class="font-mono text-[24px] font-bold tracking-tight md:text-[28px]" style={`color:${k.color}`}>{k.value}</p>
              {k.sub && <p class="font-mono text-[11px] text-[#71717a]">{k.sub}</p>}
              <p class="mt-1 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">{k.label}</p>
            </div>
          ))}
        </div>

        <!-- Growth chart -->
        <div class="mx-auto mt-8 max-w-[720px]">
          <canvas id="leadsChart" width="720" height="240" class="w-full"></canvas>
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: SNAPSHOT ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-10">
      <div class="mx-auto max-w-[1200px]">
        <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">At a Glance</p>
            <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">Company Snapshot</h2>
          </div>
          <a href="#strategy" class="inline-flex items-center gap-1.5 font-mono text-[12px] font-semibold uppercase tracking-[0.06em] text-[#4f39f6] transition-colors hover:text-[#615fff]">
            Jump to Strategy
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </a>
        </div>
        <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-4">
          {[
            { label: 'Product', value: 'Vertical Industry SAAS' },
            { label: 'Customers', value: '500+ companies' },
            { label: 'Markets', value: 'Global (8 languages)' },
            { label: 'Pricing', value: '$1,299–$1,899/yr' },
            { label: 'Campaign Start', value: 'May 2026' },
            { label: 'Duration', value: 'Ongoing' },
            { label: 'Primary Module', value: 'Blog + Programmatic' },
            { label: 'Pages Indexed', value: '5,500+' },
          ].map((item) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.1em] text-[#a8a29e]">{item.label}</p>
              <p class="mt-1 font-sans text-[15px] font-semibold text-[#292524]">{item.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: THE PROBLEM ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">The Challenge</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">5,500 Pages. Zero Visibility.</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          the SaaS platform had built an enormous content library across blogs, reviews, guides, and tools. But the site was competing against itself, blocking AI crawlers, and generating only 5 leads per month.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
          {painPoints.map((card) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5 transition-shadow hover:shadow-sm">
              <div class="flex items-start gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#fef2f2]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </div>
                <div>
                  <h3 class="font-sans text-[15px] font-semibold text-[#292524]">{card.title}</h3>
                  <p class="mt-1 font-sans text-[14px] leading-[1.6] text-[#57534e]">{card.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6 rounded-xl border border-[#fee2e2] bg-[#fef2f2] p-5">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#dc2626]">Starting Point — March 2025</p>
          <div class="mt-3 grid grid-cols-2 gap-4 md:grid-cols-4">
            {[
              { label: 'Leads/Month', value: '5' },
              { label: 'Daily Clicks', value: '10' },
              { label: 'Daily Impressions', value: '1,157' },
              { label: 'Top 10 Keywords', value: '1' },
            ].map((s) => (
              <div>
                <p class="font-mono text-[20px] font-bold text-[#dc2626]">{s.value}</p>
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.08em] text-[#a8a29e]">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: AUDIT ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Discovery</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">What the SEO Audit Uncovered</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          The audit revealed why 5,500 pages generated almost zero organic value — and the exact fixes needed to unlock growth.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {auditFindings.map((f) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-5 transition-all hover:border-[#4f39f6]/30 hover:bg-white">
              <p class="font-mono text-[28px] font-bold tracking-tight text-[#dc2626]">{f.num}</p>
              <p class="mt-1 font-sans text-[14px] font-semibold text-[#292524]">{f.label}</p>
              <p class="mt-1 font-sans text-[13px] leading-[1.6] text-[#57534e]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: STRATEGY ═══════ -->
    <section id="strategy" class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">The Plan</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">4-Phase Recovery Strategy</h2>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
          {phases.map((p) => (
            <div class="relative rounded-xl border border-[#e7e5e4] bg-white p-5">
              <div class="absolute -top-3 left-5 flex h-7 w-7 items-center justify-center rounded-full bg-[#4f39f6] font-mono text-[11px] font-bold text-white">
                {p.n}
              </div>
              <h3 class="mt-3 font-sans text-[16px] font-bold text-[#292524]">{p.title}</h3>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ LIGHT: PLATFORM ═══════ -->
    <section class="border-b border-[#e7e5e4] bg-white px-6 py-12">
      <div class="mx-auto max-w-[1200px]">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Execution</p>
        <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-[#292524] md:text-[28px]">How theStacc Powered the Work</h2>
        <p class="mt-3 max-w-[640px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Six integrated modules working together across content, technical SEO, programmatic pages, and international markets.
        </p>

        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {platformFeatures.map((f) => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-5 transition-all hover:border-[#4f39f6]/30 hover:bg-white">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-[#f5f3ff]">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="mt-3 font-sans text-[15px] font-semibold text-[#292524]">{f.title}</h3>
              <p class="mt-1 font-sans text-[13px] leading-[1.6] text-[#57534e]">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════ DARK: RESULTS ═══════ -->
    <section class="relative overflow-hidden border-b border-[#1e1e2e]" style="background:#0a0a0f;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%,rgba(79,57,246,0.18) 0%,transparent 60%);"></div>
      <div class="container-x relative z-10 px-6 py-12">
        <div class="mx-auto max-w-[1200px]">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#71717a]">The Outcome</p>
          <h2 class="mt-2 font-sans text-[24px] font-bold leading-[1.2] tracking-[-0.02em] text-white md:text-[28px]">Results After 5 Months</h2>
          <p class="mt-3 max-w-[600px] font-sans text-[15px] leading-[1.7] text-[#a1a1aa]">
            Stopping the bleeding was step one. Consolidating authority, optimizing for clicks, and opening AI crawler access created compounding growth.
          </p>

          <!-- Lead counter highlight -->
          <div class="mt-8 rounded-2xl border border-[#1e1e2e] bg-[#111118] p-8 text-center">
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#71717a]">Qualified Leads Per Month</p>
            <div class="mt-4 flex items-center justify-center gap-4">
              <div class="text-center">
                <p class="font-mono text-[48px] font-bold text-[#ef4444] md:text-[64px]">5</p>
                <p class="font-mono text-[11px] uppercase tracking-[0.1em] text-[#71717a]">Before</p>
              </div>
              <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[#4f39f6]/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
              <div class="text-center">
                <p class="font-mono text-[48px] font-bold text-[#22c55e] md:text-[64px]">70+</p>
                <p class="font-mono text-[11px] uppercase tracking-[0.1em] text-[#71717a]">After</p>
              </div>
            </div>
          </div>

          <!-- Before/After Table -->
          <div class="mt-6 overflow-hidden rounded-xl border border-[#1e1e2e]">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-[#1e1e2e] bg-[#111118]">
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Metric</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Before</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">After</th>
                  <th class="px-5 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Change</th>
                </tr>
              </thead>
              <tbody>
                {beforeAfter.map((row, i) => (
                  <tr class={i < beforeAfter.length - 1 ? 'border-b border-[#1e1e2e]' : ''}>
                    <td class="px-5 py-3.5 font-sans text-[14px] text-[#a1a1aa]">{row.metric}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] text-[#71717a]">{row.before}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] font-semibold text-[#22c55e]">{row.after}</td>
                    <td class="px-5 py-3.5 font-mono text-[14px] font-semibold text-[#22c55e]">↑</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- GSC Screenshots -->
          <div class="mx-auto mt-10 max-w-[1000px] space-y-6">
            <p class="text-center font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#71717a]">Google Search Console — Total Impressions</p>
            <img src="/case-studies/gsc-impressions.webp" alt="GSC impressions growth from 1,157 to 12,000 per day" class="w-full rounded-xl border border-[#1e1e2e]" loading="lazy" />
