<script>
  // Leads growth chart
  (function() {
    const canvas = document.getElementById('leadsChart') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);

    const w = rect.width;
    const h = rect.height;
    const pad = { t: 20, r: 20, b: 30, l: 40 };
    const gw = w - pad.l - pad.r;
    const gh = h - pad.t - pad.b;

    const data = [5, 5, 6, 8, 12, 18, 25, 35, 45, 55, 65, 70];
    const labels = ['Nov', 'Dec', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct'];
    const max = 80;

    ctx.clearRect(0, 0, w, h);

    // Grid
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    for (let i = 0; i <= 4; i++) {
      const y = pad.t + gh * (i / 4);
      ctx.beginPath();
      ctx.moveTo(pad.l, y);
      ctx.lineTo(w - pad.r, y);
      ctx.stroke();
    }

    // Area gradient
    const grad = ctx.createLinearGradient(0, pad.t, 0, h - pad.b);
    grad.addColorStop(0, 'rgba(34,197,94,0.2)');
    grad.addColorStop(1, 'rgba(34,197,94,0.0)');

    ctx.beginPath();
    ctx.moveTo(pad.l, h - pad.b);
    data.forEach((v, i) => {
      const x = pad.l + (i / (data.length - 1)) * gw;
      const y = pad.t + gh * (1 - v / max);
      if (i === 0) ctx.lineTo(x, y);
      else {
        const prevX = pad.l + ((i - 1) / (data.length - 1)) * gw;
        const prevY = pad.t + gh * (1 - data[i - 1] / max);
        const cpX = (prevX + x) / 2;
        ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
      }
    });
    ctx.lineTo(w - pad.r, h - pad.b);
    ctx.closePath();
    ctx.fillStyle = grad;
    ctx.fill();

    // Line
    ctx.beginPath();
    data.forEach((v, i) => {
      const x = pad.l + (i / (data.length - 1)) * gw;
      const y = pad.t + gh * (1 - v / max);
      if (i === 0) ctx.moveTo(x, y);
      else {
        const prevX = pad.l + ((i - 1) / (data.length - 1)) * gw;
        const prevY = pad.t + gh * (1 - data[i - 1] / max);
        const cpX = (prevX + x) / 2;
        ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
      }
    });
    ctx.strokeStyle = '#22c55e';
    ctx.lineWidth = 2.5;
    ctx.stroke();

    // Points
    data.forEach((v, i) => {
      const x = pad.l + (i / (data.length - 1)) * gw;
      const y = pad.t + gh * (1 - v / max);
      ctx.beginPath();
      ctx.arc(x, y, 3, 0, Math.PI * 2);
      ctx.fillStyle = '#22c55e';
      ctx.fill();
      ctx.beginPath();
      ctx.arc(x, y, 6, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(34,197,94,0.2)';
      ctx.fill();
    });

    // Labels
    ctx.fillStyle = '#71717a';
    ctx.font = '10px monospace';
    ctx.textAlign = 'center';
    labels.forEach((l, i) => {
      const x = pad.l + (i / (labels.length - 1)) * gw;
      ctx.fillText(l, x, h - 8);
    });

    ctx.textAlign = 'right';
    for (let i = 0; i <= 4; i++) {
      const val = Math.round(max * (1 - i / 4));
      const y = pad.t + gh * (i / 4) + 3;
      ctx.fillText(val.toString(), pad.l - 8, y);
    }
  })();

  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement | null;
      const icon = btn.querySelector('.faq-icon') as HTMLElement | null;
      if (!answer) return;
      const isOpen = !answer.classList.contains('hidden');
      document.querySelectorAll('.faq-answer').forEach((a) => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach((i) => i && (i.style.transform = ''));
      if (!isOpen) {
        answer.classList.remove('hidden');
        if (icon) icon.style.transform = 'rotate(45deg)';
      }
    });
  });
</script>
