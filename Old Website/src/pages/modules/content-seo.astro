---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const faqs = [
  {
    q: "Will Google penalize AI-generated content?",
    a: "Google's own guidelines say it clearly: quality and relevance matter. Not how the content was made. Every article Stacc publishes is built on real keyword research, written to answer actual search queries, and scored against SEO benchmarks before it goes live. Our customers have published millions of words without a single manual penalty or ranking drop.",
  },
  {
    q: "How long until I see results?",
    a: "Most customers see meaningful ranking movement within 60–90 days. A few see it faster. SEO is a compounding asset. Every article you publish makes the next one easier to rank. The sooner you start, the bigger the lead you build on competitors who are still thinking about it.",
  },
  {
    q: "Which CMS platforms do you support?",
    a: "WordPress, Webflow, and Ghost are fully integrated. Direct publish, no plugins. Any CMS with a REST API or webhook support also works automatically. And if you're on something custom, you can export and paste. The content is always yours.",
  },
  {
    q: "Can I edit the articles before they publish?",
    a: "Every article sits in a review queue before it goes live. Edit, approve, or flip to auto-publish. Most customers review the first few batches. Then switch to auto-publish once they see the quality holds. After that, content just appears on their site.",
  },
  {
    q: "What if I cancel? Do I keep my content?",
    a: "Every article published to your site is yours, permanently. Cancel today and those pages keep ranking, keep driving traffic, and keep generating leads. Forever. You own 100% of everything published.",
  },
  {
    q: "How is this different from just using ChatGPT?",
    a: "ChatGPT writes words. Stacc ranks pages. The gap is the SEO layer: keyword research calibrated to your actual market, optimization scoring, internal linking, meta tags, schema markup. Then direct CMS publishing. ChatGPT gives you a draft that no one will find. Stacc gives you a live, indexed, ranking page.",
  },
];
---

<BaseLayout
  title="Blog SEO Module | theStacc | Turn Your Website Into a Lead-Generating SEO Asset"
  description="Stacc publishes 30 SEO-optimized articles to your site every month. Automatically. More articles, more rankings, more customers. Start for $1."
>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Blog SEO Module · $99/month</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Turn your website into a<br class="hidden md:block" />
            <span style="color:#4f39f6;">lead-generating SEO machine.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc publishes 30 SEO-optimized articles to your site every month. Automatically. More articles means more search rankings. More rankings means more customers finding your business, without you touching a single word.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No credit card to start · Every article you publish stays forever
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '12,000+', num: 12000, prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Articles published' },
              { value: '340+',    num: 340,   prefix: '',  suffix: '+', decimals: 0, from: 0, label: 'Local businesses' },
              { value: '4.9★',    num: 4.9,   prefix: '',  suffix: '★', decimals: 1, from: 0, label: 'Average rating' },
              { value: '0',       num: 0,     prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'Ranking penalties' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Businesses ranking with Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 from 127 reviews</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            You know content is how you get found.<br />The math just never works out.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">You need 30 articles. You published 2 last year.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Google rewards businesses that show up consistently. Every week you don't publish, your competitor does. That ranking gap compounds. And it gets harder to close every month you wait.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">SEO writers charge $200–$400 per article. Per article.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">30+ blog posts per month from a freelancer runs $6,000–$12,000. An agency charges $3,500 and writes maybe 6 posts. The ROI math never works. So you don't start. And they keep outranking you.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Writing without an SEO strategy doesn't rank.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Keyword research, internal links, optimized meta tags, schema. That's 3 extra hours per post. Miss any of it and you've published something no one will ever find. You need the whole system, not just words.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Set up in 5 minutes.<br />Runs automatically after that.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Connect your site once. Stacc maps your keyword gaps, learns your brand voice, and starts publishing. Without you lifting a finger. You'll see traffic moving before you've thought about it twice.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connect your website</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Enter your URL. Stacc crawls your site, reads your competitor rankings, finds the keyword gaps they've missed, and builds your entire content strategy in under 2 minutes.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">AI writes your content plan</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 fully-optimized articles written to target real search terms your customers type. Every article is scored against SEO benchmarks before it publishes. Nothing goes live that wouldn't rank.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Articles publish. You do nothing.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Content goes live directly to your WordPress, Webflow, or Ghost on the schedule you set. New month, fresh 30 articles. Your site builds authority while you run your business.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── WHY STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Why Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            The only option that does the whole job.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Ranking requires keyword research, quality writing, optimization, and consistent publishing. Every month, without fail. No other option delivers all four without consuming your time or your budget.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <!-- Header row -->
          <div class="grid grid-cols-4 bg-[#f5f3ff] px-0">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Agency</div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Freelancer</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Stacc</div>
          </div>
          <!-- Rows -->
          {[
            { label: 'Monthly cost',          agency: '$3,500+',  freelancer: '$1,200+',  stacc: '$99'       },
            { label: 'Articles per month',    agency: '6–8',      freelancer: '4–6',      stacc: '30'        },
            { label: 'Keyword research',      agency: '✓',        freelancer: '✗',        stacc: '✓'         },
            { label: 'SEO optimization',      agency: '✓',        freelancer: 'Sometimes', stacc: '✓'        },
            { label: 'Brand voice training',  agency: 'Sometimes', freelancer: 'Sometimes', stacc: '✓'       },
            { label: 'Auto-publishing',       agency: '✗',        freelancer: '✗',        stacc: '✓'         },
            { label: 'Time required from you',agency: 'High',     freelancer: 'Medium',   stacc: 'None'      },
          ].map((row, i) => (
            <div class={`grid grid-cols-4 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.agency}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.freelancer}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.stacc}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/demo/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
          >
            Start for $1 today
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>


    <!-- ─── FEATURE 1: KEYWORD RESEARCH ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
          <div>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Keyword Research</span>
            <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.1rem]">
              Rank for what your customers search. Before your competitor does.
            </h2>
            <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
              Most keyword tools give you a list and leave you to figure it out. Stacc turns your URL into a complete content strategy. We find what your market is searching, identify the gaps your competitors haven't filled, and build your entire publishing plan from that data. The result: you rank for terms that drive real inquiries, not just traffic.
            </p>
            <ul class="mt-7 space-y-3">
              {[
                'Competitor gap analysis. Own every term they rank for, plus the ones they missed',
                'Search intent mapping. Informational, commercial, and local separated automatically',
                'Difficulty scoring so you target winnable terms first and see rankings faster',
                'Updated monthly as your rankings improve and new opportunities open up',
              ].map(item => (
                <li class="flex items-start gap-3">
                  <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="order-first md:order-last">
            <img
              src="/content-module/onboarding-website-analysis-results.webp"
              alt="Stacc keyword research and website analysis"
              class="w-full rounded-xl border border-[#e7e5e4] shadow-[0_8px_40px_rgba(0,0,0,0.08)]"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FEATURE 2: BRAND VOICE ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-6xl grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
          <div>
            <img
              src="/content-module/Onboarding-icp-selection.webp"
              alt="Stacc ICP and audience setup"
              class="w-full rounded-xl border border-[#e7e5e4] shadow-[0_8px_40px_rgba(0,0,0,0.08)]"
              loading="lazy"
            />
          </div>
          <div>
