---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  { q: "What is rank tracking software?", a: "Rank tracking software monitors where your website and Google Business Profile appear in search results for your target keywords. Local rank tracking specifically tracks your position in the Google local pack, Google Maps, and organic results — the three separate ranking surfaces that matter for local businesses." },
  { q: "How often does Stacc update rankings?", a: "Daily. Rankings update every day across every tracked keyword at every location. You always see current-day position data, not a weekly or monthly snapshot." },
  { q: "Does Stacc track local pack rankings separately from organic rankings?", a: "Yes. For local businesses, local pack and organic are separate ranking surfaces with different algorithms. Stacc tracks both independently so you can see your Maps/pack position and your organic position for the same keyword — because they often behave differently." },
  { q: "Can I track rankings for multiple locations?", a: "Yes. Each location gets its own keyword set tracked independently. The portfolio dashboard compares all locations side by side. You can sort by any metric to instantly see which locations are winning and which are underperforming." },
  { q: "How does Stacc alert me when rankings change?", a: "You can configure ranking change alerts that fire when any tracked keyword crosses a threshold — e.g., when a keyword drops out of the top 3 or when a keyword enters the top 3 for the first time. Alerts deliver via email or in-dashboard notification." },
  { q: "Does rank tracking data feed into client reports?", a: "Yes. Ranking data is included in automated client reports. Reports are generated on your schedule and delivered automatically — no manual export required. Agencies can white-label all reports under their own brand." },
  { q: "What does rank tracking software cost?", a: "Rank tracking is included in Stacc's Local SEO module starting at $49/month. Daily tracking across unlimited keywords per location is included." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Rank Tracking Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Local rank tracking software with daily updates for every keyword at every location. Track local pack, Maps, and organic rankings — all in one dashboard.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Rank Tracking Software", "item": "https://thestacc.com/rank-tracking-software/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Local Rank Tracking Software — Daily Rankings for Every Location | theStacc"
  description="Track local pack, Maps, and organic rankings daily for every keyword at every location. theStacc's rank tracking software updates automatically — no manual checks."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Rank Tracking Software · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Rankings updated daily.<br />
            <span style="color:#4f39f6;">Every keyword. Every location. Automatically.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc tracks local pack, Maps, and organic rankings for every keyword at every location — updated daily, compared across locations, and alerting you the moment something changes.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/features/rank-tracking/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See rank tracking details
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Daily updates for 1,200+ locations</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">3 ranking surfaces tracked</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Why daily ranking data matters</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            A ranking drop you catch today<br />costs a fraction of one you catch in 30 days.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>A keyword that drops from position 3 to position 7 loses more than 50% of its click-through rate overnight. If your ranking tool updates weekly or monthly, that drop can cost you four weeks of lost traffic before you even know it happened. By the time you diagnose the cause and take action, you're recovering from a month-long deficit — not a day-long one.</p>
            <p>Daily rank tracking changes the response timeline. A position change that happened yesterday can be acted on today. You catch algorithmic shifts, competitor changes, and ranking declines at day one — not day thirty.</p>
            <p class="font-semibold text-[#111827]">And for local businesses specifically, ranking in the local pack and Maps is a different signal than organic — and requires different monitoring. Stacc tracks both separately so you always know exactly where you stand in each placement type.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Rank tracking capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every ranking data point you need.<br />All updated daily.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Local pack + Maps tracking', body: 'Track your position in the Google local 3-pack and Maps separately from organic. For local businesses, pack placement drives the highest-intent clicks.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Daily updates, zero manual checks', body: 'Rankings refresh every 24 hours automatically. Open your dashboard each morning and see where every keyword stands — no manual tracking required.' },
            { icon: 'M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2', title: 'Multi-location comparison', body: 'See all locations ranked side by side for any keyword. Identify which markets you\'re winning and which need attention from a single portfolio view.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Ranking change alerts', body: 'Configure alerts for significant ranking movements — keywords entering or leaving top 3, drops of 3+ positions, new keywords breaking into page 1.' },
            { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Trend analysis', body: '30, 60, and 90-day ranking trend views per keyword and location. Identify momentum and spot early warning signs of algorithmic impact.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Ranking data in client reports', body: 'Ranking data feeds directly into automated client reports. Reports are generated and delivered on your schedule — white-labeled under your brand.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Daily rank data, multi-location comparison,<br />and automatic alerts — all in one place.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Daily Ranking Dashboard</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Every keyword position updated each morning. Local pack, Maps, and organic — separately.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Open Stacc each morning and every tracked keyword shows its current position — in the local 3-pack, in Maps, and in organic results. Three separate numbers, because for local businesses they can move independently. A position 1 in organic with a position 7 in Maps is a very different situation from the reverse. Stacc shows you both so you always know where the opportunity is.
              </p>
              <a href="/features/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See rank tracking in detail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Today's rank update</p>
              {[
                { kw: 'dentist near me', pack: 1, org: 3, change: '+2', trend: 'up' },
                { kw: 'emergency dentist [city]', pack: 2, org: 5, change: '+1', trend: 'up' },
                { kw: 'teeth whitening near me', pack: 3, org: 4, change: '+4', trend: 'up' },
                { kw: 'dental implants [city]', pack: 5, org: 8, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[12px] text-[#374151] truncate">{r.kw}</span>
                  <div class="flex gap-1.5">
                    <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-[10px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] text-[10px] font-bold text-[#79716b]">#{r.org}</div>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <div class="mt-3 flex items-center justify-between">
                <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Pack · Organic · Updated daily</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-1 font-mono text-[9px] font-semibold text-[#4f39f6]">ALL AUTO</span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Multi-location comparison</p>
              {[
                { name: 'Downtown Chicago', rank: 1, score: 94, trend: '↑' },
                { name: 'River North', rank: 2, score: 89, trend: '↑' },
                { name: 'Lincoln Park', rank: 3, score: 85, trend: '→' },
                { name: 'Hyde Park', rank: 8, score: 52, trend: '↓' },
              ].map(loc => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[11px] font-bold ${loc.rank <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#fff1f2] text-[#ef4444]'}`}>#{loc.rank}</div>
                  <span class="flex-1 font-sans text-[13px] text-[#374151]">{loc.name}</span>
                  <div class="h-1.5 w-16 rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${loc.score}%`}></div></div>
                  <span class={`font-mono text-[11px] font-semibold ${loc.trend === '↑' ? 'text-[#059669]' : loc.trend === '↓' ? 'text-[#ef4444]' : 'text-[#79716b]'}`}>{loc.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">All locations compared · Updated daily</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Portfolio Ranking View</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Every location ranked side by side. Underperformers surface instantly.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Managing multiple locations means you need to know which ones are winning and which need attention — at a glance. The portfolio ranking view shows every location's position for every tracked keyword, sorted by any metric you choose. You don't check each location separately. You see the whole picture in one view and act on what matters.
              </p>
              <a href="/features/multi-location-reporting/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See multi-location reporting
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ranking Change Alerts</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Know when rankings move — before your client does.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Set threshold-based alerts for any tracked keyword: notify when a keyword drops out of the top 3, enters the top 3 for the first time, or moves 3+ positions in either direction. Alerts fire instantly via email. For agencies, this means you're always the first to know — so you can respond, communicate, and show value before the client notices anything changed.
              </p>
              <a href="/solutions/agencies/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See Stacc for agencies
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Ranking alerts — this week</p>
              {[
                { type: 'up', kw: '"plumber near me" — entered top 3', time: '2h ago', loc: 'Oak Park' },
                { type: 'down', kw: '"emergency plumber" — dropped to #6', time: '1d ago', loc: 'Evanston' },
                { type: 'up', kw: '"water heater repair" — hit #1', time: '2d ago', loc: 'Oak Park' },
                { type: 'up', kw: '"drain cleaning" — entered top 3', time: '3d ago', loc: 'Naperville' },
              ].map(a => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[10px] ${a.type === 'up' ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#fff1f2] text-[#ef4444]'}`}>{a.type === 'up' ? '↑' : '↓'}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-medium text-[#111827] truncate">{a.kw}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{a.loc} · {a.time}</p>
                  </div>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Instant email delivery · Zero manual checks</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 1, suffix: '×/day', label: 'Ranking update frequency', sub: 'Every keyword, every location, daily' },
            { to: 3, suffix: ' surfaces', label: 'Ranking surfaces tracked', sub: 'Local pack, Maps, and organic' },
            { to: 5, suffix: '×', label: 'Faster change detection', sub: 'Daily vs monthly tracking' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What customers say</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Real results from businesses<br />and agencies using Stacc.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-2">
          {[
            { quote: "I stopped manually checking keywords in spreadsheets the day I started Stacc. Daily updates, instant alerts. We caught a major ranking drop on day 2 instead of day 30 — that's the difference between a fixable problem and a month of lost traffic.", name: "Sam H.", role: "SEO Manager · 18 clients", result: "Caught drop on day 2" },
            { quote: "Managing 18 clients with daily rank data used to mean 3 hours of manual tracking every week. Now I open the dashboard and it's done. Every client, every keyword, every location — updated automatically every morning.", name: "Rosa M.", role: "Agency Owner · 18 clients", result: "3 hrs/week saved" },
            { quote: "The local pack vs. organic tracking is the thing nobody else offers clearly. For local businesses, knowing your pack position separately is critical. Your organic position being #2 means nothing if you're #7 in the pack.", name: "Tom B.", role: "Local SEO Consultant", result: "Separate pack + organic data" },
