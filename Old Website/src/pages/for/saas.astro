---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "How long until our SaaS blog starts ranking on Google?",
    a: "SEO content compounds over time. Most SaaS companies see their first meaningful organic ranking improvements at 3–6 months, with significant traffic growth by month 9–12. The key is publishing volume and consistency — 30+ blog posts per month for 6 months is 180 permanent ranking assets. Each month you publish adds to a compounding foundation that your competitors can't easily replicate.",
  },
  {
    q: "Are the articles actually high quality, or just keyword-stuffed content?",
    a: "Every article is researched for search intent, competitive gap, and ranking opportunity — not just keyword density. Articles follow proper heading structure, include internal linking, and are optimized for the specific search query they're targeting. They read like content written by someone who understands the SaaS category, not a generic content mill output.",
  },
  {
    q: "What keywords does Stacc target for SaaS companies?",
    a: "Stacc targets the full funnel of SaaS searches: problem-awareness terms ('how to manage [problem]'), solution-comparison searches ('best [category] software'), alternative searches ('[competitor] alternative'), and high-intent trial terms ('[category] software for [use case]'). These are the searches your future users make before they sign up — capturing them is top-of-funnel demand generation at the cost of a monthly subscription.",
  },
  {
    q: "Which CMS platforms does Stacc publish to?",
    a: "Stacc publishes directly to WordPress, Webflow, HubSpot CMS, Ghost, and custom platforms via API. Setup takes under 10 minutes. After the initial connection, articles are published on schedule every month without you touching anything.",
  },
  {
    q: "Can we review and approve articles before they go live?",
    a: "Yes. You can choose an approval workflow where articles are sent for review before publishing, or a fully automated workflow where articles publish on schedule. Most SaaS companies start with approval and switch to fully automated once they see the quality is consistent.",
  },
  {
    q: "How is Stacc different from a content marketing agency?",
    a: "A content marketing agency that publishes 30+ blog posts per month for a SaaS company charges $5,000–$15,000/month. They have account managers, strategy calls, editorial processes, and significant overhead. Stacc automates every part of that process — keyword research, article writing, CMS publishing, internal linking, meta optimization — for $99/month. The output is comparable. The cost difference is not.",
  },
  {
    q: "How specific can articles be to our product's niche?",
    a: "Very specific. Stacc is trained on your product category, target customer, and competitive landscape. Articles reference your specific use case, target the keywords your ICP searches, and are written for your audience — not a generic SaaS audience. The more context you provide during setup, the more targeted the content.",
  },
  {
    q: "Is blog SEO different from local SEO? We're not a local business.",
    a: "Yes — blog SEO and local SEO are completely different. Local SEO (the $49/month module) targets Google Maps and GBP for businesses that serve a geographic area. Blog SEO (the $99/month module) targets Google's organic search results with article content. SaaS companies need blog SEO — ranking for the problem, comparison, and solution searches that happen before someone signs up for a trial.",
  },
];
---

<BaseLayout
  title="SaaS SEO | Rank for High-Intent Keywords That Drive Signups | theStacc"
  description="Stacc publishes 30 SEO blog posts to your SaaS website every month — researched, written, and live. Rank for the keywords your trial users search before they find you. $99/month."

>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SaaS SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            30 SEO articles published to your SaaS site.<br />
            <span style="color:#4f39f6;">Every single month.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Your SaaS competitors are publishing 30+ SEO articles a month. If you're publishing 2–3, you're losing organic search ground every week. Stacc researches, writes, and publishes 30 SEO-optimized articles to your site every month — targeting the keywords your future users are searching right now.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No contracts · 30+ blog posts published monthly
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '30',  num: 30, prefix: '', suffix: '',   decimals: 0, from: 0, label: 'SEO articles published per month' },
              { value: '3yr', num: 3,  prefix: '', suffix: 'yr', decimals: 0, from: 0, label: 'Average article ranking lifespan' },
              { value: '15×', num: 15, prefix: '', suffix: '×',  decimals: 0, from: 0, label: 'More content than avg SaaS competitor' },
              { value: '$99', num: 99, prefix: '$', suffix: '',  decimals: 0, from: 0, label: 'per month, all inclusive' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">SaaS companies publishing with Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 from 127 reviews</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Project Management SaaS — San Francisco, CA', 'CRM Platform — Austin, TX', 'Analytics Tool — New York, NY', 'Scheduling SaaS — Denver, CO', 'HR Software — Seattle, WA', 'Sales Platform — Chicago, IL', 'Marketing SaaS — Boston, MA', 'Project Management SaaS — San Francisco, CA', 'CRM Platform — Austin, TX', 'Analytics Tool — New York, NY', 'Scheduling SaaS — Denver, CO', 'HR Software — Seattle, WA', 'Sales Platform — Chicago, IL', 'Marketing SaaS — Boston, MA'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Your competitors are publishing 30+ blog posts per month.<br />You're publishing two.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            SEO content compounds. Every article your competitor publishes is a permanent ranking asset that captures search traffic for years. Every month you wait, the gap widens.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Your competitor published 30+ blog posts last month. You published 2.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">SEO compounds. Every article your competitor publishes is a permanent asset that captures search traffic for 3+ years. Every month you're below your publishing velocity benchmark, the gap widens. By the time you try to catch up, they'll have 200 more articles ranking above you for your best keywords.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Your trial users are Googling questions your blog doesn't answer.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Before someone signs up for your SaaS, they research. They search "best [category] software," "how to [problem you solve]," and "[competitor] alternative." If your blog doesn't rank for those searches, your competitor's blog does — and your future customer converts there instead of coming to you.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">You have 5 blog posts from 2022. Your competitor has 400.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Content volume is a competitive moat. A SaaS with 400 optimized articles captures search traffic for hundreds of keywords — problem-awareness terms, solution-comparison terms, and high-intent trial-signup terms. A blog with 5 posts captures almost none of it. Every month without consistent publishing is a month that moat gets deeper on their side, not yours.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does for SaaS companies</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            30 SEO articles a month. Every lever that drives organic signups. Handled.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Ranking for the keywords your trial users search requires consistent content publishing, keyword research, and CMS execution — every single month. Stacc handles all of it automatically.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Blog Content Publishing',
              body: '30 SEO-optimized articles published to your SaaS website every month. Researched, written, and live — targeting the keywords your future users search before they sign up.',
              icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
            },
            {
              title: 'SaaS Keyword Research',
              body: 'Pain-point keywords, comparison searches, tutorial content, and alternative searches — the full funnel of queries your ICP types before they evaluate SaaS tools in your category.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'SEO-Optimized Articles',
              body: 'Every article includes optimized meta titles, meta descriptions, proper H1/H2 structure, and internal linking to your most important product pages. Built to rank, not just to publish.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Competitor Content Gap Analysis',
              body: "Identifies the exact keywords your competitors are ranking for that you aren't. Surfaces the highest-opportunity articles to publish first — so every month's content budget goes to maximum ranking impact.",
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
            {
              title: 'Content Calendar Planning',
              body: "Monthly content calendar with keyword targets, search volume, intent mapping, and priority scoring. You know exactly what's being published, why it's being targeted, and what ranking it's going after.",
              icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
            },
            {
              title: 'CMS Publishing',
              body: 'Direct publishing to WordPress, Webflow, HubSpot CMS, Ghost, or your custom platform via API. No copy-pasting, no manual uploads. Articles go live on your site automatically, on schedule.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connect once. 30 SEO articles publish to your<br />SaaS site every month from there.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            No keyword research spreadsheets. No writers to manage. No manual CMS uploads. Set it up once and your blog runs itself — publishing 30+ blog posts per month on autopilot.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connect your CMS</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Stacc integrates with your WordPress, Webflow, HubSpot, Ghost, or custom CMS. We audit your existing content, identify keyword gaps, and build a 30-article monthly content plan targeting your highest-value search terms.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">AI researches and writes 30 SEO articles</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Each article is researched for search intent, competitive gap, and ranking opportunity. Articles target problem-awareness keywords, solution-comparison searches, and high-intent alternative keywords — the content that captures users before they sign up.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Articles publish to your site. Rankings build. Signups increase.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Content goes live on your site every month on schedule. Each article builds domain authority, captures long-tail keywords, and compounds over time. Your organic traffic grows month over month without you writing a single word.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── RESULTS METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">By the numbers</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What the data says about SaaS<br />content and organic growth.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            The publishing velocity gap between top-ranking SaaS companies and everyone else is wider than most founders realize.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-2 md:grid-cols-4" style="border:1px solid rgba(255,255,255,0.08);">
          {[
