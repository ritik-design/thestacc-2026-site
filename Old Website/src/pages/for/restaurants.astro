---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "How long until my restaurant ranks higher on Google Maps?",
    a: "Most restaurants see meaningful Maps movement within 60–90 days of consistent GBP activity. Restaurants that were posting nothing before tend to see results fastest. The Maps algorithm immediately rewards fresh, consistent content — especially in competitive dining markets.",
  },
  {
    q: "Does posting to GBP actually help a restaurant rank?",
    a: "Yes. Google's local algorithm factors in posting frequency, review responsiveness, and keyword relevance. Every week your GBP is inactive, the restaurant down the street that posts daily gains ground on 'restaurant near me' searches. Stacc posts 30 times a month so your profile is always fresh.",
  },
  {
    q: "What restaurant keywords does Stacc target?",
    a: "Stacc targets cuisine + city and occasion-based combinations — 'Italian restaurant near me,' 'best brunch [city],' 'family dinner [city],' 'date night restaurant [city],' 'happy hour [city].' All calibrated to your cuisine type, price point, and the dining occasions you want to own.",
  },
  {
    q: "My restaurant already has a GBP. Do I need to do anything to set it up?",
    a: "Just connect it. Stacc pulls your existing GBP data — restaurant name, cuisine type, photos, review history, and current ranking — and builds a content plan from there. Setup takes under five minutes.",
  },
  {
    q: "What happens when I get a negative review?",
    a: "Stacc sends an instant alert the moment a new review appears on Google, with the review text and a response template. In the restaurant business, how you respond to a bad review publicly is often more important than the review itself — it shows every future customer how you handle problems.",
  },
  {
    q: "Do you work with restaurant groups and multi-location concepts?",
    a: "Yes. Each location gets its own keyword strategy, content calendar, GBP post schedule, and ranking report — all managed from one dashboard. Posts target that location's specific neighborhood and local dining keywords.",
  },
  {
    q: "How is Stacc different from a restaurant marketing agency?",
    a: "A restaurant marketing agency charges $500–$1,500/month for manual GBP management and requires long contracts. Stacc automates everything for $49/month. Most restaurant owners who use Stacc had previously paid agencies far more for less volume and less consistency.",
  },
  {
    q: "Does Stacc help with restaurant blog content?",
    a: "Stacc's Local SEO module handles GBP posts, review monitoring, and rank tracking. If you want blog content — articles like 'best date night restaurants in [city]' or '[city] restaurant week guide' that rank on Google and drive organic traffic — that's the Blog SEO module at $99/month.",
  },
];
---

<BaseLayout
  title="Restaurant SEO | Get More Diners From Google | theStacc"
  description="Stacc posts to your restaurant's Google Business Profile every day, manages your reviews, and tracks your Maps ranking — automatically. Get more diners from Google for $49/month."

>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Restaurant SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            More diners from Google.<br />
            <span style="color:#4f39f6;">Every single day.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            1.8 million people search "restaurant near me" every day. 86% of those searches lead to a visit within 24 hours. Stacc makes sure your restaurant shows up first — by posting to your Google Business Profile daily, managing your reviews, and tracking your Maps ranking.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No contracts · Posts to your GBP every day
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '1.8M', num: 1.8, prefix: '',  suffix: 'M', decimals: 1, from: 0, label: 'Daily "restaurant near me" searches' },
              { value: '86%',  num: 86,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Searchers visit within 24 hours' },
              { value: '4.4×', num: 4.4, prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Avg Maps ranking lift' },
              { value: '100%', num: 100, prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Reviews captured instantly' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Local businesses ranking with Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 from 127 reviews</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['The Corner Bistro — Chicago, IL', 'Casa del Sol — Houston, TX', 'Desert Rose Kitchen — Phoenix, AZ', 'Mountain Table — Denver, CO', 'Pier 42 Restaurant — Seattle, WA', 'Bayfront Grill — Miami, FL', 'The Southern Table — Atlanta, GA', 'The Corner Bistro — Chicago, IL', 'Casa del Sol — Houston, TX', 'Desert Rose Kitchen — Phoenix, AZ', 'Mountain Table — Denver, CO', 'Pier 42 Restaurant — Seattle, WA', 'Bayfront Grill — Miami, FL', 'The Southern Table — Atlanta, GA'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Diners are searching right now.<br />They're sitting in a competitor's booth.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            86% of people who find a restaurant in local search visit within 24 hours. The only question is whose restaurant they find.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Your competitor posts daily specials and events. Your GBP was last updated last month.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">The Maps algorithm rewards restaurants that post consistently — daily specials, weekend events, menu updates, holiday hours. Every week your GBP goes dark, a competing restaurant that posts regularly gets more of the 'restaurant near me' searches that should be going to you.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">One 2-star review about cold food is keeping tables empty.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">90% of diners check online reviews before choosing a restaurant. A negative review left unanswered tells future customers you don't care — which is the one thing a restaurant can never afford to signal. Your star rating determines whether you fill seats or watch them sit empty.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">You show up when people search your name. Not when they're hungry.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Hungry people don't search your restaurant name — they search 'Italian restaurant near me,' 'best brunch [city],' and 'family restaurant open now.' If you're not in the Map Pack for those searches, those diners are sitting in a competitor's booth tonight.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does for restaurants</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every lever that drives new diners from Google. Handled.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Maps ranking for restaurants requires consistent GBP activity, fast review responses, and keyword-targeted content — every single month. Stacc handles all of it automatically.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'GBP Post Publishing',
              body: '30 location-optimized posts per month — daily specials, seasonal menus, events, holiday hours, and "best [cuisine] in [city]" content. Published on schedule automatically so your profile is always active.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Restaurant Keyword Targeting',
              body: 'Cuisine + city combinations, occasion-based searches, and intent-specific keywords — "brunch near me," "date night restaurant [city]," "best pizza [city]." Calibrated to your cuisine type and the occasions you want to own.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Review Monitoring',
              body: 'Instant alerts the moment a new review appears — Yelp, Google, TripAdvisor. Star rating trend tracking week-over-week. Response templates so you can reply in under a minute and protect the reputation that fills your seats.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Local Rank Tracking',
              body: 'Grid-based Maps ranking reports showing exactly where your restaurant ranks for every target keyword across your neighborhood and city. Month-over-month tracking to see your position compound.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Multi-Location Management',
              body: 'Multiple restaurant locations? Each gets its own keyword strategy, content calendar, and performance report — all from one dashboard. Track which locations need attention and see every location\'s Maps ranking side by side.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Citation Building',
              body: 'NAP consistency checks and directory submissions across restaurant platforms — Yelp, TripAdvisor, OpenTable, Grubhub, and 50+ others. The authority signals that help you rank above competing restaurants.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connect once. Stacc runs your restaurant's<br />Maps presence from that day forward.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            No GBP logins. No writing posts. No manually checking reviews. Set it up once and your Google Business Profile runs itself — so you can focus on running the kitchen.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connect your Google Business Profile</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Search for your restaurant by name. Stacc pulls your GBP data, review history, and ranking position — and identifies which food and dining keywords you're not showing up for in your neighborhood.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">AI builds your restaurant content plan</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 location-optimized posts per month. Daily specials, seasonal promotions, events, and cuisine-specific content targeting your exact neighborhood and dining occasion keywords.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Posts go live. Rankings climb. Tables fill.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Content publishes to your GBP on schedule. Review alerts arrive instantly. Your Maps ranking updates monthly. Diners discover you on Google while you focus on running the kitchen.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── RESULTS METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">By the numbers</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What the data says about diners<br />and local search.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            The opportunity is bigger than most restaurants realize — and most competitors aren't taking it seriously yet.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-2 md:grid-cols-4" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '1.8M', num: 1.8, prefix: '', suffix: 'M', decimals: 1, from: 0, label: '"Restaurant near me" searches per day', sub: 'in the US alone'                         },
            { value: '86%',  num: 86,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Searchers visit within 24 hours',       sub: 'highest purchase intent of any search'  },
            { value: '90%',  num: 90,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Diners check reviews before visiting',  sub: 'your star rating is your curb appeal'  },
            { value: '4.4×', num: 4.4, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Avg Maps ranking lift with Stacc',     sub: 'within 90 days of consistent activity' },
          ].map(s => (
