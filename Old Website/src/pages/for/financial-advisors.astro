---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "How long until my financial advisory firm ranks higher on Google Maps?",
    a: "Most independent advisors see meaningful movement in 60–90 days. Financial advisory has strong local search demand and many advisors who have never updated their GBP — so the ranking opportunity is significant.",
  },
  {
    q: "Does posting to GBP actually help a financial advisor rank?",
    a: "Yes. The Maps algorithm rewards consistent GBP activity — market updates, retirement planning tips, tax season reminders, and life event content. Advisors who stay top-of-mind through consistent posting rank higher and capture clients at the moment of financial decision.",
  },
  {
    q: "What financial advisor keywords does Stacc target?",
    a: "Stacc targets service + city combinations — 'financial advisor near me,' 'retirement planner [city],' 'wealth management [city],' 'investment advisor [city],' 'fiduciary [city].' All calibrated to your specific specialty and location.",
  },
  {
    q: "My firm already has a GBP. Do I need to do anything special?",
    a: "Just connect it. Stacc pulls your existing data and builds a content plan in under 5 minutes. After that, posts publish automatically and review alerts arrive instantly.",
  },
  {
    q: "What happens when I get a negative review?",
    a: "Instant alert with review text and a response template so you can reply promptly. When someone is deciding who will manage their retirement savings, your response to criticism tells them everything about how you handle client relationships.",
  },
  {
    q: "Do you work with multi-office advisory firms?",
    a: "Yes. Each office gets its own keyword strategy, content calendar, and ranking report from one dashboard.",
  },
  {
    q: "How is Stacc different from a financial marketing agency?",
    a: "Agencies charge $1,000–$3,000/month for manual GBP management. Stacc automates everything for $49/month with more output — 30 posts/month vs the typical 8–12.",
  },
  {
    q: "Does Stacc help with financial planning blog content?",
    a: "Yes — the Blog SEO module at $99/month publishes articles like 'when should I start saving for retirement' and 'how to choose a financial advisor' that rank on Google and drive new client inquiries. Many advisors use both.",
  },
];
---

<BaseLayout
  title="Financial Advisor SEO | Get More Clients From Google | theStacc"
  description="Stacc posts to your financial advisory firm's Google Business Profile every day, manages your reviews, and tracks your Maps ranking — automatically. Get more financial planning clients from Google for $49/month."

>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Financial Advisor SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            More financial planning clients from Google.<br />
            <span style="color:#4f39f6;">Without cold calling.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            160,000 people search "financial advisor near me" every month. 71% of people research financial advisors online before reaching out. Stacc makes sure your firm shows up first — posting to your GBP daily, managing reviews, and tracking your Maps ranking.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No contracts · Posts to your GBP every day
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '160K',  num: 160,  prefix: '',  suffix: 'K', decimals: 0, from: 0, label: 'Monthly "financial advisor near me" searches' },
              { value: '71%',   num: 71,   prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Clients research advisors online first' },
              { value: '4.3×',  num: 4.3,  prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Avg Maps ranking lift' },
              { value: '100%',  num: 100,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Reviews captured instantly' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Local businesses ranking with Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 from 127 reviews</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Metro Wealth Advisors — Chicago, IL', 'Lone Star Financial — Houston, TX', 'Desert Wealth Group — Phoenix, AZ', 'Summit Financial Planning — Denver, CO', 'Pacific Wealth Partners — Seattle, WA', 'Coastal Financial Group — Miami, FL', 'Southern Wealth Advisors — Atlanta, GA', 'Metro Wealth Advisors — Chicago, IL', 'Lone Star Financial — Houston, TX', 'Desert Wealth Group — Phoenix, AZ', 'Summit Financial Planning — Denver, CO', 'Pacific Wealth Partners — Seattle, WA', 'Coastal Financial Group — Miami, FL', 'Southern Wealth Advisors — Atlanta, GA'].map((name, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Prospective clients are searching right now.<br />They're calling a competing advisor.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            73% of people read reviews before choosing a financial advisor. The only question is whose firm they find first in the Map Pack.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Your GBP has never been updated. Your competitor posts retirement planning content every week.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Financial advisors who stay top-of-mind through consistent GBP activity — market updates, retirement planning tips, tax season reminders, and life event content — rank higher in Maps AND capture clients at the moment of financial decision. Every week your profile goes dark, a competing advisor builds the visibility and trust that brings new clients to their door.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">One unanswered negative review is costing you a $1M AUM client.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">73% of people read reviews before choosing a financial advisor. When someone is deciding who will manage their retirement savings, they vet you thoroughly. A review about poor communication or unexpected fees that goes unanswered tells every future client the worst possible thing: that you don't stand behind your service. Your star rating is your credibility at scale.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">You rank for your firm name. Not for "financial advisor near me."</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">People who need a financial advisor search "financial advisor near me," "retirement planner [city]," and "wealth management [city]." They don't search for your firm name. If you're not in the Map Pack for those searches, you're invisible to the people who are ready to move their IRA or start their retirement plan right now.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does for financial advisors</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every lever that drives new clients from Google. Handled.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Maps ranking for financial advisors requires consistent GBP activity, fast review responses, and keyword-targeted content — every single month. Stacc handles all of it automatically.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'GBP Post Publishing',
              body: '30 posts/month — market updates, retirement planning tips, tax season reminders, life event financial milestones, and educational content. Published automatically.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Financial Keyword Targeting',
              body: 'Service + city: financial advisor, retirement planner, wealth management, investment advisor, fiduciary. Calibrated to your specialty and location.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Review Monitoring',
              body: 'Instant review alerts with response templates to protect the credibility that wins clients who are entrusting you with their financial future.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Local Rank Tracking',
              body: 'Grid-based Maps ranking for every keyword across your service area. Month-over-month tracking so you see your position compound.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Multi-Office Management',
              body: 'Multiple office locations? Each gets its own keyword strategy, content calendar, and ranking report from one dashboard.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Citation Building',
              body: 'Directory submissions across NAPFA, CFP Board, financial directories, Yelp, and 50+ others. Authority signals that build trust and rank.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connect once. Stacc runs your advisory firm's<br />Maps presence from that day forward.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            No GBP logins. No writing posts. No manually checking reviews. Set it up once and your Google Business Profile runs itself — so you can focus on clients and portfolios.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connect your Google Business Profile</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Search for your advisory firm. Stacc identifies which financial keywords you're not showing up for — retirement planner, wealth management, fiduciary, and more.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">AI builds your financial content plan</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 posts/month — market updates, retirement planning tips, tax reminders, life event milestones. All written to match the search intent of people ready to move assets or start a financial plan.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Posts live. Rankings climb. New clients call.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Content publishes on schedule. Review alerts arrive instantly. New client inquiries come in while you're in client meetings.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── RESULTS METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">By the numbers</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What the data says about financial planning<br />clients and local search.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            The opportunity is significant — and most independent advisors aren't taking local search seriously yet.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-2 md:grid-cols-4" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '160K',  num: 160,  prefix: '', suffix: 'K', decimals: 0, from: 0, label: '"Financial advisor near me" searches per month', sub: 'in the US alone' },
            { value: '71%',   num: 71,   prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Clients research advisors before reaching out', sub: 'your GBP is their first impression' },
            { value: '85%',   num: 85,   prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Maps searchers contact the firm', sub: 'high intent — ready to move assets' },
            { value: '4.3×',  num: 4.3,  prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Avg Maps ranking lift with Stacc', sub: 'within 90 days of consistent activity' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[2.8rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[13px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
