---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const localSEO = [
  { label: 'Accountants',        href: '/for/accountants/'        },
  { label: 'Auto Dealers',       href: '/for/auto-dealers/'       },
  { label: 'Chiropractors',      href: '/for/chiropractors/'      },
  { label: 'Cleaning Services',  href: '/for/cleaning/'           },
  { label: 'Contractors',        href: '/for/contractors/'        },
  { label: 'Dentists',           href: '/for/dentists/'           },
  { label: 'Electricians',       href: '/for/electricians/'       },
  { label: 'Financial Advisors', href: '/for/financial-advisors/' },
  { label: 'Gyms',               href: '/for/gyms/'               },
  { label: 'Healthcare',         href: '/for/healthcare/'         },
  { label: 'Home Inspectors',    href: '/for/home-inspectors/'    },
  { label: 'HVAC',               href: '/for/hvac/'               },
  { label: 'Insurance',          href: '/for/insurance/'          },
  { label: 'Landscapers',        href: '/for/landscapers/'        },
  { label: 'Lawyers',            href: '/for/lawyers/'            },
  { label: 'Movers',             href: '/for/movers/'             },
  { label: 'Pet Services',       href: '/for/pet-services/'       },
  { label: 'Photographers',      href: '/for/photographers/'      },
  { label: 'Plumbers',           href: '/for/plumbers/'           },
  { label: 'Real Estate',        href: '/for/real-estate/'        },
  { label: 'Restaurants',        href: '/for/restaurants/'        },
  { label: 'Roofers',            href: '/for/roofers/'            },
  { label: 'Salons',             href: '/for/salons/'             },
  { label: 'Therapists',         href: '/for/therapists/'         },
  { label: 'Tutoring',           href: '/for/tutoring/'           },
  { label: 'Veterinarians',      href: '/for/veterinarians/'      },
  { label: 'Wedding Vendors',    href: '/for/wedding/'            },
];

const blogSEO = [
  { label: 'Consulting Firms',   href: '/for/consulting/'         },
  { label: 'Ecommerce',          href: '/for/ecommerce/'          },
  { label: 'SaaS',               href: '/for/saas/'               },
];
---

<BaseLayout
  title="Stacc for Every Industry | SEO Automation by Business Type | theStacc"
  description="Stacc automates SEO for 30+ industries — from local service businesses to SaaS companies. Find your industry and see exactly how Stacc grows your organic search traffic."

>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-[680px] text-center">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">30 Industries · Local SEO &amp; Blog SEO</span>
          </div>
          <h1 class="font-sans text-[2.2rem] font-semibold leading-[1.15] tracking-[-0.035em] text-[#111827] md:text-[3rem]">
            SEO built for your industry.
          </h1>
          <p class="mx-auto mt-5 max-w-[540px] font-sans text-[1.05rem] leading-[1.7] text-[#57534e]">
            Every industry has different keywords, different buyers, and different ranking signals. Stacc is trained on your category — so the posts, articles, and optimizations that go out every month are specific to how your customers actually search.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#292524] transition-colors hover:bg-[#fafaf9]"
            >
              See pricing
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── MODULE EXPLAINER STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-10">
        <div class="mx-auto grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-2">
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">Local SEO</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$49/mo</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">For businesses that depend on local search — GBP posts, review monitoring, and Maps rank tracking. Best for service businesses, brick-and-mortar, and anyone who wants to rank in the Map Pack.</p>
            </div>
          </div>
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">Blog SEO</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$99/mo</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">For businesses that grow through organic content — 30 SEO articles published to your site every month. Best for SaaS, ecommerce, and professional services that compete nationally.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── LOCAL SEO INDUSTRIES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Local SEO Module</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$49/mo · {localSEO.length} industries</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Local service businesses
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            GBP posts, review management, and Map Pack rank tracking — all automated.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {localSEO.map(item => (
            <a
              href={item.href}
              class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BLOG SEO INDUSTRIES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Blog SEO Module</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">$99/mo · {blogSEO.length} industries</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Content-driven businesses
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            30 SEO articles published to your site every month — researched, written, and live.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3">
          {blogSEO.map(item => (
            <a
              href={item.href}
              class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BOTTOM CTA ─── -->
    <section class="relative overflow-hidden py-16 md:py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.18) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.03) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>

      <div class="container-x relative">
        <div class="mx-auto max-w-xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Don't see your industry?</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.03em] text-[#292524] md:text-[2.4rem]">
            Stacc works for any<br />business that needs organic traffic.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            If your customers search for you on Google, Stacc can automate the SEO that gets you found. Book a demo and we'll show you how it works for your specific business.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]"
            >
              Book a demo
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/pricing/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff] bg-white"
            >
              View pricing
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
