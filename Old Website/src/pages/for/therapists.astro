---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "How long until my therapy practice ranks higher on Google Maps?",
    a: "Most therapy practices see meaningful Maps movement within 60–90 days of consistent GBP activity. Google's local algorithm rewards frequency, relevance, and engagement — all three of which Stacc provides automatically every month. Practices that were posting nothing before tend to see results fastest.",
  },
  {
    q: "Does posting to GBP actually help a therapy practice rank?",
    a: "Yes. Google's own documentation states that regularly updated Business Profiles are more likely to appear in local search results. The Maps algorithm factors in posting frequency, review responsiveness, and keyword relevance. Every day you're inactive, a competing therapist who posts consistently gains ground. Stacc posts 30 times a month so your profile is never dark.",
  },
  {
    q: "What therapy keywords does Stacc target?",
    a: "Stacc targets your core specialty + city combinations — things like 'therapist near me,' 'anxiety therapist [city],' 'couples counseling [city],' 'EMDR therapist [city],' 'depression therapy [city],' 'CBT therapist [city],' and 'child therapist [city].' All keywords are calibrated to your specific specialties and location.",
  },
  {
    q: "My practice already has a Google Business Profile. Do I need to do anything to set it up?",
    a: "Just connect it. Stacc pulls your existing GBP data — business name, services, photos, review history, and current ranking position — and builds a content plan from there. Setup takes under five minutes. After that, Stacc handles everything: writing posts, publishing on schedule, sending review alerts, and tracking your Maps ranking month over month.",
  },
  {
    q: "What happens when I get a negative review? Trust is everything in therapy.",
    a: "Stacc sends an instant alert the moment a new review appears, positive or negative. You get the review text, the star rating, and a response template so you can reply in under a minute. In therapy, where trust is the foundation of every client relationship, responding thoughtfully to negative reviews is one of the highest-ROI actions you can take — it signals to every future client that you take their experience seriously.",
  },
  {
    q: "Do you work with group practices or multi-location therapy centers?",
    a: "Yes. Each location gets its own keyword strategy, content calendar, GBP post schedule, and ranking report — all managed from one dashboard. Posts target that location's specific city, specialties, and local search intent. You can see every location's performance side by side.",
  },
  {
    q: "How is Stacc different from a therapy marketing agency or Psychology Today?",
    a: "Psychology Today charges $29–$59/month per listing and generates inconsistent leads. A therapy marketing agency charges $700–$1,800/month. Stacc automates GBP posting, review monitoring, and rank tracking for $49/month — and Google Maps leads are free. The intent-to-book rate for local search is significantly higher than directory browsing.",
  },
  {
    q: "Does Stacc help with mental health blog content or just GBP?",
    a: "Stacc's Local SEO module handles GBP posts, review monitoring, and rank tracking. If you want mental health articles published to your website every month — the type that ranks for 'signs of anxiety' and 'how to find a therapist' — that's the Blog SEO module at $99/month. Many therapy practices use both together for full organic search coverage.",
  },
];
---

<BaseLayout
  title="Therapist SEO | Get More Therapy Clients From Google | theStacc"
  description="Stacc posts to your therapy practice's Google Business Profile every day, manages your reviews, and tracks your Maps ranking — automatically. Get more therapy clients from Google for $49/month."

>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Therapist SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            More therapy clients from Google.<br />
            <span style="color:#4f39f6;">Without the directory fees.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            720,000 people search "therapist near me" every month. 74% of people seeking therapy research practitioners online before reaching out. Stacc makes sure your practice shows up first — posting to your GBP daily, managing reviews, and tracking your Maps ranking.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No contracts · Posts to your GBP every day
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '720K',  num: 720,  prefix: '',  suffix: 'K',  decimals: 0, from: 0, label: 'Monthly "therapist near me" searches' },
              { value: '74%',   num: 74,   prefix: '',  suffix: '%',  decimals: 0, from: 0, label: 'Clients research online first' },
              { value: '4.5×',  num: 4.5,  prefix: '',  suffix: '×',  decimals: 1, from: 0, label: 'Avg Maps ranking lift' },
              { value: '100%',  num: 100,  prefix: '',  suffix: '%',  decimals: 0, from: 0, label: 'Reviews captured instantly' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Therapy practices ranking with Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 from 127 reviews</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Mindful Path Therapy — Chicago, IL','Lone Star Counseling — Houston, TX','Desert Healing Center — Phoenix, AZ','Summit Therapy Group — Denver, CO','Pacific Counseling Center — Seattle, WA','Sunshine Behavioral Health — Miami, FL','Southern Counseling Group — Atlanta, GA','Mindful Path Therapy — Chicago, IL','Lone Star Counseling — Houston, TX','Desert Healing Center — Phoenix, AZ','Summit Therapy Group — Denver, CO','Pacific Counseling Center — Seattle, WA','Sunshine Behavioral Health — Miami, FL','Southern Counseling Group — Atlanta, GA'].map((name, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            People seeking therapy are searching right now.<br />They're calling someone else.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            83% of Maps searchers contact the practice they find. The only question is whose practice they find first.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Psychology Today charges you monthly. Google Maps sends clients for free — if you rank.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Therapist directory listings on Psychology Today cost $29–$59/month per listing and generate inconsistent leads. Google Maps leads are free — clients call directly from your GBP. But capturing those leads requires ranking in the top 3, which requires consistent GBP activity. Every month your profile goes dark, a competing therapist who posts consistently gains the Maps authority that fills their calendar.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">One unanswered review about a bad experience is keeping clients away.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">76% of people check reviews before choosing a therapist. Therapy is the most trust-dependent service relationship that exists — clients are sharing their most private struggles. An unanswered negative review about feeling unheard or dismissed tells every future client exactly what they're afraid of. Your star rating is your first impression for every person who finds you on Maps.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">You rank for your name. Not for "anxiety therapist near me."</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">People seeking therapy don't search for your name — they search 'therapist near me,' 'anxiety therapist [city],' and 'couples counseling [city].' If you're not in the Map Pack for those searches, those clients call whoever is — and miss out on the practice that might be the best fit for them.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does for therapists</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every lever that drives new therapy clients from Google. Handled.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Maps ranking for therapy practices requires consistent GBP activity, fast review responses, and keyword-targeted content — every single month. Stacc handles all of it automatically.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'GBP Post Publishing',
              body: '30 location-optimized posts per month — mental health awareness content, specialty spotlights, accepting new clients updates, and seasonal mental health content. Published on schedule automatically.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Therapy Keyword Targeting',
              body: 'Specialty + city combinations — anxiety therapist, couples counseling, EMDR, depression therapy, CBT therapist, child therapist. All calibrated to your specific specialties and location.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Review Monitoring',
              body: 'Instant alerts the moment a new review appears. Star rating trend tracking week-over-week. Response templates so you can reply thoughtfully in under a minute — critical in the trust-sensitive world of mental health.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Local Rank Tracking',
              body: 'Grid-based Maps ranking reports showing exactly where your therapy practice ranks for every target keyword across your service area. Month-over-month tracking so you see your progress compound.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Multi-Location / Group Practice',
              body: 'Multiple therapists or locations? Each gets its own keyword strategy, content calendar, and performance report — all from one dashboard. See which locations need attention and track improvement across every office.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Citation Building',
              body: 'NAP consistency checks and directory submissions across mental health directories — Psychology Today, Zocdoc, Healthgrades, and 50+ others. The behind-the-scenes authority signals that help you outrank competitors.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connect once. Stacc runs your therapy practice's<br />Maps presence from that day forward.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            No GBP logins. No writing posts. No manually checking reviews. Set it up once and your Google Business Profile runs itself — so you can focus on your clients.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connect your Google Business Profile</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Search for your therapy practice by name. Stacc pulls your current GBP data, review history, and ranking position — and identifies exactly which therapy keywords you're not showing up for in your area.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">AI builds your therapy practice content plan</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30 location-optimized posts per month targeting your specific specialties and city — anxiety therapy, couples counseling, EMDR, depression, CBT — all written to boost your Maps signals and match what clients are searching.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Posts go live. Rankings climb. New clients call.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Content publishes to your GBP on schedule every month. Review alerts arrive the instant a new one appears. Your Maps ranking report updates monthly. New client inquiries come in while you focus on your sessions.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── RESULTS METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">By the numbers</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What the data says about therapy clients<br />and local search.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            The demand for mental health services has never been higher — and most therapy practices aren't capturing it from Google.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-2 md:grid-cols-4" style="border:1px solid rgba(255,255,255,0.08);">
