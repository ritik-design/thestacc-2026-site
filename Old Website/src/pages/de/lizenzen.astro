---
import LegalLayout from '../../layouts/LegalLayout.astro';

const toc = [
  { id: 'intro',    label: 'Über diese Seite' },
  { id: 'frontend', label: 'Frontend-Technologien' },
  { id: 'fonts',    label: 'Schriftarten' },
  { id: 'devtools', label: 'Entwicklungstools' },
];

const frontendLibraries = [
  { name: 'Astro',        licence: 'MIT License',           url: 'https://astro.build' },
  { name: 'Tailwind CSS', licence: 'MIT License',           url: 'https://tailwindcss.com' },
  { name: 'Three.js',     licence: 'MIT License',           url: 'https://threejs.org' },
];

const fonts = [
  { name: 'Geist Sans',   licence: 'SIL Open Font License', url: 'https://fonts.google.com/specimen/Geist' },
  { name: 'Geist Mono',   licence: 'SIL Open Font License', url: 'https://fonts.google.com/specimen/Geist+Mono' },
];

const devTools = [
  { name: 'TypeScript',   licence: 'Apache License 2.0',    url: 'https://typescriptlang.org' },
];
---

<LegalLayout
  title="Lizenzen"
  description="Open-Source-Software und Schriftarten-Lizenzen für theStacc. Vollständige Namensnennung und Lizenzdetails für alle Drittanbieter-Komponenten."
  lastUpdated="April 2026"
  badge="Rechtliches · Lizenzen"
  tocItems={toc}
  currentPath="/de/lizenzen/"
>
  <Fragment slot="head">
  </Fragment>

  <div class="flex flex-col gap-10">

    <section id="intro" class="scroll-mt-6">
      <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
        theStacc wurde mit einer Vielzahl von Open-Source-Software und Schriftarten entwickelt. Wir sind den Entwicklern und Communities dankbar, die ihre Arbeit öffentlich zugänglich gemacht haben. Nachfolgend finden Sie eine Liste der wichtigsten Open-Source-Bibliotheken und Assets, die wir verwenden, samt ihrer jeweiligen Lizenzen.
      </p>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="frontend" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-5">
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Frontend-Technologien</h2>
      </div>
      <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
        <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Bibliothek</span>
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Lizenz</span>
        </div>
        {frontendLibraries.map((item, i) => (
          <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < frontendLibraries.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]"
            >
              {item.name}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
          </div>
        ))}
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="fonts" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-5">
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Schriftarten</h2>
      </div>
      <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
        <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Schriftart</span>
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Lizenz</span>
        </div>
        {fonts.map((item, i) => (
          <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < fonts.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]"
            >
              {item.name}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
          </div>
        ))}
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="devtools" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-5">
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Entwicklungstools</h2>
      </div>
      <div class="overflow-hidden rounded-xl border border-[#e7e5e4]">
        <div class="flex items-center justify-between border-b border-[#e7e5e4] bg-[#fafaf9] px-5 py-3">
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Tool</span>
          <span class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Lizenz</span>
        </div>
        {devTools.map((item, i) => (
          <div class={`flex items-center justify-between px-5 py-4 bg-white transition-colors hover:bg-[#fafaf9] ${i < devTools.length - 1 ? 'border-b border-[#e7e5e4]' : ''}`}>
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-sans text-[15px] font-medium text-[#111827] transition-colors hover:text-[#4f39f6]"
            >
              {item.name}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
            <span class="rounded-full border border-[#e7e5e4] px-3 py-1 font-mono text-[11px] text-[#79716b]">{item.licence}</span>
          </div>
        ))}
      </div>
      <p class="mt-5 font-sans text-[13px] text-[#79716b]">
        Die vollständige Liste der Abhängigkeiten und ihrer Lizenzen finden Sie in unserer <code class="rounded bg-[#f5f3ff] px-1.5 py-0.5 font-mono text-[12px] text-[#4f39f6]">package.json</code> oder kontaktieren Sie uns unter <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
      </p>
    </section>

  </div>
</LegalLayout>
