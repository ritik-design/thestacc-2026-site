---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist Google Business Profile Software?", a: "Google Business Profile Software hilft Unternehmen, ihre GBP-Einträge effizienter zu verwalten — Posts veröffentlichen, Bewertungen beantworten, Öffnungszeiten und Attribute aktualisieren und die Performance überwachen — besonders bei mehreren Standorten, wo manuelle Verwaltung unpraktisch wird." },
  { q: "Wie hilft Stacc bei der Google Business Profile-Verwaltung?", a: "Stacc automatisiert die GBP-Post-Veröffentlichung (30 Posts pro Monat und Standort), überwacht Bewertungen in Echtzeit, meldet vorgeschlagene Änderungen bevor sie live gehen und verfolgt GBP-Performance-Signale. Für Multi-Standort-Unternehmen läuft alles gleichzeitig für alle Standorte von einem Dashboard." },
  { q: "Verbessert das Posten auf GBP wirklich die Google Maps-Rankings?", a: "Ja. Regelmäßige GBP-Post-Aktivität ist ein dokumentiertes lokales Ranking-Signal. Google behandelt konsistentes Posten als Indikator für ein aktives, legitimes Unternehmen — was mit höherer Local Pack- und Maps-Sichtbarkeit korreliert. Unternehmen, die konsistent posten, sehen messbare Ranking-Verbesserungen im Vergleich zu ihrer inaktiven Profil-Baseline." },
  { q: "Kann ich GBP-Posts für mehrere Standorte gleichzeitig veröffentlichen?", a: "Ja. Schreiben Sie einen Post, wählen Sie alle Standorte oder eine bestimmte Gruppe aus und veröffentlichen Sie gleichzeitig. Standortspezifische Anpassungen (Adresse, Telefonnummer, lokale Hashtags) können vor der Massenveröffentlichung pro Standort hinzugefügt werden." },
  { q: "Wie behandelt Stacc vorgeschlagene GBP-Änderungen?", a: "Stacc überwacht Ihre GBP-Einträge auf vorgeschlagene Änderungen von Dritten und benachrichtigt Sie, bevor diese angewendet werden. Sie können vorgeschlagene Änderungen vom Dashboard aus genehmigen, ablehnen oder bearbeiten, ohne sich bei jedem GBP einzeln anmelden zu müssen." },
  { q: "Kann Stacc GBP für Unternehmen mit 100+ Standorten verwalten?", a: "Ja. Es gibt kein praktisches Standortlimit. Massenoperationen funktionieren identisch, ob Sie 10 oder 500 Standorte haben — wählen Sie einfach mehr Standorte aus, bevor Sie die Aktion anwenden. Dieselben GBP-Verwaltungstools, die für 10 Standorte funktionieren, funktionieren auch bei 500." },
  { q: "Was kostet GBP-Software?", a: "Staccs Lokales SEO-Modul — das vollständige GBP-Verwaltung enthält — beginnt bei 49 €/Monat mit einer 14-tägigen kostenlosen Testphase." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Google Business Profile Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Google Business Profile Software, die GBP-Post-Veröffentlichung, Bewertungsmonitoring und Eintragsmanagement für alle Standorte gleichzeitig automatisiert.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Google Business Profile Software", "item": "https://thestacc.com/de/google-business-profile-software/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Google Business Profile Software — GBP automatisch für jeden Standort | theStacc"
  description="Automatisieren Sie Google Business Profile-Verwaltung für alle Standorte. Stacc veröffentlicht 30 GBP-Posts pro Monat, überwacht Bewertungen und verwaltet Einträge — ohne manuelle Anmeldungen."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Google Business Profile Software · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            GBP automatisch verwaltet.<br />
            <span style="color:#4f39f6;">Jeder Standort. Jeden Tag.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc veröffentlicht 30 GBP-Posts pro Monat und Standort, überwacht Bewertungen in Echtzeit und verwaltet Ihre Einträge für alle Standorte — ohne eine einzige manuelle Anmeldung.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/integrationen/google-business-profile/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              GBP-Integration ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">30 Posts/Monat pro Standort</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ verwaltete Standorte</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Warum GBP-Verwaltung Software braucht</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Inaktive GBP-Profile verlieren Rankings.<br />Manuelle Verwaltung hält nicht Schritt.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Googles lokaler Ranking-Algorithmus belohnt aktive GBP-Profile. Regelmäßiges Post-Publishing, schnelle Bewertungsantworten und aktuelle Eintragsinfos tragen zur Sichtbarkeit im Local Pack und Maps bei. Hören Sie drei Wochen mit dem Posten auf, sinkt Ihr Aktivitätswert. Bleiben Bewertungen unbeantwortet, verschlechtern sich Ihre Antwortrate-Signale. Eine veraltete Öffnungszeit im Eintrag schafft eine Vertrauensinkonsistenz, die Ihr Ranking beeinträchtigt.</p>
            <p>Ein aktives GBP für einen Standort zu pflegen kostet 3–4 Stunden pro Woche. Bei 20 Standorten sind das 80 Stunden. GBP-Software eliminiert diese Arbeit durch Automatisierung — nicht nur indem sie Ihnen zeigt, was getan werden muss, sondern indem sie es tatsächlich erledigt.</p>
            <p class="font-semibold text-[#111827]">Stacc veröffentlicht Posts, überwacht Bewertungen, beobachtet unbefugte Änderungen und hält Ihre GBP-Einträge konsequent aktiv — damit Ihre Profile nie verstummen, auch wenn Sie nicht hinsehen.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Staccs GBP-Software enthält</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede GBP-Aufgabe automatisiert.<br />Jeden Standort abgedeckt.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: '30 GBP-Posts pro Monat, automatisiert', body: 'Stacc schreibt und veröffentlicht 30 Posts pro Standort und Monat, die auf Ihre Service- + Standort-Keyword-Kombinationen ausgerichtet sind. Profile bleiben jeden Tag aktiv, automatisch.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Echtzeit-Bewertungsmonitoring', body: 'Neue Bewertungen erscheinen sofort in Ihrem Dashboard. Direkt antworten ohne GBP-Login. Antwortraten und Durchschnittswert pro Standort verfolgen.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Überwachung unbefugter Änderungen', body: 'Vorgeschlagene Drittänderungen an Ihren Einträgen werden gemeldet, bevor sie angewendet werden. Genehmigen, ablehnen oder bearbeiten vom Dashboard — keine unbefugte Änderung wird verpasst.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Massen-Eintrags-Updates', body: 'Öffnungszeiten, Beschreibungen, Attribute und Kategorien für alle Standorte gleichzeitig aktualisieren. Kein standortweises GBP-Login erforderlich.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'GBP-Performance-Tracking', body: 'Aufrufe, Klicks, Anrufanfragen und Wegbeschreibungsanfragen pro Standort über die Zeit verfolgen. Sehen, welche GBP-Aktivität mit Performance-Änderungen korreliert.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Q&A-Verwaltung', body: 'Den Q&A-Bereich aller GBP-Einträge überwachen und verwalten. Sicherstellen, dass korrekte Antworten für Suchende sichtbar sind, bevor sie falsche Informationen finden.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP-Automatisierung im Detail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Posts, Bewertungen, Änderungen — alles verwaltet<br />von einem Dashboard, automatisch.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Automated Post Publishing -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisierte GBP-Post-Veröffentlichung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 Posts pro Standort pro Monat. Auf Suchanfragen ausgerichtet, die Anrufe generieren.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Googles Maps-Algorithmus belohnt Unternehmen, die konsistent posten, mit höherer Local Pack-Sichtbarkeit. Stacc schreibt 30 standortoptimierte Posts pro Monat — ausgerichtet auf Ihre Service- + Stadt-Keyword-Kombinationen, „in meiner Nähe"-Intent, Notfallsuchen und saisonale Themen — und veröffentlicht sie planmäßig. Ihr Profil bleibt jeden Tag aktiv. Sie müssen nichts anfassen.
              </p>
              <a href="/de/lokales-seo-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Lokale SEO-Software ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">GBP-Posts diesen Monat</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 22 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Bisher veröffentlichte Posts</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">22 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:73%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">8 weitere geplant · Vollständig automatisiert · Null manuelle Arbeit</p>
            </div>
          </div>

          <!-- Review Monitoring -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Bewertungs-Posteingang — alle Standorte</p>
              {[
                { biz: 'Standort München', stars: 5, text: 'Bester Service, den ich hatte. Komme definitiv wieder!', time: 'Vor 2 Std.', responded: false },
                { biz: 'Standort Hamburg', stars: 4, text: 'Tolle Erfahrung insgesamt, schnell und professionell.', time: 'Vor 1 Tag', responded: true },
                { biz: 'Standort Berlin', stars: 5, text: 'Sehr zu empfehlen — schnelle Reaktion und tolle Ergebnisse.', time: 'Vor 2 Tagen', responded: true },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center justify-between mb-1">
                    <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">{r.biz}</span>
                    <div class="flex items-center gap-2">
                      <div class="flex">{Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}</div>
                      {r.responded ? <span class="font-mono text-[9px] text-[#059669]">✓ Beantwortet</span> : <span class="font-mono text-[9px] text-[#f59e0b]">Antwort erforderlich</span>}
                    </div>
                  </div>
                  <p class="font-sans text-[12px] text-[#57534e] truncate">"{r.text}"</p>
                  <p class="font-mono text-[10px] text-[#79716b] mt-0.5">{r.time}</p>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alle Standorte · Echtzeit-Benachrichtigungen</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Einheitliches Bewertungsmonitoring</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Jede Bewertung von jedem Standort in einem Posteingang. Antworten ohne GBP-Login.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Bewertungsantwortrate ist ein Maps-Ranking-Signal. Unternehmen, die prompt auf Bewertungen antworten, übertreffen dauerhaft solche mit unbeantworteten Bewertungen. Stacc zentralisiert jede Bewertung von jedem Standort in einem Posteingang, sendet sofortige Benachrichtigungen für neue Bewertungen und ermöglicht direkte Antworten — ohne individuelle GBP-Accounts einzuloggen. Für Multi-Standort-Unternehmen ist das die einzige Möglichkeit, Reputationsmanagement in großem Maßstab im Griff zu behalten.
              </p>
              <a href="/de/funktionen/bewertungsmonitoring/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Bewertungsmonitoring ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Bulk Listing Management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Massen-Eintrags-Verwaltung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Alle Standorte auf einmal aktualisieren. Feiertagsöffnungszeiten, Beschreibungen, Kategorien — alles in Sekunden.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Jede Änderung, die Ihr gesamtes Portfolio betrifft, kann gleichzeitig auf alle Standorte angewendet werden. Weihnachtsöffnungszeiten für alle 40 Standorte in 2 Sekunden aktualisieren. Unternehmensbeschreibung vor einem Rebranding über alle Einträge hinweg ändern. Eine neue Servicekategorie in einer Aktion zu jedem Standort hinzufügen. Was früher stundenlangem Tab-Wechseln und manuellem Login bedurfte, dauert jetzt unter einer Minute — und Stacc überwacht dazwischen auf unbefugte Drittänderungen und warnt Sie, bevor unerwünschte Änderungen Ihre Rankings beeinflussen.
              </p>
              <a href="/de/google-maps-ranking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Google-Maps-Ranking verbessern
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Massen-Update — Feiertagsöffnungszeiten</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Anwenden auf:</p>
