---
import LegalLayout from '../../layouts/LegalLayout.astro';

const toc = [
  { id: 'controller',   label: '1. Verantwortlicher' },
  { id: 'types',        label: '2. Verarbeitete Datenarten' },
  { id: 'legal-basis',  label: '3. Rechtsgrundlage' },
  { id: 'retention',    label: '4. Datenspeicherung' },
  { id: 'processors',   label: '5. Drittanbieter' },
  { id: 'transfers',    label: '6. Grenzüberschreitende Übermittlungen' },
  { id: 'rights',       label: '7. Ihre Rechte (DSGVO)' },
  { id: 'contact',      label: '8. Kontakt' },
];

const dataTypes = [
  { label: 'Kontodaten',       body: 'Name, E-Mail-Adresse, Unternehmensname, Rechnungsadresse.' },
  { label: 'Nutzungsdaten',    body: 'Dienstinteraktionen, Verlauf der Inhaltserstellung, Feature-Nutzungsmuster.' },
  { label: 'Geschäftsdaten',   body: 'Website-URLs, Keywords, Unternehmensbeschreibungen, die Sie zur Konfiguration unserer Dienste bereitstellen.' },
  { label: 'Technische Daten', body: 'IP-Adressen, Browser-Typ, Gerätekennungen und andere Protokolldaten.' },
];

const gdprRights = [
  { label: 'Auskunftsrecht',            body: 'Fordern Sie eine Kopie der Daten an, die wir über Sie gespeichert haben.' },
  { label: 'Recht auf Berichtigung',    body: 'Fordern Sie die Korrektur ungenauer oder unvollständiger Daten an.' },
  { label: 'Recht auf Löschung',        body: 'Fordern Sie die Löschung Ihrer personenbezogenen Daten unter bestimmten Umständen an.' },
  { label: 'Recht auf Einschränkung',   body: 'Fordern Sie an, dass wir die Verwendung Ihrer Daten einschränken.' },
  { label: 'Recht auf Datenübertragbarkeit', body: 'Erhalten Sie Ihre Daten in einem strukturierten, maschinenlesbaren Format.' },
  { label: 'Widerspruchsrecht',         body: 'Widersprechen Sie der Verarbeitung auf Basis berechtigter Interessen.' },
];
---

<LegalLayout
  title="Datenverarbeitungsvereinbarung"
  description="Wie theStacc Ihre Daten gemäß DSGVO verarbeitet. Rechtsgrundlage, Speicherfristen, Unterauftragsverarbeiter und Betroffenenrechte."
  lastUpdated="April 2026"
  badge="Rechtliches · Compliance"
  tocItems={toc}
  currentPath="/de/datenverarbeitung/"
>
  <Fragment slot="head">
  </Fragment>

  <div class="flex flex-col gap-10">

    <section id="controller" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Verantwortlicher</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          SOLARTREK VENTURES LLP fungiert als Verantwortlicher für personenbezogene Daten, die über unsere Plattform verarbeitet werden. Wir bestimmen die Zwecke und Mittel der Verarbeitung Ihrer personenbezogenen Daten in Übereinstimmung mit den geltenden Datenschutzgesetzen, einschließlich der Datenschutz-Grundverordnung (DSGVO), soweit anwendbar.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="types" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Verarbeitete Datenarten</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">Im Rahmen unserer Dienstleistungserbringung verarbeiten wir folgende Datenkategorien:</p>
        <div class="flex flex-col gap-3">
          {dataTypes.map(item => (
            <div class="flex items-start gap-3">
              <span class="mt-[5px] h-1.5 w-1.5 shrink-0 rounded-full bg-[#4f39f6]"></span>
              <p class="font-sans text-[15px] leading-[1.7] text-[#57534e]">
                <strong class="font-semibold text-[#111827]">{item.label}:</strong> {item.body}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="legal-basis" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Rechtsgrundlage der Verarbeitung</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">Wir verarbeiten Ihre personenbezogenen Daten auf folgenden Rechtsgrundlagen:</p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {[
            { label: 'Vertragserfüllung',       body: 'Verarbeitung, die erforderlich ist, um die von Ihnen abonnierten Dienste bereitzustellen.' },
            { label: 'Berechtigte Interessen',  body: 'Verbesserung unserer Plattform, Betrugsprävention und Sicherheit.' },
            { label: 'Gesetzliche Verpflichtung', body: 'Einhaltung geltender Gesetze und Vorschriften.' },
            { label: 'Einwilligung',            body: 'Für optionale Kommunikation und nicht wesentliche Cookies, soweit erforderlich.' },
          ].map(item => (
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-4">
              <p class="font-sans text-[13px] font-semibold text-[#111827] mb-1">{item.label}</p>
              <p class="font-sans text-[13px] leading-[1.65] text-[#79716b]">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="retention" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Datenspeicherung</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Wir speichern Ihre personenbezogenen Daten so lange, wie Ihr Konto aktiv ist oder wie dies für die Bereitstellung unserer Dienste erforderlich ist. Nach Kontoschließung werden Ihre personenbezogenen Daten innerhalb von 90 Tagen gelöscht oder anonymisiert, sofern wir nicht gesetzlich verpflichtet sind, sie länger aufzubewahren, um rechtliche Verpflichtungen zu erfüllen, Streitigkeiten beizulegen oder unsere Vereinbarungen durchzusetzen.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="processors" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">5</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Drittanbieter-Auftragsverarbeiter</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Wir beauftragen vertrauenswürdige Drittanbieter als Unterauftragsverarbeiter zur Unterstützung bei der Bereitstellung unserer Dienste, darunter Cloud-Infrastrukturanbieter, Zahlungsabwickler und KI-Modellanbieter. Alle Unterauftragsverarbeiter sind durch Datenverarbeitungsvereinbarungen gebunden und müssen angemessene Sicherheitsmaßnahmen implementieren. Eine aktuelle Liste der Unterauftragsverarbeiter ist auf Anfrage erhältlich.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="transfers" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">6</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Grenzüberschreitende Datenübermittlungen</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Ihre Daten können in Länder außerhalb Ihres Wohnsitzlandes übermittelt und dort verarbeitet werden, einschließlich der Vereinigten Staaten. Bei der Übermittlung von Daten aus dem Europäischen Wirtschaftsraum stützen wir uns auf Standardvertragsklauseln oder andere geeignete Schutzmaßnahmen gemäß DSGVO, um ein angemessenes Schutzniveau sicherzustellen.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="rights" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">7</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Ihre Rechte (DSGVO)</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e] mb-5">
          Wenn Sie sich im Europäischen Wirtschaftsraum befinden, haben Sie folgende Rechte bezüglich Ihrer personenbezogenen Daten:
        </p>
        <div class="flex flex-col gap-3">
          {gdprRights.map(item => (
            <div class="flex items-start gap-3">
              <svg class="mt-[3px] shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <p class="font-sans text-[15px] leading-[1.7] text-[#57534e]">
                <strong class="font-semibold text-[#111827]">{item.label}:</strong> {item.body}
              </p>
            </div>
          ))}
        </div>
        <p class="mt-5 font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Um eines dieser Rechte auszuüben, kontaktieren Sie uns unter <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>. Wir antworten innerhalb von 30 Tagen.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="contact" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">8</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Kontakt</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Für Datenschutzanfragen wenden Sie sich bitte an unser Team unter <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
        </p>
        <div class="mt-4 font-sans text-[15px] leading-[1.75] text-[#57534e]">
          <p><strong class="font-semibold text-[#111827]">Rechtlicher Name:</strong> SOLARTREK VENTURES LLP</p>
          <p><strong class="font-semibold text-[#111827]">Adresse:</strong> Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India</p>
        </div>
      </div>
    </section>

  </div>
</LegalLayout>
