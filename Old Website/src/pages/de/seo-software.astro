---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist SEO-Software?", a: "SEO-Software hilft Unternehmen, die Signale zu verwalten, die ihre Rankings in Suchmaschinen bestimmen — einschließlich Keyword-Rankings, On-Page-Optimierung, Zitationen, GBP-Aktivität und Bewertungsgenerierung. Moderne SEO-Software geht über Dashboards hinaus, um die eigentliche Ausführungsarbeit zu automatisieren." },
  { q: "Wie unterscheidet sich theStacc von anderer SEO-Software?", a: "Die meisten SEO-Tools sind Datentools. Sie verfolgen, was passiert, lassen aber alle Ausführung bei Ihnen. Stacc erledigt wirklich die Arbeit — GBP-Posts veröffentlichen, Zitationen synchronisieren, Bewertungen in Echtzeit überwachen und White-Label-Berichte nach Zeitplan liefern." },
  { q: "Brauche ich mehrere SEO-Tools, wenn ich Stacc verwende?", a: "Für lokales SEO nein. Stacc ersetzt separate Rank-Tracker, GBP-Verwaltungstools, Zitationsdienste, Bewertungsmonitoring-Tools und Berichtssoftware. Agenturen eliminieren typischerweise 4–5 separate Abonnements beim Wechsel zu Stacc." },
  { q: "Ist Stacc für Agenturen oder interne Teams?", a: "Beides. Agenturen erhalten White-Label-Berichte und Multi-Kunden-Verwaltung. Interne Teams bei Multi-Standort-Unternehmen erhalten Massenverwaltungstools und automatisierte Berichte. Dieselbe Plattform bedient beide Workflows." },
  { q: "Beinhaltet Stacc White-Label-Berichte?", a: "Ja. White-Label-Berichte mit Ihrem Logo, Ihren Markenfarben und Ihrer benutzerdefinierten Domain sind in Growth- und Scale-Plänen verfügbar. Berichte werden unter Ihrer Marke erstellt und geliefert." },
  { q: "Was kostet Stacc?", a: "Pläne beginnen bei 49 €/Monat für das Lokale-SEO-Modul. Das Blog-SEO-Modul kostet 99 €/Monat. Das Social-Media-Modul 49 €/Monat. Alle Module umfassen eine 14-tägige kostenlose Testphase." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO-Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "All-in-One-SEO-Software, die lokale Rankings, Zitationen, Bewertungen, GBP-Verwaltung und Berichte für Unternehmen und Agenturen automatisiert.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "SEO-Software", "item": "https://thestacc.com/de/seo-software/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="SEO-Software — Lokales SEO vollständig automatisieren | theStacc"
  description="theStacc ist die SEO-Software, die wirklich die Arbeit erledigt. GBP-Verwaltung, Rank-Tracking, Zitations-Monitoring, Bewertungsmanagement und automatisierte Berichte — alles auf Autopilot."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO-Software · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO-Software, die die Arbeit<br />
            <span style="color:#4f39f6;">wirklich erledigt.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc automatisiert die vollständige lokale SEO-Ausführung — GBP-Posts, Rank-Tracking, Zitationen, Bewertungen und White-Label-Berichte — über jeden Standort. Keine manuelle Arbeit. Keine Tool-Sammelsurium.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ Unternehmen und Agenturen</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ verwaltete Standorte</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Eine Plattform. Alle lokalen SEO-Aufgaben.<br />Vollständig automatisiert.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP-Automatisierung', body: '30 Posts/Monat pro Standort, auf lokale Suchabsicht ausgerichtet. Täglich veröffentlicht, nie manuell.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rank-Tracking', body: 'Local Pack, Maps und organische Rankings täglich aktualisiert für alle Standorte und Keywords.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Zitationsverwaltung', body: 'NAP in 50+ Verzeichnissen kontinuierlich überwacht. Inkonsistenzen erkannt und gemeldet.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Bewertungsmonitoring', body: 'Echtzeit-Benachrichtigungen für neue Bewertungen. Mit Antwortvorlagen direkt aus dem Dashboard.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'White-Label-Berichte', body: 'Vollständige Kundenberichte monatlich erstellt und zugestellt. Ihr Logo, Ihre Domain, kein Stacc-Branding.' },
            { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Blog-SEO-Automatisierung', body: '30 SEO-Blogbeiträge pro Monat, direkt auf Ihrer Website veröffentlicht. Keyword-Recherche und interne Verlinkung inklusive.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Schlüsselfunktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Fünf Tools durch eine Plattform ersetzen.<br />Zeitaufwand halbieren.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisches Rank-Tracking</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Jedes Keyword, jeder Standort, jeden Morgen — ohne sich irgendwo einzuloggen.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc verfolgt Ihre Rankings im lokalen 3-Pack, Google Maps und in den organischen Ergebnissen täglich für jedes relevante Keyword. Alerts werden automatisch ausgelöst, wenn sich Positionen signifikant verschieben. Sie wachen auf und wissen, wo Sie stehen — ohne ein einziges Dashboard zu öffnen. Für Agenturen mit 20 Kunden bedeutet das: Dienstag auf Rank-Checks oder auf Strategie verwenden.
              </p>
              <a href="/de/funktionen/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Rank-Tracking im Detail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Heutige Ranking-Aktualisierung — alle Kunden</p>
              {[
                { client: 'Müller Sanitär GmbH', kw: 'Klempner in der Nähe', pos: 1, change: '+3', trend: 'up' },
                { client: 'Zahnarzt Dr. Schmidt', kw: 'Zahnarzt [Stadt]', pos: 2, change: '+2', trend: 'up' },
                { client: 'Elite Heizung & Klima', kw: 'Heizung Reparatur Nähe', pos: 2, change: '+5', trend: 'up' },
                { client: 'Kanzlei Weber', kw: 'Anwalt in der Nähe', pos: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Täglich aktualisiert · Local Pack + Organisch + Maps</p>
            </div>
          </div>

          <!-- Zitationsverwaltung -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Zitations-Status — alle Verzeichnisse</p>
              {[
                { dir: 'Google Business Profile', status: 'Korrekt', ok: true },
                { dir: 'Yelp', status: 'Korrekt', ok: true },
                { dir: 'Apple Maps', status: 'Korrekt', ok: true },
                { dir: 'Gelbe Seiten', status: 'Abweichung korrigiert', ok: true },
                { dir: 'Foursquare', status: 'Automatisch behoben', ok: true },
              ].map(c => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{c.dir}</span>
                  <span class={`flex items-center gap-1.5 font-mono text-[11px] font-semibold ${c.ok ? 'text-[#059669]' : 'text-[#dc2626]'}`}>
                    {c.ok ? '✓' : '✗'} {c.status}
                  </span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ Verzeichnisse überwacht · Korrekturen automatisiert</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Zitationsverwaltung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Inkonsistente Zitationen schaden Ihren Rankings. Stacc findet und behebt sie automatisch.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google gleicht Ihre Unternehmensdaten in 50+ Verzeichnissen ab, um zu verifizieren, wer Sie sind. Wenn Name, Adresse oder Telefonnummer nicht übereinstimmen, leiden Ihre lokalen Rankings. Stacc überwacht jedes wichtige Verzeichnis kontinuierlich — und korrigiert Abweichungen automatisch. Keine vierteljährlichen Zitations-Audits. Kein manuelles Einreichungswerkzeug mehr.
              </p>
              <a href="/de/loesungen/agenturen/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Stacc für Agenturen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Automatisiertes Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisiertes Kunden-Reporting</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Berichte, die sich selbst erstellen und versenden. Unter Ihrer Marke. Jede Woche.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Für die meisten Agenturen ist Kunden-Reporting die Steuer, die nie weggeht — Stunden jeden Monat, die Sie nicht abrechnen und nicht eliminieren können. Stacc eliminiert sie. Template einmal pro Kunde festlegen. Stacc erstellt den Bericht, formatiert ihn mit Ihrem Branding und liefert ihn termingerecht in den Posteingang des Kunden. Der Moment, in dem Reporting automatisch wird, ist der Moment, in dem Sie über Ihre aktuelle Kapazitätsgrenze skalieren können.
              </p>
              <a href="/de/white-label-berichte/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                White-Label-Berichte ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Ihre Agentur</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Monatlicher SEO-Performance-Bericht</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Gesendet</span>
              </div>
              {[
                { label: 'Keywords in Top 3 verschoben', val: '+8 diesen Monat' },
                { label: 'GBP-Posts veröffentlicht', val: '30 automatisiert' },
                { label: 'Bewertungen erhalten', val: '11 ⭐ Ø 4,7' },
                { label: 'Zitations-Genauigkeit', val: '100% in 50+ Verzeichnissen' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Automatisch erstellt und geliefert · White-Label-Branding</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- METRIKEN -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was passiert, wenn SEO-Software<br />wirklich die Arbeit erledigt.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Durchschnittswerte von Unternehmen und Agenturen, die lokales SEO mit Stacc betreiben.
          </p>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '5',    num: 5,   prefix: '', suffix: '', decimals: 0, from: 0, label: 'Tools durch ein Stacc-Konto ersetzt', sub: 'Rank-Tracker, Zitationen, Bewertungen, GBP, Reporting' },
            { value: '8 Std.', num: 8, prefix: '', suffix: ' Std.', decimals: 0, from: 0, label: 'Gespart pro Kunde pro Monat', sub: 'bei manuellen SEO- und Reporting-Aufgaben' },
            { value: '4,7×', num: 4.7, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Ø Maps-Ranking-Verbesserung', sub: 'innerhalb von 90 Tagen konsistenter Automatisierung' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- KUNDENSTIMMEN -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
