---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';
---

<BaseLayout
  title="Dokumentation — theStacc Hilfe und Anleitungen | theStacc"
  description="theStacc Dokumentation: Anleitungen zur Einrichtung, Funktionen, Integrationen und häufig gestellte Fragen zur lokalen SEO-Automatisierungsplattform."
  lang="de"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Dokumentation</span>
          <h1 class="mt-3 font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#111827] md:text-[3rem]">
            Hilfe und Anleitungen.
          </h1>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Anleitungen, Tutorials und technische Dokumentation für die theStacc-Plattform — von der Ersteinrichtung bis zu erweiterten Funktionen.
          </p>
          <div class="mt-8 flex gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Konto erstellen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/kontakt/" class="inline-flex h-11 items-center rounded-xl border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#fafaf9]">Support kontaktieren</a>
          </div>
        </div>
        <div class="mx-auto mt-16 max-w-2xl">
          <p class="font-sans text-[0.95rem] text-[#79716b]">Deutsche Dokumentation wird in Kürze verfügbar. Besuchen Sie in der Zwischenzeit die <a href="/docs/" class="text-[#4f39f6] hover:underline">englische Dokumentation</a>.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
