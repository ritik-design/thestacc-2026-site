---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist Bewertungsmanagement-Software?", a: "Bewertungsmanagement-Software hilft Unternehmen, Kundenbewertungen in Google, Yelp und anderen Plattformen zu überwachen und darauf zu antworten. Stacc sendet Echtzeit-Benachrichtigungen für neue Bewertungen und bietet Antwortvorlagen, damit Sie schnell und professionell reagieren können." },
  { q: "Wie schnell benachrichtigt Stacc bei neuen Bewertungen?", a: "Sofort. Stacc überwacht Ihre Bewertungsprofile kontinuierlich und sendet eine Benachrichtigung, sobald eine neue Bewertung erscheint — mit dem Bewertungstext, der Sternebewertung und dem Rezensenten, damit Sie sofort den Kontext haben." },
  { q: "Auf welchen Plattformen werden Bewertungen überwacht?", a: "Stacc überwacht Bewertungen auf Google Business Profile, Facebook und anderen wichtigen Plattformen, die für Ihre Branche relevant sind. Google-Bewertungen haben den stärksten Einfluss auf lokale Rankings und werden priorisiert." },
  { q: "Hilft Bewertungsmanagement bei lokalen Rankings?", a: "Ja. Bewertungsanzahl, Durchschnittsbewertung und Antwortquote sind alle Ranking-Faktoren im lokalen Algorithmus von Google. Ein aktives Bewertungsprofil mit konsequenten Antworten signalisiert Vertrauen und Engagement an Google." },
  { q: "Kann ich Bewertungsantworten aus dem Dashboard senden?", a: "Ja. Stacc zeigt Ihnen die Bewertung, bietet Antwortvorlagen und ermöglicht es Ihnen, direkt aus dem Dashboard zu antworten — Sie müssen sich nicht bei jeder Plattform separat anmelden." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Bewertungsmanagement-Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Bewertungsmanagement-Software für lokale Unternehmen. Echtzeit-Benachrichtigungen, zentrales Antworten und Reputationsmonitoring für alle Standorte.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Bewertungsmanagement-Software", "item": "https://thestacc.com/de/bewertungsmanagement-software/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Bewertungsmanagement-Software — Echtzeit-Bewertungen für alle Standorte | theStacc"
  description="Überwachen und verwalten Sie Kundenbewertungen über alle Standorte. Sofortige Benachrichtigungen, zentrale Antworten, Reputationstrends pro Standort."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Bewertungsmanagement-Software · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Jede Bewertung. Jeder Standort.<br />
            <span style="color:#4f39f6;">Sofort benachrichtigt.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc überwacht Bewertungen über alle Standorte in Echtzeit und sendet sofortige Benachrichtigungen, wenn neue Bewertungen erscheinen. Mit Antwortvorlagen antworten Sie in einer Minute — nicht einer Stunde.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/funktionen/bewertungsmonitoring/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Bewertungsmonitoring ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>

          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Google, Facebook, Yelp überwacht</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Benachrichtigungen in Minuten</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FEATURES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was enthalten ist</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vollständiges Bewertungsmanagement.<br />Für jeden Standort.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Echtzeit-Benachrichtigungen', body: 'Sofortige Benachrichtigung für jede neue Bewertung — mit Bewertungstext, Sternebewertung und Plattform.' },
            { icon: 'M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6', title: 'Zentrale Antworten', body: 'Direkt aus dem Stacc-Dashboard auf Bewertungen antworten. Keine Plattform-Logins für jede Reaktion.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Antwortvorlagen', body: 'Gebrandmarkte Antwortvorlagen für positive und negative Bewertungen. Konsistente, professionelle Tonalität.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Reputations-Dashboard', body: 'Durchschnittsbewertung, Gesamtanzahl, Antwortquote und Trend über die Zeit — für jeden Standort.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Bewertungsberichte', body: 'Bewertungsperformance automatisch in monatliche Kundenberichte eingeschlossen. Kein manuelles Erfassen.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Multi-Standort-Übersicht', body: 'Alle Bewertungen aller Standorte in einer Ansicht. Sehen Sie, welche Standorte Aufmerksamkeit benötigen.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="funktionen" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So verwaltet Stacc Bewertungen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede Bewertung gesehen. Jeder Trend verfolgt.<br />Jeder Kundenbericht automatisiert.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Sofort-Benachrichtigungen -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Sofortige Bewertungsbenachrichtigungen</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Erfahren Sie von jeder Bewertung in Minuten — nicht in Tagen.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc überwacht Ihre Google-, Facebook- und Yelp-Profile kontinuierlich. Sobald eine neue Bewertung erscheint, erhalten Sie eine Benachrichtigung. Bei negativen Bewertungen unter Ihrem Schwellenwert erhalten Sie eine Prioritätsbenachrichtigung — per E-Mail oder SMS — damit Sie reagieren können, bevor sich die Situation verschlimmert. Unternehmen, die Stacc nutzen, antworten im Durchschnitt 73 % schneller als solche, die manuell prüfen.
              </p>
              <a href="/de/funktionen/bewertungsmonitoring/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Bewertungsmonitoring ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Aktuelle Bewertungsbenachrichtigungen</p>
              {[
                { platform: 'Google', rating: '⭐⭐⭐⭐⭐', preview: '"Toller Service, sehr empfehlenswert"', time: 'vor 12 Min.', type: 'positive' },
                { platform: 'Yelp', rating: '⭐⭐', preview: '"Wartezeit war zu lang"', time: 'vor 2 Std.', type: 'negative' },
                { platform: 'Facebook', rating: '⭐⭐⭐⭐⭐', preview: '"Bestes Restaurant der Stadt, komme wieder"', time: 'vor 5 Std.', type: 'positive' },
              ].map(r => (
                <div class={`rounded-xl p-3 mb-3 border ${r.type === 'negative' ? 'border-[#fecaca] bg-[#fef2f2]' : 'border-[#e7e5e4] bg-[#fafaf9]'}`}>
                  <div class="flex items-center justify-between mb-1">
                    <span class="font-mono text-[11px] font-semibold text-[#374151]">{r.platform}</span>
                    <span class="font-mono text-[10px] text-[#79716b]">{r.time}</span>
                  </div>
                  <p class="font-sans text-[11px] text-[#57534e]">{r.rating} {r.preview}</p>
                  {r.type === 'negative' && <p class="mt-1 font-mono text-[10px] font-semibold text-[#dc2626]">⚠ Prioritätsbenachrichtigung gesendet</p>}
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alle Plattformen · Echtzeit-Monitoring</p>
            </div>
          </div>

          <!-- Bewertungstrend-Verfolgung -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Reputationswert — 90 Tage</p>
              <div class="flex items-end gap-1 h-24 mb-4">
                {[3.8, 3.9, 4.0, 4.1, 4.0, 4.1, 4.2, 4.3, 4.4, 4.4, 4.5, 4.6].map((v, i) => (
                  <div class="flex-1 rounded-t" style={`height:${((v-3.5)/1.5)*100}%;background:${i >= 9 ? '#4f39f6' : '#e7e5e4'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Vor 90 Tagen: 3,8 ★</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">Heute: 4,6 ★</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">+0,8 Sterne in 90 Tagen · Google Business Profile</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Bewertungstrend-Verfolgung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sehen Sie automatisch, ob Ihr Ruf sich verbessert oder verschlechtert.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc verfolgt Ihre Sternebewertung, Bewertungsanzahl und Antwortquote über die Zeit auf allen Plattformen. Sie sehen auf einen Blick, ob Sie im Aufwärtstrend oder Abwärtstrend sind, welche Plattformen Aufmerksamkeit benötigen und wie schnell Ihr Team reagiert. Für Agenturen fließen diese Daten automatisch in Kundenberichte ein — und zeigen Kunden den Mehrwert, den Sie liefern, ohne eine einzige Folie zu erstellen.
              </p>
              <a href="/de/funktionen/bewertungsmonitoring/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Alle Tracking-Funktionen ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Berichterstattung für Agenturen -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Bewertungsberichte für Agenturen</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Bewertungsdaten in Ihren Kundenberichten. Automatisch zugestellt. Unter Ihrer Marke.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Staccs White-Label-Monatsberichte enthalten automatisch Bewertungsdaten — neue erhaltene Bewertungen, Ratingtrends, Antwortquote und Plattformaufschlüsselung. Ihre Kunden sehen genau, wie sich ihre Reputation entwickelt, ohne dass Sie Zeit dafür aufwenden. Richten Sie die Vorlage einmal ein. Berichte liefern sich jeden Monat selbst — unter Ihrer Marke.
              </p>
              <a href="/de/loesungen/agenturen/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Stacc für Agenturen ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Ihre Agentur</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Monatlicher Reputationsbericht</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Gesendet</span>
              </div>
              {[
                { label: 'Neue Bewertungen diesen Monat', val: '14 Bewertungen' },
                { label: 'Durchschnittsbewertung', val: '4,6 ★ (+0,2)' },
                { label: 'Antwortquote', val: '94 %' },
                { label: 'Überwachte Plattformen', val: 'Google · Facebook · Yelp' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Automatisch erstellt · Unter Ihrer Marke zugestellt</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was konsistentes Bewertungsmanagement<br />mit Ihren Zahlen macht.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '73 %', num: 73, prefix: '', suffix: ' %', decimals: 0, from: 0, label: 'Schnellere Reaktionszeit bei Bewertungen', sub: 'im Vergleich zu Unternehmen, die einmal pro Woche manuell prüfen' },
            { value: '0,4 ★', num: 0.4, prefix: '', suffix: ' ★', decimals: 1, from: 0, label: 'Durchschnittliche Bewertungsverbesserung', sub: 'innerhalb von 90 Tagen nach Nutzung von Stacc Bewertungsmanagement' },
            { value: '4,2 Std.', num: 4.2, prefix: '', suffix: ' Std.', decimals: 1, from: 0, label: 'Gespart pro Woche pro Standort', sub: 'bei der manuellen Überprüfung von Bewertungen auf allen Plattformen' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]"
                 data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Kunden sagen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Echte Ergebnisse von Unternehmen, die Stacc<br />für Bewertungsmanagement nutzen.
          </h2>
        </div>
