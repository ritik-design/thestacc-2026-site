---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was sind lokale Zitationen und warum sind sie wichtig?", a: "Lokale Zitationen sind Erwähnungen Ihres Unternehmens im Web — Name, Adresse, Telefonnummer (NAP) — in Verzeichnissen, Bewertungsseiten und lokalen Webseiten. Googles lokaler Algorithmus nutzt Zitationskonsistenz als Vertrauenssignal: Je konsistenter und vollständiger Ihre NAP-Daten im Web sind, desto wahrscheinlicher rankt Ihr Unternehmen lokal." },
  { q: "Was ist Zitationsaufbau-Software?", a: "Zitationsaufbau-Software automatisiert den Prozess, Ihr Unternehmen in lokalen Verzeichnissen einzutragen — Google, Yelp, Apple Maps, Bing Places und 50+ mehr — mit konsistenten NAP-Daten. Stacc prüft Ihre vorhandenen Zitationen, findet Inkonsistenzen, korrigiert sie und baut neue Zitationen automatisch auf." },
  { q: "Warum schaden falsche Zitationen meinen Rankings?", a: "Falsche NAP-Daten in Verzeichnissen schaden aktiv Ihren lokalen Rankings. Google sieht widersprüchliche Signale und verringert das Vertrauen in Ihren Eintrag. Kunden finden die falsche Nummer oder Adresse. Stacc prüft alle 50+ Verzeichnisse, markiert Inkonsistenzen und korrigiert sie automatisch — damit Ihre Daten überall korrekt sind." },
  { q: "Wie viele Verzeichnisse überwacht Stacc?", a: "Stacc verwaltet Zitationen in 50+ lokalen Verzeichnissen, darunter Google Business Profile, Yelp, Bing Places, Apple Maps, Facebook, Foursquare, YellowPages, Angi, HomeAdvisor, BBB, Nextdoor und Dutzende weitere branchenspezifische Verzeichnisse. Alles inklusive für 49 €/Monat — keine Gebühren pro Verzeichnis." },
  { q: "Funktioniert Stacc für Unternehmen mit mehreren Standorten?", a: "Ja. Multi-Standort-Zitations-Verwaltung ist eine der Kernstärken von Stacc. Jeder Standort erhält sein eigenes Zitationsprofil, das unabhängig überwacht und korrigiert wird. Sie verwalten alles von einem Dashboard aus. Fügen Sie einen neuen Standort hinzu und Stacc beginnt sofort, Zitationen dafür aufzubauen." },
  { q: "Wie lange dauert es, Ergebnisse beim Zitationsaufbau zu sehen?", a: "Erste Zitations-Audits werden innerhalb von 48 Stunden nach dem Verbinden Ihres Unternehmens abgeschlossen. Korrekturen und neue Einträge werden in den folgenden 1–2 Wochen bereitgestellt, da Verzeichnisse Updates verarbeiten. Die meisten Unternehmen sehen messbare NAP-Konsistenzverbesserungen innerhalb von 30 Tagen." },
  { q: "Kann ich Stacc als Agentur für den Zitationsaufbau nutzen?", a: "Ja. Agenturen verwalten alle Kundenzitationen von einem Dashboard aus. Zitationsberichte sind in Staccs monatlichen White-Label-Berichten enthalten — automatisch unter Ihrer Marke geliefert. Sie sehen aus, als hätten Sie ein dediziertes Zitations-Team. Sie haben Stacc." },
  { q: "Ist Zitationsaufbau eine einmalige Aufgabe oder kontinuierlich?", a: "Kontinuierlich. Neue Verzeichnisse entstehen. Bestehende Verzeichnisse erlauben nutzerübermittelte Änderungen, die Ihre Daten korrumpieren können. Geschäftsinformationen ändern sich. Stacc überwacht kontinuierlich und korrigiert automatisch — damit Ihre Zitationen ohne manuelle Arbeit nach der Ersteinrichtung korrekt bleiben." },
  { q: "Was kostet Stacc für den Zitationsaufbau?", a: "Zitations-Verwaltung ist im Lokalen SEO-Modul für 49 €/Monat enthalten. Keine Gebühren pro Verzeichnis. Keine Aufschläge pro Standort. Alles ist inklusive — Audit, Korrektur, neue Einträge, laufendes Monitoring und Zitationsdaten in Ihren White-Label-Berichten." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Zitationsaufbau-Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Zitationsaufbau in 50+ lokalen Verzeichnissen automatisieren. Stacc prüft vorhandene Zitationen, behebt NAP-Inkonsistenzen und baut neue Zitationen, die Ihre lokalen Rankings stärken.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Zitationsaufbau-Software", "item": "https://thestacc.com/de/zitationsaufbau-software/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Zitationsaufbau-Software — NAP-Konsistenz in 50+ Verzeichnissen | theStacc"
  description="Zitationsaufbau in 50+ lokalen Verzeichnissen automatisieren. Stacc prüft vorhandene Zitationen, behebt NAP-Inkonsistenzen und baut neue Zitationen, die Ihre lokalen Rankings stärken."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Zitationsaufbau-Software · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Ihre Zitationen sind irgendwo falsch.<br />
            <span style="color:#4f39f6;">Stacc findet und korrigiert sie.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            NAP-Inkonsistenz ist der unsichtbare Killer lokaler Rankings. Falsche Telefonnummer auf Yelp. Alte Adresse auf Apple Maps. Duplizierter Eintrag auf Foursquare. Stacc prüft 50+ Verzeichnisse, korrigiert jede Inkonsistenz und hält Ihre Daten automatisch korrekt.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Kostenloses Zitations-Audit starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">14 Tage kostenlos testen · Keine Kreditkarte · Jederzeit kündbar</p>
          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">50+ synchronisierte Verzeichnisse</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Einrichtung in unter 10 Minuten</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PAIN NARRATIVE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Warum Zitationen still Ihre Rankings zerstören</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sie haben falsche Informationen<br />irgendwo veröffentlicht. Sie wissen nur nicht wo.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>
              Sie sind die Person, die vor zwei Jahren Büros umgezogen ist, Google aktualisiert, die Website aktualisiert und es dabei belassen hat. Oder die Telefonnummer geändert hat, als der Anbieter wechselte. Oder ein Franchise hatte, das seinen eigenen Yelp-Eintrag mit einem leicht anderen Unternehmensnamen einreichte. Jedes dieser Ereignisse ist eine Zitationsinkonsistenz — und Zitationsinkonsistenzen häufen sich still und leise, in großem Maßstab, über 50+ Verzeichnisse, an die Sie nie denken.
            </p>
            <p>
              Googles lokaler Ranking-Algorithmus behandelt NAP-Konsistenz als Vertrauenssignal. Wenn Ihr Name, Ihre Adresse und Telefonnummer in Dutzenden von Verzeichnissen übereinstimmen, ist Google zuversichtlicher, dass Ihr Unternehmen legitim, aktuell und es wert ist, angezeigt zu werden. Wenn sie nicht übereinstimmen — selbst subtil, wie "Str." vs. "Straße" — erodiert dieses Vertrauen. Ihre Wettbewerber mit saubereren Zitationsprofilen übertreffen Sie nicht, weil sie bessere Unternehmen sind, sondern weil ihre Daten konsistenter sind.
            </p>
            <p>
              Die Agenturen, die oben in Google Maps ranken, überprüfen nicht manuell 50 Verzeichnisse. Sie haben es automatisiert. Sie haben Software, die jedes Verzeichnis überwacht, bei jeder Inkonsistenz Alarm schlägt und sie korrigiert, bevor Google das nächste Mal crawlt. Sie können dasselbe System für 49 €/Monat haben — und der ROI aus dem ersten wiederhergestellten Ranking zahlt sich sofort aus.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- PLATFORM OVERVIEW (Features Grid) -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc für Zitationen tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Prüfen. Korrigieren. Aufbauen. Überwachen.<br />Alles automatisiert, alles inklusive.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          {[
            {
              title: 'Zitations-Audit',
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              features: ['50+ Verzeichnisse sofort scannen', 'Jede NAP-Inkonsistenz markieren', 'Fehlende Einträge identifizieren', 'Doppelte Einträge erkennen'],
              href: '/de/funktionen/rank-tracking/',
            },
            {
              title: 'Zitations-Korrektur',
              icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
              features: ['Falsche Adressen automatisch korrigieren', 'Veraltete Telefonnummern aktualisieren', 'Doppelte Einträge entfernen', 'Unternehmensnamen-Format standardisieren'],
              href: '/de/lokales-seo-software/',
            },
            {
              title: 'Zitations-Monitoring',
              icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
              features: ['Kontinuierliches Verzeichnis-Monitoring', 'Benachrichtigung bei Datenänderungen', 'Nutzerübermittelte Änderungen auto-korrigieren', 'Monatlicher Zitations-Gesundheitsbericht'],
              href: '/de/loesungen/agenturen/',
            },
          ].map(m => (
            <a href={m.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7 transition-all hover:border-[#c7c0fc] hover:bg-white hover:shadow-[0_4px_24px_rgba(79,57,246,0.08)]">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={m.icon}/></svg>
              </div>
              <p class="font-sans text-[16px] font-semibold text-[#111827]">{m.title}</p>
              <ul class="mt-4 space-y-2">
                {m.features.map(f => (
                  <li class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#57534e]">{f}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-5 flex items-center gap-2">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Mehr erfahren</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Wie Stacc Zitationen verwaltet</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vom Audit zur Korrektur zum Monitoring.<br />Null manuelle Arbeit nach der Einrichtung.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Audit -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Sofortiges Zitations-Audit</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Ihren Zitations-Gesundheitswert über 50+ Verzeichnisse in 48 Stunden kennen.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Wenn Sie Ihr Unternehmen verbinden, scannt Stacc sofort jedes wichtige lokale Verzeichnis nach Ihren vorhandenen Einträgen. Es prüft jeden auf NAP-Genauigkeit, markiert Duplikate, identifiziert fehlende Einträge und berechnet einen Gesamtzitations-Gesundheitswert. Sie sehen genau, wo Sie stehen — welche Verzeichnisse falsche Informationen haben, welche komplett fehlen und welche korrekt sind — in einer Dashboard-Ansicht.
              </p>
              <a href="/de/lokales-seo-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Lokale SEO-Software ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Zitations-Audit — Ihre Standorte</p>
              {[
                { dir: 'Google Business Profile', status: '✓ Korrekt', color: 'text-[#059669]' },
                { dir: 'Yelp', status: '⚠ Falsche Telefonnummer', color: 'text-[#d97706]' },
                { dir: 'Apple Maps', status: '⚠ Alte Adresse', color: 'text-[#d97706]' },
                { dir: 'Bing Places', status: '✓ Korrekt', color: 'text-[#059669]' },
                { dir: 'Foursquare', status: '✗ Fehlend', color: 'text-[#dc2626]' },
              ].map(r => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{r.dir}</span>
                  <span class={`font-mono text-[11px] font-semibold ${r.color}`}>{r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Stacc korrigiert alle Probleme automatisch · Keine manuelle Arbeit</p>
            </div>
          </div>

          <!-- Correction -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">NAP-Genauigkeitswert</p>
              <div class="flex items-center justify-between mb-3">
                <span class="font-sans text-[13px] text-[#57534e]">Vor Stacc</span>
                <span class="font-mono text-[12px] font-semibold text-[#dc2626]">61 % korrekt</span>
              </div>
              <div class="h-2 w-full rounded-full bg-[#f5f3ff] mb-6">
                <div class="h-2 rounded-full bg-[#dc2626]" style="width:61%"></div>
              </div>
              <div class="flex items-center justify-between mb-3">
                <span class="font-sans text-[13px] text-[#57534e]">Nach 30 Tagen</span>
                <span class="font-mono text-[12px] font-semibold text-[#059669]">94 % korrekt</span>
              </div>
              <div class="h-2 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-2 rounded-full bg-[#059669]" style="width:94%"></div>
              </div>
              <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Durchschnitt bei Stacc-Kunden · 50+ Verzeichnisse</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatische NAP-Korrektur</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Jede Inkonsistenz korrigiert. Jedes Verzeichnis aktualisiert. Sie heben keinen Finger.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Nach dem Audit übermittelt Stacc automatisch Korrekturen an jedes Verzeichnis, das API-Updates erlaubt. Für Verzeichnisse, die manuelle Eingriffe erfordern, stellt Stacc die Korrekturen in die Warteschlange und bearbeitet sie über seine Verzeichnis-Partnerschaften. Der durchschnittliche Stacc-Kunde geht von 61 % NAP-Genauigkeit auf 94 % innerhalb von 30 Tagen — ohne ein einziges Verzeichnis manuell anzufassen.
              </p>
              <a href="/de/funktionen/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Sehen, wie Rankings sich verbessern
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Monitoring -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Kontinuierliches Zitations-Monitoring</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Zitationen driften ab. Stacc erkennt es, bevor Google es tut.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Verzeichnisse erlauben öffentliche Änderungen. Aggregatoren übertragen veraltete Daten. Ihre Informationen können in dem Moment wieder falsch werden, in dem Sie aufhören, sie zu beobachten. Stacc überwacht jedes Verzeichnis kontinuierlich und benachrichtigt Sie sofort, wenn sich Zitationsdaten ändern. Die automatische Korrektur greift sofort für unterstützte Verzeichnisse ein. Ihr NAP bleibt korrekt, auch wenn sich die Verzeichnisse um Sie herum verändern.
              </p>
              <a href="/de/loesungen/agenturen/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Stacc für Agenturen ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Zitations-Monitoring — diese Woche</p>
