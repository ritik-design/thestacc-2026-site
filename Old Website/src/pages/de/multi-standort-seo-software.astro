---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist Multi-Standort-SEO-Software?", a: "Multi-Standort-SEO-Software ist eine Plattform, mit der Unternehmen oder Agenturen mit mehreren physischen Standorten die lokale SEO für alle Standorte zentral verwalten können — Rankings verfolgen, GBP-Inhalte veröffentlichen, Zitationen verwalten und Bewertungen überwachen, alles von einem einzigen Dashboard aus." },
  { q: "Wie handhabt Stacc mehrere Standorte?", a: "Jeder Standort erhält seine eigene Keyword-Strategie, seinen eigenen GBP-Post-Zeitplan, sein eigenes Zitations-Profil und seinen eigenen Berichtszeitraum — alles von einem Dashboard aus verwaltet. Sie können alle Standorte mit einem Klick Posts veröffentlichen oder standortspezifische Strategien konfigurieren." },
  { q: "Gibt es eine Begrenzung für die Anzahl der Standorte?", a: "Keine praktische Begrenzung. Stacc ist skalierbar von 2 bis zu Hunderten von Standorten. Die Preisgestaltung basiert auf der Anzahl der verwalteten Standorte, nicht auf Benutzern oder Kunden." },
  { q: "Kann ich die Leistung über Standorte hinweg vergleichen?", a: "Ja. Die Multi-Standort-Dashboard-Ansicht zeigt Rankings, GBP-Aktivität und Bewertungsmetriken für jeden Standort nebeneinander. Identifizieren Sie unterdurchschnittliche Standorte und skalieren Sie, was für Top-Performer funktioniert." },
  { q: "Unterstützt Stacc White-Label-Berichte für Multi-Standort-Kunden?", a: "Ja. Jeder Standort oder Kunde kann seinen eigenen gebrandeten Bericht erhalten. Konfigurieren Sie einmalig, und Stacc erstellt und liefert jeden Bericht automatisch nach Zeitplan." },
  { q: "Wie lange dauert das Einrichten eines neuen Standorts?", a: "Etwa 2 Minuten. Kerndaten eingeben, das GBP-Listing verbinden und Stacc propagiert die Einrichtung automatisch über Ihr Zitations-Netzwerk." },
  { q: "Was kostet Multi-Standort-SEO-Software?", a: "Das Local SEO-Modul von Stacc beginnt bei 49 €/Monat. Alle Multi-Standort-Funktionen — Bulk-Management, Portfolio-Berichte, Vergleichs-Dashboard — sind enthalten." },
  { q: "Kann ich GBP-Posts an alle Standorte gleichzeitig veröffentlichen?", a: "Ja. Einen Post schreiben und ihn gleichzeitig an alle Standorte veröffentlichen, oder standortspezifische Details vor dem Massen-Publishing anpassen. Stacc verarbeitet die GBP-API-Aufrufe für jeden Standort in einer einzigen Aktion." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Multi-Standort-SEO-Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Multi-Standort-SEO-Software für lokale Unternehmen und Agenturen. Verwalten Sie Rankings, GBP, Zitationen und Bewertungen für alle Standorte von einem Dashboard.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Multi-Standort-SEO-Software", "item": "https://thestacc.com/de/multi-standort-seo-software/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Multi-Standort-SEO-Software — Alle Standorte von einem Dashboard | theStacc"
  description="Verwalten Sie lokales SEO für alle Standorte von einem Dashboard. Rankings, GBP-Posts, Zitationen und Bewertungen — automatisiert für jeden Standort."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Multi-Standort-SEO-Software · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokales SEO für alle Standorte.<br />
            <span style="color:#4f39f6;">Von einem Dashboard aus verwaltet.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc automatisiert lokales SEO für jeden Standort — GBP-Posts, Rank-Tracking, Zitationen und Bewertungen — alles in einer Plattform. Verwalten Sie 2 oder 200 Standorte mit demselben Aufwand.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funktionen" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Funktionen ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">500+ Standort-Portfolios verwaltet</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Einrichtung in unter 45 Min.</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Warum Multi-Standort-SEO im großen Maßstab scheitert</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jeder Standort braucht tägliche Arbeit.<br />Manuell ist das nicht zu schaffen.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Lokales SEO für einen Standort zu verwalten ist Halbzeitarbeit. Für zehn Standorte ist es Vollzeitarbeit. Für fünfzig Standorte braucht man ein ganzes Team. Die Mathematik bricht irgendwann zusammen — und für die meisten Unternehmen passiert das um den dritten oder vierten Standort herum, wenn die Tabellen sich multiplizieren und die manuelle Arbeit sich häuft.</p>
            <p>Das kostet "manuelles Verwalten" im großen Maßstab tatsächlich: Jeder Standort braucht tägliche GBP-Aktivität, konsistente Zitationen in 50+ Verzeichnissen, überwachtes Keyword-Ranking und verwaltetes Reputationsmanagement. Dann muss jemand über all das berichten. Mit 30 Standorten multiplizieren. Das ist kein Workflow — das ist eine ganze Abteilung.</p>
            <p class="font-semibold text-[#111827]">Stacc wurde speziell für dieses Problem entwickelt. Eine Plattform, die jede lokale SEO-Aufgabe an jedem Standort jeden Tag automatisiert — ohne zusätzliches Personal, wenn Ihre Standortanzahl wächst.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FEATURES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Kernfunktionen für Multi-Standort-Unternehmen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede Funktion optimiert für<br />standortübergreifende Skalierung.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Zentrales Standort-Dashboard', body: 'Alle Standorte in einer Ansicht. Rankings, GBP-Aktivität und Bewertungsmetriken nebeneinander vergleichen.' },
            { icon: 'M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z', title: 'Bulk-Post-Veröffentlichung', body: 'Veröffentlichen Sie an alle Standorte gleichzeitig oder erstellen Sie standortspezifische Post-Zeitpläne mit lokalem Keyword-Targeting.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Pro-Standort-Berichte', body: 'Individuelle Leistungsberichte für jeden Standort. Automatisch erstellt und zugestellt — ohne manuelle Arbeit.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Standortübergreifendes Rank-Tracking', body: 'Verfolgen Sie lokale Pack- und Maps-Rankings für jeden Standort gleichzeitig. Sehen Sie, welche Standorte aufsteigen und welche Aufmerksamkeit brauchen.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Zitations-Synchronisation', body: 'NAP-Genauigkeit für jeden Standort in 50+ Verzeichnissen überwacht. Konsistente Informationen überall.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Bewertungsmonitoring', body: 'Alle Bewertungen aller Standorte in einer Ansicht. Reagieren Sie schnell — egal für welchen Standort.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="funktionen" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Schlüsselfunktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede Multi-Standort-SEO-Aufgabe automatisiert.<br />Jedes Ergebnis sichtbar.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Showcase 1: Portfolio Dashboard -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Standort-Portfolio-Dashboard</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Alle Standorte nebeneinander bewertet. Schwachstellen sofort erkennbar.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Das Portfolio-Dashboard zeigt alle Standorte im Vergleich nach Rankings, Zitationsgenauigkeit, Bewertungsscore und GBP-Aktivität. Nach einer beliebigen Metrik sortieren, um sofort zu sehen, wer gewinnt, wer stagniert und wo Ihr Aufwand den höchsten ROI bringt. Kein Tab-Wechseln mehr, um jeden Standort zu prüfen — der Vergleich wird täglich automatisch erstellt.</p>
              <a href="/de/funktionen/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Rank-Tracking ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Standort-Portfolio — heute</p>
              {[
                { name: 'Berlin Mitte', rank: 1, trend: '↑', score: 94 },
                { name: 'Prenzlauer Berg', rank: 2, trend: '↑', score: 91 },
                { name: 'Charlottenburg', rank: 3, trend: '→', score: 88 },
                { name: 'Steglitz', rank: 7, trend: '↓', score: 61 },
              ].map(loc => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${loc.rank <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#fff1f2] text-[#ef4444]'}`}>#{loc.rank}</div>
                  <span class="flex-1 font-sans text-[13px] text-[#374151]">{loc.name}</span>
                  <div class="h-1.5 w-16 rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${loc.score}%`}></div></div>
                  <span class={`font-mono text-[11px] font-semibold ${loc.trend === '↑' ? 'text-[#059669]' : loc.trend === '↓' ? 'text-[#ef4444]' : 'text-[#79716b]'}`}>{loc.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Täglich aktualisiert · Alle Standorte automatisch verglichen</p>
            </div>
          </div>

          <!-- Showcase 2: Bulk Management -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Massen-Update — Feiertagszeiten</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Standorte auswählen</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {['Alle 47 Standorte', 'Region Berlin', 'Benutzerdefiniert'].map(opt => (
                    <span class={`rounded-lg px-3 py-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] ${opt === 'Alle 47 Standorte' ? 'bg-[#4f39f6] text-white' : 'border border-[#e7e5e4] text-[#79716b]'}`}>{opt}</span>
                  ))}
                </div>
              </div>
              <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-white p-4">
                <span class="font-sans text-[13px] text-[#57534e]">Weihnachtszeiten auf alle 47 anwenden</span>
                <span class="rounded-lg bg-[#059669] px-3 py-1 font-mono text-[10px] font-bold text-white">Anwenden</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">2 Sekunden vs. 47 manuelle Logins</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Bulk-Standort-Management</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Jeden Standort in Sekunden aktualisieren. Nicht in Stunden.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Feiertagszeiten. Kategorieänderungen. Neue Telefonnummern. Beschreibungsaktualisierungen. Jede Änderung, die Ihr gesamtes Portfolio betrifft, kann in einer einzigen Aktion gleichzeitig auf alle Standorte angewendet werden. Keine Logins, kein Tab-Wechseln, keine manuellen Fehler. Bulk-Updates werden automatisch an GBP und Ihr Zitations-Netzwerk weitergegeben.</p>
              <a href="/de/loesungen/agenturen/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Für Agenturen ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Showcase 3: Automated Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisierte Portfolio-Berichte</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">Berichte für jeden Standort, termingerecht zugestellt. Null manuelle Arbeit.</h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Automatisierte Berichte für jeden Standort oder jeden Kunden einmalig einrichten. Stacc erstellt standortspezifische Berichte und Portfolio-Zusammenfassungen nach Ihrem Zeitplan — wöchentlich, monatlich oder individuell — und stellt sie automatisch zu. Agenturen können jeden Bericht unter ihrer Marke white-labeln. Kein Exportieren. Kein Formatieren. Kein Vergessen.</p>
              <a href="/de/white-label-berichte/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                White-Label-Berichte ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Portfolio-Bericht dieser Woche</p>
              {[
                { label: 'Verbesserte Standorte', val: '34 von 47' },
                { label: 'Top-3-Pack-Keywords', val: '+18 diese Woche' },
                { label: 'GBP-Posts veröffentlicht', val: '94 über alle Standorte' },
                { label: 'Beantwortete Bewertungen', val: '12 / Ø 4,7 ⭐' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Automatisch erstellt und versendet · Ihre Marke auf allem</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
