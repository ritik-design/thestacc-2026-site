---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';
---

<BaseLayout
  title="Changelog — Was neu ist bei theStacc | theStacc"
  description="theStacc Changelog: neue Funktionen, Verbesserungen und Korrekturen. Bleiben Sie über Plattform-Updates informiert."
  lang="de"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Changelog</span>
          <h1 class="mt-3 font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#111827]">Was neu ist.</h1>

          <div class="mt-10 space-y-12">

            <div>
              <div class="flex items-center gap-3">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">April 2026</span>
                <span class="inline-flex items-center rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider text-[#4f39f6]">Neu</span>
              </div>
              <div class="mt-4 space-y-4 font-sans text-[0.95rem] leading-relaxed text-[#57534e]">
                <p><strong class="text-[#111827]">Deutsche Sprachversion:</strong> theStacc ist jetzt vollständig auf Deutsch verfügbar — alle Seiten, Funktionen und Support in Ihrer Sprache.</p>
                <p><strong class="text-[#111827]">Verbesserte Zitationsüberwachung:</strong> Schnellere Erkennung von NAP-Inkonsistenzen in neuen Verzeichnisquellen.</p>
              </div>
            </div>

            <div>
              <div class="flex items-center gap-3">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">März 2026</span>
                <span class="inline-flex items-center rounded-full bg-[#f0fdf4] px-2.5 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider text-[#16a34a]">Verbesserung</span>
              </div>
              <div class="mt-4 space-y-4 font-sans text-[0.95rem] leading-relaxed text-[#57534e]">
                <p><strong class="text-[#111827]">Rank-Tracking-Dashboard:</strong> Neue Trendvisualisierungen zeigen Rankings-Entwicklung über 30, 60 und 90 Tage.</p>
                <p><strong class="text-[#111827]">GBP-Post-Vorlagen:</strong> Neue branchenspezifische Post-Vorlagen für 15+ Branchen hinzugefügt.</p>
              </div>
            </div>

            <div>
              <div class="flex items-center gap-3">
                <span class="font-mono text-[12px] font-semibold text-[#4f39f6]">Februar 2026</span>
                <span class="inline-flex items-center rounded-full bg-[#f0fdf4] px-2.5 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider text-[#16a34a]">Verbesserung</span>
              </div>
              <div class="mt-4 space-y-4 font-sans text-[0.95rem] leading-relaxed text-[#57534e]">
                <p><strong class="text-[#111827]">Bewertungsbenachrichtigungen:</strong> Schnellere Benachrichtigungen bei neuen Bewertungen — jetzt unter 5 Minuten nach Veröffentlichung.</p>
                <p><strong class="text-[#111827]">White-Label-Berichte:</strong> Erweiterte Anpassungsoptionen für Agenturberichte — eigenes Logo, Farben und benutzerdefinierte Abschnitte.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
