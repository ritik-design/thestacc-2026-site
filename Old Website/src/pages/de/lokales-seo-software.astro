---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist lokale SEO-Software?", a: "Lokale SEO-Software hilft Unternehmen, die Signale zu verwalten, die bestimmen, wie sie in der lokalen Suche ranken — einschließlich Google-Business-Profile-Aktivität, Keyword-Rankings im Local Pack und Google Maps, Zitationskonsistenz in Verzeichnissen und Kundenbewertungen. Stacc automatisiert alle diese Aufgaben in einer Plattform." },
  { q: "Was macht Stacc, was ein einfacher Rank-Tracker nicht kann?", a: "Die meisten Rank-Tracker verfolgen nur Rankings. Stacc postet täglich auf Ihr Google Business Profile, überwacht und benachrichtigt bei Bewertungen in Echtzeit, verwaltet Zitationen in 50+ Verzeichnissen und erstellt automatisch White-Label-Kundenberichte. Es ist ein vollständiges lokales SEO-Betriebssystem — nicht nur ein Daten-Dashboard." },
  { q: "Funktioniert Stacc für Unternehmen mit mehreren Standorten?", a: "Ja — Multi-Standort-Verwaltung ist eine Kernfähigkeit. Verwalten Sie alle Standorte von einem Dashboard, veröffentlichen Sie Posts an alle gleichzeitig und erstellen Sie individuelle oder aggregierte Berichte pro Standort. Es gibt keine praktische Grenze für die Anzahl der Standorte." },
  { q: "Ist Stacc für Agenturen oder interne Marketing-Teams?", a: "Beides. Agenturen erhalten White-Label-Berichte, Multi-Kunden-Kontenverwaltung und gebrandmarkte Kundenportale. Interne Teams bei Multi-Standort-Unternehmen erhalten Massenverwaltungstools und automatisierte Berichte für interne Stakeholder." },
  { q: "Wie lange dauert die Einrichtung von Stacc für einen neuen Standort?", a: "Die meisten Einrichtungen dauern unter 45 Minuten — Standorte hinzugefügt, Keywords konfiguriert, GBP verbunden und automatische Berichte geplant. Danach erledigt Stacc alles laufend ohne zusätzliche Zeit Ihres Teams." },
  { q: "Was kostet Stacc?", a: "Pläne beginnen bei 49 €/Monat für das Lokale-SEO-Modul, das GBP-Post-Veröffentlichung, tägliches Rank-Tracking, Bewertungsmonitoring und Zitationsverwaltung umfasst. Das Blog-SEO-Modul kostet 99 €/Monat. Das Social-Media-Modul 49 €/Monat." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Lokale SEO-Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Lokale SEO-Software, die GBP-Verwaltung, Rank-Tracking, Zitations-Monitoring, Bewertungsmanagement und Kundenberichte automatisiert.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Lokale SEO-Software", "item": "https://thestacc.com/de/lokales-seo-software/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Lokale SEO-Software — Lokales SEO über jeden Standort automatisieren | theStacc"
  description="theStacc ist die lokale SEO-Software, die die Arbeit erledigt — nicht nur verfolgt. GBP-Verwaltung, Rank-Tracking, Zitations-Monitoring und automatisierte Berichte auf Autopilot."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Lokale SEO-Software · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokales SEO, das die Arbeit<br />
            <span style="color:#4f39f6;">für Sie erledigt. Nicht nur verfolgt.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Die meisten lokalen SEO-Tools geben Ihnen Dashboards. Stacc gibt Ihnen Automatisierung. Google Business Profile, Rank-Tracking, Zitationsverwaltung, Bewertungsmonitoring und White-Label-Berichte — alles läuft von selbst, über jeden Standort.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#funktionen" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Was enthalten ist
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <!-- Trust bar -->
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ verwaltete Standorte</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Setup in unter 45 Min.</span>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem mit den meisten lokalen SEO-Tools</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sie haben die Tools ausprobiert.<br />Sie erledigen immer noch die Arbeit selbst.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Vielleicht haben Sie einen Rank-Tracker. Vielleicht haben Sie ein Zitations-Tool. Vielleicht etwas für Bewertungen. Und vielleicht haben Sie es mit Tabellenkalkulationen und Slack-Nachrichten zusammengeflickt und wöchentlich in fünf verschiedene Plattformen eingeloggt, um einen Bericht zu erstellen, der drei Stunden gedauert hat.</p>
            <p>Das ist das schmutzige Geheimnis der meisten lokalen SEO-Software: <strong class="text-[#111827]">Sie verfolgt Dinge. Sie tut keine Dinge.</strong> Sie tun immer noch die Dinge. Die Software zeigt Ihnen nur eine schönere Ansicht, wie viel Arbeit Sie zu erledigen haben.</p>
            <p class="font-semibold text-[#111827]">Ihre Konkurrenten automatisieren es. Sie bedienen mehr Kunden, skalieren schneller und wirken professioneller — nicht weil sie klüger sind, sondern weil sie aufgehört haben, manuell zu tun, was Software automatisch tun sollte.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PLATFORM OVERVIEW ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Eine Plattform. Jeder lokale SEO-Hebel.<br />Alles automatisiert.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP-Post-Automatisierung', body: '30 standortoptimierte Posts pro Monat. Geschrieben und nach Zeitplan veröffentlicht — Ihr Profil bleibt jeden Tag aktiv.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Tägliches Rank-Tracking', body: 'Lokales Pack, Google Maps und organische Rankings — täglich für jeden Standort aktualisiert. Trends und Änderungen sofort sichtbar.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Zitations-Monitoring', body: 'NAP-Genauigkeit in 50+ Verzeichnissen kontinuierlich überwacht. Inkonsistenzen erkannt und gemeldet.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Bewertungsmonitoring', body: 'Echtzeit-Benachrichtigungen für jede neue Bewertung. Antworten direkt aus dem Dashboard. Reputationstrends pro Standort.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'White-Label-Berichte', body: 'Vollständige Kundenberichte automatisch erstellt und zugestellt. Ihr Logo, Ihre Domain, Ihre Farben — kein Stacc-Branding.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Multi-Standort-Verwaltung', body: 'Alle Standorte von einem Dashboard aus verwalten. Bulk-Aktionen, aggregierte Berichte und standortübergreifende Vergleiche.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE SHOWCASE ─── -->
    <section id="funktionen" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Kernfunktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede lokale SEO-Aufgabe automatisiert.<br />Jedes Ergebnis sichtbar.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP-Beitrags-Automatisierung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 GBP-Posts pro Monat. Automatisch veröffentlicht. Auf Suchen ausgerichtet, die Anrufe generieren.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Googles Maps-Algorithmus belohnt Unternehmen, die konsistent posten, mit höherer Sichtbarkeit im Local Pack. Stacc schreibt 30 standortoptimierte Posts pro Monat — ausgerichtet auf Ihre Dienstleistungs- und Stadt-Keyword-Kombinationen, „in meiner Nähe"-Intent, Notfallsuchen und saisonale Themen — und veröffentlicht sie planmäßig. Ihr Profil bleibt jeden Tag aktiv. Sie müssen nichts anfassen.
              </p>
              <a href="/de/module/lokales-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Das Lokales-SEO-Modul ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">GBP-Posts diesen Monat</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 20 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Bisher veröffentlichte Posts</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">20 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:66%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">10 weitere geplant · Vollständig automatisiert · Kein manueller Aufwand</p>
            </div>
          </div>

          <!-- Rank Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Heutiges Ranking-Update</p>
              {[
                { kw: 'Zahnarzt in meiner Nähe', pack: 1, change: '+2', trend: 'up' },
                { kw: 'Notfallzahnarzt [Stadt]', pack: 2, change: '+1', trend: 'up' },
                { kw: 'Zahnaufhellung in meiner Nähe', pack: 3, change: '+4', trend: 'up' },
                { kw: 'Zahnimplantate [Stadt]', pack: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[13px] text-[#374151] truncate">{r.kw}</span>
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Täglich aktualisiert · Local Pack + Organisch + Maps</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tägliches Rank-Tracking</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Wissen, wo Sie ranken — im Local Pack, in Maps und organisch — jeden Morgen.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Rankings werden täglich für jedes verfolgte Keyword an jedem Standort aktualisiert. Sie sehen Ihre Position in organischen Ergebnissen und im lokalen 3-Pack separat — denn für lokale Unternehmen ist das 3-Pack der Ort, an dem fast alle kaufbereiten Klicks landen. Benachrichtigungen werden automatisch ausgelöst, wenn sich Rankings erheblich ändern, damit Sie es immer vor Ihrem Kunden wissen.
              </p>
              <a href="/de/funktionen/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Rank-Tracking im Detail ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisiertes White-Label-Berichtwesen</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Berichte, die sich selbst erstellen und versenden. Für jeden Kunden. Jede Woche. Unter Ihrer Marke.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Der Moment, in dem Sie aufhören, Berichte manuell zu erstellen, ist der Moment, in dem Sie beginnen zu skalieren. Legen Sie Ihre Vorlage einmal pro Kunde fest. Stacc erstellt den Bericht, formatiert ihn mit dem Branding Ihrer Agentur und liefert ihn planmäßig in den Posteingang des Kunden. Niemand in Ihrem Team muss es anfassen. Das ist nicht nur eine Zeitersparnis — es ist das, was Sie Ihren Kundenstamm verdoppeln lässt, ohne Ihre Mitarbeiterzahl zu verdoppeln.
              </p>
              <a href="/de/loesungen/agenturen/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Stacc für Agenturen ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Ihre Agentur</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Wöchentlicher Lokaler-SEO-Bericht</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Gesendet</span>
              </div>
              {[
                { label: 'Ranking-Verbesserungen', val: '+6 Keywords in Top 3' },
                { label: 'Veröffentlichte GBP-Posts', val: '8 diese Woche' },
                { label: 'Neue Bewertungen erhalten', val: '4 ⭐ Ø 4,8' },
                { label: 'Geschätzter Traffic-Wert', val: '+1.200 € organisch' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Automatisch erstellt und zugestellt · Kein manueller Aufwand</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was konsistente lokale SEO-Automatisierung<br />mit Ihren Zahlen macht.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Durchschnittswerte von Unternehmen und Agenturen, die ihr lokales SEO von Stacc verwalten lassen.
