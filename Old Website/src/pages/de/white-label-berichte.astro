---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist White-Label-Reporting?", a: "White-Label-Reporting bedeutet, dass eine Agentur Kundenberichte unter ihrem eigenen Logo, Agenturnamen und ihrer Domain erstellt — nicht unter dem des Software-Anbieters. Kunden erhalten professionell formatierte Berichte, die die Marke der Agentur stärken, ohne dass der Name eines Drittanbieter-Tools irgendwo sichtbar ist." },
  { q: "Welche Daten sind in Staccs White-Label-Berichten enthalten?", a: "Berichte umfassen Keyword-Rankings (Local Pack, Maps, organisch), GBP-Aktivitätsmetriken (veröffentlichte Posts, Aufrufe, Anruf-Klicks), Zitations-Genauigkeitswerte, Bewertungsdaten (Anzahl, Durchschnittsbewertung, Antwortquote) und Monat-für-Monat-Vergleichsdaten. Sie konfigurieren, welche Abschnitte pro Kunde enthalten werden." },
  { q: "Werden Berichte automatisch geliefert oder muss ich sie exportieren?", a: "Vollautomatisch. Konfigurieren Sie Ihren Lieferzeitplan für jeden Kunden — wöchentlich oder monatlich — und Stacc erstellt und sendet den Bericht automatisch per E-Mail. Keine Exporte, keine Formatierung, kein manuelles Versenden. Berichte landen in Kunden-Posteingängen, ohne dass Ihr Team sie anfassen muss." },
  { q: "Kann der Bericht so aussehen, als käme er von meiner Agentur, nicht von Stacc?", a: "Ja. Ihr Logo, Ihr Agenturname, Ihre Domain im E-Mail-Absender, Ihr Farbschema in der PDF. Staccs Name erscheint nirgendwo im kundenorientierten Bericht. Kunden erleben es als Ihr proprietäres Berichtssystem." },
  { q: "Kann ich Berichte überprüfen, bevor sie an Kunden gesendet werden?", a: "Ja. Sie können Berichte auf den Modus 'Vor dem Senden prüfen' einstellen, wo sie in Ihrem Dashboard zur Genehmigung zurückgehalten werden. Oder stellen Sie sie auf vollautomatische Zustellung ein, wo sie direkt an Kunden gehen. Individuelle Konfiguration pro Kunde." },
  { q: "Beinhaltet White-Label-Reporting auch Live-Kunden-Dashboards?", a: "Ja. Zusätzlich zur automatischen Berichtszustellung können Kunden ein Live-Dashboard auf Ihrer Domain aufrufen, das sich kontinuierlich mit frischen Daten aktualisiert. Das Live-Dashboard zeigt aktuelle Rankings, aktuelle GBP-Aktivitäten und Bewertungsstatistiken in Echtzeit." },
  { q: "Was kostet White-Label-Reporting?", a: "In Staccs Growth- und Scale-Plänen enthalten. Das lokale SEO-Modul beginnt bei 49 €/Monat. Die Berichtszustellung ist ohne zusätzliche Kosten pro Kunde enthalten." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — White-Label-Berichte", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "White-Label-SEO-Reporting für Agenturen. Automatische Berichtserstellung und -zustellung unter Ihrer Agenturmarke — Ihr Logo, Ihre Domain, Ihr Bericht.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "White-Label-Berichte", "item": "https://thestacc.com/de/white-label-berichte/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="White-Label-SEO-Berichte für Agenturen — Automatisiert, gebrandmarkt | theStacc"
  description="Automatisieren Sie Kunden-SEO-Berichte unter der Marke Ihrer Agentur. theStacc erstellt und liefert White-Label-Berichte mit Ihrem Logo und Ihrer Domain — wöchentlich oder monatlich, ohne manuelle Arbeit."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">White-Label-Berichte · Für Agenturen · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Kundenberichte, die sich selbst<br />
            <span style="color:#4f39f6;">erstellen und versenden. Unter Ihrer Marke.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc generiert jeden Monat vollständige lokale SEO-Berichte für jeden Kunden und stellt sie automatisch unter Ihrer Marke zu. Kein Export. Keine Formatierung. Keine manuelle Arbeit.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/loesungen/agenturen/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Agenturfunktionen ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <!-- Trust bar: 5 stars -->
          <div class="mx-auto mt-8 inline-flex flex-wrap items-center justify-center gap-2">
            <div class="flex items-center gap-0.5">
              {[...Array(5)].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#79716b]">4,9 / 5 · 127 Agenturen</span>
          </div>
          <div class="mx-auto mt-6 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">100% automatisch</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">Ihr Logo · Ihre Domain</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">0 € pro Bericht</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">400+ Agenturen</span>
          </div>
        </div>
      </div>
    </section>


    <!-- EDITORIAL SECTION -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Warum manuelle Berichtserstellung Agenturen bremst</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede Stunde für Berichte<br />ist eine Stunde nicht für Strategie.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Die meisten Agenturen verbringen 4–8 Stunden pro Monat damit, manuelle SEO-Berichte zu erstellen — Daten aus mehreren Tools exportieren, in Präsentationen einfügen, formatieren, an Kunden senden. Das multipliziert sich schnell: 10 Kunden bedeuten 40–80 Stunden Berichtsarbeit monatlich, die nichts dazu beiträgt, tatsächliche SEO-Ergebnisse zu liefern.</p>
            <p>Stacc automatisiert jeden Schritt. Konfigurieren Sie die Berichtsvorlage und den Zeitplan für jeden Kunden einmal. Danach generiert Stacc jeden Monat einen vollständigen gebrandmarkten Bericht, formatiert ihn mit Ihrem Logo und Ihren Farben und sendet ihn direkt an den Posteingang des Kunden. Sie überprüfen das Ergebnis — Sie arbeiten es nicht manuell.</p>
            <p class="font-semibold text-[#111827]">Agenturen, die von manuellen zu automatisierten Berichten wechseln, gewinnen durchschnittlich 3–6 Stunden pro Monat und Kunde zurück.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was enthalten ist</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vollständiges Reporting-System.<br />Vollständig automatisiert. Vollständig gebrandmarkt.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Automatische Berichtserstellung', body: 'Berichte werden monatlich oder wöchentlich automatisch generiert. Alle Daten werden direkt von Stacc eingezogen — keine manuellen Exporte.' },
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Vollständiges White-Label-Branding', body: 'Berichte tragen Ihr Logo, werden von Ihrer Domain gesendet und mit Ihren Farben formatiert. Kunden sehen niemals Staccs Namen.' },
            { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Direkte Kunden-E-Mail-Zustellung', body: 'Berichte gehen direkt in den Posteingang des Kunden. Konfigurieren Sie Zustellungszeit, Häufigkeit und Empfänger pro Kunde.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Anpassbare Berichtsabschnitte', body: 'Wählen Sie aus, welche Metriken in den Bericht jedes Kunden aufgenommen werden: Rankings, GBP-Aktivität, Zitationen, Bewertungen, Monat-für-Monat-Vergleiche.' },
            { icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z', title: 'Vorab-Prüfungsmodus', body: 'Richten Sie Berichte so ein, dass sie vor dem Versand Ihre Genehmigung erfordern. Oder wählen Sie vollständig automatisierte Zustellung — pro Kunde konfigurierbar.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Live-Kunden-Dashboard', body: 'Kunden greifen auf ein Live-Dashboard auf Ihrer Domain zu, das sich kontinuierlich mit frischen Daten aktualisiert — Rankings, GBP und Bewertungen in Echtzeit.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- 1. FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert automatisiertes Reporting</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Einmal einrichten. Monatlich automatisch liefern.
          </h2>
        </div>

        <div class="mx-auto max-w-5xl space-y-16">

          <!-- Feature 1: Branded Report PDF -->
          <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">01 — Gebrandmarkte Berichte</span>
              <h3 class="mt-3 font-sans text-[1.5rem] font-semibold leading-[1.25] tracking-[-0.02em] text-[#111827]">
                Ihr Logo. Ihre Farben. Kein Stacc-Branding.
              </h3>
              <p class="mt-4 font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">
                Jeder Bericht, der an Ihre Kunden geht, trägt vollständig Ihre Agentur-Identität. Logo, Farbschema, Agenturname — alles konfigurierbar. Stacc erscheint nirgendwo: nicht im PDF, nicht im E-Mail-Absender, nicht in der URL. Kunden erleben es als Ihr System.
              </p>
              <ul class="mt-5 space-y-2">
                {['Logo und Farbschema vollständig anpassbar', 'PDF mit Ihrer Agentur-Identität', 'E-Mail von berichte@ihreagentur.de', 'Stacc-Name nirgendwo sichtbar'].map(item => (
                  <li class="flex items-center gap-2 font-sans text-[13px] text-[#374151]">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <!-- Visual Mockup: Branded Report Preview -->
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 shadow-sm">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="h-9 w-9 rounded-xl bg-[#4f39f6] flex items-center justify-center">
                    <span class="font-mono text-[11px] font-bold text-white">AG</span>
                  </div>
                  <div>
                    <p class="font-sans text-[13px] font-bold text-[#111827]">Ihre Agentur GmbH</p>
                    <p class="font-mono text-[9px] text-[#6b7280]">Monatlicher SEO-Bericht</p>
                  </div>
                </div>
                <div class="flex items-center gap-1.5">
                  <span class="rounded-full bg-[#d1fae5] px-2 py-0.5 font-mono text-[9px] font-semibold text-[#065f46]">PDF</span>
                  <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[9px] font-semibold text-[#4f39f6]">April 2026</span>
                </div>
              </div>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#f9fafb] p-3">
                <p class="font-mono text-[9px] uppercase tracking-[0.1em] text-[#9ca3af] mb-2">Kunden-Zusammenfassung</p>
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Bäckerei Müller · München</p>
                <p class="font-mono text-[10px] text-[#6b7280]">Berichtszeitraum: 01.–30. April 2026</p>
              </div>
              <div class="space-y-2 mb-4">
                {[['Top-3-Rankings', '23 Keywords', '+5 ggü. Vormonat'], ['GBP-Aufrufe', '3.240 Aufrufe', '+18%'], ['Neue Bewertungen', '9 neue', 'Ø 4,8 Sterne'], ['Zitations-Score', '97%', '+2%']].map(([label, val, change]) => (
                  <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] px-3 py-2">
                    <span class="font-sans text-[11px] text-[#57534e]">{label}</span>
                    <div class="flex items-center gap-2">
                      <span class="font-sans text-[11px] font-semibold text-[#111827]">{val}</span>
                      <span class="font-mono text-[9px] text-[#10b981]">{change}</span>
                    </div>
                  </div>
                ))}
              </div>
              <div class="rounded-xl border border-[#e7e5e4] bg-[#f5f3ff] px-4 py-2.5 text-center">
                <p class="font-mono text-[9px] text-[#4f39f6]">Von: berichte@ihreagentur.de · Kein Stacc-Branding</p>
              </div>
            </div>
          </div>

          <!-- Feature 2: Automated Delivery -->
          <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
            <!-- Visual Mockup: Delivery Schedule Card -->
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 shadow-sm order-2 md:order-1">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-[#9ca3af] mb-4">Lieferzeitplan — 4 Kunden aktiv</p>
              <div class="space-y-3 mb-4">
                {[
                  { name: 'Bäckerei Müller', schedule: 'Monatlich · 1. jeden Monat', status: 'Gesendet', color: '#10b981' },
                  { name: 'Autowerkstatt König', schedule: 'Monatlich · 5. jeden Monat', status: 'Geplant', color: '#818cf8' },
                  { name: 'Zahnarzt Dr. Braun', schedule: 'Wöchentlich · Montags', status: 'Gesendet', color: '#10b981' },
                  { name: 'Fitnessstudio Flex', schedule: 'Monatlich · 1. jeden Monat', status: 'Zur Prüfung', color: '#f59e0b' },
                ].map(c => (
                  <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] px-3 py-2.5">
                    <div>
                      <p class="font-sans text-[12px] font-semibold text-[#111827]">{c.name}</p>
                      <p class="font-mono text-[9px] text-[#9ca3af]">{c.schedule}</p>
                    </div>
                    <span class="rounded-full px-2 py-0.5 font-mono text-[9px] font-semibold" style={`background:${c.color}20;color:${c.color};`}>{c.status}</span>
                  </div>
                ))}
              </div>
              <div class="rounded-xl border border-[#e7e5e4] bg-[#f5f3ff] px-4 py-2.5 text-center">
                <p class="font-mono text-[10px] text-[#4f39f6] font-semibold">Vollautomatisch · Kein manueller Trigger nötig</p>
              </div>
            </div>
            <div class="order-1 md:order-2">
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">02 — Automatische Zustellung</span>
              <h3 class="mt-3 font-sans text-[1.5rem] font-semibold leading-[1.25] tracking-[-0.02em] text-[#111827]">
                Berichte werden ohne Ihr Zutun versendet.
              </h3>
              <p class="mt-4 font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">
                Konfigurieren Sie Zeitplan und Empfänger für jeden Kunden einmal — dann übernimmt Stacc. Wöchentlich oder monatlich, zu einem Zeitpunkt Ihrer Wahl. Kein manueller Export, kein Formatieren, kein Versenden. Berichte landen pünktlich im Posteingang des Kunden.
              </p>
              <ul class="mt-5 space-y-2">
                {['Wöchentlich oder monatlich planbar', 'Individuelle Einstellung pro Kunde', 'Pünktlich — ohne manuelle Eingriffe', 'Optionaler Vorab-Prüfungsmodus'].map(item => (
                  <li class="flex items-center gap-2 font-sans text-[13px] text-[#374151]">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Feature 3: Live Dashboard -->
          <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">03 — Live-Dashboard zwischen Berichten</span>
              <h3 class="mt-3 font-sans text-[1.5rem] font-semibold leading-[1.25] tracking-[-0.02em] text-[#111827]">
                Aktuelle Daten — immer auf Ihrer Domain.
