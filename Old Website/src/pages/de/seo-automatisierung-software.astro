---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist SEO-Automatisierungs-Software?", a: "SEO-Automatisierungs-Software übernimmt die wiederholenden Ausführungsaufgaben der lokalen SEO — GBP-Posts veröffentlichen, Rankings täglich verfolgen, Zitationen überwachen, Bewertungsbenachrichtigungen senden und Kundenberichte erstellen — ohne dass jemand diese Aufgaben manuell ausführen muss." },
  { q: "Welche SEO-Aufgaben automatisiert Stacc?", a: "Stacc automatisiert: GBP-Post-Erstellung und -Veröffentlichung (30/Monat), tägliches Rank-Tracking (Local Pack + Maps + organisch), Zitationsüberwachung in 50+ Verzeichnissen, Echtzeit-Bewertungsbenachrichtigungen und monatliche oder wöchentliche Kundenberichtszustellung." },
  { q: "Ersetzt SEO-Automatisierung menschliches Urteilsvermögen?", a: "Nein — sie ersetzt manuelle Ausführung. Strategie, Keyword-Auswahl und Analyse erfordern immer noch menschliches Input. Stacc automatisiert die Execution-Schicht: Inhalte werden nach Zeitplan veröffentlicht, Daten werden täglich aktualisiert, Berichte werden automatisch generiert. Sie konzentrieren sich auf Strategie und Wachstum." },
  { q: "Wie schnell ist der ROI bei SEO-Automatisierung sichtbar?", a: "Sofort in einigen Bereichen — Zeit, die mit manueller Berichterstattung und Datenerfassung verbracht wird, wird von Tag 1 an eingespart. Ranking-Verbesserungen durch konsistente GBP-Aktivität sind typischerweise innerhalb von 60–90 Tagen sichtbar." },
  { q: "Ist SEO-Automatisierung für Agenturen oder interne Teams?", a: "Beides. Agenturen automatisieren die Ausführung für mehrere Kunden und gewinnen Skalierungskapazität zurück. Interne Marketing-Teams automatisieren laufende lokale SEO, um sich auf strategische Initiativen konzentrieren zu können." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO-Automatisierungs-Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Automatisieren Sie lokale SEO-Aufgaben: GBP-Posts, Rank-Tracking, Zitationen, Bewertungen und Berichte — vollständig automatisiert, keine manuelle Ausführung erforderlich.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "SEO-Automatisierungs-Software", "item": "https://thestacc.com/de/seo-automatisierung-software/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="SEO-Automatisierungs-Software — Lokale SEO vollautomatisch | theStacc"
  description="Automatisieren Sie GBP-Posts, Rank-Tracking, Zitationen, Bewertungen und Berichte. Stacc erledigt die SEO-Ausführungsarbeit automatisch — Sie konzentrieren sich auf Strategie."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO-Automatisierung · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokale SEO-Automatisierung.<br />
            <span style="color:#4f39f6;">Vollständig. Für jeden Standort.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc automatisiert jeden wiederholenden Teil der lokalen SEO — Content-Erstellung, Veröffentlichung, Ranking-Tracking, Zitations-Monitoring, Bewertungsbenachrichtigungen und Berichterstattung — damit Sie sich auf Strategie konzentrieren können.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/module/lokales-seo/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Automatisierungsmodule ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc automatisiert</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede SEO-Aufgabe automatisiert.<br />Jeden Monat. Für jeden Standort.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP-Posts (30/Monat)', body: 'Lokal relevante Posts werden automatisch erstellt und täglich veröffentlicht — keine manuellen Uploads.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Tägliches Rank-Tracking', body: 'Local Pack, Maps und organische Rankings täglich aktualisiert. Trends sofort sichtbar.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Zitations-Monitoring', body: 'NAP in 50+ Verzeichnissen kontinuierlich überwacht. Inkonsistenzen automatisch erkannt.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Bewertungsbenachrichtigungen', body: 'Echtzeit-Benachrichtigungen für neue Bewertungen, mit Kontext zum schnellen Antworten.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Automatische Berichte', body: 'Vollständige SEO-Berichte jeden Monat erstellt und zugestellt — an Kunden oder interne Stakeholder.' },
            { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Blog-Content-Automatisierung', body: '30 SEO-optimierte Blogbeiträge pro Monat erstellt und auf Ihrer Website veröffentlicht.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisierung in der Praxis</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Was täglich automatisch läuft —<br />für jeden Standort, jeden Tag.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP-Post-Automatisierung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 GBP-Posts pro Standort pro Monat veröffentlicht. Niemand in Ihrem Team muss sie anfassen.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc erstellt 30 standortoptimierte GBP-Posts pro Monat — mit Fokus auf Ihre Dienstleistungs- und Stadt-Keyword-Kombinationen, „in meiner Nähe"-Suchen und saisonale Themen — und veröffentlicht sie planmäßig. Ihr Profil bleibt täglich aktiv, ohne dass jemand in Ihrem Team sich einloggen, Texte schreiben oder etwas planen muss. Das ist echte Automatisierung: die Aufgabe erledigt sich selbst.
              </p>
              <a href="/de/module/lokales-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Lokales-SEO-Modul ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Automatisierungs-Aktivitätslog — heute</p>
              {[
                { task: 'GBP-Post veröffentlicht', loc: 'München-Mitte · "Klempner in meiner Nähe"', time: '7:02', status: 'done' },
                { task: 'GBP-Post veröffentlicht', loc: 'Schwabing · "Rohrservice [Stadt]"', time: '7:02', status: 'done' },
                { task: 'Zitationen geprüft', loc: '50 Verzeichnisse · 0 Probleme', time: '6:45', status: 'done' },
                { task: 'Ranking-Daten aktualisiert', loc: '18 Keywords · 3 Standorte', time: '6:30', status: 'done' },
              ].map(a => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#dcfce7] text-[10px] text-[#059669]">✓</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">{a.task}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{a.loc} · {a.time} Uhr</p>
                  </div>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alle Aufgaben automatisch erledigt · Null manuelle Arbeit</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Eingesparte Zeit diesen Monat</p>
              {[
                { label: 'GBP-Post-Erstellung und Veröffentlichung', before: '6 Std.', after: '0 Std.', saved: '6 Std.' },
                { label: 'Zitations-Audit', before: '3 Std.', after: '0 Std.', saved: '3 Std.' },
                { label: 'Ranking-Prüfung und Erfassung', before: '4 Std.', after: '0 Std.', saved: '4 Std.' },
                { label: 'Bericht erstellen und versenden', before: '5 Std.', after: '0 Std.', saved: '5 Std.' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-2.5">
                  <span class="flex-1 font-sans text-[12px] text-[#374151] truncate">{r.label}</span>
                  <span class="font-mono text-[11px] text-[#79716b] line-through">{r.before}</span>
                  <span class="font-mono text-[11px] font-bold text-[#059669]">{r.saved} gespart</span>
                </div>
              ))}
              <div class="mt-4 rounded-xl bg-[#f5f3ff] px-4 py-3 text-center">
                <p class="font-sans text-[1.5rem] font-bold text-[#4f39f6]">18 Std.</p>
                <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-[#79716b]">gespart diesen Monat · pro Standort</p>
              </div>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Zeitersparnis im Maßstab</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                8 Stunden gespart pro Standort pro Monat. Multiplizieren Sie mit Ihrer Standortanzahl.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Die Rechnung potenziert sich schnell. Ein Standort spart 8 Stunden/Monat. Zehn Standorte sparen 80 Stunden. Zwanzig Standorte sparen 160 Stunden — das ist eine Vollzeitkraft. Automatisierung spart nicht nur Zeit, sie verändert das, was möglich ist. Mit Stacc als Ausführungsebene konzentriert sich Ihr Team auf Strategie, Neukundengewinnung und Wachstum statt auf fünf Tools und Berichtsvorlagen.
              </p>
              <a href="/de/loesungen/agenturen/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Stacc für Agenturen ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatische Berichtszustellung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Berichte, die sich selbst schreiben und versenden. Unter Ihrer Marke. Jeden Kunden. Jede Woche.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Legen Sie Ihren Berichtszeitplan einmal pro Kunde fest. Stacc ruft die Daten ab, erstellt den Bericht in Ihrer gebrandeten Vorlage und sendet ihn planmäßig direkt in das Postfach des Kunden. Niemand in Ihrem Team berührt ihn. Für Agenturen ist das die wirkungsvollste Automatisierung: Sie ermöglicht es, mehr Kunden auf höherem Standard zu betreuen, ohne die Zeit für Berichte proportional zu erhöhen.
              </p>
              <a href="/de/white-label-berichte/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                White-Label-Berichte ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Ihre Agentur</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Monatlicher Lokale-SEO-Bericht</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Auto-versendet</span>
              </div>
              {[
                { label: 'Ranking-Verbesserungen', val: '+9 Keywords in Top 3' },
                { label: 'GBP-Posts veröffentlicht', val: '30 diesen Monat' },
                { label: 'Neue Bewertungen', val: '7 · Ø 4,8 ⭐' },
                { label: 'Zitationen überwacht', val: '50 Verz. · 0 Probleme' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Automatisch erstellt und versendet · Ihr Logo, Ihre Marke</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was SEO-Automatisierung mit Ihren Zahlen macht
          </h2>
        </div>
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 8, suffix: ' Std.', label: 'Gespart pro Standort pro Monat', sub: 'Automatisierung ersetzt manuelle Ausführung' },
            { to: 89, suffix: '%', label: 'GBP-Ranking-Steigerung in 90 Tagen', sub: 'Gegenüber inaktiver Baseline' },
            { to: 100, suffix: '%', label: 'Pünktliche Berichtszustellung', sub: 'Keine manuellen Schritte, keine Verzögerungen' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Kunden sagen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Die Automatisierung spart nicht nur Zeit.<br />Sie liefert bessere Ergebnisse.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-2">
          {[
