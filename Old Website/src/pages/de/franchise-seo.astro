---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist Franchise-SEO?", a: "Franchise-SEO ist die Optimierung der lokalen Suchsichtbarkeit für Franchise-Netzwerke. Jeder Franchise-Standort konkurriert lokal in seiner eigenen Stadt — mit eigenen Keywords, eigenem GBP-Profil und eigenen Bewertungen. Systemweite Markenkonsistenz muss mit lokalem Relevanz-Targeting verbunden werden." },
  { q: "Was unterscheidet Franchise-SEO von normalem lokalem SEO?", a: "Die Komplexität liegt in der Skalierung mit Markenkontrolle. Generischer Inhalt für alle Standorte rankt nirgendwo gut. Vollständig individualisierter Inhalt pro Standort ist manuell nicht skalierbar. Franchise-SEO braucht systemweite Konsistenz bei gleichzeitig lokaler Relevanz pro Standort." },
  { q: "Wie automatisiert Stacc Franchise-SEO?", a: "Stacc erstellt standortspezifische GBP-Posts mit lokalen Keywords und Stadtbezügen für jeden Standort — gleichzeitig für alle Standorte im Netzwerk. Franchise-Geber behalten systemweite Markenkontrolle; Franchise-Nehmer erhalten lokal relevante SEO-Aktivität ohne manuelle Arbeit." },
  { q: "Kann die Franchise-Zentrale Inhalte kontrollieren?", a: "Ja. Franchise-Geber haben Admin-Zugriff und können Inhaltsgenehmigungsflows einrichten, systemweite Standards festlegen und welche Aktivitäten Franchise-Nehmer selbst verwalten können. Markenschutz bleibt zentral, während Standorte lokale Relevanz erhalten." },
  { q: "Wie wird Franchise-SEO berichtet?", a: "Stacc erstellt automatische Performance-Berichte für jeden Standort und eine Netzwerk-Gesamtübersicht. Franchise-Zentrale sieht Rankings-Performance, Bewertungsaktivität und GBP-Aktivität für alle Standorte von einem Dashboard — keine manuellen Berichte zusammenstellen." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Franchise-SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Franchise-SEO-Automatisierung für lokales Ranking über das gesamte Netzwerk. Systemweite Markenkonsistenz mit lokalem Keyword-Targeting pro Standort.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Franchise-SEO", "item": "https://thestacc.com/de/franchise-seo/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Franchise-SEO — Lokales Ranking für das gesamte Netzwerk | theStacc"
  description="Franchise-SEO automatisieren: standortspezifische GBP-Posts, Bewertungsmonitoring und Rankings-Tracking für alle Franchise-Standorte. Markenkonsistenz mit lokalem Targeting."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Franchise-SEO · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Franchise-SEO im gesamten Netzwerk.<br />
            <span style="color:#4f39f6;">Markenkonsistenz. Lokale Relevanz.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc erstellt standortspezifische GBP-Posts mit lokalen Keywords für jeden Franchise-Standort gleichzeitig — systemweite Markenkonsistenz mit lokalem Ranking-Targeting.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/franchise-seo-software/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Franchise-Software ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ Unternehmen und Agenturen</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ verwaltete Standorte</span>
          </div>
        </div>
      </div>
    </section>


    <!-- PROBLEM SECTION -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Die Herausforderung des Franchise-SEOs</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Systemweite Konsistenz mit<br />lokalem Relevanz-Gleichgewicht.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Franchise-SEO hat eine einzigartige Spannung: Ihre Marke muss systemweit konsistent sein, aber jeder Standort konkurriert lokal in seiner eigenen Stadt gegen andere lokale Unternehmen. Generischer Inhalt, der für alle Standorte identisch ist, sendet keine lokalspezifischen Signale an Google — und rankt entsprechend schlecht. Vollständig individuell erstellter Inhalt für jeden Standort ist ohne Automatisierung manuell schlicht nicht skalierbar, sobald das Netzwerk eine Handvoll Standorte übersteigt.</p>
            <p>Stacc löst genau diese Spannung: Die Plattform erstellt standortspezifische Posts mit lokalen Keywords und Stadtbezügen für jeden Standort automatisch, während Markenkonsistenz und Qualitätsstandards systemweit gewährleistet bleiben. Franchise-Zentrale und Standorte profitieren gleichzeitig — ohne zusätzliche manuelle Arbeit auf beiden Seiten.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Eine Plattform. Alle Franchise-SEO-Aufgaben.<br />Vollständig automatisiert.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Lokale Posts pro Standort', body: '30 GBP-Posts/Monat mit stadtspezifischen Keywords für jeden Franchise-Standort. Automatisch erstellt und veröffentlicht.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Systemweites Rank-Tracking', body: 'Alle Standorte täglich verfolgt — Local Pack, Maps und organisch. Vollständige Netzwerkübersicht auf einen Blick.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Zitationskonsistenz', body: 'NAP-Daten über alle Standorte und 50+ Verzeichnisse hinweg synchronisiert. Abweichungen automatisch erkannt.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Bewertungsmanagement', body: 'Echtzeit-Alerts mit Antwortvorlagen für jeden Standort. Bewertungen direkt aus dem Dashboard beantworten.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Franchise-Berichte', body: 'Standort-Berichte und Netzwerk-Gesamtübersicht automatisch erstellt und termingerecht geliefert.' },
            { icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z', title: 'Admin-Kontrolle', body: 'Franchise-Zentrale behält volle Kontrolle über das System, Standorte erhalten lokale Autonomie im definierten Rahmen.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Schlüsselfunktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Franchise-SEO skalieren.<br />Ohne den manuellen Aufwand.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Lokale Keywords für jeden Standort -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lokale Keywords für jeden Standort</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Jeder Standort erhält stadtspezifische Posts — nicht denselben generischen Inhalt.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc erstellt für jeden Franchise-Standort 30 Posts pro Monat, die lokal relevant sind. Jeder Post enthält die richtige Stadt, die richtigen stadtspezifischen Keywords und lokale Bezüge — automatisch generiert und veröffentlicht, ohne manuelle Arbeit von der Zentrale oder den Standorten. Das Ergebnis: jeder Standort sendet Google präzise lokale Relevanzsignale, während das systemweite Branding konsistent bleibt.
              </p>
              <a href="/de/franchise-seo-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Franchise-SEO-Software ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Automatisierte Posts — diese Woche</p>
              {[
                { location: 'Standort München', post: 'Klempner in München — Notdienst 24/7', status: 'Veröffentlicht', ok: true },
                { location: 'Standort Hamburg', post: 'Klempner Hamburg Altona — Schnell vor Ort', status: 'Veröffentlicht', ok: true },
                { location: 'Standort Berlin', post: 'Rohrbruch Berlin? Klempner sofort verfügbar', status: 'Veröffentlicht', ok: true },
              ].map(r => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.location}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.post}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold shrink-0 text-[#059669]">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">30 Posts/Monat pro Standort · Lokal optimiert</p>
            </div>
          </div>

          <!-- Das gesamte Netzwerk auf einem Blick -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Systemweite Rankings — heute</p>
              {[
                { location: 'München', kw: 'Klempner in der Nähe', pos: 1, change: '+2', trend: 'up' },
                { location: 'Hamburg', kw: 'Klempner Hamburg', pos: 2, change: '+3', trend: 'up' },
                { location: 'Berlin', kw: 'Klempner Berlin', pos: 3, change: '+1', trend: 'up' },
                { location: 'Frankfurt', kw: 'Klempner Frankfurt', pos: 5, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.location}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.kw}</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Täglich aktualisiert · Alle Standorte im Überblick</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das gesamte Netzwerk auf einem Blick</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Zentrales Dashboard für alle Franchise-Standorte — täglich aktualisiert.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Die Franchise-Zentrale sieht auf einen Blick, wie jeder Standort in seinem lokalen Markt rankt. Täglich aktualisierte Positionen im Local Pack, Google Maps und organischen Ergebnissen — für alle Standorte gleichzeitig, von einem einzigen Dashboard aus. Alerts werden automatisch ausgelöst, wenn sich Rankings signifikant verschieben. Sie erkennen sofort, welcher Standort Aufmerksamkeit benötigt.
              </p>
              <a href="/de/multi-standort-seo-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Multi-Standort SEO ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Automatische Leistungsberichte -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatische Leistungsberichte</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Monatliche Berichte für jeden Standort und das gesamte Netzwerk. Automatisch.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Jeder Franchise-Nehmer erhält monatlich einen vollständigen SEO-Bericht für seinen Standort — mit Ranking-Entwicklung, veröffentlichten Posts, Bewertungsübersicht und Zitationsstatus. Die Zentrale erhält zusätzlich einen netzwerkweiten Überblick. Alles mit Franchise-Branding, automatisch erstellt und termingerecht geliefert. Kein manueller Aufwand, keine vergessenen Berichte, kein Zusammenstellen von Daten aus verschiedenen Tools.
              </p>
              <a href="/de/white-label-berichte/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                White-Label-Berichte ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="flex items-center gap-3 mb-5">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">F</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Ihr Franchise-System</p>
                  <p class="font-mono text-[10px] text-[#79716b]">Monatlicher SEO-Bericht — Standort München</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Gesendet</span>
              </div>
              {[
                { label: 'Rankings in Top 3 verbessert', val: '+5 diesen Monat' },
                { label: 'GBP-Posts veröffentlicht', val: '30 automatisiert' },
                { label: 'Neue Bewertungen', val: '8 ⭐ Ø 4,8' },
                { label: 'Zitations-Genauigkeit', val: '100% in 50+ Verzeichnissen' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Automatisch erstellt · Franchise-Branding · Alle Standorte</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRIKEN -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was passiert, wenn Franchise-SEO<br />wirklich automatisiert wird.
          </h2>
