  <!-- Hero: interactive particle canvas + mouse-follow glow -->
  <script>
    (function () {
      const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
      const section = document.getElementById('hero-section');
      const glow = document.getElementById('hero-mouse-glow');
      if (!canvas) return;
      const ctx = canvas.getContext('2d')!;

      let W = 0, H = 0;
      const PARTICLE_COUNT = 90;
      const CONNECT_DIST = 130;
      const MOUSE_DIST = 180;

      interface P { x: number; y: number; vx: number; vy: number; r: number; }
      let particles: P[] = [];
      let mouse = { x: -9999, y: -9999 };

      function resize() {
        W = canvas!.width = canvas!.offsetWidth;
        H = canvas!.height = canvas!.offsetHeight;
      }

      function mkParticle(): P {
        return {
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          r: Math.random() * 1.2 + 0.4,
        };
      }

      function init() {
        resize();
        particles = Array.from({ length: PARTICLE_COUNT }, mkParticle);
      }

      function tick() {
        ctx.clearRect(0, 0, W, H);

        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > W) p.vx *= -1;
          if (p.y < 0 || p.y > H) p.vy *= -1;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(79,57,246,0.45)';
          ctx.fill();
        }

        for (let i = 0; i < particles.length; i++) {
          const a = particles[i];
          for (let j = i + 1; j < particles.length; j++) {
            const b = particles[j];
            const d = Math.hypot(a.x - b.x, a.y - b.y);
            if (d < CONNECT_DIST) {
              ctx.beginPath();
              ctx.strokeStyle = `rgba(79,57,246,${0.22 * (1 - d / CONNECT_DIST)})`;
              ctx.lineWidth = 0.6;
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
          const dm = Math.hypot(a.x - mouse.x, a.y - mouse.y);
          if (dm < MOUSE_DIST) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(79,57,246,${0.45 * (1 - dm / MOUSE_DIST)})`;
            ctx.lineWidth = 0.9;
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(mouse.x, mouse.y);
            ctx.stroke();
          }
        }

        requestAnimationFrame(tick);
      }

      section?.addEventListener('mousemove', (e) => {
        const rect = canvas!.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
        if (glow) {
          glow.style.background = `radial-gradient(500px circle at ${mouse.x}px ${mouse.y}px, rgba(79,57,246,0.08) 0%, transparent 70%)`;
        }
      });
      section?.addEventListener('mouseleave', () => {
        mouse.x = -9999;
        mouse.y = -9999;
        if (glow) glow.style.background = '';
      });

      window.addEventListener('resize', init);
      init();
      tick();
    })();
  </script>

  <!-- Scroll-reveal IntersectionObserver -->
  <script>
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('[data-reveal],[data-reveal-stagger]').forEach((el) => io.observe(el));
  </script>

