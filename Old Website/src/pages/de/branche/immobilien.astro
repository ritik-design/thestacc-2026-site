---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie lange dauert es, bis ich als Immobilienmakler auf Google Maps höher ranke?",
    a: "Die meisten Immobilienmakler sehen innerhalb von 60–90 Tagen bei konsistenter GBP-Aktivität deutliche Maps-Verbesserungen. Makler, die vorher nichts gepostet haben, erzielen meist die schnellsten Ergebnisse – der Maps-Algorithmus belohnt sofort frische, konsistente Inhalte. Die Dominanz im Zielgebiet baut sich typischerweise über 3–6 Monate auf.",
  },
  {
    q: "Hilft das Posten auf GBP einem Immobilienmakler wirklich beim Ranking?",
    a: "Ja. Der lokale Algorithmus von Google berücksichtigt Posting-Häufigkeit, Bewertungsreaktionsfähigkeit und Keyword-Relevanz. Jede Woche, in der Ihr GBP inaktiv ist, gewinnt ein konkurrierender Makler Boden. Stacc postet 30 Mal pro Monat, damit Ihr Profil konstante Aktivität signalisiert – genau das, was der Maps-Algorithmus belohnt.",
  },
  {
    q: "Welche Immobilien-Keywords zielt Stacc an?",
    a: `Stacc zielt auf Service- und Standortkombinationen ab – „Immobilienmakler in der Nähe", „Makler [Stadt]", „Häuser kaufen [Stadtteil]", „Käufermakler [Stadt]", „Luxusimmobilien [Stadt] und spezifische Stadtteilsuchen. Alle auf Ihr Zielgebiet und die von Ihnen angestrebten Transaktionsarten abgestimmt."`,
  },
  {
    q: "Mein Immobilienunternehmen hat bereits ein GBP. Muss ich etwas Besonderes tun?",
    a: "Einfach verbinden. Stacc zieht Ihre vorhandenen GBP-Daten und erstellt daraus einen Inhaltsplan. Die Einrichtung dauert weniger als fünf Minuten. Danach erledigt Stacc alles: Posts schreiben, planmäßig veröffentlichen, Bewertungsbenachrichtigungen senden und Ihr Maps-Ranking tracken.",
  },
  {
    q: "Was passiert, wenn ich eine negative Bewertung erhalte?",
    a: "Stacc sendet sofort eine Benachrichtigung, sobald eine neue Bewertung erscheint. Sie erhalten den Bewertungstext, die Sternebewertung und eine Antwortvorlage, damit Sie professionell in unter einer Minute antworten können. Bei einem Empfehlungsgeschäft wie Immobilien zeigt Ihre Reaktion auf Kritik zukünftigen Kunden alles.",
  },
  {
    q: "Arbeiten Sie mit Immobilienteams und Maklerbüros?",
    a: "Ja. Jeder Makler oder Standort erhält eine eigene Keyword-Strategie, einen Inhaltskalender, einen GBP-Post-Zeitplan und einen Ranking-Bericht – alles über ein Dashboard. Sie können die Maps-Performance jedes Maklers oder Standorts nebeneinander sehen.",
  },
  {
    q: "Wie unterscheidet sich Stacc von einer Immobilien-Marketingagentur?",
    a: "Eine Immobilien-Marketingagentur berechnet 1.000–3.000 €/Monat für manuelles GBP-Management und erfordert lange Verträge. Stacc automatisiert alles für 49 €/Monat. Das Ergebnis ist dasselbe. Der Overhead und die Aufschläge entfallen.",
  },
  {
    q: "Hilft Stacc auch bei Immobilien-Blog-Inhalten?",
    a: `Das Local-SEO-Modul von Stacc kümmert sich um GBP-Posts, Bewertungsmonitoring und Rank-Tracking. Wenn Sie Blog-Inhalte auf Ihrer Website möchten – Artikel wie „beste Stadtteile in [Stadt]" und „[Stadt] Immobilienmarkt 2025" – ist das das Blog-SEO-Modul für 99 €/Monat. Viele Immobilienunternehmen nutzen beides zusammen."`,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc – Lokales SEO für Immobilienmakler",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Stacc postet täglich auf das Google Business Profile Ihres Immobilienunternehmens, verwaltet Bewertungen und trackt Ihr Maps-Ranking automatisch.",
      "inLanguage": "de",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "EUR",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "49",
          "priceCurrency": "EUR",
          "unitText": "MONTH"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Branchen", "item": "https://thestacc.com/de/branche/" },
        { "@type": "ListItem", "position": 3, "name": "Für Immobilienmakler", "item": "https://thestacc.com/de/branche/immobilien/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Immobilienmakler SEO | Mehr Kunden von Google | theStacc"
  description="Stacc postet täglich auf das Google Business Profile Ihres Immobilienunternehmens, verwaltet Bewertungen und trackt Ihr Maps-Ranking automatisch. Mehr Immobilienkunden von Google für 49 €/Monat."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Immobilien SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mehr Immobilienkunden von Google.<br />
            <span style="color:#4f39f6;">Auf Autopilot.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            246.000 Menschen suchen jeden Monat nach „Immobilienmakler in der Nähe". 76 % der Käufer recherchieren Makler online, bevor sie Kontakt aufnehmen. Stacc sorgt dafür, dass Ihr Immobilienunternehmen als Erstes erscheint – durch tägliche Posts auf Ihrem Google Business Profile, Bewertungsmanagement und Rank-Tracking.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/de/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              So funktioniert es
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Keine Verträge · Täglich Posts auf Ihrem GBP
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '246K', num: 246, prefix: '',  suffix: 'K', decimals: 0, from: 0, label: 'Monatliche „Makler in der Nähe"-Suchen' },
              { value: '76%',  num: 76,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Käufer recherchieren Makler zuerst online' },
              { value: '4,5×', num: 4.5, prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Durchschn. Maps-Ranking-Verbesserung' },
              { value: '100%', num: 100, prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Bewertungen sofort erfasst' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Lokale Unternehmen, die mit Stacc ranken</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 aus 127 Bewertungen</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['The Smith Gruppe — Berlin', 'Premier Immobilien — Hamburg', 'Desert Properties — München', 'Mountain Realty — Köln', 'Pacific Makler — Frankfurt', 'Coastal Realty — Stuttgart', 'Metro Makler — Düsseldorf', 'The Smith Gruppe — Berlin', 'Premier Immobilien — Hamburg', 'Desert Properties — München', 'Mountain Realty — Köln', 'Pacific Makler — Frankfurt', 'Coastal Realty — Stuttgart', 'Metro Makler — Düsseldorf'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ihre besten Kunden suchen gerade jetzt.<br />Sie rufen einen anderen Makler an.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            83 % der Käufer, die einen Immobilienmakler in der lokalen Suche finden, nehmen Kontakt auf. Die einzige Frage ist: Wessen Profil sie zuerst finden.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Google belohnt aktive Profile. Ihr GBP ist seit Wochen inaktiv.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Der Maps-Algorithmus bevorzugt Immobilienmakler, die konsequent posten, auf Bewertungen reagieren und aktiv bleiben. Jede Woche, in der Ihr GBP dunkel ist, gewinnt ein konkurrierender Makler, der Marktberichte, Neulistings und Stadtteilinhalte postet, Boden. Im Immobilienbereich bekommt der sichtbare Makler den Anruf.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Eine unbeantwortete Bewertung leitet Käufer zu einem anderen Makler um.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">76 % der Käufer und Verkäufer lesen Online-Bewertungen, bevor sie einen Makler auswählen. Eine negative Bewertung, die unbeantwortet bleibt, sagt jedem künftigen Kunden, dass Sie zu beschäftigt – oder zu gleichgültig – sind. In einem Beziehungsgeschäft ist Ihr Online-Ruf Ihre Mundpropaganda in großem Maßstab.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Sie ranken für Ihren Namen. Nicht für „Immobilienmakler in der Nähe".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Käufer suchen zu Beginn ihrer Suche nicht nach Ihrem Namen – sie kennen ihn noch nicht. Sie suchen „Immobilienmakler in der Nähe", „Häuser kaufen [Stadtteil]" und „Makler [Stadt]". Wenn Sie für diese Begriffe nicht im Map Pack sind, sind Sie für kaufbereite Käufer unsichtbar.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc für Immobilienmakler tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jeder Hebel, der neue Kunden von Google bringt. Erledigt.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Maps-Ranking für Immobilienmakler erfordert konsistente GBP-Aktivität, schnelle Bewertungsantworten und keyword-optimierten Content – jeden einzelnen Monat. Stacc erledigt das alles automatisch.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'GBP-Post-Veröffentlichung',
              body: '30 standortoptimierte Posts pro Monat – Neulistings, Marktberichte, Stadtteilführer, Käufertipps und Verkäufertipps für Ihre spezifischen Märkte. Automatisch nach Zeitplan veröffentlicht.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Immobilien-Keyword-Targeting',
              body: 'Service- und Standortkombinationen für jeden von Ihnen bedienten Markt – Käufermakler, Verkäufermakler, Luxusimmobilien, Eigentumswohnungen, Kapitalanlagen, spezifische Stadtteile. Alle auf Ihr Zielgebiet abgestimmt.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Bewertungsmonitoring',
              body: 'Sofortige Benachrichtigungen, sobald eine neue Bewertung erscheint. Wöchentliches Sternebewertungs-Tracking. Antwortvorlagen, damit Sie in unter einer Minute antworten und den Ruf aufbauen können, der Empfehlungen generiert.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Lokales Rank-Tracking',
              body: 'Gitterbasierte Maps-Ranking-Berichte, die genau zeigen, wo Ihr Immobilienunternehmen für jedes Ziel-Keyword in Ihrem Zielgebiet rankt. Monatliches Tracking, damit Sie sehen, wie sich Ihre Maps-Position verbessert.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Multi-Markt-Management',
              body: 'Mehrere Stadtteile oder Städte? Jeder Markt erhält eine eigene Keyword-Strategie, einen Inhaltskalender und einen Performance-Bericht – alles über ein Dashboard. Sehen Sie, welche Märkte Aufmerksamkeit benötigen.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Zitationsaufbau',
              body: 'NAP-Konsistenzprüfungen und Verzeichniseinträge auf Immobilienplattformen – Immobilienscout24, Immonet, Immo Welt, Yelp und 50+ weitere. Die Autoritätssignale, die Ihre Maps-Rankings verbessern.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Einmal verbinden. Stacc verwaltet Ihre Immobilien-<br />Maps-Präsenz von da an.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Keine GBP-Logins. Kein Posts-Schreiben. Kein manuelles Prüfen von Bewertungen. Einmal einrichten und Ihr Google Business Profile läuft von selbst – damit Sie sich auf Kunden konzentrieren können.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
