---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie lange dauert es, bis mein Reinigungsunternehmen bei Google Maps höher rankt?",
    a: "Die meisten Reinigungsunternehmen sehen innerhalb von 60–90 Tagen konsistenter GBP-Aktivität deutliche Verbesserungen im Maps-Ranking. Reinigung ist ein wiederkehrender Service – sobald Sie im Map Pack sind, gewinnen Sie Monat für Monat neue Kunden.",
  },
  {
    q: "Hilft das Posten auf GBP einem Reinigungsunternehmen tatsächlich beim Ranking?",
    a: "Ja. Der Maps-Algorithmus belohnt konsistente GBP-Aktivität – Service-Updates, Reinigungstipps, Saisonangebote und Vorher/Nachher-Beiträge. Jede Woche, in der Ihr Profil inaktiv ist, baut ein konkurrierender Reinigungsservice die Maps-Autorität auf, die wiederkehrende Verträge gewinnt.",
  },
  {
    q: "Welche Reinigungs-Keywords zielt Stacc an?",
    a: `Stacc zielt auf Dienst- und Stadtkombinationen ab – „Reinigungsservice in meiner Nähe", „Haushaltshilfe [Stadt]", „Grundreinigung [Stadt]", „Büroreinigung [Stadt]", „Einzugsreinigung [Stadt]. Alle auf Ihre Servicearten und Ihr Gebiet abgestimmt."`,
  },
  {
    q: "Mein Reinigungsunternehmen hat bereits ein GBP. Muss ich etwas Besonderes tun?",
    a: "Einfach verbinden. Stacc ruft Ihre vorhandenen Daten ab und erstellt in unter 5 Minuten einen Inhaltsplan. Danach werden Beiträge automatisch veröffentlicht und Bewertungsbenachrichtigungen kommen sofort an.",
  },
  {
    q: "Was passiert, wenn ich eine negative Bewertung erhalte?",
    a: "Sofortige Benachrichtigung mit Bewertungstext und einer Antwortvorlage, damit Sie noch am selben Tag antworten können. Bei Reinigungsservices ist Vertrauen alles – Kunden geben Ihnen den Schlüssel zu ihrem Zuhause. Schnell auf Kritik zu reagieren zeigt zukünftigen Kunden, dass Sie Qualität ernst nehmen.",
  },
  {
    q: "Arbeiten Sie mit Reinigungsunternehmen, die mehrere Gebiete bedienen?",
    a: "Ja. Jedes Servicegebiet erhält seine eigene Keyword-Strategie, seinen eigenen Inhaltskalender und Ranking-Bericht – alles von einem Dashboard aus.",
  },
  {
    q: "Wie unterscheidet sich Stacc von einer Reinigungs-Marketingagentur?",
    a: "Agenturen berechnen 500–1.200 €/Monat für manuelles GBP-Management. Stacc automatisiert alles für 49 €/Monat mit mehr Leistung – 30 Beiträge/Monat gegenüber den typischen 8–12.",
  },
  {
    q: "Hilft Stacc mit Blog-Inhalten für Reinigung?",
    a: `Ja – das Blog-SEO-Modul für 99 €/Monat veröffentlicht Artikel wie „Wie oft sollte man sein Zuhause grundreinigen" und „Einzugs-Reinigungscheckliste", die bei Google ranken und neue Kundenanfragen generieren. Viele Reinigungsunternehmen nutzen beide Module zusammen."`,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc für Reinigungsdienste",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "theStacc veröffentlicht täglich Beiträge im Google-Unternehmensprofil Ihres Reinigungsunternehmens, verwaltet Ihre Bewertungen und verfolgt Ihr Maps-Ranking – automatisch. Mehr Reinigungskunden über Google für 49 €/Monat.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "EUR"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Startseite",
          "item": "https://thestacc.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Branchen",
          "item": "https://thestacc.com/de/branche/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "SEO für Reinigungsdienste",
          "item": "https://thestacc.com/de/branche/reinigungsdienste/"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  lang="de"
  title="Reinigungsdienste SEO | Mehr Reinigungskunden über Google | theStacc"
  description="Stacc veröffentlicht täglich Beiträge im Google-Unternehmensprofil Ihres Reinigungsunternehmens, verwaltet Ihre Bewertungen und verfolgt Ihr Maps-Ranking – automatisch. Mehr Reinigungskunden über Google für 49 €/Monat."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Reinigungsdienste SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mehr Reinigungskunden über Google.<br />
            <span style="color:#4f39f6;">Im Dauerauftrag.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            440.000 Menschen suchen jeden Monat nach „Reinigungsservice in meiner Nähe". 78 % der Haushalte recherchieren Reinigungsunternehmen online, bevor sie buchen. Stacc stellt sicher, dass Ihr Reinigungsunternehmen zuerst erscheint – täglich Beiträge in Ihrem GBP veröffentlichen, Bewertungen verwalten und Ihr Maps-Ranking verfolgen. Alles automatisch.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/de/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              So funktioniert es
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Keine Verträge · Täglich Beiträge in Ihrem GBP
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '440K', num: 440, prefix: '', suffix: 'K', decimals: 0, from: 0, label: 'Monatliche Suchen nach „Reinigungsservice in meiner Nähe"' },
              { value: '78%',  num: 78,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Haushalte recherchieren zuerst online' },
              { value: '4,4×', num: 4.4, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Durchschnittliche Maps-Ranking-Verbesserung' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Bewertungen sofort erfasst' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Lokale Unternehmen, die mit Stacc ranken</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 aus 127 Bewertungen</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Glanz Reinigung — Berlin', 'Sauber Profi — München', 'Blank & Rein — Hamburg', 'Frisch Reinigung — Frankfurt', 'Klean Team — Köln', 'Top Reinigung — Stuttgart', 'Blitz Sauber — Düsseldorf', 'Glanz Reinigung — Berlin', 'Sauber Profi — München', 'Blank & Rein — Hamburg', 'Frisch Reinigung — Frankfurt', 'Klean Team — Köln', 'Top Reinigung — Stuttgart', 'Blitz Sauber — Düsseldorf'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Haushalte suchen gerade jetzt nach Reinigern.<br />Sie buchen bei Ihrem Mitbewerber.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            82 % der Haushalte lesen Bewertungen, bevor sie ein Reinigungsunternehmen beauftragen. Die einzige Frage ist, wessen Profil sie zuerst finden.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Ihr Mitbewerber postet wöchentlich Reinigungstipps und Angebote. Ihr GBP wurde seit einem Monat nicht aktualisiert.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Reinigung ist ein wiederkehrender Service – das erste Unternehmen, das ein Haushalt beauftragt, behält diese Kunden oft jahrelang. Der Maps-Algorithmus belohnt konsistente GBP-Aktivität mit Service-Updates, Reinigungstipps und Saisonangeboten. Jede Woche, in der Ihr Profil inaktiv ist, baut ein konkurrierender Reinigungsservice die Maps-Autorität auf, die diese wiederkehrenden Verträge gewinnt.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Eine unbeantwortete 2-Sterne-Bewertung über einen übersehenen Fleck kostet Sie wiederkehrende monatliche Einnahmen.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">82 % der Haushalte lesen Bewertungen, bevor sie ein Reinigungsunternehmen beauftragen. Reinigungsservices basieren auf Vertrauen – Kunden geben Ihnen den Schlüssel zu ihrem Zuhause. Eine unbeantwortete negative Bewertung über schlechte Qualität signalisiert jedem zukünftigen Kunden, dass man Ihnen nicht trauen kann. Ihre Sternebewertung entscheidet, ob Sie den Schlüssel bekommen oder der Anruf an jemand anderen geht.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Sie ranken für Ihren Firmennamen. Nicht für „Haushaltshilfe in meiner Nähe".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Haushalte, die einen Reinigungsservice suchen, suchen nicht nach Ihrem Firmennamen – sie suchen nach „Haushaltshilfe in meiner Nähe", „Reinigungsservice [Stadt]" und „Grundreinigung [Stadt]". Wenn Sie nicht im Map Pack für diese Suchanfragen erscheinen, haben diese wiederkehrenden Kunden nie die Chance, Sie zu finden.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc für Reinigungsunternehmen tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jeder Hebel, der neue Reinigungskunden über Google bringt. Erledigt.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Das Maps-Ranking für Reinigungsunternehmen erfordert konsistente GBP-Aktivität, schnelle Bewertungsantworten und keyword-zielgerichtete Inhalte – jeden Monat. Stacc erledigt alles automatisch.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'GBP-Beiträge Veröffentlichen',
              body: '30 Beiträge pro Monat – Reinigungstipps, Saisonale Grundreinigungsangebote, Einzugs-/Auszugs-Specials, Vorher/Nachher-Inhalte. Automatisch nach Zeitplan veröffentlicht.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Reinigungs-Keyword-Targeting',
              body: 'Dienst- und Stadtkombinationen: Haushaltshilfe, Reinigungsservice, Grundreinigung, Büroreinigung, Einzugsreinigung. Abgestimmt auf Ihre Servicearten und Ihr Gebiet.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Bewertungsüberwachung',
              body: 'Sofortige Bewertungsbenachrichtigungen mit Antwortvorlagen, um das vertrauensbasierte Ansehen zu schützen, das wiederkehrende Kundenprogramme antreibt.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Lokales Rang-Tracking',
              body: 'Rasterbasierte Maps-Ranking-Berichte für jedes Reinigungs-Keyword in Ihrem Servicegebiet. Monatliches Tracking, damit Sie Ihren Fortschritt wachsen sehen.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Mehrere Gebiete Verwalten',
              body: 'Mehrere Servicegebiete von einem Dashboard aus. Jedes Gebiet erhält seine eigene Keyword-Strategie und seinen eigenen Inhaltskalender.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Zitations-Aufbau',
              body: 'Verzeichniseinträge bei Yelp, Blauarbeit, MyHammer, Trusted Shops und 50+ weiteren. Die Autoritätssignale, die konkurrierende Reinigungsunternehmen in Ihrem Markt übertreffen.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Einmal verbinden. Stacc führt die Maps-Präsenz<br />Ihres Reinigungsunternehmens von da an.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Kein GBP-Login. Kein Schreiben von Beiträgen. Kein manuelles Prüfen von Bewertungen. Einmal einrichten und Ihr Google-Unternehmensprofil läuft von selbst – damit Sie sich auf Ihre Kunden konzentrieren können.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
