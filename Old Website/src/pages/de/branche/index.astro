---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const localSEO = [
  { label: 'Steuerberater',             href: '/de/branche/steuerberater/'           },
  { label: 'Autohändler',               href: '/de/branche/autohaendler/'            },
  { label: 'Chiropraktiker',            href: '/de/branche/chiropraktiker/'          },
  { label: 'Reinigungsdienste',         href: '/de/branche/reinigungsdienste/'       },
  { label: 'Handwerker',                href: '/de/branche/handwerker/'              },
  { label: 'Zahnärzte',                 href: '/de/branche/zahnaerzte/'              },
  { label: 'Elektriker',                href: '/de/branche/elektriker/'              },
  { label: 'Finanzberater',             href: '/de/branche/finanzberater/'           },
  { label: 'Fitnessstudios',            href: '/de/branche/fitnessstudios/'          },
  { label: 'Gesundheitswesen',          href: '/de/branche/gesundheitswesen/'        },
  { label: 'Hausinspektoren',           href: '/de/branche/hausinspektoren/'         },
  { label: 'Heizung, Lüftung & Klima', href: '/de/branche/heizung-lueftung-klima/'  },
  { label: 'Versicherungen',            href: '/de/branche/versicherungen/'          },
  { label: 'Gartenbau',                 href: '/de/branche/gartenbau/'              },
  { label: 'Rechtsanwälte',             href: '/de/branche/rechtsanwaelte/'          },
  { label: 'Umzugsunternehmen',         href: '/de/branche/umzugsunternehmen/'       },
  { label: 'Tierdienstleistungen',      href: '/de/branche/tierdienstleistungen/'    },
  { label: 'Fotografen',                href: '/de/branche/fotografen/'              },
  { label: 'Klempner',                  href: '/de/branche/klempner/'               },
  { label: 'Immobilien',                href: '/de/branche/immobilien/'              },
  { label: 'Restaurants',               href: '/de/branche/restaurants/'             },
  { label: 'Dachdecker',                href: '/de/branche/dachdecker/'              },
  { label: 'Friseure',                  href: '/de/branche/friseure/'               },
  { label: 'Therapeuten',               href: '/de/branche/therapeuten/'             },
  { label: 'Nachhilfe',                 href: '/de/branche/nachhilfe/'              },
  { label: 'Tierärzte',                 href: '/de/branche/tieraerzte/'              },
  { label: 'Hochzeitsdienstleister',    href: '/de/branche/hochzeitsdienstleister/'  },
];

const blogSEO = [
  { label: 'Unternehmensberatung', href: '/de/branche/unternehmensberatung/' },
  { label: 'E-Commerce',           href: '/de/branche/ecommerce/'           },
  { label: 'SaaS',                 href: '/de/branche/saas/'                },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "theStacc",
      "url": "https://thestacc.com/",
      "inLanguage": "de"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Branchen", "item": "https://thestacc.com/de/branche/" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Stacc für jede Branche | SEO-Automatisierung nach Unternehmenstyp | theStacc"
  description="Stacc automatisiert SEO für 30+ Branchen — von lokalen Dienstleistern bis zu SaaS-Unternehmen. Finden Sie Ihre Branche und sehen Sie, wie Stacc Ihren organischen Traffic steigert."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-[680px] text-center">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">30 Branchen · Lokales SEO &amp; Blog-SEO</span>
          </div>
          <h1 class="font-sans text-[2.2rem] font-semibold leading-[1.15] tracking-[-0.035em] text-[#111827] md:text-[3rem]">
            SEO, entwickelt für Ihre Branche.
          </h1>
          <p class="mx-auto mt-5 max-w-[540px] font-sans text-[1.05rem] leading-[1.7] text-[#57534e]">
            Jede Branche hat andere Keywords, andere Käufer und andere Ranking-Signale. Stacc ist auf Ihre Kategorie trainiert — damit die Posts, Artikel und Optimierungen, die jeden Monat veröffentlicht werden, genau darauf ausgerichtet sind, wie Ihre Kunden wirklich suchen.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#292524] transition-colors hover:bg-[#fafaf9]"
            >
              Preise ansehen
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── MODULE EXPLAINER STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-10">
        <div class="mx-auto grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-2">
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">Lokales SEO</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">49 €/Monat</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">Für Unternehmen, die auf lokale Suche angewiesen sind — GBP-Posts, Bewertungsmonitoring und Maps-Rank-Tracking. Am besten für Dienstleistungsbetriebe, stationäre Händler und alle, die im Map Pack ranken wollen.</p>
            </div>
          </div>
          <div class="flex gap-5 bg-white px-8 py-7">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-mono text-[12px] font-bold uppercase tracking-[0.1em] text-[#292524]">Blog-SEO</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">99 €/Monat</span>
              </div>
              <p class="mt-1.5 font-sans text-[14px] leading-[1.65] text-[#57534e]">Für Unternehmen, die durch organische Inhalte wachsen — 30 SEO-Artikel werden jeden Monat auf Ihrer Website veröffentlicht. Am besten für SaaS, E-Commerce und professionelle Dienstleister, die national konkurrieren.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── LOKALES SEO BRANCHEN ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Lokales SEO Modul</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">49 €/Monat · {localSEO.length} Branchen</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Lokale Dienstleistungsunternehmen
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            GBP-Posts, Bewertungsmanagement und Map-Pack-Rank-Tracking — vollständig automatisiert.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {localSEO.map(item => (
            <a
              href={item.href}
              class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BLOG SEO BRANCHEN ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Blog-SEO Modul</span>
            <span class="rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[10px] font-semibold text-[#4f39f6]">99 €/Monat · {blogSEO.length} Branchen</span>
          </div>
          <h2 class="mt-2 font-sans text-[1.6rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#111827]">
            Content-getriebene Unternehmen
          </h2>
          <p class="mt-2 font-sans text-[15px] leading-relaxed text-[#57534e]">
            30 SEO-Artikel werden jeden Monat auf Ihrer Website veröffentlicht — recherchiert, geschrieben und live.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3">
          {blogSEO.map(item => (
            <a
              href={item.href}
              class="group flex items-center justify-between gap-3 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3.5 transition-all hover:border-[#c7c0fc] hover:bg-[#f5f3ff]"
            >
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 012.828 2.828L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-sans text-[14px] font-medium text-[#292524]">{item.label}</span>
              </div>
              <svg class="shrink-0 text-[#79716b] transition-transform group-hover:translate-x-0.5 group-hover:text-[#4f39f6]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BOTTOM CTA ─── -->
    <section class="relative overflow-hidden py-16 md:py-20" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.18) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.03) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>

      <div class="container-x relative">
        <div class="mx-auto max-w-xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ihre Branche nicht dabei?</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.03em] text-[#292524] md:text-[2.4rem]">
            Stacc funktioniert für jedes<br />Unternehmen, das organischen Traffic braucht.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Wenn Ihre Kunden bei Google nach Ihnen suchen, kann Stacc das SEO automatisieren, mit dem Sie gefunden werden. Buchen Sie eine Demo und wir zeigen Ihnen, wie es für Ihr spezifisches Unternehmen funktioniert.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]"
            >
              Demo buchen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff] bg-white"
            >
              Preise ansehen
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
