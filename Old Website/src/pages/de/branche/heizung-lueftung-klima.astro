---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie lange dauert es, bis mein HLK-Unternehmen auf Google Maps höher rankt?",
    a: "Die meisten HLK-Unternehmen sehen innerhalb von 60–90 Tagen nach konsistenter GBP-Aktivität eine spürbare Verbesserung auf Maps. HLK ist eine lokale Suchkategorie mit hoher Suchabsicht, in der viele Konkurrenten GBP-inaktiv sind – was die Ranking-Chance erheblich macht. Unternehmen, die vor Stacc nichts gepostet haben, sehen oft schon innerhalb der ersten 30–45 Tage Bewegung.",
  },
  {
    q: "Hilft das Posten im GBP einem HLK-Unternehmen wirklich beim Ranking?",
    a: "Ja. Googles lokaler Algorithmus belohnt konsistente Posting-Häufigkeit, Reaktionszeit auf Bewertungen und Keyword-Relevanz. In einem Saisongeschäft wie HLK ist es das Aktiv-Bleiben das ganze Jahr über – nicht nur in der Hochsaison –, was die Maps-Autorität aufbaut, die Notfallanrufe gewinnt, wenn die Nachfrage steigt.",
  },
  {
    q: "Auf welche HLK-Keywords zielt Stacc ab?",
    a: `Stacc zielt auf Leistung + Stadt-Kombinationen ab – „Klimaanlagenreparatur in meiner Nähe", „HLK-Wartung [Stadt]", „Heizungsinstallation [Stadt]", „Wärmepumpenreparatur [Stadt]", „Klimaanlage Austausch [Stadt]", „Lüftungsreinigung in der Nähe". Alle kalibriert auf Ihre Leistungen und die spezifischen Städte, die Sie bedienen."`,
  },
  {
    q: "Mein HLK-Unternehmen hat bereits ein GBP. Muss ich etwas Besonderes einrichten?",
    a: "Einfach verbinden. Stacc ruft Ihre GBP-Daten, Bewertungshistorie und aktuelle Rankingposition ab – und erstellt einen Content-Plan für die HLK-Keywords, für die Sie noch nicht ranken. Die Einrichtung dauert unter fünf Minuten.",
  },
  {
    q: "Was passiert, wenn ich eine negative Bewertung erhalte?",
    a: "Stacc sendet sofort eine Benachrichtigung, sobald eine neue Bewertung erscheint. Sie erhalten den Bewertungstext und eine Antwortvorlage, damit Sie in unter einer Minute reagieren können. Im HLK-Bereich, wo ein einziger schlechter Serviceeinsatz eine sichtbare Bewertung erzeugen kann, zeigt schnelles Reagieren zukünftigen Kunden, wie Sie mit Problemen umgehen – was oft überzeugender ist als die Bewertung selbst.",
  },
  {
    q: "Arbeiten Sie auch mit HLK-Unternehmen, die mehrere Städte bedienen?",
    a: "Ja. Jedes Versorgungsgebiet erhält seine eigene Keyword-Strategie, Content-Kalender und Ranking-Bericht – alles über ein Dashboard. Posts zielen auf die spezifischen HLK-Suchbegriffe und saisonalen Muster jeder Stadt ab, damit Sie in Ihrem gesamten Versorgungsgebiet ranken.",
  },
  {
    q: "Wie unterscheidet sich Stacc von einer HLK-Marketingagentur?",
    a: "Eine HLK-Marketingagentur berechnet 600–1.500 €/Monat für manuelle GBP-Verwaltung und erfordert lange Verträge. Stacc automatisiert alles für 49 €/Monat. Die meisten HLK-Unternehmen, die Stacc nutzen, haben zuvor Agenturen weit mehr für die Hälfte der Leistung bezahlt.",
  },
  {
    q: "Hilft Stacc auch bei HLK-Blog-Inhalten?",
    a: `Staccs Local-SEO-Modul übernimmt GBP-Posts, Bewertungsüberwachung und Ranking-Tracking. Wenn Sie HLK-Blog-Inhalte auf Ihrer Website möchten – Artikel, die für „Wie oft sollte ich meine Klimaanlage warten lassen" und „Anzeichen, dass Ihre Heizung ersetzt werden muss" ranken – ist das das Blog-SEO-Modul für 99 €/Monat."`,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc für HLK-Unternehmen",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Stacc postet täglich in das Google Business-Profil Ihres HLK-Unternehmens, verwaltet Ihre Bewertungen und verfolgt Ihr Maps-Ranking – automatisch. Mehr HLK-Anrufe über Google für 49 €/Monat.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Branchen", "item": "https://thestacc.com/de/branche/" },
        { "@type": "ListItem", "position": 3, "name": "Für HLK-Unternehmen", "item": "https://thestacc.com/de/branche/heizung-lueftung-klima/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="HLK SEO | Mehr HLK-Anrufe über Google | theStacc"
  description="Stacc postet täglich in das Google Business-Profil Ihres HLK-Unternehmens, verwaltet Ihre Bewertungen und verfolgt Ihr Maps-Ranking – automatisch. Mehr Serviceanrufe für 49 €/Monat."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">HLK SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mehr HLK-Anrufe über Google.<br />
            <span style="color:#4f39f6;">Bevor Ihre Konkurrenten antworten.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            320.000 Menschen suchen jeden Monat „HLK in meiner Nähe". 88 % der HLK-Notfallanrufe gehen an das Unternehmen, das auf Google Maps zuerst erscheint. Stacc stellt sicher, dass das Ihr Unternehmen ist – durch tägliches Posten in Ihr Google Business-Profil, Bewertungsverwaltung und Maps-Ranking-Tracking.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/de/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              So funktioniert es
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Keine Verträge · Täglich in Ihr GBP gepostet
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '320K', num: 320, prefix: '',  suffix: 'K', decimals: 0, from: 0, label: 'Monatliche „HLK"-Suchen' },
              { value: '88%',  num: 88,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Notfallanrufe gehen an das erste Maps-Ergebnis' },
              { value: '4,8×', num: 4.8, prefix: '',  suffix: '×', decimals: 1, from: 0, label: 'Durchschn. Maps-Ranking-Verbesserung' },
              { value: '100%', num: 100, prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'Bewertungen sofort erfasst' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Lokale Unternehmen, die mit Stacc ranken</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 aus 127 Bewertungen</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Arktische Luft HLK — Berlin', 'Komfortzone HLK — Hamburg', 'Wüstenkühlung Systeme — München', 'Gipfel HLK — Stuttgart', 'Pazifischer Komfort — Frankfurt', 'Sonnenschein HLK — Köln', 'Metro Komfort Systeme — Düsseldorf', 'Arktische Luft HLK — Berlin', 'Komfortzone HLK — Hamburg', 'Wüstenkühlung Systeme — München', 'Gipfel HLK — Stuttgart', 'Pazifischer Komfort — Frankfurt', 'Sonnenschein HLK — Köln', 'Metro Komfort Systeme — Düsseldorf'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ihre besten Kunden suchen gerade.<br />Sie rufen jemand anderen an.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            88 % der Hausbesitzer, die nach HLK-Service suchen, rufen das erste Unternehmen an, das sie auf Google Maps sehen. Die einzige Frage ist, ob das Sie sind.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Sommer kommt. Klimaanlage bricht zusammen. Hausbesitzer rufen denjenigen an, der zuerst rankt – nicht Sie.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">HLK-Notfallanrufe haben die höchste Suchabsicht jeder Heimdienstleistung. Wenn die Klimaanlage eines Hausbesitzers an einem 35-Grad-Tag nachmittags ausfällt, sucht er „Klimaanlagenreparatur in meiner Nähe" und ruft das erste Unternehmen an, das erscheint. Wenn Ihr GBP inaktiv ist und auf Seite 2 rankt, geht dieser Anruf jedes Mal an Ihren Konkurrenten.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Eine unbeantwortete Bewertung sagt Hausbesitzern, dass Ihr Service unzuverlässig ist.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">75 % der Hausbesitzer prüfen Bewertungen, bevor sie zum ersten Mal ein HLK-Unternehmen anrufen. Eine unbeantwortete negative Bewertung signalisiert genau das, was Hausbesitzer am meisten fürchten: ein Unternehmen, das nicht hinter seiner Arbeit steht. Im HLK ist der Ruf der Unterschied zwischen einem 5.000-€-Installationsauftrag und einem leeren Kalender.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Sie ranken für Ihren Firmennamen. Nicht für „Klimaanlagenreparatur in meiner Nähe".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Hausbesitzer, die HLK-Service brauchen, suchen nicht nach Ihrem Firmennamen – sie suchen „Klimaanlagenreparatur in meiner Nähe", „Heizungsreparatur [Stadt]" und „HLK-Wartung [Stadt]". Wenn Sie für diese Begriffe nicht im Map Pack ranken, wenn die Hitzewelle kommt, gehen diese Serviceanrufe an denjenigen, der dort ist – die ganze Saison lang.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc für HLK-Unternehmen tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jeder Hebel, der neue HLK-Anrufe über Google bringt. Erledigt.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Maps-Ranking für HLK-Unternehmen erfordert konsistente GBP-Aktivität, schnelle Bewertungsantworten und keyword-optimierte Inhalte – jeden Monat. Stacc übernimmt das alles automatisch.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'GBP-Post-Veröffentlichung',
              body: '30 standortoptimierte Posts pro Monat – saisonale Klimaanlagen- und Heizungswartungstipps, Tune-up-Aktionen, Energieeffizienztipps und Notdienst-Verfügbarkeit. Automatisch veröffentlicht, damit Ihr Profil das ganze Jahr aktiv bleibt.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'HLK-Keyword-Targeting',
              body: 'Leistung + Stadt-Kombinationen für jeden Auftrag Ihres Teams – Klimaanlagenreparatur, Heizungsinstallation, Wärmepumpenwartung, Lüftungsreinigung, Luftqualitätsmessung. Kalibriert auf Ihre saisonalen Serviceprioritäten und Ihr Versorgungsgebiet.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Bewertungsüberwachung',
              body: 'Sofortige Benachrichtigungen, sobald eine neue Bewertung erscheint. Sternebewertungstrend-Tracking wöchentlich. Antwortvorlagen, damit Sie in unter einer Minute reagieren und den Ruf aufrechterhalten können, der das HLK-Serviceanrufvolumen antreibt.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Lokales Ranking-Tracking',
              body: 'Rasterbasierte Maps-Ranking-Berichte, die genau zeigen, wo Ihr HLK-Unternehmen für jedes Ziel-Keyword in Ihrem Versorgungsgebiet rankt. Monatliches Tracking, um saisonale Ranking-Muster und langfristiges Wachstum zu sehen.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Multi-Standort-Management',
              body: 'Mehrere Versorgungsgebiete oder Standorte? Jeder erhält seine eigene Keyword-Strategie, Content-Kalender und Leistungsbericht – alles über ein Dashboard. Verfolgen Sie Verbesserungen in jedem Gebiet, das Sie bedienen.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Zitationsaufbau',
              body: 'NAP-Konsistenzprüfungen und Verzeichniseinträge in Heimdienstleistungsverzeichnissen – MyHammer, Angi, Thumbtack, Yelp und 50+ weitere. Die Autoritätssignale, die Ihnen helfen, konkurrierende HLK-Unternehmen zu übertreffen.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Einmal verbinden. Stacc steuert die Maps-Präsenz<br />Ihres HLK-Unternehmens von da an.
