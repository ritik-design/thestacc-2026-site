---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie lange dauert es, bis mein Dachdeckerunternehmen auf Google Maps höher rankt?",
    a: "Die meisten Dachdeckerunternehmen sehen innerhalb von 60–90 Tagen bei konsistenter GBP-Aktivität deutliche Maps-Verbesserungen. Wenn Sie auf eine Sturmsaison zusteuern, sind die Unternehmen, die in den vorangegangenen Monaten ihre GBP-Präsenz aufgebaut haben, diejenigen, die den Nachfrageschub abfangen. Googles lokaler Algorithmus belohnt Häufigkeit, Relevanz und Engagement – alle drei liefert Stacc automatisch jeden Monat.",
  },
  {
    q: "Hilft das Posten auf GBP einem Dachdeckerunternehmen wirklich beim Ranking?",
    a: "Ja. Googles eigene Dokumentation besagt, dass regelmäßig aktualisierte Business Profile häufiger in lokalen Suchergebnissen erscheinen. Der Maps-Algorithmus berücksichtigt Posting-Häufigkeit, Bewertungsreaktionsfähigkeit und Keyword-Relevanz. Jeden Tag, an dem Sie inaktiv sind, gewinnt ein konkurrierender Dachdecker, der konsequent postet, Boden. Stacc postet 30 Mal pro Monat, damit Ihr Profil nie dunkel ist – auch in den Monaten vor der Sturmsaison.",
  },
  {
    q: "Welche Dachdecker-Keywords zielt Stacc an?",
    a: `Stacc zielt auf Ihre Kerndienste und Stadtkombinationen ab – „Dachdecker in der Nähe", „Dachsanierung [Stadt]", „Dachdeckerbetrieb [Stadt]", „Sturmschaden Dachreparatur [Stadt]", „Dachinspektion [Stadt]" und „Dachrinnenreinigung [Stadt]. Wir zielen auch auf saisonale Begriffe wie „Hagelschaden Dachreparatur" und „Notfall-Dachreparatur" ab. Alle Keywords werden auf Ihre spezifischen Leistungen und Ihr Einsatzgebiet abgestimmt."`,
  },
  {
    q: "Mein Unternehmen hat bereits ein Google Business Profile. Muss ich etwas für die Einrichtung tun?",
    a: "Einfach verbinden. Stacc zieht Ihre vorhandenen GBP-Daten – Firmenname, Dienstleistungen, Fotos, Bewertungshistorie und aktuelles Ranking – und erstellt daraus einen Inhaltsplan. Die Einrichtung dauert weniger als fünf Minuten. Danach erledigt Stacc alles: Posts schreiben, planmäßig veröffentlichen, Bewertungsbenachrichtigungen senden und Ihr Maps-Ranking monatlich tracken.",
  },
  {
    q: "Was passiert, wenn ich eine negative Bewertung erhalte?",
    a: "Stacc sendet sofort eine Benachrichtigung, sobald eine neue Bewertung erscheint, positiv oder negativ. Sie erhalten den Bewertungstext, die Sternebewertung und eine Antwortvorlage, damit Sie in unter einer Minute antworten können. Das schnelle Reagieren auf negative Bewertungen ist für Dachdeckerunternehmen entscheidend – eine sichtbare, professionelle Antwort auf eine Beschwerde über Arbeitsqualität sagt jedem Hausbesitzer, der Ihr Profil liest, dass Sie zu Ihrer Arbeit stehen.",
  },
  {
    q: "Arbeiten Sie mit Dachdeckerunternehmen, die mehrere Städte bedienen?",
    a: "Ja. Ob Sie ein Stadtgebiet oder mehrere Städte bedienen, Stacc erstellt Keyword-Strategien für jedes Einsatzgebiet. Multi-Standort-Unternehmen erhalten separate GBP-Strategien, Inhaltskalender und Ranking-Berichte für jeden Standort – alles über ein Dashboard. Sie können die Performance jedes Einsatzgebiets nebeneinander sehen.",
  },
  {
    q: "Wie unterscheidet sich Stacc von einer Dachdecker-Marketingagentur?",
    a: "Eine Dachdecker-Marketingagentur schreibt Ihre GBP-Posts manuell, berechnet 700–2.000 €/Monat und erfordert Onboarding-Gespräche und lange Verträge. Stacc automatisiert jeden Teil dieses Prozesses – Recherche, Schreiben, Planung, Bewertungsmonitoring, Rank-Tracking – für 49 €/Monat. Das Ergebnis ist dasselbe. Der Overhead und die Aufschläge entfallen.",
  },
  {
    q: "Hilft Stacc auch bei Dachdecker-Blog-Inhalten oder nur bei GBP?",
    a: `Das Local-SEO-Modul von Stacc kümmert sich um GBP-Posts, Bewertungsmonitoring und Rank-Tracking. Wenn Sie Dachdecker-Artikel auf Ihrer Website möchten – die Art, die für „Wie lange hält ein Dach oder „Anzeichen, dass Sie ein neues Dach benötigen" rankt – ist das das Blog-SEO-Modul für 99 €/Monat. Viele Dachdeckerunternehmen nutzen beides für vollständige organische Suchabdeckung."`,
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc – Lokales SEO für Dachdecker",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Stacc postet täglich auf das Google Business Profile Ihres Dachdeckerunternehmens, verwaltet Bewertungen und trackt Ihr Maps-Ranking automatisch.",
      "inLanguage": "de",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "EUR",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "49",
          "priceCurrency": "EUR",
          "unitText": "MONTH"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Branchen", "item": "https://thestacc.com/de/branche/" },
        { "@type": "ListItem", "position": 3, "name": "Für Dachdecker", "item": "https://thestacc.com/de/branche/dachdecker/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Dachdecker SEO | Mehr Dachdeckeraufträge von Google | theStacc"
  description="Stacc postet täglich auf das Google Business Profile Ihres Dachdeckerunternehmens, verwaltet Bewertungen und trackt Ihr Maps-Ranking automatisch. Mehr Dachdeckeraufträge von Google für 49 €/Monat."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Dachdecker SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mehr Dachdeckeraufträge von Google.<br />
            <span style="color:#4f39f6;">Sturmsaison hin oder her.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            390.000 Menschen suchen jeden Monat nach „Dachdecker in der Nähe". 76 % der Hausbesitzer recherchieren Dachdeckerunternehmen online, bevor sie anrufen. Stacc sorgt dafür, dass Ihr Dachdeckerunternehmen als Erstes erscheint – durch tägliche Posts auf Ihrem GBP, Bewertungsmanagement und Rank-Tracking.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/de/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              So funktioniert es
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Keine Verträge · Täglich Posts auf Ihrem GBP
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '390K', num: 390, prefix: '', suffix: 'K', decimals: 0, from: 0, label: 'Monatliche „Dachdecker in der Nähe"-Suchen' },
              { value: '76%',  num: 76,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Hausbesitzer recherchieren zuerst online' },
              { value: '4,7×', num: 4.7, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Durchschn. Maps-Ranking-Verbesserung' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Bewertungen sofort erfasst' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Lokale Unternehmen, die mit Stacc ranken</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 aus 127 Bewertungen</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Gipfel Bedachungen — Berlin', 'Lone Star Dachdecker — Hamburg', 'Wüstensky Bedachungen — München', 'Bergkamm Dachdecker — Köln', 'Pacific Roofing — Frankfurt', 'Sunshine Bedachungen — Stuttgart', 'Südliche Dachdecker — Düsseldorf', 'Gipfel Bedachungen — Berlin', 'Lone Star Dachdecker — Hamburg', 'Wüstensky Bedachungen — München', 'Bergkamm Dachdecker — Köln', 'Pacific Roofing — Frankfurt', 'Sunshine Bedachungen — Stuttgart', 'Südliche Dachdecker — Düsseldorf'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Hochpreisige Dachdeckeraufträge gehen an denjenigen,<br />der bei Google Maps als Erstes erscheint.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            78 % der Hausbesitzer prüfen Bewertungen, bevor sie einen Dachdecker beauftragen. Das Dachdeckerunternehmen im Map Pack mit der besten Bewertung gewinnt. Wer darunter liegt, wird fast nie angerufen.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Ein Sturm trifft Ihren Markt. Hausbesitzer googeln Dachdecker. Sie rufen denjenigen an, der als Erstes rankt.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Sturmschäden erzeugen massive lokale Suchspitzen – und das Dachdeckerunternehmen, das im Map Pack rankt, fängt den Großteil dieser Nachfrage ab. Der Maps-Algorithmus baut Ranking-Autorität über Monate konsistenter Aktivität auf, nicht in Tagen. Die Unternehmen, die die Sturmsaison gewinnen, sind diejenigen, die ihre GBP-Präsenz aufgebaut haben, bevor der Sturm trifft.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Eine 2-Sterne-Bewertung über eine undichte Reparatur kostet Sie Aufträge über 15.000 €.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">78 % der Hausbesitzer prüfen Bewertungen, bevor sie einen Dachdecker beauftragen. Dachreparatur ist ein hochpreisiger, vertrauensabhängiger Kauf – Hausbesitzer treffen eine Entscheidung über 8.000–20.000 € basierend auf Ihrem Ruf. Eine unbeantwortete negative Bewertung über schlechte Arbeitsqualität sagt jedem künftigen Kunden genau das, was er befürchtet.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Sie ranken für Ihren Firmennamen. Nicht für „Dachsanierung in der Nähe".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Hausbesitzer, die ein neues Dach benötigen, suchen „Dachsanierung in der Nähe", „Dachdecker [Stadt]" und „Dachdeckerbetrieb [Stadt]". Sie suchen nicht nach Ihrem Firmennamen – sie kennen ihn noch nicht. Wenn Sie für diese Suchen nicht im Map Pack sind, gehen diese Aufträge über 15.000–30.000 € an denjenigen, der dort ist.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc für Dachdecker tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jeder Hebel, der neue Dachdeckeraufträge von Google bringt. Erledigt.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Maps-Ranking für Dachdeckerunternehmen erfordert konsistente GBP-Aktivität, schnelle Bewertungsantworten und keyword-optimierten Content – jeden einzelnen Monat. Stacc erledigt das alles automatisch.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'GBP-Post-Veröffentlichung',
              body: '30 standortoptimierte Posts pro Monat, die auf saisonale Sturm-Vorbereitungsinhalte, Dachinspektionserinnerungen, Materialvorstellungen, Garantieinformationen und abgeschlossene Projektberichte abzielen. Automatisch nach Zeitplan veröffentlicht.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Dachdecker-Keyword-Targeting',
              body: 'Service- und Stadtkombinationen für jeden Job Ihres Unternehmens – Dachsanierung, Sturmschadensreparatur, Dachrinnen, Inspektionen, Flachdach und Notfallreparaturen. Alle auf Ihr spezifisches Einsatzgebiet abgestimmt.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Bewertungsmonitoring',
              body: 'Sofortige Benachrichtigungen, sobald eine neue Bewertung auf Google, MyHammer oder Angi erscheint. Wöchentliches Sternebewertungs-Tracking. Antwortvorlagen, damit Sie in unter einer Minute antworten und Ihren hochpreisigen Ruf schützen können.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Lokales Rank-Tracking',
              body: 'Gitterbasierte Maps-Ranking-Berichte, die genau zeigen, wo Ihr Dachdeckerunternehmen für jedes Ziel-Keyword in Ihrem Einsatzgebiet rankt. Monatliches Tracking, damit Sie Ihre Autorität vor der Sturmsaison wachsen sehen.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Multi-Gebiets-Management',
              body: 'Mehrere Städte oder Landkreise? Jedes Einsatzgebiet erhält eine eigene Keyword-Strategie, einen Inhaltskalender und einen Performance-Bericht – alles über ein Dashboard. Verfolgen Sie Verbesserungen in jedem Gebiet.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Zitationsaufbau',
              body: 'NAP-Konsistenzprüfungen und Verzeichniseinträge in Handwerkerverzeichnissen – MyHammer, Gelbe Seiten, DAA-zertifiziertes Verzeichnis und 50+ weitere. Die Autoritätssignale, die Ihnen helfen, Storm-Chaser zu übertreffen.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
