---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie lange, bis der Blog meiner Unternehmensberatung zu ranken beginnt?",
    a: "Die meisten Unternehmensberatungen sehen erste spürbare Rankingbewegungen innerhalb von 3–6 Monaten bei konsistenter Veröffentlichung. Einzelne Artikel können bei Long-Tail-Keywords schneller ranken. Der Compounding-Effekt — bei dem jeder Artikel die Domain-Autorität steigert, was alle Artikel nach oben zieht — wird am deutlichsten ab Monat 3–4."
  },
  {
    q: "Zu welchen Themen und Keywords schreibt Stacc für Unternehmensberatungen?",
    a: "Stacc zielt auf Service- und Ergebnis-Kombinationen ab, die auf Ihre Schwerpunkte zugeschnitten sind — 'Betriebseffizienz verbessern', 'digitale Transformation Beratung', 'Go-to-Market-Strategie für SaaS', 'Revenue-Operations-Beratung'. Dazu Wettbewerbs- und Alternativen-Suchen, die kaufbereite Interessenten erfassen."
  },
  {
    q: "Woher weiß Stacc, was für meine spezifische Beratungsnische zu schreiben ist?",
    a: "Beim Setup prüft Stacc Ihre bestehenden Inhalte, analysiert die Top-Inhalte in Ihrer Nische und identifiziert die Keyword-Lücken zwischen dem, wofür Ihre Wettbewerber ranken, und dem, wofür Sie es nicht tun. Der Content-Kalender wird aus dieser Lückenanalyse aufgebaut."
  },
  {
    q: "Welche CMS-Plattformen unterstützt Stacc?",
    a: "Stacc veröffentlicht auf WordPress, Webflow, HubSpot, Ghost, Squarespace und benutzerdefinierte CMS-Lösungen. Wenn Ihr CMS Inhalte per API oder geplanter Veröffentlichung akzeptiert, unterstützen wir es. Das Setup dauert unter 10 Minuten."
  },
  {
    q: "Kann ich Artikel vor der Veröffentlichung prüfen?",
    a: "Ja. Sie können einen Freigabe-Workflow einrichten, bei dem Artikel zur Prüfung in eine Warteschlange gestellt werden, oder vollautomatische Veröffentlichung aktivieren. Die meisten Beratungen starten mit Freigabe und wechseln nach den ersten Qualitätsprüfungen zu automatischer Veröffentlichung."
  },
  {
    q: "Wie unterscheidet sich Stacc von einer Content-Marketing-Agentur?",
    a: "Eine Content-Marketing-Agentur berechnet 5.000–15.000 €/Monat für 4–8 Artikel, erfordert Onboarding-Gespräche und hat Account-Manager zwischen Ihnen und den Textern. Stacc ist vollautomatisch — Recherche, Schreiben, Veröffentlichen — für 99 €/Monat. Das Ausgabevolumen ist 3–7× höher."
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Blog-SEO für Unternehmensberatungen",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Blog-SEO-Automatisierung für Unternehmensberatungen. 30 SEO-Artikel pro Monat — recherchiert, geschrieben und veröffentlicht.",
      "offers": { "@type": "Offer", "price": "99", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Branchen", "item": "https://thestacc.com/de/branche/" },
        { "@type": "ListItem", "position": 3, "name": "Unternehmensberatung", "item": "https://thestacc.com/de/branche/unternehmensberatung/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
};
---

<BaseLayout
  title="Blog-SEO für Unternehmensberatungen — Thought-Leadership-Inhalte automatisieren | theStacc"
  description="Stacc veröffentlicht 30 SEO-Blogartikel pro Monat auf der Website Ihrer Unternehmensberatung — Thought Leadership, Fallstudien und Service-Keyword-Inhalte, die ranken und Leads generieren."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Blog-SEO für Unternehmensberatungen · Ab 99 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            30 SEO-Artikel, die Ihre Beratung als Experten positionieren.<br />
            <span style="color:#4f39f6;">Jeden Monat veröffentlicht.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Beratungskunden googeln ihre Probleme, bevor sie wissen, wen sie beauftragen sollen. Beratungen, die 30 SEO-Artikel pro Monat veröffentlichen — die genau diese Probleme ansprechen — gewinnen Inbound-Leads, bevor ein Wettbewerber überhaupt auf dem Radar erscheint.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/blog-seo/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">Blog-SEO-Software ansehen</a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
        </div>
      </div>
    </section>
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Häufige Fragen beantwortet.</h2>
          <div class="mt-10 divide-y divide-[#e7e5e4]">
            {faqs.map((f) => (
              <div class="py-5">
                <button class="faq-btn flex w-full items-start justify-between gap-4 text-left" aria-expanded="false">
                  <span class="font-sans text-[1rem] font-semibold text-[#111827]">{f.q}</span>
                  <span class="mt-0.5 flex-shrink-0">
                    <svg class="faq-icon-plus h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    <svg class="faq-icon-minus hidden h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                  </span>
                </button>
                <div class="faq-answer hidden pt-3">
                  <p class="font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.12) 0%,transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-24 text-center">
        <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.8rem]">Inhalte veröffentlichen.<br />Mandanten gewinnen.</h2>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/de/demo/" class="inline-flex h-12 items-center gap-2 rounded-xl bg-[#4f39f6] px-7 font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">Kostenlos starten<svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
          <a href="/de/preise/" class="inline-flex h-12 items-center rounded-xl border border-[#e7e5e4] bg-white px-7 font-sans text-[15px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">Preise ansehen</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      if (answer) answer.classList.toggle('hidden', expanded);
      btn.querySelector('.faq-icon-plus')?.classList.toggle('hidden', !expanded);
      btn.querySelector('.faq-icon-minus')?.classList.toggle('hidden', expanded);
    });
  });
</script>
