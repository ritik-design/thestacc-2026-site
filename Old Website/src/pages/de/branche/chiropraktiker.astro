---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie lange dauert es, bis meine Chiropraktik-Praxis bei Google Maps höher rankt?",
    a: "Die meisten Chiropraktik-Praxen sehen innerhalb von 60–90 Tagen bei konsistenter GBP-Aktivität deutliche Verbesserungen im Maps-Ranking. Googles lokaler Algorithmus belohnt Häufigkeit, Relevanz und Engagement – alle drei liefert Stacc automatisch jeden Monat. Praxen, die vorher gar keine Beiträge veröffentlicht haben, sehen die Ergebnisse am schnellsten.",
  },
  {
    q: "Hilft das Posten auf GBP einer Chiropraktik-Praxis tatsächlich beim Ranking?",
    a: "Ja. Googles eigene Dokumentation besagt, dass regelmäßig aktualisierte Unternehmensprofile eher in lokalen Suchergebnissen erscheinen. Der Maps-Algorithmus berücksichtigt Posting-Häufigkeit, Bewertungsreaktionsfähigkeit und Keyword-Relevanz. Jeden Tag, an dem Ihr Profil inaktiv ist, gewinnt ein konkurrierender Chiropraktiker, der täglich postet, Terrain. Stacc postet 30 Mal im Monat, damit Ihr Profil nie dunkel ist.",
  },
  {
    q: "Welche Chiropraktik-Keywords zielt Stacc an?",
    a: "Stacc zielt auf Ihre Kerndienst- und Stadtkombinationen ab – Dinge wie 'Chiropraktiker in meiner Nähe', 'Rückenschmerzen [Stadt]', 'Sportchiropraktiker [Stadt]', 'Autounfall-Chiropraktiker [Stadt]', 'Nackenschmerzen Behandlung [Stadt]' und 'chiropraktische Einstellung [Stadt]'. Alle Keywords sind auf Ihren spezifischen Praxistyp und Standort abgestimmt.",
  },
  {
    q: "Meine Praxis hat bereits ein Google-Unternehmensprofil. Muss ich etwas einrichten?",
    a: "Einfach verbinden. Stacc ruft Ihre vorhandenen GBP-Daten ab – Praxisname, Dienste, Fotos, Bewertungshistorie und aktuelle Ranking-Position – und erstellt daraus einen Inhaltsplan. Die Einrichtung dauert unter fünf Minuten. Danach übernimmt Stacc alles: Beiträge schreiben, nach Zeitplan veröffentlichen, Bewertungsbenachrichtigungen senden und Ihr Maps-Ranking monatlich verfolgen.",
  },
  {
    q: "Was passiert, wenn ich eine negative Bewertung erhalte?",
    a: "Stacc sendet sofort eine Benachrichtigung, sobald eine neue Bewertung erscheint, positiv oder negativ. Sie erhalten den Bewertungstext, die Sternebewertung und eine Antwortvorlage, damit Sie in unter einer Minute antworten können. In der Chiropraktik – einem vertrauensbasierten, manuellen Dienst – signalisiert eine schnelle, professionelle Antwort auf eine negative Bewertung jedem zukünftigen Patienten, dass Sie ihre Erfahrung ernst nehmen.",
  },
  {
    q: "Arbeiten Sie mit Chiropraktik-Praxen an mehreren Standorten?",
    a: "Ja. Jeder Standort erhält seine eigene Keyword-Strategie, seinen eigenen Inhaltskalender, GBP-Posting-Zeitplan und Ranking-Bericht – alles von einem Dashboard aus verwaltet. Beiträge zielen auf die spezifische Stadt, Dienste und lokale Suchabsichten des jeweiligen Standorts ab. Sie können die Leistung aller Standorte nebeneinander sehen.",
  },
  {
    q: "Wie unterscheidet sich Stacc von einer Chiropraktik-Marketingagentur?",
    a: "Eine Chiropraktik-Marketingagentur schreibt Ihre GBP-Beiträge manuell, berechnet 800–2.000 €/Monat und erfordert lange Verträge. Stacc automatisiert jeden Teil dieses Prozesses – Recherche, Schreiben, Planung, Bewertungsüberwachung, Rang-Tracking – für 49 €/Monat. Die Ausgabe ist dieselbe. Der Overhead und die Agenturmarge entfallen. Die meisten Chiropraktiker, die Stacc ausprobieren, haben vorher 15–40× mehr für weniger bezahlt.",
  },
  {
    q: "Hilft Stacc mit Chiropraktik-Blog-Inhalten oder nur GBP?",
    a: "Staccs Lokales-SEO-Modul verarbeitet GBP-Beiträge, Bewertungsüberwachung und Rang-Tracking. Wenn Sie monatlich Chiropraktik-Blog-Inhalte auf Ihrer Website veröffentlicht haben möchten – die Art, die für 'Wie viele chiropraktische Sitzungen braucht man' und 'Chiropraktik vs. Physiotherapie bei Rückenschmerzen' rankt – das ist das Blog-SEO-Modul für 99 €/Monat. Viele Praxen verwenden beide zusammen für vollständige organische Suchabdeckung.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc für Chiropraktiker",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "theStacc veröffentlicht täglich Beiträge im Google-Unternehmensprofil Ihrer Chiropraktik-Praxis, verwaltet Ihre Bewertungen und verfolgt Ihr Maps-Ranking – automatisch. Mehr Chiropraktik-Patienten aus Google für 49 €/Monat.",
      "offers": {
        "@type": "Offer",
        "price": "49",
        "priceCurrency": "EUR"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Startseite",
          "item": "https://thestacc.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Branchen",
          "item": "https://thestacc.com/de/branche/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "SEO für Chiropraktiker",
          "item": "https://thestacc.com/de/branche/chiropraktiker/"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  lang="de"
  title="Chiropraktiker SEO | Mehr Patienten über Google | theStacc"
  description="Stacc veröffentlicht täglich Beiträge im Google-Unternehmensprofil Ihrer Chiropraktik-Praxis, verwaltet Ihre Bewertungen und verfolgt Ihr Maps-Ranking – automatisch. Mehr Chiropraktik-Patienten über Google für 49 €/Monat."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Chiropraktiker SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Mehr Chiropraktik-Patienten über Google.<br />
            <span style="color:#4f39f6;">Ohne Agenturgebühren.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            720.000 Menschen suchen jeden Monat nach „Chiropraktiker in meiner Nähe". 74 % der Patienten recherchieren Chiropraktiker online, bevor sie anrufen. Stacc stellt sicher, dass Ihre Praxis zuerst erscheint – täglich Beiträge in Ihrem GBP veröffentlichen, Bewertungen verwalten und Ihr Maps-Ranking verfolgen. Alles automatisch.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/de/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              So funktioniert es
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Keine Verträge · Täglich Beiträge in Ihrem GBP
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '720K', num: 720, prefix: '', suffix: 'K', decimals: 0, from: 0, label: 'Monatliche Suchen nach „Chiropraktiker in meiner Nähe"' },
              { value: '74%',  num: 74,  prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Patienten recherchieren zuerst online' },
              { value: '4,7×', num: 4.7, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Durchschnittliche Maps-Ranking-Verbesserung' },
              { value: '100%', num: 100, prefix: '', suffix: '%', decimals: 0, from: 0, label: 'Bewertungen sofort erfasst' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Lokale Unternehmen, die mit Stacc ranken</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 aus 127 Bewertungen</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Wirbel Chiropraktik — Berlin', 'Rücken Zentrum München — München', 'Heil Chiropraktik — Hamburg', 'Körper Balance — Frankfurt', 'Bewegung Plus — Köln', 'Spine Wellness — Stuttgart', 'Chiropraktik Nord — Düsseldorf', 'Wirbel Chiropraktik — Berlin', 'Rücken Zentrum München — München', 'Heil Chiropraktik — Hamburg', 'Körper Balance — Frankfurt', 'Bewegung Plus — Köln', 'Spine Wellness — Stuttgart', 'Chiropraktik Nord — Düsseldorf'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ihre besten Patienten suchen gerade jetzt.<br />Sie buchen bei der Praxis nebenan.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            86 % der Patienten, die einen Chiropraktiker in der lokalen Suche finden, nehmen Kontakt auf. Die einzige Frage ist, wessen Praxis sie zuerst finden.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Google belohnt aktive Profile. Ihr chiropraktisches GBP postet einmal im Monat.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Der Maps-Algorithmus bevorzugt Chiropraktik-Praxen, die konsistent posten, auf Bewertungen reagieren und aktiv bleiben. Jede Woche, in der Ihr Profil dunkel ist, gewinnt ein konkurrierender Chiropraktiker, der täglich über Rückenschmerzen, Körperhaltung, Verletzungsrehabilitation und Wellness postet, Terrain, das Sie Monate zurückzugewinnen brauchen.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Eine unbeantwortete negative Bewertung kostet Sie neue Patiententermine.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">77 % der Patienten prüfen Online-Bewertungen, bevor sie einen Chiropraktiker wählen. Chiropraktik ist ein vertrauensbasierter, manueller Dienst – Patienten lassen Sie an ihrer Wirbelsäule arbeiten. Eine unbeantwortete negative Bewertung signalisiert, dass Sie das Patientenerlebnis nicht ernst nehmen. Ihre Sternebewertung ist der erste Eindruck jedes neuen Patienten, der Sie auf Maps findet.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Sie ranken für Ihren Praxisnamen. Nicht für „Chiropraktiker in meiner Nähe".</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Neue Patienten suchen nicht nach Ihrem Praxisnamen – sie suchen nach „Chiropraktiker in meiner Nähe", „Rückenschmerzen [Stadt]" und „Sportchiropraktiker [Stadt]". Wenn Sie nicht im Map Pack für diese Begriffe erscheinen, rufen diese Patienten an, wer auch immer dort erscheint – unabhängig von Ihren Jahren Erfahrung oder der Qualität Ihrer Behandlung.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc für Chiropraktiker tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jeder Hebel, der neue Chiropraktik-Patienten über Google bringt. Erledigt.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Das Maps-Ranking für Chiropraktik-Praxen erfordert konsistente GBP-Aktivität, schnelle Bewertungsantworten und keyword-zielgerichtete Inhalte – jeden Monat. Stacc erledigt alles automatisch.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'GBP-Beiträge Veröffentlichen',
              body: '30 Beiträge pro Monat zu Rückenschmerzen, Körperhaltungstipps, Wellness-Inhalten, Verletzungsrehabilitation, Sportchiropraktik und Unfallbehandlung. Automatisch nach Zeitplan veröffentlicht.',
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
            },
            {
              title: 'Chiropraktik-Keyword-Targeting',
              body: 'Dienst- und Stadtkombinationen für jeden behandelten Zustand – Rückenschmerzen, Nackenschmerzen, Sportverletzungen, Autounfall, Kopfschmerzen, Ischias. Auf Ihre Praxisspezialisierung und Ihren Standort abgestimmt.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Bewertungsüberwachung',
              body: 'Sofortige Bewertungsbenachrichtigungen. Sternebewertungs-Tracking. Antwortvorlagen, um in unter einer Minute zu antworten und das Patientenvertrauen zu schützen, das Empfehlungen im Gesundheitswesen antreibt.',
              icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
            },
            {
              title: 'Lokales Rang-Tracking',
              body: 'Rasterbasierte Maps-Ranking-Berichte für jedes Chiropraktik-Keyword in Ihrem Einzugsgebiet. Monatliches Tracking, damit Sie Ihren Fortschritt wachsen sehen.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Mehrere Standorte Verwalten',
              body: 'Mehrere Praxisstandorte? Jeder erhält seine eigene Keyword-Strategie, seinen eigenen Inhaltskalender und Ranking-Bericht von einem Dashboard aus. Alle Standorte nebeneinander verfolgen.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Zitations-Aufbau',
              body: 'Verzeichniseinträge bei Jameda, DoctoLib, Yelp und 50+ weiteren. Die Gesundheits-Autoritätssignale, die konkurrierende Praxen in Ihrem Markt übertreffen.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
