---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Wie verdiene ich Provisionen als Partner?", a: "Teilen Sie Ihren einzigartigen Partnerlink. Wenn jemand darauf klickt und sich bei theStacc anmeldet, erhalten Sie eine Provision auf jede Zahlung, die dieser Kunde tätigt — bis zu 3 Jahre lang. Bei Direktanmeldungen über Ihren Link erhalten Sie 25 %, wenn unser Vertriebsteam den Abschluss unterstützt 15 %." },
  { q: "Wann und wie werde ich bezahlt?", a: "Auszahlungen erfolgen monatlich, netto 30 Tage. Provisionen aus März werden am 15. April ausgezahlt. Mindestbetrag 50 €. Wir zahlen per PayPal, Banküberweisung oder Wise für internationale Partner." },
  { q: "Wie lange gilt das Cookie?", a: "90 Tage. Wenn jemand auf Ihren Link klickt und sich innerhalb von 90 Tagen anmeldet, erhalten Sie die Provision — auch wenn kein sofortiger Kauf erfolgt. Sie erhalten außerdem einen einzigartigen Gutscheincode, der ohne Cookies funktioniert." },
  { q: "Muss ich Kunde sein, um Partner zu werden?", a: "Nein. Jeder kann sich bewerben. Agenturen, Berater, Content-Ersteller und bestehende Kunden sind gleichermaßen willkommen." },
  { q: "Welche Materialien erhalte ich?", a: "Nach der Genehmigung erhalten Sie Zugang zum Partner-Dashboard mit Tracking-Links, Leistungsberichten, Marketingmaterialien und einem dedizierten Ansprechpartner für High-Volume-Partner." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Partner-Programm", "item": "https://thestacc.com/de/partner/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Partner-Programm — 25 % Provision für theStacc-Empfehlungen | theStacc"
  description="Werden Sie theStacc-Partner und verdienen Sie 25 % Provision auf Empfehlungen für bis zu 3 Jahre. Für Agenturen, Berater und Content-Ersteller im lokalen SEO-Bereich."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Partner-Programm · 25 % Provision</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            25 % Provision.<br />
            <span style="color:#4f39f6;">Bis zu 3 Jahre. Für jede Empfehlung.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Empfehlen Sie theStacc an lokale Unternehmen und Agenturen. Sie verdienen 25 % Provision auf jede Zahlung Ihrer Empfehlungen — für bis zu drei Jahre.
          </p>
          <div class="mt-8">
            <a href="/de/kontakt/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Partner werden
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Wie es funktioniert</h2>
        </div>
        <div class="mx-auto mt-12 max-w-4xl grid grid-cols-1 gap-6 sm:grid-cols-3">
          {[
            { step: '01', title: 'Bewerben', body: 'Melden Sie sich für das Partner-Programm an. Genehmigung innerhalb von 24 Stunden.' },
            { step: '02', title: 'Teilen', body: 'Teilen Sie Ihren einzigartigen Partnerlink oder Gutscheincode mit potenziellen Kunden.' },
            { step: '03', title: 'Verdienen', body: '25 % Provision auf jede Zahlung Ihrer Empfehlungen — für bis zu 3 Jahre.' },
          ].map(item => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] px-6 py-8">
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">{item.step}</span>
              <p class="mt-3 font-sans text-[1rem] font-semibold text-[#111827]">{item.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b]">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Häufige Fragen beantwortet.</h2>
          <div class="mt-10 divide-y divide-[#e7e5e4]">
            {faqs.map((f) => (
              <div class="py-5">
                <button class="faq-btn flex w-full items-start justify-between gap-4 text-left" aria-expanded="false">
                  <span class="font-sans text-[1rem] font-semibold text-[#111827]">{f.q}</span>
                  <span class="mt-0.5 flex-shrink-0">
                    <svg class="faq-icon-plus h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    <svg class="faq-icon-minus hidden h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                  </span>
                </button>
                <div class="faq-answer hidden pt-3">
                  <p class="font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      if (answer) answer.classList.toggle('hidden', expanded);
      btn.querySelector('.faq-icon-plus')?.classList.toggle('hidden', !expanded);
      btn.querySelector('.faq-icon-minus')?.classList.toggle('hidden', expanded);
    });
  });
</script>
