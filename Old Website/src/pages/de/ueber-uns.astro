---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';
import { SITE_URL, LOGO_URL, buildBreadcrumbs } from '../../utils/schema';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL, width: 512, height: 512 },
      description: 'theStacc entwickelt das Betriebssystem für organisches Wachstum — Blog-SEO, Lokales SEO und Social-Media-Distribution in einer automatisierten Engine.',
      founder: { '@id': `${SITE_URL}/de/ueber-uns/#founder` },
      sameAs: [
        'https://www.linkedin.com/company/thestacc',
        'https://x.com/thestacc',
      ],
      knowsAbout: ['SEO-Automatisierung', 'KI-Inhaltserstellung', 'Lokales SEO', 'Google Business Profile Management'],
      inLanguage: 'de',
    },
    {
      '@type': 'Person',
      '@id': `${SITE_URL}/de/ueber-uns/#founder`,
      name: 'Siddharth Gangal',
      url: `${SITE_URL}/de/ueber-uns/`,
      jobTitle: 'Gründer',
      worksFor: { '@id': `${SITE_URL}/#organization` },
      description: 'Gründer von theStacc und Arka360. Absolvent des IIT Mandi. Entwickler der automatisierten Content-Engine für organisches Wachstum.',
      knowsAbout: ['SEO', 'KI', 'SaaS', 'Content-Marketing'],
    },
    {
      '@type': 'AboutPage',
      '@id': `${SITE_URL}/de/ueber-uns/`,
      name: 'Über theStacc',
      url: `${SITE_URL}/de/ueber-uns/`,
      isPartOf: { '@id': `${SITE_URL}/#website` },
      mainEntity: { '@id': `${SITE_URL}/#organization` },
      inLanguage: 'de',
    },
    buildBreadcrumbs(`${SITE_URL}/de/ueber-uns/`, [
      { name: 'Startseite', url: `${SITE_URL}/de/` },
      { name: 'Über uns', url: `${SITE_URL}/de/ueber-uns/` },
    ]),
  ],
};

const values = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    name: 'Ausführung vor Analyse',
    statement: 'Dashboards, die Ihnen sagen, was zu tun ist, sind nicht dasselbe wie Systeme, die es tun.',
    proof: 'Jeder Plan bei theStacc endet mit einer veröffentlichten Seite, nicht mit einer Empfehlung. Ihre Inhalte werden veröffentlicht, auch wenn Sie sich nicht einloggen.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    name: 'Qualität die sich aufbaut',
    statement: 'Wir veröffentlichen keinen Füllinhalt. Jeder Artikel ist darauf ausgelegt, zu ranken, Traffic zu generieren und langfristig zu bestehen.',
    proof: 'Keyword-Recherche, interne Verlinkung, SEO-Struktur und Lesbarkeit — automatisch auf jeden Artikel angewendet. Kein nachträglicher Gedanke.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    name: 'Transparenz vor Übertreibung',
    statement: 'Wir konkurrieren mit mehreren Tools, über die wir schreiben. Das sagen wir immer offen.',
    proof: 'Jede Rezensions- und Vergleichsseite auf theStacc enthält eine klare redaktionelle Offenlegung. Wir zeigen echte Kennzahlen, keine Vanity-Metriken.',
  },
];

const icpCards = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M3 9h6"/><path d="M3 15h6"/><path d="M15 9h3"/><path d="M15 15h3"/></svg>`,
    title: 'Kleine und mittlere Unternehmen',
    body: 'Sie benötigen 30 Artikel im Monat, um mit Unternehmensbudgets zu konkurrieren — aber kein 10-köpfiges Content-Team. theStacc liefert Unternehmensergebnisse ohne den Personalaufwand.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Lokale Unternehmen und Dienstleister',
    body: 'Zahnärzte, Handwerker, Anwaltskanzleien, Agenturen. Unternehmen, die gewinnen, indem sie lokal am sichtbarsten sind. Wir automatisieren GBP-Beiträge, lokale SEO-Inhalte und Bewertungsantworten.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: 'Marketing-Teams unter Druck',
    body: 'Sie haben eine Content-Strategie, aber nicht genug Zeit zur Umsetzung. theStacc übernimmt die unteren 80 % der Content-Produktion, damit sich Ihr Team auf die oberen 20 % konzentrieren kann.',
  },
];
---

<BaseLayout
  title="Über theStacc | Die Geschichte von Siddharth Gangal und die Mission"
  description="theStacc wurde von Siddharth Gangal (IIT Mandi, Arka360) gegründet mit dem Ziel, organisches Wachstum zu einem System zu machen, nicht zu einem Sprint."
  lang="de"
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-20 text-center">

        <p class="font-mono text-[11px] font-bold uppercase tracking-[0.16em] text-[#4f39f6]">Über theStacc</p>
        <h1 class="mx-auto mt-4 max-w-[700px] font-sans text-[32px] font-bold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[48px]">
          Entwickelt, um die Routinearbeit zu beseitigen,<br class="hidden md:block" /> die Wachstum bremst.
        </h1>
        <p class="mx-auto mt-5 max-w-[520px] font-sans text-[16px] leading-[1.7] text-[#94a3b8]">
          Die meisten Unternehmen haben die richtige SEO-Strategie. Sie haben nur nicht die Zeit, das Team oder das Budget, sie konsequent umzusetzen. theStacc ist das System, das das für sie erledigt.
        </p>

        <!-- CTAs -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/de/demo/"
            class="inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-7 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
          >
            Demo buchen
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/de/module/blog-seo/"
            class="inline-flex h-[46px] items-center gap-2 rounded-xl border border-[rgba(255,255,255,0.12)] px-7 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-[#94a3b8] transition-colors hover:border-[rgba(255,255,255,0.25)] hover:text-[#292524]"
          >
            So funktioniert es
          </a>
        </div>

        <!-- Trust pills -->
        <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
          {[
            '30 Blog-Artikel/Monat',
            '30 GBP-Beiträge/Monat',
            'Social Media inklusive',
            'DSGVO-konform',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>

      </div>
    </section>

    <!-- ░░ BY THE NUMBERS ░░ -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mb-10 text-center">
          <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">In Zahlen</p>
          <h2 class="mt-2 font-sans text-[26px] font-bold tracking-[-0.02em] text-[#111827] md:text-[32px]">Was theStacc jeden Monat liefert</h2>
        </div>

        <!-- Bento grid -->
        <div class="grid grid-cols-2 gap-4 md:grid-cols-4">

          <div class="col-span-2 overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-8">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Blog-SEO-Modul</p>
            <p class="mt-2 font-sans text-[60px] font-bold leading-none tracking-[-0.04em] text-[#4f39f6]"
               data-count-up data-target="30" data-from="0" data-prefix="" data-suffix="" data-decimals="0">30</p>
            <p class="mt-2 font-sans text-[17px] font-semibold text-[#292524]">SEO-Blog-Artikel, jeden Monat auf Ihrer Website veröffentlicht</p>
            <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b]">Mit Keyword-Recherche, interner Verlinkung und optimierter Struktur zum Ranken — automatisch auf Ihrer Domain veröffentlicht.</p>
          </div>

          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Lokales SEO</p>
            <p class="mt-2 font-sans text-[48px] font-bold leading-none tracking-[-0.04em] text-[#292524]"
               data-count-up data-target="30" data-from="0" data-prefix="" data-suffix="" data-decimals="0">30</p>
            <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">GBP-Beiträge pro Monat</p>
            <p class="mt-1 font-sans text-[12px] leading-[1.6] text-[#79716b]">Inhalte für Google Business Profile, die Ihre lokale Präsenz aktiv halten.</p>
          </div>

          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Abdeckung</p>
            <p class="mt-2 font-sans text-[48px] font-bold leading-none tracking-[-0.04em] text-[#292524]"
               data-count-up data-target="70" data-from="0" data-prefix="" data-suffix="+" data-decimals="0">70+</p>
            <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">Branchen bedient</p>
            <p class="mt-1 font-sans text-[12px] leading-[1.6] text-[#79716b]">Von SaaS bis Solar und Zahnarzt. Eine Engine, jede Nische.</p>
          </div>

          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Einstieg</p>
            <p class="mt-2 font-sans text-[48px] font-bold leading-none tracking-[-0.04em] text-[#4f39f6]"
               data-count-up data-target="1" data-from="0" data-prefix="€" data-suffix="" data-decimals="0">€1</p>
            <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">Für Ihre ersten 30 Tage</p>
            <p class="mt-1 font-sans text-[12px] leading-[1.6] text-[#79716b]">Kein Kreditkarten-Engagement. Kündigen Sie vor Tag 30, zahlen Sie nichts weiter.</p>
          </div>

          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#79716b]">Integrierte Module</p>
            <p class="mt-2 font-sans text-[48px] font-bold leading-none tracking-[-0.04em] text-[#292524]"
               data-count-up data-target="3" data-from="0" data-prefix="" data-suffix="" data-decimals="0">3</p>
            <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]">Blog · Lokal · Social</p>
            <p class="mt-1 font-sans text-[12px] leading-[1.6] text-[#79716b]">Ein Abonnement, alle Kanäle. Alles verbunden.</p>
          </div>

          <div class="col-span-2 overflow-hidden rounded-2xl border border-[#4f39f6] bg-[#fafaf9] p-8" style="background:linear-gradient(135deg,#f5f3ff 0%,#fafaf9 100%);">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Social-Media-Modul</p>
            <p class="mt-2 font-sans text-[17px] font-semibold text-[#292524]">Social-Media-Inhalte für jede Plattform — verfasst, geplant und auf LinkedIn, Facebook, Instagram und mehr veröffentlicht. Jeden Monat. Automatisch.</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {['LinkedIn', 'Facebook', 'Instagram', 'X / Twitter'].map(p => (
                <span class="rounded-full border border-[#c4b5fd] bg-white px-3 py-1 font-mono text-[11px] font-semibold text-[#4f39f6]">{p}</span>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ░░ FOUNDER STORY ░░ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.6fr] lg:items-start">

          <!-- Left: Founder identity -->
          <div class="flex flex-col items-center text-center">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Gründer</p>
            <div class="mt-6 overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white p-6">
              <img
                src="/images/siddharth-gangal.webp"
                alt="Siddharth Gangal, Gründer von theStacc"
                width="300"
                height="300"
                class="mx-auto h-[160px] w-[160px] rounded-full object-cover ring-4 ring-[#f5f3ff]"
                loading="lazy"
              />
              <h3 class="mt-5 font-sans text-[22px] font-bold text-[#111827]">Siddharth Gangal</h3>
              <p class="mt-1 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">Gründer, theStacc</p>
              <div class="mt-4 flex flex-wrap justify-center gap-2">
                <span class="inline-flex items-center rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1 font-mono text-[11px] text-[#57534e]">IIT Mandi</span>
                <span class="inline-flex items-center rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1 font-mono text-[11px] text-[#57534e]">Gründer, Arka360</span>
                <span class="inline-flex items-center rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1 font-mono text-[11px] text-[#57534e]">Solar Labs</span>
              </div>
              <div class="mt-5 flex justify-center gap-3">
                <a href="https://www.linkedin.com/in/siddharth-gangal" target="_blank" rel="noopener noreferrer"
                  class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white transition-colors hover:border-[#c4b5fd]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="#0077b5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <a href="https://x.com/thestacc" target="_blank" rel="noopener noreferrer"
                  class="flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] bg-white transition-colors hover:border-[#c4b5fd]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#111827"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Right: Narrative -->
          <div class="flex flex-col justify-start">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Die Geschichte</p>
            <h2 class="mt-3 font-sans text-[28px] font-bold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[34px]">
              Warum ich theStacc gebaut habe
            </h2>

            <div class="mt-6 space-y-4">
              <p class="font-sans text-[16px] leading-[1.75] text-[#57534e]">
                Bei Arka360 leitete ich ein Softwareunternehmen für Solarenergie. Wir hatten ein großartiges Produkt, eine solide Kundenbindung und ein Team, das die Branche besser kannte als fast jeder andere. Aber wir waren im Internet unsichtbar. Nicht weil wir nicht wussten, was zu tun ist. Das wussten wir. Wir hatten eine Content-Strategie, Keyword-Ziele, einen Veröffentlichungskalender. Was wir nicht hatten, waren genug Stunden, um sie umzusetzen.
              </p>
              <p class="font-sans text-[16px] leading-[1.75] text-[#57534e]">
                Wir verbrachten zwischen 30 und 40 % unserer Marketing-Zeit mit Content-Produktion: Schreiben, Bearbeiten, Formatieren, Veröffentlichen, Aktualisieren. Und wiederholen. Die Arbeit war wichtig, aber mechanisch. Die Art von Arbeit, die im Autopiloten laufen sollte.
              </p>
              <p class="font-sans text-[16px] leading-[1.75] text-[#57534e]">
                Ich prüfte alle verfügbaren Tools. Sie alle hatten dieselbe Antwort: Hier sind Daten, hier sind Empfehlungen, hier ist ein Kalender. Keines veröffentlichte wirklich etwas. Keines eliminierte den manuellen Schritt.
              </p>
            </div>

            <!-- Pull quote -->
            <div class="mt-6 rounded-xl border-l-[3px] border-[#4f39f6] bg-white px-5 py-4">
              <p class="font-sans text-[17px] leading-[1.65] font-medium text-[#111827]">
                "Die meisten Unternehmen scheitern nicht an Inhalten wegen fehlender Strategie. Sie scheitern, weil die Umsetzung langsam, manuell und fragmentiert ist. Das wollte ich lösen — für jedes Unternehmen, nicht nur für solche mit großen Teams."
              </p>
              <p class="mt-3 font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#79716b]">— Siddharth Gangal, Gründer</p>
            </div>

            <p class="mt-5 font-sans text-[16px] leading-[1.75] text-[#57534e]">
              theStacc ist das System, das ich bei Arka360 gerne gehabt hätte. Es schlägt keine Inhalte vor. Es schreibt, optimiert und veröffentlicht sie. Jeden Monat. Ohne dass sich jemand einloggen muss.
            </p>

            <div class="mt-7">
              <a
                href="/de/demo/"
                class="inline-flex h-[44px] items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-mono text-[12px] font-bold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#615fff]"
              >
                Demo buchen →
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ░░ MISSION / VISION ░░ -->
    <section class="relative overflow-hidden border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.03) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 50%,black 40%,transparent 90%);"></div>
      <div class="container-x relative z-10 py-20">
        <div class="grid grid-cols-1 gap-12 md:grid-cols-2 md:items-center">
          <div>
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Unsere Mission</p>
            <h2 class="mt-3 font-sans text-[28px] font-bold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[34px]">
              Organisches Wachstum zu einem System machen, nicht zu einem Sprint.
            </h2>
            <p class="mt-4 font-sans text-[15px] leading-[1.7] text-[#57534e]">
              Wir glauben, dass konsistente, hochwertige Inhalte der zuverlässigste Motor für organisches Wachstum sind. Wir glauben auch, dass die meisten Unternehmen das nicht manuell aufrechterhalten können. Unsere Mission ist es, diese Lücke zu schließen — indem wir zugänglich machen, was früher Agenturen oder große Teams erforderte.
            </p>
          </div>
          <div class="rounded-2xl border p-8" style="background:rgba(15,23,42,0.04);border-color:rgba(255,255,255,0.08);">
            <p class="font-mono text-[11px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Unsere Vision</p>
            <p class="mt-4 font-sans text-[22px] font-bold leading-[1.3] text-[#292524]">
              Das Betriebssystem für organisches Wachstum.
            </p>
            <p class="mt-3 font-sans text-[14px] leading-[1.7] text-[#57534e]">
