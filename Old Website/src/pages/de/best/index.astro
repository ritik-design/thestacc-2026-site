---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';
import { getCollection } from 'astro:content';

const enPosts = await getCollection('best');
const langPosts = await getCollection('best_de');
const langBySlug = new Map(langPosts.map(p => [p.data.slug, p]));
const merged = enPosts.filter(p => langBySlug.has(p.data.slug)).map(p => langBySlug.get(p.data.slug)!);
const sortedPosts = merged.sort((a, b) => {
  const dateA = new Date(a.data.date);
  const dateB = new Date(b.data.date);
  if (dateB.getTime() !== dateA.getTime()) return dateB.getTime() - dateA.getTime();
  return a.data.title.localeCompare(b.data.title);
});
const visiblePosts = sortedPosts.filter(p => p.data.image);

function readTime(body: string): number {
  const words = (body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const methodologyItems = [
  { icon: '🔬', label: 'Tools getestet', detail: 'Hands-on + öffentliche Daten' },
  { icon: '💰', label: 'Preise verifiziert', detail: 'Offizielle Seiten, April 2026' },
  { icon: '⚡', label: 'ROI im Fokus', detail: 'Funktionen pro ausgegebenem Dollar' },
  { icon: '🚫', label: 'Gesponserte Empfehlungen', detail: 'Keine. Null. Niemals.' },
];

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Startseite', item: 'https://thestacc.com/de/' },
        { '@type': 'ListItem', position: 2, name: 'Beste Tools', item: 'https://thestacc.com/de/best/' },
      ],
    },
  ],
};
---

<BaseLayout
  title="Beste SEO-Tools & Software 2026 verglichen | theStacc"
  description="Wir haben die besten SEO-Tools jeder Kategorie getestet und bewertet. Automatisierung, Autoblogging, lokales SEO und branchenspezifische Empfehlungen. Echte Preise. Kein Füllstoff."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>

  <Header />
  <main class="flex-1">

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-12 pb-12">

        <nav aria-label="Brotkrümelnavigation" class="mb-3">
          <ol class="flex items-center gap-1.5 font-mono text-[11px] text-[#a8a29e]">
            <li><a href="/de/" class="hover:text-[#57534e] transition-colors">Startseite</a></li>
            <li class="before:content-['/'] before:mx-1.5 text-[#79716b]">Beste Tools</li>
          </ol>
        </nav>

        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Beste Listen</span>
          <span class="h-3 w-px bg-[#e7e5e4]"></span>
          <span class="font-mono text-[10px] text-[#79716b]">{visiblePosts.length} Guides</span>
        </div>

        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px]">
          Beste SEO-Tools &amp; Software
        </h1>
        <p class="mt-3 max-w-[560px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Wir haben die besten SEO-Tools jeder Kategorie getestet und bewertet. Automatisierung, Autoblogging, lokales SEO und branchenspezifische Empfehlungen. Echte Preise, ehrliche Vor- und Nachteile, kein Füllstoff.
        </p>

        <div class="mt-6 flex flex-wrap gap-2">
          {[
            `${visiblePosts.length} getestete Guides`,
            'Aktualisiert April 2026',
            'Preise verifiziert',
            'Keine gesponserten Empfehlungen',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- METHODENLEISTE -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x">
        <div class="flex items-center gap-6 overflow-x-auto py-4" style="-ms-overflow-style:none;scrollbar-width:none;">
          {methodologyItems.map(item => (
            <div class="flex shrink-0 items-center gap-2.5">
              <span class="text-[16px]">{item.icon}</span>
              <div>
                <p class="font-mono text-[11px] font-bold text-[#292524]">{item.label}</p>
                <p class="font-mono text-[10px] text-[#79716b]">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- KARTEN-GRID -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-6xl">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="font-sans text-[20px] font-bold text-[#111827]">Alle Listen</h2>
          <a href="/best/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6] transition-opacity hover:opacity-70">
            Englische Version →
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {visiblePosts.map((post) => (
            <a href={`/de/best/${post.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
              <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
              <div class="flex flex-1 flex-col p-6">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Beste Liste</span>
                <h2 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{post.data.title}</h2>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                  <span class="font-mono text-[10px] text-[#79716b]">{post.data.date} · {readTime(post.body ?? '')} Min.</span>
                  <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FOOTER CTA -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#818cf8]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Recherche stoppen. Ranken starten.
        </h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          30 SEO-Artikel auf Ihrer Website jeden Monat. Automatisch. Keine Autoren, kein Workflow, kein Warten.
        </p>
        <a
          href="/de/demo/"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Für $1 starten
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">$1 für 30 Tage · Jederzeit kündbar</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
