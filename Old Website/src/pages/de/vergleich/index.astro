---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('compare');
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="theStacc im Vergleich — Tool-Vergleiche | theStacc"
  description="Direkte Vergleiche zwischen theStacc und anderen SEO-Tools. Funktionen, Preise und welches Tool für Ihr Unternehmen besser geeignet ist."
  lang="de"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Vergleiche</span>
          <h1 class="mt-3 font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#111827] md:text-[3rem]">
            theStacc im Vergleich.
          </h1>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Direkte Vergleiche von theStacc mit anderen SEO-Tools — Funktionen, Preise und welches Tool für Ihre Anforderungen besser geeignet ist.
          </p>
          <div class="mt-8">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Stacc testen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        {posts.length > 0 ? (
          <div class="mx-auto mt-16 max-w-4xl grid gap-6 sm:grid-cols-2">
            {posts.map(post => (
              <a href={`/de/vergleich/${post.data.slug}/`} class="group flex flex-col rounded-xl border border-[#e7e5e4] bg-white p-6 transition-shadow hover:shadow-md">
                <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.1em] text-[#4f39f6]">Vergleich</span>
                <h2 class="mt-2 font-sans text-[17px] font-semibold text-[#292524] group-hover:text-[#4f39f6] transition-colors">{post.data.title}</h2>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#57534e] flex-1">{post.data.description}</p>
                <span class="mt-4 font-mono text-[11px] text-[#79716b]">{post.data.date}</span>
              </a>
            ))}
          </div>
        ) : (
          <div class="mx-auto mt-16 max-w-2xl">
            <p class="font-sans text-[0.95rem] text-[#79716b]">Vergleichsartikel werden in Kürze veröffentlicht. Besuchen Sie in der Zwischenzeit die <a href="/compare/" class="text-[#4f39f6] hover:underline">englischen Vergleiche</a>.</p>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
