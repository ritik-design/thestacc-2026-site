---
import LegalLayout from '../../layouts/LegalLayout.astro';

const toc = [
  { id: 'acceptance',   label: '1. Annahme der Bedingungen' },
  { id: 'service',      label: '2. Leistungsbeschreibung' },
  { id: 'accounts',     label: '3. Benutzerkonten' },
  { id: 'payment',      label: '4. Zahlungsbedingungen' },
  { id: 'acceptable',   label: '5. Zulässige Nutzung' },
  { id: 'ip',           label: '6. Geistiges Eigentum' },
  { id: 'liability',    label: '7. Haftungsbeschränkung' },
  { id: 'termination',  label: '8. Kündigung' },
  { id: 'contact',      label: '9. Kontakt' },
];
---

<LegalLayout
  title="Allgemeine Geschäftsbedingungen"
  description="Die Nutzungsbedingungen für theStacc-Dienste. Lesen Sie diese vor der Nutzung von theStacc, um Ihre Rechte und Pflichten zu verstehen."
  lastUpdated="April 2026"
  badge="Rechtliches · AGB"
  tocItems={toc}
  currentPath="/de/agb/"
>
  <Fragment slot="head">
  </Fragment>

  <div class="flex flex-col gap-10">

    <section id="acceptance" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">1</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Annahme der Bedingungen</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Durch den Zugriff auf oder die Nutzung der Dienste von theStacc stimmen Sie zu, an diese Allgemeinen Geschäftsbedingungen gebunden zu sein. Wenn Sie diesen Bedingungen nicht zustimmen, nutzen Sie unsere Dienste bitte nicht.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="service" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">2</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Leistungsbeschreibung</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          theStacc bietet SEO-Automatisierungstools an, darunter Content-Erstellung, Keyword-Recherche, lokale SEO-Optimierung und Analysen. Unsere Dienste helfen Unternehmen, ihre Sichtbarkeit in Suchmaschinen zu verbessern.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="accounts" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">3</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Benutzerkonten</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Sie sind für die Vertraulichkeit Ihrer Kontoanmeldedaten und für alle Aktivitäten verantwortlich, die unter Ihrem Konto stattfinden. Sie stimmen zu, uns unverzüglich über jede unbefugte Nutzung zu informieren.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="payment" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">4</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Zahlungsbedingungen</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Abonnementgebühren werden monatlich oder jährlich im Voraus berechnet. Alle Gebühren sind nicht erstattungsfähig, sofern in diesen Bedingungen nicht ausdrücklich anders angegeben. Wir behalten uns das Recht vor, unsere Preise mit einer Frist von 30 Tagen zu ändern.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="acceptable" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">5</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Zulässige Nutzung</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Sie stimmen zu, unsere Dienste nicht für rechtswidrige Zwecke oder auf eine Weise zu nutzen, die unsere Dienste beschädigen, deaktivieren oder beeinträchtigen könnte. Sie dürfen unsere Tools nicht verwenden, um irreführende, schädliche oder Spam-Inhalte zu erstellen.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="ip" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">6</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Geistiges Eigentum</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Inhalte, die Sie mit unseren Tools erstellen, bleiben Ihr Eigentum. Sie gewähren uns jedoch eine Lizenz zur Verwendung anonymisierter Daten zur Verbesserung unserer Dienste. Unsere Plattform, Marke und Technologie bleiben unser ausschließliches Eigentum.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="liability" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">7</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Haftungsbeschränkung</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          theStacc haftet nicht für indirekte, zufällige, besondere oder Folgeschäden, die aus Ihrer Nutzung unserer Dienste entstehen. Unsere Gesamthaftung übersteigt nicht den Betrag, den Sie in den zwölf Monaten vor dem Anspruch gezahlt haben.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="termination" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">8</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Kündigung</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Jede Partei kann diese Vereinbarung jederzeit kündigen. Nach der Kündigung erlischt Ihr Recht zur Nutzung unserer Dienste sofort. Wir können Ihre Daten aufbewahren, soweit dies gesetzlich vorgeschrieben ist oder für legitime Geschäftszwecke erforderlich ist.
        </p>
      </div>
    </section>

    <div class="border-t border-[#e7e5e4]"></div>

    <section id="contact" class="scroll-mt-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] font-mono text-[11px] font-bold text-[#4f39f6]">9</span>
        <h2 class="font-sans text-[18px] font-semibold text-[#111827]">Kontakt</h2>
      </div>
      <div class="pl-9">
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
          Bei Fragen zu diesen Bedingungen kontaktieren Sie uns unter <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
        </p>
        <div class="mt-4 font-sans text-[15px] leading-[1.75] text-[#57534e]">
          <p><strong class="font-semibold text-[#111827]">Rechtlicher Name:</strong> SOLARTREK VENTURES LLP</p>
          <p><strong class="font-semibold text-[#111827]">Adresse:</strong> Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India</p>
        </div>
        <p class="font-sans text-[15px] leading-[1.75] text-[#57534e]">
        </p>
      </div>
    </section>

  </div>
</LegalLayout>
