---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie viele Standorte kann ich gleichzeitig verwalten?",
    a: "Es gibt keine praktische Grenze. Stacc ist für Portfolios im Enterprise-Maßstab gebaut — Kunden verwalten 500+ Standorte von einem einzigen Konto aus. Massenoperationen funktionieren gleich, ob Sie 10 oder 500 Standorte haben.",
  },
  {
    q: "Was kann ich standortübergreifend in großen Mengen aktualisieren?",
    a: "Öffnungszeiten, Feiertagszeiten, Telefonnummern, Adressen, Website-URLs, Unternehmensbeschreibungen und Kategorien. Für Google Business Profile speziell: Sie können auch Attribute, Service-Menüs und Titelbild-Fotos über alle Standorte gleichzeitig aktualisieren.",
  },
  {
    q: "Wie lange dauert das Hinzufügen eines neuen Standorts?",
    a: "Ungefähr 2 Minuten. Sie geben die Kerndaten des Unternehmens einmal ein, verbinden das GBP-Listing und andere Plattformen, und Stacc verteilt die Einrichtung automatisch über Ihr Citations-Netzwerk. Es gibt keine manuelle Eingabe Verzeichnis für Verzeichnis.",
  },
  {
    q: "Kann ich unterschiedliche Aktualisierungen für verschiedene Teilmengen von Standorten vornehmen?",
    a: "Ja. Sie können Standorte nach Region, Marke, Franchisenehmer oder beliebigem benutzerdefinierten Tag gruppieren. Massenaktualisierungen können auf das gesamte Portfolio, eine bestimmte Gruppe oder ausgewählte Einzelstandorte angewendet werden. Sie haben vollständige Kontrolle über den Umfang.",
  },
  {
    q: "Was passiert, wenn ein Standort eine eindeutige Adresse oder Telefonnummer hat?",
    a: "Massenaktualisierungen verarbeiten gemeinsame Felder. Für standortspezifische Felder wie Adresse oder Direkttelefonnummer pflegt Stacc die einzigartigen Daten jedes Standorts und überschreibt sie nicht mit einer Massenaktualisierung, es sei denn, Sie wählen dies ausdrücklich. Gemeinsame Daten werden in großen Mengen aktualisiert; einzigartige Daten bleiben einzigartig.",
  },
  {
    q: "Kann ich einen CSV-Import verwenden, um Standorte in großen Mengen hinzuzufügen oder zu aktualisieren?",
    a: "Ja. Stacc unterstützt den CSV-Import zur Massenerstellung und -aktualisierung von Standorten. Laden Sie eine Tabellenkalkulation mit Ihren Standortdaten hoch, und Stacc ordnet die Felder automatisch zu. Nützlich für die anfängliche Einrichtung großer Portfolios oder die regelmäßige Datensynchronisation aus Ihren eigenen Systemen.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Massenstandort-Verwaltung",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Aktualisieren Sie Hunderte von Standorten gleichzeitig. Ändern Sie Öffnungszeiten, Adressen, Beschreibungen und Kategorien in Ihrem gesamten Portfolio in Minuten — nicht in Tagen.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/de/" },
        { "@type": "ListItem", "position": 2, "name": "Funktionen", "item": "https://thestacc.com/de/funktionen/" },
        { "@type": "ListItem", "position": 3, "name": "Massenstandort-Verwaltung", "item": "https://thestacc.com/de/funktionen/massenstandort-verwaltung/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Massenstandort-Verwaltung — 500+ Standorte in Minuten aktualisieren | theStacc"
  description="Hören Sie auf, Standorte einzeln zu aktualisieren. Die Massenstandort-Verwaltung von theStacc ermöglicht es Ihnen, Öffnungszeiten, Adressen und Geschäftsdaten für Ihr gesamtes Portfolio mit einer einzigen Aktion zu ändern."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Massenstandort-Verwaltung · Lokales SEO Modul</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            500 Standorte in<br />
            <span style="color:#4f39f6;">2 Minuten. Nicht 2 Tagen.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Die Massenstandort-Verwaltung von Stacc ermöglicht es Ihnen, Öffnungszeiten, Adressen, Unternehmensbeschreibungen und GBP-Daten im gesamten Portfolio mit einer einzigen Aktion zu ändern. Eine Aktualisierung. Jeder Standort. Erledigt.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Massenverwaltung kostenlos testen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
            {['500+ Standorte, eine Aktion', 'CSV-Import & -Export', 'GBP-Massensync inklusive', '14-tägige kostenlose Testversion'].map(c => (
              <span class="flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-[#79716b]">
                <span class="h-1 w-1 rounded-full bg-[#4f39f6]"></span>{c}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Standort-für-Standort-Aktualisierungen<br />skalieren nicht über fünf Standorte hinaus.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Feiertagszeiten. Eine neue Telefonnummer. Eine aktualisierte Adresse. Eine Kategorieänderung. Einfache Aktualisierungen, die zwei Minuten dauern sollten, dauern stattdessen zwei Tage, wenn Sie jedes Standortprofil einzeln öffnen, die Änderung vornehmen, sie überprüfen und dann zum nächsten übergehen müssen. Und während Sie bei Standort 23 sind, wurden die Öffnungszeiten von Standort 4 durch einen Nutzervorschlag zurückgesetzt, der ohne Überprüfung durchgerutscht ist. Multi-Standort-Management ohne Massentools ist kein Management — es ist Schadensbegrenzung.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Jede Änderung dauert Stunden.', body: 'Einloggen. Navigieren. Standort finden. Änderung vornehmen. Überprüfen. Ausloggen. 50 Mal wiederholen. Eine einfache Öffnungszeitenaktualisierung für ein 50-Standort-Portfolio ist ein Halbtagsprojekt, das 30 Sekunden dauern sollte.' },
            { icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636', title: 'Inkonsistenzen schaden dem Ranking.', body: 'Wenn einige Standorte die aktualisierte Telefonnummer haben und andere noch die alte anzeigen, haben Sie ein Citations-Inkonsistenzproblem. Google behandelt NAP-Inkonsistenz als Qualitätssignal — und bestraft lokale Rankings entsprechend.' },
            { icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', title: 'Neue Standorte dauern zu lange.', body: 'Die Einrichtung eines neuen Standorts bedeutet, dieselben Daten manuell in 40+ Verzeichnissen einzugeben. Die meisten Teams geben nach den ersten 10 auf und lassen den Rest leer — sie lassen Ranking-Signale vom ersten Tag an liegen.' },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Standorte auswählen. Änderung vornehmen.<br />Jedes Profil wird sofort aktualisiert.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Der Masseneditor von Stacc zentralisiert alle Standortdaten an einem Ort. Eine Änderung verbreitet sich sofort auf jeden ausgewählten Standort über jede verbundene Plattform.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Alle Standorte zum Portfolio hinzufügen', body: 'Per CSV importieren oder Standorte einzeln hinzufügen. Jedes GBP-Listing und andere Plattformen verbinden. Ihr gesamtes Portfolio ist von Tag eins aus einem Dashboard sichtbar und bearbeitbar.' },
            { n: '02', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Standorte auswählen und Felder bearbeiten', body: 'Alle Standorte oder eine bestimmte Gruppe auswählen. Beliebiges Feld im Masseneditor bearbeiten — Öffnungszeiten, Kontaktdaten, Beschreibungen, Kategorien, Attribute. Ihre Änderung gilt für jeden ausgewählten Standort gleichzeitig.' },
            { n: '03', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Änderungen verbreiten sich auf allen Plattformen', body: 'Stacc überträgt die Aktualisierung an GBP, Citations-Verzeichnisse und alle anderen verbundenen Plattformen gleichzeitig. Jeder Standort zeigt konsistente, genaue Informationen innerhalb von Minuten — nicht Tagen.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alles inklusive</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alle Massenverwaltungsfunktionen.<br />Für Portfolios jeder Größe gebaut.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Massenfeld-Bearbeitung', body: 'Beliebiges Feld aktualisieren — Öffnungszeiten, Telefon, Adresse, Beschreibung, Kategorien, Attribute — für jede Auswahl von Standorten mit einer einzigen Aktion. Änderungen werden sofort übernommen.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Massen-Feiertagszeiten', body: 'Feiertagszeiten für Ihr gesamtes Portfolio auf einmal festlegen. Eine Aktion aktualisiert die Sonderzeiten jedes Standorts vor dem Feiertag — keine ausgelassenen Standorte, keine veralteten Öffnungs-/Schließzeiten.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'CSV-Import und -Export', body: 'Eine Tabellenkalkulation hochladen, um Hunderte von Standorten auf einmal zu erstellen oder zu aktualisieren. Jederzeit das gesamte Portfolio als CSV exportieren für Audits, Sicherungen oder Synchronisation mit eigenen Systemen.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Standortgruppen und Tags', body: 'Standorte nach Region, Marke, Franchisenehmer oder benutzerdefiniertem Tag organisieren. Massenaktualisierungen auf bestimmte Gruppen anwenden — nicht das gesamte Portfolio — wenn Änderungen regionsspezifisch sind.' },
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Automatische GBP-Synchronisation', body: 'Änderungen werden sofort und automatisch an Google Business Profile übertragen. Keine manuellen GBP-Anmeldungen, keine standortweisen Google-Dashboard-Besuche. Ihre GBP-Daten bleiben im großen Maßstab aktuell.' },
            { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Datenkonsistenz-Monitoring', body: 'Stacc überwacht NAP-Inkonsistenzen, die durch nutzervorgeschlagene Änderungen oder Verzeichnisfehler entstehen. Abweichungen werden markiert und können in großen Mengen korrigiert werden, bevor sie Ihre Rankings beeinflussen.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">In Zahlen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was Massenverwaltung für<br />Standort-Teams bewirkt.
          </h2>
        </div>
        <div class="mx-auto mt-14 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { from: 0, to: 500, suffix: '+', label: 'Standorte von einer Person verwaltet', sub: 'Kein zusätzliches Personal erforderlich' },
            { from: 0, to: 95, suffix: '%', label: 'Weniger Zeit pro Portfolio-Aktualisierung', sub: 'Massenbearbeitung vs. Standort für Standort' },
            { from: 0, to: 2, suffix: ' Min', label: 'Für die Einrichtung eines neuen Standorts', sub: 'Von null auf vollständig konfiguriert' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from={m.from} data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <figure class="mx-auto max-w-2xl text-center">
          <blockquote class="font-sans text-[1.25rem] font-medium leading-[1.55] tracking-[-0.015em] text-[#111827]">
            „Wir haben letztes Jahr alle zwei Wochen einen neuen Standort eröffnet. Vor Stacc war die Einrichtung ein zweitägiges Projekt pro Standort. Jetzt dauert es unter 10 Minuten vom Zeitpunkt, an dem wir die Adresse erhalten, bis wir in jedem Verzeichnis live sind."
          </blockquote>
          <figcaption class="mt-6">
            <span class="font-sans text-[14px] font-semibold text-[#292524]">Marcus Webb</span>
            <span class="mx-2 text-[#e7e5e4]">·</span>
            <span class="font-sans text-[14px] text-[#79716b]">VP Operations, Restaurantgruppe mit 60 Standorten</span>
          </figcaption>
        </figure>
      </div>
    </section>


    <!-- ─── RELATED FEATURES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Verwandte Funktionen</p>
        <div class="mt-8 grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-3">
          {[
            { href: '/de/funktionen/zitationsverwaltung/', label: 'Zitationsverwaltung', desc: 'Konsistente Citations über 40+ Verzeichnisse automatisch aufbauen und pflegen.' },
            { href: '/de/funktionen/multi-standort-berichte/', label: 'Multi-Standort-Berichte', desc: 'Alle Standort-Performances in einem Dashboard sehen. Schwachstellen sofort identifizieren.' },
            { href: '/de/funktionen/white-label-dashboard/', label: 'White-Label-Dashboard', desc: 'Ihre Marke in jedem Bericht und jeder Kundenansicht. Nicht Stacc\'s.' },
          ].map(r => (
            <a href={r.href} class="group bg-white px-7 py-7 transition-colors hover:bg-[#f5f3ff]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#4f39f6]">{r.label}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.6] text-[#57534e]">{r.desc}</p>
