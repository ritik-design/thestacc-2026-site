---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Welche Plattformen unterstützt Stacc für Social Scheduling?",
    a: "Stacc unterstützt Google Business Profile, Facebook-Seiten und Instagram-Geschäftskonten. Die Integration mit diesen Plattformen erfolgt über offizielle APIs und ist vollständig DSGVO-konform.",
  },
  {
    q: "Kann ich Beiträge für mehrere Standorte gleichzeitig planen?",
    a: "Ja. Sie können einen Beitrag erstellen und ihn auf mehrere Standorte anwenden — mit der Möglichkeit, Text oder Bilder für jeden Standort anzupassen. Besonders nützlich für Unternehmen mit mehreren Standorten, die ähnlichen, aber nicht identischen Content benötigen.",
  },
  {
    q: "Wie weit im Voraus kann ich Beiträge planen?",
    a: "Sie können Beiträge bis zu 6 Monate im Voraus planen. Für die meisten lokalen Unternehmen empfehlen wir eine Vorausplanung von 2-4 Wochen, um konsistent zu bleiben ohne zu viel Zeit auf einmal zu investieren.",
  },
  {
    q: "Was passiert, wenn eine geplante Veröffentlichung fehlschlägt?",
    a: "Stacc versucht die Veröffentlichung automatisch erneut und sendet Ihnen eine Warnung, wenn die Veröffentlichung nach mehreren Versuchen nicht erfolgreich war. Sie können den Beitrag dann manuell einreichen oder für einen anderen Zeitpunkt neu planen.",
  },
  {
    q: "Werden GBP-Beiträge genauso behandelt wie reguläre Social-Media-Posts?",
    a: "GBP-Beiträge haben einzigartige Eigenschaften — sie enthalten Call-to-Action-Schaltflächen (Angebot, Ereignis, Neuigkeit) und haben spezifische Zeichenanzahlbeschränkungen. Stacc bietet separate GBP-Post-Vorlagen und Optimierungsempfehlungen speziell für dieses Format.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Social Scheduling",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Planen Sie Ihre Social-Media-Beiträge für Google Business Profile, Facebook und Instagram automatisch. Sparen Sie Stunden pro Woche und halten Sie Ihre Konten ohne manuellen Aufwand aktiv.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/de/" },
        { "@type": "ListItem", "position": 2, "name": "Funktionen", "item": "https://thestacc.com/de/funktionen/" },
        { "@type": "ListItem", "position": 3, "name": "Social Scheduling", "item": "https://thestacc.com/de/funktionen/social-scheduling/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Social Scheduling — Social-Media-Posts automatisch planen und veröffentlichen | theStacc"
  description="Planen Sie Ihre Social-Media-Beiträge für Google Business Profile, Facebook und Instagram automatisch. Sparen Sie Stunden pro Woche und halten Sie Ihre Konten ohne manuellen Aufwand aktiv."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Social Scheduling · Lokales SEO-Modul</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Sie wissen, dass Sie regelmäßig posten sollten.<br />
            <span style="color:#4f39f6;">Sie finden nur nie die Zeit dafür.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Konsistentes Posten auf Google Business Profile, Facebook und Instagram ist entscheidend für lokale Sichtbarkeit — aber es kostet Zeit, die Sie nicht haben. Stacc ermöglicht es Ihnen, Beiträge einmal pro Woche zu planen und automatisch zu veröffentlichen, damit Ihre Konten ohne täglichen Aufwand aktiv bleiben.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Kostenlos starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'GBP+', label: 'Google Business Profile, Facebook, Instagram' },
              { value: 'Auto', label: 'Automatische Veröffentlichung nach Zeitplan' },
              { value: '3h', label: 'Durchschnittlich gesparte Zeit pro Woche' },
              { value: '4.9★', label: 'Kundenbewertung' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Regelmäßiges Posten ist das Erste, das wegfällt,<br />wenn der Alltag voll ist.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Sie wissen, dass aktive Social-Media-Konten die lokale Sichtbarkeit verbessern. Aber zwischen Kundengesprächen, Terminplanung und dem täglichen Betrieb rückt das Posting immer weiter nach hinten. Bis aus einer Woche ohne Beiträge ein Monat wird — und Google die Inaktivität bemerkt.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Manuelles tägliches Posten ist das erste, was bei vollen Terminkalendern wegfällt.',
              body: 'Sie haben gute Absichten, aber wenn der Tag voll ist, verschwindet das Posting. Eine Woche ohne Beiträge wird zu einem Monat. Google bemerkt die Inaktivität und Ihr lokales Ranking spiegelt das wider.',
            },
            {
              icon: 'M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4',
              title: 'Das Wechseln zwischen drei Social-Plattformen verdoppelt den Zeitaufwand.',
              body: 'Separate Anmeldungen für Google, Facebook und Instagram. Verschiedene Bildformate. Verschiedene Beschriftungsanforderungen. Eine 20-minütige Posting-Aufgabe wird durch Plattformwechsel zu einer 60-minütigen Routine.',
            },
            {
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              title: 'Inkonsistente Veröffentlichung schadet Ihrer lokalen SEO-Leistung.',
              body: 'Google Business Profile-Beiträge sind ein direktes Ranking-Signal. Konten, die regelmäßig veröffentlichen, werden als aktiver und relevanter für lokale Suchen eingestuft. Lücken in der Veröffentlichung signalisieren Inaktivität — genau das, was Ihr Ranking kostet.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Einmal planen. Überall automatisch veröffentlichen.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1', title: 'Verbinden Sie Ihre Social-Media-Konten', body: 'Verknüpfen Sie Ihr Google Business Profile, Ihre Facebook-Seite und Ihr Instagram-Konto mit Stacc. Einmalige Einrichtung — danach verwaltet Stacc die Veröffentlichung auf allen Plattformen.' },
            { n: '02', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Beiträge einmal erstellen, für alle Plattformen anpassen', body: 'Erstellen Sie einen Beitrag und passen Sie ihn für jede Plattform an — ohne die Seite zu verlassen. Stacc zeigt die Vorschau für jedes Format. Planen Sie für sofortige Veröffentlichung oder für ein bestimmtes Datum und eine bestimmte Uhrzeit.' },
            { n: '03', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Automatisch veröffentlichen, Leistung verfolgen', body: 'Stacc veröffentlicht zum geplanten Zeitpunkt. Sie sehen, wie jeder Beitrag performen — Klicks, Reichweite, Engagement — direkt in Ihrem Dashboard, ohne sich auf mehreren Plattformen anzumelden.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alles inklusive</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alles, was Sie brauchen,<br />um konsistent zu posten.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Multi-Plattform-Veröffentlichung', body: 'Gleichzeitige Veröffentlichung auf Google Business Profile, Facebook und Instagram von einer Plattform aus.', icon: 'M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z' },
            { title: 'Beitrags-Planung und Kalender', body: 'Visualisieren Sie Ihren Content-Kalender für Wochen im Voraus. Planen Sie Beiträge für spezifische Daten und Uhrzeiten.', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { title: 'GBP Post-Optimierung', body: 'Google Business Profile-Beiträge haben spezifische Anforderungen und beste Praktiken. Stacc optimiert Ihre GBP-Beiträge automatisch für maximale Sichtbarkeit.', icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' },
            { title: 'Bildverwaltung', body: 'Laden Sie Bilder einmal hoch und verwenden Sie sie über mehrere Beiträge und Plattformen hinweg. Automatische Größenanpassung für jede Plattformanforderung.', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { title: 'Leistungsanalyse nach Beitrag', body: 'Sehen Sie, welche Beitragstypen, Veröffentlichungszeiten und Themen die beste Interaktion erzeugen — für jeden Standort und jede Plattform.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Multi-Standort-Inhaltsplanung', body: 'Erstellen Sie Beiträge für einen Standort und passen Sie sie für andere an. Skalieren Sie Ihre Content-Strategie, ohne jeden Standort separat zu verwalten.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was konsistentes Posten für lokale<br />Unternehmen bewirkt.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '3h', label: 'Gesparte Zeit pro Woche', sub: 'durch Automatisierung der manuellen Posting-Routine' },
            { value: '+34%', label: 'Mehr GBP-Profilaufrufe', sub: 'für Konten mit regelmäßigen GBP-Beiträgen vs. inaktive Konten' },
            { value: '4×', label: 'Höheres Posting-Volumen', sub: 'im Vergleich zur manuellen Posting-Häufigkeit vor Stacc' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Vor Stacc posteten wir unregelmäßig — manchmal wochenlang gar nicht. Jetzt plane ich am Montagmorgen die Woche vor, und die Beiträge gehen automatisch auf allen Plattformen live. Unser GBP-Profil ist viel aktiver, und wir sehen deutlich mehr Profilaufrufe als früher."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">JM</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Jana M.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Inhaberin, lokales Einzelhandelsgeschäft · Berlin</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">4× mehr Posts, gleicher Zeitaufwand</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Häufige Fragen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Fragen zum Social Scheduling
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Hören Sie auf, Posting auf morgen zu verschieben</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Konsistentes Posten ist das, was lokale Sichtbarkeit<br />von lokaler Unsichtbarkeit trennt.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Jede Woche, die Sie ohne regelmäßige Beiträge verbringen, verlieren Sie Boden gegenüber Mitbewerbern, die aktiv posten. Stacc macht es so einfach, dass Sie keine Ausrede mehr haben — und Ihnen die Zeit zurückgibt, die Sie für bessere Arbeit nutzen können.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Social Scheduling testen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Preise ansehen
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
