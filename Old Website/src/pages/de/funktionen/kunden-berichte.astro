---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Welche Daten können in Kunden-Berichte aufgenommen werden?",
    a: "Kunden-Berichte können Ranking-Änderungen (alle verfolgten Keywords), neue Bewertungen und aktuelle Durchschnittsbewertung, GBP-Profilaufrufe und Beitragsleistung sowie Citation-Gesundheit und Fehler enthalten. Sie wählen für jeden Kunden aus, was relevant ist.",
  },
  {
    q: "Können Berichte unter meiner Marke geliefert werden?",
    a: "Ja. Berichte können mit Ihrem Logo, Ihren Farben und von Ihrer Domain gesendet werden — vollständig White-Label. Kunden interagieren mit Ihrem Brand, nicht mit Stacc.",
  },
  {
    q: "Wie häufig können Berichte geliefert werden?",
    a: "Sie können wöchentliche, monatliche oder benutzerdefinierte Lieferpläne einrichten. Viele Agenturen senden wöchentliche Zusammenfassungen und monatliche Tiefenberichte.",
  },
  {
    q: "Kann ich Berichte vor dem Versand überprüfen?",
    a: "Ja. Sie können Berichte als \"Entwurf zuerst\" konfigurieren — Stacc erstellt den Bericht, sendet ihn aber in eine Warteschlange für Ihre Genehmigung, bevor er an den Kunden geliefert wird. Oder Sie lassen Berichte vollautomatisch versenden.",
  },
  {
    q: "Was passiert, wenn Daten fehlen, wenn ein Bericht geplant ist?",
    a: "Stacc warnt Sie, wenn Daten, die normalerweise in einem Bericht enthalten wären, nicht verfügbar sind — zum Beispiel wenn eine GBP-Verbindung getrennt wurde. Der Bericht wird trotzdem geliefert, aber Sie werden auf das Problem hingewiesen.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Kunden-Berichte",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Erstellen Sie professionelle lokale SEO-Berichte für Ihre Kunden automatisch. Rankings, Bewertungen, Citations und GBP-Aktivität in einem übersichtlichen Bericht — automatisch geliefert.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/de/" },
        { "@type": "ListItem", "position": 2, "name": "Funktionen", "item": "https://thestacc.com/de/funktionen/" },
        { "@type": "ListItem", "position": 3, "name": "Kunden-Berichte", "item": "https://thestacc.com/de/funktionen/kunden-berichte/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Automatische Kunden-Berichte — SEO-Berichte automatisch erstellen und liefern | theStacc"
  description="Erstellen Sie professionelle lokale SEO-Berichte für Ihre Kunden automatisch. Rankings, Bewertungen, Citations und GBP-Aktivität in einem übersichtlichen Bericht — automatisch geliefert."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Kunden-Berichte · Lokales SEO-Modul</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Jeden Monat 20 Stunden für Berichte ausgeben,<br />
            <span style="color:#4f39f6;">die Kunden in 2 Minuten lesen.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Kunden-Berichte sollten beweisen, dass Ihre Arbeit funktioniert — nicht Stunden Ihres Teams verbrauchen. Stacc erstellt umfassende lokale SEO-Berichte automatisch und liefert sie pünktlich — damit Ihr Team SEO statt Tabellen machen kann.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Kostenlos starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'Auto', label: 'Automatische Berichterstellung und Lieferung' },
              { value: '80%', label: 'Weniger Zeit für manuelle Berichte' },
              { value: 'White-Label', label: 'Unter Ihrer Marke lieferbar' },
              { value: '4.9★', label: 'Kundenbewertung' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Berichte, die Stunden kosten,<br />werden in Minuten gelesen.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Das Erstellen von Kunden-Berichten ist eine der zeitaufwändigsten Aufgaben in einer SEO-Agentur — und eine der am wenigsten wertschöpfenden. Wenn Ihr Team Stunden damit verbringt, Daten aus verschiedenen Tools zusammenzuführen und in PowerPoint-Folien zu formatieren, fehlt diese Zeit für die eigentliche SEO-Arbeit.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Manuell erstellte Berichte kosten Sie Stunden, die nicht in Rechnung gestellt werden.',
              body: '4-6 Stunden pro Kunde pro Monat für das Zusammenstellen von Ranking-Daten, Bewertungen, GBP-Aktivität und Citations. Mit 15 Kunden sind das 60-90 Stunden im Monat — ein ganzer Vollzeitjob, der ausschließlich Berichte erstellt.',
            },
            {
              icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Inkonsistente Berichte untergraben das Vertrauen der Kunden.',
              body: 'Wenn Berichte mal pünktlich, mal zu spät kommen — oder unterschiedliche Formate haben je nachdem, wer sie erstellt hat — fragen Kunden an, ob Sie wirklich aufmerksam sind. Konsistenz schafft Vertrauen. Manueller Prozess garantiert Inkonsistenz.',
            },
            {
              icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Kunden ohne regelmäßige Berichte kündigen eher.',
              body: 'Kunden, die nicht sehen, was ihr Geld tut, hören auf zu zahlen. Kunden, die jede Woche Beweise des Fortschritts sehen, bleiben länger. Berichte sind nicht nur Verwaltungsaufwand — sie sind Ihr wichtigstes Kundenbindungsinstrument.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Einmal konfigurieren. Berichte liefern sich selbst.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Bericht-Vorlage pro Kunde einrichten', body: 'Definieren Sie, welche Daten jeder Kundenbericht enthalten soll — Rankings, Bewertungen, GBP-Aktivität, Citations, oder alles zusammen. Legen Sie Lieferhäufigkeit und Empfänger fest. Einmalige Einrichtung.' },
            { n: '02', icon: 'M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4', title: 'Stacc aggregiert alle Daten automatisch', body: 'Zum geplanten Termin zieht Stacc alle relevanten Daten — aktuelle Rankings, neue Bewertungen, GBP-Beitragsleistung, Citation-Gesundheit — und formatiert sie in einen übersichtlichen Bericht.' },
            { n: '03', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Bericht direkt an den Kunden geliefert', body: 'Der fertige Bericht wird automatisch an die Kunden-E-Mail gesendet — mit Ihrer Marke, Ihrem Logo und Ihren Kommentaren. Kein manueller Eingriff von Ihrer Seite.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alles inklusive</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alles in einem Kundenbericht,<br />der sich selbst erstellt.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Automatische Berichterstellung', body: 'Stacc erstellt den Bericht nach festgelegtem Zeitplan — täglich, wöchentlich oder monatlich — ohne dass jemand in Ihrem Team etwas tun muss.', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
            { title: 'Alle lokalen SEO-Daten in einem Bericht', body: 'Ranking-Änderungen, neue Bewertungen, GBP-Aktivität, Citation-Gesundheit — alles in einem strukturierten Bericht, der den Gesamtfortschritt klar zeigt.', icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
            { title: 'White-Label-Formatierung', body: 'Berichte unter Ihrem Logo, Ihren Farben und Ihrer Domain geliefert. Kunden sehen Ihren Brand — nicht Stacc.', icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01' },
            { title: 'Anpassbare Berichtsinhalte', body: 'Wählen Sie, welche Metriken in jedem Kundenbericht erscheinen. Einige Kunden wollen alles — andere nur Rankings. Passen Sie jeden Bericht an die Prioritäten des Kunden an.', icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4' },
            { title: 'Kommentarfelder für Kontext', body: 'Fügen Sie für jeden Kunden standard Kommentare oder Erklärungen hinzu, die automatisch in den Bericht aufgenommen werden — ohne jedes Mal zu schreiben.', icon: 'M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z' },
            { title: 'Berichts-Lieferverfolgung', body: 'Sehen Sie, welche Berichte geliefert wurden, wann sie geöffnet wurden und ob Kunden damit interagiert haben.', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was Agenturen gewinnen, wenn<br />Berichte automatisiert sind.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '80%', label: 'Weniger Zeit für Berichte', sub: 'bezogen auf alle Kunden pro Monat' },
            { value: '+40%', label: 'Bessere Kundenbindung', sub: 'für Kunden mit wöchentlichen automatisierten Berichten' },
            { value: '3×', label: 'Mehr Kunden mit demselben Team', sub: 'wenn Reporting nicht mehr manuell ist' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Früher bauten wir Berichte manuell in PowerPoint. Es dauerte 3-4 Stunden pro Kunde, und sie sahen jedes Mal leicht anders aus. Jetzt werden Berichte automatisch jeden Montag an alle Kunden geliefert. Ich habe in den letzten 4 Monaten keinen Kundenbericht manuell erstellt."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">AR</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Andreas R.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Gründer, SEO-Agentur · 28 aktive Kunden</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">90+ Stunden/Monat gespart</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Häufige Fragen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Fragen zu Kunden-Berichten
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Hören Sie auf, Stunden für Berichte zu verschwenden</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Berichte sollten Ihre Arbeit beweisen,<br />nicht Ihre Zeit stehlen.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Jede Stunde, die Ihr Team mit manuellen Berichten verbringt, ist eine Stunde weniger für SEO. Die besten Agenturen schlagen die Konkurrenz nicht, weil sie härter arbeiten — sie schaffen es, weil ihre Infrastruktur die Basisarbeit erledigt, damit ihr Team sich auf das Wesentliche konzentrieren kann.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Automatische Berichte testen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Preise ansehen
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
