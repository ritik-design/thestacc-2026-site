---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Was sind Citations und warum sind sie wichtig für lokales SEO?",
    a: "Citations sind Erwähnungen Ihrer Unternehmens-NAP (Name, Adresse, Telefon) auf anderen Websites — Verzeichnisse, Branchenbücher, Bewertungsplattformen. Google verwendet sie als Vertrauenssignal für lokale Rankings. Konsistente Citations signalisieren, dass Ihre Unternehmensinformationen zuverlässig sind; inkonsistente Citations signalisieren das Gegenteil.",
  },
  {
    q: "Welche Verzeichnisse überwacht Stacc?",
    a: "Stacc überwacht 50+ Verzeichnisse, einschließlich Google Business Profile, Yelp, Facebook, Apple Maps, Bing Places, Yellow Pages und branchenspezifischer Plattformen, die für Ihren Unternehmenstyp relevant sind.",
  },
  {
    q: "Kann Stacc Citations automatisch korrigieren?",
    a: "Stacc identifiziert Fehler und leitet Sie durch den Korrekturprozess für jedes Verzeichnis. Bei einigen Plattformen können Korrekturen direkt innerhalb von Stacc eingereicht werden. Für andere erhalten Sie genaue Anweisungen, wie Sie die Korrektur manuell einreichen können.",
  },
  {
    q: "Wie oft werden Citations überprüft?",
    a: "Stacc führt wöchentliche automatische Scans über alle überwachten Verzeichnisse durch. Hochpriorisierte Verzeichnisse wie Google Business Profile werden täglich überwacht.",
  },
  {
    q: "Was soll ich tun, wenn ein Verzeichnis Ihre Korrekturen nicht akzeptiert?",
    a: "Einige Verzeichnisse haben strenge Überprüfungsprozesse. Stacc gibt Ihnen für jedes Verzeichnis spezifische Anleitung — einschließlich alternativer Einreichungsmethoden für schwierigere Plattformen. In seltenen Fällen, in denen eine Korrektur nicht möglich ist, priorisiert Stacc alternative Verzeichnisse mit hoher Autorität.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Zitationsverwaltung",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Stellen Sie sicher, dass Name, Adresse und Telefonnummer Ihres Unternehmens in allen Online-Verzeichnissen korrekt und konsistent sind. Stacc findet inkonsistente Citations und hilft Ihnen, sie zu bereinigen.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/de/" },
        { "@type": "ListItem", "position": 2, "name": "Funktionen", "item": "https://thestacc.com/de/funktionen/" },
        { "@type": "ListItem", "position": 3, "name": "Zitationsverwaltung", "item": "https://thestacc.com/de/funktionen/zitationsverwaltung/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Zitationsverwaltung — NAP-Konsistenz in allen Verzeichnissen | theStacc"
  description="Stellen Sie sicher, dass Name, Adresse und Telefonnummer Ihres Unternehmens in allen Online-Verzeichnissen korrekt und konsistent sind. Stacc findet inkonsistente Citations und hilft Ihnen, sie zu bereinigen."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Zitationsverwaltung · Lokales SEO-Modul</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Falsche Unternehmensdaten in Verzeichnissen kosten Sie Kunden.<br />
            <span style="color:#4f39f6;">Stacc findet und behebt jede Inkonsistenz.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Name, Adresse und Telefonnummer müssen in Hunderten von Online-Verzeichnissen identisch sein. Eine einzige Abweichung verwirrt Google — und senkt Ihre lokalen Rankings. Stacc prüft alle Ihre Citations und stellt sicher, dass Kunden Sie überall finden können.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Citation-Audit starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '50+', label: 'Verzeichnisse überwacht' },
              { value: 'NAP', label: 'Name, Adresse, Telefon — konsistent gehalten' },
              { value: 'Auto', label: 'Automatische Fehlerkennung' },
              { value: '4.9★', label: 'Kundenbewertung' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Inkonsistente Unternehmensdaten in Verzeichnissen kosten Sie Rankings und Kunden.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Ihre aktuelle Adresse steht korrekt bei Google. Aber bei Yelp ist noch die alte Anschrift. Bei Apple Maps eine andere Telefonnummer. Bei einem Branchenverzeichnis ein leicht abweichender Unternehmensname. Keiner dieser Fehler wirkt für sich genommen gravierend. Zusammen senden sie Google ein Unsicherheitssignal über Ihre Identität — und das schlägt sich direkt in niedrigeren lokalen Rankings nieder.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Inkonsistente Unternehmensdaten verwirren Google und Kunden.',
              body: 'Wenn Google Ihre Adresse in drei verschiedenen Schreibweisen in Verzeichnissen findet, verliert es das Vertrauen in die Richtigkeit Ihrer Informationen. Das Ergebnis: niedrigere lokale Rankings und verpasste Kunden, die zu einem Mitbewerber mit sauberem Profil gehen.',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Manuelle Überwachung von 50+ Verzeichnissen ist unrealistisch.',
              body: 'Verzeichnisse ändern Ihre Daten ohne Benachrichtigung. Mitbewerber können falsche Korrekturen einreichen. Ohne systematische Überwachung verbreiten sich Fehler — und bleiben oft monatelang unentdeckt.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Jede falsche Citation ist eine verpasste Chance zu ranken.',
              body: 'Google verwendet Citations als Rankingfaktor für lokale Suche. Verzeichnisse mit hoher Autorität, auf denen Ihr Unternehmen korrekt gelistet ist, stärken Ihre Sichtbarkeit. Fehlende oder fehlerhafte Listings sind Rankings, die Sie Ihren Mitbewerbern überlassen.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Citations bereinigen. Konsistenz<br />aufrechterhalten. Automatisch.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Citation-Audit über alle Verzeichnisse', body: 'Stacc scannt 50+ Verzeichnisse und prüft, ob Ihr Unternehmensname, Ihre Adresse und Telefonnummer überall identisch sind. Sie sehen sofort, welche Listings Korrekturen benötigen.' },
            { n: '02', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Fehler identifizieren und priorisieren', body: 'Nicht alle Citation-Fehler sind gleich schwerwiegend. Stacc priorisiert Korrekturen nach dem Einfluss auf Ihre Rankings — beginnend mit hochautoritären Verzeichnissen wie Google, Yelp und branchenspezifischen Plattformen.' },
            { n: '03', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Konsistenz überwachen, sobald sie erreicht ist', body: 'Wenn Ihr Profil bereinigt ist, überwacht Stacc es weiterhin. Wenn ein Verzeichnis Ihre Daten ändert oder ein neues Listing erscheint, werden Sie benachrichtigt — bevor es Ihre Rankings beeinflusst.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alles inklusive</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vollständige Citation-Verwaltung<br />ohne manuellen Aufwand.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Citation-Audit und Analyse', body: 'Vollständige Überprüfung Ihrer NAP-Konsistenz über 50+ Verzeichnisse mit einer detaillierten Fehlerliste und Prioritätswertung.', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
            { title: 'Fehlerkennung in Echtzeit', body: 'Automatische Erkennung, wenn Verzeichnisse Ihre Daten ohne Ankündigung ändern, mit sofortiger Warnbenachrichtigung.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Priorisierte Korrekturempfehlungen', body: 'Korrekturen nach SEO-Einfluss priorisiert — hochautoritäre Verzeichnisse zuerst, damit sich Ihre Verbesserungsarbeit am meisten lohnt.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
            { title: 'Überwachung auf Duplikate', body: 'Doppelte Listings in Verzeichnissen verwirren Suchmaschinen. Stacc identifiziert Duplikate und empfiehlt Zusammenführungsaktionen.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Branchenspezifische Verzeichnisse', body: 'Neben allgemeinen Verzeichnissen überwacht Stacc branchenspezifische Plattformen, die für Ihren Unternehmenstyp relevant sind.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Multi-Standort-Citation-Übersicht', body: 'Sehen Sie den Citation-Gesundheitszustand über alle Standorte in einem Dashboard. Identifizieren Sie, welche Standorte sofortige Aufmerksamkeit benötigen.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was passiert, wenn Citations korrekt<br />und konsistent sind.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '+23%', label: 'Verbesserung der lokalen Sichtbarkeit', sub: 'nach vollständiger Citation-Bereinigung' },
            { value: '50+', label: 'Überwachte Verzeichnisse', sub: 'einschließlich branchenspezifischer Plattformen' },
            { value: '48h', label: 'Durchschnittliche Erkennungszeit', sub: 'für neue Citation-Fehler nach Auftreten' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Wir wussten nicht einmal, dass unsere Telefonnummer in 23 Verzeichnissen falsch war. Stacc fand alle Inkonsistenzen in einer Stunde und priorisierte, was zuerst behoben werden musste. Innerhalb von 6 Wochen verbesserten sich unsere lokalen Rankings deutlich."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">TB</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Thomas B.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Inhaber, Handwerksbetrieb · 3 Standorte</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">23 Fehler in 1 Stunde gefunden und behoben</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Häufige Fragen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Fragen zur Zitationsverwaltung
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Falsche Daten kosten Sie Rankings</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Jede inkonsistente Citation ist ein Ranking,<br />das Sie Ihrem Mitbewerber überlassen.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Im Moment könnten Dutzende von Verzeichnissen Ihre falsche Adresse, Telefonnummer oder Ihren Unternehmensnamen zeigen — ohne dass Sie es wissen. Jede Inkonsistenz signalisiert Google, dass Ihren Daten nicht zu vertrauen ist. Stacc findet sie alle.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Citation-Audit starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Preise ansehen
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
