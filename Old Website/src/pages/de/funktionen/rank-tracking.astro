---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Welche Keywords verfolgt Stacc für mein Unternehmen?",
    a: "Stacc verfolgt die Keywords, die Sie wählen — lokal ausgerichtete Begriffe mit hoher Absicht wie \"Klempner in meiner Nähe\", \"bestes Restaurant in [Stadt]\" oder jeder für Ihren Service und Bereich spezifische Begriff. Wir schlagen Keywords basierend auf Ihrem Unternehmenstyp und Standort vor, und Sie wählen aus, was Sie überwachen möchten. Sie können jederzeit eigene Begriffe hinzufügen.",
  },
  {
    q: "Wie oft werden die Rankings aktualisiert?",
    a: "Ranking-Daten werden täglich aktualisiert. Jeden Morgen erhalten Sie eine Momentaufnahme, wie Sie in Google Maps und den lokalen Suchergebnissen für jedes verfolgte Keyword positionieren. Wesentliche Änderungen — erhebliche Anstiege oder Rückgänge — generieren zusätzliche Echtzeit-Warnungen.",
  },
  {
    q: "Verfolgt Stacc Rankings in Google Maps speziell?",
    a: "Ja. Stacc verfolgt sowohl das lokale Paket von Google (die 3 Kartenergebnisse) als auch die organischen lokalen Suchergebnisse. Für die meisten lokalen Unternehmen ist das Erscheinen im Kartenpaket wertvoller als das organische Ergebnis — daher überwachen wir es separat und priorisiert.",
  },
  {
    q: "Kann ich die Rankings meiner Mitbewerber sehen?",
    a: "Ja. Für jedes verfolgte Keyword zeigt Stacc Ihre Position neben der Ihrer 3 wichtigsten lokalen Mitbewerber. Sie sehen genau, wen Sie überholt haben und wer vor Ihnen liegt. Lücken zwischen Ihrer Leistung und der der Mitbewerber werden automatisch als Verbesserungsmöglichkeiten markiert.",
  },
  {
    q: "Wie funktioniert die Verfolgung an mehreren Standorten?",
    a: "Jeder Standort verfolgt Keywords in seinem spezifischen geografischen Markt. Eine Kette mit 20 Standorten kann \"Friseur in meiner Nähe\" gleichzeitig in 20 verschiedenen Städten verfolgen. Rankings werden täglich für jeden Standort aktualisiert und können einzeln oder in einer aggregierten Portfolio-Ansicht eingesehen werden.",
  },
  {
    q: "Was soll ich tun, wenn ein Ranking fällt?",
    a: "Stacc zeigt Ihnen, was und wie viel gefallen ist, weist aber auch auf die wahrscheinlichsten Faktoren hin: GBP-Profilaktivität, Citationsgesundheit, aktuelle Bewertungsbewertung. Durch die Kombination von Rank Tracking mit den anderen Stacc-Funktionen können Sie im selben Dashboard diagnostizieren und handeln — ohne mehrere Tools öffnen zu müssen.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Rank Tracking",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Verfolgen Sie Ihre Google Maps-Positionen täglich. Sehen Sie genau, wo Sie für jedes Keyword und jeden Standort erscheinen — und erkennen Sie Veränderungen, bevor sie Ihr Geschäft beeinflussen.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/de/" },
        { "@type": "ListItem", "position": 2, "name": "Funktionen", "item": "https://thestacc.com/de/funktionen/" },
        { "@type": "ListItem", "position": 3, "name": "Rank Tracking", "item": "https://thestacc.com/de/funktionen/rank-tracking/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Rank Tracking — Google Maps Rankings täglich überwachen | theStacc"
  description="Verfolgen Sie Ihre Google Maps-Positionen täglich. Sehen Sie genau, wo Sie für jedes Keyword und jeden Standort erscheinen — und erkennen Sie Veränderungen, bevor sie Ihr Geschäft beeinflussen."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Rank Tracking · Lokales SEO-Modul</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Ihr Google Maps-Ranking fiel gestern.<br />
            <span style="color:#4f39f6;">Wann erfahren Sie davon?</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc verfolgt Ihre Google Maps- und lokale Suchpositionen täglich — für jedes Keyword, an jedem Standort. Erkennen Sie Auf- und Abstiege, bevor sie Ihr Geschäft beeinflussen. Keine Tabellen. Keine manuellen Suchen. Nur echte Daten, jeden Morgen.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Kostenlos starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'Täglich', label: 'Aktualisierungsfrequenz der Rankings' },
              { value: '500+', label: 'Verfolgbare Standorte in einem Dashboard' },
              { value: 'Top 3', label: 'Ziel: Google Maps-Paket' },
              { value: '4.9★', label: 'Durchschnittliche Kundenbewertung' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Manuelle Suchen, um zu prüfen, wo Sie erscheinen, sind keine Strategie.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Die Standardvorgehensweise: Ihr Unternehmen jeden Montag in Google suchen, Ergebnisse in eine Tabelle eintragen, für jeden Standort wiederholen, versuchen zu erinnern, ob die Position letzte Woche 4. oder 5. war. Und wenn Ihr Ranking an einem Dienstagnachmittag fällt, erfahren Sie es am nächsten Montag — nachdem Sie eine ganze Woche Sichtbarkeit gegenüber Kunden verloren haben, die sich für Ihren Mitbewerber entschieden.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Sie erfahren von Rückgängen, wenn der Schaden bereits angerichtet ist.',
              body: 'Ein Ranking-Rückgang kann Tage dauern, bis Sie ihn manuell erkennen. Währenddessen fanden Kunden, die nach Ihrem Service suchten, Ihren Mitbewerber. Sie wissen nicht, wie viele Anrufe oder Besuche Sie verloren haben — weil Sie nicht wussten, dass es ein Problem gab.',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Manuelle Überprüfungen verbrauchen Zeit, die Sie nicht abrechnen können.',
              body: 'Manuelle Ranking-Überprüfungen für 10 Standorte und 5 Keywords dauern mehr als 2 Stunden pro Woche. Das sind 8+ Stunden im Monat für eine Aufgabe, die automatisiert sein sollte. Jede Stunde, die Sie mit der Überprüfung von Rankings verbringen, ist eine Stunde, in der Sie nichts optimieren.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Ohne historische Daten können Sie keine Ergebnisse nachweisen.',
              body: 'Ihr Kunde fragt, ob die SEO funktioniert. Was zeigen Sie ihm? Ohne systematische Ranking-Historie können Sie keinen Fortschritt belegen. Vage Berichte untergraben das Vertrauen. Konkrete Daten schaffen es — aber nur, wenn Sie sie erfasst haben.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Einmal einrichten. Ihre Rankings kommen<br />jeden Morgen von selbst.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Verbinden Sie Standorte und wählen Sie Keywords', body: 'Verknüpfen Sie Ihr Google Business Profile, fügen Sie die Keywords hinzu, die Sie für jeden Standort verfolgen möchten. Stacc schlägt Begriffe mit hoher lokaler Absicht für Ihren Unternehmenstyp vor. Einrichtung in weniger als 10 Minuten.' },
            { n: '02', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Rankings täglich automatisch aktualisiert', body: 'Jeden Morgen prüft Stacc Ihre Position in Google Maps und der lokalen organischen Suche für jedes Keyword und jeden Standort. Wesentliche Änderungen generieren sofortige Warnungen. Kein manueller Eingriff Ihrerseits.' },
            { n: '03', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Trends erkennen und datenbasiert handeln', body: 'Die Ranking-Historie zeigt Ihnen Trends über die Zeit. Korrelieren Sie Auf- und Abstiege mit Änderungen in Ihrem GBP-Profil, Citations oder Bewertungen. Genau zu wissen, was Ihre Rankings bewegt, eliminiert Mutmaßungen aus Ihrer lokalen SEO-Strategie.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alles inklusive</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vollständiges Rank Tracking<br />ohne Werkzeugwechsel.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Rankings in Google Maps', body: 'Position im lokalen Paket (die ersten 3 der Karte) und organische lokale Ergebnisse separat für jedes Keyword verfolgt.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Ranking-Änderungswarnungen', body: 'Sofortige Benachrichtigung, wenn ein Ranking wesentlich steigt oder fällt. Erkennen Sie Probleme am selben Tag, an dem sie auftreten.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Mitbewerber-Vergleich', body: 'Sehen Sie Ihre Position neben der Ihrer 3 wichtigsten lokalen Mitbewerber für jedes Keyword. Wissen Sie genau, wen Sie überholt haben und wer Sie überholt.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Ranking-Historie', body: 'Positionstrends über die Zeit für jedes Keyword. Korrelieren Sie Ranking-Änderungen mit Maßnahmen, die Sie am GBP-Profil, Citations oder Bewertungen vorgenommen haben.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
            { title: 'Multi-Standort-Verfolgung', body: 'Verwalten Sie Rankings für alle Ihre Standorte von einem Dashboard aus. Sehen Sie die Leistung pro Standort einzeln oder in einer aggregierten Portfolio-Ansicht.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
            { title: 'Keyword-Lückenanalyse', body: 'Welche Keywords haben Ihre Mitbewerber, die Sie nicht haben? Identifizieren Sie Ranking-Möglichkeiten mit nachgewiesener lokaler Nachfrage, bei denen Sie derzeit nicht erscheinen.', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was Unternehmen erreichen, wenn sie<br />wissen, wo sie ranken.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '2.3×', label: 'Mehr Klicks aus Google Maps', sub: 'beim Aufstieg von Position 5+ auf Top 3' },
            { value: '90 Tage', label: 'Für sichtbare Ranking-Verbesserungen', sub: 'mit konstanter datengesteuerter Optimierung' },
            { value: '4.9★', label: 'Durchschnittliche Stacc-Bewertung', sub: 'unter Rank Tracking-Nutzern' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Vor Stacc überprüfte ich die Rankings meiner Kunden durch manuelle Google-Suchen. Das dauerte 4 Stunden pro Woche und die Daten waren inkonsistent, weil personalisierte Suchen die Ergebnisse verfälschen. Mit Stacc habe ich jeden Morgen präzise Positionsdaten für alle Standorte, und wenn ein Ranking fällt, erfahre ich es am selben Tag — nicht eine Woche später."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">KR</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Klaus R.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Lokale SEO-Agentur · 22 aktive Kunden</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">4 Stunden/Woche zurückgewonnen</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Häufige Fragen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Fragen zum Rank Tracking
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Hören Sie auf zu raten, wo Sie erscheinen</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Ihre Rankings ändern sich täglich.<br />Zu wissen, wann sie sich ändern, ist der Vorteil.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Im Moment könnte Ihr Google Maps-Ranking steigen oder fallen, ohne dass Sie es wissen. Ihre Mitbewerber handeln. Stacc zeigt Ihnen alles täglich — damit Sie handeln können, wenn es darauf ankommt, nicht wenn es bereits zu spät ist.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Rankings verfolgen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Preise ansehen
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
