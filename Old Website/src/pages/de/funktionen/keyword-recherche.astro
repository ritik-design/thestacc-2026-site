---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie unterscheidet sich Stacc von anderen Keyword-Recherche-Tools?",
    a: "Die meisten Keyword-Tools zeigen nationales Suchvolumen. Stacc fokussiert sich auf lokale Suchvolumendaten — was in Ihrer spezifischen Stadt oder Ihrem Postleitzahlgebiet gesucht wird. Das macht einen erheblichen Unterschied für lokale Unternehmen, die lokale Kunden ansprechen, keine nationalen.",
  },
  {
    q: "Kann ich Keywords für mehrere Standorte recherchieren?",
    a: "Ja. Jeder Standort kann eine eigene Keyword-Recherche mit standortspezifischem Suchvolumen haben. Eine Kette kann sehen, welche Begriffe in München anders sind als in Hamburg — weil lokale Suchmuster tatsächlich variieren.",
  },
  {
    q: "Wie oft werden die Keyword-Daten aktualisiert?",
    a: "Keyword-Volumen- und Schwierigkeitsdaten werden monatlich aktualisiert. Mitbewerber-Keyword-Lückendaten werden wöchentlich aktualisiert, da sich Mitbewerber-Rankings häufiger ändern.",
  },
  {
    q: "Welche Branchen werden unterstützt?",
    a: "Stacc hat vorgefertigte Keyword-Vorschläge für Dutzende lokale Unternehmenskategorien — von Klempnern und Ärzten bis hin zu Restaurants und Anwälten. Wenn Ihre Kategorie nicht in der Liste ist, können Sie sie mit allgemeinen Unternehmenstypbeschreibungen manuell eingeben.",
  },
  {
    q: "Kann ich Keyword-Recherche-Daten exportieren?",
    a: "Ja. Keyword-Listen können in CSV exportiert und in Google Sheets, Ihrem GBP-Optimierungsprozess oder externen Reporting-Tools verwendet werden.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Keyword-Recherche für lokales SEO",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Entdecken Sie Keywords, die lokale Kunden tatsächlich verwenden. Stacc liefert Keyword-Ideen mit lokalem Suchvolumen, Schwierigkeitsgrad und Geschäftsabsicht — damit Sie bei den Suchen ranken, die Ihnen Kunden bringen.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/de/" },
        { "@type": "ListItem", "position": 2, "name": "Funktionen", "item": "https://thestacc.com/de/funktionen/" },
        { "@type": "ListItem", "position": 3, "name": "Keyword-Recherche", "item": "https://thestacc.com/de/funktionen/keyword-recherche/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Keyword-Recherche für lokales SEO — Finden Sie die richtigen lokalen Suchbegriffe | theStacc"
  description="Entdecken Sie Keywords, die lokale Kunden tatsächlich verwenden. Stacc liefert Keyword-Ideen mit lokalem Suchvolumen, Schwierigkeitsgrad und Geschäftsabsicht — damit Sie bei den Suchen ranken, die Ihnen Kunden bringen."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Keyword-Recherche · Lokales SEO-Modul</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Die meisten lokalen Unternehmen optimieren für die falschen Keywords.<br />
            <span style="color:#4f39f6;">Stacc zeigt Ihnen, welche Kunden tatsächlich bringen.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Entdecken Sie Keywords mit echtem lokalem Suchvolumen und klarer Kaufabsicht. Stacc identifiziert Begriffe, für die Ihre Mitbewerber ranken, aber Sie noch nicht — und priorisiert die, die tatsächlich Kunden in Ihr Unternehmen bringen.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Kostenlos starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'Lokal', label: 'Suchvolumen nach Postleitzahl und Stadt' },
              { value: 'KD-Score', label: 'Schwierigkeitsgrad pro Keyword' },
              { value: 'Absicht', label: 'Kaufabsicht vs. informative Suche' },
              { value: '4.9★', label: 'Kundenbewertung' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Für generische Keywords optimieren ist Zeitverschwendung im lokalen SEO.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Das typische Problem: Sie haben eine Liste von Keywords, aber keine Ahnung, welche davon in Ihrer Stadt tatsächlich gesucht werden. Sie optimieren für "Klempner" — aber in Ihrer Stadt suchen die Leute nach "Klempner [Stadtname] Notfall". Das eine bringt nationale Konkurrenz. Das andere bringt Ihren nächsten Kunden.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          {[
            {
              icon: 'M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
              title: 'Sie optimieren für Keywords, die keine lokale Nachfrage haben.',
              body: 'Generische Keywords wie "beste Pizza" haben Millionen von Suchanfragen — aber niemand, der in Ihrer Stadt Pizza bestellen möchte, tippt das ein. Lokale Suchen sind spezifisch. Ohne lokale Keyword-Daten raten Sie bei der Optimierung.',
            },
            {
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
              title: 'Ihre Mitbewerber ranken für lokale Begriffe, die Sie nicht kennen.',
              body: 'Für jedes Keyword, das Sie verpassen, erscheinen Mitbewerber genau dort, wo Ihre potenziellen Kunden suchen. Die Lücke wächst jeden Monat. Ohne einen systematischen Überblick über Keyword-Möglichkeiten kämpfen Sie blind.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Ohne Absichtsfilterung bringen Keywords Besucher, keine Kunden.',
              body: '"Wie man einen Hahn repariert" und "Klempner in meiner Nähe" sind beide Klempner-Keywords — aber nur eines davon wird Ihren Laden anrufen. Ohne Absichtsfilterung verschwenden Sie Optimierungsaufwand für Besucher, die nie kaufen werden.',
            },
          ].map(p => (
            <div class="bg-white px-8 py-10">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Lokale Keywords finden, die tatsächlich<br />Kunden bringen.
          </h2>
        </div>

        <div class="mx-auto mt-14 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
          {[
            { n: '01', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Geben Sie Ihr Unternehmen und Ihren Standort an', body: 'Stacc analysiert Ihren Unternehmenstyp, Standort und Ihre Mitbewerber. Es identifiziert, für welche Keywords Ihre lokale Konkurrenz rankt — und welche lokalen Suchbegriffe in Ihrem Markt Volumen haben.' },
            { n: '02', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Filtern Sie nach lokaler Absicht und Schwierigkeitsgrad', body: 'Sehen Sie sofort, welche Keywords kaufbereite Kunden anziehen versus informative Sucher. Filtern Sie nach Suchvolumen, Keyword-Schwierigkeitsgrad und Entfernung zu Ihrem Standort. Fokussieren Sie Ihren Aufwand auf Begriffe mit realistischen Ranking-Chancen.' },
            { n: '03', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Optimieren Sie mit Vertrauen und verfolgen Sie Ergebnisse', body: 'Wenden Sie die Keyword-Empfehlungen auf Ihr GBP-Profil, Ihre Website und Ihre lokalen Inhalte an. Verfolgen Sie dann Ranking-Änderungen für diese Keywords direkt in Stacc. Sehen Sie, was sich bewegt und warum.' },
          ].map(s => (
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={s.icon}/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">{s.n}</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{s.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CAPABILITY GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alles inklusive</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alle Keyword-Insights, die Sie für<br />lokales SEO brauchen.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { title: 'Lokales Suchvolumen', body: 'Sehen Sie, wie viele Suchen es für jedes Keyword in Ihrer Stadt oder Ihrem Postleitzahlgebiet gibt — nicht nur nationales Volumen, das Ihre lokale Realität verdeckt.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
            { title: 'Keyword-Schwierigkeitsgrad', body: 'Verstehen Sie, wie schwer es ist, für jeden Begriff zu ranken, basierend auf den aktuellen lokalen Mitbewerbern, die die ersten Positionen halten.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' },
            { title: 'Absichtsklassifizierung', body: 'Keywords automatisch als kaufbereit (transaktional) oder informativ klassifiziert. Fokussieren Sie Optimierungsaufwand auf Begriffe, die Käufer anziehen, nicht nur Leser.', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
            { title: 'Mitbewerber-Keyword-Lücken', body: 'Welche Keywords ranken Ihre Mitbewerber, für die Sie nicht erscheinen? Identifizieren Sie ungenutzte Möglichkeiten mit bestehender lokaler Nachfrage.', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9' },
            { title: 'Keyword-Vorschläge nach Unternehmenstyp', body: 'Vorgefertigte Keyword-Listen für Dutzende lokale Unternehmenskategorien. Keine leere Suchmaske — relevante Startpunkte für Ihren spezifischen Markt.', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
            { title: 'Integration mit Rank Tracking', body: 'Keywords aus der Recherche direkt zu Ihrem Tracking-Dashboard hinzufügen. Schließt den Kreis von der Entdeckung bis zur Leistungsüberwachung.', icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── DARK METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was passiert, wenn Sie mit den richtigen<br />Keywords optimieren.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '+40%', label: 'Mehr qualifizierter Traffic', sub: 'durch Optimierung für Keywords mit Kaufabsicht' },
            { value: '3×', label: 'Höhere Konversionsrate', sub: 'lokale transaktionale Keywords vs. generische Begriffe' },
            { value: '60 Tage', label: 'Bis erste Ranking-Verbesserungen', sub: 'für gut gewählte Keywords mit mittlerem Schwierigkeitsgrad' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIAL ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#f5f3ff]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <div class="rounded-2xl border border-[#c7c0fc] bg-white px-10 py-12 shadow-sm">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <blockquote class="font-sans text-[1.2rem] leading-[1.65] text-[#111827] font-medium">
              "Wir haben jahrelang für Keywords optimiert, die wir für wichtig hielten. Stacc zeigte uns, dass unsere tatsächlichen potenziellen Kunden ganz andere Begriffe verwendeten. Nach drei Monaten Optimierung für die richtigen Keywords verdoppelte sich unser Google Maps-Traffic."
            </blockquote>
            <div class="mt-8 flex items-center gap-4">
              <div class="h-11 w-11 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                <span class="font-mono text-[14px] font-bold text-white">MS</span>
              </div>
              <div>
                <p class="font-sans text-[14px] font-semibold text-[#111827]">Monika S.</p>
                <p class="font-mono text-[11px] text-[#79716b]">Inhaberin, lokaler Dienstleistungsbetrieb · München</p>
              </div>
              <div class="ml-auto hidden sm:flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3 py-1.5">
                <span class="font-mono text-[11px] font-semibold text-[#059669]">2× Google Maps-Traffic</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Häufige Fragen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Fragen zur Keyword-Recherche
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Hören Sie auf zu raten, was Kunden suchen</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Die richtigen Keywords sind der Unterschied zwischen<br />Traffic und echten Kunden.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Jeden Tag suchen potenzielle Kunden in Ihrer Stadt nach Ihren Services — aber vielleicht nicht mit den Keywords, für die Sie optimiert haben. Stacc zeigt Ihnen genau, welche Begriffe lokale Kunden verwenden, damit Sie genau dort erscheinen, wo Ihr nächster Kunde sucht.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Keyword-Recherche starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Preise ansehen
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">14 Tage kostenlos testen · Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
