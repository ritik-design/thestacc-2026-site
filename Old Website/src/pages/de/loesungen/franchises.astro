---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Wie unterscheiden sich Zugriffsebenen in Stacc für Franchise-Systeme?",
    a: "Stacc unterstützt drei Ebenen: Netzwerk-Administrator (sieht alle Standorte und aggregierte Berichte), Regional-Manager (sieht zugewiesene Standortgruppen) und Franchisenehmer (sieht nur ihren eigenen Standort). Jede Ebene hat die für ihre Rolle relevante Ansicht.",
  },
  {
    q: "Können Franchisegeber Berichte für die gesamte Kette erstellen?",
    a: "Ja. Netzwerk-Administratoren können automatisch generierte Portfolio-Berichte mit aggregierten Metriken über alle Standorte erstellen. Diese können nach Region, Leistungsbereich oder benutzerdefinierten Gruppen gefiltert werden.",
  },
  {
    q: "Können Franchisenehmer ohne technisches SEO-Wissen Stacc verwenden?",
    a: "Ja, das ist ein zentrales Design-Prinzip. Das Franchisenehmer-Dashboard zeigt klar, was gut läuft und was Aufmerksamkeit benötigt — ohne technisches SEO-Vokabular. Empfehlungen sind in verständlicher Sprache und mit klaren nächsten Schritten.",
  },
  {
    q: "Kann die Zentrale GBP-Änderungen für alle Standorte gleichzeitig vornehmen?",
    a: "Ja. Netzwerk-Administratoren können GBP-Änderungen, die auf alle Standorte zutreffen — wie saisonale Ankündigungen, Marken-Updates oder systemweite Angebote — einmal erstellen und auf alle oder ausgewählte Standorte anwenden.",
  },
  {
    q: "Was passiert, wenn ein Franchisenehmer seinen Standort in Stacc nicht aktiv verwaltet?",
    a: "Das System funktioniert weiterhin — Stacc überwacht Rankings, Bewertungen und Citations automatisch und sendet Warnungen, wenn Maßnahmen erforderlich sind. Ein nicht aktiver Franchisenehmer verpasst Warnungen, aber die Zentrale sieht alle Standort-Performance-Daten und kann eingreifen.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc für Franchises",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Stacc gibt Franchise-Systemen zentrale Kontrolle über lokales SEO bei jedem Franchisenehmer. Einheitliche Markenstandards, lokale Sichtbarkeit und vollständige Transparenz über das gesamte Netzwerk.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://thestacc.com/de/loesungen/" },
        { "@type": "ListItem", "position": 3, "name": "Für Franchises", "item": "https://thestacc.com/de/loesungen/franchises/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Lokales SEO für Franchises — Markenstandards und lokale Sichtbarkeit in einem System | theStacc"
  description="Stacc gibt Franchise-Systemen zentrale Kontrolle über lokales SEO bei jedem Franchisenehmer. Einheitliche Markenstandards, lokale Sichtbarkeit und vollständige Transparenz über das gesamte Netzwerk."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Für Franchise-Systeme</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Franchise-SEO: Markenstandards<br />und lokale Sichtbarkeit<br /><span style="color:#4f39f6;">gleichzeitig sicherstellen.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Franchise-Geber benötigen einheitliche Markenstandards und vollständige Transparenz über alle Standorte. Franchisenehmer benötigen lokale Sichtbarkeit ohne technisches SEO-Wissen. Stacc liefert beides — von einer Plattform.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Demo anfragen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Skaliert von 5 bis 500+ Franchise-Standorte · Hierarchische Zugriffsebenen · DSGVO-konform
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'Zentral',  label: 'Kontrollierte Markenstandards' },
              { value: 'Lokal',    label: 'Individuelle Standort-Sichtbarkeit' },
              { value: '100%',     label: 'Transparenz über das gesamte Netzwerk' },
              { value: '4.9★',    label: 'Kundenbewertung' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Für Franchise-Systeme</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Was Franchise-Systeme ohne die<br />richtige Infrastruktur erleben.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Franchisenehmer betreiben lokales SEO inkonsistent — oder gar nicht.',
              body: 'Manche Franchisenehmer sind SEO-affin, andere nicht. Ohne eine zentrale Plattform ist die lokale SEO-Qualität über Standorte hinweg stark variierend. Das schadet dem Gesamtnetz-Ruf und macht es unmöglich, einheitliche Standards durchzusetzen.',
            },
            {
              icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
              title: 'Ohne Transparenz wissen Franchisegeber nicht, welche Standorte underperformen.',
              body: 'Wenn Franchise-Zentrale keine zentralen Reporting-Tools hat, erfahren Sie von Problemen erst, wenn sie in Kundenbeschwerden, Vertragsgesprächen oder sinkenden Systemumsätzen auftauchen. Zu diesem Zeitpunkt ist der Schaden bereits angerichtet.',
            },
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Inkonsistente GBP-Profile untergraben die Markenidentität.',
              body: 'Wenn 30 Standorte 30 verschiedene GBP-Profilfotos, Beschreibungen und Öffnungszeiten-Formate haben, wirkt die Marke uneinheitlich. Kunden, die von einem Standort zum anderen wechseln, haben unterschiedliche Erwartungen — und das schadet der Gesamtmarke.',
            },
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Manuelle Franchise-Berichte für die Zentrale sind aufwändig zu erstellen.',
              body: 'Aggregierte Performance-Berichte für die Franchise-Zentrale manuell aus 50 Standortberichten zusammenzubauen ist kein skalierbarer Prozess. Und ohne diese Berichte fehlt der Zentrale das Fundament für Entscheidungen über Support, Investitionen und Standort-Priorisierung.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── WHAT CHANGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Franchise-SEO mit und ohne Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Zentrale Kontrolle. Lokale Ausführung.<br />Vollständige Transparenz.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Ohne Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Mit Stacc</div>
          </div>
          {[
            { label: 'GBP-Profil-Standards',           before: 'Jeder Franchisenehmer individuell',         after: 'Zentrale Vorlagen, lokale Anpassung' },
            { label: 'Netzwerk-Performance-Überblick', before: 'Manuell aus Einzelberichten',               after: 'Echtzeit-Netzwerk-Dashboard' },
            { label: 'Bewertungsmonitoring',           before: 'Franchisegeber nicht informiert',           after: 'Zentrale Warnungen + lokale Ansicht' },
            { label: 'Citation-Konsistenz',            before: 'Standortweise variierend',                  after: 'Kontinuierlich über alle Standorte' },
            { label: 'Franchisenehmer-Onboarding',     before: '2–4 Stunden SEO-Setup',                    after: 'Unter 45 Minuten geführte Einrichtung' },
            { label: 'Performance-Reporting an Zentrale', before: 'Manueller Aufwand, Wochen Vorlaufzeit', after: 'Automatisch generiert und geliefert' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE HIGHLIGHTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Für Franchise-Systeme entwickelt</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Zentrale Kontrolle und lokale Ausführung<br />in einem System.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Hierarchical Access -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Hierarchische Zugriffsebenen</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Franchisegeber sehen alles. Franchisenehmer sehen ihr Eigenes.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Franchise-Geber haben vollständige Transparenz über das gesamte Netzwerk — aggregierte Berichte, Standort-Vergleiche, Ausreißer-Erkennung. Franchisenehmer haben Zugang zu ihrem eigenen Standort-Dashboard mit allen lokalen SEO-Daten — ohne andere Standorte zu sehen.
              </p>
              <ul class="mt-6 space-y-3">
                {['Netzwerk-Administratoren sehen alle Standorte und aggregierte Berichte', 'Regional-Manager sehen zugewiesene Standortgruppen', 'Franchisenehmer sehen nur ihren eigenen Standort', 'Vollständige Audit-Trails für alle Änderungen und Zugriffe'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Zugriffsebenen-Übersicht</p>
              <div class="space-y-3">
                {[
                  { role: 'Netzwerk-Administrator', scope: 'Alle 23 Standorte + Berichte', color: '#4f39f6', bg: '#f5f3ff' },
                  { role: 'Regional-Manager Süd', scope: 'München, Frankfurt, Stuttgart', color: '#0284c7', bg: '#f0f9ff' },
                  { role: 'Regional-Manager Nord', scope: 'Hamburg, Bremen, Kiel', color: '#0284c7', bg: '#f0f9ff' },
                  { role: 'Franchisenehmer München', scope: 'Nur eigener Standort', color: '#059669', bg: '#f0fdf4' },
                ].map(item => (
                  <div class="flex items-center gap-3 rounded-xl px-4 py-3" style={`background:${item.bg};`}>
                    <div class="h-7 w-7 rounded-lg flex items-center justify-center shrink-0" style={`background:${item.color};`}>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z"/></svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{item.role}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{item.scope}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Brand Standards -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Netzwerk-weite GBP-Aktion</p>
              <div class="rounded-xl bg-[#f5f3ff] p-4 mb-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Weihnachts-Angebot 2024</p>
                <p class="font-mono text-[10px] text-[#79716b] mt-1">Erstellt von: Franchise-Zentrale</p>
              </div>
              <div class="space-y-2">
                {[
                  { loc: 'München Schwabing', status: 'Veröffentlicht' },
                  { loc: 'Hamburg Nord', status: 'Veröffentlicht' },
                  { loc: 'Berlin Mitte', status: 'Veröffentlicht' },
                  { loc: 'Frankfurt Sachsenhausen', status: 'Veröffentlicht' },
                  { loc: 'Alle 23 weiteren Standorte', status: 'Veröffentlicht' },
                ].map(item => (
                  <div class="flex items-center justify-between rounded-lg bg-[#fafaf9] px-3 py-2">
                    <span class="font-sans text-[12px] text-[#374151]">{item.loc}</span>
                    <span class="font-mono text-[10px] font-semibold text-[#059669]">{item.status}</span>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Einmal erstellt — für alle Standorte ausgerollt</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Netzwerk-weite Markenstandards</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Einheitliche Markenpräsenz. Lokale Relevanz.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Franchise-Zentrale kann GBP-Profil-Templates, Citation-Standards und Posting-Richtlinien zentral definieren. Franchisenehmer wenden sie auf ihren Standort an, mit lokaler Anpassungsmöglichkeit innerhalb definierter Grenzen. Einheitliche Marke ohne Flexibilitätsverlust.
              </p>
              <ul class="mt-6 space-y-3">
                {['Zentrale GBP-Profil-Templates mit lokalen Anpassungsfeldern', 'Standardisierte Citation-Informationen für alle Standorte', 'Netzwerk-weite GBP-Posts für systemweite Ankündigungen', 'Lokale Posts für standortspezifische Angebote und Ereignisse'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Eine Woche mit Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Wie Franchise-Zentrale und Franchisenehmer<br />dieselbe Woche erleben.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: 'Montag, Franchise-Zentrale', title: 'Netzwerk-Wochenbericht verfügbar.', body: 'Alle Standorte aggregiert: Durchschnitts-Rankings, neue Bewertungen, GBP-Aktivität. Sofortige Identifizierung der 3 Standorte, die diese Woche Aufmerksamkeit benötigen.', type: 'automated' },
