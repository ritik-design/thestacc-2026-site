        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '2.3×', label: 'Mehr Klicks, wenn Top-3 statt Position 5+', sub: 'in Google Maps-Suchergebnissen' },
            { value: '30min', label: 'Wöchentlicher SEO-Zeitaufwand', sub: 'statt stundenlanger manueller Überprüfungen' },
