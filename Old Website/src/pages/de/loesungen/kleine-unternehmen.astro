---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Brauche ich SEO-Kenntnisse, um Stacc zu verwenden?",
    a: "Nein. Stacc ist so gestaltet, dass lokale Unternehmer ohne technisches Vorwissen es effektiv nutzen können. Die Plattform erklärt, was die Daten bedeuten, und gibt klare Empfehlungen, was als nächstes zu tun ist — in verständlicher Sprache.",
  },
  {
    q: "Wie viel Zeit muss ich wöchentlich in lokales SEO investieren?",
    a: "Die meisten kleinen Unternehmen verbringen 20–30 Minuten pro Woche mit Stacc — die wöchentliche Zusammenfassung anschauen, auf neue Bewertungen antworten und eventuell einen GBP-Post veröffentlichen. Das Monitoring und die Datenerfassung laufen automatisch.",
  },
  {
    q: "Was ist im Starter-Plan enthalten?",
    a: "Der Starter-Plan enthält Rank Tracking für bis zu 5 Keywords pro Standort, Bewertungsmonitoring für Google Business Profile, Citation-Audit und GBP-Profil-Überwachung. Für die meisten kleinen Einzelstandort-Unternehmen ist das ein vollständiges lokales SEO-System.",
  },
  {
    q: "Funktioniert Stacc für jede Art von lokalem Unternehmen?",
    a: "Ja. Stacc funktioniert für jedes Unternehmen, das in lokalen Google-Suchen erscheinen möchte — Handwerker, Restaurants, Arztpraxen, Kosmetik-Studios, Einzelhändler, Dienstleistungsunternehmen. Wenn Ihre Kunden lokal suchen, hilft Stacc Ihnen, gefunden zu werden.",
  },
  {
    q: "Was passiert nach dem 14-tägigen Testzeitraum?",
    a: "Nach dem Test können Sie einen Plan wählen, der zu Ihrem Unternehmen passt. Wenn Stacc nicht das Richtige für Sie ist, endet der Test einfach ohne Kosten — keine automatische Verlängerung, kein Kleingedrucktes.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc für Kleine Unternehmen",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Stacc gibt kleinen lokalen Unternehmen die SEO-Tools, die große Unternehmen verwenden — ohne technisches Wissen, ohne großes Budget, ohne täglichen Aufwand.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://thestacc.com/de/loesungen/" },
        { "@type": "ListItem", "position": 3, "name": "Für Kleine Unternehmen", "item": "https://thestacc.com/de/loesungen/kleine-unternehmen/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Lokales SEO für Kleine Unternehmen — Gefunden werden in Google, ohne SEO-Experte zu sein | theStacc"
  description="Stacc gibt kleinen lokalen Unternehmen die SEO-Tools, die große Unternehmen verwenden — ohne technisches Wissen, ohne großes Budget, ohne täglichen Aufwand."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Für Kleine und Mittelständische Unternehmen</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokale Kunden suchen täglich<br />nach Ihren Services.<br /><span style="color:#4f39f6;">Sie finden nur Ihre Mitbewerber.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc gibt kleinen lokalen Unternehmen die SEO-Tools, die zuvor nur Unternehmen mit eigenen Marketing-Teams hatten. Verfolgen Sie Ihre Google Maps-Rankings, verwalten Sie Bewertungen und halten Sie Ihr GBP-Profil aktuell — ohne SEO-Experte zu sein.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              14 Tage kostenlos testen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Ab €49/Monat · 14 Tage kostenlos · Keine Kreditkarte erforderlich · DSGVO-konform
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: 'Täglich', label: 'Ranking-Updates für Ihren Standort' },
              { value: '30min',   label: 'Wöchentlicher Zeitaufwand für lokales SEO' },
              { value: 'Top 3',   label: 'Google Maps-Ziel für lokale Sichtbarkeit' },
              { value: '4.9★',   label: 'Kundenbewertung' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Für lokale Kleinunternehmer</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Was lokale Kleinunternehmer<br />täglich erleben.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Lokale Kunden suchen nach Ihren Services — und finden Ihre Mitbewerber.',
              body: 'Jeden Tag suchen Menschen in Ihrer Stadt nach dem, was Sie anbieten. Wenn Sie nicht in den ersten drei Google Maps-Ergebnissen erscheinen, entscheiden sie sich für jemanden, der das tut — ohne jemals zu wissen, dass Ihr Unternehmen existiert.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Ohne Daten wissen Sie nicht, was funktioniert und was nicht.',
              body: 'Sie haben Ihr GBP-Profil erstellt, aber Sie wissen nicht, wie viele Leute es sehen. Sie haben Öffnungszeiten aktualisiert, aber Sie wissen nicht, ob Ihr Ranking dadurch gestiegen ist. Ohne Daten optimieren Sie im Dunkeln.',
            },
            {
              icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
              title: 'Negative Bewertungen, von denen Sie zu spät erfahren, schaden Ihrem Ruf dauerhaft.',
              body: 'Ein Kunde hinterlässt eine 2-Sterne-Bewertung. Eine Woche später entdecken Sie sie — nachdem 50 potenzielle Kunden sie gelesen haben, ohne dass jemand geantwortet hat. Für einen kleinen Betrieb kann eine unbeantwortete negative Bewertung Wochen an Neukunden kosten.',
            },
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'SEO-Tools sind entweder zu komplex oder zu teuer für kleine Unternehmen.',
              body: 'Die meisten SEO-Plattformen wurden für Agenturen oder Großunternehmen gebaut. Sie sind voller Funktionen, die Sie nie brauchen werden, und kosten Hunderte Euro im Monat. Was Sie brauchen: einfache, klare Tools für lokale Sichtbarkeit — zu einem Preis, der für ein kleines Unternehmen Sinn macht.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── WHAT CHANGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was sich mit Stacc ändert</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Lokales SEO, das für kleine<br />Unternehmen gebaut wurde.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Ohne Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Mit Stacc</div>
          </div>
          {[
            { label: 'Google Maps-Rankings',    before: 'Unbekannt — manuelle Suche nötig',         after: 'Täglich verfolgt und gemeldet' },
            { label: 'Neue Bewertungen',        before: 'Zufällig entdeckt',                        after: 'Sofortige Warnungen für jede neue Bewertung' },
            { label: 'GBP-Profil-Status',       before: 'Selten überprüft',                         after: 'Laufend überwacht und optimiert' },
            { label: 'Citation-Konsistenz',     before: 'Nie systematisch geprüft',                 after: 'Automatisch in 50+ Verzeichnissen überwacht' },
            { label: 'SEO-Zeitaufwand',         before: '2–4 Stunden/Woche manuelle Überprüfung',   after: '30 Minuten/Woche im Dashboard' },
            { label: 'Erforderliches SEO-Wissen', before: 'Technisches Fachwissen nötig',           after: 'Keine Vorkenntnisse erforderlich' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE HIGHLIGHTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Für kleine Unternehmen entwickelt</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alles, was Sie für lokale Sichtbarkeit<br />brauchen. Nichts, was Sie nicht brauchen.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Easy to understand -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Einfach zu verstehen</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Stacc erklärt Ihnen, was wichtig ist — und was zu tun ist.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Sie müssen kein SEO-Experte sein. Stacc übersetzt technische Rankingdaten in verständliche Einblicke: Ihr Ranking ist diese Woche um 3 Positionen gefallen, weil Ihr GBP-Profil in letzter Zeit wenig Aktivität hatte. Hier sind zwei Schritte, die helfen können.
              </p>
              <ul class="mt-6 space-y-3">
                {['Klare Erklärungen statt technischer Fachbegriffe', 'Priorisierte Handlungsempfehlungen, was als nächstes zu tun ist', 'Wöchentlicher Zusammenfassungs-Bericht für Ihren Standort', 'Keine Interpretation von Daten erforderlich — Stacc tut das für Sie'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Ihr wöchentlicher Überblick</p>
                <span class="rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">Diese Woche</span>
              </div>
              <div class="space-y-3">
                {[
                  { label: 'Klempner Hamburg', rank: '#2 in Google Maps', change: '+3', good: true },
                  { label: 'Klempner Notdienst', rank: '#4 in Google Maps', change: '0', good: true },
                  { label: 'Rohrreinigung Hamburg', rank: '#6 in Google Maps', change: '-1', good: false },
                ].map(kw => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{kw.label}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{kw.rank}</p>
                    </div>
                    <span class={`font-mono text-[11px] font-semibold shrink-0 ${kw.good ? 'text-[#059669]' : 'text-[#ef4444]'}`}>{kw.change !== '0' ? kw.change : '—'}</span>
                  </div>
                ))}
                <div class="mt-3 rounded-xl bg-[#fef3c7] border border-[#fde68a] px-4 py-3">
                  <p class="font-sans text-[12px] font-semibold text-[#92400e]">Empfehlung für diese Woche</p>
                  <p class="font-sans text-[11px] text-[#78350f] mt-1">Fügen Sie einen GBP-Post hinzu, um die Aktivität zu erhöhen. Ihr Profil hatte 10 Tage keine Updates.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- All-in-one -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Ihr lokales SEO-Dashboard</p>
              <div class="space-y-3">
                {[
                  { module: 'Rank Tracking', detail: '3 Keywords verfolgt · Täglich aktualisiert', status: 'Aktiv' },
                  { module: 'Bewertungs-Monitoring', detail: '4.7★ Durchschnitt · 2 neue diese Woche', status: 'Aktiv' },
                  { module: 'GBP-Verwaltung', detail: 'Profil vollständig · Letzter Post: 3 Tage', status: 'Gut' },
                  { module: 'Citation-Überwachung', detail: '47/50 Verzeichnisse korrekt', status: 'Prüfen' },
                ].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{item.module}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{item.detail}</p>
                    </div>
                    <span class={`font-mono text-[10px] font-semibold shrink-0 ${item.status === 'Aktiv' || item.status === 'Gut' ? 'text-[#059669]' : 'text-[#d97706]'}`}>{item.status}</span>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alles in einem Tool · Kein zweites Login</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Alles, was ein lokales Unternehmen braucht</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Rankings, Bewertungen, GBP und Citations — in einem Tool.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Statt mehrere Tools mit mehreren Logins zu verwalten, haben Sie alles in einer Plattform: Rank Tracking zeigt, wo Sie stehen. Bewertungsmonitoring stellt sicher, dass Sie sofort reagieren können. GBP-Verwaltung hält Ihr Profil aktuell. Citation-Überwachung stellt sicher, dass Ihre Daten überall korrekt sind.
              </p>
              <ul class="mt-6 space-y-3">
                {['Tägliches Rank Tracking für Ihre lokalen Keywords', 'Sofortige Bewertungswarnungen über alle Plattformen', 'GBP-Profil-Überwachung und Optimierungsempfehlungen', 'Citation-Audit und kontinuierliche Konsistenzüberwachung'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Eine Woche mit Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Wie Ihr Wochenstart als kleines Unternehmen<br />mit Stacc aussieht.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: 'Montagmorgen, 10 Minuten', title: 'Wöchentliche Zusammenfassung angeschaut.', body: 'Rankings diese Woche: 2 Positionen gestiegen für "Klempner [Stadt]", stabil für andere Keywords. Zwei neue Bewertungen vom Wochenende — beide 5 Sterne, beide noch ohne Antwort. Das erledigen Sie in den nächsten 10 Minuten.', type: 'automated' },
            { time: 'Dienstag, sofortige Warnung', title: 'Neue 3-Sterne-Bewertung — sofort beantwortet.', body: 'Stacc sendet eine Warnung. Sie lesen die Bewertung, verstehen das Problem und antworten professionell innerhalb einer Stunde. Nicht erst nächste Woche — innerhalb einer Stunde.', type: 'alert' },
            { time: 'Mittwoch, 15 Minuten', title: 'GBP-Optimierungsempfehlung umgesetzt.', body: 'Stacc empfiehlt, ein aktuelles Foto Ihres Unternehmens hinzuzufügen. Sie laden es hoch, fügen einen aktuellen GBP-Post hinzu — 15 Minuten Arbeit, die Ihrer lokalen Sichtbarkeit hilft.', type: 'onboarding' },
