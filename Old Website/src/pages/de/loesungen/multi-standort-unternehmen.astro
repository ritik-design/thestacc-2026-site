---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Für wie viele Standorte ist Stacc ausgelegt?",
    a: "Stacc unterstützt von einem einzelnen Standort bis zu 500+ Standorten in einem Konto. Das Pricing skaliert mit der Anzahl der Standorte — Sie zahlen nur für das, was Sie verwalten.",
  },
  {
    q: "Kann ich verschiedene Teams verschiedenen Standorten zuweisen?",
    a: "Ja. Sie können standortspezifische Zugangsrechte für verschiedene Benutzer einrichten. Regionale Manager sehen nur ihre Standorte, während Administratoren alle Standorte überblicken.",
  },
  {
    q: "Wie lange dauert die Einrichtung mehrerer Standorte?",
    a: "Die meisten Multi-Standort-Konten werden in einem einzigen Einrichtungs-Session vollständig konfiguriert. Mit der Bulk-Import-Funktion können Sie alle Standortinformationen auf einmal hochladen. Einzel-Standort-Feinabstimmung (spezifische Keywords, GBP-Verbindung) dauert 10–15 Minuten pro Standort.",
  },
  {
    q: "Verfolgt Stacc Rankings standortspezifisch?",
    a: "Ja. Jeder Standort hat seine eigene Keyword-Liste und verfolgt Rankings für seinen spezifischen geografischen Markt. Ein Standort in Berlin verfolgt andere lokale Keywords als ein Standort in München — selbst wenn es dasselbe Unternehmenskonzept ist.",
  },
  {
    q: "Kann ich Berichte für alle Standorte zusammen und für jeden Standort einzeln erhalten?",
    a: "Ja. Stacc kann sowohl aggregierte Portfolio-Berichte (Zusammenfassung aller Standorte) als auch individuelle Standortberichte generieren — nach unterschiedlichen Zeitplänen und an unterschiedliche Empfänger.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc für Multi-Standort-Unternehmen",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Verwalten Sie Rankings, Bewertungen, GBP und Citations für alle Ihre Standorte von einer Plattform aus. Skalieren Sie Ihr lokales SEO ohne proportional mehr Zeit aufzuwenden.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://thestacc.com/de/loesungen/" },
        { "@type": "ListItem", "position": 3, "name": "Multi-Standort-Unternehmen", "item": "https://thestacc.com/de/loesungen/multi-standort-unternehmen/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Lokales SEO für Multi-Standort-Unternehmen — Alle Standorte in einem Dashboard | theStacc"
  description="Verwalten Sie Rankings, Bewertungen, GBP und Citations für alle Ihre Standorte von einer Plattform aus. Skalieren Sie Ihr lokales SEO ohne proportional mehr Zeit aufzuwenden."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Für Multi-Standort-Unternehmen</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokales SEO für 10 Standorte<br />sollte nicht 10× mehr Zeit kosten.<br /><span style="color:#4f39f6;">Mit Stacc tut es das nicht.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Verwalten Sie Rankings, Bewertungen, GBP-Profile und Citations für alle Ihre Standorte von einem Dashboard aus. Skalieren Sie Ihre lokale SEO-Präsenz ohne proportional mehr Zeit zu investieren.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Demo anfragen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Skaliert von 2 bis 500+ Standorte · Täglich aktualisierte Rankings · DSGVO-konform
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '500+',    label: 'Standorte in einem Dashboard' },
              { value: 'Täglich', label: 'Ranking-Updates für jeden Standort' },
              { value: 'Zentral', label: 'Alle Standorte in einer Plattform' },
              { value: '4.9★',   label: 'Kundenbewertung' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Für Multi-Standort-Unternehmen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Die Herausforderungen, die jedes<br />Multi-Standort-Unternehmen kennt.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Separate Tools für jeden Standort machen den Überblick unmöglich.',
              body: 'Wenn jeder Standort ein eigenes Tool, einen eigenen Login und ein eigenes Reporting-Format hat, verbringen Sie mehr Zeit mit Navigation zwischen Systemen als mit der eigentlichen Optimierung. Probleme bleiben unentdeckt, weil die Überprüfung zu aufwändig ist.',
            },
            {
              icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
              title: 'Ranking-Probleme an einem Standort wirken sich auf Ihren gesamten Ruf aus.',
              body: 'Ein Standort mit sinkenden Rankings oder negativen Bewertungen, den Sie nicht im Blick haben, kostet Ihnen täglich Kunden. Bei mehreren Standorten ist das Risiko proportional höher — aber die manuelle Überprüfungskapazität bleibt gleich.',
            },
            {
              icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
              title: 'Inkonsistente Unternehmensdaten über Standorte schaden Ihrem gesamten Netzwerk.',
              body: 'Wenn Citations für Standort A korrekt sind, aber für Standort C falsch, verliert das gesamte Unternehmen lokale Ranking-Kraft. NAP-Konsistenz muss für alle Standorte gleichzeitig gepflegt werden — was manuell fast unmöglich ist.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Wachstum verursacht operationale Komplexität bevor es Umsatz bringt.',
              body: 'Jeder neue Standort verdoppelt nicht den Verwaltungsaufwand — er multipliziert ihn. Ohne die richtige Infrastruktur wird jeder neue Standort zum Hemmnis statt zum Wachstumstreiber.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── WHAT CHANGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was sich mit Stacc ändert</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alle Standorte. Eine Plattform.<br />Skalierbar.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Ohne Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Mit Stacc</div>
          </div>
          {[
            { label: 'Rankings verfolgen',        before: 'Jeder Standort separat prüfen',             after: 'Alle Standorte in einem Dashboard' },
            { label: 'Bewertungen überwachen',    before: 'Manuelle Prüfung je Plattform je Standort', after: 'Echtzeit-Warnungen für alle Standorte' },
            { label: 'GBP-Profile pflegen',       before: 'Separater Login für jeden Standort',        after: 'Alle GBP-Profile zentral verwalten' },
            { label: 'Citations-Konsistenz',      before: 'Periodische manuelle Audits',               after: 'Kontinuierliche automatische Überwachung' },
            { label: 'Performance-Vergleich',     before: 'Manuell aus Einzelberichten zusammenstellen', after: 'Sofortiger Standortvergleich im Dashboard' },
            { label: 'Neue Standorte einrichten', before: 'Stunden pro Standort',                      after: 'Minuten mit geführter Einrichtung' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE HIGHLIGHTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Für Multi-Standort entwickelt</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede Funktion, die Sie für alle<br />Standorte benötigen.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Portfolio Overview -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Portfolio-Übersicht</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Sehen Sie alle Standorte auf einen Blick. Gehen Sie tiefer, wenn nötig.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Das Portfolio-Dashboard zeigt aggregierte Metriken über alle Standorte — und daneben die individuelle Standortleistung. Erkennen Sie Ausreißer sofort: welcher Standort underperformt, wo Bewertungen fallen, wo Rankings sinken.
              </p>
              <ul class="mt-6 space-y-3">
                {['Aggregierte Portfolio-Metriken über alle Standorte', 'Standortvergleich nach Rankings, Bewertungen, GBP-Aktivität', 'Automatische Markierung von Standorten, die unter dem Durchschnitt liegen', 'Klick auf einen Standort für vollständige Tiefenanalyse'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center justify-between">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Portfolio-Übersicht</p>
                <span class="rounded-full bg-[#f5f3ff] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#4f39f6]">4 Standorte</span>
              </div>
              <div class="space-y-3">
                {[
                  { name: 'Berlin Mitte', rank: '#2 lokal', reviews: '4.8★', status: 'gut' },
                  { name: 'Hamburg Nord', rank: '#5 lokal', reviews: '4.2★', status: 'aufmerksamkeit' },
                  { name: 'München Schwabing', rank: '#1 lokal', reviews: '4.9★', status: 'gut' },
                  { name: 'Frankfurt Sachsenhausen', rank: '#3 lokal', reviews: '4.6★', status: 'gut' },
                ].map(loc => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="h-7 w-7 rounded-lg bg-[#4f39f6] flex items-center justify-center shrink-0">
                      <span class="font-mono text-[9px] font-bold text-white">{loc.name[0]}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{loc.name}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{loc.rank} · {loc.reviews}</p>
                    </div>
                    <span class={`font-mono text-[10px] font-semibold shrink-0 ${loc.status === 'gut' ? 'text-[#059669]' : 'text-[#d97706]'}`}>{loc.status === 'gut' ? 'Gut' : 'Prüfen'}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Centralized GBP -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">GBP-Verwaltung · Alle Standorte</p>
              <div class="space-y-3">
                {[
                  { action: 'Weihnachts-Öffnungszeiten', scope: 'Alle 4 Standorte', status: 'Veröffentlicht' },
                  { action: 'Neues Produktfoto', scope: 'Berlin, Hamburg', status: 'Geplant' },
                  { action: 'Angebot Januar', scope: 'Alle 4 Standorte', status: 'Entwurf' },
                  { action: 'GBP-Profil-Update', scope: 'München', status: 'Veröffentlicht' },
                ].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <div class="flex-1 min-w-0">
                      <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{item.action}</p>
                      <p class="font-mono text-[10px] text-[#79716b]">{item.scope}</p>
                    </div>
                    <span class={`font-mono text-[10px] font-semibold shrink-0 ${item.status === 'Veröffentlicht' ? 'text-[#059669]' : item.status === 'Geplant' ? 'text-[#4f39f6]' : 'text-[#79716b]'}`}>{item.status}</span>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Einmal erstellen — für alle Standorte veröffentlichen</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Zentralisierte GBP-Verwaltung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Alle Google Business Profile-Standorte von einer Oberfläche aus verwalten.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Anstatt sich bei jedem GBP-Konto separat anzumelden, verwalten Sie alle Profile — Posts, Fotos, Öffnungszeiten, Angebote — direkt in Stacc. Änderungen, die auf alle Standorte zutreffen, einmal anwenden.
              </p>
              <ul class="mt-6 space-y-3">
                {['GBP-Posts für alle oder ausgewählte Standorte gleichzeitig veröffentlichen', 'Öffnungszeiten-Updates für alle Standorte auf einmal anwenden', 'Alle GBP-Profilaufrufe und Aktionen in einem Bericht', 'Automatische Warnung bei GBP-Profilproblemen über alle Standorte'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Eine Woche mit Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Eine Woche, in der Sie 10 Standorte<br />mit Stacc verwalten.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: '8:00 Uhr Montag', title: 'Portfolio-Übersicht in 2 Minuten.', body: 'Sie öffnen Stacc und sehen sofort: Rankings über alle Standorte, neue Bewertungen vom Wochenende, GBP-Aktivität letzte Woche. Was früher 2 Stunden manuelle Überprüfung dauerte, dauert jetzt 2 Minuten.', type: 'automated' },
            { time: '9:00 Uhr Mittwoch', title: 'Standort Hamburg hat ein Bewertungsproblem.', body: 'Stacc markierte eine 2-Stern-Bewertung am Dienstag. Sie haben die Warnung sofort erhalten, den Kontext gelesen und bis Mittwoch morgen eine durchdachte Antwort hinterlassen. Andere lokale Unternehmen hätten es eine Woche später bemerkt.', type: 'alert' },
            { time: '14:00 Uhr Donnerstag', title: 'Neuen Standort in 30 Minuten eingerichtet.', body: 'Neuer Standort geöffnet? Keywords hinzugefügt, GBP verbunden, Citations-Baseline erfasst, Berichts-Zeitplan konfiguriert. Der neue Standort ist vollständig aktiv in Stacc, bevor die Kaffeepause endet.', type: 'onboarding' },
