---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Ist das White-Label-Dashboard in allen Plänen verfügbar?",
    a: "White-Label-Berichte — Ihr Logo, Ihre Farben, Ihre Domain — sind in den Growth- und Scale-Plänen verfügbar. Der Starter-Plan enthält Berichte mit Stacc-Branding. Sie können jederzeit ein Upgrade durchführen, und bestehende Berichts-Zeitpläne werden automatisch übertragen.",
  },
  {
    q: "Wie viele Kundenkonten kann ich verwalten?",
    a: "Alle Pläne unterstützen unbegrenzte Kundenkonten. Das Pricing basiert auf der Anzahl der Standorte, die Sie verwalten, nicht auf der Anzahl der Kunden. Eine Agentur mit 20 Kunden mit einem Standort zahlt dasselbe wie eine Agentur mit 10 Kunden mit zwei Standorten — wenn die Gesamtzahl der Standorte gleich ist.",
  },
  {
    q: "Kann ich kontrollieren, was Kunden in ihrem Dashboard sehen?",
    a: "Ja. Sie entscheiden genau, welche Daten, Funktionen und Berichte jeder Kunde sehen kann. Sie können die Sichtbarkeit nach Modul, Datumsbereich oder Standort einschränken. Kunden sehen, was für sie nützlich ist. Sie behalten die vollständige Sichtbarkeit über alles.",
  },
  {
    q: "Wie lange dauert das Onboarding eines neuen Kunden?",
    a: "Die meisten neuen Kunden sind vollständig eingerichtet — Standorte hinzugefügt, Keywords festgelegt, GBP verbunden und automatischer Berichts-Zeitplan aktiv — in weniger als 45 Minuten. Für Multi-Standort-Kunden mit mehr als 10 Standorten planen Sie eine Stunde. Danach verwaltet Stacc alles automatisch.",
  },
  {
    q: "Ersetzt Stacc meine aktuellen SEO-Tools?",
    a: "Für lokales SEO speziell — Rank Tracking, Citations-Verwaltung, GBP-Verwaltung, Bewertungsmonitoring und Kunden-Berichte — ja. Die meisten Agenturen konsolidieren 4 bis 6 separate Tools in Stacc und reduzieren ihr Tool-Budget um 60–70%.",
  },
  {
    q: "Kann ich Stacc als Service an meine Kunden weiterverkaufen?",
    a: "Ja. Viele Agenturen verwenden Stacc als Basisplattform für ihre lokalen SEO-Mandate. Mit White-Label-Berichten und Kunden-Portalen interagieren Kunden jederzeit mit Ihrer Marke — Stacc ist unsichtbar.",
  },
  {
    q: "Welche Integrationen sind für Kunden-Berichte verfügbar?",
    a: "Berichte werden per E-Mail an Kunden-Postfächer gesendet, sind über White-Label-Kunden-Portale verfügbar und können Daten an Google Sheets, Looker Studio und Slack für Agenturen mit benutzerdefinierten Reporting-Workflows senden.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc für Agenturen",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Die lokale SEO-Plattform für Agenturen. Verwalten Sie Rankings, GBP, Bewertungen und automatisierte White-Label-Berichte für jeden Kunden von einem Dashboard aus.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Lösungen", "item": "https://thestacc.com/de/loesungen/" },
        { "@type": "ListItem", "position": 3, "name": "Für Agenturen", "item": "https://thestacc.com/de/loesungen/agenturen/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="SEO-Tool für Agenturen — Jeden Kunden verwalten, alles automatisieren | theStacc"
  description="theStacc ist die lokale SEO-Plattform für Agenturen. Verwalten Sie Rankings, GBP, Bewertungen und automatisierte White-Label-Berichte für jeden Kunden von einem Dashboard aus."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Für SEO-Agenturen · White-Label inklusive</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Das SEO-Tool,<br />das für Agenturen gebaut wurde.<br /><span style="color:#4f39f6;">Jeden Kunden verwalten. Alles automatisieren.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Ein Dashboard für das lokale SEO jedes Kunden — Rank Tracking, GBP-Verwaltung, Bewertungsmonitoring, Citations und White-Label-Berichte. Alles automatisiert. Alles unter Ihrer Marke.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Demo anfragen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Preise ansehen
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            400+ Agenturen · White-Label in allen Growth-Plänen · Einrichtung in weniger als 45 Minuten
          </p>

          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '400+',  label: 'Agenturen nutzen Stacc' },
              { value: '45min', label: 'Durchschnittliche Onboarding-Zeit' },
              { value: '80%',   label: 'Weniger Zeit für manuelle Berichte' },
              { value: '3×',    label: 'Mehr Kunden, gleiches Team' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Wenn Sie eine SEO-Agentur leiten</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Kennen Sie genau dieses Gefühl.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2">
          {[
            {
              icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
              title: 'Die Berichts-Steuer.',
              body: 'Jeden Montagmorgen baut jemand in Ihrem Team Berichte statt echtes SEO zu betreiben. 4 Stunden pro Kunde im Monat. Mit 20 Kunden sind das 80 Stunden im Monat — ein ganzer Vollzeitjob, der ausschließlich PDFs erstellt, die niemand manuell erstellen wollte.',
            },
            {
              icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
              title: '"Ranken wir?" — ein Freitagabend.',
              body: 'Ein Kunde ruft an. Sie haben die Antwort nicht vor sich. Sie öffnen einen Inkognito-Tab. Sie gewinnen Zeit, während die Kunden das Vertrauen verlieren. Sie sollten nicht 20 Minuten brauchen, um eine Frage zu beantworten, die Sie bereits kennen sollten.',
            },
            {
              icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z',
              title: 'Sechs Tools. Sechs Logins. Ein Team ertrinkt in Tabs.',
              body: 'Rank-Tracker. Citations-Tool. GBP-Verwaltung. Bewertungsplattform. Reporting-Software. Analytics-Dashboard. Jeder Kunde braucht alle sechs. Jedes Tool hat seinen eigenen Login, sein eigenes Datenformat, seinen eigenen Exportprozess. Das Stack, das Sie effizienter machen sollte, bremst Sie aus.',
            },
            {
              icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
              title: 'Wachstum kostet Sie Kapazität bevor es Geld bringt.',
              body: 'Jeder neue Kunde bedeutet mehr Handarbeit — mehr Berichte zu erstellen, mehr Dashboards zu überprüfen, mehr Tabs zu öffnen. Irgendwann nehmen Sie keine neuen Kunden mehr an, um die Blutung zu stoppen. Das Unternehmen, das wachsen sollte, stößt an eine Decke aus Tabellen.',
            },
          ].map(p => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={p.icon}/></svg>
              </div>
              <p class="font-sans text-[1rem] font-semibold text-[#111827]">{p.title}</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── WHAT CHANGES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was sich mit Stacc ändert</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Eine Plattform. Jeder Kunde.<br />Nichts manuell.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#79716b]"></div>
            <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-[#6b7280]">Ohne Stacc</div>
            <div class="border-l border-[#4f39f6] bg-[#4f39f6] px-6 py-4 text-center font-mono text-[11px] font-bold uppercase tracking-[0.1em] text-white">Mit Stacc</div>
          </div>
          {[
            { label: 'Kunden-Berichte',           before: '4–6 Stunden manuell / Kunde / Monat', after: 'Automatisiert, pünktlich geliefert' },
            { label: 'Tool-Stack',                 before: '4–6 Tools, 4–6 Rechnungen',           after: 'Eine Plattform, eine Rechnung' },
            { label: 'Kunden-Transparenz',         before: 'Kunde fragt → Sie rennen',             after: 'Dashboard immer aktuell' },
            { label: 'Neukunden-Onboarding',       before: 'Mindestens 3–4 Stunden',              after: 'Weniger als 45 Minuten' },
            { label: 'Ranking-Monitoring',         before: 'Manuelle Überprüfung oder wöchentlicher Export', after: 'Automatische tägliche Warnungen' },
            { label: 'GBP-Verwaltung',             before: 'Separat in jedem Konto einloggen',    after: 'Alle Standorte an einem Ort' },
          ].map((row, i) => (
            <div class={`grid grid-cols-3 border-t border-[#e7e5e4] ${i % 2 === 0 ? 'bg-white' : 'bg-[#fafaf9]'}`}>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#374151]">{row.label}</div>
              <div class="border-l border-[#e7e5e4] px-6 py-4 text-center font-sans text-[13px] text-[#6b7280]">{row.before}</div>
              <div class="border-l border-[#c7c0fc] bg-[#f5f3ff] px-6 py-4 text-center font-sans text-[13px] font-semibold text-[#4f39f6]">{row.after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURE HIGHLIGHTS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Für Agenturen entwickelt</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede Funktion, die Ihre Agentur braucht.<br />Nichts, das im Weg steht.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- White Label -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">White-Label-Dashboard</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Kunden greifen auf Ihre Plattform zu. Nicht auf unsere.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Jede kundenseitige Oberfläche — das Dashboard, die Berichte, die E-Mail-Lieferung — trägt Ihr Logo, Ihre Farben und Ihre Domain. Kunden interagieren jederzeit mit Ihrer Marke. Sie sehen Stacc nie.
              </p>
              <ul class="mt-6 space-y-3">
                {['Ihr Logo und Ihre Markenfarben in allen Kunden-Dashboards', 'Berichte von Ihrer Domain geliefert — nicht von einer Stacc-E-Mail', 'Kunden-Portal-URLs unter Ihrer Agentur-Subdomain', 'Vollständige Entfernung aller Stacc-Marken in Growth- und Scale-Plänen'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <div class="mb-4 flex items-center gap-3">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">A</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Ihr Agenturname</p>
                  <p class="font-mono text-[10px] text-[#79716b]">berichte.ihreagentur.de</p>
                </div>
                <span class="ml-auto rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">Vollständig angepasst</span>
              </div>
              <div class="space-y-3">
                {['Kunden-Login-Portal', 'Wöchentliche Ranking-Berichte', 'Bewertungs-Monitoring-Warnungen', 'GBP-Leistungs-Dashboard', 'Citations-Status-Zusammenfassung'].map(item => (
                  <div class="flex items-center gap-3 rounded-xl bg-[#fafaf9] px-4 py-3">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#374151]">{item}</span>
                    <span class="ml-auto font-mono text-[10px] font-semibold text-[#4f39f6]">Ihre Marke</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Automated Reporting -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-5">Montag 7:00 Uhr · Kunden-Berichte versendet</p>
              {[
                { client: 'Klempnerei Schmidt', stat: '+4 Positionen' },
                { client: 'Zahnarzt Dr. Müller', stat: '3 neue Bewertungen' },
                { client: 'HVAC Sommer GmbH', stat: '28 GBP-Posts' },
                { client: 'Rechtsanwalt Hoffmann', stat: 'Top 3 lokal — 3 Keywords' },
              ].map(r => (
                <div class="flex items-center gap-4 border-t border-[#f5f3ff] py-3">
                  <div class="h-8 w-8 rounded-full bg-[#f5f3ff] flex items-center justify-center shrink-0">
                    <span class="font-mono text-[11px] font-semibold text-[#4f39f6]">{r.client[0]}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[13px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">Wöchentlicher Bericht</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669] shrink-0">{r.stat}</span>
                </div>
              ))}
              <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alle automatisch versendet · Sie haben nichts getan</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisierte Berichte</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Berichte, die sich selbst erstellen und versenden. Jeden Kunden. Jede Woche.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Richten Sie die Berichts-Vorlage einmal pro Kunde ein. Ab diesem Tag erstellt Stacc den Bericht, formatiert ihn mit Ihrer Marke und liefert ihn in den Posteingang des Kunden nach Zeitplan. Niemand in Ihrem Team berührt ihn.
              </p>
              <ul class="mt-6 space-y-3">
                {['Einmal konfigurieren — liefert für immer nach Ihrem Zeitplan', 'White-Label-Format mit Ihrer Agentur-Marke und Kommentaren', 'Deckt Rankings, GBP-Aktivität, Bewertungen, Citations in einem Bericht ab', 'Kunden erhalten wöchentlich Beweise Ihrer Arbeit, ohne dass Sie ein Wort sagen müssen'].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[14px] leading-relaxed text-[#57534e]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── A WEEK WITH STACC ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Wie Ihr Montag aussieht</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Eine Woche, in der Sie Ihre Agentur<br />mit Stacc leiten.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { time: '7:00 Uhr Montag', title: 'Berichte bereits geliefert.', body: 'Der wöchentliche Bericht jedes Kunden kam um 7 Uhr in sein Postfach. Sie haben sie nicht angerührt. Stacc hat über Nacht 18 Berichte erstellt und versendet. Ihr Montag beginnt ohne Berichts-Schulden.', type: 'automated' },
            { time: '8:30 Uhr Montag', title: 'Ein Kunde hatte einen Ranking-Rückgang. Sie haben bereits geantwortet.', body: 'Stacc markierte den Rückgang Freitagabend. Sie erhielten die Warnung, recherchierten und hatten einen Antwortplan bereit, bevor der Kunde es bemerkte. Sie glauben, dass Sie ihr Konto rund um die Uhr überwachen. Das tun Sie.', type: 'alert' },
            { time: '9:15 Uhr Montag', title: 'Neuer Kunde in 40 Minuten ongeboardet.', body: 'Standorte hinzugefügt. Keywords eingestellt. GBP verbunden. Berichts-Zeitplan konfiguriert. Dieser Kunde ist vollständig in Stacc aktiv, bevor Ihr zweiter Kaffee fertig ist.', type: 'onboarding' },
            { time: '16:00 Uhr Freitag', title: 'Sie beendeten die Woche mit echter SEO-Arbeit.', body: 'Keine Berichte. Kein Tab-Wechsel. Kein Kopieren und Einfügen von Daten zwischen sechs Tools. Sie widmeten die Woche der Strategie, der Akquise und der Arbeit, für die Kunden Sie tatsächlich bezahlen.', type: 'outcome' },
          ].map(w => (
            <div class="flex gap-5 rounded-2xl border border-[#e7e5e4] bg-white p-6">
              <div class="shrink-0">
                <div class={`flex h-10 w-10 items-center justify-center rounded-xl ${w.type === 'automated' ? 'bg-[#dcfce7] border border-[#bbf7d0]' : w.type === 'alert' ? 'bg-[#fef3c7] border border-[#fde68a]' : w.type === 'onboarding' ? 'bg-[#f5f3ff] border border-[#c7c0fc]' : 'bg-[#f0f9ff] border border-[#bae6fd]'}`}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={w.type === 'automated' ? '#059669' : w.type === 'alert' ? '#d97706' : w.type === 'onboarding' ? '#4f39f6' : '#0284c7'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    {w.type === 'automated' && <path d="M20 6 9 17l-5-5"/>}
                    {w.type === 'alert' && <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>}
                    {w.type === 'onboarding' && <path d="M12 4v16m8-8H4"/>}
                    {w.type === 'outcome' && <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>}
                  </svg>
                </div>
              </div>
              <div>
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">{w.time}</p>
                <p class="mt-1 font-sans text-[15px] font-semibold text-[#111827]">{w.title}</p>
                <p class="mt-1.5 font-sans text-[13px] leading-[1.65] text-[#57534e]">{w.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">ROI für Agenturen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Die Zahlen, die zählen,<br />wenn Sie eine Agentur leiten.
          </h2>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '80%',   label: 'Weniger Zeit für manuelle Berichte', sub: 'pro Monat über Ihre gesamte Kundenbasis zurückgewonnen' },
            { value: '3×',    label: 'Mehr Kunden, gleiches Team', sub: 'wenn Berichte und Monitoring automatisiert sind' },
            { value: '45min', label: 'Durchschnittliche Neukunden-Einrichtungszeit', sub: 'von null bis vollständig konfiguriert und aktiv' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center px-8 py-12 text-center" style="background:rgba(15,23,42,0.04);">
              <p class="font-sans text-[3rem] font-semibold tracking-[-0.04em] text-[#292524]">{s.value}</p>
              <p class="mt-2 font-sans text-[14px] font-semibold text-[#292524]/70">{s.label}</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em]" style="color:#4b5563;">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── TESTIMONIALS ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Agentur-Inhaber</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Was passiert, wenn Agenturen aufhören,<br />alles manuell zu machen.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-2">
          {[
            { quote: "Wir wuchsen von 18 auf 41 Kunden in 8 Monaten ohne eine einzige neue Einstellung. Stacc automatisierte die Berichte und das Monitoring, das unsere gesamte Kapazität aufgefressen hat. Die Plattform hat sich selbst eingestellt.", name: "Markus D.", role: "Gründer, lokale SEO-Agentur", result: "18 → 41 Kunden, gleiches Team" },
            { quote: "Die Kundenbindung verbesserte sich. Ich glaube, es liegt daran, dass Berichte jeden Montag konsistent mit echten Daten ankommen. Kunden fragten sich früher, warum sie zahlen. Jetzt erhalten sie jede Woche Beweise. In 6 Monaten hat kein Kunde sein Mandat in Frage gestellt.", name: "Aisha T.", role: "Agentur-Direktorin, 23 Kunden", result: "0 Churn in 6 Monaten" },
          ].map(t => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8">
              <div class="flex gap-1 mb-5">
                {[1,2,3,4,5].map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                ))}
              </div>
              <blockquote class="font-sans text-[15px] leading-[1.7] text-[#292524]">"{t.quote}"</blockquote>
              <div class="mt-6 flex items-center gap-3">
                <div class="h-10 w-10 rounded-full bg-[#4f39f6] flex items-center justify-center shrink-0">
                  <span class="font-mono text-[12px] font-bold text-white">{t.name.split(' ').map((n: string) => n[0]).join('')}</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">{t.name}</p>
                  <p class="font-mono text-[10px] text-[#79716b]">{t.role}</p>
                </div>
                <span class="ml-auto rounded-full bg-[#dcfce7] px-2.5 py-1 font-mono text-[10px] font-semibold text-[#059669]">{t.result}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Häufige Fragen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Fragen, die Agenturen stellen, bevor sie anfangen
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq, i) => (
            <div class="faq-item">
              <button class="faq-btn flex w-full items-center justify-between gap-4 px-7 py-5 text-left" aria-expanded={i === 0 ? 'true' : 'false'}>
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="faq-icon-plus shrink-0" class:list={[i === 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                <svg class="faq-icon-minus shrink-0" class:list={[i !== 0 && 'hidden']} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
              </button>
              <div class="faq-answer px-7 pb-6" class:list={[i !== 0 && 'hidden']}>
                <p class="font-sans text-[14px] leading-[1.75] text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-20 md:py-28" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at center, rgba(79,57,246,0.2) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at center,black 35%,transparent 85%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Eine Einrichtung von nie mehr manuellen Berichten entfernt</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.75rem]">
            Eine Einrichtung entfernt davon, nie wieder<br />einen Kundenbericht manuell erstellen zu müssen.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Die Agenturen, die am schnellsten wachsen, sind nicht intelligenter. Sie arbeiten nicht harder. Sie stellen nicht schneller ein. Sie arbeiten mit besserer Infrastruktur — und nutzen die zurückgewonnene Zeit zum echten Wachstum. Schließen Sie sich den 400+ Agenturen an, die diesen Schritt gemacht haben.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Agenturen-Demo anfragen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/preise/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-white/15 px-6 font-sans text-[14px] font-medium text-white/70 transition-colors hover:bg-white/5">
              Preise ansehen
            </a>
          </div>
          <div class="mt-8 inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <p class="font-sans text-[12px] text-white/60">Keine Verträge · Jederzeit kündbar</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    document.querySelectorAll('.faq-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const parent = btn.parentElement;
        const answer = parent?.querySelector('.faq-answer');
        const iconPlus = btn.querySelector('.faq-icon-plus');
        const iconMinus = btn.querySelector('.faq-icon-minus');
        const isOpen = !answer?.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
        document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
        document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
        if (!isOpen) {
          answer?.classList.remove('hidden');
          iconPlus?.classList.add('hidden');
          iconMinus?.classList.remove('hidden');
        }
      });
    });
  </script>
</BaseLayout>
