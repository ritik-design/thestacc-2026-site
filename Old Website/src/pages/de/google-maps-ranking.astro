---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was beeinflusst Google Maps-Rankings?", a: "Google Maps-Rankings werden hauptsächlich durch drei Faktoren bestimmt: Relevanz (wie gut Ihr Unternehmen zur Suchanfrage passt), Entfernung (wie weit Ihr Standort vom Suchenden entfernt ist) und Bekanntheit (wie gut bekannt und vertrauenswürdig Ihr Unternehmen ist). GBP-Vollständigkeit, Bewertungsvolumen und -qualität, Zitationskonsistenz und Post-Aktivität beeinflussen alle diese Faktoren." },
  { q: "Wie verfolgt Stacc Google Maps-Rankings?", a: "Stacc verfolgt täglich Ihre Position im Google Maps-Paket für jeden Ihrer Ziel-Keywords und Standorte. Sie sehen Trends über Zeit, erhalten Benachrichtigungen bei signifikanten Positionsänderungen und können die Rankings-Performance über alle Standorte von einem Dashboard aus vergleichen." },
  { q: "Welche Maßnahmen verbessern Google Maps-Rankings?", a: "Die größten Rankingfaktoren sind: vollständiges und konsistentes GBP-Profil, regelmäßige Post-Aktivität (30 Posts/Monat), hohes Bewertungsvolumen mit Antworten, NAP-Konsistenz in Verzeichnissen und standortspezifische Keywords. Stacc automatisiert alle diese Faktoren gleichzeitig." },
  { q: "Wie lange dauert es, Google Maps-Rankings zu verbessern?", a: "Die meisten Unternehmen sehen erste Rankings-Verbesserungen innerhalb von 30–60 Tagen nach Behebung der Grundursachen. Vollständige Ranking-Gewinne dauern typischerweise 90–120 Tage, da Google konsistente Aktivität über Zeit braucht, um vertrauen aufzubauen." },
  { q: "Kann Stacc Rankings für mehrere Standorte verfolgen?", a: "Ja. Jeder Standort hat sein eigenes Keyword-Set und Ranking-Verlauf. Vergleichen Sie die Maps-Performance über alle Standorte hinweg und identifizieren Sie, welche Standorte Aufmerksamkeit benötigen." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Google Maps Ranking Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Google Maps-Rankings täglich verfolgen und verbessern. Automatisierte GBP-Optimierung, Bewertungsmanagement und Zitationskonsistenz für bessere Maps-Sichtbarkeit.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Google Maps Ranking", "item": "https://thestacc.com/de/google-maps-ranking/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Google Maps Ranking verbessern — Täglich verfolgt und optimiert | theStacc"
  description="Google Maps-Rankings täglich verfolgen und verbessern. Stacc automatisiert GBP-Posts, Bewertungsmonitoring und Zitationskonsistenz — die Faktoren, die Maps-Rankings bewegen."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Google Maps Ranking · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Google Maps-Rankings täglich<br />
            <span style="color:#4f39f6;">verfolgt und verbessert.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc verfolgt Ihre Google Maps-Positionen täglich und automatisiert die Maßnahmen, die Rankings bewegen: GBP-Posts, Bewertungsmanagement und Zitationskonsistenz — für alle Standorte gleichzeitig.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/rank-tracking-software/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Rank-Tracking ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ Unternehmen und Agenturen</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ verwaltete Standorte</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Google Maps-Rankings bestimmt</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Relevanz, Entfernung, Bekanntheit —<br />alle drei optimierbar.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Google Maps-Rankings basieren auf drei Hauptfaktoren. Entfernung ist unveränderlich — Sie können Ihren Standort nicht verschieben. Relevanz wird durch GBP-Vollständigkeit, Kategorien und Keywords beeinflusst. Bekanntheit — der einflussreichste Faktor — wird durch Bewertungsvolumen, Post-Aktivität und Zitationskonsistenz gesteuert.</p>
            <p>Stacc automatisiert alle optimierbaren Signale: tägliche GBP-Posts, Bewertungsmonitoring mit Antwortbenachrichtigungen und NAP-Konsistenz in 50+ Verzeichnissen. Gleichzeitig verfolgt Stacc täglich Ihre Maps-Positionen, damit Sie Fortschritte messen und erkennen, wann ein Standort Ihre Aufmerksamkeit benötigt.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc tut</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Eine Plattform. Alle Maps-Ranking-Faktoren.<br />Vollständig automatisiert.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Google Maps Rang-Tracking', body: 'Täglich aktualisierte Positionen im Local 3-Pack für alle Keywords. Alerts bei signifikanten Positionsveränderungen.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP-Post-Automatisierung', body: '30 Posts/Monat verbessern Engagement-Signale für Maps-Rankings. Automatisch erstellt und veröffentlicht.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Zitations-Konsistenz', body: 'NAP-Konsistenz in 50+ Verzeichnissen stärkt Vertrauenswürdigkeit bei Google. Abweichungen automatisch behoben.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Bewertungsvolumen', body: 'Mehr Bewertungen, schneller — direkte Links zur Bewertungsabgabe. Echtzeit-Alerts für neue Bewertungen.' },
            { icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z', title: 'Grid-Rank-Tracking', body: 'Rasterbasierte Maps-Analyse im gesamten Einzugsgebiet. Sehen Sie genau, wo Sie sichtbar sind und wo nicht.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Ranking-Alerts', body: 'Sofortige Benachrichtigung bei signifikanten Positionsveränderungen. Reagieren Sie, bevor Rankings weiter sinken.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Schlüsselfunktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Maps-Rankings verbessern.<br />Mit den richtigen Signalen.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Tägliches Maps-Rank-Tracking -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tägliches Maps-Rank-Tracking</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Wissen Sie jeden Morgen, wo Sie im Local 3-Pack stehen — ohne sich einzuloggen.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc verfolgt täglich Ihre Position im Google Maps Local 3-Pack für jedes relevante Keyword. Sie sehen Trends über Zeit, erkennen, welche Keywords sich verbessern und welche Aufmerksamkeit benötigen. Alerts werden automatisch ausgelöst, wenn sich Positionen signifikant verschieben — nach oben oder unten. Für Unternehmen mit mehreren Standorten: alle Maps-Positionen in einem Dashboard, täglich aktualisiert.
              </p>
              <a href="/de/rank-tracking-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Rank-Tracking im Detail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Maps-Positionen — heute</p>
              {[
                { kw: 'Klempner in der Nähe', pos: 1, change: '+3', trend: 'up' },
                { kw: 'Klempner [Stadt]', pos: 2, change: '+2', trend: 'up' },
                { kw: 'Rohrbruch Notdienst', pos: 2, change: '+4', trend: 'up' },
                { kw: 'Heizung reparieren Nähe', pos: 4, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.pos <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pos}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.kw}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">Google Maps Local 3-Pack</p>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold shrink-0 ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Täglich aktualisiert · Local 3-Pack + Maps + Organisch</p>
            </div>
          </div>

          <!-- GBP-Aktivitätssignale -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">GBP-Post-Kalender — April</p>
              <div class="grid grid-cols-7 gap-1 mb-3">
                {['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'].map(d => (
                  <div class="text-center font-mono text-[9px] text-[#79716b]">{d}</div>
                ))}
              </div>
              <div class="grid grid-cols-7 gap-1">
                {Array.from({ length: 30 }, (_, i) => i + 1).map(day => (
                  <div class={`flex h-7 w-full items-center justify-center rounded text-[10px] font-mono ${[1,3,5,8,10,12,15,17,19,22,24,26,29].includes(day) ? 'bg-[#4f39f6] text-white font-semibold' : 'bg-[#f5f3ff] text-[#79716b]'}`}>{day}</div>
                ))}
              </div>
              <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">13 Posts veröffentlicht · 17 geplant · 30 gesamt/Monat</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP-Aktivitätssignale</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Regelmäßige Posts verbessern Google Maps-Rankings. Stacc postet automatisch.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google bewertet die Aktivität eines GBP-Profils als Vertrauenssignal. Unternehmen, die regelmäßig posten, erhalten bessere Maps-Sichtbarkeit als inaktive Profile. Stacc erstellt und veröffentlicht 30 Posts pro Monat für jeden Standort — mit lokalen Keywords, die für Maps-Rankings relevant sind. Kein manueller Aufwand, keine vergessenen Wochen ohne Post-Aktivität.
              </p>
              <a href="/de/google-business-profile-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                GBP-Software ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Zitations-Monitoring -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Zitations-Monitoring</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Inkonsistente Zitationen schaden Maps-Rankings. Stacc findet und behebt sie automatisch.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google prüft Ihre Unternehmensdaten in Dutzenden von Verzeichnissen, um Ihre lokale Vertrauenswürdigkeit zu bewerten. Wenn Name, Adresse oder Telefonnummer nicht übereinstimmen, sinkt Ihr Maps-Ranking. Stacc überwacht kontinuierlich 50+ Verzeichnisse und korrigiert Abweichungen automatisch — damit Ihr NAP-Datensatz konsistent und Maps-freundlich bleibt.
              </p>
              <a href="/de/zitationsaufbau-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Zitationsaufbau ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Zitations-Status — Verzeichnisse</p>
              {[
                { dir: 'Google Business Profile', status: 'Korrekt', ok: true },
                { dir: 'Yelp', status: 'Korrekt', ok: true },
                { dir: 'Apple Maps', status: 'Korrekt', ok: true },
                { dir: 'Gelbe Seiten', status: 'Abweichung korrigiert', ok: true },
                { dir: 'Foursquare', status: 'Automatisch behoben', ok: true },
              ].map(c => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#374151]">{c.dir}</span>
                  <span class={`flex items-center gap-1.5 font-mono text-[11px] font-semibold ${c.ok ? 'text-[#059669]' : 'text-[#dc2626]'}`}>
                    {c.ok ? '✓' : '✗'} {c.status}
                  </span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">50+ Verzeichnisse überwacht · Korrekturen automatisiert</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- METRIKEN -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Ergebnisse</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            Was passiert, wenn Maps-Ranking-Faktoren<br />wirklich automatisiert werden.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Durchschnittswerte von Unternehmen, die Google Maps-Rankings mit Stacc verbessern.
          </p>
        </div>
        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 md:grid-cols-3" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '#2', num: 2, prefix: '#', suffix: '', decimals: 0, from: 0, label: 'Ø Position-Verbesserung', sub: 'von Position 5+ auf Top 3 im Local Pack' },
            { value: '90', num: 90, prefix: '', suffix: ' Tage', decimals: 0, from: 0, label: 'Bis volle Wirkung sichtbar', sub: 'konsistente Automatisierung über 90 Tage' },
            { value: '4,9×', num: 4.9, prefix: '', suffix: '×', decimals: 1, from: 0, label: 'Höhere Klickrate mit Top-3-Platzierung', sub: 'im Vergleich zu Position 4–7' },
