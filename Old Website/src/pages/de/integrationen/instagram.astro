---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';

const faqs = [
  {
    q: "Welche Instagram-Kontotypen funktionieren mit Stacc?",
    a: "Stacc verbindet sich mit Instagram Business-Konten und Instagram Creator-Konten. Persönliche Konten werden nicht unterstützt. Ihr Instagram-Konto muss mit einer Facebook Business Page verknüpft sein, damit die API-Verbindung funktioniert — das ist eine Instagram-Anforderung, keine Stacc-Einschränkung.",
  },
  {
    q: "Kann ich auf mehreren Instagram-Konten gleichzeitig veröffentlichen?",
    a: "Ja. Verbinden Sie ein Instagram-Konto pro Unternehmensstandort und veröffentlichen Sie auf allen gleichzeitig. Schreiben Sie einen Beitrag, wählen Sie alle Konten aus, und Stacc veröffentlicht überall auf einmal — kein Ein- und Ausloggen in separate Instagram-Konten.",
  },
  {
    q: "Welche Inhaltsformate kann ich planen?",
    a: "Stacc unterstützt Feed-Beiträge (Bild und Video) und Reels für Instagram. Stories werden derzeit nicht über die Instagram API unterstützt. Karussell-Beiträge (mehrere Bilder) werden für die Feed-Veröffentlichung unterstützt.",
  },
  {
    q: "Verfolgt Stacc Instagram-Engagement-Metriken?",
    a: "Ja. Reichweite, Impressionen, Likes, Kommentare, Saves und Follower-Änderungen werden automatisch in Ihr Stacc-Dashboard eingezogen. Sie können das Engagement aller verbundenen Konten vergleichen und sehen, welche Standorte wachsen und welche zurückfallen.",
  },
  {
    q: "Kann ich Instagram-Beiträge im Voraus planen?",
    a: "Ja. Planen Sie Beiträge Stunden, Tage oder Wochen im Voraus. Richten Sie einen wiederkehrenden Posting-Zeitplan ein, und Stacc veröffentlicht automatisch in Ihrem Rhythmus. Sie können auch mehrere Beiträge auf einmal hochladen und mit dem Inhaltskalender planen.",
  },
  {
    q: "Ist die Instagram-Verbindung stabil?",
    a: "Stacc verwendet Instagrams offizielle Meta Business API. Das ist dieselbe API, die Enterprise-Social-Media-Tools verwenden — sie ist stabil und offiziell unterstützt. Instagram erfordert periodisch eine erneute Authentifizierung aus Sicherheitsgründen, wozu Stacc Sie auffordern wird, wenn es nötig ist.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Instagram Integration",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "inLanguage": "de",
      "description": "Verbinden Sie Instagram Business-Konten mit theStacc. Planen Sie Beiträge, verfolgen Sie Engagement und verwalten Sie mehrere Standortkonten von einem Dashboard aus.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Integrationen", "item": "https://thestacc.com/de/integrationen/" },
        { "@type": "ListItem", "position": 3, "name": "Instagram", "item": "https://thestacc.com/de/integrationen/instagram/" }
      ]
    },
    {
      "@type": "FAQPage",
      "inLanguage": "de",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Instagram Integration — Planen & auf jedem Standort-Instagram veröffentlichen | theStacc"
  description="Verwalten Sie Instagram-Inhalte für jeden Unternehmensstandort ohne Kontowechsel. Beiträge planen, Engagement verfolgen und konsistente Präsenz an allen Standorten halten."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integration · Instagram</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" aria-label="Instagram" aria-hidden="true">
                <defs><linearGradient id="ig" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" style="stop-color:#f09433"/><stop offset="25%" style="stop-color:#e6683c"/><stop offset="50%" style="stop-color:#dc2743"/><stop offset="75%" style="stop-color:#cc2366"/><stop offset="100%" style="stop-color:#bc1888"/></linearGradient></defs>
                <rect x="2" y="2" width="20" height="20" rx="5" fill="url(#ig)"/>
                <circle cx="12" cy="12" r="4" fill="none" stroke="white" stroke-width="1.5"/>
                <circle cx="17.5" cy="6.5" r="1.2" fill="white"/>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Instagram.<br />
            <span style="color:#4f39f6;">Jedes Konto, ein Zeitplan.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Verbinden Sie jedes Instagram Business-Konto aller Standorte mit Stacc. Planen Sie Feed-Beiträge und Reels auf allen Konten gleichzeitig, verfolgen Sie Engagement in einem Dashboard und melden Sie sich nie wieder in ein separates Instagram-Konto ein.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Instagram kostenlos verbinden
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#wie-verbinden"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              So funktioniert es
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            Meta Business API · Einrichtung in 2 Minuten · Funktioniert für 1 oder 100 Konten
          </p>
        </div>
      </div>
    </section>


    <!-- ─── WHAT THIS DOES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Sie erhalten</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Einmal verbinden. Alle Konten<br />posten nach Zeitplan.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z', title: 'Massenpost auf allen Konten gleichzeitig', body: 'Ein Beitrag, alle Standorte gleichzeitig veröffentlicht. Unterstützt Bilder, Videos und Reels. Optionale standortspezifische Bildunterschriften vor der Veröffentlichung.' },
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: 'Inhaltskalender-Planung', body: 'Planen Sie Ihre Instagram-Inhalte Wochen im Voraus. Stellen Sie wiederkehrende Zeitpläne ein, und Stacc veröffentlicht automatisch in Ihrem Rhythmus. Keine Erinnerungen, kein manuelles Posten.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Kontoübergreifendes Engagement-Tracking', body: 'Reichweite, Impressionen, Likes, Saves und Follower-Wachstum aller verbundenen Konten in einer Ansicht. Erkennen Sie schwächelnde Standorte, bevor sie weiter zurückfallen.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'Standortspezifische Anpassung', body: 'Fügen Sie standortspezifische Hashtags, Tags oder Bildunterschriften vor der Massenveröffentlichung hinzu. Der Kerninhalt bleibt konsistent; die lokalen Details werden pro Konto angepasst.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Reels-Veröffentlichungsunterstützung', body: 'Planen und veröffentlichen Sie Instagram Reels direkt aus Stacc. Unterstützt Videodateien mit benutzerdefinierten Thumbnails und Bildunterschriften, massenweise auf allen Konten geplant.' },
            { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z', title: 'Multi-Konto-Verwaltung', body: 'Jedes verbundene Instagram-Konto von einem Dashboard aus sichtbar. Neue Konten hinzufügen, wenn Sie Standorte eröffnen. Zwischen Konten wechseln, ohne sich ein- und auszuloggen.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── SETUP STEPS ─── -->
    <section id="wie-verbinden" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So verbinden Sie</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Drei Schritte. Unter fünf Minuten.<br />Alle Konten verbunden.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Über Meta Business OAuth verbinden', body: 'Klicken Sie in den Stacc-Einstellungen auf „Instagram verbinden". Sie authentifizieren sich über Metas offiziellen Login. Stellen Sie sicher, dass Ihre Instagram-Konten zuerst mit Facebook Business Pages verknüpft sind — das ist eine Voraussetzung von Instagrams API.' },
            { step: '02', title: 'Ihre Instagram-Konten auswählen', body: 'Stacc listet jedes mit Ihrem Meta Business Manager verknüpfte Instagram Business-Konto auf. Wählen Sie die Konten aus, die Sie verwalten möchten. Sie können Konten jederzeit hinzufügen oder entfernen.' },
            { step: '03', title: 'Mit Planen und Verfolgen beginnen', body: 'Ihre Konten erscheinen sofort im Stacc Social-Dashboard. Planen Sie Ihren ersten Beitrag, prüfen Sie das Engagement aller Konten und richten Sie einen wiederkehrenden Posting-Kalender ein — ohne Instagram auch nur einmal zu öffnen.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BEFORE / AFTER ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Vorher vs. nachher</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Was sich ändert, wenn Instagram<br />über Stacc läuft.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Aufgabe</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Ohne Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Mit Stacc</div>
          </div>
          {[
            ['Auf 10 Standortkonten posten', '10x einloggen, 45 Min. pro Posting-Zyklus', 'Ein Beitrag, alle Konten, 2 Min.'],
            ['Standortübergreifendes Engagement prüfen', 'Exporte von jedem Konto herunterladen', 'Live einheitliches Dashboard, immer aktuell'],
            ['Posting-Konsistenz aufrechterhalten', 'Handy-Erinnerungen, täglich manuell posten', 'Wiederkehrender Zeitplan, Beiträge automatisch'],
            ['Launch-Beitrag planen', 'Kalender-Erinnerungen für 10 Konten', 'Einmal massenweise planen, überall veröffentlichen'],
            ['Follower-Wachstum pro Standort verfolgen', 'Tabelle mit manueller Dateneingabe', 'Automatisch verfolgt, Trends pro Konto angezeigt'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── USE CASES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Wer das nutzt</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Drei Workflows, die diese<br />Integration sofort freischaltet.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Einzelhandelsketten', title: 'Markenkonsistente Instagram-Präsenz in allen Filialen', body: 'Produktfotos und Aktionen gleichzeitig auf jedes Filialkonto veröffentlichen. Konsistente Markenstimme, konsistenter Posting-Rhythmus — keine Filiale zurückgelassen.' },
            { label: 'Restaurantgruppen', title: 'Tägliche Beiträge an jedem Standort ohne Mehraufwand', body: 'Fotos, Specials und Events werden automatisch auf jedem Restaurant-Instagram veröffentlicht. Ihre Social-Media-Präsenz läuft ohne einen Vollzeit-Social-Manager.' },
            { label: 'SEO-Agenturen', title: 'Alle Kunden-Instagram-Konten von einem Login verwalten', body: 'Keine Kunden-Instagram-Zugangsdaten mehr. Verbinden Sie alle Kundenkonten mit Stacc und erledigen Sie Content-Publishing und Reporting für jeden Kunden an einem Ort.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── RELATED INTEGRATIONS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Oft zusammen verbunden</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Instagram funktioniert am besten<br />neben diesen.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Facebook', desc: 'Veröffentlichen Sie denselben Beitrag gleichzeitig auf Instagram und Facebook. Eine Aktion, beide Kanäle abgedeckt.', href: '/de/integrationen/facebook/' },
            { title: 'Google Business Profile', desc: 'Runden Sie Ihre Social-Präsenz ab, indem Sie von einem einzigen Workflow aus auf GBP, Facebook und Instagram posten.', href: '/de/integrationen/google-business-profile/' },
            { title: 'Social-Scheduling', desc: 'Richten Sie einmal einen Veröffentlichungskalender ein und lassen Sie Stacc konsistentes Posting auf allen Plattformen automatisch aufrechterhalten.', href: '/de/funktionen/social-scheduling/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Fragen zur<br />Instagram-Integration
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
