---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';
import { getCollection, render } from 'astro:content';
import { SITE_URL, organizationSchema, publisherRef, authorRef, websiteSchema, buildBreadcrumbs } from '../../../utils/schema';
import { isNoindexed } from '../../../data/noindex-list';

export async function getStaticPaths() {
  const langTerms = await getCollection('glossary_de');
  return langTerms.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allTerms = await getCollection('glossary_de');
const relatedSlugs = entry.data.relatedTerms || [];
const relatedTerms = allTerms.filter((t) => relatedSlugs.includes(t.data.slug));

const categoryTerms = allTerms
  .filter((t) => t.data.category === entry.data.category && t.data.slug !== entry.data.slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 5);

const categoryColors: Record<string, string> = {
  'Marketing': '#4f39f6',
  'SEO': '#16a34a',
  'Local SEO': '#ea580c',
  'Social Media': '#db2777',
  'AI & Emerging': '#7c3aed',
};

const difficultyLabels: Record<string, string> = {
  'Beginner': 'Einsteiger',
  'Intermediate': 'Fortgeschrittene',
  'Advanced': 'Experten',
};

const difficultyColors: Record<string, string> = {
  'Beginner': '#16a34a',
  'Intermediate': '#d97706',
  'Advanced': '#dc2626',
};

const catColor = categoryColors[entry.data.category] || '#4f39f6';
const t = entry.data.term;

const deUrl = `${SITE_URL}/de/glossar/${entry.data.slug}/`;
const enUrl = `${SITE_URL}/glossary/${entry.data.slug}/`;

const schemaData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'DefinedTerm',
      '@id': `${deUrl}#term`,
      name: t,
      description: entry.data.definition,
      inDefinedTermSet: { '@type': 'DefinedTermSet', name: 'SEO Glossar', url: `${SITE_URL}/de/glossar/` },
    },
    {
      '@type': 'Article',
      '@id': `${deUrl}#article`,
      headline: `Was ist ${t}?`,
      description: entry.data.definition,
      url: deUrl,
      datePublished: entry.data.date,
      dateModified: entry.data.date,
      author: authorRef,
      publisher: publisherRef,
      mainEntityOfPage: { '@type': 'WebPage', '@id': deUrl },
      inLanguage: 'de',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(deUrl, [
      { name: 'Home', url: `${SITE_URL}/de/` },
      { name: 'Glossar', url: `${SITE_URL}/de/glossar/` },
      { name: t, url: deUrl },
    ]),
    organizationSchema,
    websiteSchema,
  ],
};
---

<BaseLayout
  title={`${t} — Definition &amp; Bedeutung | theStacc SEO-Glossar`}
  description={entry.data.definition}
  lang="de"
  noindex={isNoindexed(`/de/glossar/${entry.data.slug}/`)}
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

    <!-- Hero (dark) -->
    <div class="relative overflow-hidden" style={`background:#0d1117;`}>
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style={`background:radial-gradient(ellipse at 50% -5%, ${catColor}55 0%, transparent 60%);`}></div>
      <div class="relative z-10 mx-auto max-w-[1320px] px-6 pt-8 pb-12">

        <nav class="flex items-center gap-1.5" aria-label="Breadcrumb">
          <a href="/de/glossar/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#6b7280] transition-colors hover:text-[#818cf8]">Glossar</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#374151" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em]" style={`color:${catColor};`}>{entry.data.category}</span>
        </nav>

        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="rounded-md px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.1em]" style={`background:${catColor}22;color:${catColor};`}>{entry.data.category}</span>
          {entry.data.difficulty && (
            <span class="rounded-md px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.1em]" style={`color:${difficultyColors[entry.data.difficulty] || '#79716b'};background:${difficultyColors[entry.data.difficulty] || '#79716b'}22;`}>
              {difficultyLabels[entry.data.difficulty] || entry.data.difficulty}
            </span>
          )}
        </div>

        <h1 class="mt-4 font-sans text-[28px] leading-[36px] md:text-[38px] md:leading-[48px] font-bold tracking-[-0.02em] text-white">
          Was ist {t}?
        </h1>
        <p class="mt-4 font-sans text-[16px] leading-[26px] text-[#9ca3af] max-w-2xl">{entry.data.definition}</p>
      </div>
    </div>

    <!-- Content + Sidebar -->
    <div class="mx-auto max-w-[1320px] px-6 py-12">
      <div class="flex flex-col gap-10 lg:flex-row lg:gap-12">

        <div class="min-w-0 flex-1">
          <div class="glossary-content overflow-x-hidden">
            <Content />
          </div>

          <!-- Related terms -->
          {relatedTerms.length > 0 && (
            <div class="mt-12 border-t border-[#e7e5e4] pt-8">
              <h2 class="font-sans text-[18px] font-semibold text-[#292524]">Verwandte Begriffe</h2>
              <div class="mt-4 flex flex-wrap gap-2">
                {relatedTerms.map(term => (
                  <a href={`/de/glossar/${term.data.slug}/`} class="rounded-lg border border-[#e7e5e4] px-3 py-1.5 font-sans text-[13px] font-medium text-[#292524] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
                    {term.data.term}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <aside class="w-full lg:w-[280px] shrink-0 space-y-6">
          <div class="sticky top-20 space-y-5">

            <!-- CTA -->
            <div class="rounded-xl border border-[#e7e5e4] bg-white p-5 shadow-sm">
              <p class="font-sans text-[14px] font-semibold text-[#292524]">{t} in der Praxis</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#57534e]">theStacc hilft Ihnen, {t} zu implementieren und zu automatisieren — ohne technisches Know-how.</p>
              <a href="/de/demo/" class="mt-4 flex h-9 items-center justify-center rounded-lg bg-[#4f39f6] font-sans text-[13px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">Demo buchen</a>
            </div>

            <!-- More in this category -->
            {categoryTerms.length > 0 && (
              <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.08em] text-[#79716b]">Mehr zu {entry.data.category}</p>
                <div class="mt-3 space-y-2">
                  {categoryTerms.map(term => (
                    <a href={`/de/glossar/${term.data.slug}/`} class="block font-sans text-[13px] text-[#57534e] hover:text-[#4f39f6] transition-colors">{term.data.term}</a>
                  ))}
                </div>
              </div>
            )}

            <!-- English version -->
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
              <p class="font-sans text-[12px] text-[#79716b]">Auf Englisch lesen:</p>
              <a href={enUrl} class="mt-1 block font-sans text-[13px] font-medium text-[#4f39f6] hover:underline">Read in English →</a>
            </div>

          </div>
        </aside>
      </div>
    </div>

  </main>
  <Footer />
</BaseLayout>
