---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist lokale SEO-Automatisierung?", a: "Lokale SEO-Automatisierung bezieht sich auf Software, die wiederkehrende lokale SEO-Aufgaben ausführt, ohne manuelle Intervention zu erfordern: GBP-Posts veröffentlichen, Bewertungen überwachen, Zitationskonsistenz prüfen und Rankings verfolgen — alles automatisch, für alle Standorte gleichzeitig." },
  { q: "Welche lokalen SEO-Aufgaben automatisiert Stacc?", a: "Stacc automatisiert: GBP-Post-Veröffentlichung (30 Posts/Monat pro Standort), Bewertungsmonitoring und Antwortbenachrichtigungen, Zitationskonsistenz-Überwachung in 50+ Verzeichnissen, tägliches Rank-Tracking (Local Pack, Maps, organisch) und automatische Performance-Berichte." },
  { q: "Wie viel Zeit spart lokale SEO-Automatisierung?", a: "Unternehmen mit mehreren Standorten sparen typischerweise 10–20 Stunden pro Monat durch die Automatisierung von GBP-Management, Bewertungsüberwachung und Berichterstattung. Für Agenturen, die mehrere Kunden verwalten, ist die Zeitersparnis noch größer." },
  { q: "Ersetzt Automatisierung manuelle SEO-Arbeit vollständig?", a: "Automatisierung behandelt konsistente, wiederholbare Aufgaben. Strategie, Inhaltsplanung und die Reaktion auf einzigartige lokale Ereignisse erfordern nach wie vor menschliches Urteil. Stacc automatisiert die Ausführung, damit Sie sich auf die Strategie konzentrieren können." },
  { q: "Ist lokale SEO-Automatisierung für Einzelstandort-Unternehmen sinnvoll?", a: "Ja, aber der ROI ist bei Multi-Standort-Unternehmen am höchsten. Für Einzelstandorte spart Automatisierung trotzdem mehrere Stunden pro Monat und stellt konsistente Aktivität sicher — konsistentes Posten und Monitoring, das manuell oft einschläft." },
  { q: "Wie beginne ich mit lokaler SEO-Automatisierung?", a: "Starten Sie mit dem 1-Euro-Test bei Stacc. Verbinden Sie Ihre GBP-Standorte, stellen Sie Keywords für das Rank-Tracking ein und konfigurieren Sie Bewertungsbenachrichtigungen. Automatisierung läuft ab diesem Zeitpunkt ohne weitere Einrichtung." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Lokale SEO-Automatisierung", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Lokale SEO-Automatisierungssoftware für GBP-Posts, Bewertungsmonitoring, Zitationsverwaltung und Rank-Tracking — alles automatisch für alle Standorte.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Lokale SEO-Automatisierung", "item": "https://thestacc.com/de/lokales-seo-automatisierung/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Lokale SEO-Automatisierung — GBP, Bewertungen, Rankings automatisch | theStacc"
  description="Lokale SEO-Aufgaben automatisieren: GBP-Posts, Bewertungsmonitoring, Zitationskonsistenz und Rank-Tracking. Stacc erledigt die Ausführung, Sie konzentrieren sich auf die Strategie."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Lokale SEO-Automatisierung · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokales SEO läuft automatisch.<br />
            <span style="color:#4f39f6;">GBP. Bewertungen. Rankings. Zitationen.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc automatisiert alle wiederkehrenden lokalen SEO-Aufgaben: Posts veröffentlichen, Bewertungen überwachen, Zitationskonsistenz prüfen, Rankings täglich verfolgen — für alle Standorte gleichzeitig.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/seo-automatisierung-software/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              SEO-Automatisierung ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ Unternehmen und Agenturen</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ verwaltete Standorte</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Stacc automatisiert</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede wiederkehrende lokale SEO-Aufgabe.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-4xl grid grid-cols-1 gap-6 sm:grid-cols-2">
          {[
            { label: 'GBP-Post-Automatisierung', detail: '30 standortspezifische Posts pro Monat automatisch erstellt und veröffentlicht. Keine manuelle Eingabe erforderlich.' },
            { label: 'Bewertungsmonitoring', detail: 'Neue Bewertungen auf Google und anderen Plattformen werden sofort gemeldet, mit Kontext für eine schnelle Antwort.' },
            { label: 'Zitationskonsistenz', detail: 'NAP-Daten in 50+ Verzeichnissen werden kontinuierlich überwacht. Inkonsistenzen werden zur Korrektur gemeldet.' },
            { label: 'Tägliches Rank-Tracking', detail: 'Local Pack, Google Maps und organische Rankings werden täglich für alle Standorte und Keywords verfolgt.' },
            { label: 'Performance-Berichte', detail: 'Automatische Berichte werden nach Zeitplan erstellt und zeigen Rankings-Trends, Bewertungsaktivität und GBP-Performance.' },
            { label: 'Änderungsbenachrichtigungen', detail: 'Sofortige Benachrichtigungen bei signifikanten Ranking-Änderungen oder neuen vorgeschlagenen GBP-Änderungen.' },
          ].map(item => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] px-6 py-5">
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{item.label}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b]">{item.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Die Automatisierungs-Plattform</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Eine Plattform. Alle Aufgaben.<br />Vollständig automatisiert.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP-Post-Automatisierung', body: '30 standortspezifische Posts/Monat automatisch erstellt und veröffentlicht.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Automatisches Rank-Tracking', body: 'Täglich aktualisierte Rankings ohne manuelles Einloggen — alle Standorte, alle Keywords.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Automatische Zitations-Überwachung', body: 'NAP-Abweichungen in 50+ Verzeichnissen erkannt und gemeldet.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Echtzeit-Bewertungsalerts', body: 'Neue Bewertungen sofort gemeldet — direkt auf Dashboard beantworten.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Auto-Berichtszustellung', body: 'Berichte werden automatisch erstellt und an Kunden zugestellt.' },
            { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Fehler-Erkennung', body: 'Proaktive Warnung bei Rankings-Einbrüchen, Bewertungsproblemen und GBP-Suspensionen.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Schlüsselfunktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Automatisierung, die wirklich läuft.<br />Jeden Tag. Ohne Ausnahme.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Showcase 1: text left, card right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tägliche Aufgaben-Automatisierung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Alles automatisch — nichts vergessen.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Stacc führt jeden Tag alle lokalen SEO-Aufgaben automatisch aus — GBP-Posts veröffentlichen, Rankings prüfen, Bewertungen überwachen, Zitationen abgleichen. Keine Erinnerungen, keine manuellen Logins, keine verpassten Aufgaben. Das System läuft im Hintergrund, während Sie sich auf Ihr Kerngeschäft konzentrieren. Praxistauglich für Einzelstandort-Unternehmen und Multi-Standort-Betreiber gleichermaßen.
              </p>
              <a href="/de/seo-automatisierung-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                SEO-Automatisierung im Detail
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Heutige Aufgaben — automatisch erledigt</p>
              {[
                { task: 'GBP-Post veröffentlicht', time: '06:00 Uhr', done: true },
                { task: 'Rankings aktualisiert', time: '06:15 Uhr', done: true },
                { task: 'Zitationen geprüft', time: '06:30 Uhr', done: true },
                { task: 'Bewertungsalerts gesendet', time: '06:45 Uhr', done: true },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[#4f39f6] text-white">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.task}</p>
                    <p class="font-mono text-[10px] text-[#79716b] truncate">{r.time}</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold shrink-0 text-[#059669]">✓</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Täglich automatisch · Keine manuelle Eingabe</p>
            </div>
          </div>

          <!-- Showcase 2: card left, text right -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Neue Bewertung — sofort gemeldet</p>
              <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4 mb-4">
                <div class="flex items-center gap-2 mb-2">
                  <div class="flex gap-0.5">
                    {[1,2,3,4,5].map(() => <svg width="11" height="11" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}
                  </div>
                  <span class="font-mono text-[10px] text-[#79716b]">vor 2 Minuten</span>
                </div>
                <p class="font-sans text-[12px] text-[#374151] leading-relaxed">"Sehr professionell und schnell. Kann ich nur empfehlen!"</p>
                <p class="mt-1 font-mono text-[10px] text-[#79716b]">— Maria S. via Google</p>
              </div>
              <a href="/de/demo/" class="flex h-9 w-full items-center justify-center gap-2 rounded-xl bg-[#4f39f6] font-sans text-[13px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
                1-Klick-Antwort senden
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Echtzeit-Alert · Antwortvorlagen inklusive</p>
