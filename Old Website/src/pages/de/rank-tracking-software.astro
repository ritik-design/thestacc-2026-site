---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist Rank-Tracking-Software?", a: "Rank-Tracking-Software überwacht, wie Ihr Unternehmen für Ziel-Keywords in den Suchmaschinenergebnissen steht — einschließlich Local Pack, Google Maps und organischen Ergebnissen. Stacc aktualisiert Ihre Rankings täglich für alle Standorte und Keywords und zeigt Trends und Positionsänderungen im Zeitverlauf." },
  { q: "Wie oft aktualisiert Stacc die Rankings?", a: "Täglich. Im Gegensatz zu Tools, die wöchentliche oder monatliche Snapshots machen, aktualisiert Stacc jeden Tag, sodass Sie Positionsänderungen sofort sehen, wenn sie eintreten — nicht Wochen später." },
  { q: "Welche Art von Rankings verfolgt Stacc?", a: "Stacc verfolgt lokale Pack-Rankings (die Top-3-Kartenergebnisse), Google Maps-Rankings und organische Suchergebnisse. Alle drei werden separat verfolgt, da dieselbe Website in verschiedenen SERP-Bereichen unterschiedlich abschneiden kann." },
  { q: "Kann ich die Rankings mehrerer Standorte verfolgen?", a: "Ja. Jeder Standort hat sein eigenes Keyword-Set und seinen eigenen Ranking-Verlauf. Vergleichen Sie die Performance über Standorte hinweg von einem Dashboard aus." },
  { q: "Werden Ranking-Benachrichtigungen gesendet?", a: "Ja. Konfigurieren Sie Benachrichtigungen für signifikante Positionsänderungen — ob ein Standort stark ansteigt oder fällt. So können Sie schnell reagieren, wenn etwas Ihre Aufmerksamkeit erfordert." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Rank-Tracking-Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "Tägliches lokales Rank-Tracking für Local Pack, Google Maps und organische Rankings. Alle Standorte und Keywords in einem Dashboard.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Rank-Tracking-Software", "item": "https://thestacc.com/de/rank-tracking-software/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Rank-Tracking-Software — Tägliches lokales Rank-Tracking | theStacc"
  description="Verfolgen Sie Local Pack, Google Maps und organische Rankings täglich für alle Standorte. Positionsänderungen sofort erkennen, Trends visualisieren, Erfolge messen."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Rank-Tracking-Software · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokales Rank-Tracking.<br />
            <span style="color:#4f39f6;">Täglich. Für jeden Standort.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Verfolgen Sie Local Pack, Google Maps und organische Rankings täglich für alle Standorte und Keywords. Sehen Sie Positionsänderungen sofort, wenn sie eintreten.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/funktionen/rank-tracking/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Rank-Tracking-Funktion ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Tägliche Updates für 1.200+ Standorte</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">3 Ranking-Flächen verfolgt</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Warum tägliche Ranking-Daten wichtig sind</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ein Ranking-Einbruch, den Sie heute entdecken,<br />kostet einen Bruchteil dessen, was Sie in 30 Tagen verlieren.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Ein Keyword, das von Position 3 auf Position 7 fällt, verliert über Nacht mehr als 50 % seiner Klickrate. Wenn Ihr Ranking-Tool wöchentlich oder monatlich aktualisiert, kann dieser Einbruch vier Wochen lang Ihren Traffic kosten, bevor Sie es überhaupt wissen. Bis Sie die Ursache diagnostiziert und reagiert haben, erholen Sie sich von einem monatlichen Defizit — nicht einem eintägigen.</p>
            <p>Tägliches Rank-Tracking verändert den Reaktionszeitraum. Eine Positionsänderung von gestern kann heute noch behoben werden. Sie erkennen Algorithmus-Verschiebungen, Wettbewerber-Veränderungen und Ranking-Rückgänge an Tag 1 — nicht an Tag 30.</p>
            <p class="font-semibold text-[#111827]">Und für lokale Unternehmen ist das Ranking im Local Pack und Maps ein anderes Signal als das organische — und erfordert unterschiedliche Beobachtung. Stacc verfolgt beides separat, damit Sie immer genau wissen, wo Sie in jeder Platzierungsart stehen.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Staccs Rank-Tracking enthält</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Vollständige Sichtbarkeit. Täglich aktualisiert.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Local Pack + Maps-Tracking', body: 'Verfolgen Sie Ihre Position im Google-Local-3-Pack und Maps separat von organisch. Für lokale Unternehmen generiert die Pack-Platzierung die klickintensivsten Besuche.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Tägliche Updates, null manuelle Prüfungen', body: 'Rankings werden alle 24 Stunden automatisch aktualisiert. Öffnen Sie jeden Morgen Ihr Dashboard und sehen Sie, wo jedes Keyword steht — keine manuelle Verfolgung nötig.' },
            { icon: 'M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2', title: 'Multi-Standort-Vergleich', body: 'Alle Standorte für jedes Keyword nebeneinander sehen. Identifizieren Sie, welche Märkte Sie gewinnen und welche Aufmerksamkeit benötigen — in einer einzigen Portfolio-Ansicht.' },
            { icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', title: 'Ranking-Änderungs-Benachrichtigungen', body: 'Konfigurieren Sie Benachrichtigungen für signifikante Ranking-Bewegungen — Keywords, die in die Top 3 eintreten oder sie verlassen, Abfälle von 3+ Positionen, Keywords, die erstmals Seite 1 erreichen.' },
            { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Trend-Analyse', body: '30-, 60- und 90-Tage-Ranking-Trendansichten pro Keyword und Standort. Identifizieren Sie Dynamik und erkennen Sie frühe Warnsignale algorithmischer Auswirkungen.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Ranking-Daten in Kundenberichten', body: 'Ranking-Daten fließen direkt in automatisierte Kundenberichte ein. Berichte werden nach Ihrem Zeitplan erstellt und zugestellt — White-Label unter Ihrer Marke.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Tägliche Ranking-Daten, Multi-Standort-Vergleich<br />und automatische Benachrichtigungen — alles an einem Ort.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Tägliches Ranking-Dashboard</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Jede Keyword-Position jeden Morgen aktualisiert. Local Pack, Maps und organisch — separat.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Öffnen Sie Stacc jeden Morgen und jedes verfolgte Keyword zeigt seine aktuelle Position — im lokalen 3-Pack, in Maps und in organischen Ergebnissen. Drei separate Zahlen, denn für lokale Unternehmen können sie sich unabhängig voneinander bewegen. Position 1 in organisch mit Position 7 in Maps ist eine völlig andere Situation als umgekehrt. Stacc zeigt Ihnen beides, damit Sie immer wissen, wo die Chance liegt.
              </p>
              <a href="/de/funktionen/rank-tracking/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Rank-Tracking im Detail ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Heutiges Ranking-Update</p>
              {[
                { kw: 'Zahnarzt in meiner Nähe', pack: 1, org: 3, change: '+2', trend: 'up' },
                { kw: 'Notfallzahnarzt [Stadt]', pack: 2, org: 5, change: '+1', trend: 'up' },
                { kw: 'Zahnaufhellung in meiner Nähe', pack: 3, org: 4, change: '+4', trend: 'up' },
                { kw: 'Zahnimplantate [Stadt]', pack: 5, org: 8, change: '0', trend: 'flat' },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <span class="flex-1 font-sans text-[12px] text-[#374151] truncate">{r.kw}</span>
                  <div class="flex gap-1.5">
                    <div class={`flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-[10px] font-bold ${r.pack <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>#{r.pack}</div>
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f5f3ff] text-[10px] font-bold text-[#79716b]">#{r.org}</div>
                  </div>
                  <span class={`font-mono text-[11px] font-semibold ${r.trend === 'up' ? 'text-[#059669]' : 'text-[#79716b]'}`}>{r.trend === 'up' ? '↑' : '→'} {r.change}</span>
                </div>
              ))}
              <div class="mt-3 flex items-center justify-between">
                <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Pack · Organisch · Täglich aktualisiert</p>
                <span class="rounded-full bg-[#f5f3ff] px-2 py-1 font-mono text-[9px] font-semibold text-[#4f39f6]">VOLLAUTOMATISCH</span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Multi-Standort-Vergleich</p>
              {[
                { name: 'Innenstadt Hamburg', rank: 1, score: 94, trend: '↑' },
                { name: 'Altona', rank: 2, score: 89, trend: '↑' },
                { name: 'Eimsbüttel', rank: 3, score: 85, trend: '→' },
                { name: 'Wandsbek', rank: 8, score: 52, trend: '↓' },
              ].map(loc => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[11px] font-bold ${loc.rank <= 3 ? 'bg-[#4f39f6] text-white' : 'bg-[#fff1f2] text-[#ef4444]'}`}>#{loc.rank}</div>
                  <span class="flex-1 font-sans text-[13px] text-[#374151]">{loc.name}</span>
                  <div class="h-1.5 w-16 rounded-full bg-[#f5f3ff]"><div class="h-1.5 rounded-full bg-[#4f39f6]" style={`width:${loc.score}%`}></div></div>
                  <span class={`font-mono text-[11px] font-semibold ${loc.trend === '↑' ? 'text-[#059669]' : loc.trend === '↓' ? 'text-[#ef4444]' : 'text-[#79716b]'}`}>{loc.trend}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Alle Standorte verglichen · Täglich aktualisiert</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Portfolio-Ranking-Ansicht</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Jeder Standort nebeneinander gereiht. Underperformer sofort sichtbar.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Mehrere Standorte zu verwalten bedeutet, auf einen Blick zu wissen, welche gewinnen und welche Aufmerksamkeit brauchen. Die Portfolio-Ranking-Ansicht zeigt die Position jedes Standorts für jedes verfolgte Keyword, sortierbar nach jedem beliebigen Kriterium. Sie prüfen nicht jeden Standort einzeln. Sie sehen das Gesamtbild in einer Ansicht und handeln, wo es wichtig ist.
              </p>
              <a href="/de/multi-standort-seo-software/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Multi-Standort-SEO ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Ranking-Änderungs-Benachrichtigungen</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Ranking-Bewegungen erkennen — bevor Ihr Kunde es tut.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Legen Sie schwellenwertbasierte Benachrichtigungen für jedes verfolgte Keyword fest: Benachrichtigung, wenn ein Keyword die Top 3 verlässt, zum ersten Mal in die Top 3 eintritt oder sich um 3+ Positionen in eine Richtung bewegt. Benachrichtigungen werden sofort per E-Mail gesendet. Für Agenturen bedeutet das, dass Sie immer als Erste informiert sind — so können Sie reagieren, kommunizieren und Mehrwert zeigen, bevor der Kunde etwas bemerkt.
              </p>
              <a href="/de/loesungen/agenturen/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Stacc für Agenturen ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Ranking-Benachrichtigungen — diese Woche</p>
              {[
                { type: 'up', kw: '"Klempner in meiner Nähe" — Top 3 erreicht', time: 'vor 2 Std.', loc: 'München-Mitte' },
                { type: 'down', kw: '"Notfallklempner" — auf #6 gefallen', time: 'vor 1 Tag', loc: 'Schwabing' },
                { type: 'up', kw: '"Heizungsreparatur" — Platz #1 erreicht', time: 'vor 2 Tagen', loc: 'München-Mitte' },
                { type: 'up', kw: '"Rohrreinigung" — Top 3 erreicht', time: 'vor 3 Tagen', loc: 'Pasing' },
              ].map(a => (
                <div class="flex items-start gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[10px] ${a.type === 'up' ? 'bg-[#dcfce7] text-[#059669]' : 'bg-[#fff1f2] text-[#ef4444]'}`}>{a.type === 'up' ? '↑' : '↓'}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-medium text-[#111827] truncate">{a.kw}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">{a.loc} · {a.time}</p>
                  </div>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Sofortige E-Mail-Zustellung · Null manuelle Prüfungen</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
