---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist ein SEO-Reseller?", a: "Ein SEO-Reseller ist eine Agentur oder ein Berater, der lokale SEO-Dienste für Kunden über eine Drittanbieter-Plattform anbietet — white-labeled als eigene. Die Agentur legt ihre eigenen Preise fest, verwaltet Kundenbeziehungen und liefert Ergebnisse über die Reseller-Plattform unter ihrer eigenen Marke." },
  { q: "Wie funktioniert Stacc als SEO-Reseller-Plattform?", a: "Sie registrieren sich bei Stacc, konfigurieren die White-Label-Einstellungen (Ihr Logo, Domain, Farben) und verwalten dann alle lokalen SEO-Aktivitäten für Kunden über Ihr gebrandmarktes Dashboard. Kunden sehen Ihre Marke. Sie liefern echte lokale SEO-Ergebnisse — GBP-Verwaltung, Rank-Tracking, Citations, Bewertungen, Berichte — unter Ihrem Namen." },
  { q: "Welche Marge kann ich mit dem Weiterverkauf von Stacc erzielen?", a: "Stacc beginnt ab 49 €/Monat für das Lokales-SEO-Modul. Die meisten Agenturen berechnen Kunden 300–1.500 €/Monat für lokale SEO-Dienste. Die Marge zwischen Ihren Kosten und Ihren Kunden­preisen gehört Ihnen." },
  { q: "Müssen Kunden wissen, dass ich Stacc verwende?", a: "Nein. White-Label bedeutet vollständige Markenersetzung. Ihr Logo auf jedem Bildschirm, Ihre Domain in jeder URL, Ihr Name auf jedem Bericht. Das Branding von Stacc erscheint nirgendwo im Kunden-Erlebnis." },
  { q: "Kann ich alle meine Reseller-Kunden von einem Konto aus verwalten?", a: "Ja. Ein Stacc-Konto deckt alle Ihre Kunden ab. Jeder Kunde erhält seinen eigenen, auf Ihr gebrandmarktes Dashboard beschränkten Login. Sie haben Admin-Sichtbarkeit über alle Kunden aus einer einzigen Agentur-Ansicht." },
  { q: "Wie viel laufende Arbeit muss ich pro Kunde leisten?", a: "Minimal. Nach der Ersteinrichtung (GBP verbinden, Keywords konfigurieren, Berichterstattung einrichten) automatisiert Stacc die laufende Arbeit: GBP-Posts, Rank-Tracking, Citation-Monitoring, Bewertungswarnungen und Berichtslieferung — automatisch. Ihre laufende Arbeit pro Kunde beschränkt sich auf strategische Aufsicht, nicht tägliche Ausführung." },
  { q: "Kann ich lokales SEO als Reseller anbieten, ohne ein eigenes SEO-Team zu haben?", a: "Ja. Staccs Automatisierung übernimmt die Ausführung, die normalerweise einen SEO-Spezialisten pro Kunde erfordern würde. Viele Einzelunternehmer und kleine Agenturen nutzen Stacc, um lokale SEO-Dienste anzubieten, ohne dediziertes internes SEO-Personal." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO-Reseller-Plattform", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "White-Label-SEO-Reseller-Plattform. Lokale SEO-Ergebnisse für Kunden unter Ihrer Agenturmarke liefern. Vollständige Automatisierung, vollständiges White-Label, kein Stacc-Branding sichtbar.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "SEO-Reseller", "item": "https://thestacc.com/de/seo-reseller/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="SEO-Reseller-Programm — White-Label lokales SEO für Agenturen | theStacc"
  description="Lokale SEO-Dienste unter Ihrer Agenturmarke weiterverkaufen. theStacc ist eine vollständige White-Label-SEO-Reseller-Plattform — automatisierte Lieferung, gebrandmarkte Dashboards, kein Stacc-Branding sichtbar."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO-Reseller · White-Label Lokales SEO · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokale SEO-Dienste weiterverkaufen<br />
            <span style="color:#4f39f6;">vollständig unter Ihrer Marke.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc ist die White-Label-Plattform für lokales SEO, mit der Sie Kunden Ergebnisse unter Ihrer eigenen Marke liefern können. Vollständige Automatisierung, gebrandmarkte Dashboards, automatisierte Berichterstattung — und Stacc erscheint nie in etwas, das Kunden sehen.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/loesungen/agenturen/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              Agentur-Funktionen ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">400+ Unternehmen und Agenturen</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1.200+ verwaltete Standorte</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Wie SEO-Reselling mit Stacc funktioniert</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sie verkaufen. Stacc liefert.<br />Kunden sehen die ganze Zeit Ihre Marke.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Die Wirtschaftlichkeit eines SEO-Reseller-Geschäfts funktioniert, wenn Ihre Kosten pro Kunde niedrig und Ihre Lieferung automatisiert sind. Lokale SEO-Kunden zahlen typischerweise 300–1.500 €/Monat. Staccs Lokales-SEO-Modul beginnt ab 49 €/Monat pro Konto ohne Gebühren pro Kunde über die Standortanzahl hinaus. Die Marge zwischen Ihren Kosten und Ihren Kunden­preisen gehört Ihnen.</p>
            <p>Das operative Modell ist unkompliziert: Sie onboarden einen Kunden (GBP verbinden, Keywords konfigurieren, Berichterstattung einrichten), und von diesem Punkt an übernimmt Stacc die laufende Ausführung — GBP-Posts, Rank-Tracking, Citation-Monitoring, Bewertungswarnungen und Berichtslieferung — automatisch. Ihre Zeit pro Kunde reduziert sich auf strategische Aufsicht und gelegentliche Bewertungsantworten. Sie skalieren, indem Sie Kunden hinzufügen, nicht Köpfe.</p>
            <p class="font-semibold text-[#111827]">Und weil alles white-labeled ist, erleben Ihre Kunden es als Ihre proprietäre Plattform. Sie wissen nie, dass Stacc existiert. Die Beziehung, der Markenwert und die Marge gehören vollständig Ihnen.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reseller-Plattform-Funktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alles, was ein lokaler SEO-Reseller<br />auf einer Plattform braucht.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Vollständiges White-Label', body: 'Ihr Logo, Ihre Domain, Ihre Farben — auf jedem Dashboard und Bericht.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP-Management für Kunden', body: '30 Posts/Monat pro Kundenstandort, automatisch veröffentlicht.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Kunden-Rank-Tracking', body: 'Täglich aktualisierte Rankings für alle Kundenstandorte und Keywords.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Zitationsverwaltung', body: 'NAP-Konsistenz in 50+ Verzeichnissen für alle Kunden.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Automatisierte Berichte', body: 'Monatliche White-Label-SEO-Berichte automatisch erstellt und zugestellt.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Multi-Kunden-Verwaltung', body: 'Alle Kunden in einem Dashboard mit schnellem Wechsel zwischen Accounts.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURE SHOWCASE -->
    <section id="features" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Schlüsselfunktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Lokales SEO verkaufen.<br />Stacc liefert die Ergebnisse.
          </h2>
        </div>

        <div class="mx-auto max-w-6xl space-y-16">

          <!-- Showcase 1: Lokale SEO verkaufen -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">SEO-Reseller ohne eigene Infrastruktur</span>
