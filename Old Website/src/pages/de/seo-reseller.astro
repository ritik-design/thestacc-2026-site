              </a>
            </div>
          </div>

          <!-- Showcase 3: Skalieren -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automatisierte Skalierung</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Skalieren ohne mehr Mitarbeiter.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Traditionelles SEO-Reselling hat ein Skalierungsproblem: Mehr Kunden bedeuten mehr manuelle Arbeit, was mehr Mitarbeiter erfordert. Stacc bricht diesen Zusammenhang. Automatisierung übernimmt die laufende Ausführung für jeden Kunden — GBP-Posts, Rank-Updates, Zitationsmonitoring, Berichtslieferung. Ein Agenturmitarbeiter kann 20+ lokale SEO-Kunden verwalten, statt 5–7 ohne Automatisierung. Neue Kunden konfigurieren, und die Plattform übernimmt den Rest — ohne Teamwachstum.
              </p>
              <a href="/de/loesungen/agenturen/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Stacc für Agenturen ansehen
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Kunden-Portfolio-Übersicht</p>
              {[
                { client: 'Müller Sanitär GmbH', status: 'Aktiv', rank: '#1', ok: true },
                { client: 'Zahnarzt Dr. Schmidt', status: 'Aktiv', rank: '#2', ok: true },
                { client: 'Elite Heizung & Klima', status: 'Aktiv', rank: '#2', ok: true },
                { client: 'Kanzlei Weber & Partner', status: 'Aktiv', rank: '#4', ok: true },
                { client: 'Bäckerei Hoffmann', status: 'Aktiv', rank: '#1', ok: true },
              ].map(r => (
                <div class="flex items-center gap-3 border-t border-[#f5f3ff] py-3">
                  <div class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[12px] font-bold ${r.rank === '#1' || r.rank === '#2' ? 'bg-[#4f39f6] text-white' : 'bg-[#f5f3ff] text-[#4f39f6]'}`}>{r.rank}</div>
                  <div class="flex-1 min-w-0">
                    <p class="font-sans text-[12px] font-semibold text-[#111827] truncate">{r.client}</p>
                    <p class="font-mono text-[10px] text-[#79716b]">Local Pack Position</p>
                  </div>
                  <span class="font-mono text-[11px] font-semibold text-[#059669] shrink-0">✓ {r.status}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">20+ Kunden · Ein Dashboard · Alle automatisiert</p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- METRIKEN -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
