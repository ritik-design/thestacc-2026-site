                  <p class="font-mono text-[10px] text-[#79716b]">dashboard.ihredomain.de</p>
                </div>
                <span class="ml-auto font-mono text-[10px] font-semibold text-[#059669]">✓ Live</span>
              </div>
              {[
                { label: 'Branding', val: 'Vollständig Ihre Marke' },
                { label: 'Stacc sichtbar', val: 'Nirgendwo' },
                { label: 'Kunden-Login', val: 'Ihre Domain' },
                { label: 'Einrichtungszeit', val: 'Ca. 2 Stunden' },
              ].map(row => (
                <div class="flex items-center justify-between border-t border-[#f5f3ff] py-3">
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class="font-sans text-[13px] font-semibold text-[#111827]">{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Vollständiges White-Label · Sofort einsatzbereit</p>
            </div>
          </div>

          <!-- Showcase 2: Marge -->
          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Kosten vs. Einnahmen — Pro Kunde</p>
