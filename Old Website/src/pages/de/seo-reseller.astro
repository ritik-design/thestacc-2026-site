                { label: 'Stacc-Plattformkosten', val: 'Ab 49 €/Monat', highlight: false },
                { label: 'Typischer Kundenpreis', val: '300–1.500 €/Monat', highlight: false },
                { label: 'Ihre Marge', val: '251–1.451 €/Kunde', highlight: true },
                { label: 'Manuelle Arbeit pro Kunde', val: 'Unter 1 Std./Monat', highlight: false },
              ].map(row => (
                <div class={`flex items-center justify-between border-t border-[#f5f3ff] py-3 ${row.highlight ? 'bg-[#f5f3ff] -mx-4 px-4 rounded' : ''}`}>
                  <span class="font-sans text-[13px] text-[#57534e]">{row.label}</span>
                  <span class={`font-sans text-[13px] font-semibold ${row.highlight ? 'text-[#4f39f6]' : 'text-[#111827]'}`}>{row.val}</span>
                </div>
              ))}
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">Sie legen Ihre eigenen Preise fest · Marge gehört Ihnen</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reseller-Wirtschaftlichkeit</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                300–1.500 € Marge pro Kunde.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Lokale SEO-Kunden zahlen typischerweise 300–1.500 €/Monat für professionelle Dienstleistungen. Staccs Lokales-SEO-Modul beginnt ab 49 €/Monat für Ihr gesamtes Konto — nicht pro Kunde. Die Marge zwischen dem, was Sie berechnen, und dem, was Stacc kostet, gehört vollständig Ihnen. Sie legen Ihre eigenen Preise fest. Kein Umsatzteilung, keine versteckten Gebühren pro Kunden-Login, keine Beschränkungen beim Skalieren. Mehr Kunden bedeuten mehr Marge — nicht proportional steigende Kosten.
              </p>
              <a href="/de/preise/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                Preise ansehen
