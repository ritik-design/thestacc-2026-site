---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';
import { SITE_URL, buildBreadcrumbs } from '../../../utils/schema';

const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true  },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true  },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true  },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",               showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",       showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
];

const howItWorksSteps = [
  {
    n: '01',
    title: 'URL eingeben und Branche angeben',
    body: 'Stacc liest Ihre bestehenden Inhalte, analysiert Ihren Markt und identifiziert alle Keyword-Lücken, die Ihr Wettbewerber bereits nutzt. In unter 5 Minuten.',
  },
  {
    n: '02',
    title: 'Stacc erstellt Ihren 30-Artikel-Plan',
    body: 'Kein generischer Content-Kalender. Ein präziser, wettbewerbsorientierter Veröffentlichungsplan, der auf die Begriffe ausgerichtet ist, die Ihre Kunden in Google eingeben.',
  },
  {
    n: '03',
    title: 'Artikel werden verfasst und optimiert',
    body: 'Jeder Artikel wird für Ihr spezifisches Keyword geschrieben, durch interne Verlinkung, Meta-Tags und Schema-Markup optimiert und vor der Veröffentlichung bewertet.',
  },
  {
    n: '04',
    title: 'Automatisch auf Ihrer Website veröffentlicht',
    body: 'Direkte Integration mit WordPress, Webflow, Ghost und weiteren CMS-Systemen. Artikel erscheinen planmäßig auf Ihrer Website. Ohne dass Sie eingreifen müssen.',
  },
];

const features = [
  { title: 'Keyword-Recherche auf Marktebene', text: 'Nicht allgemeine Keywords — die genauen Begriffe, die Ihre Kunden in Ihrer Stadt und Branche suchen. Bewertet nach Traffic-Potenzial, Schwierigkeit und Conversion-Wahrscheinlichkeit.' },
  { title: 'KI-Textgenerierung in Ihrer Markensprache', text: 'Stacc analysiert Ihren bestehenden Content und lernt Ihren Schreibstil. Die Artikel klingen nach Ihnen — nicht nach einem generischen KI-Tool.' },
  { title: 'SEO-Bewertung vor der Veröffentlichung', text: 'Jeder Artikel wird vor der Veröffentlichung bewertet: Keyword-Dichte, Lesbarkeit, interne Verlinkungsstruktur, Meta-Tags und Schema-Markup. Kein Artikel, der unter dem Schwellenwert liegt, wird veröffentlicht.' },
  { title: 'Automatische interne Verlinkung', text: 'Stacc verbindet neue Artikel mit bestehenden Seiten auf Ihrer Website und verteilt die Linkautorität automatisch — ein kritischer SEO-Faktor, den die meisten Unternehmen ignorieren.' },
  { title: 'CMS-Integration ohne Plugins', text: 'Direkte Veröffentlichung in WordPress, Webflow und Ghost ohne Plugins. Für andere Systeme: REST-API oder Webhook. Einmalige Einrichtung in weniger als 10 Minuten.' },
  { title: 'Vollständiger Content-Kalender', text: 'Sehen Sie, was wann veröffentlicht wird. Genehmigen Sie individuell oder aktivieren Sie die vollautomatische Veröffentlichung. Die meisten Kunden wechseln nach dem ersten Monat zur automatischen Veröffentlichung.' },
];

const faqs = [
  {
    q: "Bestraft Google KI-generierte Inhalte?",
    a: "Googles eigene Richtlinien sind eindeutig: Qualität und Nutzen zählen — nicht wie der Inhalt erstellt wurde. Jeder Artikel, den Stacc veröffentlicht, basiert auf echter Keyword-Recherche, ist geschrieben, um echte Suchanfragen zu beantworten, und wird gegen SEO-Standards bewertet, bevor er veröffentlicht wird. Unsere Kunden haben Millionen von Wörtern veröffentlicht, ohne eine einzige manuelle Maßnahme oder einen Ranking-Rückgang.",
  },
  {
    q: "Wie lange, bis ich Ergebnisse sehe?",
    a: "Die meisten Kunden sehen innerhalb von 60–90 Tagen signifikante Ranking-Bewegungen. SEO ist ein kumulatives Asset. Jeder Artikel, den Sie veröffentlichen, macht den nächsten einfacher zu ranken. Je früher Sie beginnen, desto größer der Vorsprung gegenüber Wettbewerbern, die noch zögern.",
  },
  {
    q: "Welche CMS-Plattformen werden unterstützt?",
    a: "WordPress, Webflow und Ghost sind vollständig integriert. Direkte Veröffentlichung, ohne Plugins. Jedes CMS mit REST-API- oder Webhook-Unterstützung funktioniert ebenfalls automatisch. Und wenn Sie etwas Benutzerdefiniertes nutzen, können Sie exportieren und einfügen. Der Content gehört immer Ihnen.",
  },
  {
    q: "Kann ich Artikel vor der Veröffentlichung bearbeiten?",
    a: "Jeder Artikel befindet sich vor der Veröffentlichung in einer Überprüfungswarteschlange. Bearbeiten, genehmigen oder aktivieren Sie die automatische Veröffentlichung. Die meisten Kunden überprüfen die ersten Chargen und wechseln dann zur automatischen Veröffentlichung, wenn sie feststellen, dass die Qualität konstant bleibt. Danach erscheint der Content einfach auf ihrer Website.",
  },
  {
    q: "Was passiert, wenn ich kündige? Behalte ich meinen Content?",
    a: "Jeder auf Ihrer Website veröffentlichte Artikel gehört Ihnen dauerhaft. Kündigen Sie heute und diese Seiten ranken weiter, generieren Traffic und gewinnen Interessenten. Für immer. Sie besitzen 100 % aller veröffentlichten Inhalte.",
  },
  {
    q: "Wie unterscheidet sich das von ChatGPT?",
    a: "ChatGPT schreibt Wörter. Stacc rankt Seiten. Der Unterschied liegt in der SEO-Schicht: Keyword-Recherche, die auf Ihren echten Markt zugeschnitten ist, Optimierungsbewertung, interne Verlinkung, Meta-Tags, Schema-Markup und dann direkte Veröffentlichung in Ihrem CMS. ChatGPT liefert einen Entwurf, den niemand finden wird. Stacc liefert eine live, indexierte, rankende Seite.",
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'theStacc — Blog-SEO-Modul',
      description: 'KI-gestützter Blogpost-Generator, der 30 SEO-optimierte Artikel pro Monat automatisch auf Ihrer Website veröffentlicht.',
      url: `${SITE_URL}/de/module/blog-seo/`,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      inLanguage: 'de',
      offers: { '@type': 'Offer', price: '99.00', priceCurrency: 'USD' },
      provider: { '@type': 'Organization', name: 'theStacc', url: SITE_URL },
    },
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/de/module/blog-seo/`,
      name: 'Blog-SEO-Modul | theStacc | Ihre Website zur SEO-Lead-Maschine machen',
      url: `${SITE_URL}/de/module/blog-seo/`,
      inLanguage: 'de',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(`${SITE_URL}/de/module/blog-seo/`, [
      { name: 'Startseite', url: `${SITE_URL}/de/` },
      { name: 'Module', url: `${SITE_URL}/de/` },
      { name: 'Blog-SEO', url: `${SITE_URL}/de/module/blog-seo/` },
    ]),
  ],
};
---

<BaseLayout
  title="Blog-SEO-Modul | theStacc | Ihre Website zur SEO-Lead-Maschine machen"
  description="Stacc veröffentlicht jeden Monat 30 SEO-optimierte Artikel automatisch auf Ihrer Website. Mehr Artikel bedeuten mehr Rankings. Mehr Rankings bedeuten mehr Kunden. Start für $1."
  lang="de"
>
  <Header />
  <main>
    <script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[760px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Blog-SEO-Modul · $99/Monat zzgl. MwSt.</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Machen Sie Ihre Website zur<br class="hidden md:block" />
            <span style="color:#4f39f6;">SEO-Lead-Maschine.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[560px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc veröffentlicht 30 SEO-optimierte Artikel pro Monat automatisch auf Ihrer Website. Mehr Artikel bedeuten mehr Rankings. Mehr Rankings bedeuten mehr Kunden — ohne dass Sie ein einziges Wort anfassen.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/de/demo/"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Für $1 heute starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              So funktioniert es
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            30 Tage Garantie · Keine Kreditkarte erforderlich · Jeder veröffentlichte Artikel bleibt dauerhaft Ihrer
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '12.000+', label: 'Veröffentlichte Artikel' },
              { value: '340+',    label: 'Lokale Unternehmen' },
              { value: '4,9★',    label: 'Durchschnittsbewertung' },
              { value: '0',       label: 'Ranking-Strafen' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]">{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Mit Stacc rankende Unternehmen</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4,9 von 127 Bewertungen</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee">
            {[...customers, ...customers].map((c) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <img src={c.logo} alt={c.name} width="120" height="40" class={c.showName ? "h-[28px] w-[28px] object-contain grayscale opacity-50" : "h-[32px] w-auto object-contain grayscale opacity-50"} loading="lazy" />
                {c.showName && <span class="font-mono text-[15px] font-medium text-[#374151] whitespace-nowrap">{c.name}</span>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PROBLEM SECTION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Das Problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Sie wissen, dass Content der Weg ist, gefunden zu werden.<br />Aber die Zahlen passen nie.
          </h2>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Sie brauchen 30 Artikel. Letztes Jahr haben Sie 2 veröffentlicht.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Google belohnt Unternehmen, die regelmäßig erscheinen. Jede Woche, in der Sie nicht veröffentlichen, tut es Ihr Wettbewerber. Diese Ranking-Lücke akkumuliert sich. Und je länger Sie warten, desto schwieriger wird es, sie zu schließen.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">SEO-Texter berechnen $200–$400 pro Artikel. Pro Artikel.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">30 Artikel pro Monat von einem Freelancer kosten $6.000–$12.000. Eine Agentur berechnet $3.500 und schreibt vielleicht 6 Beiträge. Die ROI-Zahlen funktionieren nie. Also fangen Sie nicht an. Und Ihr Wettbewerber rankt weiter vor Ihnen.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Schreiben ohne SEO-Strategie rankt nicht.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Keyword-Recherche, interne Verlinkung, optimierte Meta-Tags, Schema-Markup. Das sind 3 Stunden zusätzliche Arbeit pro Artikel. Wenn Sie einen Teil auslassen, haben Sie etwas veröffentlicht, das niemand finden wird. Sie brauchen das vollständige System — nicht nur Wörter.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            In 5 Minuten einrichten.<br />Danach vollautomatisch.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Verbinden Sie Ihre Website einmalig. Stacc identifiziert Ihre Keyword-Lücken, lernt Ihre Markensprache und beginnt zu veröffentlichen. Sie werden den Traffic-Anstieg bemerken, bevor Sie zweimal darüber nachgedacht haben.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-4xl grid grid-cols-1 gap-6 md:grid-cols-2">
          {howItWorksSteps.map(step => (
            <div class="flex gap-5 rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-7">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#4f39f6] font-mono text-[12px] font-bold text-white">{step.n}</span>
              <div>
                <h3 class="font-sans text-[15px] font-semibold text-[#111827]">{step.title}</h3>
                <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{step.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FEATURES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Im Lieferumfang enthalten</span>
          <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2rem]">
            Alles, was Sie brauchen, um täglich zu ranken.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {features.map(f => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#f0effe]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              </div>
              <h3 class="mt-4 font-sans text-[15px] font-semibold text-[#111827]">{f.title}</h3>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16 md:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Häufige Fragen</span>
          <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2rem]">
            Antworten, die Sie brauchen.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {faqs.map(faq => (
            <details class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9]">
              <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <svg class="shrink-0 transition-transform group-open:rotate-180" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="border-t border-[#e7e5e4] px-6 py-5">
                <p class="font-sans text-[14px] leading-[1.7] text-[#57534e]">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── CTA ─── -->
    <section style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-[580px] text-center">
          <h2 class="font-sans text-[2rem] font-semibold leading-[1.18] tracking-[-0.03em] text-[#292524] md:text-[2.4rem]">
            Ihr Wettbewerber veröffentlicht gerade. Sie noch nicht.
          </h2>
          <p class="mx-auto mt-4 font-sans text-[1rem] leading-[1.7]" style="color:#6b7280;">
            Jede Woche ohne konsistente Blog-Inhalte ist eine Woche, in der Ihr Wettbewerber einen weiteren Artikel indexiert. Starten Sie heute für $1. Kein Vertrag. DSGVO-konform.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
