---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';
---

<BaseLayout
  title="Kostenlose lokale SEO-Tools — Für lokale Unternehmen | theStacc"
  description="Kostenlose lokale SEO-Tools von theStacc. Analysieren Sie Ihre lokale Sichtbarkeit, prüfen Sie Ihre GBP-Einträge und verstehen Sie Ihre Rankings."
  lang="de"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.04) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.04) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white/5 px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#818cf8]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-white/60">Kostenlose Tools · Keine Anmeldung erforderlich</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Kostenlose lokale SEO-Tools.<br />
            <span style="color:#818cf8;">Sofort einsetzbar.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Analysieren Sie Ihre lokale Sichtbarkeit mit kostenlosen Tools von theStacc — ohne Anmeldung oder Kreditkarte.
          </p>
          <div class="mt-8">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Vollversion testen
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-4xl text-center">
          <h2 class="font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">Alle kostenlosen Tools</h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">Weitere kostenlose lokale SEO-Tools werden in Kürze hinzugefügt. In der Zwischenzeit testen Sie die vollständige Stacc-Plattform für 1 € im ersten Monat.</p>
          <div class="mt-8">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">Jetzt für 1 € starten</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
