---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/de/HeaderDe.astro';
import Footer from '../../../components/de/FooterDe.astro';
---

<BaseLayout
  title="Kostenloser SEO-ROI-Rechner — Return on Investment berechnen | theStacc"
  description="Berechnen Sie den ROI Ihrer SEO-Investitionen kostenlos. Branchen-Presets für Zahnärzte, Klempner, Rechtsanwälte und mehr. 12-Monats-Prognosen inklusive."
  lang="de"
>
  <Fragment slot="head">
  </Fragment>

  <Header />
  <main>
    <!-- Dark hero -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.04) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.04) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white/5 px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#818cf8]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-white/60">SEO-ROI-Rechner · Kostenlos</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            SEO-Rendite in 10 Sekunden berechnen.<br />
            <span style="color:#818cf8;">Mit Branchen-Presets.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Geben Sie Ihre Branche, aktuelle Traffic-Daten und SEO-Investition ein — und sehen Sie sofort Ihre projizierte Rendite über 12 Monate. Mit Branchen-Presets für lokale Dienstleister, DIY-Vergleich und Prognosen für Agentur vs. Stacc.
          </p>
          <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
            <a href="/tools/seo-roi-calculator/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Tool verwenden
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white/5 px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-white/10">
              Vollversion testen
            </a>
          </div>
          <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.18em] text-[#292524]/20">Kostenlos · Keine Anmeldung erforderlich</p>
        </div>
      </div>
    </section>

    <!-- What it does — white bg -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mx-auto max-w-2xl">
          <h2 class="font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2rem]">Was macht der SEO-ROI-Rechner?</h2>
          <p class="mt-5 font-sans text-[1rem] leading-[1.75] text-[#57534e]">
            Der SEO-ROI-Rechner von theStacc berechnet Ihre projizierte SEO-Rendite basierend auf Ihrer Branche, aktuellem Website-Traffic, durchschnittlichem Kundenwert und monatlicher SEO-Investition. Das Ergebnis zeigt Ihnen den erwarteten zusätzlichen Umsatz über 12 Monate.
          </p>
          <p class="mt-4 font-sans text-[1rem] leading-[1.75] text-[#57534e]">
            Branchen-Presets für Zahnärzte, Klempner, Rechtsanwälte und andere lokale Dienstleister machen den Einstieg einfach. Der Rechner vergleicht auch DIY-SEO mit einer Agentur und mit theStacc — damit Sie die beste Entscheidung für Ihr Budget treffen können.
          </p>
          <div class="mt-8">
            <a href="/tools/seo-roi-calculator/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Tool verwenden
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Dark bottom CTA -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.03) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 text-center">
        <div class="mx-auto max-w-lg">
          <p class="font-sans text-[22px] font-bold leading-tight text-white">ROI berechnet.<br />Stacc liefert die Rendite — automatisch.</p>
          <p class="mt-3 font-sans text-[15px] leading-relaxed text-[#94a3b8]">SEO-optimierte Inhalte, GBP-Posts und lokale Rankings — ohne Agenturkosten. Bereits ab 49 $/Monat.</p>
          <a href="/de/demo/" class="mt-6 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]">Vollversion testen &rarr;</a>
          <p class="mt-3 font-mono text-xs text-[#64748b]">1 $ für 30 Tage · Jederzeit kündbar</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
