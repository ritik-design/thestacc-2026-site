---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';

const faqs = [
  { q: "Was ist White-Label-SEO?", a: "White-Label-SEO bedeutet, dass eine Agentur lokale SEO-Dienste für Kunden über eine Software bereitstellt, die mit dem eigenen Logo und der eigenen Domain der Agentur gebrandmarkt ist – nicht mit der des Software-Anbieters. Kunden erleben die Marke der Agentur auf jedem Dashboard, Bericht und jeder Benachrichtigung, ohne Einblick in die zugrundeliegenden Tools." },
  { q: "Was wird bei Stacc white-gelabelt?", a: "Alles, was der Kunde sieht: die Dashboard-URL (Ihre Domain per CNAME), alle Logos und Farben, Berichts-PDFs, automatische Berichtszustellung per E-Mail und Kunden-Login-Benachrichtigungen. Staccs Name und Branding erscheinen nirgendwo, wo Kunden es sehen." },
  { q: "Benötige ich technische Kenntnisse für das White-Label-Setup?", a: "Kein Entwickler erforderlich. Sie laden Ihr Logo hoch, legen den Agenturnamen und das Farbschema fest und konfigurieren einen CNAME-Eintrag für Ihre Subdomain. Die vollständige Einrichtung dauert etwa 2 Stunden. Alles wird über das Dashboard konfiguriert – kein Code, kein technisches Fachwissen nötig." },
  { q: "Kann jeder Kunde seinen eigenen Login haben?", a: "Ja. Jeder Kunde erhält einen Login, der auf seine eigenen Standorte beschränkt ist. Kunden können keine Daten anderer Kunden sehen. Sie behalten vollen Administratorzugriff auf alle Kunden. Kunden-Logins sind immer kostenlos, unabhängig von der Anzahl der hinzugefügten Kunden." },
  { q: "Kann ich eine benutzerdefinierte Domain für Kunden-Dashboards verwenden?", a: "Ja. Leiten Sie Ihre Subdomain (z.B. seo.ihreagentur.de) per CNAME-Eintrag auf Stacc. Alle kundenorientierten Dashboards laden auf Ihrer Domain. Staccs Domain erscheint in keiner Client-URL." },
  { q: "Beeinflusst das White-Labeling die Preisgestaltung?", a: "White-Label-Funktionen sind in Staccs Growth- und Scale-Plänen enthalten. Pläne beginnen ab 49 €/Monat für das lokale SEO-Modul. Kunden-Logins sind immer kostenlos pro Seat." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — White-Label-SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "inLanguage": "de", "description": "White-Label lokale SEO-Software für Agenturen. Gebrandmarkte Dashboards, Berichte und Kunden-Logins auf Ihrer Domain – Stacc erscheint nirgendwo, wo Kunden es sehen.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "EUR" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "White-Label-SEO", "item": "https://thestacc.com/de/white-label-seo/" }] },
    { "@type": "FAQPage", "inLanguage": "de", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="White-Label-SEO-Software für Agenturen — Ihre Marke auf allem | theStacc"
  description="White-Label lokales SEO für Agenturen. Gebrandmarkte Dashboards, Berichte und Kunden-Logins auf Ihrer Domain. Setup in 2 Stunden. Kunden-Logins für 0 €."
  lang="de"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- HERO -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">White-Label-SEO · Ab 49 €/Monat</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Lokales SEO bereitgestellt<br />
            <span style="color:#4f39f6;">unter dem Markennamen Ihrer Agentur.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Jedes Dashboard, jeder Bericht und jeder Kunden-Login trägt das Logo und die Domain Ihrer Agentur. Stacc erscheint nirgendwo, wo Kunden es sehen. Ihre Marke wird stärker, jedes Mal wenn ein Kunde einloggt und Ergebnisse sieht.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/de/demo/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Jetzt für 1 € starten
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/de/funktionen/white-label-dashboard/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              White-Label-Funktionen ansehen
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">Keine Kreditkarte erforderlich · Jederzeit kündbar</p>
          <!-- Trust bar: 5 stars -->
          <div class="mx-auto mt-8 inline-flex flex-wrap items-center justify-center gap-2">
            <div class="flex items-center gap-0.5">
              {[...Array(5)].map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#79716b]">4,9 / 5 · 127 Agenturen</span>
          </div>
          <div class="mx-auto mt-6 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">Eigene Domain (CNAME)</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">0 € pro Kunden-Login</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">2 Stunden Setup</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">400+ Agenturen</span>
          </div>
        </div>
      </div>
    </section>


    <!-- EDITORIAL SECTION -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Warum Marke bei jeder Kundeninteraktion wichtig ist</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jedes Tool mit dem Logo eines Anbieters<br />ist ein Touchpoint, den Ihre Marke nicht besitzt.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Wenn ein Kunde sich in ein Dashboard mit dem Namen eines Anbieters einloggt, denkt er nicht an Ihre Agentur — er denkt an diesen Anbieter. Jeder Login, jeder Bericht, jede E-Mail stärkt die Markenbekanntheit des Anbieters auf Ihre Kosten. Und wenn sie die Preisseite dieses Anbieters aufrufen, beginnen sie eine Frage zu stellen, die Sie nicht wollen.</p>
            <p>White-Label-SEO ändert diese Dynamik. Jede Interaktion, die ein Kunde mit Ihrem Service hat — jeder Login, jeder Bericht, jede Benachrichtigung — trägt den Namen und das Logo Ihrer Agentur. Die Ergebnisse, die sie sehen, werden mental Ihrem Team zugeordnet. Ihr Markenwert wächst mit jedem Bericht, der eintrifft. Und Kunden, die Ihre Marke konsequent bei positiven Ergebnissen sehen, bleiben länger.</p>
            <p class="font-semibold text-[#111827]">Staccs White-Label-Setup dauert 2 Stunden. Kunden-Logins kosten 0 €. Und jeder Kunden-Touchpoint stärkt von da an Ihre Marke — nicht unsere.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- FEATURES GRID -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">White-Label-Funktionen</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Alles kundenorientiert.<br />Alles Ihre Marke, nichts von uns.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Benutzerdefinierte Domain (CNAME)', body: 'Kunden-Dashboards laden auf Ihrer Subdomain (z.B. seo.ihreagentur.de). Staccs Domain erscheint in keiner Kunden-URL.' },
            { icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01', title: 'Vollständige Logo- und Markenanpassung', body: 'Laden Sie Ihr Logo hoch, legen Sie Ihr Farbschema fest, konfigurieren Sie Ihren Agenturnamen. Konsistente Markenidentität auf jedem Bildschirm, den Kunden sehen.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Gebrandmarkte automatische Berichte', body: 'Berichte tragen Ihr Logo, werden von Ihrer Domain gesendet und mit Ihren Farben formatiert. Werden nach Ihrem Zeitplan geliefert – ohne manuelle Arbeit.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: '0 € pro Kunden-Login', body: 'Unbegrenzte Kunden-Logins hinzufügen. Die Preisgestaltung basiert auf verwalteten Standorten – nicht auf Seats. Sie können jedem Kunden seinen eigenen Login geben, ohne Ihre Rechnung zu beeinflussen.' },
            { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'Gebrandmarkte E-Mail-Benachrichtigungen', body: 'Automatische Benachrichtigungen und Berichtszustellung per E-Mail werden von Ihrer Domain gesendet. Keine thestacc.com E-Mail-Adressen im Kunden-Posteingang.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Rollenbasierter Kundenzugriff', body: 'Kunden sehen nur ihre eigenen Standorte und Daten. Ihr Team hat vollen Admin-Überblick über alle Kunden. Berechtigungen werden auf Datenebene durchgesetzt.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- 1. FEATURE SHOWCASE -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">So funktioniert es in der Praxis</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Jede Funktion. Vollständig unter Ihrer Marke.
          </h2>
        </div>

        <div class="mx-auto max-w-5xl space-y-16">

          <!-- Feature 1: Custom Domain Dashboard -->
          <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">01 — Eigene Domain</span>
              <h3 class="mt-3 font-sans text-[1.5rem] font-semibold leading-[1.25] tracking-[-0.02em] text-[#111827]">
                Ihr Dashboard auf Ihrer Domain — nicht auf unserer.
              </h3>
              <p class="mt-4 font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">
                Kunden rufen seo.ihreagentur.de auf — nicht thestacc.com. Ein einziger CNAME-Eintrag bei Ihrem DNS-Anbieter genügt. Setup dauert 15 Minuten, danach laden alle Kunden-Dashboards dauerhaft auf Ihrer Domain. Kein Entwickler, kein Code.
              </p>
              <ul class="mt-5 space-y-2">
                {['Unbegrenzte Subdomains konfigurierbar', 'SSL automatisch bereitgestellt', 'Stacc-Domain nirgendwo sichtbar', 'Funktioniert mit allen DNS-Anbietern'].map(item => (
                  <li class="flex items-center gap-2 font-sans text-[13px] text-[#374151]">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <!-- Visual Mockup: Domain Browser Card -->
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 shadow-sm">
              <div class="mb-4 flex items-center gap-2">
                <div class="flex gap-1.5">
                  <span class="h-3 w-3 rounded-full bg-[#fee2e2]"></span>
                  <span class="h-3 w-3 rounded-full bg-[#fef3c7]"></span>
                  <span class="h-3 w-3 rounded-full bg-[#d1fae5]"></span>
                </div>
                <div class="flex-1 rounded-md border border-[#e7e5e4] bg-[#f9fafb] px-3 py-1.5">
                  <span class="font-mono text-[11px] text-[#374151]">seo.ihreagentur.de/dashboard/</span>
                </div>
                <div class="flex h-6 w-6 items-center justify-center rounded border border-[#e7e5e4]">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
              </div>
              <div class="flex items-center gap-3 rounded-xl border border-[#e7e5e4] bg-[#f5f3ff] px-4 py-3 mb-4">
                <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                  <span class="font-mono text-[10px] font-bold text-white">AG</span>
                </div>
                <div>
                  <p class="font-sans text-[13px] font-semibold text-[#111827]">Ihre Agentur GmbH</p>
                  <p class="font-mono text-[10px] text-[#6b7280]">SEO-Dashboard · Eingeloggt als Kunde</p>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                {[['Rankings', '+12 diese Woche'], ['GBP-Aufrufe', '1.847 / Mo.'], ['Bewertungen', '4,8 ★ (63)'], ['Zitationen', '94% korrekt']].map(([label, val]) => (
                  <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-3 py-3">
                    <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-[#9ca3af]">{label}</p>
                    <p class="mt-1 font-sans text-[15px] font-semibold text-[#111827]">{val}</p>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-center font-mono text-[9px] uppercase tracking-[0.1em] text-[#d1d5db]">Powered by Ihre Agentur — keine Stacc-Branding sichtbar</p>
            </div>
          </div>

          <!-- Feature 2: Branded Reports -->
          <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
            <!-- Visual Mockup: Report PDF Card -->
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-6 shadow-sm order-2 md:order-1">
              <div class="mb-4 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="h-8 w-8 rounded-lg bg-[#4f39f6] flex items-center justify-center">
                    <span class="font-mono text-[10px] font-bold text-white">AG</span>
                  </div>
                  <div>
                    <p class="font-sans text-[12px] font-semibold text-[#111827]">Ihre Agentur GmbH</p>
                    <p class="font-mono text-[9px] text-[#6b7280]">Monatlicher SEO-Bericht · April 2026</p>
                  </div>
                </div>
                <span class="rounded-full bg-[#d1fae5] px-2 py-0.5 font-mono text-[9px] font-semibold text-[#065f46]">PDF</span>
              </div>
              <div class="space-y-2 mb-4">
                {[['Keyword-Rankings', '38 Keywords in Top 3'], ['GBP-Aktivität', '12 Posts · 2.140 Aufrufe'], ['Neue Bewertungen', '+7 · Ø 4,9 Sterne'], ['Zitations-Score', '96% — +3% ggü. Vormonat']].map(([label, val]) => (
                  <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] px-3 py-2">
                    <span class="font-sans text-[11px] text-[#57534e]">{label}</span>
                    <span class="font-sans text-[11px] font-semibold text-[#111827]">{val}</span>
                  </div>
                ))}
              </div>
              <div class="rounded-xl border border-[#e7e5e4] bg-[#f5f3ff] px-4 py-3 text-center">
                <p class="font-mono text-[9px] uppercase tracking-[0.1em] text-[#6b7280]">Gesendet von: berichte@ihreagentur.de</p>
                <p class="mt-0.5 font-mono text-[9px] text-[#9ca3af]">Automatisch generiert — kein manueller Export</p>
              </div>
            </div>
            <div class="order-1 md:order-2">
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">02 — Automatische Berichte</span>
              <h3 class="mt-3 font-sans text-[1.5rem] font-semibold leading-[1.25] tracking-[-0.02em] text-[#111827]">
                Berichte, die sich selbst erstellen und versenden.
              </h3>
              <p class="mt-4 font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">
                Einmal konfiguriert — monatlich oder wöchentlich — erstellt Stacc automatisch einen vollständigen gebrandmarkten Bericht für jeden Kunden. Ihr Logo, Ihre Farben, Ihre Domain im E-Mail-Absender. Der Bericht landet direkt im Kunden-Posteingang, ohne dass Ihr Team auch nur einen Finger rührt.
              </p>
              <ul class="mt-5 space-y-2">
                {['PDF mit Ihrem Logo und Farbschema', 'E-Mail von Ihrer eigenen Domain', 'Wöchentlich oder monatlich planbar', 'Vorab-Prüfungsmodus verfügbar'].map(item => (
                  <li class="flex items-center gap-2 font-sans text-[13px] text-[#374151]">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Feature 3: Role-based Client Access -->
          <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-2">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">03 — Kundenzugriff</span>
              <h3 class="mt-3 font-sans text-[1.5rem] font-semibold leading-[1.25] tracking-[-0.02em] text-[#111827]">
                Jeder Kunde sieht nur seine eigenen Daten. Immer.
              </h3>
              <p class="mt-4 font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">
                Kunden-Logins sind auf die eigenen Standorte und Daten des jeweiligen Kunden beschränkt. Kein Kunde sieht jemals Daten eines anderen Kunden. Ihr Team behält den vollen Admin-Überblick über alle Kunden — in einem zentralen Dashboard. Kunden-Logins kosten immer 0 €, egal wie viele Kunden Sie hinzufügen.
              </p>
