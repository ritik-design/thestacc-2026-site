---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/de/HeaderDe.astro';
import Footer from '../../components/de/FooterDe.astro';
import { SITE_URL, LOGO_URL, buildBreadcrumbs } from '../../utils/schema';

const plans = [
  {
    name: 'Lokales Wachstum',
    tagline: 'Blog + Lokales SEO, vollständig verwaltet.',
    price: 749,
    annualPrice: 625,
    popular: false,
    features: [
      '30 Artikel veröffentlicht/Monat',
      '30 Google-Business-Beiträge/Monat',
      'Tägliches Bewertungsmonitoring und -antworten',
      'Wöchentliche Performance-Berichte',
      'Monatlicher Strategie-Videoanruf',
      '1 Standort enthalten (+$150/Standort extra)',
    ],
  },
  {
    name: 'Growth Pro',
    tagline: 'Blog + Lokales SEO + Social Media.',
    price: 999,
    annualPrice: 835,
    popular: true,
    features: [
      'Alles aus Lokales Wachstum',
      '60 Social-Media-Beiträge/Monat auf 6 Plattformen',
      'Plattformspezifischer Content und Hashtags',
      'Optimierter Veröffentlichungsplan',
      'Tägliches Engagement-Monitoring',
      'Monatliche Analysen + Strategiegespräch',
    ],
  },
  {
    name: 'Growth Complete',
    tagline: 'Alles: Blog, Lokal, Social und Website.',
    price: 1299,
    annualPrice: 999,
    popular: false,
    features: [
      'Alles aus Growth Pro',
      'KI-erstellte Website, gehostet und verwaltet',
      'Monatliche Updates und SEO-Optimierung',
      'Geschwindigkeitsmonitoring und Sicherheits-Patches',
      'Wöchentliche Berichte + monatlicher Strategieanruf',
      'US-basiertes Operations-Team',
    ],
  },
];

const steps = [
  {
    n: '01',
    title: '30-Minuten-Gespräch buchen',
    body: 'Schildern Sie Ihre Branche, Ziele und den aktuellen Stand Ihrer Sichtbarkeit. Kein Verkaufsdruck, keine Präsentationen. Nur ein sachliches Gespräch.',
  },
  {
    n: '02',
    title: 'Wir erstellen Ihren 90-Tage-Plan',
    body: 'Unser Team definiert Keyword-Ziele, GBP-Verbesserungen und die Social-Media-Strategie speziell für Ihre Branche und Ihren Standort.',
  },
  {
    n: '03',
    title: 'Wir übernehmen alles',
    body: 'Content wird veröffentlicht, Bewertungen werden beantwortet, Beiträge erscheinen täglich. Sie überprüfen monatlich. Das war es.',
  },
];

const callDeliverables = [
  'Ein individueller Content- und Lokales-SEO-Plan für 90 Tage',
  'Keyword-Lücken-Analyse für Ihre Branche und Ihren Standort',
  'Ehrliche Bewertung Ihres aktuellen Google Business Profile',
  'Eine klare Planempfehlung ohne versteckte Preise',
];

const objections = [
  {
    q: "Ich habe keine Zeit für ein weiteres Meeting.",
    a: "30 Minuten. Wir kommen vorbereitet mit Daten zu Ihrem Markt, Ihren Wettbewerbern und Ihren Keyword-Lücken. Sie kommen mit Fragen. Kein Smalltalk, keine Zeitverschwendung.",
  },
  {
    q: "Ich bin skeptisch gegenüber KI-Content-Tools.",
    a: "Vernünftig. Die meisten dieser Tools produzieren generischen Content, der niemanden beeindruckt. Stacc wurde für lokale Unternehmen entwickelt — Keyword-Recherche auf Stadtebene, Markensprache-Training und direkte CMS-Integration. Sehen Sie in 30 Minuten, ob es für Ihren spezifischen Markt funktioniert.",
  },
  {
    q: "Was, wenn es nach dem Gespräch nicht passt?",
    a: "Dann passt es nicht. Wir empfehlen Stacc nicht jedem. Wenn Ihre Situation kein klares Match ist, sagen wir es Ihnen direkt — und empfehlen, was stattdessen helfen würde. Kein Verkaufsdruck.",
  },
];

const demoSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/de/demo/`,
      name: 'Demo | theStacc — Ergebnisse für Ihr Unternehmen sehen',
      url: `${SITE_URL}/de/demo/`,
      inLanguage: 'de',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
    buildBreadcrumbs(`${SITE_URL}/de/demo/`, [
      { name: 'Startseite', url: `${SITE_URL}/de/` },
      { name: 'Demo', url: `${SITE_URL}/de/demo/` },
    ]),
    {
      '@type': 'Organization',
      '@id': `${SITE_URL}/#organization`,
      name: 'theStacc',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: LOGO_URL },
    },
  ],
};
---

<BaseLayout
  title="Demo | theStacc — Ergebnisse für Ihr Unternehmen sehen"
  description="Sehen Sie, wie Stacc für Ihr spezifisches Unternehmen, Ihren Markt und Ihre Keyword-Lücken arbeitet. 30-Minuten-Gespräch. Kein Verkaufsdruck. DSGVO-konform."
  lang="de"
>
  <Header />
  <main class="flex-1">

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 py-20 md:py-28 text-center">

        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Keine Kreditkarte · DSGVO-konform · Kein Vertrag</span>
        </div>

        <h1 class="mx-auto mt-4 max-w-[680px] font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.2rem]">
          Sehen Sie, was Stacc für Ihr<br class="hidden md:block" /> Unternehmen bewirken kann.
        </h1>
        <p class="mx-auto mt-5 max-w-[520px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
          Ein 30-Minuten-Gespräch mit konkreten Ergebnissen: Keyword-Lücken-Analyse, GBP-Bewertung und ein individueller 90-Tage-Plan für Ihr Unternehmen.
        </p>

        <!-- Trust pills -->
        <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
          {[
            'Antwort in weniger als 24 Stunden',
            'Kein Verkaufsdruck',
            'Vom Gründer persönlich geführt',
            'DSGVO-konform',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#1e2633] bg-[rgba(15,23,42,0.05)] px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── PROCESS + FORM ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-12 lg:grid-cols-2">

          <!-- Left: What you get -->
          <div>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Was Sie bekommen</span>
            <h2 class="mt-3 font-sans text-[1.5rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
              In 30 Minuten haben Sie einen konkreten Plan.
            </h2>

            <div class="mt-8 space-y-5">
              {steps.map(step => (
                <div class="flex gap-4">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#4f39f6] font-mono text-[12px] font-bold text-white">{step.n}</span>
                  <div>
                    <h3 class="font-sans text-[15px] font-semibold text-[#111827]">{step.title}</h3>
                    <p class="mt-1 font-sans text-[13px] leading-[1.65] text-[#79716b]">{step.body}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-10 rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
              <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">Das Gespräch beinhaltet</p>
              <ul class="mt-4 space-y-3">
                {callDeliverables.map(item => (
                  <li class="flex items-start gap-2.5">
                    <svg class="mt-0.5 shrink-0" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#374151]">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Right: Form -->
          <div class="rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-8">
            <p class="font-sans text-[17px] font-semibold text-[#111827]">Gespräch buchen</p>
            <p class="mt-1 font-sans text-[13px] text-[#79716b]">Wir melden uns innerhalb von 24 Stunden, um einen Termin zu vereinbaren.</p>

            <form
              name="de-demo"
              method="POST"
              data-netlify="true"
              action="/de/demo/?success=true"
              class="mt-6 space-y-4"
            >
              <input type="hidden" name="form-name" value="de-demo" />
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                  <label for="de-name" class="mb-1.5 block font-sans text-[12px] font-semibold text-[#374151]">Ihr Name</label>
                  <input type="text" id="de-name" name="name" required placeholder="Max Mustermann" class="h-10 w-full rounded-xl border border-[#e7e5e4] bg-white px-3 font-sans text-[14px] text-[#111827] outline-none focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]" />
                </div>
                <div>
                  <label for="de-company" class="mb-1.5 block font-sans text-[12px] font-semibold text-[#374151]">Unternehmen</label>
                  <input type="text" id="de-company" name="company" placeholder="Mustermann GmbH" class="h-10 w-full rounded-xl border border-[#e7e5e4] bg-white px-3 font-sans text-[14px] text-[#111827] outline-none focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]" />
                </div>
              </div>
              <div>
                <label for="de-email" class="mb-1.5 block font-sans text-[12px] font-semibold text-[#374151]">E-Mail-Adresse</label>
                <input type="email" id="de-email" name="email" required placeholder="max@mustermann.de" class="h-10 w-full rounded-xl border border-[#e7e5e4] bg-white px-3 font-sans text-[14px] text-[#111827] outline-none focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]" />
              </div>
              <div>
                <label for="de-url" class="mb-1.5 block font-sans text-[12px] font-semibold text-[#374151]">Website-URL</label>
                <input type="url" id="de-url" name="website" placeholder="https://www.ihre-website.de" class="h-10 w-full rounded-xl border border-[#e7e5e4] bg-white px-3 font-sans text-[14px] text-[#111827] outline-none focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]" />
              </div>
              <div>
                <label for="de-goal" class="mb-1.5 block font-sans text-[12px] font-semibold text-[#374151]">Was ist Ihr wichtigstes Ziel?</label>
                <select id="de-goal" name="goal" class="h-10 w-full rounded-xl border border-[#e7e5e4] bg-white px-3 font-sans text-[14px] text-[#57534e] outline-none focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]">
                  <option value="">Bitte auswählen</option>
                  <option value="blog">Mehr organischen Traffic durch Blog-Inhalte</option>
                  <option value="local">Besser in Google Maps / lokaler Suche ranken</option>
                  <option value="social">Konsistentes Social-Media-Posting</option>
                  <option value="all">Alle drei Bereiche</option>
                </select>
              </div>
              <div>
                <label for="de-message" class="mb-1.5 block font-sans text-[12px] font-semibold text-[#374151]">Weitere Informationen (optional)</label>
                <textarea id="de-message" name="message" rows="3" placeholder="Branche, aktuelles Marketing-Setup, spezifische Herausforderungen..." class="w-full rounded-xl border border-[#e7e5e4] bg-white px-3 py-2.5 font-sans text-[14px] text-[#111827] outline-none focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6] resize-none"></textarea>
              </div>
              <button type="submit" class="flex h-11 w-full items-center justify-center rounded-xl bg-[#4f39f6] font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
                Gespräch anfragen
                <svg class="ml-2" width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <p class="text-center font-mono text-[10px] uppercase tracking-[0.14em] text-[#79716b]">DSGVO-konform · Keine Kreditkarte · Kein Vertrag · Alle Preise zzgl. MwSt.</p>
            </form>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── OBJECTION HANDLING ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Häufige Einwände</span>
          <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2rem]">
            Wir hören sie regelmäßig.
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl space-y-4">
          {objections.map(obj => (
            <details class="group rounded-2xl border border-[#e7e5e4] bg-white">
              <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{obj.q}</span>
                <svg class="shrink-0 transition-transform group-open:rotate-180" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="border-t border-[#e7e5e4] px-6 py-5">
                <p class="font-sans text-[14px] leading-[1.7] text-[#57534e]">{obj.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── MANAGED PLANS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-16">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Vollständig verwaltete Pakete</span>
          <h2 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2rem]">
            Wir erledigen alles für Sie.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-6 md:grid-cols-3">
          {plans.map(plan => (
            <div class={`relative flex flex-col rounded-2xl border p-7 bg-white ${plan.popular ? 'border-[#4f39f6]/40 shadow-[0_8px_40px_rgba(79,57,246,0.1)]' : 'border-[#e7e5e4]'}`}>
              {plan.popular && (
                <span class="absolute -top-3.5 left-6 inline-flex items-center rounded-full bg-[#4f39f6] px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-white">Beliebteste Wahl</span>
              )}
              <h3 class="font-sans text-[16px] font-semibold text-[#111827]">{plan.name}</h3>
              <p class="mt-1 font-sans text-[13px] text-[#79716b]">{plan.tagline}</p>
              <div class="mt-4 flex items-baseline gap-1">
                <span class="font-sans text-[2.2rem] font-bold tracking-tight text-[#111827]">${plan.price}</span>
                <span class="font-sans text-[13px] text-[#9ca3af]">/Monat zzgl. MwSt.</span>
              </div>
              <p class="mt-0.5 font-sans text-[11px] text-[#79716b]">oder ${plan.annualPrice}/Monat jährlich</p>
              <div class="mt-5 flex flex-1 flex-col gap-2.5 border-t border-[#e7e5e4] pt-5">
                {plan.features.map(f => (
                  <div class="flex items-start gap-2">
                    <svg class="mt-0.5 shrink-0" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                    <span class="font-sans text-[13px] text-[#374151]">{f}</span>
                  </div>
                ))}
              </div>
              <button
                type="button"
                onclick="document.querySelector('form[name=de-demo]').scrollIntoView({behavior:'smooth'})"
                class="mt-5 flex h-10 w-full items-center justify-center rounded-xl bg-[#4f39f6] font-sans text-[13px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
              >
                Gespräch anfragen
              </button>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
