---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
---
<BaseLayout title="Acceptable Use Policy - theStacc" description="Rules and guidelines for the acceptable use of theStacc services. Review what is and isn't allowed on the platform.">
  <Header />
  <main class="min-h-screen bg-white pt-32 pb-20 px-4">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-mono text-4xl font-bold text-[#292524] mb-2">Acceptable Use Policy</h1>
      <p class="font-mono text-sm text-[#79716b] mb-10">Last updated: January 2026</p>
      <div class="space-y-10">
        <section>
          <h2 class="font-sans text-xl font-semibold text-[#292524] mb-4">1. Permitted Use</h2>
          <p class="font-sans text-base text-[#57534e] leading-[1.75]">
            theStacc is designed to help businesses automate and scale their SEO content production.
            You may use our services to generate blog posts, local SEO pages, and other content that
            accurately represents your business and provides genuine value to your audience. All use
            must comply with applicable laws and our <a href="/terms" class="text-[#4f39f6] hover:underline">Terms &amp; Conditions</a>.
          </p>
        </section>

        <section>
          <h2 class="font-sans text-xl font-semibold text-[#292524] mb-4">2. Prohibited Activities</h2>
          <p class="font-sans text-base text-[#57534e] leading-[1.75] mb-4">
            You may not use theStacc to engage in any of the following activities:
          </p>
          <ul class="font-sans text-base text-[#57534e] leading-[1.75] space-y-3 list-none">
            <li class="flex gap-3">
              <span class="text-[#4f39f6] font-mono shrink-0 mt-1">—</span>
              <span><strong class="text-[#292524]">Spam and mass distribution.</strong> Generating content intended for bulk, unsolicited distribution across unrelated websites, link farms, or private blog networks.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#4f39f6] font-mono shrink-0 mt-1">—</span>
              <span><strong class="text-[#292524]">Misleading content.</strong> Creating content that intentionally deceives, impersonates other businesses, makes false claims, or spreads misinformation.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#4f39f6] font-mono shrink-0 mt-1">—</span>
              <span><strong class="text-[#292524]">Scraping and unauthorized access.</strong> Using our platform to scrape competitor data, bypass access controls, or harvest information from third-party sites in violation of their terms.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#4f39f6] font-mono shrink-0 mt-1">—</span>
              <span><strong class="text-[#292524]">Harmful or illegal content.</strong> Generating content that promotes violence, discrimination, illegal activity, or that violates the intellectual property rights of others.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-[#4f39f6] font-mono shrink-0 mt-1">—</span>
              <span><strong class="text-[#292524]">Reselling without authorization.</strong> Reselling or sublicensing access to theStacc to third parties without our prior written consent.</span>
            </li>
          </ul>
        </section>

        <section>
          <h2 class="font-sans text-xl font-semibold text-[#292524] mb-4">3. Content Standards</h2>
          <p class="font-sans text-base text-[#57534e] leading-[1.75]">
            Content generated through theStacc should meet a standard of quality and accuracy appropriate
            for public publication. You are responsible for reviewing all AI-generated content before
            publishing and ensuring it accurately represents your business. We encourage you to add your
            own expertise and unique insights to content we produce on your behalf.
          </p>
        </section>

        <section>
          <h2 class="font-sans text-xl font-semibold text-[#292524] mb-4">4. Enforcement</h2>
          <p class="font-sans text-base text-[#57534e] leading-[1.75]">
            We reserve the right to investigate suspected violations of this policy. If we determine that
            your use violates this policy, we may suspend or terminate your account without notice. We may
            also report unlawful activity to the appropriate authorities. Accounts terminated for policy
            violations are not eligible for a refund.
          </p>
        </section>

        <section>
          <h2 class="font-sans text-xl font-semibold text-[#292524] mb-4">5. Contact</h2>
          <p class="font-sans text-base text-[#57534e] leading-[1.75]">
            To report a potential policy violation or ask questions about permitted use, contact us at
            <a href="mailto:hello@thestacc.com" class="text-[#4f39f6] hover:underline">hello@thestacc.com</a>.
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
