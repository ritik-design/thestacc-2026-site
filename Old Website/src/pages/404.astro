---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
---

<BaseLayout title="404 | Page Not Found | theStacc" description="This page doesn't exist or has been moved.">
  <Header />
  <main class="flex-1 flex items-center justify-center px-6 py-12 md:py-20">
    <div class="w-full max-w-md">

      <!-- Glitch 404 hero -->
      <div class="text-center mb-6">
        <div class="font-mono text-[100px] sm:text-[130px] md:text-[150px] font-bold leading-none tracking-tighter select-none">
          <span class="inline-block text-[#e7e5e4] relative">
            4
            <span class="absolute inset-0 text-[#615fff] animate-glitch-1 clip-glitch-1" aria-hidden="true">4</span>
          </span>
          <span class="inline-block relative mx-0.5 sm:mx-1">
            <span class="text-[#615fff]">0</span>
            <span class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
              <span class="w-[70%] h-[85%] rounded-full border-2 border-[#615fff]/20 animate-ping-slow"></span>
            </span>
          </span>
          <span class="inline-block text-[#e7e5e4] relative">
            4
            <span class="absolute inset-0 text-[#615fff] animate-glitch-2 clip-glitch-2" aria-hidden="true">4</span>
          </span>
        </div>
        <p class="font-sans text-[22px] leading-[30px] md:text-[28px] md:leading-[36px] font-normal text-[#292524] -mt-2">
          This page didn't rank
        </p>
        <p class="mt-2 font-sans text-[15px] leading-[22px] text-[#79716b] max-w-sm mx-auto">
          Zero search volume. The page doesn't exist, was moved, or never made it past draft.
        </p>
      </div>

      <!-- SEO Report Card -->
      <div class="rounded-2xl border border-[#e7e5e4] bg-white shadow-[0px_4px_24px_0px_rgba(0,0,0,0.06)] overflow-hidden">

        <!-- Score header -->
        <div class="bg-[#fafaf9] border-b border-[#e7e5e4] px-5 py-5 flex items-center gap-5">
          <!-- Score circle - compact -->
          <div class="relative w-20 h-20 shrink-0">
            <svg class="w-20 h-20 -rotate-90" viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="52" fill="none" stroke="#f5f5f4" stroke-width="8" />
              <circle cx="60" cy="60" r="52" fill="none" stroke="#ef4444" stroke-width="8"
                stroke-dasharray="326.7" stroke-dashoffset="326.7" stroke-linecap="round" />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="font-mono text-[26px] font-bold text-[#ef4444] leading-none">0</span>
              <span class="font-mono text-[9px] text-[#79716b] mt-0.5">/100</span>
            </div>
          </div>
          <div>
            <p class="font-mono text-[10px] tracking-widest uppercase text-[#79716b]">SEO Audit</p>
            <p class="font-sans text-[17px] font-medium text-[#292524] mt-0.5">Page Not Found</p>
            <p class="font-mono text-[11px] text-[#79716b] mt-0.5">URL returned 404 status</p>
          </div>
        </div>

        <!-- Metrics -->
        <div class="px-5 py-4 space-y-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ef4444]"></span>
              <span class="font-sans text-[13px] text-[#292524]">Indexability</span>
            </div>
            <span class="font-mono text-[11px] text-[#ef4444] font-medium">BLOCKED</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ef4444]"></span>
              <span class="font-sans text-[13px] text-[#292524]">Content Score</span>
            </div>
            <span class="font-mono text-[11px] text-[#ef4444] font-medium">NO CONTENT</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ef4444]"></span>
              <span class="font-sans text-[13px] text-[#292524]">Backlinks</span>
            </div>
            <span class="font-mono text-[11px] text-[#ef4444] font-medium">0</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <span class="w-1.5 h-1.5 rounded-full bg-[#ef4444]"></span>
              <span class="font-sans text-[13px] text-[#292524]">Search Volume</span>
            </div>
            <span class="font-mono text-[11px] text-[#ef4444] font-medium">0</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <span class="w-1.5 h-1.5 rounded-full bg-[#f59e0b]"></span>
              <span class="font-sans text-[13px] text-[#292524]">User Experience</span>
            </div>
            <span class="font-mono text-[11px] text-[#f59e0b] font-medium">CONFUSED</span>
          </div>
        </div>

        <!-- Recommendation -->
        <div class="border-t border-[#e7e5e4] px-5 py-4 bg-[#fafaf9]">
          <p class="font-mono text-[10px] tracking-widest uppercase text-[#79716b] mb-1.5">Recommendation</p>
          <p class="font-sans text-[13px] leading-relaxed text-[#79716b]">
            Navigate to a page that actually exists. We suggest starting from the homepage.
          </p>
        </div>

        <!-- CTAs -->
        <div class="px-5 py-4 flex flex-col gap-2.5">
          <a
            href="/"
            class="flex h-[40px] items-center justify-center gap-2 rounded-[12px] border border-[#4f39f6] bg-[#615fff] font-mono text-[14px] font-semibold uppercase text-[#fafaf9] transition-colors hover:bg-[#4f39f6]"
          >
            Fix This Issue
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <div class="flex gap-2.5">
            <a href="/blog/" class="flex-1 flex h-[36px] items-center justify-center rounded-[12px] border border-[#e7e5e4] font-mono text-[12px] font-semibold uppercase text-[#79716b] transition-colors hover:bg-[#fafaf9]">Blog</a>
            <a href="/docs/" class="flex-1 flex h-[36px] items-center justify-center rounded-[12px] border border-[#e7e5e4] font-mono text-[12px] font-semibold uppercase text-[#79716b] transition-colors hover:bg-[#fafaf9]">Docs</a>
            <a href="/pricing/" class="flex-1 flex h-[36px] items-center justify-center rounded-[12px] border border-[#e7e5e4] font-mono text-[12px] font-semibold uppercase text-[#79716b] transition-colors hover:bg-[#fafaf9]">Pricing</a>
          </div>
        </div>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  @keyframes glitch-1 {
    0%, 100% { opacity: 0; transform: translate(0); }
    20% { opacity: 0.8; transform: translate(-2px, 2px); }
    21% { opacity: 0; }
    50% { opacity: 0.6; transform: translate(2px, -1px); }
    51% { opacity: 0; }
    80% { opacity: 0.7; transform: translate(-1px, 1px); }
    81% { opacity: 0; }
  }

  @keyframes glitch-2 {
    0%, 100% { opacity: 0; transform: translate(0); }
    30% { opacity: 0.7; transform: translate(2px, -2px); }
    31% { opacity: 0; }
    60% { opacity: 0.5; transform: translate(-2px, 1px); }
    61% { opacity: 0; }
    90% { opacity: 0.8; transform: translate(1px, -1px); }
    91% { opacity: 0; }
  }

  @keyframes ping-slow {
    0% { transform: scale(1); opacity: 0.4; }
    75%, 100% { transform: scale(1.3); opacity: 0; }
  }

  .animate-glitch-1 { animation: glitch-1 4s ease-in-out infinite; }
  .animate-glitch-2 { animation: glitch-2 4s ease-in-out infinite 0.5s; }
  .animate-ping-slow { animation: ping-slow 2.5s cubic-bezier(0, 0, 0.2, 1) infinite; }

  .clip-glitch-1 { clip-path: inset(20% 0 40% 0); }
  .clip-glitch-2 { clip-path: inset(60% 0 10% 0); }
</style>
