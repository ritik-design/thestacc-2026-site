---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

const faqs = [
  { q: "What is white-label local SEO?", a: "White-label local SEO is the practice of agencies delivering local search optimization services to clients using a platform branded with the agency's own identity — their logo, domain, and colors — rather than the software vendor's. Clients experience the agency brand across all dashboards, reports, and communications." },
  { q: "What local SEO tasks does Stacc automate under a white-label?", a: "All of them: GBP post publishing (30/month per location), daily rank tracking, citation monitoring across 50+ directories, real-time review alerts, and automated report generation and delivery. Everything is fully automated and delivered under your agency brand." },
  { q: "Can I sell Stacc's local SEO services as my own?", a: "Yes. Stacc is designed specifically for this use case. You deliver local SEO results through a platform that carries your brand. Clients never see Stacc's name. You set your own pricing to clients and keep the margin between what you charge and what Stacc costs." },
  { q: "Can I have different report templates for different clients?", a: "Yes. Each client can have a custom report configuration — different metrics, different delivery schedules, different logos if you're running sub-brands. Reports are generated and delivered automatically for each client based on their configuration." },
  { q: "Is there a minimum client count to use white-label?", a: "No minimum. You can set up white-label with one client and scale from there. Pricing is based on locations managed, not client count." },
  { q: "Does Stacc offer agency support for white-label onboarding?", a: "Yes. The Stacc team provides setup support for white-label configuration and initial client onboarding. Most agencies complete their first white-label setup independently in about 2 hours." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — White-Label Local SEO", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "White-label local SEO platform for agencies. Deliver GBP management, rank tracking, citation monitoring, and reporting under your own brand.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "White-Label Local SEO", "item": "https://thestacc.com/white-label-local-seo/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="White-Label Local SEO for Agencies — Deliver Results Under Your Brand | theStacc"
  description="White-label local SEO platform for agencies. GBP management, rank tracking, citations, and reporting — automated and delivered under your agency's brand to every client."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">White-Label Local SEO · For Agencies · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            White-label local SEO your clients<br />
            <span style="color:#4f39f6;">experience as your own platform.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc delivers complete local SEO automation — GBP, rankings, citations, reviews, reporting — through a platform branded entirely as yours. Clients see your logo, your domain, your reports.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/solutions/agencies/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See agency features
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What white-label local SEO actually delivers</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Clients see your brand. You deliver<br />real local SEO results. Automatically.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>White-label local SEO isn't just about slapping your logo on someone else's dashboard. It's about being able to deliver high-quality, automated local SEO execution under your own brand — so you can scale your client base without scaling your team in proportion.</p>
            <p>Stacc automates every ongoing local SEO task: 30 GBP posts per month, daily rank tracking, citation monitoring across 50+ directories, real-time review alerts, and automated client reports. All of it happens under your brand. You configure clients once and the platform runs the ongoing work automatically — giving you the ability to serve three times as many local SEO clients without three times the staff.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What's included</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Complete local SEO under your brand.<br />Every task. Every client.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP post automation', body: 'Stacc publishes 30 posts per month per location targeting local search intent. Profiles stay active daily — no client work, no agency work.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Daily rank tracking', body: 'Every keyword updated daily for each client location. Rankings visible in branded client dashboards with trend data and change alerts.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Citation monitoring', body: 'Continuous NAP accuracy monitoring across 50+ directories for every client. Inconsistencies flagged and corrected automatically.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Review management', body: 'Real-time review alerts for every client location. Respond from your agency dashboard. Track response rates and reputation scores per client.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Branded automated reporting', body: 'Reports generated on schedule, formatted with your logo, and delivered from your domain. Zero manual steps per client per month.' },
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Custom domain + branding', body: 'Clients access dashboards on your subdomain. Your logo and colors on every screen. $0 per client login. Stacc\'s name never visible.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 3, suffix: '×', label: 'More clients per employee', sub: 'Automation removes the execution bottleneck' },
            { to: 400, suffix: '+', label: 'Agencies using Stacc white-label', sub: 'From boutique to enterprise' },
            { to: 100, suffix: '%', label: 'Client-facing Stacc branding removed', sub: 'Complete brand replacement, not co-branding' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            White-label local SEO:<br />common questions answered.
          </h2>
          <div class="mt-10 divide-y divide-[#e7e5e4]">
            {faqs.map((f, i) => (
              <div class="py-5">
                <button class="faq-btn flex w-full items-start justify-between gap-4 text-left" aria-expanded="false">
                  <span class="font-sans text-[1rem] font-semibold text-[#111827]">{f.q}</span>
                  <span class="mt-0.5 flex-shrink-0">
                    <svg class="faq-icon-plus h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    <svg class="faq-icon-minus hidden h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                  </span>
                </button>
                <div class="faq-answer hidden pt-3">
                  <p class="font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Related resources</p>
        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {[
            { href: '/white-label-seo/', label: 'White-Label SEO' },
            { href: '/white-label-reporting/', label: 'White-Label Reporting' },
            { href: '/features/white-label-dashboard/', label: 'White-Label Dashboard' },
            { href: '/seo-reseller/', label: 'SEO Reseller' },
            { href: '/solutions/agencies/', label: 'Stacc for Agencies' },
            { href: '/features/client-reporting/', label: 'Client Reporting' },
            { href: '/local-seo-software/', label: 'Local SEO Software' },
            { href: '/local-seo-automation/', label: 'Local SEO Automation' },
          ].map(l => (
            <a href={l.href} class="flex items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 font-sans text-[13px] font-medium text-[#374151] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              {l.label}
            </a>
          ))}
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.35) 0%,transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-24 text-center">
        <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.8rem]">
          Deliver local SEO results<br />as your own platform.
        </h2>
        <p class="mx-auto mt-5 max-w-[520px] font-sans text-[1rem] leading-[1.7]" style="color:#9ca3af;">Start your $1 trial today and have white-label configured before you onboard your first client.</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-12 items-center gap-2 rounded-xl bg-[#4f39f6] px-7 font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
            Start free — no credit card
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/pricing/" class="inline-flex h-12 items-center rounded-xl border border-white/15 bg-white/5 px-7 font-sans text-[15px] font-medium text-white/80 transition-colors hover:bg-white/10">See pricing</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      if (answer) answer.classList.toggle('hidden', expanded);
      btn.querySelector('.faq-icon-plus')?.classList.toggle('hidden', !expanded);
      btn.querySelector('.faq-icon-minus')?.classList.toggle('hidden', expanded);
    });
  });
  document.querySelectorAll<HTMLElement>('[data-count-up]').forEach(el => {
    const from = parseFloat(el.dataset.from || '0'), to = parseFloat(el.dataset.to || '0'), suffix = el.dataset.suffix || '', duration = 1800; let start: number | null = null;
    const obs = new IntersectionObserver(entries => {
      if (!entries[0].isIntersecting) return; obs.disconnect();
      const step = (ts: number) => { if (!start) start = ts; const p = Math.min((ts - start) / duration, 1); el.textContent = (from + (to - from) * (1 - Math.pow(1 - p, 3))).toFixed(0) + suffix; if (p < 1) requestAnimationFrame(step); };
      requestAnimationFrame(step);
    }, { threshold: 0.3 }); obs.observe(el);
  });
</script>
