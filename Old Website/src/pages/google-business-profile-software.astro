---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ExitIntent from '../components/common/ExitIntent.astro';

const faqs = [
  { q: "What is Google Business Profile software?", a: "Google Business Profile software helps businesses manage their GBP listings more efficiently — publishing posts, responding to reviews, updating hours and attributes, and monitoring performance — especially across multiple locations where manual management becomes impractical." },
  { q: "How does Stacc help with Google Business Profile management?", a: "Stacc automates GBP post publishing (30 posts per month per location), monitors reviews in real time, flags suggested edits before they go live, and tracks GBP performance signals. For multi-location businesses, all of this happens across every location simultaneously from one dashboard." },
  { q: "Does posting to GBP actually improve Google Maps rankings?", a: "Yes. Regular GBP post activity is a documented local ranking signal. Google treats consistent posting as an indicator of an active, legitimate business — which correlates with higher local pack and Maps visibility. Businesses that post consistently see measurable ranking improvements compared to their inactive-profile baselines." },
  { q: "Can I bulk-publish GBP posts to multiple locations?", a: "Yes. Write one post, select all locations or a specific group, and publish simultaneously. Location-specific customizations (address, phone number, local hashtags) can be added per location before bulk-publishing." },
  { q: "How does Stacc handle GBP suggested edits?", a: "Stacc monitors your GBP listings for suggested edits from third parties and alerts you before they're applied. You can approve, reject, or modify suggested edits from the dashboard without logging into each GBP individually." },
  { q: "Can Stacc manage GBP for businesses with 100+ locations?", a: "Yes. There's no practical location limit. Bulk operations work identically whether you have 10 locations or 500. The same GBP management tools that work for 10 locations work at 500 — you just select more locations before applying the action." },
  { q: "What does GBP software cost?", a: "Stacc's Local SEO module — which includes full GBP management — starts at $49/month with a $1, 3-day trial." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — Google Business Profile Software", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "Google Business Profile software that automates GBP post publishing, review monitoring, and listing management across every location simultaneously.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "Google Business Profile Software", "item": "https://thestacc.com/google-business-profile-software/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="Google Business Profile Software — Automate GBP Across Every Location | theStacc"
  description="Automate Google Business Profile management across every location. theStacc publishes 30 GBP posts per month, monitors reviews, and manages listings — without manual logins."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Google Business Profile Software · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            GBP managed automatically.<br />
            <span style="color:#4f39f6;">Every location. Every day.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc publishes 30 GBP posts per month per location, monitors reviews in real time, and manages your listings across every location — without a single manual login.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/integrations/google-business-profile/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See GBP integration
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
          <div class="mx-auto mt-10 inline-flex flex-wrap items-center justify-center gap-6 rounded-2xl border border-[#e7e5e4] bg-white px-8 py-4">
            <span class="font-mono text-[11px] text-[#79716b]">30 posts/month per location</span>
            <div class="h-4 w-px bg-[#f5f3ff]"></div>
            <span class="font-mono text-[11px] text-[#79716b]">1,200+ locations managed</span>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Why GBP management needs software</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Inactive GBP profiles lose rankings.<br />Manual management doesn't keep up.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>Google's local ranking algorithm rewards active GBP profiles. Regular post publishing, prompt review responses, and up-to-date listing information all contribute to local pack and Maps visibility. Stop posting for three weeks and your activity score drops. Let reviews go unanswered and your response rate signals drop. Let an outdated business hour sit in your listing and you create a trust inconsistency that hurts your ranking.</p>
            <p>Maintaining an active GBP for one location is 3–4 hours of work per week. For 20 locations, that's 80 hours. GBP software eliminates that work by automating the execution — not just showing you what needs to be done, but actually doing it.</p>
            <p class="font-semibold text-[#111827]">Stacc publishes posts, monitors reviews, watches for unauthorized edits, and keeps your GBP listings consistently active — so your profiles never go quiet, even when you're not watching them.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP management capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every GBP task automated.<br />Every location covered.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z', title: '30 GBP posts per month, automated', body: 'Stacc writes and publishes 30 posts per location per month targeting your service + location keyword combinations. Profiles stay active every day, automatically.' },
            { icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z', title: 'Real-time review monitoring', body: 'New reviews surface instantly in your dashboard. Respond directly without logging into GBP. Track response rates and average score per location.' },
            { icon: 'M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z', title: 'Unauthorized edit monitoring', body: 'Third-party suggested edits to your listings are flagged before they\'re applied. Approve, reject, or modify from the dashboard — never miss an unauthorized change.' },
            { icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', title: 'Bulk listing updates', body: 'Update hours, descriptions, attributes, and categories across all locations simultaneously. No location-by-location GBP logins required.' },
            { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'GBP performance tracking', body: 'Track views, clicks, call requests, and direction requests per location over time. See which GBP activity correlates with performance changes.' },
            { icon: 'M4 6h16M4 10h16M4 14h16M4 18h16', title: 'Q&A management', body: 'Monitor and manage the Q&A section of every GBP listing. Ensure accurate answers are visible to searchers before they find incorrect information.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-14">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">GBP automation in detail</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Posts, reviews, edits — all managed<br />from one dashboard, automatically.
          </h2>
        </div>
        <div class="mx-auto max-w-6xl space-y-16">

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Automated GBP Post Publishing</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                30 posts per location per month. Targeting searches that drive calls.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Google's Maps algorithm rewards businesses that post consistently with higher local pack visibility. Stacc writes 30 location-optimized posts per month — targeting your service + city keyword combinations, "near me" intent, emergency searches, and seasonal topics — then publishes them on schedule. Your profile stays active every day. You don't touch it.
              </p>
              <a href="/modules/local-seo/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See the Local SEO module
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">This month's GBP posts</p>
              <div class="grid grid-cols-7 gap-1.5 mb-4">
                {Array.from({length: 28}).map((_, i) => (
                  <div class={`h-5 w-full rounded ${i < 22 ? 'bg-[#4f39f6]' : 'bg-[#f5f3ff]'}`}></div>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <span class="font-sans text-[13px] text-[#57534e]">Posts published so far</span>
                <span class="font-sans text-[13px] font-semibold text-[#4f39f6]">22 / 30</span>
              </div>
              <div class="mt-3 h-1.5 w-full rounded-full bg-[#f5f3ff]">
                <div class="h-1.5 rounded-full bg-[#4f39f6]" style="width:73%"></div>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">8 more scheduled · All automated · Zero manual work</p>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Review inbox — all locations</p>
              {[
                { biz: 'Oak Park Location', stars: 5, text: 'Best service I\'ve had. Will definitely return!', time: '2h ago', responded: false },
                { biz: 'Evanston Location', stars: 4, text: 'Great experience overall, quick and professional.', time: '1d ago', responded: true },
                { biz: 'Lincoln Park', stars: 5, text: 'Highly recommend — fast response and great results.', time: '2d ago', responded: true },
              ].map(r => (
                <div class="border-t border-[#f5f3ff] py-3">
                  <div class="flex items-center justify-between mb-1">
                    <span class="font-mono text-[10px] font-semibold text-[#4f39f6]">{r.biz}</span>
                    <div class="flex items-center gap-2">
                      <div class="flex">{Array.from({length: r.stars}).map(() => <svg width="10" height="10" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>)}</div>
                      {r.responded ? <span class="font-mono text-[9px] text-[#059669]">✓ Responded</span> : <span class="font-mono text-[9px] text-[#f59e0b]">Needs reply</span>}
                    </div>
                  </div>
                  <p class="font-sans text-[12px] text-[#57534e] truncate">"{r.text}"</p>
                  <p class="font-mono text-[10px] text-[#79716b] mt-0.5">{r.time}</p>
                </div>
              ))}
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">All locations · Real-time alerts</p>
            </div>
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Unified Review Monitoring</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Every review across every location in one inbox. Respond without logging into GBP.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Review response rate is a Maps ranking signal. Businesses that respond promptly to reviews consistently outperform those with unanswered reviews. Stacc centralizes every review from every location into one inbox, fires instant alerts for new reviews, and lets you respond directly — without logging into individual GBP accounts. For multi-location businesses, this is the only way to stay on top of reputation management at scale.
              </p>
              <a href="/features/review-monitoring/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See review monitoring
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 items-center gap-14 md:grid-cols-2 md:gap-20">
            <div>
              <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Bulk Listing Management</span>
              <h3 class="mt-3 font-sans text-[1.75rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827]">
                Update every location at once. Holiday hours, descriptions, categories — all in seconds.
              </h3>
              <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
                Any change that affects your entire portfolio can be applied to all locations simultaneously. Update Thanksgiving hours for all 40 locations in 2 seconds. Change your business description across every listing before a rebrand. Add a new service category to every location in one action. What used to take hours of tab-switching and manual logins takes under a minute — and Stacc monitors for unauthorized third-party edits in between, alerting you before rogue changes affect your rankings.
              </p>
              <a href="/features/bulk-location-management/" class="mt-6 inline-flex items-center gap-2 font-mono text-[12px] font-semibold text-[#4f39f6] hover:underline">
                See bulk location management
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-8 shadow-[0_8px_40px_rgba(0,0,0,0.06)]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524] mb-4">Bulk update — holiday hours</p>
              <div class="mb-4 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-4">
                <p class="font-sans text-[13px] font-semibold text-[#111827]">Apply to:</p>
                <div class="mt-2 flex flex-wrap gap-2">
                  {['All 34 locations', 'Chicago region', 'Custom'].map(opt => (
                    <span class={`rounded-lg px-3 py-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em] ${opt === 'All 34 locations' ? 'bg-[#4f39f6] text-white' : 'border border-[#e7e5e4] text-[#79716b]'}`}>{opt}</span>
                  ))}
                </div>
              </div>
              <div class="flex items-center justify-between rounded-xl border border-[#e7e5e4] bg-white p-4">
                <span class="font-sans text-[13px] text-[#57534e]">Apply Thanksgiving hours</span>
                <span class="rounded-lg bg-[#059669] px-3 py-1 font-mono text-[10px] font-bold text-white">Apply to all</span>
              </div>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-[#79716b]">2 seconds vs. 34 manual GBP logins</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 30, suffix: '/mo', label: 'GBP posts per location', sub: 'Published automatically, no manual work' },
            { to: 89, suffix: '%', label: 'Ranking lift in 90 days', sub: 'Consistent GBP activity vs inactive baseline' },
            { to: 1200, suffix: '+', label: 'Locations managed on Stacc', sub: 'All getting consistent GBP management' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center mb-10">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What customers say</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Real results from businesses<br />using Stacc to manage GBP.
          </h2>
        </div>
        <div class="mx-auto max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-2">
          {[
            { quote: "We have 14 locations and GBP management was the thing nobody had time for. Now it's fully automated. Every location gets posts, every review gets flagged, and we catch rogue edits before they go live.", name: "Sarah K.", role: "Marketing Director · 14 locations", result: "14 locations fully automated" },
            { quote: "The 30 automated posts per month changed everything for our Maps rankings. Within 60 days of consistent GBP activity, we moved from position 8 to position 2 for our main keywords.", name: "James P.", role: "Dental Practice Owner · Phoenix", result: "Position 8 → 2 in 60 days" },
            { quote: "Review management across multiple locations used to mean checking each GBP separately every morning. Now I get instant alerts and respond from one place. It's not even a question anymore.", name: "Rachel V.", role: "Franchise Operations Manager", result: "All reviews in one inbox" },
            { quote: "We stopped two unauthorized edits that could have tanked our listings. The monitoring is something I didn't even know I needed until I had it. Both times Stacc caught them before they went live.", name: "David C.", role: "Retail Chain Manager · 22 locations", result: "2 unauthorized edits blocked" },
          ].map(t => (
