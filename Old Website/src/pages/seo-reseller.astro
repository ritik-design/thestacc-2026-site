---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ExitIntent from '../components/common/ExitIntent.astro';

const faqs = [
  { q: "What is an SEO reseller?", a: "An SEO reseller is an agency or consultant that delivers local SEO services to clients using a third-party platform — white-labeled as their own. The agency sets its own pricing, manages client relationships, and delivers results through the reseller platform under their own brand." },
  { q: "How does Stacc work as an SEO reseller platform?", a: "You sign up for Stacc, configure the white-label settings (your logo, domain, colors), and then manage all client local SEO through your branded dashboard. Clients see your brand. You deliver real local SEO results — GBP management, rank tracking, citations, reviews, reporting — under your name." },
  { q: "What margin can I make reselling Stacc?", a: "Stacc starts at $49/month for the Local SEO module. Most agencies charge clients $300-1,500/month for local SEO services. The margin between your cost and your client pricing is yours to keep." },
  { q: "Do clients need to know I'm using Stacc?", a: "No. White-label means complete brand replacement. Your logo on every screen, your domain in every URL, your name on every report. Stacc's branding never appears anywhere in the client experience." },
  { q: "Can I manage all my reseller clients from one account?", a: "Yes. One Stacc account covers all your clients. Each client gets their own scoped login to your branded dashboard. You have admin visibility across all clients from a single agency view." },
  { q: "What ongoing work do I need to do per client?", a: "Minimal. After initial setup (connect GBP, configure keywords, set up reporting), Stacc automates the ongoing work: GBP posting, rank tracking, citation monitoring, review alerts, and report delivery. Your ongoing work per client is strategic oversight, not daily execution." },
  { q: "Can I offer local SEO reselling without an existing SEO team?", a: "Yes. Stacc's automation handles the execution that would normally require an SEO specialist per client. Many solo operators and small agencies use Stacc to offer local SEO services without dedicated in-house SEO staff." },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "SoftwareApplication", "name": "theStacc — SEO Reseller Platform", "applicationCategory": "BusinessApplication", "operatingSystem": "Web", "description": "White-label SEO reseller platform. Deliver local SEO results to clients under your agency brand. Full automation, full white-label, zero Stacc branding visible.", "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" } },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" }, { "@type": "ListItem", "position": 2, "name": "SEO Reseller", "item": "https://thestacc.com/seo-reseller/" }] },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) }
  ]
};
---

<BaseLayout
  title="SEO Reseller Program — White-Label Local SEO for Agencies | theStacc"
  description="Resell local SEO services under your agency brand. theStacc is a complete white-label SEO reseller platform — automated delivery, branded dashboards, zero Stacc branding visible."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[800px] text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">SEO Reseller · White-Label Local SEO · From $49/month</span>
          </div>
          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Resell local SEO services<br />
            <span style="color:#4f39f6;">entirely under your brand.</span>
          </h1>
          <p class="mx-auto mt-6 max-w-[600px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Stacc is the white-label local SEO platform that lets you deliver results to clients under your own brand. Full automation, branded dashboards, automated reporting — and Stacc never appears in anything clients see.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/solutions/agencies/" class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See agency features
            </a>
          </div>
          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">No credit card to start · Cancel anytime</p>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-3xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How SEO reselling works with Stacc</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            You sell. Stacc delivers.<br />Clients see your brand the whole time.
          </h2>
          <div class="mt-6 space-y-5 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            <p>The economics of an SEO reseller business work when your cost per client is low and your delivery is automated. Local SEO clients typically pay $300-1,500/month. Stacc's Local SEO module starts at $49/month per account with no per-client fees beyond location count. The margin between your cost and your client pricing stays with you.</p>
            <p>The operational model is straightforward: you onboard a client (connect GBP, configure keywords, set up reporting), and from that point Stacc handles the ongoing execution — GBP posts, rank tracking, citation monitoring, review alerts, and report delivery — automatically. Your time per client drops to strategic oversight and occasional review responses. You scale by adding clients, not headcount.</p>
            <p class="font-semibold text-[#111827]">And because everything is white-labeled, your clients experience it as your proprietary platform. They never know Stacc exists. The relationship, the brand equity, and the margin are entirely yours.</p>
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Reseller platform capabilities</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Everything a local SEO reseller<br />needs in one platform.
          </h2>
        </div>
        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', title: 'Complete white-label', body: 'Your domain, your logo, your colors on everything client-facing. Stacc\'s brand completely invisible. $0 per client login.' },
            { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', title: 'GBP automation per client', body: '30 GBP posts per month per client location, published automatically. Profiles stay active without any work from you or your clients.' },
            { icon: 'M7 12l3-3 3 3 4-4', title: 'Rank tracking for all clients', body: 'Daily rankings for every client across local pack, Maps, and organic. Client dashboards show their own data only — your admin sees everything.' },
            { icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', title: 'Automated client reporting', body: 'Branded reports generate and deliver to clients on your schedule. No manual export, no formatting, no forgetting a client\'s monthly report.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Citation management', body: 'Citation monitoring and correction for every client location across 50+ directories. High-impact local ranking factor handled automatically.' },
            { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', title: 'Multi-client management', body: 'Full portfolio view across all your reseller clients. See each client\'s performance, set up new clients quickly, and manage everything from one admin dashboard.' },
          ].map(c => (
            <div class="bg-white px-7 py-8">
              <div class="mb-4 flex h-9 w-9 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={c.icon}/></svg>
              </div>
              <p class="font-sans text-[0.95rem] font-semibold text-[#111827]">{c.title}</p>
              <p class="mt-1.5 font-sans text-[13px] leading-[1.6] text-[#79716b]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.10) 0%,transparent 65%);" aria-hidden="true"></div>
      <div class="container-x relative py-20">
        <div class="mx-auto mt-0 grid max-w-4xl grid-cols-1 gap-8 sm:grid-cols-3">
          {[
            { to: 3, suffix: '×', label: 'More clients per employee', sub: 'Automation removes execution bottleneck' },
            { to: 400, suffix: '+', label: 'Agencies on Stacc white-label', sub: 'Boutique to enterprise' },
            { to: 49, suffix: '/mo', label: 'Platform cost — local SEO module', sub: 'You set your own client pricing' },
          ].map(m => (
            <div class="text-center">
              <div class="font-sans text-[3.5rem] font-bold leading-none tracking-[-0.04em] text-white">
                <span data-count-up data-from="0" data-to={m.to} data-suffix={m.suffix}>0</span>
              </div>
              <p class="mt-3 font-sans text-[0.95rem] font-semibold text-[#292524]/90">{m.label}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.1em]" style="color:#818cf8;">{m.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            SEO reseller program:<br />common questions answered.
          </h2>
          <div class="mt-10 divide-y divide-[#e7e5e4]">
            {faqs.map((f, i) => (
              <div class="py-5">
                <button class="faq-btn flex w-full items-start justify-between gap-4 text-left" aria-expanded="false">
                  <span class="font-sans text-[1rem] font-semibold text-[#111827]">{f.q}</span>
                  <span class="mt-0.5 flex-shrink-0">
                    <svg class="faq-icon-plus h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                    <svg class="faq-icon-minus hidden h-5 w-5 text-[#4f39f6]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                  </span>
                </button>
                <div class="faq-answer hidden pt-3">
                  <p class="font-sans text-[0.95rem] leading-[1.7] text-[#57534e]">{f.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-16">
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Related resources</p>
        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {[
            { href: '/white-label-seo/', label: 'White-Label SEO' },
            { href: '/white-label-local-seo/', label: 'White-Label Local SEO' },
            { href: '/white-label-reporting/', label: 'White-Label Reporting' },
            { href: '/features/white-label-dashboard/', label: 'White-Label Dashboard' },
            { href: '/solutions/agencies/', label: 'Stacc for Agencies' },
            { href: '/features/client-reporting/', label: 'Client Reporting' },
            { href: '/local-seo-software/', label: 'Local SEO Software' },
            { href: '/multi-location-seo-software/', label: 'Multi-Location SEO Software' },
          ].map(l => (
            <a href={l.href} class="flex items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 font-sans text-[13px] font-medium text-[#374151] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              {l.label}
            </a>
          ))}
        </div>
      </div>
    </section>


    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[400px]" style="background:radial-gradient(ellipse at 50% 0%,rgba(79,57,246,0.35) 0%,transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative py-24 text-center">
        <h2 class="font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-white md:text-[2.8rem]">
          Build a local SEO business<br />on Stacc's infrastructure.
        </h2>
        <p class="mx-auto mt-5 max-w-[520px] font-sans text-[1rem] leading-[1.7]" style="color:#9ca3af;">Start your $1 trial. White-label set up in 2 hours. First client onboarded before the end of the week.</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/demo/" target="_blank" rel="noopener noreferrer" class="inline-flex h-12 items-center gap-2 rounded-xl bg-[#4f39f6] px-7 font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
            Start free — no credit card
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/pricing/" class="inline-flex h-12 items-center rounded-xl border border-white/15 bg-white/5 px-7 font-sans text-[15px] font-medium text-white/80 transition-colors hover:bg-white/10">See pricing</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <ExitIntent />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      if (answer) answer.classList.toggle('hidden', expanded);
      btn.querySelector('.faq-icon-plus')?.classList.toggle('hidden', !expanded);
      btn.querySelector('.faq-icon-minus')?.classList.toggle('hidden', expanded);
    });
  });
  document.querySelectorAll<HTMLElement>('[data-count-up]').forEach(el => {
    const from = parseFloat(el.dataset.from || '0'), to = parseFloat(el.dataset.to || '0'), suffix = el.dataset.suffix || '', duration = 1800; let start: number | null = null;
    const obs = new IntersectionObserver(entries => {
      if (!entries[0].isIntersecting) return; obs.disconnect();
      const step = (ts: number) => { if (!start) start = ts; const p = Math.min((ts - start) / duration, 1); el.textContent = (from + (to - from) * (1 - Math.pow(1 - p, 3))).toFixed(0) + suffix; if (p < 1) requestAnimationFrame(step); };
      requestAnimationFrame(step);
    }, { threshold: 0.3 }); obs.observe(el);
  });
</script>
