---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
---

<BaseLayout
  title="Book Your Strategy Call | theStacc"
  description="Tell us about your business and pick a time. We'll review your site and come prepared with a 90-day growth plan."
  noindex={true}
>
  <Header />
  <main>
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="px-6 pt-10 pb-16">

        <!-- Back link -->
        <a href="/pricing/" class="inline-flex items-center gap-1.5 font-sans text-[14px] font-medium text-[#79716b] transition-colors hover:text-[#292524]">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back to pricing
        </a>

        <!-- Step indicator -->
        <div class="mt-6 flex items-center gap-3">
          <div class="flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[#615fff] font-mono text-[11px] font-bold text-white">✓</span>
            <span class="font-sans text-[13px] font-semibold text-[#615fff]">Choose plan</span>
          </div>
          <div class="h-px w-8 bg-[#615fff]"></div>
          <div class="flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[#615fff] font-mono text-[11px] font-bold text-white">2</span>
            <span class="font-sans text-[13px] font-semibold text-[#615fff]">Book your call</span>
          </div>
        </div>

        <!-- Heading -->
        <h1 class="mt-8 font-sans text-[24px] leading-[32px] md:text-[32px] md:leading-[40px] font-normal text-[#292524]">
          Book your strategy call
        </h1>
        <p class="mt-2 font-sans text-[16px] leading-[24px] text-[#79716b]">
          Tell us about your business and pick a time. We'll review your site before the call.
        </p>

        <!-- Two-column layout -->
        <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-[1fr_360px]">

          <!-- Left: Form -->
          <form id="checkout-form" novalidate class="flex flex-col gap-8">

            <!-- Section 1: Your details -->
            <div>
              <h2 class="font-sans text-[16px] font-semibold text-[#292524]">Your details</h2>
              <p class="mt-1 font-sans text-[13px] text-[#79716b]">We'll send a confirmation and prep questions to your email.</p>

              <div class="mt-4 flex flex-col gap-4">
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                  <div class="flex flex-col gap-1.5">
                    <label for="co-fname" class="font-sans text-[13px] font-semibold text-[#292524]">First name <span class="text-[#ef4444]">*</span></label>
                    <input id="co-fname" name="first_name" type="text" required autocomplete="given-name" placeholder="Jane"
                      class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#292524] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#615fff] focus:ring-2 focus:ring-[#615fff]/10" />
                  </div>
                  <div class="flex flex-col gap-1.5">
                    <label for="co-lname" class="font-sans text-[13px] font-semibold text-[#292524]">Last name <span class="text-[#ef4444]">*</span></label>
                    <input id="co-lname" name="last_name" type="text" required autocomplete="family-name" placeholder="Smith"
                      class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#292524] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#615fff] focus:ring-2 focus:ring-[#615fff]/10" />
                  </div>
                </div>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                  <div class="flex flex-col gap-1.5">
                    <label for="co-email" class="font-sans text-[13px] font-semibold text-[#292524]">Work email <span class="text-[#ef4444]">*</span></label>
                    <input id="co-email" name="email" type="email" required autocomplete="email" placeholder="jane@yourbusiness.com"
                      class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#292524] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#615fff] focus:ring-2 focus:ring-[#615fff]/10" />
                  </div>
                  <div class="flex flex-col gap-1.5">
                    <label for="co-phone" class="font-sans text-[13px] font-semibold text-[#292524]">Phone <span class="text-[#ef4444]">*</span></label>
                    <input id="co-phone" name="phone" type="tel" required autocomplete="tel" placeholder="+1 (555) 000-0000"
                      class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#292524] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#615fff] focus:ring-2 focus:ring-[#615fff]/10" />
                  </div>
                </div>

                <div class="flex flex-col gap-1.5">
                  <label for="co-website" class="font-sans text-[13px] font-semibold text-[#292524]">Website URL</label>
                  <input id="co-website" name="website" type="url" autocomplete="url" placeholder="https://yourbusiness.com"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#292524] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#615fff] focus:ring-2 focus:ring-[#615fff]/10" />
                </div>

                <div class="flex flex-col gap-1.5">
                  <label for="co-business" class="font-sans text-[13px] font-semibold text-[#292524]">Business name & industry <span class="text-[#ef4444]">*</span></label>
                  <input id="co-business" name="business" type="text" required placeholder="Smith Dental · Dentistry"
                    class="h-11 rounded-xl border border-[#e7e5e4] bg-white px-4 font-sans text-[14px] text-[#292524] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#615fff] focus:ring-2 focus:ring-[#615fff]/10" />
                </div>

                <div class="flex flex-col gap-1.5">
                  <label for="co-goal" class="font-sans text-[13px] font-semibold text-[#292524]">Biggest marketing challenge right now</label>
                  <textarea id="co-goal" name="goal" rows="3" placeholder="e.g. We don't rank on Google Maps, our blog hasn't been updated in 2 years..."
                    class="rounded-xl border border-[#e7e5e4] bg-white px-4 py-3 font-sans text-[14px] text-[#292524] placeholder:text-[#d1d5db] outline-none transition-colors focus:border-[#615fff] focus:ring-2 focus:ring-[#615fff]/10 resize-none leading-relaxed"></textarea>
                </div>
              </div>
            </div>

            <!-- Hidden inputs -->
            <input type="hidden" id="hidden-modules" name="selected_modules" />
            <input type="hidden" id="hidden-billing" name="billing" />

          </form>

          <!-- Right: Sticky order summary -->
          <div class="lg:sticky lg:top-24 self-start flex flex-col gap-4">
            <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-6">
              <h2 class="font-sans text-[16px] font-semibold text-[#292524]">Your plan</h2>

              <!-- Empty state -->
              <div id="summary-empty" class="mt-4 rounded-lg border border-dashed border-[#e7e5e4] bg-white px-4 py-6 text-center">
                <p class="font-sans text-[14px] text-[#79716b]">No modules selected.</p>
                <a href="/pricing/" class="mt-2 inline-block font-sans text-[14px] font-medium text-[#615fff] hover:underline">Go back and choose a plan</a>
              </div>

              <!-- Filled state -->
              <div id="summary-filled" class="hidden mt-4 flex flex-col gap-3">
                <div id="summary-modules"></div>

                <div class="border-t border-[#e7e5e4] pt-3 flex flex-col gap-2">
                  <div id="summary-discount-row" class="hidden items-center justify-between">
                    <span class="font-sans text-[13px] text-[#79716b]">Bundle discount (15%)</span>
                    <span class="font-mono text-[13px] font-semibold text-[#615fff]" id="summary-discount-amount"></span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="font-sans text-[13px] text-[#79716b]">Billing</span>
                    <span class="font-sans text-[13px] font-medium text-[#292524]" id="summary-billing">Annual</span>
                  </div>
                </div>

                <div class="rounded-lg border border-[#615fff]/15 bg-[#615fff]/[0.03] px-4 py-3">
                  <div class="flex items-center justify-between">
                    <div>
                      <p class="font-sans text-[12px] text-[#79716b]">Due today</p>
                      <p class="font-sans text-[22px] font-bold text-[#292524]">$1.00</p>
                    </div>
                    <div class="text-right">
                      <p class="font-sans text-[12px] text-[#79716b]">Then</p>
                      <p class="font-sans text-[18px] font-bold text-[#292524]">$<span id="summary-total">0</span><span class="text-[13px] font-normal text-[#79716b]">/mo</span></p>
                    </div>
                  </div>
                  <p class="mt-1.5 font-sans text-[11px] text-[#79716b]">3-day trial. Cancel before it ends and pay nothing more.</p>
                </div>
              </div>
            </div>

            <!-- Submit -->
            <button
              form="checkout-form"
              type="submit"
              id="checkout-submit"
              class="cursor-pointer flex h-[48px] w-full items-center justify-center gap-2 rounded-xl border border-[#615fff] bg-[#615fff] font-sans text-[16px] font-semibold text-white transition-colors hover:bg-[#4f39f6]"
            >
              Book my strategy call
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>

            <!-- Trust -->
            <div class="flex flex-col gap-1.5 px-1">
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span class="font-sans text-[12px] text-[#79716b]">$1 trial · Cancel anytime · No commitment</span>
              </div>
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                <span class="font-sans text-[12px] text-[#79716b]"> guarantee</span>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  // ─── ORDER SUMMARY FROM URL PARAMS ───
  (function () {
    const blogTiers = [
      { label: '30 articles', price: 99 },
      { label: '50 articles', price: 149 },
      { label: '80 articles', price: 199 },
    ];
    const localTiers = [
      { label: '30 posts', price: 49 },
      { label: '60 posts', price: 79 },
      { label: '80 posts', price: 99 },
    ];
    const socialTiers = [
      { label: '30 posts', price: 49 },
      { label: '60 posts', price: 79 },
      { label: '120 posts', price: 129 },
    ];
    type ModKey = 'blog' | 'local' | 'social';
    const allTiers: Record<ModKey, { label: string; price: number }[]> = { blog: blogTiers, local: localTiers, social: socialTiers };
    const modLabels: Record<ModKey, string> = { blog: 'Blog SEO', local: 'Local SEO', social: 'Social Media' };
    const modIcons: Record<ModKey, string> = {
      blog: '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>',
      local: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
      social: '<path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>',
    };
    const modIconColors: Record<ModKey, string> = { blog: '#615fff', local: '#22c55e', social: '#f59e0b' };
    const modIconBgs: Record<ModKey, string> = { blog: 'bg-[#615fff]/10', local: 'bg-[#22c55e]/10', social: 'bg-[#f59e0b]/10' };

    function round(n: number) { return Math.round(n); }

    const params = new URLSearchParams(window.location.search);
    const isAnnual = params.get('billing') !== 'monthly';
    const selected: { mod: ModKey; tierIdx: number }[] = [];
    (['blog', 'local', 'social'] as ModKey[]).forEach(mod => {
      const v = params.get(mod);
      if (v !== null) {
        const idx = parseInt(v);
        if (!isNaN(idx) && idx >= 0 && idx < allTiers[mod].length) selected.push({ mod, tierIdx: idx });
      }
    });

    // Populate hidden inputs
    (document.getElementById('hidden-modules') as HTMLInputElement).value = selected.map(s => s.mod).join(',');
    (document.getElementById('hidden-billing') as HTMLInputElement).value = isAnnual ? 'annual' : 'monthly';

    const emptyEl = document.getElementById('summary-empty')!;
    const filledEl = document.getElementById('summary-filled')!;
    const modulesEl = document.getElementById('summary-modules')!;
    const discountRow = document.getElementById('summary-discount-row')!;
    const discountAmountEl = document.getElementById('summary-discount-amount')!;
    const billingEl = document.getElementById('summary-billing')!;
    const totalEl = document.getElementById('summary-total')!;

    if (selected.length === 0) {
      emptyEl.classList.remove('hidden');
      filledEl.classList.add('hidden');
    } else {
      emptyEl.classList.add('hidden');
      filledEl.classList.remove('hidden');

      modulesEl.innerHTML = selected.map(({ mod, tierIdx }) => {
        const tier = allTiers[mod][tierIdx];
        const price = isAnnual ? round(tier.price * 0.83) : tier.price;
        return `
          <div class="flex items-center justify-between rounded-lg border border-[#e7e5e4] bg-white px-3 py-2.5">
            <div class="flex items-center gap-2.5">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg ${modIconBgs[mod]}">
                <svg viewBox="0 0 24 24" fill="none" stroke="${modIconColors[mod]}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-[15px] w-[15px]">${modIcons[mod]}</svg>
              </div>
              <div>
                <p class="font-sans text-[13px] font-semibold text-[#292524]">${modLabels[mod]}</p>
                <p class="font-sans text-[11px] text-[#79716b]">${tier.label}/mo</p>
              </div>
            </div>
            <span class="font-mono text-[14px] font-bold text-[#292524]">$${price}</span>
          </div>
        `;
      }).join('');

      const hasBundle = selected.length >= 2;
      let rawTotal = selected.reduce((s, { mod, tierIdx }) => {
        const base = allTiers[mod][tierIdx].price;
        return s + (isAnnual ? round(base * 0.83) : base);
      }, 0);
      if (hasBundle) {
        const discountAmt = rawTotal - round(rawTotal * 0.85);
        discountRow.classList.remove('hidden');
        discountRow.classList.add('flex');
        discountAmountEl.textContent = `-$${discountAmt}`;
        rawTotal = round(rawTotal * 0.85);
      }
      billingEl.textContent = isAnnual ? 'Annual (save 17%)' : 'Monthly';
      totalEl.textContent = String(rawTotal);
    }
  })();

  // ─── FORM SUBMISSION ───
  (function () {
    const form = document.getElementById('checkout-form') as HTMLFormElement;
    const submitBtn = document.getElementById('checkout-submit') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const originalHTML = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        Getting you set up...
      `;

      try {
        const fd = new FormData(form);
        const data = {
          first_name: (fd.get('first_name') as string)?.trim(),
          last_name: (fd.get('last_name') as string)?.trim(),
          email: (fd.get('email') as string)?.trim(),
          phone: (fd.get('phone') as string)?.trim(),
          website: (fd.get('website') as string)?.trim() || undefined,
          business: (fd.get('business') as string)?.trim() || undefined,
          goal: (fd.get('goal') as string)?.trim() || undefined,
          selected_modules: (fd.get('selected_modules') as string) || undefined,
          billing: (fd.get('billing') as string) || undefined,
        };

        const res = await fetch('/api/checkout/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          // Show success state
          const main = document.querySelector('main section')!;
          main.innerHTML = `
            <div class="px-6 py-24 text-center max-w-[520px] mx-auto">
              <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-[#22c55e]/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              </div>
              <h1 class="mt-6 font-sans text-[28px] leading-[36px] font-semibold text-[#292524]">You're in.</h1>
              <p class="mt-3 font-sans text-[15px] leading-[24px] text-[#79716b]">
                We've received your details. Our team will be in touch within 1 business day to confirm your strategy call.
              </p>
              <p class="mt-3 font-sans text-[14px] leading-[22px] text-[#79716b]">
                Check your inbox — we've sent a confirmation with next steps.
              </p>
              <div class="mt-8">
                <a href="/" class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#615fff] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#4f39f6]">
                  Back to theStacc
                </a>
              </div>
            </div>
          `;
        } else {
          const result = await res.json().catch(() => ({}));
          throw new Error(result.error || 'Something went wrong');
        }
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalHTML;
        const msg = err instanceof Error ? err.message : 'Something went wrong.';
        alert(`${msg} Email us at hello@thestacc.com`);
      }
    });
  })();
</script>
