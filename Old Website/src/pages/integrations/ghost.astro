---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';

const faqs = [
  {
    q: "What data syncs between Stacc and Ghost?",
    a: "Business name, address, phone number, hours, and service descriptions sync from Stacc to your Ghost site. Any update made in Stacc — including changes pulled automatically from Google Business Profile — can push to your Ghost content without manual edits.",
  },
  {
    q: "Does Stacc inject local schema markup on Ghost?",
    a: "Yes. Stacc pushes LocalBusiness JSON-LD schema to your Ghost site's head section via the Code Injection feature. This structured data helps Google understand your business's location, hours, and category for local search ranking.",
  },
  {
    q: "Can I embed a review widget on Ghost?",
    a: "Yes. Stacc provides an embeddable review feed that you can add to any Ghost page or post using a custom HTML card. Your latest Google and Facebook reviews display dynamically — no manual updates needed.",
  },
  {
    q: "Does the Ghost integration require a developer?",
    a: "No. The integration uses Ghost's built-in Code Injection and Custom Integration features — no theme modification or custom code is required. If you can paste text into Ghost settings, you can set this up.",
  },
  {
    q: "Which Ghost plans are supported?",
    a: "The Stacc integration works with Ghost Pro (Starter, Creator, Team, and Business plans) and self-hosted Ghost installations. Ghost's Code Injection feature, which is required for schema injection, is available on all paid Ghost Pro plans.",
  },
  {
    q: "Can I use this for a multi-location Ghost site?",
    a: "Yes. For businesses with multiple locations, Stacc can populate location-specific data on different Ghost pages or sections. Each location's data — address, hours, reviews — stays accurate and in sync across your Ghost site.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "theStacc — Ghost Integration",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Web",
      "description": "Connect Ghost to theStacc. Sync local business data, auto-inject local schema, and embed live review feeds on your Ghost-powered site.",
      "offers": { "@type": "Offer", "price": "49", "priceCurrency": "USD" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Integrations", "item": "https://thestacc.com/integrations/" },
        { "@type": "ListItem", "position": 3, "name": "Ghost", "item": "https://thestacc.com/integrations/ghost/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<BaseLayout
  title="Ghost Integration — Sync Local SEO Data With Your Ghost Site | theStacc"
  description="Connect Ghost with theStacc to keep local business data consistent across your Ghost-powered site. Automate local schema and NAP sync without touching code."

>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Header />
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Integration · Ghost</span>
          </div>

          <div class="mb-8 flex items-center justify-center gap-5">
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-label="theStacc" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4" fill="#4f39f6"/>
                <path d="M8 12h8M12 8v8" stroke="white" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              <div class="h-px w-8 bg-[#f5f3ff]"></div>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl border border-[#e7e5e4] bg-white">
              <svg width="28" height="28" viewBox="0 0 24 24" aria-label="Ghost" aria-hidden="true">
                <circle cx="12" cy="12" r="10" fill="#15212A"/>
                <text x="12" y="17" font-size="14" font-weight="bold" fill="white" text-anchor="middle" font-family="sans-serif">G</text>
              </svg>
            </div>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            Stacc + Ghost.<br />
            <span style="color:#4f39f6;">Local SEO, built in.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Connect your Ghost site to Stacc and keep all your local business data accurate automatically. NAP synced, local schema injected, and a live review feed embedded — without touching your theme or writing any code.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]">
              Connect Ghost free
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#how-to-connect"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No code required · 3-minute setup · Ghost Pro + self-hosted
          </p>
        </div>
      </div>
    </section>


    <!-- ─── WHAT THIS DOES ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What you get</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Local SEO signals flow from Stacc<br />into your Ghost site automatically.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'NAP data sync', body: 'Business name, address, and phone stay accurate between Stacc, Google, and your Ghost site. One update in Stacc corrects everywhere.' },
            { icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', title: 'Local schema injection', body: 'LocalBusiness JSON-LD schema pushes to your Ghost site\'s Code Injection section automatically. Search engines get clean structured data with zero manual work.' },
            { icon: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z', title: 'Dynamic review feed', body: 'Embed your latest Google and Facebook reviews on any Ghost page. The feed updates automatically as new reviews come in — always showing fresh social proof.' },
            { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', title: 'Business hours sync', body: 'Hours updated in Stacc push to your Ghost site automatically. Holiday hours, seasonal changes — customers always see the right information.' },
            { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', title: 'Services and description sync', body: 'Service descriptions from your GBP profile sync to Ghost pages. Consistent, accurate descriptions wherever customers and search engines look.' },
            { icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', title: 'Multi-location support', body: 'Connect multiple Ghost sites — one per location — and sync location-specific data to each. Each site stays accurate without manual management.' },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d={f.icon}/></svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── SETUP STEPS ─── -->
    <section id="how-to-connect" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How to connect</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Three steps. No developer.<br />Ghost connected.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-3xl space-y-4">
          {[
            { step: '01', title: 'Generate an API key in Ghost', body: 'In your Ghost Admin, go to Settings → Integrations → Add Custom Integration. Give it a name (e.g. "Stacc") and copy the Admin API Key generated. This is what Stacc uses to push data to your site.' },
            { step: '02', title: 'Add the API key to Stacc', body: 'In Stacc settings under Integrations → Ghost, paste your Admin API Key and your Ghost site URL. Stacc verifies the connection and confirms which location it\'s linked to.' },
            { step: '03', title: 'Enable sync and embed your review widget', body: 'Turn on NAP sync, schema injection, and hours sync. Grab the review widget embed code from Stacc and add it to any Ghost page using a Custom HTML card. Done.' },
          ].map(s => (
            <div class="flex gap-6 rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[2rem] font-semibold leading-none tracking-[-0.04em] text-[#4f39f6]/20 shrink-0">{s.step}</span>
              <div>
                <p class="font-sans text-[15px] font-semibold text-[#111827]">{s.title}</p>
                <p class="mt-1.5 font-sans text-[14px] leading-relaxed text-[#57534e]">{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── BEFORE / AFTER ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Before vs. after</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            What changes when Ghost<br />connects to Stacc.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-[#e7e5e4]">
          <div class="grid grid-cols-3 bg-[#f5f3ff] border-b border-[#e7e5e4]">
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Task</div>
            <div class="border-x border-[#e7e5e4] px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Without Stacc</div>
            <div class="px-6 py-4 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">With Stacc</div>
          </div>
          {[
            ['Add local schema to Ghost', 'Hire dev or manually add JSON-LD to theme', 'Auto-injected via Code Injection'],
            ['Update business hours on site', 'Edit Ghost page content manually', 'Update in Stacc, pushes automatically'],
            ['Show reviews on Ghost site', 'Screenshot and paste reviews manually', 'Live embed, always shows latest reviews'],
            ['Keep NAP consistent', 'Update Ghost, GBP, directories separately', 'One update in Stacc, syncs everywhere'],
            ['Change business address', 'Update 6+ platforms manually', 'Update once, pushes to all connected platforms'],
          ].map(([task, before, after]) => (
            <div class="grid grid-cols-3 border-b border-[#e7e5e4] last:border-0">
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#292524]">{task}</div>
              <div class="border-x border-[#e7e5e4] px-6 py-4 font-sans text-[13px] text-[#79716b]">{before}</div>
              <div class="px-6 py-4 font-sans text-[13px] font-medium text-[#4f39f6]">{after}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── USE CASES ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Who uses this</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Three workflows this<br />integration unlocks immediately.
          </h2>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-5 md:grid-cols-3">
          {[
            { label: 'Local businesses on Ghost', title: 'Always-accurate local data without developer help', body: 'Your Ghost site stays in sync with your real business data automatically. Hours, address, phone, and reviews — accurate everywhere without manual updates.' },
            { label: 'Content-first local businesses', title: 'SEO-optimized local pages with correct schema', body: 'Ghost is built for content. Stacc adds the local SEO layer — schema markup, NAP consistency, and review signals — so your content ranks locally.' },
            { label: 'SEO agencies', title: 'Automate local SEO setup for Ghost clients', body: 'Connect client Ghost sites to Stacc and deploy local schema, NAP sync, and review feeds across all client sites in minutes instead of hours.' },
          ].map(c => (
            <div class="rounded-2xl border border-[#e7e5e4] bg-white p-7">
              <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.14em] text-[#4f39f6]">{c.label}</span>
              <p class="mt-3 font-sans text-[15px] font-semibold leading-snug text-[#111827]">{c.title}</p>
              <p class="mt-2.5 font-sans text-[13px] leading-relaxed text-[#57534e]">{c.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── RELATED INTEGRATIONS ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">Often connected together</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Ghost works best<br />alongside these.
          </h2>
        </div>
        <div class="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-5 sm:grid-cols-3">
          {[
            { title: 'Google Business Profile', desc: 'The source of truth. Changes in GBP sync to Stacc, then push to your Ghost site automatically.', href: '/integrations/google-business-profile/' },
            { title: 'Citation Management', desc: 'Keep NAP consistent across 50+ directories — including your Ghost site — from one dashboard.', href: '/features/citation-management/' },
            { title: 'Review Monitoring', desc: 'Monitor reviews across platforms and display the latest ones on Ghost with the live review embed.', href: '/features/review-monitoring/' },
          ].map(r => (
            <a href={r.href} class="group rounded-2xl border border-[#e7e5e4] bg-[#fafaf9] p-6 transition-colors hover:border-[#4f39f6]/30 hover:bg-[#f5f3ff]/40">
              <p class="font-sans text-[14px] font-semibold text-[#111827] group-hover:text-[#4f39f6]">{r.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-relaxed text-[#57534e]">{r.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FAQ ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">FAQ</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Questions about the<br />Ghost integration
          </h2>
        </div>
        <div class="mx-auto mt-10 max-w-3xl divide-y divide-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white">
          {faqs.map((faq) => (
            <div class="faq-item">
              <button class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 text-left">
                <span class="font-sans text-[15px] font-semibold text-[#111827]">{faq.q}</span>
                <span class="faq-icon-plus shrink-0 text-[#4f39f6]">+</span>
                <span class="faq-icon-minus hidden shrink-0 text-[#4f39f6]">−</span>
              </button>
              <div class="faq-answer hidden px-6 pb-5">
                <p class="font-sans text-[14px] leading-relaxed text-[#57534e]">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── FINAL CTA ─── -->
    <section class="relative overflow-hidden py-24" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[500px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.06) 0%, transparent 60%);" aria-hidden="true"></div>
      <div class="container-x relative">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">Connect in minutes</span>
          <h2 class="mt-3 font-sans text-[2rem] font-semibold leading-[1.15] tracking-[-0.03em] text-[#292524] md:text-[2.75rem]">
            Your Ghost site.<br />Local SEO handled automatically.
          </h2>
          <p class="mt-5 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            Ghost is excellent for content. Stacc adds the local SEO layer it's missing — schema markup, NAP sync, and review feeds — automatically. No developer, no maintenance, no outdated business info on your site.
          </p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo/" target="_blank" rel="noopener noreferrer"
              class="inline-flex h-12 items-center gap-2 rounded-xl bg-white px-6 font-sans text-[14px] font-semibold text-[#111827] transition-colors hover:bg-[#f9fafb]">
              Connect Ghost free
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/pricing/"
              class="inline-flex h-12 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]">
              View pricing
            </a>
          </div>
          <p class="mt-5 font-mono text-[10px] uppercase tracking-[0.18em] text-[#292524]/20">$1 for 3 days · No credit card · Cancel anytime</p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const plus = btn.querySelector('.faq-icon-plus');
      const minus = btn.querySelector('.faq-icon-minus');
      if (!answer) return;
      const isOpen = !answer.classList.contains('hidden');
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon-plus').forEach(i => i.classList.remove('hidden'));
      document.querySelectorAll('.faq-icon-minus').forEach(i => i.classList.add('hidden'));
      if (!isOpen) {
        answer.classList.remove('hidden');
        plus?.classList.add('hidden');
        minus?.classList.remove('hidden');
      }
    });
  });
</script>
