---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { getCollection } from 'astro:content';

const alternatives = await getCollection('alternatives');

const sortedAlternatives = alternatives.sort((a, b) => a.data.title.localeCompare(b.data.title));
const visibleAlts = sortedAlternatives.filter(a => a.data.image);

function readTime(body: string): number {
  const words = (body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

// Extract tool names from slugs for filter tabs
const popularTools = ['ahrefs', 'semrush', 'jasper', 'surfer', 'frase', 'clearscope', 'copy-ai'];
const toolTabs = popularTools.filter(tool =>
  visibleAlts.some(a => a.data.slug.toLowerCase().includes(tool))
);

function matchesTool(slug: string, tool: string): boolean {
  return slug.toLowerCase().includes(tool.toLowerCase());
}

const toolLabel = (t: string) => t.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

const switchReasons = [
  { icon: '💸', reason: 'Too expensive', detail: 'Find tools that deliver more per dollar' },
  { icon: '🔧', reason: 'Missing features', detail: 'Get what you actually need' },
  { icon: '📉', reason: 'Poor results', detail: 'Tools that move rankings, not just metrics' },
  { icon: '🤖', reason: 'No automation', detail: 'Stop doing manually what can run on autopilot' },
];
---

<BaseLayout
  title="SEO Tool Alternatives 2026 - Ranked Comparisons - theStacc"
  description="Looking for alternatives to popular SEO tools? Full comparisons with pricing, features, and switching guides. Ranked by an SEO team that publishes 30+ articles/month."
>
  <Header />
  <main class="flex-1">

    <!-- ░░ DARK HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-12 pb-12">

        <div class="flex items-center gap-2 mb-3">
          <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">Alternatives</span>
          <span class="h-3 w-px bg-[#e7e5e4]"></span>
          <span class="font-mono text-[10px] text-[#79716b]">{visibleAlts.length} comparison guides</span>
        </div>

        <h1 class="font-sans text-[28px] font-bold leading-[1.18] tracking-[-0.025em] text-[#292524] md:text-[40px]">
          SEO Tool Alternatives
        </h1>
        <p class="mt-3 max-w-[560px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          Thinking of switching? We've done the research. Full comparisons with pricing, features, and honest switching guides. Ranked by practitioners who run 30+ articles a month.
        </p>

        <!-- Trust pills -->
        <div class="mt-6 flex flex-wrap gap-2">
          {[
            `${visibleAlts.length} comparison guides`,
            'Pricing verified March 2026',
            'Honest switching costs',
            'Unbiased rankings',
          ].map(text => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-[#e7e5e4] bg-white px-3 py-1 font-mono text-[11px] text-[#6b7280]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {text}
            </span>
          ))}
        </div>

      </div>
    </section>

    <!-- ░░ WHY TEAMS SWITCH STRIP ░░ -->
    <div class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x">
        <div class="flex items-center gap-6 overflow-x-auto py-4 scrollbar-none">
          {switchReasons.map(item => (
            <div class="flex shrink-0 items-center gap-2.5">
              <span class="text-[16px]">{item.icon}</span>
              <div>
                <p class="font-mono text-[11px] font-bold text-[#292524]">{item.reason}</p>
                <p class="font-mono text-[10px] text-[#79716b]">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ░░ TOOL FILTER TABS ░░ -->
    <div class="sticky top-0 z-20 border-b border-[#e7e5e4] bg-white">
      <div class="container-x">
        <div class="flex items-center gap-1 overflow-x-auto py-3 scrollbar-none" id="tool-tabs">
          <button data-tool="all" class="tool-tab active shrink-0">All ({visibleAlts.length})</button>
          {toolTabs.map(tool => (
            <button data-tool={tool} class="tool-tab shrink-0">
              {toolLabel(tool)} ({visibleAlts.filter(a => matchesTool(a.data.slug, tool)).length})
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- ░░ CARD GRID ░░ -->
    <section class="bg-[#fafaf9] px-6 py-10">
      <div class="mx-auto max-w-6xl">

        <!-- All panel -->
        <div id="grid-all" class="tool-panel">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {visibleAlts.map((alt) => (
              <a href={`/alternatives/${alt.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
                <div class="flex flex-1 flex-col p-6">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Alternatives</span>
                  <h2 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{alt.data.title}</h2>
                  <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{alt.data.description}</p>
                  <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                    <span class="font-mono text-[10px] text-[#79716b]">{alt.data.date} · {readTime(alt.body ?? '')} min</span>
                    <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Per-tool panels -->
        {toolTabs.map(tool => (
          <div id={`grid-${tool}`} class="tool-panel hidden">
            <div class="mb-6">
              <h2 class="font-sans text-[20px] font-bold text-[#292524]">{toolLabel(tool)} Alternatives</h2>
              <p class="mt-1 font-mono text-[11px] text-[#79716b]">{visibleAlts.filter(a => matchesTool(a.data.slug, tool)).length} guides</p>
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {visibleAlts.filter(a => matchesTool(a.data.slug, tool)).map((alt: any) => (
                <a href={`/alternatives/${alt.data.slug}/`} class="group relative flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm">
                  <div class="h-[3px] w-full bg-gradient-to-r from-[#4f39f6] via-[#818cf8] to-[#c4b5fd]"></div>
                  <div class="flex flex-1 flex-col p-6">
                    <span class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#4f39f6]">Alternatives</span>
                    <h3 class="mt-2.5 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-3 transition-colors group-hover:text-[#4f39f6]">{alt.data.title}</h3>
                    <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{alt.data.description}</p>
                    <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                      <span class="font-mono text-[10px] text-[#79716b]">{alt.data.date} · {readTime(alt.body ?? '')} min</span>
                      <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}

      </div>
    </section>

    <!-- ░░ DARK FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <p class="font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-[#818cf8]">theStacc</p>
        <h3 class="mt-3 font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Done comparing. Time to publish.
        </h3>
        <p class="mx-auto mt-3 max-w-[440px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          Stop evaluating tools. theStacc writes, optimizes, and publishes 30 SEO articles to your site every month. Automatically.
        </p>
        <a
          href="/demo/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Start Your $1 Trial
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">$1 for 3 days · Cancel anytime</p>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
.tool-tab {
  cursor: pointer;
  padding: 0.4rem 0.875rem;
  font-family: var(--font-geist-mono);
  font-size: 12px;
  font-weight: 600;
  color: #57534e;
  background: transparent;
  border: none;
  white-space: nowrap;
  transition: color 0.1s, background 0.1s;
}
.tool-tab:hover { color: #4f39f6; background: #f5f3ff; }
.tool-tab.active { color: #4f39f6; background: #f5f3ff; }
.scrollbar-none::-webkit-scrollbar { display: none; }
.scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
const toolTabs = document.querySelectorAll('.tool-tab');
const toolPanels = document.querySelectorAll('.tool-panel');

toolTabs.forEach(tab => {
  tab.addEventListener('click', () => {
    const tool = (tab as HTMLElement).dataset.tool;
    toolTabs.forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    toolPanels.forEach((panel: any) => {
      const id = panel.id.replace('grid-', '');
      panel.classList.toggle('hidden', id !== tool);
    });
  });
});
</script>
