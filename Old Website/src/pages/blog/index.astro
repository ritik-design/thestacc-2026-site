---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { getCollection } from 'astro:content';
import { POSTS_PER_PAGE } from '../../data/constants';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const visiblePosts = sortedPosts.filter(p => p.data.image);
const totalPages = Math.ceil(visiblePosts.length / POSTS_PER_PAGE);
const pagePosts = visiblePosts.slice(0, POSTS_PER_PAGE);

function getReadTime(post: any): number {
  const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

// All-posts categories for Browse by Topic
const allCategoryCounts = visiblePosts.reduce<Record<string, number>>((acc, p) => {
  acc[p.data.category] = (acc[p.data.category] || 0) + 1;
  return acc;
}, {});
const allCategories = Object.entries(allCategoryCounts).sort((a, b) => b[1] - a[1]);

// Page-scoped counts for filter bar
const pageCategoryCounts = pagePosts.reduce<Record<string, number>>((acc, p) => {
  acc[p.data.category] = (acc[p.data.category] || 0) + 1;
  return acc;
}, {});
const pageCategories = Object.entries(pageCategoryCounts).sort((a, b) => b[1] - a[1]);

const featuredPosts = pagePosts.slice(0, 3);
const featuredLabels = ['Most Popular', 'Trending', "Editor's Pick"];

const tools = [
  { name: 'SEO Audit', href: '/tools/seo-audit/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>` },
  { name: 'Website Score', href: '/tools/website-seo-score/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>` },
  { name: 'Meta Tags', href: '/tools/meta-tag-analyzer/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>` },
  { name: 'On-Page SEO', href: '/tools/on-page-seo-checker/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>` },
  { name: 'Schema Maker', href: '/tools/schema-markup-generator/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>` },
  { name: 'Headline Analyzer', href: '/tools/headline-analyzer/', svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h7"/></svg>` },
];
---

<BaseLayout
  title="SEO Blog | theStacc"
  description="500+ SEO guides, tutorials, and strategies for ranking higher and converting more traffic. Local SEO, content strategy, AI SEO, and agency growth. Updated weekly."
>
  <Fragment slot="head">
    {totalPages > 1 && <link rel="next" href="/blog/page/2/" />}
  </Fragment>
  <Header />
  <main class="flex-1">

    <!-- ░░ HERO ░░ -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.18) 0%, transparent 62%);"></div>
      <div class="container-x relative z-10 pt-8 pb-10">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">SEO Blog</p>
        <h1 class="mt-3 max-w-[600px] font-sans text-[28px] font-bold leading-[1.15] tracking-[-0.025em] text-[#292524] md:text-[38px]">
          The SEO Resource Library
        </h1>
        <p class="mt-3 max-w-[500px] font-sans text-[15px] leading-[1.7] text-[#57534e]">
          {visiblePosts.length}+ guides, tutorials, and strategies for ranking higher and converting more traffic.
        </p>

        <!-- Search -->
        <div class="mt-5 max-w-[520px]">
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <input
              id="blog-search"
              type="search"
              placeholder={`Search ${visiblePosts.length}+ SEO guides and strategies...`}
              style="background:#f5f5f4;color:#292524;"
              class="w-full rounded-xl border border-[#e7e5e4] py-3 pl-11 pr-4 font-sans text-[14px] placeholder-[#4b5563] outline-none ring-0 transition-all focus:border-[#4f39f6]"
            />
          </div>
        </div>

      </div>
    </section>

    <!-- ░░ BROWSE BY TOPIC ░░ -->
    <section class="border-b border-[#e7e5e4] bg-white py-8">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-5 flex items-center justify-between">
          <h2 class="font-sans text-[17px] font-bold text-[#111827]">Browse by Topic</h2>
          <span class="font-mono text-[11px] text-[#79716b]">{allCategories.length} categories · {visiblePosts.length} articles</span>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {allCategories.map(([cat, count]) => (
            <button
              class="topic-btn group flex cursor-pointer flex-col items-start gap-1 rounded-xl border border-[#e7e5e4] bg-white p-4 text-left transition-all hover:border-[#c4b5fd] hover:shadow-sm"
              data-topic={cat}
            >
              <span class="font-sans text-[12px] font-semibold leading-[1.4] text-[#292524] transition-colors group-hover:text-[#4f39f6]">{cat}</span>
              <span class="font-mono text-[10px] text-[#79716b]">{count} articles</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ POPULAR THIS MONTH ░░ -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9] py-8">
      <div class="mx-auto max-w-6xl px-6">
        <p class="mb-5 font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#79716b]">Popular This Month</p>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
          {featuredPosts.map((post, i) => (
            <a
              href={`/blog/${post.data.slug}/`}
              class="group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-md"
            >
              <div class="flex flex-1 flex-col p-5">
                <div class="mb-2.5 flex items-center justify-between gap-2">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                  <span class="shrink-0 rounded-full bg-[#f5f3ff] px-2.5 py-0.5 font-mono text-[9px] font-bold uppercase tracking-[0.06em] text-[#7c3aed]">{featuredLabels[i]}</span>
                </div>
                <h3 class="flex-1 font-sans text-[15px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                  {post.data.title}
                </h3>
                <div class="mt-3 flex items-center gap-2">
                  <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min read</span>
                  <span class="text-[#d6d3d1]">·</span>
                  <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ STICKY FILTER BAR ░░ -->
    <div id="article-grid-top" class="sticky top-0 z-30 border-b border-[#e7e5e4] bg-white/95 backdrop-blur-sm">
      <div class="mx-auto max-w-6xl px-6 py-3.5">
        <div class="flex flex-wrap items-center gap-1.5">
          <button
            data-category="all"
            class="blog-cat-btn cursor-pointer rounded-lg border border-[#4f39f6] bg-[#4f39f6] px-3 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-white transition-colors"
          >All <span class="font-normal opacity-70">{pagePosts.length}</span></button>
          {pageCategories.map(([cat, count]) => (
            <button
              data-category={cat}
              class="blog-cat-btn cursor-pointer rounded-lg border border-[#e7e5e4] bg-white px-3 py-1.5 font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]"
            >{cat} <span class="font-normal opacity-70">{count}</span></button>
          ))}
        </div>
      </div>
    </div>

    <!-- ░░ GRID ░░ -->
    <section class="bg-[#fafaf9] px-6 py-8">
      <div class="mx-auto max-w-6xl">

        <!-- First 9 cards -->
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
          {pagePosts.slice(0, 9).map((post) => (
            <a
              href={`/blog/${post.data.slug}/`}
              class="blog-card group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm"
              data-category={post.data.category}
              data-title={post.data.title.toLowerCase()}
              data-desc={(post.data.description ?? '').toLowerCase()}
            >
              <div class="flex flex-1 flex-col p-5">
                <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                <h3 class="mt-2 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                  {post.data.title}
                </h3>
                <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                    <span class="text-[#e7e5e4]">·</span>
                    <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min read</span>
                  </div>
                  <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Newsletter CTA (hidden when searching) -->
        <div class="newsletter-row my-6 rounded-2xl border border-[#e7e5e4] bg-white p-6 md:p-8">
          <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
            <div class="max-w-[480px]">
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Weekly SEO Wins</p>
              <h3 class="mt-1.5 font-sans text-[20px] font-bold leading-[1.2] text-[#111827]">Get the strategies that actually move rankings</h3>
              <p class="mt-2 font-sans text-[14px] leading-[1.6] text-[#57534e]">One weekly email: tactics, tool updates, and case studies worth your time. Join thousands of SEO professionals and business owners.</p>
            </div>
            <div class="shrink-0">
              <div class="flex flex-col gap-2 sm:flex-row">
                <input
                  type="email"
                  placeholder="your@email.com"
                  class="h-10 rounded-lg border border-[#e7e5e4] px-4 font-sans text-[14px] text-[#292524] placeholder-[#a8a29e] outline-none focus:border-[#4f39f6] sm:w-[220px]"
                />
                <a
                  href="/demo/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex h-10 items-center justify-center rounded-lg bg-[#4f39f6] px-5 font-mono text-[12px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#615fff] whitespace-nowrap"
                >
                  Subscribe Free
                </a>
              </div>
              <p class="mt-1.5 font-mono text-[10px] text-[#79716b]">No spam · Unsubscribe anytime</p>
            </div>
          </div>
        </div>

        <!-- Remaining cards -->
        {pagePosts.length > 9 && (
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {pagePosts.slice(9).map((post) => (
              <a
                href={`/blog/${post.data.slug}/`}
                class="blog-card group flex flex-col overflow-hidden rounded-xl border border-[#e7e5e4] bg-white transition-all hover:border-[#c4b5fd] hover:shadow-sm"
                data-category={post.data.category}
                data-title={post.data.title.toLowerCase()}
                data-desc={(post.data.description ?? '').toLowerCase()}
              >
                <div class="flex flex-1 flex-col p-5">
                  <span class="font-mono text-[10px] font-bold uppercase tracking-[0.12em] text-[#4f39f6]">{post.data.category}</span>
                  <h3 class="mt-2 flex-1 font-sans text-[16px] font-semibold leading-[1.4] text-[#292524] line-clamp-2 transition-colors group-hover:text-[#4f39f6]">
                    {post.data.title}
                  </h3>
                  <p class="mt-2 font-sans text-[13px] leading-[1.6] text-[#79716b] line-clamp-2">{post.data.description}</p>
                  <div class="mt-4 flex items-center justify-between border-t border-[#f5f5f4] pt-3">
                    <div class="flex items-center gap-2">
                      <span class="font-mono text-[10px] text-[#79716b]">{post.data.date}</span>
                      <span class="text-[#e7e5e4]">·</span>
                      <span class="font-mono text-[10px] text-[#79716b]">{getReadTime(post)} min read</span>
                    </div>
                    <svg class="text-[#c4b5fd] transition-colors group-hover:text-[#4f39f6]" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}

        <!-- No results -->
        <div id="no-results" class="hidden py-16 text-center">
          <p class="font-sans text-[16px] text-[#79716b]">
            No articles found.
            <button id="clear-search" class="cursor-pointer text-[#4f39f6] underline">Clear search</button>
          </p>
        </div>

        <!-- Pagination -->
        {totalPages > 1 && (
          <nav class="mt-10 flex items-center justify-center gap-2" aria-label="Blog pagination">
            <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-[#4f39f6] font-mono text-[13px] font-semibold text-white">1</span>
            {Array.from({ length: Math.min(totalPages - 1, 4) }, (_, i) => i + 2).map(num => (
              <a href={`/blog/page/${num}/`} class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] font-mono text-[13px] font-semibold text-[#79716b] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">{num}</a>
            ))}
            {totalPages > 5 && <span class="font-mono text-sm text-[#79716b]">…</span>}
            {totalPages > 5 && (
              <a href={`/blog/page/${totalPages}/`} class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[#e7e5e4] font-mono text-[13px] font-semibold text-[#79716b] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">{totalPages}</a>
            )}
            <a href="/blog/page/2/" class="ml-1 inline-flex items-center gap-1.5 rounded-lg border border-[#e7e5e4] px-4 py-2 font-mono text-[12px] font-semibold text-[#57534e] transition-colors hover:border-[#4f39f6] hover:text-[#4f39f6]">
              Next
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </nav>
        )}
      </div>
    </section>

    <!-- ░░ FREE TOOLS ░░ -->
    <section class="border-t border-b border-[#e7e5e4] bg-white py-10">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-6 flex items-center justify-between">
          <div>
            <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.12em] text-[#4f39f6]">Free SEO Tools</p>
            <h2 class="mt-1 font-sans text-[20px] font-bold text-[#111827]">Audit and optimize. Free</h2>
          </div>
          <a href="/tools/" class="font-mono text-[11px] font-semibold uppercase tracking-[0.08em] text-[#4f39f6] transition-opacity hover:opacity-70">
            View all →
          </a>
        </div>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
          {tools.map(tool => (
            <a
              href={tool.href}
              class="group flex flex-col items-center gap-2.5 rounded-xl border border-[#e7e5e4] bg-white p-4 text-center transition-all hover:border-[#c4b5fd] hover:shadow-sm"
            >
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#f5f3ff] transition-colors group-hover:bg-[#ede9fe]" set:html={tool.svg}></div>
              <span class="font-sans text-[12px] font-semibold leading-[1.3] text-[#292524] transition-colors group-hover:text-[#4f39f6]">{tool.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ░░ FOOTER CTA ░░ -->
    <section class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:56px 56px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.4) 0%, transparent 65%);"></div>
      <div class="container-x relative z-10 py-16 text-center">
        <h3 class="font-sans text-[26px] font-bold leading-[1.2] tracking-[-0.02em] text-white">
          Stop writing SEO content manually
        </h3>
        <p class="mx-auto mt-3 max-w-[420px] font-sans text-[15px] leading-[1.7] text-[#94a3b8]">
          30 blog articles, 30 GBP posts, and social media content. Published to your site every month. Automatically.
        </p>
        <a
          href="/demo/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 inline-flex h-[46px] items-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] px-8 font-mono text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-[#4f39f6]"
        >
          Start Your $1 Trial
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <p class="mt-3 font-mono text-[11px] tracking-[0.08em] text-[#4b5563]">$1 for 3 days · Cancel anytime</p>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
    const catBtns = document.querySelectorAll('.blog-cat-btn');
    const topicBtns = document.querySelectorAll('.topic-btn');
    const cards = document.querySelectorAll('.blog-card') as NodeListOf<HTMLElement>;
    const newsletterRow = document.querySelector('.newsletter-row') as HTMLElement | null;
    const noResults = document.getElementById('no-results');
    const clearBtn = document.getElementById('clear-search');

    let activeCategory = 'all';
    let searchQuery = '';

    function filterCards() {
      let visible = 0;
      cards.forEach((card) => {
        const matchesCat = activeCategory === 'all' || card.dataset.category === activeCategory;
        const text = (card.dataset.title ?? '') + ' ' + (card.dataset.desc ?? '');
        const matchesSearch = !searchQuery || text.includes(searchQuery);
        const show = matchesCat && matchesSearch;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (newsletterRow) newsletterRow.style.display = searchQuery ? 'none' : '';
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    function setActive(cat: string) {
      activeCategory = cat;
      catBtns.forEach((btn) => {
        const on = btn.getAttribute('data-category') === cat;
        btn.classList.toggle('bg-[#4f39f6]', on);
        btn.classList.toggle('text-white', on);
        btn.classList.toggle('border-[#4f39f6]', on);
        btn.classList.toggle('bg-white', !on);
        btn.classList.toggle('text-[#57534e]', !on);
        btn.classList.toggle('border-[#e7e5e4]', !on);
      });
      filterCards();
    }

    catBtns.forEach((btn) => btn.addEventListener('click', () => setActive(btn.getAttribute('data-category') || 'all')));

    topicBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        setActive(btn.getAttribute('data-topic') || 'all');
        document.getElementById('article-grid-top')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        searchQuery = searchInput.value.toLowerCase().trim();
        filterCards();
      });
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        searchQuery = '';
        filterCards();
      });
    }
  </script>
</BaseLayout>
