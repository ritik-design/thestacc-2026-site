---
const year = new Date().getFullYear();

const active = 'font-sans text-[13px] text-[#57534e] transition-colors hover:text-[#4f39f6]';
const activeSm = 'font-sans text-[13px] text-[#57534e] transition-colors hover:text-[#4f39f6]';
---

<footer class="border-t border-[#e7e5e4] bg-white">

  <!-- Mega footer top section -->
  <div class="border-b border-[#e7e5e4] px-6 py-10">
    <div class="mx-auto max-w-[1200px] grid grid-cols-2 gap-x-8 gap-y-8 md:grid-cols-4">

      <!-- Fonctionnalités -->
      <div>
        <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Fonctionnalités</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/fr/fonctionnalites/suivi-positions/" class={activeSm}>Suivi des positions</a>
          <a href="/fr/fonctionnalites/recherche-mots-cles/" class={activeSm}>Recherche de mots-clés</a>
          <a href="/fr/fonctionnalites/gestion-citations/" class={activeSm}>Gestion des citations</a>
          <a href="/fr/fonctionnalites/surveillance-avis/" class={activeSm}>Surveillance des avis</a>
          <a href="/fr/fonctionnalites/programmation-sociale/" class={activeSm}>Planification sociale</a>
          <a href="/fr/fonctionnalites/rapports-clients/" class={activeSm}>Rapports clients</a>
          <a href="/fr/fonctionnalites/rapports-multi-sites/" class={activeSm}>Rapports multi-sites</a>
          <a href="/fr/fonctionnalites/gestion-de-masse-des-sites/" class={activeSm}>Gestion multi-sites en masse</a>
          <a href="/fr/fonctionnalites/tableau-bord-marque-blanche/" class={activeSm}>Tableau de bord marque blanche</a>
        </div>
      </div>

      <!-- Solutions + Pour les agences -->
      <div>
        <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Solutions</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/fr/solutions/agences/" class={activeSm}>Agences</a>
          <a href="/fr/solutions/entreprises-multi-sites/" class={activeSm}>Entreprises multi-sites</a>
          <a href="/fr/solutions/franchises/" class={activeSm}>Franchises</a>
          <a href="/fr/solutions/petites-entreprises/" class={activeSm}>PME</a>
        </div>
        <p class="mt-5 font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Pour les agences</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/fr/seo-marque-blanche/" class={activeSm}>SEO marque blanche</a>
          <a href="/fr/seo-local-marque-blanche/" class={activeSm}>SEO local marque blanche</a>
          <a href="/fr/rapports-marque-blanche/" class={activeSm}>Rapports marque blanche</a>
          <a href="/fr/revendeur-seo/" class={activeSm}>Programme revendeur SEO</a>
        </div>
      </div>

      <!-- Logiciels SEO -->
      <div>
        <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Logiciels SEO</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/fr/logiciel-seo-local/" class={activeSm}>Logiciel SEO local</a>
          <a href="/fr/logiciel-seo/" class={activeSm}>Logiciel SEO</a>
          <a href="/fr/logiciel-seo-multi-sites/" class={activeSm}>Logiciel SEO multi-sites</a>
          <a href="/fr/logiciel-seo-franchise/" class={activeSm}>Logiciel SEO franchise</a>
          <a href="/fr/logiciel-suivi-positions/" class={activeSm}>Logiciel de suivi des positions</a>
          <a href="/fr/logiciel-automatisation-seo/" class={activeSm}>Logiciel d'automatisation SEO</a>
          <a href="/fr/logiciel-creation-citations/" class={activeSm}>Logiciel de création de citations</a>
          <a href="/fr/logiciel-gestion-avis/" class={activeSm}>Logiciel de gestion des avis</a>
          <a href="/fr/logiciel-google-business-profile/" class={activeSm}>Logiciel GBP</a>
          <a href="/fr/outil-automatisation-reseaux-sociaux/" class={activeSm}>Automatisation réseaux sociaux</a>
          <a href="/fr/classement-google-maps/" class={activeSm}>Classement Google Maps</a>
          <a href="/fr/automatisation-seo-local/" class={activeSm}>Automatisation SEO local</a>
        </div>
      </div>

      <!-- Intégrations + Cas d'utilisation -->
      <div>
        <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Intégrations</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/fr/integrations/google-business-profile/" class={activeSm}>Google Business Profile</a>
          <a href="/fr/integrations/facebook/" class={activeSm}>Facebook</a>
          <a href="/fr/integrations/instagram/" class={activeSm}>Instagram</a>
          <a href="/fr/integrations/wordpress/" class={activeSm}>WordPress</a>
          <a href="/fr/integrations/ghost/" class={activeSm}>Ghost</a>
          <a href="/fr/integrations/wix/" class={activeSm}>Wix</a>
          <a href="/fr/integrations/webflow/" class={activeSm}>Webflow</a>
        </div>
        <p class="mt-5 font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Cas d'utilisation</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/fr/seo-multi-sites/" class={activeSm}>SEO multi-sites</a>
          <a href="/fr/seo-franchise/" class={activeSm}>SEO franchise</a>
        </div>
      </div>

    </div>
  </div>

  <!-- Standard columns -->
  <div class="mx-auto max-w-[1200px] grid grid-cols-2 gap-x-8 gap-y-10 px-6 py-12 md:grid-cols-4">

    <!-- Modules -->
    <div>
      <p class="font-sans text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Modules</p>
      <div class="mt-4 flex flex-col gap-3">
        <a href="/fr/modules/seo-blog/" class={active}>Blog SEO</a>
        <a href="/fr/modules/seo-local/" class={active}>Référencement Local</a>
        <a href="/fr/modules/reseaux-sociaux/" class={active}>Réseaux Sociaux</a>
        <a href="/fr/tarifs/" class={active}>Tarifs</a>
        <a href="/fr/outils/" class={active}>Outils SEO gratuits</a>
      </div>
    </div>

    <!-- Ressources -->
    <div>
      <p class="font-sans text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Ressources</p>
      <div class="mt-4 flex flex-col gap-3">
        <a href="/fr/blog/" class={active}>Blog</a>
        <a href="/fr/meilleures-listes/" class={active}>Meilleures listes</a>
        <a href="/fr/glossaire/" class={active}>Glossaire SEO</a>
        <a href="/fr/avis/" class={active}>Avis</a>
        <a href="/fr/alternatives/" class={active}>Alternatives</a>
        <a href="/fr/documentation/" class={active}>Documentation</a>
      </div>
    </div>

    <!-- Entreprise -->
    <div>
      <p class="font-sans text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Entreprise</p>
      <div class="mt-4 flex flex-col gap-3">
        <a href="/fr/a-propos/" class={active}>À propos</a>
        <a href="/fr/contact/" class={active}>Contact</a>
        <a href="/fr/affilies/" class={active}>Programme d'affiliation</a>
        <a href="/fr/normes-editoriales/" class={active}>Standards éditoriaux</a>
        <a href="/fr/journal-modifications/" class={active}>Changelog</a>
      </div>
    </div>

    <!-- Mentions légales -->
    <div>
      <p class="font-sans text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Mentions légales</p>
      <div class="mt-4 flex flex-col gap-3">
        <a href="/fr/confidentialite/" class={active}>Politique de confidentialité</a>
        <a href="/fr/conditions-utilisation/" class={active}>Conditions générales d'utilisation</a>
        <a href="/fr/politique-cookies/" class={active}>Politique de cookies</a>
        <a href="/fr/traitement-donnees/" class={active}>Traitement des données</a>
        <a href="/fr/licences/" class={active}>Licences</a>
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[#e7e5e4] px-6 py-5">
    <div class="mx-auto flex max-w-[1200px] flex-col items-center justify-between gap-3 sm:flex-row">
      <a href="/fr/" class="flex items-center">
        <img src="/Logo_horizontal_light_cropped.webp" alt="theStacc" width="136" height="14" class="h-[14px] w-auto" style="filter: brightness(0) saturate(100%) invert(23%) sepia(96%) saturate(2700%) hue-rotate(240deg) brightness(95%) contrast(100%);" />
      </a>
      <div class="text-right">
        <p class="font-sans text-[13px] text-[#79716b]">&copy; {year} SOLARTREK VENTURES LLP. Tous droits réservés.</p>
        <p class="mt-1 font-sans text-[11px] text-[#a8a29e]">Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India</p>
      </div>
    </div>
  </div>

</footer>
