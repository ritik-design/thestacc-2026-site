---
const year = new Date().getFullYear();
const active = 'font-sans text-[13px] text-[#57534e] transition-colors hover:text-[#4f39f6]';
const activeSm = 'font-sans text-[13px] text-[#57534e] transition-colors hover:text-[#4f39f6]';
---

<footer class="border-t border-[#e7e5e4] bg-white">

  <!-- Mega footer top section -->
  <div class="border-b border-[#e7e5e4] px-6 py-10">
    <div class="mx-auto max-w-[1200px] grid grid-cols-2 gap-x-8 gap-y-8 md:grid-cols-4">

      <!-- Funktionen -->
      <div>
        <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Funktionen</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/de/funktionen/rank-tracking/" class={activeSm}>Rang-Verfolgung</a>
          <a href="/de/funktionen/keyword-recherche/" class={activeSm}>Keyword-Recherche</a>
          <a href="/de/funktionen/zitationsverwaltung/" class={activeSm}>Zitations-Management</a>
          <a href="/de/funktionen/bewertungsmonitoring/" class={activeSm}>Bewertungs-Monitoring</a>
          <a href="/de/funktionen/social-scheduling/" class={activeSm}>Social-Planung</a>
          <a href="/de/funktionen/kunden-berichte/" class={activeSm}>Kunden-Reporting</a>
          <a href="/de/funktionen/multi-standort-berichte/" class={activeSm}>Multi-Standort-Reporting</a>
          <a href="/de/funktionen/massenstandort-verwaltung/" class={activeSm}>Standort-Massenverwaltung</a>
          <a href="/de/funktionen/white-label-dashboard/" class={activeSm}>White-Label-Dashboard</a>
        </div>
      </div>

      <!-- Lösungen + Für Agenturen -->
      <div>
        <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Lösungen</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/de/loesungen/agenturen/" class={activeSm}>Agenturen</a>
          <a href="/de/loesungen/multi-standort-unternehmen/" class={activeSm}>Multi-Standort-Unternehmen</a>
          <a href="/de/loesungen/franchises/" class={activeSm}>Franchises</a>
          <a href="/de/loesungen/kleine-unternehmen/" class={activeSm}>Kleinunternehmen</a>
        </div>
        <p class="mt-5 font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Für Agenturen</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/de/white-label-seo/" class={activeSm}>White-Label SEO</a>
          <a href="/de/white-label-lokales-seo/" class={activeSm}>White-Label Local SEO</a>
          <a href="/de/white-label-berichte/" class={activeSm}>White-Label Reporting</a>
          <a href="/de/seo-reseller/" class={activeSm}>SEO-Reseller-Programm</a>
        </div>
      </div>

      <!-- SEO-Software -->
      <div>
        <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">SEO-Software</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/de/lokales-seo-software/" class={activeSm}>Lokale SEO-Software</a>
          <a href="/de/seo-software/" class={activeSm}>SEO-Software</a>
          <a href="/de/multi-standort-seo-software/" class={activeSm}>Multi-Standort-SEO-Software</a>
          <a href="/de/franchise-seo-software/" class={activeSm}>Franchise-SEO-Software</a>
          <a href="/de/rank-tracking-software/" class={activeSm}>Ranking-Tracking-Software</a>
          <a href="/de/seo-automatisierung-software/" class={activeSm}>SEO-Automatisierungs-Software</a>
          <a href="/de/zitationsaufbau-software/" class={activeSm}>Zitations-Aufbau-Software</a>
          <a href="/de/bewertungsmanagement-software/" class={activeSm}>Bewertungsmanagement-Software</a>
          <a href="/de/google-business-profile-software/" class={activeSm}>GBP-Software</a>
          <a href="/de/social-media-automatisierung/" class={activeSm}>Social-Media-Automatisierung</a>
          <a href="/de/google-maps-ranking/" class={activeSm}>Google Maps Ranking</a>
          <a href="/de/lokales-seo-automatisierung/" class={activeSm}>Lokale SEO-Automatisierung</a>
        </div>
      </div>

      <!-- Integrationen + Anwendungsfälle -->
      <div>
        <p class="font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Integrationen</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/de/integrationen/google-business-profile/" class={activeSm}>Google Business Profile</a>
          <a href="/de/integrationen/facebook/" class={activeSm}>Facebook</a>
          <a href="/de/integrationen/instagram/" class={activeSm}>Instagram</a>
          <a href="/de/integrationen/wordpress/" class={activeSm}>WordPress</a>
          <a href="/de/integrationen/ghost/" class={activeSm}>Ghost</a>
          <a href="/de/integrationen/wix/" class={activeSm}>Wix</a>
          <a href="/de/integrationen/webflow/" class={activeSm}>Webflow</a>
        </div>
        <p class="mt-5 font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Anwendungsfälle</p>
        <div class="mt-4 flex flex-col gap-2.5">
          <a href="/de/multi-standort-seo/" class={activeSm}>Multi-Standort-SEO</a>
          <a href="/de/franchise-seo/" class={activeSm}>Franchise-SEO</a>
        </div>
      </div>

    </div>
  </div>

  <!-- Standard columns -->
  <div class="mx-auto max-w-[1200px] grid grid-cols-2 gap-x-8 gap-y-10 px-6 py-12 md:grid-cols-4">

    <!-- Module -->
    <div>
      <p class="font-sans text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Module</p>
      <div class="mt-4 flex flex-col gap-3">
        <a href="/de/module/blog-seo/" class={active}>Blog SEO</a>
        <a href="/de/module/lokales-seo/" class={active}>Lokales SEO</a>
        <a href="/de/module/social-media/" class={active}>Social Media</a>
        <a href="/de/preise/" class={active}>Preise</a>
        <a href="/de/tools/" class={active}>Kostenlose SEO-Tools</a>
      </div>
    </div>

    <!-- Ressourcen -->
    <div>
      <p class="font-sans text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Ressourcen</p>
      <div class="mt-4 flex flex-col gap-3">
        <a href="/de/blog/" class={active}>Blog</a>
        <a href="/de/best/" class={active}>Bestenlisten</a>
        <a href="/de/glossar/" class={active}>SEO-Glossar</a>
        <a href="/de/bewertungen/" class={active}>Rezensionen</a>
        <a href="/de/alternativen/" class={active}>Alternativen</a>
        <a href="/de/dokumentation/" class={active}>Dokumentation</a>
      </div>
      <p class="mt-5 font-sans text-[12px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Blog in anderen Sprachen</p>
      <div class="mt-3 flex flex-col gap-2.5">
        <a href="/blog/" class={activeSm}>🇬🇧 English Blog</a>
        <a href="/es/blog/" class={activeSm}>🇪🇸 Español Blog</a>
        <a href="/fr/blog/" class={activeSm}>🇫🇷 Français Blog</a>
        <a href="/it/blog/" class={activeSm}>🇮🇹 Italiano Blog</a>
        <a href="/pt-br/blog/" class={activeSm}>🇧🇷 Português Blog</a>
      </div>
    </div>

    <!-- Unternehmen -->
    <div>
      <p class="font-sans text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Unternehmen</p>
      <div class="mt-4 flex flex-col gap-3">
        <a href="/de/ueber-uns/" class={active}>Über uns</a>
        <a href="/de/kontakt/" class={active}>Kontakt</a>
        <a href="/de/partner/" class={active}>Partnerprogramm</a>
        <a href="/de/redaktionelle-standards/" class={active}>Redaktionelle Standards</a>
        <a href="/de/changelog/" class={active}>Changelog</a>
      </div>
    </div>

    <!-- Rechtliches -->
    <div>
      <p class="font-sans text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">Rechtliches</p>
      <div class="mt-4 flex flex-col gap-3">
        <a href="/de/datenschutz/" class={active}>Datenschutzerklärung</a>
        <a href="/de/agb/" class={active}>Allgemeine Geschäftsbedingungen</a>
        <a href="/de/cookies/" class={active}>Cookie-Richtlinie</a>
        <a href="/de/datenverarbeitung/" class={active}>Datenverarbeitung</a>
        <a href="/de/lizenzen/" class={active}>Lizenzen</a>
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[#e7e5e4] px-6 py-5">
    <div class="mx-auto flex max-w-[1200px] flex-col items-center justify-between gap-3 sm:flex-row">
      <a href="/de/" class="flex items-center">
        <img src="/Logo_horizontal_light_cropped.webp" alt="theStacc" width="136" height="14" class="h-[14px] w-auto" style="filter: brightness(0) saturate(100%) invert(23%) sepia(96%) saturate(2700%) hue-rotate(240deg) brightness(95%) contrast(100%);" />
      </a>
      <div class="text-right">
        <p class="font-sans text-[13px] text-[#79716b]">&copy; {year} SOLARTREK VENTURES LLP. Alle Rechte vorbehalten.</p>
        <p class="mt-1 font-sans text-[11px] text-[#a8a29e]">Ground Floor, Flat No. 05, Vatika Infotech City, Bauhinia Street, Urbanwoods, Near GVK Toll Plaza, Thikariya Ajmer Road, Jaipur, Rajasthan – 302026, India</p>
      </div>
    </div>
  </div>

</footer>
