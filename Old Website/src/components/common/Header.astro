        </button>
        <div id="modules-panel" class="absolute left-0 top-full pt-1 z-50 invisible opacity-0 transition-all duration-150">
          <div class="w-[320px] overflow-hidden rounded-xl border border-[#e7e5e4] bg-white shadow-[0px_4px_16px_0px_rgba(0,0,0,0.08)]">
            <div class="px-4 py-2.5 border-b border-[#e7e5e4]">
              <p class="font-mono text-xs font-semibold uppercase tracking-[0.6px] text-[#79716b]">{isEs ? 'Módulos' : isPtBr ? 'Módulos' : isDe ? 'Module' : isIt ? 'Moduli' : 'Modules'}</p>
            </div>
            <div class="p-2 space-y-0.5">
              <a href={isEs ? '/es/modulos/seo-blog/' : isPtBr ? '/pt-br/modulos/seo-blog/' : isDe ? '/de/module/blog-seo/' : isIt ? '/it/moduli/seo-blog/' : '/modules/content-seo/'} class="flex items-center gap-3 rounded-lg px-3 py-3 hover:bg-[#fafaf9] transition-colors">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#f5f5f4]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <div class="min-w-0">
                  <p class="font-sans text-[14px] font-semibold text-[#292524] leading-none">Blog SEO</p>
                  <p class="mt-1 font-sans text-sm text-[#57534e] leading-none truncate">{isEs ? 'Artículos publicados diariamente con IA' : isPtBr ? 'Artigos publicados diariamente com IA' : isDe ? 'KI-Blogartikel täglich veröffentlicht' : isIt ? 'Articoli pubblicati giornalmente con IA' : 'AI generated blogs published daily'}</p>
                </div>
              </a>
              <a href={isEs ? '/es/modulos/seo-local/' : isPtBr ? '/pt-br/modulos/seo-local/' : isDe ? '/de/module/lokales-seo/' : isIt ? '/it/moduli/seo-locale/' : '/modules/local-seo/'} class="flex items-center gap-3 rounded-lg px-3 py-3 hover:bg-[#fafaf9] transition-colors">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#f5f5f4]">
