---
import StaccLogo from './StaccLogo.astro';
import { buildHreflangAlternates, getLangFromPath } from '../../utils/hreflang';

const pathname = Astro.url.pathname;
const lang = getLangFromPath(pathname);
const isEs = lang === 'es';
const isPtBr = lang === 'pt-BR';
const isDe = lang === 'de';
const isIt = lang === 'it';
const hreflangAlts = buildHreflangAlternates(pathname);
const langLinks = hreflangAlts.filter(a => a.lang !== 'x-default');
const hasLangSwitch = langLinks.length > 1;
const langMeta: Record<string, { flag: string; name: string; code: string }> = {
  'en':    { flag: '🇬🇧', name: 'English',    code: 'EN' },
  'de':    { flag: '🇩🇪', name: 'Deutsch',    code: 'DE' },
  'fr':    { flag: '🇫🇷', name: 'Français',   code: 'FR' },
  'es':    { flag: '🇪🇸', name: 'Español',    code: 'ES' },
  'pt-BR': { flag: '🇧🇷', name: 'Português',  code: 'PT' },
  'it':    { flag: '🇮🇹', name: 'Italiano',   code: 'IT' },
};
const currentMeta = langMeta[lang] || { flag: '🌐', name: lang.toUpperCase(), code: lang.toUpperCase() };

// Localized resource URLs per language
const resUrls: Record<string, Record<string, string>> = {
  blog:        { en: '/blog/',        de: '/de/blog/',        es: '/es/blog/',        it: '/it/blog/',        fr: '/fr/blog/',        'pt-BR': '/pt-br/blog/' },
  tools:       { en: '/tools/',       de: '/de/tools/',       es: '/es/herramientas/', it: '/it/strumenti/',  fr: '/fr/outils/',     'pt-BR': '/pt-br/ferramentas/' },
  glossary:    { en: '/glossary/',    de: '/de/glossar/',     es: '/es/glosario/',    it: '/it/glossario/',   fr: '/fr/glossaire/',  'pt-BR': '/pt-br/glossario/' },
  best:        { en: '/best/',        de: '/de/best/',        es: '/es/mejor/',       it: '/it/migliori/',    fr: '/fr/meilleures-listes/', 'pt-BR': '/pt-br/melhores/' },
  reviews:     { en: '/reviews/',     de: '/de/bewertungen/', es: '/es/resenas/',     it: '/it/recensioni/',  fr: '/fr/avis/',       'pt-BR': '/pt-br/avaliacoes/' },
  alternatives:{ en: '/alternatives/',de: '/de/alternativen/',es: '/es/alternativas/',it: '/it/alternative/', fr: '/fr/alternatives/','pt-BR': '/pt-br/alternativas/' },
  for:         { en: '/for/',         de: '',                 es: '/es/para/',        it: '/it/per/',         fr: '/fr/pour/',       'pt-BR': '/pt-br/para/' },
  docs:        { en: '/docs/',        de: '/de/dokumentation/',es:'/docs/',           it: '/it/documentazione/',fr:'/documentation/','pt-BR': '/docs/' },
};
const r = (key: string) => resUrls[key]?.[lang] || resUrls[key]?.en || '';
const hasPage = (key: string) => !!r(key);

const blogLangs = [
  { code: 'en',    flag: '🇬🇧', name: 'English',    url: '/blog/' },
  { code: 'de',    flag: '🇩🇪', name: 'Deutsch',    url: '/de/blog/' },
  { code: 'es',    flag: '🇪🇸', name: 'Español',    url: '/es/blog/' },
  { code: 'it',    flag: '🇮🇹', name: 'Italiano',   url: '/it/blog/' },
  { code: 'fr',    flag: '🇫🇷', name: 'Français',   url: '/fr/blog/' },
  { code: 'pt-BR', flag: '🇧🇷', name: 'Português',  url: '/pt-br/blog/' },
];
const otherBlogs = blogLangs.filter(b => b.code !== lang);
---

<header id="site-header" class="sticky top-0 z-50 transition-all duration-300 bg-white/90 backdrop-blur-md">
  <div class="flex h-16 items-center justify-between px-6">

    <!-- Logo -->
    <a href={isEs ? '/es/' : isPtBr ? '/pt-br/' : isDe ? '/de/' : isIt ? '/it/' : '/'} class="cursor-pointer flex items-center shrink-0">
      <img src="/Logo_horizontal_light_cropped.webp" alt="theStacc" width="136" height="14" class="h-[14px] w-auto" style="filter: brightness(0) saturate(100%) invert(23%) sepia(96%) saturate(2700%) hue-rotate(240deg) brightness(95%) contrast(100%);" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-0.5">

      <!-- Modules dropdown -->
      <div class="relative" id="modules-nav">
        <button
          id="modules-btn"
          class="cursor-pointer flex items-center gap-1.5 rounded-lg px-3 py-2 font-sans text-[13px] font-medium transition-colors text-stone-700 hover:text-stone-900"
        >
          {isEs ? 'Módulos' : isPtBr ? 'Módulos' : isDe ? 'Module' : isIt ? 'Moduli' : 'Modules'}
