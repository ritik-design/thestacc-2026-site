                    <a href={isDe ? '' : '/features/bulk-location-management/'} data-nav-link={isDe ? '' : '/features/bulk-location-management'} class={isDe ? 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 opacity-40 cursor-not-allowed pointer-events-none' : 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 hover:bg-[#fafaf9] transition-colors'}>
                      <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-[#f5f5f4]">
