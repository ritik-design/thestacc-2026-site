                </div>
                <div class="min-w-0">
                  <p class="font-sans text-[14px] font-semibold text-[#292524] leading-none">{isEs ? 'SEO Local' : isPtBr ? 'SEO Local' : isDe ? 'Lokales SEO' : isIt ? 'SEO Locale' : 'Local SEO'}</p>
                  <p class="mt-1 font-sans text-sm text-[#57534e] leading-none truncate">{isEs ? 'Domina las búsquedas "cerca de mí"' : isPtBr ? 'Domine as buscas "perto de mim"' : isDe ? '"In meiner Nähe"-Suchen dominieren' : isIt ? 'Domina le ricerche "vicino a me"' : 'Dominate near me searches'}</p>
                </div>
              </a>
              <a href={isEs ? '/es/modulos/redes-sociales/' : isPtBr ? '/pt-br/modulos/redes-sociais/' : isDe ? '/de/module/social-media/' : isIt ? '/it/moduli/social-media/' : '/modules/social-media/'} class="flex items-center gap-3 rounded-lg px-3 py-3 hover:bg-[#fafaf9] transition-colors">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-[#f5f5f4]">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                </div>
                <div class="min-w-0">
                  <p class="font-sans text-[14px] font-semibold text-[#292524] leading-none">Social Media</p>
                  <p class="mt-1 font-sans text-sm text-[#57534e] leading-none truncate">{isEs ? 'Posts con IA en todas las plataformas' : isPtBr ? 'Posts com IA em todas as plataformas' : isDe ? 'KI-Posts auf allen Plattformen' : isIt ? 'Post IA su tutte le piattaforme' : 'AI posts across every platform'}</p>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Features mega menu (English + German) -->
