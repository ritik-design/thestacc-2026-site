                      </div>
                    </a>

                    <a href={isDe ? '' : '/features/keyword-research/'} data-nav-link={isDe ? '' : '/features/keyword-research'} class={isDe ? 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 opacity-40 cursor-not-allowed pointer-events-none' : 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 hover:bg-[#fafaf9] transition-colors'}>
                      <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-[#f5f5f4]">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                      </div>
                      <div>
                        <p class="font-sans text-[13px] font-semibold text-[#292524] leading-tight">{isDe ? 'Keyword-Recherche' : 'Keyword Research'}</p>
                        <p class="font-sans text-[11px] text-[#79716b] leading-snug">{isDe ? 'Lücken finden, die Konkurrenten verpassen' : 'Find gaps competitors miss'}</p>
                      </div>
                    </a>

                    <a href={isDe ? '' : '/features/citation-management/'} data-nav-link={isDe ? '' : '/features/citation-management'} class={isDe ? 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 opacity-40 cursor-not-allowed pointer-events-none' : 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 hover:bg-[#fafaf9] transition-colors'}>
                      <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-[#f5f5f4]">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
