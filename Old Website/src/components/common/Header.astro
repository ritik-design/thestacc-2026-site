                    <a href={isDe ? '' : '/features/review-monitoring/'} data-nav-link={isDe ? '' : '/features/review-monitoring'} class={isDe ? 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 opacity-40 cursor-not-allowed pointer-events-none' : 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 hover:bg-[#fafaf9] transition-colors'}>
                      <div class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-[#f5f5f4]">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      </div>
                      <div>
                        <p class="font-sans text-[13px] font-semibold text-[#292524] leading-tight">{isDe ? 'Bewertungs-Monitoring' : 'Review Monitoring'}</p>
