                        <p class="font-sans text-[11px] text-[#79716b] leading-snug">{isDe ? 'PDF- und CSV-Exporte mit Branding' : 'Branded PDF + CSV exports'}</p>
                      </div>
                    </a>

                    <a href={isDe ? '' : '/features/multi-location-reporting/'} data-nav-link={isDe ? '' : '/features/multi-location-reporting'} class={isDe ? 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 opacity-40 cursor-not-allowed pointer-events-none' : 'flex items-start gap-2.5 rounded-lg px-2.5 py-2.5 hover:bg-[#fafaf9] transition-colors'}>
