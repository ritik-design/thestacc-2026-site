---
/**
 * ExitIntent — Email capture modal triggered when cursor leaves viewport
 * Shows once per session. Dismissed state stored in sessionStorage.
 * Captures email for lead nurture pipeline.
 */
---

<!-- Exit Intent Modal -->
<div id="exit-intent-overlay" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/50 backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Get free SEO audit">
  <div class="relative mx-4 w-full max-w-[460px] rounded-[16px] bg-white p-8 shadow-2xl">
    <!-- Close -->
    <button id="exit-intent-close" class="absolute right-4 top-4 text-[#79716b] hover:text-[#57534e] transition-colors cursor-pointer" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <!-- Content -->
    <div class="text-center">
      <span class="inline-flex items-center rounded-full border border-[#bbf7d0] bg-[#f0fdf4] px-3 py-1 font-mono text-[11px] font-semibold uppercase text-[#16a34a]">
        Free — No signup required
      </span>

      <h3 class="mt-4 font-sans text-[22px] font-bold leading-[28px] text-[#292524]">
        Get your free SEO score before you go
      </h3>

      <p class="mt-2 font-sans text-[15px] leading-[22px] text-[#79716b]">
        Enter your website and we will send you a full SEO audit with actionable fixes — completely free.
      </p>

      <!-- Form -->
      <form id="exit-intent-form" class="mt-6 flex flex-col gap-3">
        <input
          type="url"
          name="website"
          placeholder="https://yourwebsite.com"
          required
          class="h-[44px] w-full rounded-[10px] border border-[#e7e5e4] bg-[#fafaf9] px-4 font-sans text-[14px] text-[#292524] placeholder:text-[#79716b] outline-none focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/20 transition-all"
        />
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="h-[44px] w-full rounded-[10px] border border-[#e7e5e4] bg-[#fafaf9] px-4 font-sans text-[14px] text-[#292524] placeholder:text-[#79716b] outline-none focus:border-[#4f39f6] focus:ring-2 focus:ring-[#4f39f6]/20 transition-all"
        />
        <button
          type="submit"
          class="h-[44px] w-full rounded-[10px] bg-[#615fff] font-mono text-[13px] font-semibold uppercase tracking-wide text-white transition-colors hover:bg-[#4f39f6] cursor-pointer"
        >
          Send My Free Audit
        </button>
      </form>

      <p class="mt-3 font-sans text-[12px] text-[#79716b]">
        No spam. Just your SEO score and how to fix it.
      </p>
    </div>

    <!-- Success state (hidden by default) -->
    <div id="exit-intent-success" class="hidden text-center py-4">
      <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-[#f0fdf4]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h3 class="font-sans text-[20px] font-bold text-[#292524]">Check your inbox</h3>
      <p class="mt-2 font-sans text-[15px] text-[#79716b]">Your free SEO audit is on its way.</p>
    </div>
  </div>
</div>

<script>
  (function () {
    const STORAGE_KEY = 'stacc_exit_shown';

    // Don't show if already shown this session
    if (sessionStorage.getItem(STORAGE_KEY)) return;

    const overlay = document.getElementById('exit-intent-overlay');
    const closeBtn = document.getElementById('exit-intent-close');
    const form = document.getElementById('exit-intent-form') as HTMLFormElement | null;
    const success = document.getElementById('exit-intent-success');

    if (!overlay) return;

    let triggered = false;

    function showModal() {
      if (triggered) return;
      triggered = true;
      sessionStorage.setItem(STORAGE_KEY, '1');
      overlay!.classList.remove('hidden');
      overlay!.classList.add('flex');
    }

    function hideModal() {
      overlay!.classList.add('hidden');
      overlay!.classList.remove('flex');
    }

    // Trigger on mouse leave (desktop)
    document.addEventListener('mouseout', (e) => {
      if (e.clientY <= 0 && !triggered) {
        // Wait 2 seconds after page load minimum
        if (performance.now() > 5000) {
          showModal();
        }
      }
    });

    // Close handlers
    closeBtn?.addEventListener('click', hideModal);
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) hideModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') hideModal();
    });

    function showSuccess() {
      form!.classList.add('hidden');
      form!.previousElementSibling?.classList.add('hidden');
      const badge = form!.parentElement?.querySelector('span');
      if (badge) badge.classList.add('hidden');
      const h3 = form!.parentElement?.querySelector('h3');
      if (h3) h3.classList.add('hidden');
      const note = form!.nextElementSibling;
      if (note) (note as HTMLElement).classList.add('hidden');
      success?.classList.remove('hidden');
    }

    // Form submit
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form!);
      const website = data.get('website') as string;
      const email = data.get('email') as string;

      // Fire analytics
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'exit_intent_capture', { website, email });
      }

      // Send to CRM (best-effort — show success regardless)
      fetch('/api/exit-intent/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, website }),
      }).catch(() => { /* silent */ });

      showSuccess();
    });
  })();
</script>
