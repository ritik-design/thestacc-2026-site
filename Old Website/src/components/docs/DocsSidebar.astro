---
import { docsCategories } from '../../data/docs';

interface Props {
  currentCategorySlug?: string;
  currentPageSlug?: string;
}

const { currentCategorySlug, currentPageSlug } = Astro.props;
---

<!-- Mobile sidebar toggle -->
<button
  id="docs-sidebar-toggle"
  class="fixed bottom-5 right-5 z-50 flex h-12 w-12 items-center justify-center rounded-full border border-[#e7e5e4] bg-white shadow-lg lg:hidden"
  aria-label="Toggle docs navigation"
>
  <svg id="docs-sidebar-open-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M3 12h18"/><path d="M3 6h18"/><path d="M3 18h18"/>
  </svg>
  <svg id="docs-sidebar-close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
  </svg>
</button>

<!-- Backdrop -->
<div id="docs-sidebar-backdrop" class="fixed inset-0 z-40 bg-black/20 hidden lg:hidden"></div>

<!-- Sidebar -->
<aside
  id="docs-sidebar"
  class="docs-sidebar fixed left-0 top-14 z-40 h-[calc(100vh-56px)] w-[280px] -translate-x-full border-r border-[#e7e5e4] bg-white transition-transform duration-200 lg:translate-x-0 lg:w-[256px] overflow-y-auto scrollbar-thin"
>
  <div class="px-2.5 py-4">
    <!-- Category sections -->
    <nav class="space-y-4">
      {docsCategories.map((category) => {
        const isExpanded = true;
        return (
          <div class="docs-nav-section" data-section={category.slug}>
            <button
              class="docs-nav-section-btn flex w-full items-center justify-between px-2 py-2 text-left font-mono text-[12px] font-semibold uppercase tracking-[0.5px] text-[#79716b] transition-colors hover:text-[#292524]"
              data-expanded={isExpanded ? 'true' : 'false'}
            >
              {category.name}
              <svg class="docs-nav-chevron h-3 w-3 text-[#79716b] transition-transform duration-150" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <div class={`docs-nav-items mt-0.5 space-y-0.5 ${isExpanded ? '' : 'hidden'}`}>
              {category.items.map((page) => {
                const isActive = currentCategorySlug === category.slug && currentPageSlug === page.slug;
                return (
                  <a
                    href={`/docs/${category.slug}/${page.slug}`}
                    class={`block rounded-lg py-1.5 pl-4 pr-2 font-sans text-[14px] transition-colors ${
                      isActive
                        ? 'bg-[#eef2ff] font-medium text-[#4f39f6]'
                        : 'text-[#57534e] hover:bg-[#fafaf9] hover:text-[#292524]'
                    }`}
                  >
                    {page.title}
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </nav>
  </div>
</aside>

<script>
  const STORAGE_KEY = 'docs-sidebar-state';

  // Load saved state from localStorage
  function getSavedState(): Record<string, boolean> {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      return saved ? JSON.parse(saved) : {};
    } catch {
      return {};
    }
  }

  function saveState(slug: string, expanded: boolean) {
    const state = getSavedState();
    state[slug] = expanded;
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    } catch {}
  }

  const savedState = getSavedState();

  // Apply saved state on load, then wire up toggles
  document.querySelectorAll('.docs-nav-section').forEach((section) => {
    const slug = (section as HTMLElement).dataset.section;
    const btn = section.querySelector('.docs-nav-section-btn');
    const items = section.querySelector('.docs-nav-items');
    const chevron = btn?.querySelector('.docs-nav-chevron');
    if (!slug || !btn || !items || !chevron) return;

    // If user previously collapsed this section, apply it
    if (slug in savedState && !savedState[slug]) {
      items.classList.add('hidden');
      chevron.classList.add('-rotate-90');
      btn.setAttribute('data-expanded', 'false');
    }

    btn.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('data-expanded') === 'true';
      if (isExpanded) {
        items.classList.add('hidden');
        chevron.classList.add('-rotate-90');
        btn.setAttribute('data-expanded', 'false');
        saveState(slug, false);
      } else {
        items.classList.remove('hidden');
        chevron.classList.remove('-rotate-90');
        btn.setAttribute('data-expanded', 'true');
        saveState(slug, true);
      }
    });
  });

  // Mobile sidebar toggle
  const toggle = document.getElementById('docs-sidebar-toggle');
  const sidebar = document.getElementById('docs-sidebar');
  const backdrop = document.getElementById('docs-sidebar-backdrop');
  const openIcon = document.getElementById('docs-sidebar-open-icon');
  const closeIcon = document.getElementById('docs-sidebar-close-icon');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    sidebar?.classList.add('translate-x-0');
    backdrop?.classList.remove('hidden');
    openIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
  }

  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    sidebar?.classList.remove('translate-x-0');
    backdrop?.classList.add('hidden');
    openIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = !sidebar?.classList.contains('-translate-x-full');
    if (isOpen) closeSidebar();
    else openSidebar();
  });

  backdrop?.addEventListener('click', closeSidebar);
</script>
