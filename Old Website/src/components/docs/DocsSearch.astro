---
import { docsCategories } from '../../data/docs';

// Build search index at build time
const searchIndex = docsCategories.flatMap((category) =>
  category.items.map((page) => ({
    title: page.title,
    description: page.description,
    category: category.name,
    href: `/docs/${category.slug}/${page.slug}`,
    popular: !!page.popular,
    // Strip markdown for plain text search (original case kept so result
    // snippets read naturally). Code fences and raw HTML tags are removed so
    // embedded <h1>/<h2>/etc. in code examples aren't treated as headings.
    text: page.content
      .replace(/```[\s\S]*?```/g, '')
      .replace(/^#{1,3}\s+/gm, '')
      .replace(/\*\*(.+?)\*\*/g, '$1')
      .replace(/`([^`]+)`/g, '$1')
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
      .replace(/<\/?[a-zA-Z][^>]*>/g, '')
      .replace(/^- /gm, '')
      .replace(/^\d+\.\s/gm, '')
      .replace(/^> /gm, '')
      .replace(/\s+/g, ' ')
      .trim(),
  }))
);
---

<!-- Search Modal -->
<div id="docs-search-modal" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="docs-search-backdrop" class="absolute inset-0 bg-[#1c1917]/40 backdrop-blur-[2px]"></div>

  <!-- Dialog -->
  <div class="relative mx-auto mt-[12vh] w-full max-w-[600px] px-4">
    <div class="overflow-hidden rounded-2xl border border-[#e7e5e4] bg-white shadow-[0px_24px_80px_rgba(28,25,23,0.18)]">
      <!-- Input -->
      <div class="flex items-center gap-3 border-b border-[#e7e5e4] px-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#79716b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input
          id="docs-search-input"
          type="text"
          placeholder="Search documentation..."
          autocomplete="off"
          spellcheck="false"
          class="flex-1 border-0 bg-transparent py-4 font-sans text-[16px] text-[#292524] outline-none placeholder:text-[#a8a29e]"
        />
        <kbd class="hidden shrink-0 rounded-md border border-[#e7e5e4] bg-[#fafaf9] px-1.5 py-0.5 font-mono text-[11px] text-[#79716b] sm:inline-block">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="docs-search-results" class="max-h-[58vh] overflow-y-auto scrollbar-thin p-2"></div>

      <!-- Footer with keyboard hints -->
      <div class="flex items-center gap-4 border-t border-[#e7e5e4] bg-[#fafaf9] px-4 py-2.5">
        <span class="flex items-center gap-1.5 font-sans text-[11px] text-[#79716b]">
          <kbd class="inline-flex h-[18px] min-w-[18px] items-center justify-center rounded border border-[#e7e5e4] bg-white px-1 font-mono text-[10px]">↑</kbd>
          <kbd class="inline-flex h-[18px] min-w-[18px] items-center justify-center rounded border border-[#e7e5e4] bg-white px-1 font-mono text-[10px]">↓</kbd>
          to navigate
        </span>
        <span class="flex items-center gap-1.5 font-sans text-[11px] text-[#79716b]">
          <kbd class="inline-flex h-[18px] min-w-[18px] items-center justify-center rounded border border-[#e7e5e4] bg-white px-1 font-mono text-[10px]">↵</kbd>
          to select
        </span>
        <span class="ml-auto flex items-center gap-1.5 font-sans text-[11px] text-[#79716b]">
          <kbd class="inline-flex h-[18px] items-center justify-center rounded border border-[#e7e5e4] bg-white px-1 font-mono text-[10px]">esc</kbd>
          to close
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Inject search data -->
<script is:inline define:vars={{ searchIndex }}>
  window.__docsSearchIndex = searchIndex;
</script>

<script>
  type Doc = {
    title: string;
    description: string;
    category: string;
    href: string;
    popular: boolean;
    text: string;
  };

  const modal = document.getElementById('docs-search-modal');
  const backdrop = document.getElementById('docs-search-backdrop');
  const input = document.getElementById('docs-search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('docs-search-results');
  const searchBtn = document.getElementById('docs-search-btn');

  const searchIndex = ((window as any).__docsSearchIndex as Doc[]) || [];
  const popularDocs = searchIndex.filter((d) => d.popular).slice(0, 5);

  // Currently selectable result anchors + active pointer.
  let resultLinks: HTMLAnchorElement[] = [];
  let activeIndex = 0;

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function escapeRegExp(s: string): string {
    return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  // Wrap query matches in <mark> on already-escaped text.
  function highlight(text: string, query: string): string {
    const escaped = escapeHtml(text);
    if (!query.trim()) return escaped;
    const re = new RegExp(`(${escapeRegExp(query.trim())})`, 'ig');
    return escaped.replace(re, '<mark class="docs-search-mark">$1</mark>');
  }

  // Pull a short body snippet centered on the first query match.
  function snippet(text: string, query: string): string {
    const q = query.trim().toLowerCase();
    const lower = text.toLowerCase();
    const idx = lower.indexOf(q);
    if (idx === -1) return '';
    const start = Math.max(0, idx - 40);
    const end = Math.min(text.length, idx + q.length + 80);
    let slice = text.slice(start, end).trim();
    if (start > 0) slice = '…' + slice;
    if (end < text.length) slice = slice + '…';
    return slice;
  }

  function openSearch() {
    if (!modal) return;
    modal.classList.remove('hidden');
    input?.focus();
    document.body.style.overflow = 'hidden';
    render('');
  }

  function closeSearch() {
    if (!modal) return;
    modal.classList.add('hidden');
    if (input) input.value = '';
    document.body.style.overflow = '';
  }

  function resultRowHTML(doc: Doc, query: string): string {
    const snip = query.trim() ? snippet(doc.text, query) : '';
    const desc = snip || doc.description;
    return (
      `<span class="docs-search-result-cat">${escapeHtml(doc.category)}</span>` +
      `<span class="docs-search-result-title">${highlight(doc.title, query)}</span>` +
      `<span class="docs-search-result-desc">${query.trim() && snip ? highlight(desc, query) : escapeHtml(desc)}</span>`
    );
  }

  function buildRows(docs: Doc[], query: string, headerLabel?: string) {
    if (!resultsContainer) return;
    if (headerLabel) {
      const h = document.createElement('p');
      h.className = 'docs-search-group-label';
      h.textContent = headerLabel;
      resultsContainer.appendChild(h);
    }
    docs.forEach((doc) => {
      const a = document.createElement('a');
      a.href = doc.href;
      a.className = 'docs-search-result';
      a.innerHTML = resultRowHTML(doc, query) +
        `<svg class="docs-search-result-arrow" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>`;
      resultsContainer.appendChild(a);
    });
  }

  function render(query: string) {
    if (!resultsContainer) return;
    resultsContainer.innerHTML = '';
    const q = query.trim().toLowerCase();

    // Default state — show popular pages.
    if (!q) {
      buildRows(popularDocs, '', 'Popular');
      refreshLinks();
      return;
    }

    const matches = searchIndex.filter(
      (doc) =>
        doc.title.toLowerCase().includes(q) ||
        doc.description.toLowerCase().includes(q) ||
        doc.text.toLowerCase().includes(q)
    );

    if (matches.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'docs-search-empty';
      empty.innerHTML =
        `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#a8a29e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>` +
        `<p>No results for “<strong>${escapeHtml(query.trim())}</strong>”</p>` +
        `<span>Try a different term or browse the sidebar.</span>`;
      resultsContainer.appendChild(empty);
      refreshLinks();
      return;
    }

    // Group by category, preserving sidebar order.
    const order: string[] = [];
    const byCat = new Map<string, Doc[]>();
    for (const doc of matches) {
      if (!byCat.has(doc.category)) {
        byCat.set(doc.category, []);
        order.push(doc.category);
      }
      byCat.get(doc.category)!.push(doc);
    }

    const countLine = document.createElement('p');
    countLine.className = 'docs-search-count';
    countLine.textContent = `${matches.length} result${matches.length === 1 ? '' : 's'}`;
    resultsContainer.appendChild(countLine);

    for (const cat of order) {
      buildRows(byCat.get(cat)!, query, cat);
    }
    refreshLinks();
  }

  function refreshLinks() {
    resultLinks = Array.from(
      resultsContainer?.querySelectorAll('.docs-search-result') ?? []
    ) as HTMLAnchorElement[];
    activeIndex = 0;
    applyActive();
    resultLinks.forEach((link, i) => {
      link.addEventListener('mousemove', () => {
        if (activeIndex !== i) {
          activeIndex = i;
          applyActive();
        }
      });
    });
  }

  function applyActive() {
    resultLinks.forEach((link, i) => {
      if (i === activeIndex) {
        link.classList.add('is-active');
        link.scrollIntoView({ block: 'nearest' });
      } else {
        link.classList.remove('is-active');
      }
    });
  }

  // Event listeners
  searchBtn?.addEventListener('click', openSearch);
  backdrop?.addEventListener('click', closeSearch);
  input?.addEventListener('input', () => render(input.value));

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (modal?.classList.contains('hidden')) openSearch();
      else closeSearch();
      return;
    }

    if (modal?.classList.contains('hidden')) return;

    if (e.key === 'Escape') {
      closeSearch();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (resultLinks.length) {
        activeIndex = Math.min(activeIndex + 1, resultLinks.length - 1);
        applyActive();
      }
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (resultLinks.length) {
        activeIndex = Math.max(activeIndex - 1, 0);
        applyActive();
      }
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const link = resultLinks[activeIndex];
      if (link) {
        closeSearch();
        window.location.href = link.href;
      }
    }
  });
</script>
