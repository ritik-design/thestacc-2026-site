---
import { Icon } from 'astro-icon/components';

const reasons = [
  {
    title: "LOCAL SEO INCLUDED",
    description: "Outrank only does blog content. theStacc also handles Google Business Profile, reviews, and city-specific pages.",
    icon: "ph:map-pin",
  },
  {
    title: "BETTER VALUE",
    description: "Comparable blog pricing, plus a full Local SEO module starting at $49/mo. Bundle both and save 10%.",
    icon: "ph:coins",
  },
  {
    title: "RELIABLE SUPPORT",
    description: "Real support from our product team. No 5-day email waits, no broken in-app chat.",
    icon: "ph:headset",
  },
];

const comparisonSections = [
  {
    title: "Content & Publishing",
    rows: [
      { label: "AI blog article generation", stacc: true, outrank: true },
      { label: "SEO keyword research", stacc: true, outrank: true },
      { label: "Auto-publish to CMS", stacc: true, outrank: true },
      { label: "WordPress integration", stacc: true, outrank: true },
      { label: "Webflow integration", stacc: true, outrank: true },
      { label: "Shopify integration", stacc: false, outrank: true },
      { label: "Daily drip publishing", stacc: true, outrank: true },
      { label: "Content calendar", stacc: true, outrank: true },
      { label: "SEO score per article", stacc: "92 avg", outrank: "Not shown" },
      { label: "Custom brand voice & tone", stacc: true, outrank: false },
      { label: "Competitor content analysis", stacc: true, outrank: true },
      { label: "AI-generated infographics", stacc: true, outrank: "Low quality" },
    ],
  },
  {
    title: "Local SEO",
    rows: [
      { label: "Google Business Profile optimization", stacc: true, outrank: false },
      { label: "GBP posting (daily)", stacc: true, outrank: false },
      { label: "Review monitoring & AI response", stacc: true, outrank: false },
      { label: "Local keyword tracking", stacc: true, outrank: false },
      { label: "City-specific landing pages", stacc: true, outrank: false },
      { label: "Multi-location support", stacc: true, outrank: false },
      { label: "Local citation building", stacc: true, outrank: false },
    ],
  },
  {
    title: "Platform & Pricing",
    rows: [
      { label: "Starting price (blog)", stacc: "$99/mo", outrank: "$99/mo" },
      { label: "Local SEO module", stacc: "From $49/mo", outrank: "Not available" },
      { label: "Bundle discount", stacc: "10% off", outrank: "N/A" },
      { label: "Annual discount", stacc: "17%", outrank: "Unspecified" },
      { label: "Trial", stacc: "$1 for 3 days", outrank: "7-day free" },
      { label: "Approval workflow", stacc: true, outrank: false },
      { label: "Backlink exchange network", stacc: false, outrank: true },
      { label: "Multi-language (150+)", stacc: false, outrank: true },
      { label: "Priority support", stacc: true, outrank: "Slow (4-5 days)" },
    ],
  },
];

const faqs = [
  {
    q: "How is theStacc different from Outrank.so?",
    a: "Both platforms generate AI blog content and auto-publish to your CMS. The key difference is that theStacc also offers a full Local SEO module — including Google Business Profile optimization, review monitoring, AI review responses, local keyword tracking, and city-specific landing pages. Outrank is blog-only. If your business depends on local customers, theStacc covers both channels.",
  },
  {
    q: "Is theStacc a replacement for Outrank.so?",
    a: "Yes. theStacc handles everything Outrank does for blog SEO — keyword research, AI content generation, SEO scoring, and auto-publishing — plus an entire Local SEO module that Outrank doesn't offer. The only feature Outrank has that theStacc doesn't is a backlink exchange network.",
  },
  {
    q: "How does pricing compare?",
    a: "Both start at $99/mo for 30 blog articles. theStacc also offers Local SEO from $49/mo, a 10% bundle discount when you combine both modules, and a 17% annual discount. Outrank offers multi-site discounts for agencies managing multiple domains.",
  },
  {
    q: "Does Outrank.so offer Local SEO?",
    a: "No. Outrank.so is purely focused on blog content generation. It does not offer Google Business Profile management, review monitoring, local keyword tracking, city-specific pages, or any local search features.",
  },
  {
    q: "What about content quality?",
    a: "Outrank.so articles are widely reviewed as needing 20-45 minutes of editing per post. theStacc generates content with an average SEO score of 92/100, includes custom brand voice settings, and offers an approval workflow so you can review every post before it goes live.",
  },
  {
    q: "Does Outrank have better support?",
    a: "Outrank's support is a commonly cited weakness in reviews — users report 4-5 day email response times, broken in-app chat, and difficulty canceling. theStacc offers priority support with direct access to the product team.",
  },
  {
    q: "What is Outrank's backlink exchange?",
    a: "Outrank offers a unique backlink exchange network where users automatically share links across their AI-generated content. It can boost Domain Rating, especially for new sites. However, the pool is small and returns diminish quickly for sites with existing authority (DR 25+).",
  },
  {
    q: "Can I try theStacc before committing?",
    a: "Yes — theStacc offers a $1 trial for 3 days with full access to all features. No contracts, cancel anytime. Outrank offers a 7-day free trial, but users have reported difficulty canceling.",
  },
];
---

<section class="bg-white">
  <!-- Hero -->
  <div class="border-b border-[#e7e5e4] px-4 md:px-6 py-16 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Compare</p>
    <h1 class="mx-auto mt-6 max-w-[520px] font-sans text-[28px] leading-[36px] md:text-[36px] md:leading-[44px] font-normal text-[#292524]">
      theStacc vs Outrank.so Complete Comparison
    </h1>
    <p class="mx-auto mt-4 max-w-[460px] font-sans text-[16px] leading-[22px] text-[#79716b]">
      Side-by-side comparison of features, pricing, local SEO, content quality, and support.
    </p>
  </div>

  <!-- Why switch -->
  <div class="border-b border-[#e7e5e4] px-6 py-12 text-center">
    <h2 class="font-sans text-[28px] leading-[36px] font-normal text-[#292524]">
      Why businesses choose<br />theStacc over Outrank
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 border-b border-[#e7e5e4]">
    {reasons.map((r, i) => (
      <div class={`border-b md:border-b-0 md:border-r ${i === reasons.length - 1 ? 'md:border-r-0' : ''} border-[#e7e5e4] bg-white px-6 py-8`}>
        <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9]">
          <Icon name={r.icon} size={20} class="text-[#292524]" />
        </div>
        <p class="mt-4 font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#292524]">{r.title}</p>
        <p class="mt-2 font-sans text-[14px] leading-[20px] text-[#79716b]">{r.description}</p>
      </div>
    ))}
  </div>

  <!-- Feature comparison header -->
  <div class="border-b border-[#e7e5e4] px-6 py-12 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Feature Comparison</p>
    <h2 class="mt-4 font-sans text-[28px] leading-[36px] font-normal text-[#292524]">How do the features compare?</h2>
  </div>

  <div>
    <!-- Table header (sticky, scoped to this wrapper) -->
    <div class="sticky top-14 z-10 grid grid-cols-[1.5fr_1fr_1fr] md:grid-cols-[2fr_1fr_1fr] border-b border-[#e7e5e4] bg-white">
      <div class="px-3 md:px-6 py-3"></div>
      <div class="border-l border-[#e7e5e4] px-2 md:px-4 py-3 text-center">
        <p class="font-mono text-xs md:text-sm font-semibold uppercase tracking-[0.48px] text-[#4f39f6]">theStacc</p>
      </div>
      <div class="border-l border-[#e7e5e4] px-2 md:px-4 py-3 text-center">
        <p class="font-mono text-xs md:text-sm font-semibold uppercase tracking-[0.48px] text-[#292524]">Outrank.so</p>
      </div>
    </div>

    {comparisonSections.map(section => (
      <div>
        <div class="border-b border-[#e7e5e4] bg-[#fafaf9] px-6 py-3">
          <p class="font-mono text-sm font-semibold uppercase tracking-[0.48px] text-[#79716b]">{section.title}</p>
        </div>
        {section.rows.map(row => (
          <div class="grid grid-cols-[1.5fr_1fr_1fr] md:grid-cols-[2fr_1fr_1fr] border-b border-[#e7e5e4]">
            <div class="flex items-center px-3 md:px-6 py-3">
              <span class="font-sans text-[12px] md:text-[14px] text-[#292524]">{row.label}</span>
            </div>
            <div class="flex items-center justify-center border-l border-[#e7e5e4] bg-[#4f39f6]/[0.02] px-4 py-3">
              {typeof row.stacc === 'string' ? (
                <span class="font-mono text-sm text-[#292524]">{row.stacc}</span>
              ) : row.stacc ? (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#4f39f6">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#d6d3d1">
                  <path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/>
                </svg>
              )}
            </div>
            <div class="flex items-center justify-center border-l border-[#e7e5e4] px-4 py-3">
              {typeof row.outrank === 'string' ? (
                <span class="font-mono text-sm text-[#79716b]">{row.outrank}</span>
              ) : row.outrank ? (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#4f39f6">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#d6d3d1">
                  <path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/>
                </svg>
              )}
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>

  <!-- CTA banner -->
  <div class="border-b border-[#e7e5e4] bg-[#fafaf9]">
    <div class="flex flex-col md:flex-row items-center justify-between px-6 py-8 gap-4">
      <div>
        <p class="font-sans text-[18px] font-medium text-[#292524]">Ready to switch?</p>
        <p class="mt-1 font-sans text-[14px] text-[#79716b]">$1 for 3 days · Cancel anytime</p>
      </div>
      <a href="/demo/"
        class="inline-flex h-[36px] items-center gap-2 rounded-[12px] border border-[#4f39f6] bg-[#615fff] px-5 font-mono text-[14px] font-semibold uppercase text-[#fafaf9] transition-colors hover:bg-[#4f39f6]">
        Start Free Trial
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Cost comparison -->
  <div class="border-b border-[#e7e5e4] px-6 py-12 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Cost Comparison</p>
    <h2 class="mt-4 font-sans text-[28px] leading-[36px] font-normal text-[#292524]">More coverage. Better price.</h2>
    <p class="mx-auto mt-3 max-w-[480px] font-sans text-[14px] leading-[22px] text-[#79716b]">
      A local business needs both blog content and local SEO. Here's what that costs with each platform.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 border-b border-[#e7e5e4]">
    <!-- Outrank side -->
    <div class="border-b md:border-b-0 md:border-r border-[#e7e5e4] px-6 py-8">
      <p class="font-mono text-sm font-semibold uppercase tracking-[0.48px] text-[#292524]">Outrank.so</p>
      <div class="mt-6 flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <span class="font-sans text-[14px] text-[#292524]">Blog SEO (30 articles)</span>
          <span class="font-mono text-[14px] font-semibold text-[#292524]">$99/mo</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="font-sans text-[14px] text-[#79716b]">Local SEO</span>
          <span class="font-mono text-[14px] text-[#d6d3d1]">Not available</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="font-sans text-[14px] text-[#79716b]">GBP management</span>
          <span class="font-mono text-[14px] text-[#d6d3d1]">Not available</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="font-sans text-[14px] text-[#79716b]">Review monitoring</span>
          <span class="font-mono text-[14px] text-[#d6d3d1]">Not available</span>
        </div>
      </div>
      <div class="mt-6 border-t border-[#e7e5e4] pt-4">
        <div class="flex items-baseline justify-between">
          <span class="font-mono text-sm font-semibold uppercase text-[#79716b]">Total</span>
          <span class="font-mono text-[24px] font-semibold text-[#292524]">$99/mo</span>
        </div>
        <p class="mt-1 font-sans text-sm text-[#79716b]">Blog only — no local SEO coverage</p>
      </div>
    </div>

    <!-- theStacc side -->
    <div class="px-6 py-8">
      <p class="font-mono text-sm font-semibold uppercase tracking-[0.48px] text-[#4f39f6]">theStacc (Bundle)</p>
      <div class="mt-6 flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <span class="font-sans text-[14px] text-[#292524]">Blog SEO (30 articles)</span>
          <span class="font-mono text-[14px] font-semibold text-[#292524]">$99/mo</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="font-sans text-[14px] text-[#292524]">Local SEO (30 posts)</span>
          <span class="font-mono text-[14px] font-semibold text-[#292524]">$49/mo</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="font-sans text-[14px] text-[#292524]">GBP + reviews + city pages</span>
          <span class="font-mono text-[14px] font-semibold text-[#4f39f6]">Included</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="font-sans text-[14px] text-[#292524]">Bundle discount</span>
          <span class="font-mono text-[14px] font-semibold text-[#4f39f6]">−10%</span>
        </div>
      </div>
      <div class="mt-6 border-t border-[#e7e5e4] pt-4">
        <div class="flex items-baseline justify-between">
          <span class="font-mono text-sm font-semibold uppercase text-[#79716b]">Total</span>
          <div class="flex items-baseline gap-2">
            <span class="font-mono text-[14px] text-[#79716b] line-through">$148/mo</span>
            <span class="font-mono text-[24px] font-semibold text-[#4f39f6]">$133/mo</span>
          </div>
        </div>
        <p class="mt-1 font-sans text-sm text-[#4f39f6]">Blog + Local SEO — complete coverage</p>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="border-b border-[#e7e5e4] px-6 py-12 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">FAQ</p>
  </div>

  <div>
    {faqs.map((faq, i) => (
      <div class={i < faqs.length - 1 ? 'border-b border-[#e7e5e4]' : ''}>
        <button class="compare-faq-btn flex w-full cursor-pointer items-center justify-between px-6 py-5 text-left">
          <span class="font-sans text-[15px] font-medium text-[#292524] pr-4">{faq.q}</span>
          <svg class="compare-faq-chevron shrink-0 text-[#79716b] transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>
        <div class="compare-faq-answer hidden px-6 pb-5">
          <p class="max-w-[700px] font-sans text-[14px] leading-[22px] text-[#79716b]">{faq.a}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll('.compare-faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const parent = btn.parentElement;
      const answer = parent?.querySelector('.compare-faq-answer');
      const chevron = btn.querySelector('.compare-faq-chevron') as HTMLElement;
      const isOpen = !answer?.classList.contains('hidden');

      // Close all
      document.querySelectorAll('.compare-faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll<HTMLElement>('.compare-faq-chevron').forEach(c => c.style.transform = '');

      if (!isOpen) {
        answer?.classList.remove('hidden');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
