---

<section class="bg-white" id="pricing-modules">
  <!-- Toolbar: Path toggle + Billing toggle -->
  <div class="mx-auto flex flex-wrap items-center justify-between gap-4 px-6 pt-8 pb-6">
    <!-- Path toggle with label -->
    <div class="flex flex-col items-start gap-3">
      <span class="select-none text-[15px] text-[#615fff]" style="font-family:'Doto',monospace;font-weight:800;letter-spacing:0.5px;">
        SELECT YOUR PATH
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#615fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-1 inline-block animate-bounce"><path d="m7 10 5 5 5-5"/></svg>
      </span>
      <div class="inline-flex overflow-hidden rounded-full bg-[#292524] p-1" role="group" aria-label="Pricing path">
        <button id="path-software" class="path-btn cursor-pointer rounded-full px-6 py-2 font-sans text-[14px] font-bold transition-all duration-200 bg-white text-[#292524] shadow-sm" type="button" aria-pressed="true">
          Software
        </button>
        <button id="path-services" class="path-btn cursor-pointer rounded-full px-6 py-2 font-sans text-[14px] font-bold transition-all duration-200 bg-transparent text-[#79716b] hover:text-white" type="button" aria-pressed="false">
          Services
