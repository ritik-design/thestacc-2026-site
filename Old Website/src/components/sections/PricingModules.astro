          <p class="mt-1 font-sans text-sm text-[#79716b]">{plan.tagline}</p>
          <div class="mt-5 flex items-baseline gap-1">
            <span class="managed-currency-symbol font-sans text-[42px] font-bold tracking-tight text-[#292524]">$</span><span class="managed-price font-sans text-[42px] font-bold tracking-tight text-[#292524]" data-usd={plan.price} data-inr={plan.indiaPrice}>{plan.price}</span>
            <span class="font-sans text-sm text-[#79716b]">/mo</span>
          </div>
          <p class="managed-annual-line mt-1 font-sans text-sm font-medium text-[#79716b]">or <span class="managed-annual-currency">$</span><span class="managed-annual-price" data-usd={plan.annualPrice} data-inr={plan.indiaAnnualPrice}>{plan.annualPrice}</span>/mo billed annually</p>
