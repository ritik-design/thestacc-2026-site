    <!-- Bundle hint -->
    <div class="mx-auto mt-4 px-6 pb-10">
      <div class="flex items-center justify-center rounded-xl border border-dashed border-[#615fff]/20 bg-[#615fff]/[0.03] px-7 py-4 text-center">
        <p class="font-sans text-[14px] text-[#79716b]">
          Pick 2 or more modules and get <span class="font-semibold text-[#615fff]">15% off your total</span>. All modules work together out of the box.
