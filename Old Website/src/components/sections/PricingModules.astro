      </button>
      <span id="mod-save-badge" class="rounded-md bg-[#615fff]/10 px-2 py-0.5 font-mono text-xs font-semibold text-[#615fff]">Save 17%</span>
    </div>
  </div>

  <!-- ==================== SOFTWARE TAB (default, visible) ==================== -->
