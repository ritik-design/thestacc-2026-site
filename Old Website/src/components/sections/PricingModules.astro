<script>
  // ─── USD pricing (source of truth for all countries) ───
  const blogTiers = [{ price: 99 }, { price: 149 }, { price: 199 }];
  const localTiers = [{ price: 49 }, { price: 79 }, { price: 99 }];
  const socialTiers = [{ price: 49 }, { price: 79 }, { price: 129 }];

  type ModKey = 'blog' | 'local' | 'social';
  const tiers: Record<ModKey, { price: number }[]> = {
    blog: blogTiers,
    local: localTiers,
    social: socialTiers,
  };

  let selectedIdx: Record<ModKey, number> = { blog: 0, local: 0, social: 0 };
  let isAnnual = true;
  let currencySymbol = '$';
  let isIndia = false;

  function round(n: number) { return Math.round(n); }

  /** Indian number format: 1,00,000 */
  function formatIndianNumber(n: number): string {
    const s = String(Math.round(n));
    if (s.length <= 3) return s;
    let lastThree = s.substring(s.length - 3);
    const otherNumbers = s.substring(0, s.length - 3);
    const formatted = otherNumbers.replace(/\B(?=(\d{2})+(?!\d))/g, ',');
    return formatted + ',' + lastThree;
  }

  function getPrice(mod: ModKey) {
    const base = tiers[mod][selectedIdx[mod]].price;
    if (isIndia) {
      // Monthly: USD base × 95  |  Yearly: USD base × 87 × 12 (total)
      const raw = isAnnual ? base * 87 * 12 : base * 95;
      return Math.round(raw / 1000) * 1000; // round to nearest 1,000
    }
    return isAnnual ? round(base * 0.83) : base;
  }

  function getSaving(mod: ModKey) {
    const base = tiers[mod][selectedIdx[mod]].price;
    if (isIndia) {
      const monthlyTotal = Math.round(base * 95 / 1000) * 1000 * 12;
      const yearlyTotal = Math.round(base * 87 * 12 / 1000) * 1000;
      return monthlyTotal - yearlyTotal;
    }
    return round(base * 12 - round(base * 0.83) * 12);
  }

  function updateCurrencySymbols() {
    document.querySelectorAll('.currency-symbol').forEach(el => {
      el.textContent = currencySymbol;
    });
  }

  function updatePeriodSuffixes() {
    document.querySelectorAll('.period-suffix').forEach(el => {
      (el as HTMLElement).textContent = (isIndia && isAnnual) ? '/yr' : '/mo';
    });
  }

  function updateAll() {
    (['blog', 'local', 'social'] as ModKey[]).forEach(mod => {
      const priceEl = document.getElementById(`mod-${mod}-price`);
      const savingEl = document.getElementById(`mod-${mod}-saving`);
      const savingAmtEl = document.getElementById(`mod-${mod}-saving-amt`);
      if (priceEl) priceEl.textContent = isIndia ? formatIndianNumber(getPrice(mod)) : String(getPrice(mod));
      if (savingAmtEl) savingAmtEl.textContent = isIndia ? formatIndianNumber(getSaving(mod)) : String(getSaving(mod));
      if (savingEl) {
        if (isAnnual) {
          savingEl.classList.remove('hidden');
        } else {
          savingEl.classList.add('hidden');
        }
      }
    });

    // Update managed services prices for India
    document.querySelectorAll('.managed-price').forEach(el => {
      const usd = el.getAttribute('data-usd');
      const inr = el.getAttribute('data-inr');
      if (usd && inr) el.textContent = isIndia ? formatIndianNumber(Number(inr)) : usd;
    });
    document.querySelectorAll('.managed-annual-price').forEach(el => {
      const usd = el.getAttribute('data-usd');
      const inr = el.getAttribute('data-inr');
      if (usd && inr) el.textContent = isIndia ? formatIndianNumber(Number(inr)) : usd;
    });
    document.querySelectorAll('.managed-currency-symbol').forEach(el => {
      el.textContent = isIndia ? '₹' : '$';
    });
    document.querySelectorAll('.managed-annual-currency').forEach(el => {
      el.textContent = isIndia ? '₹' : '$';
    });
    document.querySelectorAll('.managed-annual-line').forEach(el => {
      (el as HTMLElement).style.display = isIndia ? 'none' : '';
    });

    updateCurrencySymbols();
    updatePeriodSuffixes();

    const dot = document.getElementById('mod-billing-dot');
    const toggle = document.getElementById('mod-billing-toggle');
    const label = document.getElementById('mod-billing-label');
    const badge = document.getElementById('mod-save-badge');
    if (dot) dot.style.transform = isAnnual ? 'translateX(20px)' : 'translateX(0)';
    if (toggle) toggle.style.backgroundColor = isAnnual ? '#615fff' : '#d6d3d1';
    if (label) label.textContent = isAnnual ? 'Billed yearly' : 'Billed monthly';
    if (badge) badge.style.display = isAnnual ? '' : 'none';
  }

  function switchPath(path: 'software' | 'services') {
    const softwareBtn = document.getElementById('path-software')!;
    const servicesBtn = document.getElementById('path-services')!;
    if (path === 'software') {
      softwareBtn.classList.add('bg-white', 'text-[#292524]', 'shadow-sm');
      softwareBtn.classList.remove('bg-transparent', 'text-[#79716b]');
      softwareBtn.setAttribute('aria-pressed', 'true');
      servicesBtn.classList.remove('bg-white', 'text-[#292524]', 'shadow-sm');
      servicesBtn.classList.add('bg-transparent', 'text-[#79716b]');
      servicesBtn.setAttribute('aria-pressed', 'false');
      document.getElementById('pricing-modules')?.scrollIntoView({ behavior: 'smooth' });
    } else {
      servicesBtn.classList.add('bg-white', 'text-[#292524]', 'shadow-sm');
      servicesBtn.classList.remove('bg-transparent', 'text-[#79716b]');
      servicesBtn.setAttribute('aria-pressed', 'true');
      softwareBtn.classList.remove('bg-white', 'text-[#292524]', 'shadow-sm');
      softwareBtn.classList.add('bg-transparent', 'text-[#79716b]');
      softwareBtn.setAttribute('aria-pressed', 'false');
      document.getElementById('panel-services')?.scrollIntoView({ behavior: 'smooth' });
    }
  }

  // ─── IP-based country detection for India pricing ───
  async function detectCountry() {
    try {
      const res = await fetch('https://ipinfo.io/json');
      if (!res.ok) return;
      const data = await res.json();
      if (data.country === 'IN') {
        isIndia = true;
        currencySymbol = '₹';
        updateAll();
      }
    } catch {
      // Silently fail — keep USD pricing
    }
  }

  document.getElementById('path-software')?.addEventListener('click', () => switchPath('software'));
  document.getElementById('path-services')?.addEventListener('click', () => switchPath('services'));
  document.getElementById('mod-billing-toggle')?.addEventListener('click', () => { isAnnual = !isAnnual; updateAll(); });
  document.getElementById('mod-billing-label')?.addEventListener('click', () => { isAnnual = !isAnnual; updateAll(); });

  (['blog', 'local', 'social'] as const).forEach(mod => {
    document.querySelectorAll<HTMLButtonElement>(`[data-mod-tier="${mod}"]`).forEach(btn => {
      btn.addEventListener('click', () => {
        selectedIdx[mod] = parseInt(btn.getAttribute('data-tier-idx') || '0');
        document.querySelectorAll(`[data-mod-tier="${mod}"]`).forEach((b, i) => {
          const isActive = i === selectedIdx[mod];
          b.classList.toggle('border-[#615fff]', isActive);
          b.classList.toggle('bg-[#615fff]/5', isActive);
          b.classList.toggle('text-[#615fff]', isActive);
          b.classList.toggle('border-[#e7e5e4]', !isActive);
          b.classList.toggle('text-[#292524]', !isActive);
        });
        updateAll();
      });
    });
  });

  updateAll();
  detectCountry();
</script>
