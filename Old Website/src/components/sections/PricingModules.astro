      <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#615fff]">Software Pricing</p>
    </div>

    <!-- Module cards grid -->
    <div class="mx-auto grid grid-cols-1 gap-4 px-6 md:grid-cols-3" id="modules-grid">

      <!-- Blog SEO Card -->
