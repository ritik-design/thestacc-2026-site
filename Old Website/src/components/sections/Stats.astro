---
const stats = [
  "3,500+ Blogs Published",
  "92% Avg SEO Score",
  "50+ Pages / Month",
  "10x Average ROI",
  "70+ Industries Served",
  "24/7 Automated Publishing",
  "WordPress & Webflow Integration",
  "AI-Powered Content",
];
---

<section class="border-b border-[#e7e5e4] bg-white">
  <div class="px-6 pt-8 pb-5 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">
      Trusted by local businesses everywhere
    </p>
  </div>

  <div class="relative overflow-hidden border-t border-[#e7e5e4]">
    <!-- Fade edges -->
    <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-20 bg-gradient-to-r from-white to-transparent"></div>
    <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-20 bg-gradient-to-l from-white to-transparent"></div>

    <div class="flex animate-marquee py-6">
      <!-- First set -->
      <div class="flex shrink-0 items-center">
        {stats.map((name) => (
          <div class="flex shrink-0 items-center">
            <span class="font-mono text-[14px] font-medium tracking-[0.56px] text-[#292524]">{name}</span>
            <span class="mx-6 text-[#d6d3d1]">✦</span>
          </div>
        ))}
      </div>
      <!-- Duplicate for seamless loop -->
      <div class="flex shrink-0 items-center">
        {stats.map((name) => (
          <div class="flex shrink-0 items-center">
            <span class="font-mono text-[14px] font-medium tracking-[0.56px] text-[#292524]">{name}</span>
            <span class="mx-6 text-[#d6d3d1]">✦</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
