---

<section class="border-t border-[#e7e5e4] bg-[#fafaf9]">
  <div class="px-6 pt-10 pb-0 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Integrations</p>
    <h2 class="mx-auto mt-4 max-w-[520px] font-sans text-[26px] leading-[34px] md:text-[30px] md:leading-[38px] font-normal text-[#292524]">
      Connects to what you already use
    </h2>
    <p class="mx-auto mt-3 max-w-[560px] font-sans text-[15px] leading-[24px] text-[#79716b]">
      Publish to your CMS, post to social platforms, and manage your Google presence - all from one dashboard. No migration needed.
    </p>
  </div>

  <div class="mt-8 grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 border-t border-l border-[#e7e5e4]">
    {blogIntegrations.map((item) => (
      <div class="group flex flex-col items-center gap-2.5 border-b border-r border-[#e7e5e4] bg-white px-3 py-5 md:py-6 transition-colors hover:bg-[#fafaf9]">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-white shadow-[0px_1px_4px_0px_rgba(0,0,0,0.06)]">
          {item.useTabler ? (
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.876 13.604 12 2l7.124 11.604a5 5 0 1 1-14.248 0Z"/><path d="m15.000 15 3.5 6h-13l3.5-6"/>
            </svg>
          ) : (
            <svg width="22" height="22" viewBox="0 0 24 24" fill={item.color} xmlns="http://www.w3.org/2000/svg">
              <path d={item.path} />
            </svg>
          )}
        </div>
        <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.4px] text-[#57534e] text-center leading-tight">{item.name}</p>
      </div>
    ))}
  </div>

  <div class="border-t border-[#e7e5e4] px-6 py-5 text-center">
    <p class="font-sans text-[14px] text-[#79716b]">
      Missing an integration?
      <a href="/contact/" class="font-medium text-[#4f39f6] hover:underline">Let us know →</a>
    </p>
  </div>
</section>
