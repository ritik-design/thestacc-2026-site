---
---

<section class="relative border-b border-[#e7e5e4]">
  <div class="flex flex-col-reverse md:flex-row md:items-center md:min-h-[600px]">
    <!-- Left Content -->
    <div class="relative z-10 flex w-full md:w-[48%] md:max-w-[560px] flex-col items-center md:items-start gap-4 md:gap-6 px-4 sm:px-6 py-10 md:py-16 text-center md:text-left">

      <!-- Label -->
      <span class="inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5 font-mono text-[13px] font-medium uppercase tracking-[0.5px] text-[#4f39f6]">
        <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
        AI SEO Automation
      </span>

      <!-- Headline -->
      <h1 class="font-sans text-[28px] leading-[36px] md:text-[40px] md:leading-[50px] font-normal text-[#292524] max-w-[520px]">
        Most companies publish 1–2 blogs a&nbsp;month.
        The ones ranking on Google publish&nbsp;30.
      </h1>

      <!-- Subheadline -->
      <p class="font-sans text-[16px] leading-[26px] md:text-[18px] md:leading-[28px] text-[#57534e] max-w-[480px]">
        Stacc researches keywords, writes SEO articles, and publishes them to your blog, Google Business Profile, and social channels - automatically.
      </p>

      <!-- Bullets -->
      <div class="flex flex-col gap-2.5 w-full max-w-[420px]">
        {[
          '30 SEO blog posts published to your site every month',
          'Google Business Profile posts generated and updated daily',
          'Social media posts scheduled and published on autopilot',
        ].map((item) => (
          <div class="flex items-start gap-2.5 text-left">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" class="shrink-0 mt-0.5">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            <span class="font-sans text-[14px] leading-[20px] text-[#57534e]">{item}</span>
          </div>
        ))}
      </div>

      <!-- URL input + CTA -->
      <form id="hero-form" class="flex w-full max-w-[460px] flex-col sm:flex-row items-stretch sm:items-center gap-2 sm:gap-0 rounded-[14px] border border-[#e7e5e4] bg-white p-1.5 shadow-[0px_2px_8px_0px_rgba(0,0,0,0.06)] transition-shadow focus-within:shadow-[0px_8px_32px_0px_rgba(79,57,246,0.2)]">
        <input
          id="hero-url"
          type="text"
          placeholder="Enter your website URL"
          class="flex-1 min-w-0 bg-transparent px-3 py-1.5 font-sans text-[14px] font-medium text-[#292524] placeholder-[#a8a29e] placeholder:font-medium outline-none"
        />
        <button
          type="submit"
          class="cursor-pointer shrink-0 inline-flex h-[36px] sm:h-[32px] items-center justify-center gap-1.5 rounded-[10px] border border-[#4f39f6] bg-[#615fff] px-4 font-mono text-[13px] font-semibold uppercase text-[#fafaf9] transition-colors hover:bg-[#4f39f6]"
        >
          Automate SEO
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
      </form>

      <!-- Social proof pill -->
      <p class="font-mono text-[12px] tracking-[0.3px] text-[#79716b]">
        <span class="inline-flex flex-wrap items-center justify-center gap-1.5 rounded-full border border-[#e7e5e4] bg-[#fafaf9] px-3.5 py-1.5">
          <span>First 30 articles ready in minutes</span>
          <span class="text-[#d6d3d1]">·</span>
          <span class="font-semibold text-[#4f39f6]">$1 to start</span>
          <span class="text-[#d6d3d1]">·</span>
          <span>Cancel anytime</span>
        </span>
      </p>
    </div>

    <!-- Right - Dashboard Preview -->
    <div class="relative w-full px-4 sm:px-6 md:px-0 md:absolute md:right-0 md:top-1/2 md:w-[55%] md:-translate-y-1/2">
      <img
        src="/content-module/Dasboard-content-module.webp"
        alt="theStacc dashboard showing 30 scheduled SEO blog posts"
        width="1200"
        height="750"
        class="w-full h-auto rounded-xl shadow-[0px_8px_40px_0px_rgba(0,0,0,0.10)]"
        loading="eager"
      />
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('hero-form');
  const input = document.getElementById('hero-url') as HTMLInputElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const url = input?.value.trim();
    const normalized = url?.replace(/^https?:\/\//, '').replace(/\/+$/, '');
    window.location.href = normalized ? `/tools/seo-audit/?url=${encodeURIComponent(normalized)}` : '/tools/seo-audit/';
  });
</script>
