---
import { Icon } from 'astro-icon/components';

const steps = [
  {
    number: "01",
    title: "Connect Your Site",
    description: "Enter your URL. Stacc analyzes your website, competitors, and local market in minutes. Choose Blog SEO, Local SEO, Social, or the full bundle.",
    icon: "ph:globe-simple",
  },
  {
    number: "02",
    title: "AI Writes and Publishes",
    description: "Stacc generates 30 SEO articles a month, daily GBP posts, and social content - then publishes everything directly to your channels. You don't touch any of it.",
    icon: "ph:pen-nib",
  },
  {
    number: "03",
    title: "Rankings Climb, Leads Arrive",
    description: "Your pages get indexed. Your Google Business Profile stays active. New customers find you on Google instead of your competitors. Every month compounds on the last.",
    icon: "ph:target",
  },
];
---

<section id="how-it-works" class="border-t border-[#e7e5e4] bg-[#fafaf9]">
  <div class="px-6 pt-10 pb-0 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">How It Works</p>
    <h2 class="mx-auto mt-4 max-w-[480px] font-sans text-[26px] leading-[34px] md:text-[30px] md:leading-[38px] font-normal text-[#292524]">
      Set it up once. It runs forever.
    </h2>
    <p class="mx-auto mt-3 max-w-[500px] font-sans text-[15px] leading-[24px] text-[#79716b]">
      Three steps. No SEO skills needed. No ongoing work required.
    </p>
  </div>

  <div class="mt-8 grid grid-cols-1 md:grid-cols-3 border-t border-[#e7e5e4]">
    {steps.map((step, i) => (
      <div class={`bg-white px-6 py-8 md:py-10 ${i < steps.length - 1 ? 'border-b md:border-b-0 md:border-r border-[#e7e5e4]' : ''}`}>
        <div class="flex items-center justify-between">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9]">
            <Icon name={step.icon} size={20} class="text-[#4f39f6]" />
          </div>
          <span class="font-mono text-[32px] font-bold text-[#e7e5e4]">{step.number}</span>
        </div>
        <p class="mt-5 font-mono text-[14px] font-semibold uppercase tracking-[0.56px] text-[#292524]">{step.title}</p>
        <p class="mt-2 font-sans text-[15px] leading-[24px] text-[#79716b]">{step.description}</p>
      </div>
    ))}
  </div>
</section>
