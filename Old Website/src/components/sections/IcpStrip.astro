---

<section class="border-t border-[#e7e5e4] bg-white">
  <div class="px-6 pt-10 pb-0 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Built For</p>
    <h2 class="mx-auto mt-4 max-w-[520px] font-sans text-[26px] leading-[34px] md:text-[30px] md:leading-[38px] font-normal text-[#292524]">
      Every local business that should be ranking on Google
    </h2>
    <p class="mx-auto mt-3 max-w-[500px] font-sans text-[15px] leading-[24px] text-[#79716b]">
      If your customers search Google to find a business like yours, Stacc gets you in front of them.
    </p>
  </div>

  <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 border-t border-l border-[#e7e5e4]">
    {industries.map((industry) => (
      <div class="group flex flex-col items-center gap-3 border-b border-r border-[#e7e5e4] px-4 py-6 md:py-8 transition-colors hover:bg-[#fafaf9] text-center">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#fafaf9] transition-colors group-hover:border-[#4f39f6]/20 group-hover:bg-[#eef2ff]">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="#4f39f6" stroke-width="1.5" viewBox="0 0 24 24" set:html={industry.icon} />
        </div>
        <div>
          <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.5px] text-[#292524]">{industry.name}</p>
          <p class="mt-1 font-sans text-[12px] leading-[16px] text-[#79716b]">{industry.label}</p>
        </div>
      </div>
    ))}
  </div>
</section>
