---
---

<section id="contact" class="border-t border-[#e7e5e4] bg-white px-6 py-16">
  <div class="mx-auto max-w-[960px] flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-16">
    <!-- Left: heading -->
    <div class="lg:sticky lg:top-24 lg:w-[340px] lg:shrink-0">
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-[#4f39f6]">Get in Touch</p>
      <h1 class="mt-4 font-sans text-[30px] leading-[38px] font-normal text-[#292524]">
        Have a question? We'd love to hear from you.
      </h1>
      <p class="mt-3 font-sans text-base leading-relaxed text-[#79716b]">
        Fill out the form below and we'll get back to you within 24 hours.
      </p>
      <div class="mt-6 flex flex-col gap-3">
        <p class="font-sans text-sm leading-relaxed text-[#79716b]">
          <strong class="text-[#292524]">Product questions</strong> - Ask us anything about theStacc's Blog SEO, Local SEO, or Social Media modules. We'll help you find the right plan for your business.
        </p>
        <p class="font-sans text-sm leading-relaxed text-[#79716b]">
          <strong class="text-[#292524]">Technical support</strong> - Having trouble connecting your website, WordPress, or Google Business Profile? Our team will walk you through the setup.
        </p>
        <p class="font-sans text-sm leading-relaxed text-[#79716b]">
          <strong class="text-[#292524]">Agency &amp; partnership inquiries</strong> - Interested in using theStacc for multiple clients? We offer agency pricing and white-label options.
        </p>
      </div>
      <a
        href="mailto:sidgangal@gmail.com"
        class="mt-8 hidden lg:inline-flex items-center gap-3 rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-5 py-3 transition-colors hover:border-[#d6d3d1] hover:bg-[#f5f5f4]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
        <span class="font-sans text-base text-[#292524]">sidgangal@gmail.com</span>
      </a>
    </div>

    <!-- Right: form -->
    <form id="contact-form" class="flex flex-1 flex-col gap-5">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div>
          <label for="contact-name" class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Name *</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            class="mt-2 w-full rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-base text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="contact-email" class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Email *</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            class="mt-2 w-full rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-base text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
            placeholder="Your email"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div>
          <label for="contact-company" class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Company</label>
          <input
            type="text"
            id="contact-company"
            name="company"
            class="mt-2 w-full rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-base text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
            placeholder="Your company (optional)"
          />
        </div>

        <!-- Custom dropdown for Area of Interest -->
        <div>
          <label class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Area of Interest</label>
          <div class="relative mt-2" id="dropdown-wrapper">
            <input type="hidden" name="module" id="contact-module" value="" />
            <button
              type="button"
              id="dropdown-trigger"
              class="flex w-full items-center justify-between rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 text-left font-sans text-base outline-none transition-colors focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
            >
              <span id="dropdown-label" class="text-[#79716b]">Select area</span>
              <svg id="dropdown-chevron" class="h-5 w-5 text-[#79716b] transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </button>
            <ul
              id="dropdown-menu"
              class="absolute left-0 right-0 top-full z-10 mt-1 hidden overflow-hidden rounded-xl border border-[#e7e5e4] bg-white shadow-lg"
            >
              <li data-value="Blog SEO" class="dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Blog SEO</li>
              <li data-value="Local SEO" class="dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Local SEO</li>
              <li data-value="Social Media" class="dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Social Media</li>
              <li data-value="Managed Services" class="dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Managed Services</li>
              <li data-value="Other" class="dropdown-option cursor-pointer px-4 py-3 font-sans text-base text-[#292524] transition-colors hover:bg-[#f5f5f4]">Other</li>
            </ul>
          </div>
        </div>
      </div>

      <div>
        <label for="contact-phone" class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Phone</label>
        <input
          type="tel"
          id="contact-phone"
          name="phone"
          autocomplete="tel"
          class="mt-2 w-full rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-base text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
          placeholder="Optional — for a faster WhatsApp reply"
        />
      </div>

      <div>
        <label for="contact-message" class="block font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Message *</label>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="4"
          class="mt-2 w-full resize-none rounded-xl border border-[#e7e5e4] bg-[#fafaf9] px-4 py-3 font-sans text-base text-[#292524] outline-none transition-colors placeholder:text-[#79716b] focus:border-[#4f39f6] focus:ring-1 focus:ring-[#4f39f6]"
          placeholder="How can we help?"
        ></textarea>
      </div>

      <button
        type="submit"
        id="contact-submit"
        class="mt-1 flex h-[44px] w-full items-center justify-center gap-2 rounded-xl border border-[#4f39f6] bg-[#615fff] font-mono text-sm font-semibold uppercase tracking-wide text-white transition-colors hover:bg-[#4f39f6] disabled:cursor-not-allowed disabled:opacity-60"
      >
        <span id="submit-text">Send Message</span>
        <svg id="submit-spinner" class="hidden h-4 w-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </button>

      <p id="form-status" class="hidden text-center font-sans text-sm"></p>
    </form>
  </div>
</section>

<script>
  // Dropdown logic
  const trigger = document.getElementById('dropdown-trigger')!;
  const menu = document.getElementById('dropdown-menu')!;
  const label = document.getElementById('dropdown-label')!;
  const chevron = document.getElementById('dropdown-chevron')!;
  const hiddenInput = document.getElementById('contact-module') as HTMLInputElement;
  const options = document.querySelectorAll('.dropdown-option');

  function openDropdown() {
    menu.classList.remove('hidden');
    chevron.classList.add('rotate-180');
  }

  function closeDropdown() {
    menu.classList.add('hidden');
    chevron.classList.remove('rotate-180');
  }

  trigger.addEventListener('click', () => {
    menu.classList.contains('hidden') ? openDropdown() : closeDropdown();
  });

  options.forEach((opt) => {
    opt.addEventListener('click', () => {
      const value = (opt as HTMLElement).dataset.value!;
      hiddenInput.value = value;
      label.textContent = value;
      label.classList.remove('text-[#79716b]');
      label.classList.add('text-[#292524]');
      closeDropdown();
    });
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('#dropdown-wrapper')) {
      closeDropdown();
    }
  });

  // Form submission
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text')!;
  const spinner = document.getElementById('submit-spinner')!;
  const status = document.getElementById('form-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitText.textContent = 'Sending...';
    spinner.classList.remove('hidden');
    status.classList.add('hidden');

    const data = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value.trim(),
      email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
      phone: (form.elements.namedItem('phone') as HTMLInputElement)?.value.trim() ?? '',
      company: (form.elements.namedItem('company') as HTMLInputElement).value.trim(),
      module: (form.elements.namedItem('module') as HTMLInputElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
    };

    try {
      const res = await fetch('/api/contact/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok) {
        status.textContent = 'Message sent! We\'ll get back to you soon.';
        status.className = 'text-center font-sans text-sm text-green-600';
        form.reset();
        hiddenInput.value = '';
        label.textContent = 'Select area';
        label.classList.add('text-[#79716b]');
        label.classList.remove('text-[#292524]');
      } else {
        status.textContent = result.error || 'Something went wrong. Please try again.';
        status.className = 'text-center font-sans text-sm text-red-500';
      }
    } catch {
      status.textContent = 'Network error. Please check your connection and try again.';
      status.className = 'text-center font-sans text-sm text-red-500';
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Send Message';
      spinner.classList.add('hidden');
    }
  });
</script>
