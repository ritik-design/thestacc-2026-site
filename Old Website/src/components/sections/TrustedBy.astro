---
const credentials = [
  { heading: "3,500+", label: "Blogs Published", verified: true },
  { heading: "92%", label: "Avg SEO Score", stars: true },
  { heading: "500+", label: "Businesses Served", verified: true },
  { heading: "4.9/5", label: "Avg Rating", stars: true },
];
---

<section class="border-t border-[#e7e5e4] bg-white">
  <div class="px-6 pt-8 pb-4 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">
      Results that speak for themselves
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 border-t border-b border-[#e7e5e4]">
    {credentials.map((item, i) => (
      <div class={`flex flex-col items-center justify-center gap-4 py-8 md:py-12 ${i < credentials.length - 1 ? 'border-r border-[#e7e5e4]' : ''} ${i < 2 ? 'border-b md:border-b-0 border-[#e7e5e4]' : ''}`}>
        <p class="font-mono text-[22px] font-semibold tracking-tight text-[#292524]">{item.heading}</p>
        {item.stars ? (
          <div class="flex flex-col items-center gap-2">
            <div class="flex gap-0.5">
              {[0,1,2,3,4].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#292524">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p class="font-mono text-sm font-medium uppercase tracking-[0.48px] text-[#79716b]">{item.label}</p>
          </div>
        ) : (
          <div class="flex items-center gap-1.5">
            <p class="font-mono text-sm font-medium uppercase tracking-[0.48px] text-[#79716b]">{item.label}</p>
            {item.verified && (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#4f39f6">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            )}
          </div>
        )}
      </div>
    ))}
  </div>
</section>
