---
---

<section class="border-t border-[#e7e5e4] bg-white">
  <!-- Header -->
  <div class="px-6 pt-10 pb-0 text-center">
    <span class="inline-flex items-center rounded-xl border border-[#615fff]/20 px-4 py-1.5 font-mono text-[13px] font-medium text-[#615fff]">New: Social Media Module</span>
    <h2 class="mx-auto mt-4 max-w-[680px] font-sans text-[28px] leading-[36px] md:text-[52px] md:leading-[60px] font-normal text-[#292524]">
      Stop doing your marketing. Start growing your business.
    </h2>
    <p class="mx-auto mt-4 max-w-[560px] font-sans text-[16px] leading-[24px] text-[#79716b]">
      Three ways to get your SEO, local search, and social media handled. Pick the one that fits how you work.
    </p>
  </div>

  <!-- Three Cards -->
  <div class="mt-10 mx-auto grid grid-cols-1 lg:grid-cols-3 gap-4 px-6">

    <!-- Card 1: The DIY Approach -->
    <div class="rounded-xl border border-[#e7e5e4] bg-[#fafaf9] p-7 flex flex-col">
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-[#79716b]">The DIY Approach</p>
      <h3 class="mt-3 font-sans text-xl font-semibold text-[#292524]">Do It All Yourself</h3>
      <p class="mt-2 font-sans text-sm text-[#79716b]">
        Cobble together 4+ tools, learn SEO, write content, manage reviews, and post to social. Every week.
      </p>

      <!-- Price -->
      <div class="mt-6">
        <div class="flex items-baseline gap-1">
          <span class="font-sans text-[42px] font-bold tracking-tight text-[#b91c1c]">$1,324</span>
          <span class="font-sans text-sm text-[#79716b]">/mo</span>
        </div>
        <p class="mt-1 font-sans text-sm font-medium text-[#79716b]">$199 in tools + $1,125 of your time</p>
      </div>

      <!-- Cost breakdown -->
      <div class="mt-6 border-t border-[#e7e5e4] pt-5">
        <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Here's the math</p>
        <div class="mt-3 space-y-2">
          {[
            { name: "AI writing tool", cost: "$20" },
            { name: "SEO platform (Ahrefs, etc.)", cost: "$99" },
            { name: "Review management", cost: "$60" },
            { name: "Social scheduling tool", cost: "$20" },
          ].map((item) => (
            <div class="flex items-center justify-between">
              <span class="font-sans text-[14px] text-[#79716b]">{item.name}</span>
              <span class="font-mono text-[14px] text-[#292524]">{item.cost}</span>
            </div>
          ))}
          <div class="flex items-center justify-between border-t border-dashed border-[#e7e5e4] pt-2">
            <span class="font-sans text-[14px] text-[#79716b]">Software total</span>
            <span class="font-mono text-[14px] font-medium text-[#292524]">$199/mo</span>
          </div>
          <div class="flex items-center justify-between relative group/tip">
            <span class="font-sans text-[14px] text-[#79716b] flex items-center gap-1.5">
              Your time (9+ hrs at $125/hr)
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a8a29e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 cursor-help">
                <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
              </svg>
            </span>
            <span class="font-mono text-[14px] font-medium text-[#292524]">$1,125/mo</span>
            <!-- Tooltip -->
            <div class="invisible opacity-0 group-hover/tip:visible group-hover/tip:opacity-100 transition-all duration-200 absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-[280px] rounded-xl border border-[#e7e5e4] bg-white p-4 shadow-lg z-50">
              <p class="font-sans text-[14px] leading-[22px] text-[#79716b]">
                If your business makes $250K/year, your time is worth <span class="font-medium text-[#292524]">$125/hour</span>. That's
                <span class="font-medium text-[#b91c1c]">$1,125/month</span> spent on marketing instead of running your business.
              </p>
              <div class="absolute top-full left-1/2 -translate-x-1/2 -mt-px">
                <div class="border-[6px] border-transparent border-t-[#e7e5e4]"></div>
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -mt-[1px] border-[5px] border-transparent border-t-white"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Negatives -->
      <div class="mt-6 border-t border-[#e7e5e4] pt-5 flex flex-col gap-2.5 flex-1">
        {[
          "Juggling 4+ subscriptions",
          "No automation between tools",
          "Hours of manual work weekly",
          "You're working in your business, not on it",
        ].map((item) => (
          <div class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#fecaca" class="shrink-0">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" />
              <path d="M15 9l-6 6M9 9l6 6" stroke="#b91c1c" stroke-width="1.5" stroke-linecap="round" />
            </svg>
            <span class="font-sans text-[14px] text-[#78716c]">{item}</span>
          </div>
        ))}
      </div>

      <p class="mt-6 font-sans text-[14px] italic text-[#79716b]">
        This is where most businesses are stuck.
      </p>
    </div>

    <!-- Card 2: Recommended (theStacc) -->
    <div class="relative rounded-xl border border-[#615fff]/30 bg-white p-7 flex flex-col">
      <span class="absolute -top-3 left-6 inline-flex items-center rounded-md bg-[#615fff] px-3 py-1 font-mono text-[11px] font-bold uppercase tracking-wide text-white">
        Recommended
      </span>

      <p class="font-mono text-sm font-medium uppercase tracking-wide text-[#615fff]">Let AI Do the Work</p>
      <h3 class="mt-3 font-sans text-xl font-semibold text-[#292524]">theStacc handles everything</h3>
      <p class="mt-2 font-sans text-sm text-[#79716b]">
        Content, SEO, local search, and social media. You review and approve. That's it.
      </p>

      <!-- Price -->
      <div class="mt-6">
        <div class="flex items-baseline gap-1">
          <span class="font-sans text-[42px] font-bold tracking-tight text-[#292524]">
            $<span id="comparison-price">105</span>
          </span>
          <span class="font-sans text-sm text-[#79716b]">/mo</span>
        </div>

        <!-- Bundle savings callout -->
        <div class="mt-3 rounded-lg bg-[#615fff]/5 border border-[#615fff]/15 px-3 py-2.5">
          <p id="comp-bundle-text" class="font-sans text-[13px] leading-[20px] text-[#292524]">
            <span class="font-semibold text-[#615fff]">Bundle discount applied:</span> Blog SEO ($82/mo) + Local SEO ($41/mo) with 15% off.
            <a href="#pricing" class="text-[#615fff] hover:underline font-medium">Add more modules</a> and save more.
          </p>
        </div>

        <div class="mt-4 inline-flex items-center gap-3">
          <button id="comp-billing-toggle" class="relative w-[44px] h-[24px] rounded-full bg-[#615fff] cursor-pointer transition-colors shrink-0" aria-label="Toggle billing period">
            <div id="comp-billing-dot" class="absolute top-[3px] left-[3px] w-[18px] h-[18px] rounded-full bg-white shadow-sm transition-transform" style="transform:translateX(20px)"></div>
          </button>
          <span id="comp-btn-annual" class="cursor-pointer font-sans text-sm font-semibold text-[#292524] transition-colors">Billed yearly</span>
          <span id="comp-save-badge" class="font-sans text-xs font-semibold text-[#615fff] bg-[#615fff]/10 px-2 py-0.5 rounded-md">Save 17%</span>
        </div>

        <a href="#pricing"
          class="cursor-pointer mt-5 inline-flex h-[44px] w-full items-center justify-center rounded-xl border border-[#615fff] bg-[#615fff] font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#5550e6]">
          Start Free Trial
        </a>
      </div>

      <!-- Features -->
      <div class="mt-6 border-t border-[#e7e5e4] pt-5 flex flex-col gap-3 flex-1">
        {[
          "Blog articles written & published daily",
          "Google Business Profile managed automatically",
          "Social media posts scheduled & posted",
          "Review monitoring with AI responses",
          "One dashboard for everything",
          "1–2 hrs/week to review and approve",
        ].map((feature) => (
          <div class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#615fff" class="shrink-0">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            <span class="font-sans text-[14px] text-[#292524]">{feature}</span>
          </div>
        ))}
      </div>

      <p class="mt-6 font-sans text-[14px] leading-[22px] text-[#79716b]">
        You'll spend <span class="font-medium text-[#292524]">1–2 hours/week</span> overseeing what the AI does. The rest of your time? Back on your business where it belongs.
      </p>
    </div>

    <!-- Card 3: Done For You -->
    <div class="rounded-xl border border-[#e7e5e4] bg-white p-7 flex flex-col">
      <p class="font-mono text-sm font-medium uppercase tracking-wide text-[#79716b]">Done For You</p>
      <h3 class="mt-3 font-sans text-xl font-semibold text-[#292524]">We Handle Everything</h3>
      <p class="mt-2 font-sans text-sm text-[#79716b]">
        We take over your marketing. You show up to a monthly video call with our US-based team and review results.
      </p>

      <!-- Price -->
      <div class="mt-6">
        <p class="font-mono text-xs font-medium uppercase tracking-wide text-[#79716b]">Starting at</p>
        <div class="mt-2 flex items-baseline gap-1">
          <span class="font-sans text-[42px] font-bold tracking-tight text-[#292524]">$749</span>
          <span class="font-sans text-sm text-[#79716b]">/mo</span>
        </div>
        <p class="mt-1 font-sans text-sm font-medium text-[#79716b]">Content + Local SEO, fully managed. Higher tiers below.</p>

        <a href="mailto:sidgangal@gmail.com" target="_blank" rel="noopener noreferrer"
          class="cursor-pointer mt-5 inline-flex h-[44px] w-full items-center justify-center rounded-xl border border-[#44403c] bg-[#44403c] font-sans text-[15px] font-semibold text-white transition-colors hover:bg-[#292524]">
          Talk to Our Team
        </a>
        <p class="mt-2 text-center font-sans text-sm font-medium text-[#79716b]">Free consultation · No commitment</p>
      </div>

      <!-- Features -->
      <div class="mt-6 border-t border-[#e7e5e4] pt-5 flex flex-col gap-3 flex-1">
        {[
          "We hold all your logins",
          "Blog posts written, published, and optimized",
          "GBP posts go out on schedule",
          "Every review monitored and responded to",
          "Social media managed across platforms",
          "Monthly video call: website health, SEO progress, strategy",
          "Weekly performance reports",
          "US-based operations team",
        ].map((feature) => (
          <div class="flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#615fff" class="shrink-0">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            <span class="font-sans text-[14px] text-[#292524]">{feature}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const compAnnual = document.getElementById('comp-btn-annual');
  const compPrice = document.getElementById('comparison-price');
  const compToggle = document.getElementById('comp-billing-toggle');
  const compDot = document.getElementById('comp-billing-dot');
  let compIsAnnual = true;

  function setCompAnnual(annual: boolean) {
    compIsAnnual = annual;
    if (compPrice) compPrice.textContent = annual ? '105' : '126';
    if (compDot) compDot.style.transform = annual ? 'translateX(20px)' : 'translateX(0)';
    if (compToggle) compToggle.style.backgroundColor = annual ? '#615fff' : '#d6d3d1';
    if (compAnnual) compAnnual.textContent = annual ? 'Billed yearly' : 'Billed monthly';
    const compSaveBadge = document.getElementById('comp-save-badge');
    if (compSaveBadge) compSaveBadge.style.display = annual ? '' : 'none';
    const compBundleText = document.getElementById('comp-bundle-text');
    if (compBundleText) {
      const blogPrice = annual ? '$82' : '$99';
      const localPrice = annual ? '$41' : '$49';
      compBundleText.innerHTML = `<span class="font-semibold text-[#615fff]">Bundle discount applied:</span> Blog SEO (${blogPrice}/mo) + Local SEO (${localPrice}/mo) with 15% off. <a href="#pricing" class="text-[#615fff] hover:underline font-medium">Add more modules</a> and save more.`;
    }
  }

  compToggle?.addEventListener('click', () => setCompAnnual(!compIsAnnual));
  compAnnual?.addEventListener('click', () => setCompAnnual(!compIsAnnual));
</script>
