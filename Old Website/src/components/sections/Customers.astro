---
const customers = [
  { name: "ReplyDaddy",          logo: "/customer-logos/replydaddy.webp",          showName: true },
  { name: "NoobBookLM",          logo: "/customer-logos/noobbooklm.webp",          showName: true },
  { name: "ChartMath",           logo: "/customer-logos/chartmath.webp",           showName: true },
  { name: "Heaven Designs",      logo: "/customer-logos/heaven-designs.webp",      showName: false },
  { name: "Solar EPC Company", logo: "/customer-logos/heaven-green-energy.webp", showName: false },
  { name: "Qbits Energy",        logo: "/customer-logos/qbits.webp",              showName: false },
  { name: "QuickEstimate",       logo: "/customer-logos/quickestimate.webp",      showName: false },
  { name: "Suncart",             logo: "/customer-logos/suncart.svg",              showName: false },
  { name: "Intello",             logo: "/customer-logos/intello.webp",             showName: false },
  { name: "Rajasthan Green Solar", logo: "/customer-logos/rajasthan-green-solar.webp", showName: false },
  { name: "Suryantra Energy",    logo: "/customer-logos/suryantra-energy.webp",     showName: true },
];
---

<section class="border-t border-b border-[#e7e5e4] bg-white">
  <div class="px-6 pt-8 pb-3 text-center">
    <p class="font-mono text-[14px] leading-[20px] font-medium uppercase tracking-[0.7px] text-[#292524]">
      Trusted by growing businesses
    </p>
  </div>

  <div class="relative overflow-hidden py-8">
    <!-- Fade edges -->
    <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 sm:w-24 bg-gradient-to-r from-white to-transparent"></div>
    <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 sm:w-24 bg-gradient-to-l from-white to-transparent"></div>

    <div class="flex animate-marquee">
      <!-- First set -->
      <div class="flex shrink-0 items-center">
        {customers.map((c) => (
          <div class="flex shrink-0 items-center gap-2 mx-8 sm:mx-10">
            <img
              src={c.logo}
              alt={c.name}
              width="120"
              height="40"
              class={c.showName ? "h-[32px] w-[32px] object-contain" : "h-[36px] w-auto object-contain"}
              loading="lazy"
            />
            {c.showName && (
              <span class="font-mono text-[17px] sm:text-[20px] font-medium text-[#292524] whitespace-nowrap">{c.name}</span>
            )}
          </div>
        ))}
      </div>
      <!-- Duplicate for seamless loop -->
      <div class="flex shrink-0 items-center">
        {customers.map((c) => (
          <div class="flex shrink-0 items-center gap-2 mx-8 sm:mx-10">
            <img
              src={c.logo}
              alt={c.name}
              width="120"
              height="40"
              class={c.showName ? "h-[32px] w-[32px] object-contain" : "h-[36px] w-auto object-contain"}
              loading="lazy"
            />
            {c.showName && (
              <span class="font-mono text-[17px] sm:text-[20px] font-medium text-[#292524] whitespace-nowrap">{c.name}</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
