---
const plans = [
  {
    name: "Blog SEO",
    price: "$99",
    period: "/month",
    tagline: "30 articles. Published automatically.",
    features: [
      "30 AI-written, SEO-scored articles/month",
      "Keyword research & competitor analysis",
      "Auto-publish to WordPress, Webflow, Ghost",
      "Brand voice training",
      "Content calendar with full scheduling",
    ],
    cta: "Start for $1",
    ctaLink: "/demo/",
    highlight: false,
  },
  {
    name: "Bundle",
    price: "$167",
    period: "/month",
    tagline: "Blog + Local + Social. Everything.",
    badge: "Best Value",
    features: [
      "Everything in Blog SEO",
      "Google Business Profile posts daily",
      "Review monitoring + AI responses",
      "Social posts to Instagram, LinkedIn, X, Facebook",
      "AI image generation for social",
    ],
    cta: "Start for $1",
    ctaLink: "/demo/",
    highlight: true,
  },
  {
    name: "Local SEO",
    price: "$49",
    period: "/month",
    tagline: "Dominate Google Maps and local search.",
    features: [
      "30 GBP posts generated per month",
      "Review monitoring & AI response drafts",
      "Local keyword tracking",
      "Multi-location support",
      "Competitor GBP analysis",
    ],
    cta: "Start for $1",
    ctaLink: "/demo/",
    highlight: false,
  },
];
---

<section class="border-t border-[#e7e5e4] bg-[#fafaf9]">
  <div class="px-6 pt-10 pb-0 text-center">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Pricing</p>
    <h2 class="mx-auto mt-4 max-w-[520px] font-sans text-[26px] leading-[34px] md:text-[30px] md:leading-[38px] font-normal text-[#292524]">
      SEO agencies charge $2,000–$5,000/month. Stacc: $99.
    </h2>
    <p class="mx-auto mt-3 max-w-[480px] font-sans text-[15px] leading-[24px] text-[#79716b]">
      Start with one module. Add the others when you're ready. Cancel anytime - the content we've published keeps working for you.
    </p>
  </div>

  <div class="mx-auto max-w-[1100px] px-4 sm:px-6 mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
    {plans.map((plan) => (
      <div class={`relative flex flex-col rounded-2xl border bg-white p-6 md:p-8 ${plan.highlight ? 'border-[#4f39f6] shadow-[0px_4px_32px_0px_rgba(79,57,246,0.12)]' : 'border-[#e7e5e4]'}`}>
        {plan.badge && (
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="inline-flex items-center rounded-full border border-[#4f39f6] bg-[#615fff] px-3 py-0.5 font-mono text-[11px] font-semibold uppercase tracking-[0.4px] text-white">
              {plan.badge}
            </span>
          </div>
        )}

        <div>
          <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.5px] text-[#79716b]">{plan.name}</p>
          <div class="mt-3 flex items-baseline gap-1">
            <span class="font-sans text-[36px] font-semibold text-[#292524]">{plan.price}</span>
            <span class="font-sans text-[15px] text-[#79716b]">{plan.period}</span>
          </div>
          <p class="mt-1 font-sans text-[14px] text-[#57534e]">{plan.tagline}</p>
        </div>

        <div class="mt-6 flex flex-col gap-2.5 flex-1">
          {plan.features.map((feature) => (
            <div class="flex items-start gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill={plan.highlight ? '#4f39f6' : '#4f39f6'} class="shrink-0 mt-0.5">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
              <span class="font-sans text-[13px] leading-[20px] text-[#57534e]">{feature}</span>
            </div>
          ))}
        </div>

        <a
          href={plan.ctaLink}
          target="_blank"
          rel="noopener noreferrer"
          class={`mt-6 inline-flex h-[40px] w-full items-center justify-center rounded-[10px] font-mono text-[14px] font-semibold uppercase transition-colors ${plan.highlight ? 'border border-[#4f39f6] bg-[#615fff] text-white hover:bg-[#4f39f6]' : 'border border-[#e7e5e4] bg-[#fafaf9] text-[#292524] hover:bg-[#f5f5f4]'}`}
        >
          {plan.cta}
        </a>
      </div>
    ))}
  </div>

  <div class="pb-10 pt-6 text-center">
    <a href="/pricing/" class="inline-flex items-center gap-1.5 font-sans text-[14px] font-medium text-[#4f39f6] hover:underline">
      See full pricing and feature comparison
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>
