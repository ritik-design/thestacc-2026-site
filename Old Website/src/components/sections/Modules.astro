---
const modules = [
  {
    label: "Blog SEO",
    title: "The companies ranking on Google publish 30 articles a month. Most publish 2.",
    description: "Stacc closes that gap automatically. AI researches the keywords your customers are searching, writes full-length SEO articles, and publishes them directly to your site - every day, without you.",
    features: [
      "Keyword research built from your site and competitors",
      "AI-written articles, SEO-scored before they publish",
      "Auto-publishes to WordPress, Webflow, Ghost, or any CMS",
      "Content calendar with full scheduling visibility",
      "Brand voice trained on your existing content",
    ],
    cta: "Automate Your Blog",
    ctaLink: "/demo/",
    modulePage: "/modules/content-seo/",
    image: "/content-module/Dasboard-content-module.webp",
  },
  {
    label: "Local SEO",
    title: "Your Google Business Profile is your #1 local ranking signal. Most businesses haven't touched it in weeks.",
    description: "Stacc keeps your profile active with fresh posts and monitors every review. An active GBP ranks higher in the map pack - and Stacc makes yours the most active one in your market.",
    features: [
      "Daily GBP post generation (copy to Google in one click)",
      "Review monitoring with AI-drafted responses",
      "Local keyword tracking and ranking visibility",
      "Multi-location support for businesses with multiple sites",
      "Competitor GBP analysis",
    ],
    cta: "Own Your Local Market",
    ctaLink: "/demo/",
    modulePage: "/modules/local-seo/",
    image: "/local-seo-module/local-seo-dashboard.webp",
  },
  {
    label: "Social Media",
    title: "Your business should be posting every day. You're not - because creating content takes hours.",
    description: "Stacc generates on-brand posts with images and captions, then schedules and publishes them to Instagram, LinkedIn, X, and Facebook. Set your brand voice once. Stacc runs your social presence from there.",
    features: [
      "AI-written posts in your brand voice",
      "Auto-publishes to Instagram, LinkedIn, X, and Facebook",
      "AI image generation - photorealistic, illustration, cinematic",
      "Smart scheduling based on your content pillars",
      "Hashtag optimization and first-comment drafts",
    ],
    cta: "Automate Your Socials",
    ctaLink: "/demo/",
    modulePage: "/modules/social-media/",
    image: "/social-module-images/social-module-dashboard.webp",
  },
];
---

<section id="services" class="border-t border-[#e7e5e4] bg-white">
  <!-- Centered Header -->
  <div class="px-6 py-10 text-center border-b border-[#e7e5e4]">
    <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">Three Modules. One Platform.</p>
    <h2 class="mx-auto mt-4 max-w-[560px] font-sans text-[26px] leading-[34px] md:text-[32px] md:leading-[42px] font-normal text-[#292524]">
      Start with one module. Add the others when you're ready.
    </h2>
    <p class="mx-auto mt-4 max-w-[520px] font-sans text-[16px] leading-[24px] text-[#79716b]">
      Blog SEO, Local SEO, and Social Media - each one runs automatically. Together, they cover every channel your customers use to find a business.
    </p>
  </div>

  <!-- Stacked Module Cards -->
  {modules.map((mod, i) => (
    <div class={`border-b border-[#e7e5e4] px-6 py-10 md:py-14 ${i % 2 !== 0 ? 'bg-[#fafaf9]' : 'bg-white'}`}>
      <div class="mx-auto max-w-[1200px] grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
        <!-- Text Side -->
        <div class={i % 2 !== 0 ? 'md:order-last' : ''}>
          <p class="font-mono text-[14px] font-medium uppercase tracking-[0.56px] text-[#4f39f6]">{mod.label}</p>
          <h3 class="mt-3 font-sans text-[24px] leading-[32px] md:text-[30px] md:leading-[38px] font-normal text-[#292524]">{mod.title}</h3>
          <p class="mt-3 font-sans text-[16px] leading-[24px] text-[#79716b]">{mod.description}</p>

          <div class="mt-6 flex flex-col gap-3">
            {mod.features.map((feature) => (
              <div class="flex items-center gap-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#4f39f6" class="shrink-0">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                <span class="font-sans text-[14px] text-[#292524]">{feature}</span>
              </div>
            ))}
          </div>

          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a href={mod.ctaLink} target="_blank" rel="noopener noreferrer"
              class="cursor-pointer inline-flex h-[32px] items-center justify-center rounded-[12px] border border-[#4f39f6] bg-[#615fff] px-5 font-mono text-[14px] font-semibold uppercase text-[#fafaf9] hover:bg-[#4f39f6] transition-colors">
              {mod.cta}
            </a>
            <a href={mod.modulePage}
              class="inline-flex items-center gap-1 font-sans text-[14px] font-medium text-[#4f39f6] hover:text-[#3b2fc2] transition-colors">
              See all features
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- Image Side with Three.js Canvas -->
        <div class={`relative overflow-hidden rounded-xl ${i % 2 !== 0 ? 'md:order-first' : ''}`}>
          <canvas id={`modules-canvas-${i}`} class="absolute inset-0 pointer-events-none w-full h-full"></canvas>
          <div class="relative z-[1] p-6 md:p-10">
            <img
              src={mod.image}
              alt={mod.title}
              class="w-full h-auto rounded-xl shadow-[0px_4px_24px_0px_rgba(0,0,0,0.08)]"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  ))}
</section>

<script>
  // Three.js animated background for module cards
  async function initThreeCanvas(canvasId: string) {
    const canvas = document.getElementById(canvasId) as HTMLCanvasElement | null;
    if (!canvas) return;

    const container = canvas.parentElement;
    if (!container) return;

    const THREE = await import('three');

    const VERTEX_SHADER = `
      varying vec2 vUv;
      void main() {
        vUv = uv;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;

    const FRAGMENT_SHADER = `
      uniform float uTime;
      uniform vec2 uResolution;
      varying vec2 vUv;

      vec3 mod289(vec3 x) { return x - floor(x * (1.0/289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0/289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

      float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
        vec2 i  = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
        m = m*m; m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }

      void main() {
        vec2 uv = vUv;
        float t = uTime * 0.4;
        vec2 warp = vec2(
          snoise(uv * 1.5 + vec2(t * 0.2, 0.0)),
          snoise(uv * 1.5 + vec2(0.0, t * 0.25))
        ) * 0.3;
        vec2 uv2 = uv + warp;
        float n1 = snoise(uv2 * 1.8 + vec2(t * 0.35, t * 0.25));
        float n2 = snoise(uv2 * 3.0 + vec2(-t * 0.3, t * 0.4));
        float n3 = snoise(uv2 * 5.0 + vec2(t * 0.2, -t * 0.3));
        float n4 = snoise(uv * 0.8 + vec2(t * 0.1, t * 0.15));
        float noise = n1 * 0.4 + n2 * 0.25 + n3 * 0.15 + n4 * 0.2;
        vec3 col1 = vec3(0.31, 0.224, 0.965);
        vec3 col2 = vec3(0.38, 0.373, 1.0);
        vec3 col3 = vec3(0.647, 0.706, 0.988);
        vec3 col4 = vec3(0.933, 0.949, 1.0);
        vec3 white = vec3(0.98, 0.98, 0.976);
        vec3 color = mix(white, col4, smoothstep(-0.5, 0.3, noise) * 0.6);
        color = mix(color, col3, smoothstep(-0.2, 0.5, noise) * 0.5);
        color = mix(color, col2, smoothstep(0.0, 0.7, noise) * 0.35);
        color = mix(color, col1, smoothstep(0.2, 0.9, noise) * 0.2);
        color = mix(white, color, 0.85);
        gl_FragColor = vec4(color, 1.0);
      }
    `;

    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const w = container.offsetWidth;
    const h = container.offsetHeight;
    renderer.setSize(w, h, false);

    const uniforms = {
      uTime: { value: 0 },
      uResolution: { value: new THREE.Vector2(w, h) },
    };

    const material = new THREE.ShaderMaterial({ vertexShader: VERTEX_SHADER, fragmentShader: FRAGMENT_SHADER, uniforms });
    const geometry = new THREE.PlaneGeometry(2, 2);
    scene.add(new THREE.Mesh(geometry, material));

    const clock = new THREE.Clock();
    let animId: number;
    let running = false;

    const animate = () => {
      if (!running) return;
      uniforms.uTime.value = clock.getElapsedTime();
      renderer.render(scene, camera);
      animId = requestAnimationFrame(animate);
    };

    const start = () => {
      if (running) return;
      running = true;
      clock.start();
      animate();
    };

    const stop = () => {
      running = false;
      cancelAnimationFrame(animId);
      clock.stop();
    };

    const resize = () => {
      const nw = container.offsetWidth;
      const nh = container.offsetHeight;
      renderer.setSize(nw, nh, false);
      uniforms.uResolution.value.set(nw, nh);
    };

    const ro = new ResizeObserver(resize);
    ro.observe(container);

    // IntersectionObserver to pause/resume when off-screen
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          start();
        } else {
          stop();
        }
      },
      { threshold: 0 }
    );
    io.observe(container);

    return () => {
      stop();
      io.disconnect();
      ro.disconnect();
      renderer.dispose();
      geometry.dispose();
      material.dispose();
    };
  }

  // Init all canvases
  initThreeCanvas('modules-canvas-0');
  initThreeCanvas('modules-canvas-1');
  initThreeCanvas('modules-canvas-2');
</script>
