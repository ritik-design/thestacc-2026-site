---
interface Props {
  heading?: string;
  subtitle?: string;
}
const {
  heading = 'Rank Everywhere.<br />Do Nothing.',
  subtitle = '30 blog posts published. GBP updated daily. Social media handled. Every month compounds on the last.',
} = Astro.props;
