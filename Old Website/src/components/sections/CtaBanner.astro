<section class="bg-white px-6 py-12">
  <div class="mx-auto max-w-[960px] overflow-hidden rounded-[20px] bg-[#615fff]">
    <div class="flex flex-col items-center gap-8 px-8 py-12 md:flex-row md:items-center md:gap-8 md:px-14 md:py-14">
      <!-- Left: Text + CTA -->
      <div class="flex-1 text-center md:text-left">
        <h3 class="font-serif text-[28px] leading-[36px] font-normal text-white md:text-[32px] md:leading-[40px]">
<Fragment set:html={heading} />
        </h3>
        <p class="mx-auto mt-4 max-w-[380px] font-sans text-[16px] leading-[24px] text-white/90 md:mx-0">
          {subtitle}
        </p>
        <a
          href="/demo/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 inline-flex h-[42px] items-center gap-2 rounded-[12px] bg-white px-6 font-mono text-[14px] font-semibold uppercase text-[#4f39f6] transition-colors hover:bg-white/90"
