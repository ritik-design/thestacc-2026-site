---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  seo: any;
  title: string;
  lastUpdated: string;
  toc: { id: string; label: string }[];
}

const { seo, title, lastUpdated, toc } = Astro.props;
---
<BaseLayout seo={seo}>
  <article class="legal-article">
    <div class="legal-header">
      <span class="legal-eyebrow">Legal</span>
      <h1 class="legal-title">{title}</h1>
      <p class="legal-meta">Last updated: {lastUpdated}</p>
    </div>

    <nav class="legal-toc" aria-label="On this page">
      <span class="legal-toc-label">On this page</span>
      <div class="legal-toc-links">
        {toc.map((item) => (
          <a href={`#${item.id}`} data-target={item.id}>{item.label}</a>
        ))}
      </div>
    </nav>

    <div class="legal-body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .legal-article {
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 24px 120px;
    background: var(--bg);
  }

  .legal-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
    position: static;
    top: auto;
    z-index: auto;
  }

  .legal-eyebrow {
    display: inline-block;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand);
    font-weight: 600;
    margin-bottom: 16px;
  }

  .legal-title {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--text-1);
    margin-bottom: 16px;
  }

  .legal-meta {
    font-size: 15px;
    color: var(--text-3);
    margin: 0;
  }

  .legal-toc {
    margin-bottom: 48px;
    padding: 20px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
  }

  .legal-toc-label {
    display: block;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    font-weight: 600;
    margin-bottom: 14px;
  }

  .legal-toc-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .legal-toc-links a {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    background: var(--bg);
    border: 1px solid var(--border);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-2);
    transition: all 0.15s ease;
    text-decoration: none;
  }

  .legal-toc-links a:hover,
  .legal-toc-links a.active {
    border-color: var(--brand);
    color: var(--brand);
    background: var(--brand-softer);
  }

  .legal-body {
    color: var(--text-2);
    font-size: 16px;
    line-height: 1.7;
  }

  .legal-body section {
    margin-bottom: 56px;
    scroll-margin-top: 140px;
  }

  .legal-body section:last-child {
    margin-bottom: 0;
  }

  .legal-body h2 {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-1);
    line-height: 1.25;
    margin-bottom: 18px;
  }

  .legal-body h3 {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-1);
    line-height: 1.35;
    margin-top: 28px;
    margin-bottom: 12px;
  }

  .legal-body p {
    margin-bottom: 16px;
  }

  .legal-body p:last-child {
    margin-bottom: 0;
  }

  .legal-body ul {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .legal-body li {
    position: relative;
    padding-left: 22px;
    font-size: 16px;
    line-height: 1.6;
  }

  .legal-body li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 7px;
    height: 7px;
    background: var(--brand);
  }

  .legal-body li strong,
  .legal-body p strong {
    color: var(--text-1);
    font-weight: 600;
  }

  .legal-body a {
    color: var(--brand);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .legal-body a:hover {
    color: var(--brand-deep);
  }

  @media (max-width: 640px) {
    .legal-article {
      padding: 48px 20px 80px;
    }

    .legal-toc-links {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .legal-toc-links::-webkit-scrollbar {
      display: none;
    }

    .legal-toc-links a {
      white-space: nowrap;
      flex-shrink: 0;
    }

    .legal-body section {
      scroll-margin-top: 130px;
    }
  }

  @media print {
    .legal-toc {
      display: none;
    }

    .legal-body a {
      color: var(--text-1);
      text-decoration: none;
    }

    .legal-body a::after {
      content: ' (' attr(href) ')';
      font-size: 12px;
      color: var(--text-3);
    }
  }
</style>

<script>
  (function () {
    const links = Array.from(document.querySelectorAll('.legal-toc-links a'));
    if (!links.length) return;

    const sections = links
      .map((a) => document.getElementById(a.getAttribute('data-target') || ''))
      .filter(Boolean);
    if (!sections.length) return;

    function onScroll() {
      const scrollY = window.scrollY + 130;
      let current = sections[0];
      for (const s of sections) {
        if (s.offsetTop <= scrollY) current = s;
      }
      links.forEach((a) => {
        a.classList.toggle('active', a.getAttribute('data-target') === current.id);
      });
    }

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
