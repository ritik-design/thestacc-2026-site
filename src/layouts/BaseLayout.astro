  // ─── Case-studies carousel · infinite loop ───
  (function() {
    const carousel = document.getElementById('casesCarousel');
    const track = document.getElementById('casesTrack');
    const dotsRow = document.getElementById('casesDots');
    if (!carousel || !track || !dotsRow) return;
    const originals = Array.from(track.querySelectorAll('.case-slide'));
    if (!originals.length) return;
    const N = originals.length;
    // Clone all originals once so the track has [A, B, C, A', B', C']
    originals.forEach(s => track.appendChild(s.cloneNode(true)));
    const all = Array.from(track.querySelectorAll('.case-slide'));
    let idx = 0;
    let paused = false;
    let timer;
    let snapping = false;
    originals.forEach((_, i) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.ariaLabel = 'Case study ' + (i + 1);
      b.addEventListener('click', () => { idx = i; render(true); restartAuto(); });
      dotsRow.appendChild(b);
    });
    const dots = Array.from(dotsRow.querySelectorAll('button'));
    function getOffset(i) {
      const slideW = all[0].getBoundingClientRect().width;
      return i * (slideW + 16);
    }
    function render(animated) {
      all.forEach((s, i) => s.classList.toggle('is-active', (i % N) === (idx % N)));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === (idx % N)));
      track.style.transition = animated ? '' : 'none';
      track.style.transform = 'translateX(-' + getOffset(idx) + 'px)';
      if (!animated) track.offsetWidth; // force reflow before re-enabling transition
    }
    function next() {
      idx++;
      render(true);
      // When we've moved past the original set, snap back to the equivalent original-index
      // immediately after the transition finishes, with no animation, so the loop is seamless.
      if (idx >= N) {
        snapping = true;
        setTimeout(() => {
          idx = idx - N;
          render(false);
          snapping = false;
        }, 720); // matches the .cases-track transition duration
      }
    }
    function startAuto() { timer = setInterval(() => { if (!paused && !snapping) next(); }, 4500); }
    function restartAuto() { clearInterval(timer); startAuto(); }
    carousel.addEventListener('mouseenter', () => { paused = true; });
    carousel.addEventListener('mouseleave', () => { paused = false; });
    window.addEventListener('resize', () => render(false));
    render(false);
    startAuto();
  })();

