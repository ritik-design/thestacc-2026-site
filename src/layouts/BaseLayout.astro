  }
  .video-meta-row .item { display: inline-flex; align-items: center; gap: 8px; }
  .video-meta-row .item svg { width: 14px; height: 14px; color: var(--brand); }

  /* ═══════════════════════════════════════════════
     AUTO-CYCLING PRODUCT TABS
     ═══════════════════════════════════════════════ */
  /* ═══════════════════════════════════════════════
     MODULES BENTO GRID
     ═══════════════════════════════════════════════ */
  .modules-bento { padding: 96px 32px; background: var(--bg-soft); }
  .modules-bento .modules-tabs-header { text-align: center; max-width: 760px; margin: 0 auto 56px; padding: 0; }
  .modules-bento .modules-tabs-header .label-pill { margin-bottom: 18px; }
  .modules-bento .modules-tabs-header h2 { margin-bottom: 16px; }
  .modules-bento .modules-tabs-header .lede { font-size: 17px; line-height: 1.55; color: var(--text-2); }
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 16px;
    max-width: 1180px; margin: 0 auto;
  }
  .bento-card {
    position: relative; display: flex; flex-direction: column;
    background: white; border: 1px solid var(--border);
    padding: 32px;
    text-decoration: none; color: inherit;
    transition: border-color 0.2s, transform 0.25s, box-shadow 0.25s;
    overflow: hidden;
  }
  .bento-card:hover { border-color: var(--brand); transform: translateY(-3px); box-shadow: 0 20px 40px -16px rgba(79,57,246,0.18); }
  .bento-feature {
    background: linear-gradient(180deg, var(--brand-softer) 0%, white 60%);
  }
  /* Third card spans both columns (Social Media full width on row 2) */
  .bento-grid .bento-card:nth-child(3) { grid-column: 1 / -1; }
  .bento-grid .bento-card:nth-child(3) { display: grid; grid-template-columns: 1.2fr 1fr; gap: 28px; align-items: stretch; }
  .bento-grid .bento-card:nth-child(3) > .bento-num,
  .bento-grid .bento-card:nth-child(3) > .bento-icon,
  .bento-grid .bento-card:nth-child(3) > .bento-title,
  .bento-grid .bento-card:nth-child(3) > .bento-sub,
  .bento-grid .bento-card:nth-child(3) > .bento-desc,
  .bento-grid .bento-card:nth-child(3) > .bento-cta { grid-column: 1; }
  .bento-grid .bento-card:nth-child(3) > .bento-mock { grid-column: 2; grid-row: 2 / span 5; margin-top: 0; align-self: stretch; }
  .bento-num { position: absolute; top: 28px; right: 32px; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; color: var(--text-3); }
  .bento-icon {
    width: 44px; height: 44px;
    background: var(--brand-softer); color: var(--brand);
    border: 1px solid var(--brand-soft);
    display: grid; place-items: center;
    margin-bottom: 20px;
  }
  .bento-icon svg { width: 22px; height: 22px; }
  .bento-title { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--brand); margin: 0 0 10px; }
  .bento-sub { font-size: 22px; line-height: 1.22; font-weight: 600; letter-spacing: -0.02em; color: var(--text-1); margin: 0 0 12px; }
  .bento-feature .bento-sub { font-size: 22px; line-height: 1.22; }
  .bento-desc { font-size: 14px; line-height: 1.55; color: var(--text-2); margin: 0 0 16px; }
  .bento-list { list-style: none; padding: 0; margin: 0 0 18px; display: flex; flex-direction: column; gap: 8px; }
  .bento-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: var(--text-2); line-height: 1.45; }
  .bento-list li svg { color: var(--brand); flex-shrink: 0; margin-top: 3px; }

  /* Mockup variants inside cards — sit naturally after content, no auto-stretch */
  .bento-mock {
    margin-top: 0; background: white; border: 1px solid var(--border);
    padding: 16px; display: flex; flex-direction: column; gap: 10px;
  }
  .bento-card { padding: 28px; }
  .bento-feature { padding: 28px; }
  .bento-cta { margin-top: 18px; }
  .bento-mock-bar { display: flex; justify-content: space-between; align-items: center; }
  .bento-mock-meta { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--brand); letter-spacing: 0.08em; }
  .bento-mock-pulse { width: 6px; height: 6px; background: var(--accent-emerald); border-radius: 50% !important; box-shadow: 0 0 8px var(--accent-emerald); animation: pulseDot 1.8s infinite; }
  .bento-mock-title { font-size: 14px; font-weight: 600; line-height: 1.3; color: var(--text-1); }
  .bento-mock-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .bento-mock-tag { padding: 3px 8px; background: var(--bg-soft); border: 1px solid var(--border); font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-2); }
  .bento-mock-tag.brand { background: var(--brand-softer); border-color: rgba(79,57,246,0.2); color: var(--brand); }

  /* Local SEO map-pin grid */
  .bento-mock-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px;
    background: white;
  }
  .bento-grid-pin {
    aspect-ratio: 1; display: grid; place-items: center;
    background: var(--bg-soft); border: 1px solid var(--border);
    font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 600;
    color: var(--text-3);
    transition: transform 0.2s;
  }
  .bento-grid-pin.top3 { background: var(--brand); color: white; border-color: var(--brand); }
  .bento-card:hover .bento-grid-pin.top3 { transform: scale(1.05); }

  /* Social schedule rows */
  .bento-mock-social { gap: 8px; }
  .bento-social-row { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 10px; padding: 8px 10px; background: var(--bg-soft); border: 1px solid var(--border); }
  .bento-social-icon {
    width: 22px; height: 22px; background: var(--brand); color: white;
    display: grid; place-items: center;
    font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700;
  }
  .bento-social-text { font-size: 12px; color: var(--text-2); }
  .bento-social-status { color: var(--accent-emerald); font-size: 10px; }

  .bento-cta {
    margin-top: 18px; display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--brand);
  }
  .bento-cta .arrow { transition: transform 0.2s; }
  .bento-card:hover .bento-cta .arrow { transform: translateX(4px); }

  @media (max-width: 900px) {
    .bento-grid { grid-template-columns: 1fr; }
    .bento-feature { grid-row: span 1; }
  }

  .product-tabs { background: var(--bg-soft); padding-top: 96px; }
  .modules-tabs-header { text-align: center; max-width: 720px; margin: 0 auto 56px; padding: 0 32px; }
  .modules-tabs-header .label-pill { margin-bottom: 18px; }
  .modules-tabs-header h2 { margin-bottom: 16px; }
  .modules-tabs-header .lede { font-size: 17px; line-height: 1.55; color: var(--text-2); }
  .tabs-row { display: grid; grid-template-columns: repeat(3, 1fr); border-bottom: 1px solid var(--border); border-top: 1px solid var(--border); position: relative; background: white; max-width: 1180px; margin: 0 auto; border-left: 1px solid var(--border); border-right: 1px solid var(--border); }
  .tab-button {
    padding: 24px 16px; text-align: center; font-size: 16px; font-weight: 500;
    color: var(--text-3); border-right: 1px solid var(--border);
    transition: color 0.2s; position: relative; background: transparent;
    text-decoration: none; cursor: pointer; display: block;
  }
  .tab-button:last-child { border-right: none; }
  .tab-button:hover { color: var(--text-1); }
  .tab-button.active { color: var(--text-1); }
  .tab-link { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: var(--brand); text-decoration: none; padding: 10px 0; }
  .tab-link .arrow { transition: transform 0.2s; }
  .tab-link:hover .arrow { transform: translateX(4px); }
  /* Progress bar indicator (animated underneath active tab) */
  .tab-progress {
    position: absolute; bottom: 0; left: 0;
    height: 2px; background: var(--brand);
    transition: transform 0.5s cubic-bezier(.2,.8,.2,1);
    transform-origin: left;
    width: 33.3333%;
  }
  .tab-progress::after {
    content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(90deg, var(--brand) var(--p, 0%), rgba(79,57,246,0.2) var(--p, 0%));
  }

  .tab-content-wrap { padding: 80px 48px; min-height: 480px; }
  .tab-pane { display: none; max-width: 1100px; margin: 0 auto; }
  .tab-pane.active { display: grid; animation: fadePane 0.5s ease forwards; }
  @keyframes fadePane { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .tab-pane { grid-template-columns: 5fr 7fr; gap: 64px; align-items: center; }
  .tab-text h3 { margin-bottom: 16px; }
  .tab-text p { font-size: 17px; margin-bottom: 28px; max-width: 460px; }
  .tab-text ul { list-style: none; margin-bottom: 28px; }
  .tab-text li { display: flex; align-items: center; gap: 12px; font-size: 14px; color: var(--text-2); padding: 6px 0; }
  .tab-text li .icon { width: 18px; height: 18px; color: var(--brand); }
  .tab-visual { background: white; border: 1px solid var(--border); border-radius: 16px; padding: 28px; min-height: 320px; box-shadow: 0 16px 40px -16px rgba(0,0,0,0.08); }

  /* Article mockup inside tabs */
  .mockup-article { display: flex; flex-direction: column; gap: 14px; }
  .mockup-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); letter-spacing: 0.05em; text-transform: uppercase; }
  .mockup-article h4 { font-size: 19px; line-height: 1.25; }
  .mockup-article p { font-size: 13px; color: var(--text-3); line-height: 1.5; }
  .mockup-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .mockup-tag { padding: 4px 9px; background: var(--bg-soft); border: 1px solid var(--border); border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-2); }
  .mockup-tag.brand { background: var(--brand-softer); border-color: rgba(79,57,246,0.2); color: var(--brand); }

  @media (max-width: 900px) {
    .tab-pane { grid-template-columns: 1fr; }
    .tabs-row { grid-template-columns: 1fr; }
    .tab-button { border-right: none; border-bottom: 1px solid var(--border); }
    .tab-button:last-child { border-bottom: none; }
    .tab-progress { display: none; }
  }

  /* ═══════════════════════════════════════════════
     STAT LINE — 4 cells with vertical dividers
     ═══════════════════════════════════════════════ */
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); }
  .stat-cell { padding: 56px 32px; text-align: center; border-right: 1px solid var(--border); transition: background 0.2s; }
  .stat-cell:hover { background: var(--bg-soft); }
  .stat-cell:last-child { border-right: none; }
  .stat-num { font-size: 56px; font-weight: 700; letter-spacing: -0.04em; line-height: 1; color: var(--text-1); }
  .stat-num .accent { color: var(--brand); font-weight: 700; }
  .stat-label { margin-top: 12px; font-size: 13px; color: var(--text-3); }
  @media (max-width: 768px) { .stats-row { grid-template-columns: 1fr 1fr; } .stat-cell:nth-child(2) { border-right: none; } .stat-cell:nth-child(1), .stat-cell:nth-child(2) { border-bottom: 1px solid var(--border); } }

  /* ═══════════════════════════════════════════════
     SERP BATTLE SECTION
     ═══════════════════════════════════════════════ */
  .serp-section { padding: 96px 32px 0; background: var(--bg-soft); }
  .serp-header { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .serp-header .label-pill { margin-bottom: 24px; }
  .serp-header h2 { margin-bottom: 16px; }
  .serp-header p { font-size: 18px; color: var(--text-2); }
  .serp-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; max-width: 1180px; margin: 0 auto; align-items: stretch; padding-bottom: 96px; }
  .serp-mock {
    background: white; border: 1px solid var(--border); border-radius: 16px;
    overflow: hidden; box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 30px 60px -20px rgba(0,0,0,0.12);
    display: flex; flex-direction: column;
  }
  .serp-bar { display: flex; align-items: center; gap: 10px; padding: 14px 18px; border-bottom: 1px solid var(--border); background: var(--bg-soft); }
  .serp-bar .dot { width: 9px; height: 9px; border-radius: 50%; }
  .serp-bar .dot.r { background: #ff5f57; } .serp-bar .dot.y { background: #febc2e; } .serp-bar .dot.g { background: #28c840; }
  .serp-bar .search {
    flex: 1; margin-left: 12px; padding: 8px 16px; background: white;
    border: 1px solid var(--border); border-radius: 100px; font-size: 13px; color: var(--text-1);
    display: flex; align-items: center; gap: 8px; font-weight: 500;
  }
  .serp-bar .search svg { width: 12px; height: 12px; color: var(--text-3); }
  .serp-bar .live-pill {
    display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px;
    background: #fef2f2; border: 1px solid #fecaca; border-radius: 100px;
    font-family: 'Geist Mono', monospace; font-size: 10px; color: #dc2626; letter-spacing: 0.05em; text-transform: uppercase; font-weight: 600;
  }
  .serp-bar .live-pill::before { content: ''; width: 5px; height: 5px; background: #ef4444; border-radius: 50%; animation: pulseDot 1.4s infinite; }
  .serp-results { padding: 12px 18px 18px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .serp-result {
    padding: 14px 16px; border-radius: 10px; border: 1px solid transparent;
    transition: all 0.3s; position: relative;
  }
  .serp-result.competitor { background: #fafafa; }
  .serp-result.you { background: linear-gradient(180deg, #fff7ed 0%, #ffffff 100%); border-color: #fed7aa; }
  .serp-result .rank {
    position: absolute; top: 14px; right: 14px;
    font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .serp-result .url { font-size: 11px; color: #5e9954; margin-bottom: 4px; font-family: 'Geist Mono', monospace; }
  .serp-result .title { font-size: 15px; font-weight: 500; color: #1a0dab; margin-bottom: 6px; line-height: 1.3; }
  .serp-result.you .title { color: #b45309; }
  .serp-result .snippet { font-size: 12px; color: var(--text-2); line-height: 1.5; }
  .serp-result.you .you-badge {
    display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px;
    background: #fed7aa; color: #9a3412; border-radius: 100px;
    font-family: 'Geist Mono', monospace; font-size: 9px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 8px;
  }
  .serp-page-jump { padding: 10px 16px; text-align: center; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); border-top: 1px dashed var(--border); border-bottom: 1px dashed var(--border); margin: 4px 0; }
  .serp-footer { padding: 14px 18px; border-top: 1px solid var(--border); background: var(--bg-soft); display: flex; justify-content: space-between; align-items: center; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); }
  .serp-footer .right { color: #dc2626; font-weight: 600; }

  /* SERP right column copy */
  .serp-copy { padding: 24px 0; display: flex; flex-direction: column; justify-content: center; }
  .serp-copy h3 { font-size: 32px; font-weight: 600; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 20px; color: var(--text-1); }
  .serp-copy h3 .accent { color: var(--brand); }
  .serp-copy p { font-size: 16px; color: var(--text-2); line-height: 1.6; margin-bottom: 24px; }
  .serp-stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--border); border-radius: 12px; background: white; }
  .serp-stat-cell { padding: 16px; border-right: 1px solid var(--border); }
  .serp-stat-cell:last-child { border-right: none; }
  .serp-stat-cell .v { font-size: 22px; font-weight: 700; color: var(--brand); letter-spacing: -0.02em; line-height: 1; }
  .serp-stat-cell .l { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 8px; }

  @media (max-width: 880px) { .serp-grid { grid-template-columns: 1fr; gap: 32px; } }

  /* ═══════════════════════════════════════════════
     PROBLEM SECTION (Saaly 3x3 grid)
     ═══════════════════════════════════════════════ */
  .problem-section { padding: 96px 32px 0; }
  .problem-header { text-align: center; max-width: 720px; margin: 0 auto 64px; }
  .problem-header .label-pill { margin-bottom: 24px; }
  .problem-header h2 { margin-bottom: 16px; }
  .problem-header p { font-size: 18px; }

  .saaly-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr 1fr;
    grid-template-rows: auto auto auto;
    border-top: 1px solid var(--border);
    border-left: 1px solid var(--border);
    position: relative;
  }
  /* Plus-sign markers at grid intersections */
  .saaly-grid::before,
  .saaly-grid::after {
    content: ''; position: absolute;
    width: 1px; height: 1px;
    background: var(--border-strong);
  }
  .saaly-cell { padding: 32px; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); min-height: 180px; display: flex; flex-direction: column; justify-content: center; position: relative; }
  .saaly-cell.center { grid-row: span 3; background: var(--bg-soft); align-items: center; justify-content: center; padding: 40px; }
  .saaly-cell h4 { margin-bottom: 8px; }
  .saaly-cell p { font-size: 14px; color: var(--text-3); line-height: 1.5; }
  .saaly-cell .cell-num { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); letter-spacing: 0.1em; margin-bottom: 12px; }

  /* Center cell visual */
  .center-visual { width: 100%; max-width: 280px; aspect-ratio: 1; background: white; border: 1px solid var(--border); border-radius: 14px; padding: 24px; box-shadow: 0 8px 24px -8px rgba(0,0,0,0.06); display: flex; flex-direction: column; justify-content: space-between; }
  .cv-label { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px; }
  .cv-chart { flex: 1; display: flex; align-items: end; gap: 6px; height: 110px; padding: 12px 0; }
  .cv-bar { flex: 1; background: linear-gradient(180deg, var(--border-strong), var(--border)); border-radius: 4px; }
  .cv-bar:nth-child(1) { height: 40%; }
  .cv-bar:nth-child(2) { height: 30%; background: linear-gradient(180deg, var(--brand), var(--brand-deep)); }
  .cv-bar:nth-child(3) { height: 60%; }
  .cv-bar:nth-child(4) { height: 35%; background: linear-gradient(180deg, var(--brand), var(--brand-deep)); }
  .cv-bar:nth-child(5) { height: 80%; }
  .cv-bar:nth-child(6) { height: 50%; background: linear-gradient(180deg, var(--brand), var(--brand-deep)); }
  .cv-footer { font-size: 13px; font-weight: 600; text-align: center; color: var(--text-1); margin-top: 8px; }
  .cv-footer .accent { color: var(--brand); }

  @media (max-width: 900px) { .saaly-grid { grid-template-columns: 1fr; } .saaly-cell.center { grid-row: auto; } }

  /* ═══════════════════════════════════════════════
     SOLUTION INTRO
     ═══════════════════════════════════════════════ */
  .solution-section { padding: 120px 32px; }
  .solution-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 96px; max-width: 1100px; margin: 0 auto; align-items: end; }
  .solution-left .label-pill { margin-bottom: 24px; }
  .solution-right { font-size: 18px; line-height: 1.6; color: var(--text-2); padding-bottom: 8px; }
  .solution-right strong { color: var(--text-1); font-weight: 600; }
  @media (max-width: 900px) { .solution-grid { grid-template-columns: 1fr; gap: 32px; } }

  /* ═══════════════════════════════════════════════
     FEATURE ALTERNATING SECTIONS (Saaly pattern)
     ═══════════════════════════════════════════════ */
  .feature-block { padding: 0; border-bottom: 1px solid var(--border); }
  .feature-block:last-of-type { border-bottom: 1px solid var(--border); }
  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 480px;
  }
  .feature-grid.reverse > div:first-child { order: 2; }
  .feature-text {
    padding: 64px 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid var(--border);
  }
  .feature-grid.reverse .feature-text { border-right: none; border-left: 1px solid var(--border); }
  .feature-text .feature-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
  .feature-text h3 { margin-bottom: 20px; }
  .feature-text p { font-size: 17px; line-height: 1.55; margin-bottom: 28px; max-width: 420px; }
  .feature-text ul { list-style: none; margin-bottom: 28px; }
  .feature-text li { display: flex; align-items: start; gap: 10px; font-size: 15px; color: var(--text-2); padding: 6px 0; }
  .feature-text li .icon { width: 18px; height: 18px; color: var(--brand); margin-top: 2px; flex-shrink: 0; }
  .feature-text a.cta-link { display: inline-flex; align-items: center; gap: 8px; color: var(--brand); font-weight: 500; font-size: 15px; }
  .feature-text a.cta-link:hover { gap: 12px; }

  .feature-visual { padding: 64px 56px; background: var(--bg-soft); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
  .feature-visual::before {
    content: ''; position: absolute; inset: 0;
    background-image: linear-gradient(rgba(0,0,0,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.025) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
  }
  .feature-visual > * { position: relative; z-index: 1; }

  /* Chat mockup */
  .feature-chat { background: white; border: 1px solid var(--border); border-radius: 14px; padding: 20px; width: 100%; max-width: 380px; box-shadow: 0 16px 40px -16px rgba(79,57,246,0.15); }
  .feature-chat-top { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .feature-chat-avatar { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, var(--brand), var(--brand-bright)); }
  .feature-chat-name { font-size: 14px; font-weight: 600; }
  .feature-chat-status { font-size: 11px; color: var(--accent-emerald); }
  .feature-chat-message { padding: 12px 14px; background: var(--bg-soft); border-radius: 12px; font-size: 13px; line-height: 1.5; margin-bottom: 8px; }
  .feature-chat-message.user { background: var(--brand-softer); margin-left: 32px; color: var(--text-1); }
  .feature-chat-tags { display: flex; gap: 6px; margin-top: 12px; flex-wrap: wrap; }
  .feature-chat-tag { padding: 4px 10px; background: white; border: 1px solid var(--border); border-radius: 6px; font-size: 11px; color: var(--text-2); cursor: pointer; transition: all 0.15s; }
  .feature-chat-tag:hover { border-color: var(--brand); color: var(--brand); }

  /* Workflow mockup */
  .feature-workflow { display: flex; flex-direction: column; gap: 8px; width: 100%; max-width: 380px; }
  .workflow-card { padding: 12px 14px; background: white; border: 1px solid var(--border); border-radius: 12px; display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 12px -4px rgba(0,0,0,0.04); position: relative; }
  .workflow-card::before { content: ''; position: absolute; bottom: -8px; left: 24px; width: 2px; height: 8px; background: var(--brand); opacity: 0.4; }
  .workflow-card:last-child::before { display: none; }
  .workflow-icon { width: 28px; height: 28px; border-radius: 6px; background: var(--brand-softer); color: var(--brand); display: grid; place-items: center; flex-shrink: 0; }
  .workflow-icon svg { width: 14px; height: 14px; }
  .workflow-text { flex: 1; }
  .workflow-title { font-size: 13px; font-weight: 500; }
  .workflow-meta { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); }
  .workflow-status { font-family: 'Geist Mono', monospace; font-size: 10px; padding: 3px 8px; border-radius: 100px; }
  .workflow-status.done { background: rgba(16,185,129,0.1); color: var(--accent-emerald); }
  .workflow-status.live { background: var(--brand-softer); color: var(--brand); }

  /* Insights mockup */
  .feature-insights { width: 100%; max-width: 380px; background: white; border: 1px solid var(--border); border-radius: 14px; padding: 20px; box-shadow: 0 16px 40px -16px rgba(79,57,246,0.15); }
  .insights-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .insights-title { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.1em; text-transform: uppercase; }
  .insights-num { font-size: 36px; font-weight: 700; letter-spacing: -0.025em; line-height: 1; margin-bottom: 6px; }
  .insights-delta { font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--accent-emerald); padding: 3px 8px; background: rgba(16,185,129,0.1); border-radius: 100px; display: inline-block; }
  .insights-chart { margin-top: 16px; height: 100px; position: relative; }
  .insights-chart svg { width: 100%; height: 100%; }

  @media (max-width: 900px) {
    .feature-grid { grid-template-columns: 1fr; min-height: auto; }
    .feature-grid.reverse > div:first-child { order: 1; }
    .feature-text { border-right: none; border-bottom: 1px solid var(--border); padding: 48px 32px; }
    .feature-grid.reverse .feature-text { border-left: none; border-bottom: 1px solid var(--border); }
    .feature-visual { padding: 48px 32px; }
  }

  /* ═══════════════════════════════════════════════
     HOW IT WORKS — 3-step journey, purple visuals
     ═══════════════════════════════════════════════ */
  .howitworks-section { padding: 96px 0 0; background: white; }
  .howitworks-header { text-align: center; max-width: 760px; margin: 0 auto 64px; padding: 0 32px; }
  .howitworks-header .label-pill { margin-bottom: 18px; }
  .howitworks-header h2 { margin-bottom: 16px; }
  .howitworks-header .lede { font-size: 17px; line-height: 1.55; color: var(--text-2); }

  .step-block { border-top: 1px solid var(--border); }
  .step-block:last-child { border-bottom: 1px solid var(--border); }
  .step-grid { display: grid; grid-template-columns: 1fr 1fr; min-height: 520px; }
  .step-grid.reverse > div:first-child { order: 2; }
  .step-text {
    padding: 64px 56px;
    display: flex; flex-direction: column; justify-content: center;
    border-right: 1px solid var(--border);
  }
  .step-grid.reverse .step-text { border-right: none; border-left: 1px solid var(--border); }
  .step-meta { display: inline-flex; align-items: center; gap: 14px; margin-bottom: 22px; }
  .step-num {
    width: 36px; height: 36px;
    background: var(--brand); color: white;
    font-family: 'Geist Mono', monospace; font-size: 14px; font-weight: 600;
    display: grid; place-items: center;
    border-radius: 100px !important;
  }
  .step-day { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); }
  .step-text h3 { margin-bottom: 20px; }
  .step-text p { font-size: 17px; line-height: 1.55; margin-bottom: 28px; max-width: 480px; }
  .step-text ul { list-style: none; padding: 0; margin: 0; }
  .step-text li { display: flex; align-items: flex-start; gap: 10px; font-size: 15px; color: var(--text-2); padding: 6px 0; }
  .step-text li .icon { width: 18px; height: 18px; color: var(--brand); margin-top: 2px; flex-shrink: 0; }

  /* LIGHT VISUAL CONTAINER (soft grid bg like the feature visuals) */
  .step-visual {
    padding: 64px 56px; background: var(--bg-soft);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .step-visual::before {
    content: ''; position: absolute; inset: 0;
    background-image: linear-gradient(rgba(0,0,0,0.025) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.025) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    pointer-events: none;
  }
  .step-visual > * { position: relative; z-index: 1; }

  /* PURPLE GLASS CARD inside the light container — the focal piece */
  .step-card-1, .step-card-2, .step-card-3 {
    width: 100%; max-width: 400px;
    background:
      linear-gradient(160deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.06) 100%),
      linear-gradient(160deg, var(--brand) 0%, var(--brand-deep) 100%);
    border: 1px solid rgba(255,255,255,0.18);
    backdrop-filter: blur(14px);
    padding: 22px;
    box-shadow: 0 24px 60px -16px rgba(79,57,246,0.45), 0 8px 24px -8px rgba(79,57,246,0.25), inset 0 1px 0 rgba(255,255,255,0.2);
    color: white;
    position: relative; overflow: hidden;
  }
  .step-card-1::before, .step-card-2::before, .step-card-3::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(255,255,255,0.22) 0%, transparent 70%);
    pointer-events: none;
  }
  .step-card-1 > *, .step-card-2 > *, .step-card-3 > * { position: relative; z-index: 1; }
  .step-card-header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 14px; margin-bottom: 14px; border-bottom: 1px solid rgba(255,255,255,0.15); }
  .step-card-tag { font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 600; letter-spacing: 0.12em; color: rgba(255,255,255,0.65); text-transform: uppercase; }
  .step-card-status { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--accent-emerald); font-weight: 600; }

  /* Step 1 — setup table */
  .step-card-row { display: flex; justify-content: space-between; gap: 14px; padding: 10px 0; border-bottom: 1px dashed rgba(255,255,255,0.1); }
  .step-card-row:last-child { border-bottom: none; }
  .step-card-row.highlight { background: rgba(255,255,255,0.08); margin: 6px -14px 0; padding: 12px 14px; border: 1px solid rgba(255,255,255,0.2); }
  .step-card-key { font-family: 'Geist Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.55); letter-spacing: 0.06em; text-transform: uppercase; }
  .step-card-val { font-size: 13px; color: white; text-align: right; }
  .step-card-row.highlight .step-card-val strong { color: white; font-weight: 600; }

  /* Step 2 — feed */
  .step-feed-item { display: grid; grid-template-columns: auto 64px 1fr; align-items: center; gap: 10px; padding: 9px 0; border-bottom: 1px dashed rgba(255,255,255,0.1); }
  .step-feed-item:last-child { border-bottom: none; }
  .step-feed-dot { width: 8px; height: 8px; border-radius: 50% !important; background: var(--accent-emerald); }
  .step-feed-dot.live { background: #fbbf24; box-shadow: 0 0 12px #fbbf24; animation: pulseDot 1.6s infinite; }
  .step-feed-time { font-family: 'Geist Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.55); letter-spacing: 0.04em; }
  .step-feed-text { font-size: 12.5px; color: rgba(255,255,255,0.92); line-height: 1.4; }
  .step-feed-text strong { color: white; font-weight: 600; }

  /* Step 3 — growth */
  .step-stat-big { display: flex; flex-direction: column; gap: 4px; padding: 6px 0 18px; }
  .step-stat-num { font-size: 44px; font-weight: 700; letter-spacing: -0.025em; line-height: 1; color: white; }
  .step-stat-label { font-size: 12px; color: rgba(255,255,255,0.65); }
  .step-stat-delta { font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--accent-emerald); margin-top: 4px; font-weight: 600; }
  .step-chart { height: 90px; margin-bottom: 14px; }
  .step-chart svg { width: 100%; height: 100%; display: block; }
  .step-stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; padding-top: 14px; border-top: 1px solid rgba(255,255,255,0.15); font-size: 12px; color: rgba(255,255,255,0.78); }
  .step-stat-row strong { color: white; font-size: 16px; font-weight: 700; display: block; margin-bottom: 2px; letter-spacing: -0.015em; }

  @media (max-width: 900px) {
    .step-grid { grid-template-columns: 1fr; min-height: auto; }
    .step-grid.reverse > div:first-child { order: 1; }
    .step-text { border-right: none; border-bottom: 1px solid var(--border); padding: 48px 32px; }
    .step-grid.reverse .step-text { border-left: none; }
    .step-visual { padding: 48px 32px; }
  }

  /* ═══════════════════════════════════════════════
     BENEFITS (Saaly 4-cell grid with custom icons)
     ═══════════════════════════════════════════════ */
  .benefits-section { padding: 96px 32px; background: var(--bg-soft); }
  .benefits-header { text-align: center; max-width: 720px; margin: 0 auto 64px; }
  .benefits-header .label-pill { margin-bottom: 20px; }
  .benefits-header h2 { margin-bottom: 16px; }

  .benefits-grid { display: grid; grid-template-columns: repeat(4, 1fr); background: white; border: 1px solid var(--border); }
  .benefit-cell { padding: 36px 28px; border-right: 1px solid var(--border); transition: background 0.3s; }
  .benefit-cell:last-child { border-right: none; }
  .benefit-cell:hover { background: var(--bg-soft); }
  .benefit-icon-box { width: 44px; height: 44px; border-radius: 10px; background: var(--brand-softer); color: var(--brand); display: grid; place-items: center; margin-bottom: 20px; transition: transform 0.3s; }
  .benefit-cell:hover .benefit-icon-box { transform: scale(1.1) rotate(-3deg); }
  .benefit-icon-box svg { width: 22px; height: 22px; }
  .benefit-cell h3 { margin-bottom: 8px; }
  .benefit-cell p { font-size: 13px; line-height: 1.5; color: var(--text-3); margin-bottom: 20px; }
  .benefit-stat { padding-top: 16px; border-top: 1px dashed var(--border); }
  .benefit-stat-num { font-size: 28px; font-weight: 700; letter-spacing: -0.025em; color: var(--text-1); font-family: 'Geist', sans-serif; }
  .benefit-stat-num .accent { color: var(--brand); font-weight: 700; }

  /* ═══════════════════════════════════════════════
     BEFORE / AFTER (Problem section)
     ═══════════════════════════════════════════════ */
  .ba-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    max-width: 1180px; margin: 0 auto;
    border: 1px solid var(--border);
    background: white;
  }
  .ba-col { padding: 40px 36px; display: flex; flex-direction: column; gap: 28px; }
  .ba-col.before { background: var(--bg-soft); }
  .ba-col.after { background: linear-gradient(180deg, var(--brand-softer) 0%, white 60%); }
  .ba-head { padding-bottom: 22px; border-bottom: 1px solid var(--border); }
  .ba-col.after .ba-head { border-bottom-color: rgba(79,57,246,0.15); }
  .ba-label { display: inline-block; font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; padding: 4px 10px; margin-bottom: 12px; }
  .ba-col.before .ba-label { background: rgba(220, 38, 38, 0.08); color: #b91c1c; }
  .ba-col.after .ba-label { background: var(--brand); color: white; }
  .ba-title { font-size: 26px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.15; color: var(--text-1); margin: 0 0 6px; }
  .ba-sub { font-size: 13px; color: var(--text-3); margin: 0; }
  .ba-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 22px; }
  .ba-list li { display: grid; grid-template-columns: 32px 1fr; gap: 14px; align-items: flex-start; }
  .ba-num {
    font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600;
    color: var(--text-3); letter-spacing: 0.08em;
    padding-top: 2px;
  }
  .ba-col.after .ba-num { color: var(--brand); }
  .ba-list h4 { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: var(--text-1); margin: 0 0 4px; line-height: 1.3; }
  .ba-list p { font-size: 13px; line-height: 1.55; color: var(--text-2); margin: 0; }
  .ba-divider {
    display: grid; place-items: center;
    width: 56px;
    background: white;
    border-left: 1px solid var(--border); border-right: 1px solid var(--border);
    font-size: 22px; color: var(--brand);
  }
  @media (max-width: 900px) {
    .ba-grid { grid-template-columns: 1fr; }
    .ba-divider { width: auto; height: 56px; border-left: none; border-right: none; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); transform: rotate(90deg); }
  }

  /* ─── Benefits cards · 200ms staggered entrance ─── */
  .benefit-cell.b-stagger { opacity: 0; transform: translateY(24px); transition: opacity 0.6s cubic-bezier(.2,.8,.2,1), transform 0.7s cubic-bezier(.2,.8,.2,1); }
  .benefit-cell.b-stagger.in { opacity: 1; transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) { .benefit-cell.b-stagger, .benefit-cell.b-stagger.in { opacity: 1; transform: none; transition: none; } }

  /* ─── Three jobs · highlight on scroll-into-view ─── */
  .hl-highlight { position: relative; display: inline-block; padding: 0 4px; }
  .hl-highlight::before {
    content: ''; position: absolute; left: 0; right: 0; bottom: 6%; height: 38%;
    background: linear-gradient(90deg, rgba(79,57,246,0.28) 0%, rgba(79,57,246,0.15) 100%);
    z-index: -1;
    transform: scaleX(0); transform-origin: left center;
    transition: transform 0.85s cubic-bezier(.2,.8,.2,1);
  }
  .hl-highlight.in::before { transform: scaleX(1); }
  @media (prefers-reduced-motion: reduce) { .hl-highlight::before { transform: scaleX(1); transition: none; } }
  .benefit-stat-label { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); margin-top: 2px; letter-spacing: 0.05em; }
  @media (max-width: 900px) { .benefits-grid { grid-template-columns: 1fr 1fr; } .benefit-cell:nth-child(2) { border-right: none; } .benefit-cell:nth-child(1), .benefit-cell:nth-child(2) { border-bottom: 1px solid var(--border); } }
  @media (max-width: 540px) { .benefits-grid { grid-template-columns: 1fr; } .benefit-cell { border-right: none; border-bottom: 1px solid var(--border); } .benefit-cell:last-child { border-bottom: none; } }

  /* ═══════════════════════════════════════════════
     ENGINE SECTION (premium AI engine)
     ═══════════════════════════════════════════════ */
  .engine-section { padding: 120px 32px 160px; position: relative; overflow: hidden; }
  .engine-section::after {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 800px 600px at 50% 30%, rgba(79,57,246,0.06) 0%, transparent 60%);
    z-index: 0; pointer-events: none;
  }
  .engine-section > * { position: relative; z-index: 1; }
  .engine-header { text-align: center; margin-bottom: 80px; }
  .engine-header .label-pill { margin-bottom: 24px; }
  .engine-header h2 { margin-bottom: 24px; max-width: 18ch; margin-left: auto; margin-right: auto; }
  .engine-header h2 .accent { background: linear-gradient(135deg, var(--brand) 0%, var(--brand-bright) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .engine-header p { font-size: 18px; max-width: 680px; margin: 0 auto; }

  .engine-arch { position: relative; max-width: 1140px; margin: 0 auto; z-index: 2; }
  .arch-svg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; }
  .arch-svg path { fill: none; }
  .arch-svg .connector { stroke: url(#engineGradient); stroke-width: 1.5; stroke-dasharray: 4 6; animation: flow 2s linear infinite; opacity: 0.5; }
  @keyframes flow { to { stroke-dashoffset: -20; } }
  .arch-svg .connector-glow { stroke: url(#engineGradient); stroke-width: 6; opacity: 0.15; filter: blur(8px); }

  .input-node-wrap { display: flex; justify-content: center; margin-bottom: 64px; position: relative; z-index: 2; }
  .input-node { display: inline-flex; align-items: center; padding: 12px 16px; background: white; border: 1px solid var(--border); border-radius: 100px; box-shadow: 0 12px 32px -8px var(--brand-glow), 0 4px 12px -4px rgba(0,0,0,0.04); position: relative; }
  .input-node::before { content: ''; position: absolute; inset: -1px; border-radius: 100px; padding: 1px; background: linear-gradient(135deg, transparent 30%, var(--brand) 50%, transparent 70%); -webkit-mask: linear-gradient(white,white) content-box, linear-gradient(white,white); -webkit-mask-composite: xor; mask-composite: exclude; opacity: 0.6; }
  .input-label { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); padding: 0 14px 0 6px; border-right: 1px solid var(--border); }
  .input-platforms { display: flex; align-items: center; gap: 4px; padding: 0 6px; }
  .input-platform { padding: 8px 14px; background: var(--bg-soft); border: 1px solid var(--border); border-radius: 100px; font-size: 13px; font-weight: 500; color: var(--text-2); display: flex; align-items: center; gap: 6px; transition: all 0.2s; }
  .input-platform:hover { background: var(--brand-softer); border-color: var(--brand); color: var(--brand); }
  .input-platform-dot { width: 6px; height: 6px; border-radius: 50%; }
  .input-platform[data-p="wp"] .input-platform-dot { background: #21759b; }
  .input-platform[data-p="webflow"] .input-platform-dot { background: #4353ff; }
  .input-platform[data-p="shopify"] .input-platform-dot { background: #95bf47; }
  .input-platform[data-p="ghost"] .input-platform-dot { background: #15171a; }
  .input-platform[data-p="custom"] .input-platform-dot { background: var(--brand); }

  .engine-tier-2 { display: grid; grid-template-columns: 1.4fr 1fr; gap: 32px; margin-bottom: 80px; position: relative; z-index: 2; }
  .ai-engine {
    background:
      radial-gradient(ellipse at top right, rgba(79, 57, 246, 0.3) 0%, transparent 60%),
      radial-gradient(ellipse at bottom left, rgba(79, 57, 246, 0.2) 0%, transparent 70%),
      linear-gradient(135deg, #0f0e2e 0%, #1a1a3e 50%, #0a0a1f 100%);
    border: 1px solid rgba(79, 57, 246, 0.3); border-radius: 24px; padding: 36px;
    color: white; position: relative; overflow: hidden;
    box-shadow: 0 0 0 1px rgba(79, 57, 246, 0.15), 0 24px 64px -12px rgba(79, 57, 246, 0.35), 0 16px 32px -8px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .ai-engine::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 0%, rgba(79, 57, 246, 0.6) 0%, transparent 30%); opacity: 0.4; pointer-events: none; }
  .ai-engine::after { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 24px 24px; pointer-events: none; }
  .ai-engine > * { position: relative; z-index: 1; }
  .ai-engine h3, .ai-engine h4 { color: white; }

  .engine-header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
  .engine-title { display: flex; align-items: center; gap: 12px; }
  .engine-orb { width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%); display: grid; place-items: center; color: white; position: relative; box-shadow: 0 0 20px var(--brand-glow), inset 0 1px 0 rgba(255,255,255,0.2); }
  .engine-orb::before { content: ''; position: absolute; inset: -2px; border-radius: 12px; background: linear-gradient(135deg, var(--brand-bright), transparent); opacity: 0.5; z-index: -1; animation: orbRotate 4s linear infinite; }
  @keyframes orbRotate { to { transform: rotate(360deg); } }
  .engine-orb svg { width: 20px; height: 20px; }
  .engine-name { font-size: 17px; font-weight: 600; letter-spacing: -0.01em; }
  .engine-subtitle { font-family: 'Geist Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.5); letter-spacing: 0.05em; margin-top: 2px; }
  .engine-status { display: flex; align-items: center; gap: 8px; padding: 6px 12px; background: rgba(79,57,246,0.15); border: 1px solid rgba(79,57,246,0.3); border-radius: 100px; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand-bright); font-weight: 500; }
  .engine-status::before { content: ''; width: 6px; height: 6px; background: var(--brand-bright); border-radius: 50%; box-shadow: 0 0 8px var(--brand-bright); animation: pulseDot 2s infinite; }

  .engine-capabilities { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 28px; }
  .capability { padding: 14px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; display: flex; align-items: center; gap: 12px; transition: all 0.3s; }
  .capability:hover { border-color: rgba(79, 57, 246, 0.5); transform: translateY(-2px); }
  .capability-icon { flex-shrink: 0; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; background: rgba(79, 57, 246, 0.15); border: 1px solid rgba(79, 57, 246, 0.3); color: var(--brand-bright); }
  .capability-icon svg { width: 14px; height: 14px; }
  .capability-name { font-size: 13px; font-weight: 500; color: white; }
  .capability-meta { font-family: 'Geist Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.4); margin-top: 2px; }

  .engine-workflow { padding: 14px; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; font-family: 'Geist Mono', monospace; font-size: 11px; }
  .workflow-label { color: rgba(255,255,255,0.4); letter-spacing: 0.08em; text-transform: uppercase; font-size: 10px; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
  .workflow-label::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.08); }
  .workflow-pipeline { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .workflow-node { padding: 6px 10px; background: rgba(79, 57, 246, 0.1); border: 1px solid rgba(79, 57, 246, 0.2); border-radius: 100px; color: white; font-size: 11px; display: inline-flex; align-items: center; gap: 6px; }
  .workflow-node .dot { width: 5px; height: 5px; background: var(--brand-bright); border-radius: 50%; animation: pulseDot 2s infinite; }
  .workflow-arrow { color: rgba(255,255,255,0.3); font-size: 10px; }

  .dashboard-card { background: white; border: 1px solid var(--border); border-radius: 24px; padding: 28px; box-shadow: 0 24px 48px -16px rgba(0,0,0,0.08), 0 8px 16px -8px rgba(0,0,0,0.04); display: flex; flex-direction: column; }
  .dashboard-header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 20px; margin-bottom: 20px; border-bottom: 1px solid var(--border); }
  .dashboard-title { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-3); font-weight: 500; }
  .dashboard-site { display: flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 600; }
  .dashboard-site-dot { width: 24px; height: 24px; background: linear-gradient(135deg, var(--accent-cyan), var(--brand)); border-radius: 6px; display: grid; place-items: center; color: white; font-size: 10px; font-weight: 700; }
  .dashboard-hero-metric { margin-bottom: 24px; }
  .dashboard-metric-label { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 8px; }
  .dashboard-metric-value { display: flex; align-items: baseline; gap: 12px; }
  .dashboard-metric-num { font-size: 44px; font-weight: 700; letter-spacing: -0.035em; line-height: 1; }
  .dashboard-metric-delta { font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 500; color: var(--brand); background: var(--brand-softer); padding: 4px 10px; border-radius: 100px; }
  .dashboard-metric-delta::before { content: '↑ '; }

  .dashboard-chart { flex: 1; margin-bottom: 24px; min-height: 100px; }
  .dashboard-chart svg { width: 100%; height: 100%; display: block; }
  .dashboard-chart path.area { fill: url(#dashGradient); opacity: 0; animation: fadeIn 1s 1.5s forwards; }
  .dashboard-chart path.line { stroke: var(--brand); stroke-width: 2.5; fill: none; stroke-linecap: round; stroke-dasharray: 800; stroke-dashoffset: 800; animation: drawLine 2s 0.5s ease-out forwards; }
  @keyframes drawLine { to { stroke-dashoffset: 0; } }
  @keyframes fadeIn { to { opacity: 1; } }
  .dashboard-chart .dot-marker { fill: var(--brand); opacity: 0; animation: fadeIn 0.3s forwards; }

  .dashboard-mini-metrics { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; padding-top: 20px; border-top: 1px solid var(--border); }
  .mini-metric-label { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 4px; }
  .mini-metric-num { font-size: 18px; font-weight: 700; letter-spacing: -0.02em; color: var(--text-1); }
  .mini-metric-num .accent { color: var(--brand); font-weight: 500; }

  @media (max-width: 968px) { .engine-tier-2 { grid-template-columns: 1fr; } }

  .output-cards { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; position: relative; z-index: 2; }
  .output-card { background: white; border: 1px solid var(--border); border-radius: 18px; padding: 22px; transition: all 0.3s cubic-bezier(.2,.8,.2,1); position: relative; overflow: hidden; }
  .output-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--brand), var(--brand-bright)); transform: scaleX(0); transform-origin: left; transition: transform 0.3s; }
  .output-card:hover { transform: translateY(-6px); box-shadow: 0 24px 48px -16px var(--brand-glow); border-color: var(--brand); }
  .output-card:hover::before { transform: scaleX(1); }
  .output-icon { width: 36px; height: 36px; border-radius: 9px; display: grid; place-items: center; margin-bottom: 14px; }
  .output-icon svg { width: 18px; height: 18px; }
  .output-card[data-c="1"] .output-icon { background: var(--brand-softer); color: var(--brand); }
  .output-card[data-c="2"] .output-icon { background: rgba(6,182,212,0.1); color: var(--accent-cyan); }
  .output-card[data-c="3"] .output-icon { background: rgba(245,158,11,0.1); color: var(--accent-amber); }
  .output-card[data-c="4"] .output-icon { background: rgba(236,72,153,0.1); color: var(--accent-pink); }
  .output-card[data-c="5"] .output-icon { background: rgba(79,57,246,0.1); color: var(--brand); }
  .output-name { font-size: 14px; font-weight: 600; letter-spacing: -0.01em; margin-bottom: 6px; }
  .output-desc { font-size: 12px; color: var(--text-3); line-height: 1.5; margin-bottom: 14px; min-height: 36px; }
  .output-stat { padding-top: 14px; border-top: 1px solid var(--border); display: flex; align-items: baseline; justify-content: space-between; }
  .output-stat-num { font-size: 20px; font-weight: 700; letter-spacing: -0.025em; }
  .output-stat-num .accent { color: var(--brand); font-weight: 700; }
  .output-stat-label { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); text-align: right; line-height: 1.3; }
  @media (max-width: 1100px) { .output-cards { grid-template-columns: repeat(2, 1fr); } }

  .activity-pills { position: absolute; inset: 0; pointer-events: none; z-index: 3; }
  .activity-pill { position: absolute; display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; background: white; border: 1px solid var(--border); border-radius: 100px; font-size: 13px; font-weight: 500; color: var(--text-1); box-shadow: 0 16px 32px -8px rgba(0,0,0,0.08), 0 4px 12px -4px var(--brand-glow); animation: float 8s ease-in-out infinite; opacity: 0; animation-fill-mode: forwards; }
  .activity-pill .check-icon { width: 18px; height: 18px; background: var(--brand); color: white; border-radius: 50%; display: grid; place-items: center; }
  .activity-pill .check-icon svg { width: 10px; height: 10px; }
  @keyframes float { 0% { opacity: 0; transform: translateY(20px); } 10% { opacity: 1; transform: translateY(0); } 50% { transform: translateY(-8px); } 90% { opacity: 1; } 100% { opacity: 0; transform: translateY(-20px); } }
  .activity-pill:nth-child(1) { top: 8%; left: 5%; animation-delay: 0.5s; }
  .activity-pill:nth-child(2) { top: 22%; right: 4%; animation-delay: 2s; }
  .activity-pill:nth-child(3) { top: 55%; left: 2%; animation-delay: 3.5s; }
  .activity-pill:nth-child(4) { bottom: 28%; right: 3%; animation-delay: 5s; }
  .activity-pill:nth-child(5) { bottom: 8%; left: 8%; animation-delay: 6.5s; }
  @media (max-width: 1100px) { .activity-pill:nth-child(2), .activity-pill:nth-child(4) { display: none; } }

  /* ═══════════════════════════════════════════════
     RESOURCES MARQUEE — auto-scrolling
     ═══════════════════════════════════════════════ */
  .resources-section { padding: 96px 0; background: var(--bg-soft); overflow: hidden; }
  .resources-header { text-align: center; max-width: 720px; margin: 0 auto 56px; padding: 0 32px; }
  .resources-header .label-pill { margin-bottom: 18px; }
  .resources-header h2 { margin-bottom: 16px; }
  .resources-marquee {
    position: relative; width: 100%; overflow: hidden;
    mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
  }
  .resources-track {
    display: flex; gap: 20px; padding: 4px 0;
    width: max-content;
    animation: marqueeScroll 60s linear infinite;
  }
  .resources-track:hover { animation-play-state: paused; }
  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .resource-card {
    flex: 0 0 320px; min-height: 240px;
    background: white; border: 1px solid var(--border);
    padding: 24px; display: flex; flex-direction: column;
    text-decoration: none; color: inherit;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .resource-card:hover { border-color: var(--brand); transform: translateY(-3px); box-shadow: 0 16px 32px -12px rgba(79,57,246,0.15); }
  .resource-icon {
    width: 38px; height: 38px;
    background: var(--brand-softer); color: var(--brand);
    display: grid; place-items: center;
    border: 1px solid var(--brand-soft);
    margin-bottom: 18px;
  }
  .resource-icon svg { width: 18px; height: 18px; }
  .resource-tag { font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); margin-bottom: 8px; }
  .resource-card h3 { font-size: 17px; font-weight: 600; letter-spacing: -0.015em; line-height: 1.25; margin: 0 0 8px; color: var(--text-1); }
  .resource-card p { font-size: 13px; line-height: 1.5; color: var(--text-2); margin: 0 0 18px; flex: 1; }
  .resource-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; color: var(--brand);
    margin-top: auto;
  }
  .resource-link svg { transition: transform 0.2s; }
  .resource-card:hover .resource-link svg { transform: translateX(4px); }

  /* ═══════════════════════════════════════════════
     MODULES — Three pillars
     ═══════════════════════════════════════════════ */
  .modules-section { padding: 96px 32px; background: white; }
  .modules-header { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .modules-header .label-pill { margin-bottom: 18px; }
  .modules-header h2 { margin-bottom: 16px; }
  .modules-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    max-width: 1180px; margin: 0 auto;
    border: 1px solid var(--border);
  }
  .module-card {
    display: flex; flex-direction: column;
    padding: 36px 32px; background: white; color: inherit; text-decoration: none;
    border-right: 1px solid var(--border);
    transition: background 0.2s;
    position: relative;
  }
  .module-card:last-child { border-right: none; }
  .module-card:hover { background: var(--bg-soft); }
  .module-card.featured { background: linear-gradient(180deg, var(--brand-softer) 0%, white 100%); }
  .module-card.featured:hover { background: linear-gradient(180deg, var(--brand-soft) 0%, white 100%); }
  .module-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
  .module-num { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; color: var(--text-3); }
  .module-icon {
    width: 40px; height: 40px;
    background: var(--brand-softer); color: var(--brand);
    display: grid; place-items: center;
    border: 1px solid var(--brand-soft);
  }
  .module-icon svg { width: 20px; height: 20px; }
  .module-title { font-size: 24px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.1; margin: 0 0 10px; color: var(--text-1); }
  .module-tagline { font-size: 14px; line-height: 1.55; color: var(--text-2); margin: 0 0 22px; }
  .module-features { list-style: none; padding: 0; margin: 0 0 28px; display: flex; flex-direction: column; gap: 10px; }
  .module-features li { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: var(--text-2); line-height: 1.45; }
  .module-features li svg { width: 14px; height: 14px; color: var(--brand); flex-shrink: 0; margin-top: 2px; }
  .module-foot {
    margin-top: auto; padding-top: 18px; border-top: 1px dashed var(--border);
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .module-stat { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; color: var(--text-3); text-transform: uppercase; }
  .module-stat strong { color: var(--text-1); font-weight: 600; }
  .module-link { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: var(--brand); transition: gap 0.2s; }
  .module-card:hover .module-link { gap: 10px; }
  @media (max-width: 900px) {
    .modules-grid { grid-template-columns: 1fr; }
    .module-card { border-right: none; border-bottom: 1px solid var(--border); }
    .module-card:last-child { border-bottom: none; }
  }

  /* ═══════════════════════════════════════════════
     INTEGRATIONS MARQUEE (Saaly-inspired)
     ═══════════════════════════════════════════════ */
  .integrations-section { padding: 96px 32px; }
  .integrations-header { text-align: center; max-width: 720px; margin: 0 auto 64px; }
  .integrations-header .label-pill { margin-bottom: 20px; }
  .integrations-header h2 { margin-bottom: 16px; }
  .integrations-meta { display: inline-flex; align-items: center; gap: 14px; margin-top: 18px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: var(--text-3); text-transform: uppercase; }
  .integrations-meta strong { color: var(--text-1); font-weight: 600; }
  .integrations-meta .dot { width: 3px; height: 3px; background: var(--border-strong); border-radius: 50% !important; display: inline-block; }
  .integrations-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: 140px 140px;
    border: 1px solid var(--border);
    max-width: 1080px;
    margin: 0 auto;
  }
  .integration-cell { border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); display: grid; place-items: center; padding: 16px; transition: background 0.2s; color: var(--text-2); font-weight: 600; font-size: 15px; position: relative; }
  .integration-cell:nth-child(4n) { border-right: none; }
  .integration-cell:nth-child(n+5) { border-bottom: none; }
  .integration-cell:hover { background: var(--bg-soft); }
  .integration-cell img { width: 48px; height: 48px; object-fit: contain; filter: grayscale(1) opacity(0.65); transition: filter 0.25s; }
  .integration-cell:hover img { filter: grayscale(0) opacity(1); }
  .integration-cell .tip {
    position: absolute; bottom: 14px; font-family: 'Geist Mono', monospace; font-size: 10px;
    color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; opacity: 0;
    transition: opacity 0.2s;
  }
  .integration-cell:hover .tip { opacity: 1; }
  .integration-cell.custom { background: var(--bg-soft); }
  .integration-cell.custom .custom-label { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .integration-cell.custom .custom-label-mono { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; color: var(--brand); }
  .integration-cell.custom .custom-label-title { font-size: 16px; font-weight: 600; color: var(--text-1); letter-spacing: -0.01em; }
  @media (max-width: 700px) {
    .integrations-grid { grid-template-columns: repeat(2, 1fr); grid-template-rows: repeat(4, 120px); }
    .integration-cell { border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .integration-cell:nth-child(2n) { border-right: none; }
    .integration-cell:nth-child(n+7) { border-bottom: none; }
  }

  /* ═══════════════════════════════════════════════
     CASE STUDIES
     ═══════════════════════════════════════════════ */
  .cases-section { padding: 96px 32px; background: var(--bg-soft); }
  .cases-header { display: grid; grid-template-columns: 1fr auto; align-items: end; max-width: 1080px; margin: 0 auto 56px; gap: 32px; }
  .cases-header h2 { margin: 0; }
  .cases-header .label-pill { margin-bottom: 16px; }
  .cases-header-right .label { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-3); }
  .cases-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 0; border: 1px solid var(--border); max-width: 1080px; margin: 0 auto; background: white; }

  /* ─── Case-studies carousel · 70 / 30 sliding ─── */
  .cases-carousel { max-width: 1180px; margin: 0 auto; overflow: hidden; position: relative; }
  .cases-track { display: flex; gap: 16px; transition: transform 0.7s cubic-bezier(.2,.8,.2,1); will-change: transform; }
  .case-slide {
    flex: 0 0 calc(70% - 8px);
    background: white; border: 1px solid var(--border);
    padding: 36px; display: flex; flex-direction: column;
    color: inherit; text-decoration: none;
    transition: border-color 0.25s, background 0.25s, opacity 0.5s, transform 0.5s;
    opacity: 0.55; transform: scale(0.96);
  }
  .case-slide.is-active { opacity: 1; transform: scale(1); background: var(--brand-softer); border-color: var(--brand-soft); }
  .case-slide:hover { border-color: var(--brand); }
  .case-slide .case-stats { margin-top: auto; padding-top: 16px; }
  .case-slide .case-quote { font-size: 19px; line-height: 1.4; margin: 18px 0 24px; }
  .case-slide .case-read-more { padding-top: 16px; margin-top: 16px; border-top: 1px dashed var(--border); display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: var(--brand); }
  .case-slide .case-read-more .arrow { transition: transform 0.2s; }
  .case-slide:hover .case-read-more .arrow { transform: translateX(4px); }

  .cases-dots { display: flex; gap: 8px; justify-content: center; margin-top: 28px; }
  .cases-dots button {
    width: 28px; height: 4px; background: var(--border-strong); border: none; padding: 0;
    cursor: pointer; transition: background 0.25s, width 0.25s;
  }
  .cases-dots button.is-active { background: var(--brand); width: 44px; }

  @media (max-width: 700px) {
    .case-slide { flex: 0 0 92%; }
  }
  .case-cell { padding: 32px; border-right: 1px solid var(--border); display: flex; flex-direction: column; }
  .case-cell:last-child { border-right: none; }
  .case-cell.featured { background: var(--bg-soft); }
  a.case-cell { color: inherit; text-decoration: none; transition: background 0.2s; cursor: pointer; }
  a.case-cell:hover { background: var(--brand-softer); }
  a.case-cell.featured:hover { background: var(--brand-soft); }
  .case-read-more { margin-top: 16px; padding-top: 16px; border-top: 1px dashed var(--border); display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: var(--brand); }
  .case-read-more .arrow { transition: transform 0.2s; }
  a.case-cell:hover .case-read-more .arrow { transform: translateX(4px); }
  .cases-all-link { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: var(--brand); text-decoration: none; padding: 10px 18px; border: 1px solid var(--brand); border-radius: 100px !important; transition: background 0.15s, color 0.15s; }
  .cases-all-link:hover { background: var(--brand); color: white; }
  .cases-all-link .arrow { transition: transform 0.2s; }
  .cases-all-link:hover .arrow { transform: translateX(3px); }
  .case-header-row { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .case-avatar { width: 44px; height: 44px; border-radius: 50%; display: grid; place-items: center; color: white; font-weight: 600; font-size: 17px; letter-spacing: -0.02em; }
  .case-avatar.purple { background: linear-gradient(135deg, var(--brand), #8b5cf6); }
  .case-avatar.orange { background: linear-gradient(135deg, #f97316, #ef4444); }
  .case-avatar.green { background: linear-gradient(135deg, var(--brand-bright), #06b6d4); }
  .case-info h4 { font-size: 15px; font-weight: 600; margin-bottom: 2px; letter-spacing: -0.01em; }
  .case-info .meta { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); letter-spacing: 0.05em; }
  .case-tag { display: inline-block; padding: 4px 10px; background: var(--brand-softer); color: var(--brand); border-radius: 6px; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.02em; font-weight: 500; margin-bottom: 16px; align-self: flex-start; }
  .case-cell.featured .case-tag { background: white; }
  .case-quote { font-size: 14px; line-height: 1.5; color: var(--text-1); margin-bottom: 20px; flex: 1; }
  .case-cell.featured .case-quote { font-size: 17px; }
  .case-quote .accent { color: var(--brand); font-weight: 500; }
  .case-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; padding-top: 20px; border-top: 1px dashed var(--border); }
  .case-stat-num { font-size: 22px; font-weight: 700; letter-spacing: -0.025em; line-height: 1; }
  .case-stat-num .accent { color: var(--brand); font-weight: 700; }
  .case-stat-label { margin-top: 4px; font-size: 10px; color: var(--text-3); font-family: 'Geist Mono', monospace; letter-spacing: 0.05em; }
  @media (max-width: 900px) { .cases-grid { grid-template-columns: 1fr; } .case-cell { border-right: none; border-bottom: 1px solid var(--border); } .case-cell:last-child { border-bottom: none; } }

  /* ═══════════════════════════════════════════════
     TESTIMONIALS (DARK, sticky left, purple accents)
     ═══════════════════════════════════════════════ */
  .testimonials-section { background: var(--bg-dark); color: white; padding: 0; overflow: clip; }
  .testimonials-wrap { padding: 96px 48px; position: relative; }
  .testimonials-wrap::before {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 800px 600px at 20% 30%, rgba(79, 57, 246, 0.2) 0%, transparent 60%);
  }
  .testimonials-wrap::after {
    content: ''; position: absolute; inset: 0;
    background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 64px 64px;
  }
  .testimonials-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 64px; align-items: start; max-width: 1140px; margin: 0 auto; position: relative; z-index: 2; }
  .testimonials-left {
    position: sticky;
    top: 96px; /* sticky offset */
    align-self: start;
  }
  .testimonials-left .label-pill {
    background: rgba(79,57,246,0.15);
    border: 1px solid rgba(79,57,246,0.3);
    color: var(--brand-bright);
    margin-bottom: 28px;
  }
  .testimonials-left .label-pill::before { background: var(--brand-bright); box-shadow: 0 0 8px var(--brand-bright); }
  .testimonials-left h2 { color: white; margin-bottom: 20px; }
  .testimonials-left h2 .accent { color: var(--brand-bright); }
  .testimonials-left p { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.65); margin-bottom: 32px; }
  .testimonials-cta { display: inline-flex; align-items: center; gap: 8px; color: var(--brand-bright); font-weight: 500; font-size: 15px; padding: 10px 20px; background: rgba(79,57,246,0.1); border: 1px solid rgba(79,57,246,0.25); border-radius: 100px; transition: all 0.2s; }
  .testimonials-cta:hover { background: rgba(79,57,246,0.2); border-color: rgba(79,57,246,0.5); }
  .testimonials-cta:hover .arrow { transform: translateX(3px); }
  .testimonials-cta .arrow { transition: transform 0.2s; }

  .testimonials-right { display: flex; flex-direction: column; gap: 16px; }
  .t-card { background: linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.02) 100%); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 28px; transition: all 0.3s cubic-bezier(.2,.8,.2,1); position: relative; overflow: hidden; }
  .t-card:hover { border-color: rgba(79, 57, 246, 0.5); background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.03) 100%); transform: translateX(8px); }
  .t-card-top { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .t-avatar { width: 56px; height: 56px; border-radius: 50%; display: grid; place-items: center; color: white; font-weight: 600; font-size: 22px; letter-spacing: -0.02em; flex-shrink: 0; border: 2px solid rgba(255,255,255,0.1); position: relative; overflow: hidden; }
  .t-avatar::after { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.3), transparent 60%); }
  .t-avatar.purple { background: linear-gradient(135deg, #4f39f6, #8b5cf6); }
  .t-avatar.orange { background: linear-gradient(135deg, #f97316, #ef4444); }
  .t-avatar.cyan { background: linear-gradient(135deg, #06b6d4, var(--brand)); }
  .t-avatar.green { background: linear-gradient(135deg, #10b981, var(--brand-bright)); }
  .t-name { font-size: 17px; font-weight: 600; color: white; margin-bottom: 4px; letter-spacing: -0.01em; }
  .t-role { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--brand-bright); letter-spacing: 0.15em; text-transform: uppercase; font-weight: 500; }
  .t-quote-mark { width: 28px; height: 28px; border-radius: 8px; background: rgba(79, 57, 246, 0.2); border: 1px solid rgba(79, 57, 246, 0.3); display: grid; place-items: center; color: var(--brand-bright); margin-left: auto; flex-shrink: 0; }
  .t-quote-mark svg { width: 14px; height: 14px; }
  .t-card-quote { font-size: 15px; line-height: 1.6; color: rgba(255,255,255,0.85); }
  .t-card-quote .accent { color: var(--brand-bright); font-weight: 500; }
  @media (max-width: 900px) {
    .testimonials-grid { grid-template-columns: 1fr; gap: 48px; }
    .testimonials-left { position: static; }
  }

  /* Featured case-study card (real outcomes, progress bar, stat grid) */
  .case-card {
    background: linear-gradient(135deg, rgba(79,57,246,0.18) 0%, rgba(79,57,246,0.06) 100%);
    border: 1px solid rgba(79,57,246,0.35); border-radius: 18px; padding: 28px 28px 24px;
    margin-bottom: 24px; position: relative; overflow: hidden;
  }
  .case-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--brand) 0%, var(--brand-bright) 100%);
  }
  .case-card-top { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
  .case-card .verified {
    display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px;
    background: rgba(16, 185, 129, 0.12); border: 1px solid rgba(16, 185, 129, 0.3); color: #34d399;
    border-radius: 100px; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 600;
    margin-left: auto;
  }
  .case-card .verified svg { width: 10px; height: 10px; }
  .case-card-quote { font-size: 17px; line-height: 1.55; color: white; margin-bottom: 22px; font-weight: 500; letter-spacing: -0.01em; }
  .case-card-quote .accent { color: var(--brand-bright); }
  .case-progress { margin-bottom: 20px; }
  .case-progress-labels { display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 8px; }
  .case-progress-labels .end { color: var(--brand-bright); font-weight: 600; }
  .case-progress-track { position: relative; height: 8px; background: rgba(255,255,255,0.08); border-radius: 100px; overflow: hidden; }
  .case-progress-fill {
    position: absolute; inset: 0 8% 0 0;
    background: linear-gradient(90deg, var(--brand) 0%, var(--brand-bright) 100%);
    border-radius: 100px;
    box-shadow: 0 0 12px var(--brand-glow);
  }
  .case-progress-fill::after {
    content: ''; position: absolute; top: -3px; right: -7px; width: 14px; height: 14px;
    background: var(--brand-bright); border-radius: 50%; border: 2px solid white;
    box-shadow: 0 0 16px var(--brand-bright);
  }
  .case-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 18px; }
  .case-stat { text-align: left; padding: 0 10px; border-right: 1px solid rgba(255,255,255,0.06); }
  .case-stat:first-child { padding-left: 0; }
  .case-stat:last-child { border-right: none; }
  .case-stat .v { font-size: 22px; font-weight: 700; color: white; letter-spacing: -0.02em; line-height: 1; }
  .case-stat .v.brand { color: var(--brand-bright); }
  .case-stat .l { font-family: 'Geist Mono', monospace; font-size: 9px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.06em; margin-top: 6px; }

  /* ═══════════════════════════════════════════════
     VERTICALS (Saaly grid 3x2)
     ═══════════════════════════════════════════════ */
  /* ═══════════════════════════════════════════════
     VERTICALS BENTO (4 cols × 3 rows, asymmetric)
     ═══════════════════════════════════════════════ */
  .verticals-bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 1fr;
    gap: 16px;
    max-width: 1180px; margin: 0 auto;
  }
  .vb-card {
    position: relative; display: flex; flex-direction: column;
    background: white; border: 1px solid var(--border);
    padding: 28px;
    color: inherit; text-decoration: none;
    transition: border-color 0.2s, transform 0.25s, box-shadow 0.25s;
    overflow: hidden;
  }
  .vb-card:hover { border-color: var(--brand); transform: translateY(-3px); box-shadow: 0 18px 36px -14px rgba(79,57,246,0.16); }
  .vb-feature { grid-column: span 2; grid-row: span 1; background: linear-gradient(180deg, var(--brand-softer) 0%, white 60%); padding: 28px; }
  .vb-wide { grid-column: span 2; }
  .verticals-bento > .vb-card:nth-child(5),
  .verticals-bento > .vb-card:nth-child(6) { grid-column: span 1; }
  .vb-brand { background: linear-gradient(140deg, var(--brand) 0%, var(--brand-deep) 100%); color: white; border-color: var(--brand-deep); }
  .vb-brand .vb-eyebrow, .vb-brand .vb-stat-label { color: rgba(255,255,255,0.7); }
  .vb-brand .vb-desc { color: rgba(255,255,255,0.88); }
  .vb-brand .vb-arrow svg { color: rgba(255,255,255,0.8); }
  .vb-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 22px; }
  .vb-icon {
    width: 40px; height: 40px;
    background: var(--brand-softer); color: var(--brand);
    border: 1px solid var(--brand-soft);
    display: grid; place-items: center;
  }
  .vb-icon-light { background: rgba(255,255,255,0.16); color: white; border-color: rgba(255,255,255,0.2); }
  .vb-icon svg { width: 19px; height: 19px; }
  .vb-arrow svg { width: 14px; height: 14px; color: var(--text-3); transition: transform 0.2s, color 0.2s; }
  .vb-card:hover .vb-arrow svg { color: var(--brand); transform: translate(3px, -3px); }
  .vb-brand:hover .vb-arrow svg { color: white; }
  .vb-eyebrow { font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 600; letter-spacing: 0.14em; color: var(--text-3); margin-bottom: 8px; }
  .vb-title { font-size: 22px; font-weight: 600; letter-spacing: -0.02em; line-height: 1.22; margin: 0 0 10px; color: inherit; }
  .vb-feature .vb-title { font-size: 22px; line-height: 1.22; }
  .vb-desc { font-size: 14px; line-height: 1.5; color: var(--text-2); margin: 0 0 16px; flex: 1; }
  .vb-feature .vb-desc { font-size: 14px; line-height: 1.55; }
  .vb-stat-row { display: flex; align-items: baseline; gap: 10px; padding-top: 14px; border-top: 1px dashed var(--border); margin-top: auto; }
  .vb-brand .vb-stat-row { border-top-color: rgba(255,255,255,0.18); }
  .vb-stat-num { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; color: var(--brand); }
  .vb-brand .vb-stat-num { color: white; }
  .vb-feature .vb-stat-num { font-size: 32px; }
  .vb-stat-label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: var(--text-3); text-transform: uppercase; }

  @media (max-width: 900px) {
    .verticals-bento { grid-template-columns: repeat(2, 1fr); grid-template-rows: none; }
    .vb-feature, .vb-wide { grid-column: span 2; grid-row: span 1; }
  }
  @media (max-width: 540px) {
    .verticals-bento { grid-template-columns: 1fr; }
    .vb-feature, .vb-wide { grid-column: span 1; }
  }

  .verticals-section { padding: 96px 32px; }
  .verticals-header { max-width: 720px; margin: 0 auto 56px; text-align: center; }
  .verticals-header .label-pill { margin-bottom: 20px; }
  .verticals-header h2 { margin-bottom: 16px; }
  .verticals-grid { display: grid; grid-template-columns: repeat(3, 1fr); background: white; border: 1px solid var(--border); max-width: 1080px; margin: 0 auto; }
  .vertical-cell { padding: 32px; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); transition: all 0.3s; cursor: pointer; position: relative; }
  .vertical-cell:nth-child(3n) { border-right: none; }
  .vertical-cell:nth-child(n+4) { border-bottom: none; }
  .vertical-cell:hover { background: var(--bg-soft); }
  .vertical-cell .v-icon { width: 44px; height: 44px; background: var(--brand-softer); color: var(--brand); border-radius: 10px; display: grid; place-items: center; margin-bottom: 20px; transition: transform 0.3s; }
  .vertical-cell:hover .v-icon { transform: scale(1.1) rotate(-5deg); }
  .vertical-cell .v-icon svg { width: 22px; height: 22px; }
  .vertical-cell h3 { font-size: 19px; margin-bottom: 4px; }
  .vertical-cell .v-subtitle { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); margin-bottom: 16px; letter-spacing: 0.08em; }
  .vertical-cell p { font-size: 13px; line-height: 1.5; color: var(--text-3); margin-bottom: 20px; }
  .vertical-cell .v-stat { padding: 12px 14px; background: var(--bg-soft); border-radius: 8px; display: flex; justify-content: space-between; align-items: baseline; border: 1px dashed var(--border); }
  .vertical-cell .v-stat-num { font-size: 22px; font-weight: 700; letter-spacing: -0.025em; color: var(--brand); }
  .vertical-cell .v-stat-label { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); text-align: right; line-height: 1.3; }
  .vertical-cell .v-arrow { position: absolute; top: 28px; right: 28px; color: var(--text-3); transition: all 0.3s; }
  .vertical-cell .v-arrow svg { width: 14px; height: 14px; }
  .vertical-cell:hover .v-arrow { color: var(--brand); transform: translate(2px, -2px); }
  @media (max-width: 900px) { .verticals-grid { grid-template-columns: 1fr 1fr; } .vertical-cell { border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); } .vertical-cell:nth-child(even) { border-right: none; } }
  @media (max-width: 540px) { .verticals-grid { grid-template-columns: 1fr; } .vertical-cell { border-right: none; } }

  /* ═══════════════════════════════════════════════
     AGENCY COST COMPARISON
     ═══════════════════════════════════════════════ */
  .cost-section { padding: 96px 32px; background: white; }
  .cost-footnote { max-width: 1080px; margin: 18px auto 0; padding-bottom: 25px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.04em; color: var(--text-3); text-align: center; line-height: 1.5; }
  .cost-footnote strong { color: var(--text-2); font-weight: 600; }
  .cost-header { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .cost-header .label-pill { margin-bottom: 20px; }
  .cost-header h2 { margin-bottom: 16px; }
  .cost-header p { font-size: 18px; color: var(--text-2); }
  .cost-table {
    max-width: 1080px; margin: 0 auto;
    background: white; border: 1px solid var(--border); border-radius: 20px; overflow: hidden;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 30px 60px -20px rgba(79,57,246,0.12);
  }
  .cost-row { display: grid; grid-template-columns: 1.2fr 1fr 1fr 1fr; border-bottom: 1px solid var(--border); align-items: stretch; }
  .cost-row:last-child { border-bottom: none; }
  .cost-row.head { background: var(--bg-soft); }
  .cost-cell { padding: 22px 24px; border-right: 1px solid var(--border); display: flex; flex-direction: column; justify-content: center; }
  .cost-cell:last-child { border-right: none; }
  .cost-cell.label { background: var(--bg-soft); }
  .cost-cell.brand { background: linear-gradient(180deg, rgba(79,57,246,0.04) 0%, rgba(79,57,246,0.02) 100%); position: relative; }
  .cost-cell.brand::before { content: ''; position: absolute; top: -1px; left: -1px; right: -1px; height: 3px; background: var(--brand); }
  .cost-cell .vert { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
  .cost-cell .price { font-size: 22px; font-weight: 700; color: var(--text-1); letter-spacing: -0.02em; line-height: 1.1; }
  .cost-cell .price.crossed { color: var(--text-3); text-decoration: line-through; text-decoration-color: rgba(220, 38, 38, 0.5); text-decoration-thickness: 1.5px; }
  .cost-cell .price.brand { color: var(--brand); }
  .cost-cell .per { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.06em; }
  .cost-cell.head-cell { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; padding: 18px 24px; }
  .cost-cell.head-cell.brand { color: var(--brand); }
  .cost-savings { padding: 24px 32px; background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%); color: white; text-align: center; }
  .cost-savings .big { font-size: 36px; font-weight: 700; letter-spacing: -0.025em; }
  .cost-savings .lbl { font-family: 'Geist Mono', monospace; font-size: 11px; opacity: 0.85; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px; }
  @media (max-width: 720px) {
    .cost-row { grid-template-columns: 1fr; }
    .cost-cell { border-right: none; border-bottom: 1px solid var(--border); }
    .cost-cell:last-child { border-bottom: none; }
  }

  /* ═══════════════════════════════════════════════
     GUARANTEE STRIP
     ═══════════════════════════════════════════════ */
  .guarantee-section { padding: 80px 32px; background: var(--bg-soft); }
  .guarantee-grid { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .guarantee-card { background: white; border: 1px solid var(--border); border-radius: 16px; padding: 28px 24px; display: flex; align-items: flex-start; gap: 16px; }
  .guarantee-icon {
    flex-shrink: 0; width: 44px; height: 44px; border-radius: 12px;
    background: linear-gradient(135deg, var(--brand-softer) 0%, rgba(79,57,246,0.08) 100%);
    border: 1px solid rgba(79,57,246,0.18); display: grid; place-items: center; color: var(--brand);
  }
  .guarantee-icon svg { width: 22px; height: 22px; }
  .guarantee-text h4 { font-size: 15px; font-weight: 600; letter-spacing: -0.015em; margin-bottom: 6px; color: var(--text-1); }
  .guarantee-text p { font-size: 13px; color: var(--text-2); line-height: 1.5; margin: 0; }
  @media (max-width: 880px) { .guarantee-grid { grid-template-columns: 1fr; } }

  /* ═══════════════════════════════════════════════
     STICKY FLOATING CTA
     ═══════════════════════════════════════════════ */
  .sticky-cta {
    position: fixed; right: 24px; bottom: 24px; z-index: 100;
    opacity: 0; transform: translateY(20px) scale(0.85); pointer-events: none;
    transition: opacity 0.4s, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .sticky-cta.visible { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  .sticky-cta a {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 22px; background: var(--text-1); color: white;
    border-radius: 100px; text-decoration: none; font-weight: 600; font-size: 14px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.18), 0 0 0 4px rgba(79,57,246,0.15), 0 4px 12px rgba(79,57,246,0.3);
    transition: all 0.2s;
  }
  .sticky-cta a:hover { transform: translateY(-2px); box-shadow: 0 14px 38px rgba(0,0,0,0.22), 0 0 0 6px rgba(79,57,246,0.2), 0 6px 16px rgba(79,57,246,0.4); }
  .sticky-cta .price-pill {
    background: var(--brand); padding: 4px 10px; border-radius: 100px;
    font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.05em;
  }
  @media (max-width: 540px) { .sticky-cta { right: 16px; bottom: 16px; } .sticky-cta a { padding: 12px 18px; font-size: 13px; } }

  /* ═══════════════════════════════════════════════
     PRICING TEASER (Saaly-inspired)
     ═══════════════════════════════════════════════ */
  .pricing-section { padding: 96px 32px; background: var(--bg-soft); }
  .pricing-header { text-align: center; max-width: 720px; margin: 0 auto 64px; }
  .pricing-header .label-pill { margin-bottom: 20px; }
  .pricing-header h2 { margin-bottom: 16px; }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: 1080px; margin: 0 auto; }
  .pricing-card { background: white; border: 1px solid var(--border); border-radius: 20px; padding: 36px 32px; display: flex; flex-direction: column; transition: all 0.3s; position: relative; }
  .pricing-card.featured { background: var(--text-1); color: white; border-color: var(--text-1); position: relative; overflow: hidden; }
  .pricing-card.featured::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--brand), var(--brand-bright)); }
  .pricing-card:hover { transform: translateY(-4px); box-shadow: 0 24px 48px -16px rgba(0,0,0,0.08); }
  .pricing-card.featured:hover { box-shadow: 0 24px 48px -16px var(--brand-glow); }
  .pricing-badge { position: absolute; top: 24px; right: 24px; padding: 4px 10px; background: var(--brand); color: white; border-radius: 100px; font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.1em; font-weight: 600; }
  .pricing-name { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-3); font-weight: 500; margin-bottom: 16px; }
  .pricing-card.featured .pricing-name { color: var(--brand-bright); }
  .pricing-amount { display: flex; align-items: baseline; gap: 4px; margin-bottom: 8px; }
  .pricing-amount .num { font-size: 56px; font-weight: 700; letter-spacing: -0.04em; line-height: 1; }
  .pricing-amount .period { font-family: 'Geist Mono', monospace; font-size: 13px; color: var(--text-3); }
  .pricing-card.featured .pricing-amount .period { color: rgba(255,255,255,0.6); }
  .pricing-tagline { font-size: 14px; color: var(--text-3); margin-bottom: 32px; }
  .pricing-card.featured .pricing-tagline { color: rgba(255,255,255,0.7); }
  .pricing-features { list-style: none; flex: 1; display: flex; flex-direction: column; gap: 10px; margin-bottom: 32px; padding-top: 24px; border-top: 1px solid var(--border); }
  .pricing-card.featured .pricing-features { border-top-color: rgba(255,255,255,0.1); }
  .pricing-features li { display: flex; align-items: start; gap: 10px; font-size: 14px; }
  .pricing-features li .icon { width: 16px; height: 16px; color: var(--brand); flex-shrink: 0; margin-top: 2px; }
  .pricing-card.featured .pricing-features li { color: rgba(255,255,255,0.85); }
  .pricing-card.featured .pricing-features li .icon { color: var(--brand-bright); }
  .pricing-cta { display: block; text-align: center; padding: 14px 24px; border-radius: 100px; font-weight: 500; font-size: 15px; transition: all 0.2s; }
  .pricing-card:not(.featured) .pricing-cta { background: white; color: var(--text-1); border: 1px solid var(--border-strong); }
  .pricing-card:not(.featured) .pricing-cta:hover { border-color: var(--text-1); }
  .pricing-card.featured .pricing-cta { background: white; color: var(--text-1); }
  .pricing-card.featured .pricing-cta:hover { background: var(--brand-bright); color: white; }
  @media (max-width: 900px) { .pricing-grid { grid-template-columns: 1fr; } }

  /* ═══════════════════════════════════════════════
     FAQ
     ═══════════════════════════════════════════════ */
  .faq-section { padding: 96px 32px; }
  .faq-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 64px; max-width: 1080px; margin: 0 auto; align-items: start; }
  .faq-left .label-pill { margin-bottom: 20px; }
  .faq-left h2 { margin-bottom: 16px; }
  .faq-left p { font-size: 15px; line-height: 1.55; color: var(--text-3); }
  .faq-left p a { color: var(--brand); font-weight: 500; }
  .faq-list { border-top: 1px solid var(--border); }
  .faq-item { border-bottom: 1px solid var(--border); }
  .faq-question { width: 100%; padding: 24px 0; text-align: left; display: flex; justify-content: space-between; align-items: center; font-size: 18px; font-weight: 500; letter-spacing: -0.015em; color: var(--text-1); transition: color 0.2s; }
  .faq-question:hover { color: var(--brand); }
  .faq-icon { flex-shrink: 0; width: 26px; height: 26px; border-radius: 50%; border: 1px solid var(--border-strong); display: grid; place-items: center; transition: all 0.2s; color: var(--text-3); }
  .faq-icon svg { width: 11px; height: 11px; transition: transform 0.2s; }
  .faq-item.open .faq-icon { background: var(--text-1); color: white; border-color: var(--text-1); }
  .faq-item.open .faq-icon svg { transform: rotate(45deg); }
  .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s, padding 0.4s; font-size: 15px; line-height: 1.55; color: var(--text-2); }
  .faq-item.open .faq-answer { max-height: 400px; padding: 0 0 24px; }
  @media (max-width: 768px) { .faq-grid { grid-template-columns: 1fr; gap: 32px; } }

  /* ═══════════════════════════════════════════════
     FINAL CTA (dark)
     ═══════════════════════════════════════════════ */
  .final-section { background: var(--bg-dark); color: white; padding: 0; position: relative; overflow: hidden; }
  .final-section .dot-pattern {
    position: absolute; inset: 0; width: 100%; height: 100%;
    color: rgba(255,255,255,0.18);
    pointer-events: none; z-index: 0;
    animation: dotPulse 6s ease-in-out infinite alternate;
  }
  .final-section .final-wrap { position: relative; z-index: 1; }
  @keyframes dotPulse { from { opacity: 0.6; } to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .final-section .dot-pattern { animation: none; } }
  .final-wrap { padding: 140px 32px; text-align: center; position: relative; overflow: hidden; }
  .final-wrap::before {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 600px 400px at 30% 40%, rgba(79, 57, 246, 0.35) 0%, transparent 60%),
      radial-gradient(ellipse 500px 300px at 70% 60%, rgba(79, 57, 246, 0.15) 0%, transparent 60%);
  }
  .final-wrap::after {
    content: ''; position: absolute; inset: 0;
    background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 64px 64px;
  }
  .final-content { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; }
  .final-label { font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--brand-bright); margin-bottom: 32px; display: inline-block; padding: 8px 16px; background: rgba(79, 57, 246, 0.15); border: 1px solid rgba(79, 57, 246, 0.3); border-radius: 100px; }
  .final-headline { font-size: clamp(32px, 4.5vw, 58px); font-weight: 700; line-height: 1.1; letter-spacing: -0.025em; color: white; margin: 0 auto 28px; white-space: nowrap; }
  .final-headline br { display: block; }
  @media (max-width: 880px) { .final-headline { white-space: normal; font-size: clamp(28px, 6.5vw, 42px); } }
  .final-headline .accent { color: var(--brand-bright); }
  .final-sub { font-size: 19px; line-height: 1.45; color: rgba(255,255,255,0.65); margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto; }
  .final-cta-btn { display: inline-flex; align-items: center; gap: 12px; padding: 0 32px; height: 56px; background: white; color: var(--text-1); border-radius: 100px; font-size: 16px; font-weight: 500; transition: all 0.2s; }
  .final-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 16px 48px rgba(255,255,255,0.2); }
  .final-cta-btn .arrow { transition: transform 0.2s; }
  .final-cta-btn:hover .arrow { transform: translateX(4px); }
  .final-trust { margin-top: 28px; font-family: 'Geist Mono', monospace; font-size: 12px; color: rgba(255,255,255,0.4); letter-spacing: 0.05em; }
  .final-trust span { color: rgba(255,255,255,0.7); }
  .final-ps { max-width: 680px; margin: 40px auto 0; font-size: 14px; line-height: 1.65; color: rgba(255,255,255,0.6); padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.08); text-align: center; }
  .final-ps strong { color: var(--brand-bright); font-weight: 600; letter-spacing: 0.05em; }
  .final-ps .accent { color: white; font-weight: 500; }

  /* ═══════════════════════════════════════════════
     FOOTER (logo + brand wordmark)
     ═══════════════════════════════════════════════ */
  footer { background: var(--brand-deep); color: white; position: relative; overflow: hidden; }
  .footer-top { padding: 80px 48px 64px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 48px; max-width: var(--container-w); margin: 0 auto; align-items: start; }
  .footer-col h5 { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin: 0 0 18px; }
  .footer-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .footer-col a { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: rgba(255,255,255,0.78); transition: color 0.2s; }
  /* Arrow on every footer link via mask — replaces the explicit svg.arrow-up */
  .footer-col a svg.arrow-up { display: none; }
  .footer-col a::after {
    content: ''; flex-shrink: 0;
    width: 11px; height: 11px;
    background: currentColor;
    -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><path d='M7 17L17 7M9 7h8v8'/></svg>") center / contain no-repeat;
            mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><path d='M7 17L17 7M9 7h8v8'/></svg>") center / contain no-repeat;
    opacity: 0.5; transition: transform 0.2s, opacity 0.2s;
  }
  .footer-col a:hover::after { opacity: 1; transform: translate(3px, -3px); }
  .footer-col a:hover { color: white; }
  .footer-col a .arrow-up { width: 10px; height: 10px; color: rgba(255,255,255,0.4); transition: transform 0.2s, color 0.2s; }
  .footer-col a:hover .arrow-up { color: white; transform: translate(2px, -2px); }
  .footer-avatars { display: flex; }
  .footer-avatars .av { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--brand); display: grid; place-items: center; color: white; font-size: 12px; font-weight: 600; }
  .footer-avatars .av:not(:first-child) { margin-left: -8px; }
  .footer-avatars .av:nth-child(1) { background: linear-gradient(135deg, #4f39f6, #8b5cf6); }
  .footer-avatars .av:nth-child(2) { background: linear-gradient(135deg, #ec4899, #f97316); }
  .footer-avatars .av:nth-child(3) { background: linear-gradient(135deg, #10b981, #06b6d4); }
  .footer-avatars .av:nth-child(4) { background: linear-gradient(135deg, #f59e0b, #ef4444); }
  .footer-community-text { font-size: 14px; color: rgba(255,255,255,0.6); }
  .footer-community-text strong { color: white; font-weight: 600; }

  /* Footer brand wordmark logo */
  .footer-brand-block { padding: 24px 48px 16px; max-width: var(--container-w); margin: 0 auto; display: flex; align-items: center; justify-content: center; }
  .footer-brand-logo {
    width: 100%;
    max-width: min(1100px, 92%);
    height: auto;
    display: block;
    filter: brightness(0) invert(1) drop-shadow(0 0 60px rgba(255,255,255,0.25));
    user-select: none;
  }
  .footer-bottom { max-width: var(--container-w); margin: 0 auto; padding: 24px 48px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; font-family: 'Geist Mono', monospace; font-size: 12px; color: rgba(255,255,255,0.4); letter-spacing: 0.02em; }
  .footer-bottom-left { display: flex; align-items: center; gap: 24px; }
  .footer-bottom-left a { color: rgba(255,255,255,0.6); transition: color 0.2s; }
  .footer-bottom-left a:hover { color: white; }
  @media (max-width: 968px) { .footer-top { grid-template-columns: repeat(2, 1fr); gap: 40px 32px; } .footer-brand-block { flex-direction: column; align-items: flex-start; } }
  @media (max-width: 540px) { .footer-top { grid-template-columns: 1fr; } }
</style>
</head>
<body class={bodyClass}>
<!-- ICON DEFINITIONS (sprite) -->
<svg width="0" height="0" style="position: absolute" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Logo mark -->
    <symbol id="i-logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2 L15 9 L22 12 L15 15 L12 22 L9 15 L2 12 L9 9 Z"/>
    </symbol>
    <!-- Check -->
    <symbol id="i-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="20 6 9 17 4 12"/>
    </symbol>
    <!-- Plus -->
    <symbol id="i-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </symbol>
    <!-- Arrow up right -->
    <symbol id="i-arrow-ur" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
    </symbol>
    <!-- Star -->
    <symbol id="i-star" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26"/></symbol>
    <!-- Trending up -->
    <symbol id="i-trend" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>
    </symbol>
    <!-- Coin / dollar -->
    <symbol id="i-dollar" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><path d="M16 8h-4a2 2 0 0 0 0 4h2a2 2 0 0 1 0 4H8M12 6v2M12 16v2"/>
    </symbol>
    <!-- Clock -->
    <symbol id="i-clock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
    </symbol>
    <!-- Target -->
    <symbol id="i-target" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
    </symbol>
    <!-- Document -->
    <symbol id="i-doc" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
    </symbol>
    <!-- Map pin -->
    <symbol id="i-pin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
    </symbol>
    <!-- Message/chat -->
    <symbol id="i-msg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </symbol>
    <!-- Bolt -->
    <symbol id="i-bolt" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
    </symbol>
    <!-- Play -->
    <symbol id="i-play" viewBox="0 0 24 24" fill="currentColor">
      <path d="M8 5v14l11-7z"/>
    </symbol>
    <!-- CPU / AI -->
    <symbol id="i-cpu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="14" x2="22" y2="14"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="14" x2="4" y2="14"/>
