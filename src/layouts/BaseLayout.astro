      serpResultsEl.style.transition = 'opacity 0.4s';
      serpResultsEl.style.opacity = '1';
    }, 200);
  }
  if (serpQueryEl && serpResultsEl) {
    setInterval(() => { serpIdx = (serpIdx + 1) % serpQueries.length; renderSerp(serpIdx); }, 4500);
  }

  // ─────── MEGA MENU (hover + click + keyboard) ───────
  (function() {
    const items = document.querySelectorAll('.nav-item[data-menu]');
    let openItem = null;
    let closeTimer = null;
    function openMenu(item) {
      if (openItem && openItem !== item) closeMenu(openItem, true);
      clearTimeout(closeTimer);
      item.classList.add('open');
      const trig = item.querySelector('.nav-trigger');
      if (trig) trig.setAttribute('aria-expanded', 'true');
      openItem = item;
    }
    function closeMenu(item, immediate) {
      const doClose = () => {
        item.classList.remove('open');
        const trig = item.querySelector('.nav-trigger');
        if (trig) trig.setAttribute('aria-expanded', 'false');
        if (openItem === item) openItem = null;
      };
      if (immediate) doClose();
      else { clearTimeout(closeTimer); closeTimer = setTimeout(doClose, 140); }
    }
    items.forEach(item => {
      const trig = item.querySelector('.nav-trigger');
      item.addEventListener('mouseenter', () => openMenu(item));
      item.addEventListener('mouseleave', () => closeMenu(item));
      trig.addEventListener('click', (e) => {
        e.preventDefault();
        item.classList.contains('open') ? closeMenu(item, true) : openMenu(item);
      });
      trig.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && item.classList.contains('open')) {
          closeMenu(item, true);
          trig.focus();
        }
      });
    });
    document.addEventListener('click', (e) => {
      if (openItem && !openItem.contains(e.target)) closeMenu(openItem, true);
    });
  })();

  // ─────── RESOURCES MARQUEE — duplicate cards for seamless loop ───────
  (function() {
    const track = document.querySelector('#resourcesMarquee .resources-track');
    if (!track) return;
    track.innerHTML += track.innerHTML; // double the cards so translateX(-50%) loops perfectly
  })();

  // ─────── SCROLL PROGRESS BAR ───────
  (function() {
    const bar = document.getElementById('scrollProgress');
    if (!bar) return;
    let ticking = false;
    function update() {
      ticking = false;
      const sh = document.documentElement.scrollHeight - window.innerHeight;
      const p = sh > 0 ? Math.min(1, Math.max(0, window.scrollY / sh)) : 0;
      bar.style.transform = `scaleX(${p})`;
    }
    window.addEventListener('scroll', () => { if (!ticking) { requestAnimationFrame(update); ticking = true; } }, { passive: true });
    update();
  })();

  // ─────── SCROLL-REVEAL FADE-UP ───────
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const targets = document.querySelectorAll(
      '.modules-section .modules-header, .modules-section .module-card,' +
      '.cases-section .cases-header, .cases-section .case-cell,' +
      '.serp-section .serp-header, .serp-section .serp-mock, .serp-section .serp-copy,' +
      '.cost-section .cost-header, .cost-section .cost-table,' +
      '.integrations-section .integrations-header, .integrations-section .integration-cell,' +
      '.guarantee-section .guarantee-card,' +
      '.verticals-section .verticals-header, .verticals-section .vertical-cell,' +
      '.resources-section .resources-header,' +
      '.trust-section .trust-head, .trust-section .trust-logo,' +
      '.video-section .video-shell,' +
      '.final-section .final-content > *'
    );
    targets.forEach((el, i) => {
      el.classList.add('reveal');
      el.style.transitionDelay = Math.min((i % 6) * 40, 240) + 'ms';
    });
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    targets.forEach(t => io.observe(t));
  })();

  // ─────── ANIMATED STAT COUNTERS ───────
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const nums = document.querySelectorAll('.stats-row .stat-num');
    if (!nums.length) return;
    function animate(el) {
      // Read the leading-number portion from the FIRST text node only — everything inside
      // the trailing .accent span is the suffix and gets preserved as-is.
      const accentEl = el.querySelector('.accent');
      const leadText = (el.firstChild && el.firstChild.nodeType === 3) ? el.firstChild.nodeValue : el.textContent;
      const match = leadText.match(/[\d,\.]+/);
      if (!match) return;
      const numStr = match[0];
      const target = parseFloat(numStr.replace(/,/g, ''));
      const hasComma = numStr.includes(',');
      const decimals = (numStr.split('.')[1] || '').length;
      const before = leadText.slice(0, match.index);
      const valSpan = document.createElement('span');
      valSpan.textContent = '0';
      // rebuild: [before-text] + [counter span] + [accent suffix span unchanged]
      el.innerHTML = '';
      if (before) el.appendChild(document.createTextNode(before));
      el.appendChild(valSpan);
      if (accentEl) el.appendChild(accentEl);
      const dur = 1300;
      const start = performance.now();
      function frame(now) {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic
        const cur = target * eased;
        let display = decimals ? cur.toFixed(decimals) : Math.round(cur).toString();
        if (hasComma) display = parseFloat(display).toLocaleString('en-US');
        valSpan.textContent = display;
        if (t < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { animate(e.target); io.unobserve(e.target); } });
    }, { threshold: 0.5 });
    nums.forEach(n => io.observe(n));
  })();

