  })();

  // ─────── SCROLL-SPY NAV ───────
  (function() {
    const navItems = {
      product:    document.querySelector('.modules-section'),
      solutions:  document.querySelector('.verticals-section'),
      resources:  document.querySelector('.resources-section')
    };
    const triggers = document.querySelectorAll('.nav-item[data-menu]');
    if (!triggers.length) return;
    function spy() {
      let activeKey = null;
      let bestY = -Infinity;
      Object.entries(navItems).forEach(([k, el]) => {
        if (!el) return;
        const top = el.getBoundingClientRect().top;
        if (top < window.innerHeight * 0.4 && top > bestY) { bestY = top; activeKey = k; }
      });
      triggers.forEach(t => t.classList.toggle('active', t.dataset.menu === activeKey));
    }
    let ticking = false;
    window.addEventListener('scroll', () => { if (!ticking) { requestAnimationFrame(() => { spy(); ticking = false; }); ticking = true; } }, { passive: true });
    spy();
  })();

  // ─────── HERO VIDEO PARALLAX (subtle tilt) ───────
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const shell = document.getElementById('heroVideoShell');
    if (!shell) return;
    shell.style.transition = 'transform 0.4s cubic-bezier(.2,.8,.2,1)';
    shell.style.willChange = 'transform';
    shell.addEventListener('mousemove', (e) => {
      const r = shell.getBoundingClientRect();
      const x = ((e.clientX - r.left) / r.width - 0.5) * 2;
      const y = ((e.clientY - r.top) / r.height - 0.5) * 2;
      shell.style.transform = `perspective(1200px) rotateY(${x * 2.5}deg) rotateX(${-y * 2}deg)`;
      shell.style.transitionDuration = '0.18s';
    });
    shell.addEventListener('mouseleave', () => {
      shell.style.transform = 'perspective(1200px) rotateY(0deg) rotateX(0deg)';
      shell.style.transitionDuration = '0.5s';
    });
  })();

  // ─────── MAGNETIC CTA BUTTON (primary in hero) ───────
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const buttons = document.querySelectorAll('.hero-ctas .btn-primary, .final-cta-btn');
    buttons.forEach(btn => {
      const radius = 90;
      btn.style.transition = 'transform 0.18s cubic-bezier(.2,.8,.2,1)';
      const inner = btn.querySelector('span') || btn;
      document.addEventListener('mousemove', (e) => {
        const r = btn.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        const dist = Math.hypot(dx, dy);
        if (dist < radius) {
          const pull = (radius - dist) / radius;
          btn.style.transform = `translate(${dx * pull * 0.25}px, ${dy * pull * 0.25}px)`;
        } else {
          btn.style.transform = 'translate(0, 0)';
        }
      });
    });
  })();

  // ─────── LAZY-LOAD HERO VIDEO ───────
  (function() {
    const v = document.querySelector('.video-poster[data-src]');
    if (!v) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          v.src = v.dataset.src;
          v.play().catch(()=>{});
          io.disconnect();
        }
      });
    }, { rootMargin: '200px 0px' });
    io.observe(v);
  })();

  // ─────── STICKY FLOATING CTA ───────
  const stickyCta = document.getElementById('stickyCta');
  if (stickyCta) {
    window.addEventListener('scroll', () => {
      stickyCta.classList.toggle('visible', window.scrollY > 200);
    }, { passive: true });
  }

</script>

</body>
</html>
