---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout seo={{ title: 'Checkout · theStacc', description: 'Start your theStacc trial. Choose a plan and start automating your SEO.', canonical: 'https://thestacc.com/checkout/', noindex: true }}>
  <section style="min-height: 60vh; display: grid; place-items: center; padding: 64px 24px; text-align: center;">
    <div>
      <h1 class="h-display" style="margin-bottom: 16px;">Redirecting to pricing</h1>
      <p class="hero-sub" style="margin-bottom: 32px;">The checkout flow has moved to our pricing page. Choose a plan and start your $1 trial there.</p>
      <a href="/pricing/" class="btn btn-primary"><span>Go to pricing <span class="arrow">→</span></span></a>
    </div>
  </section>
  <meta http-equiv="refresh" content="2;url=/pricing/" />
</BaseLayout>
