---
import BaseLayout from '../../layouts/BaseLayout.astro';
const seo = {
  title: 'Blog — SEO playbooks & AI growth tactics · theStacc',
  description: '481 articles on SEO, AI search, local SEO, and content strategy. Operator-to-operator playbooks from the team building theStacc.',
  canonical: 'https://thestacc.com/blog/',
  ogImage: '/og/blog.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "theStacc blog",
    "url": "https://thestacc.com/blog/"
  }
};

const categories = ['All', 'Content Strategy', 'Local SEO', 'SEO Tips', 'AI Search'];

const featured = { slug: 'accounting-firm-seo-guide', cat: 'SEO Tips', title: 'Accounting Firm SEO (2026): Strategies, Tactics & Ex...', excerpt: 'Practical accounting firm seo guide strategies for 2026: step-by-step tactics, real examples, and tools to improve rankings and drive organic traffic.', author: 'Akshay VR', date: '2026-07-01', readTime: '7 min' };

const posts = [
  { slug: '404-error-seo', cat: 'SEO Tips', title: '404 Error SEO (2026): Strategies, Tactics & Examples', excerpt: 'Practical 404 error seo strategies for 2026: step-by-step tactics, real examples, and tools to improve rankings and drive organic traffic.', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: '5x-content-output-ai', cat: 'Content Strategy', title: 'How to 5x Content Output Without Hiring (7 Steps)', excerpt: 'Scale content production 5x without adding headcount. 7 steps covering workflow audits, AI drafts, repurposing, and automation. Updated April 2026.', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: 'adapt-google-algorithm-updates', cat: 'SEO Tips', title: 'How to Adapt to Google Algorithm Updates: A Strategi...', excerpt: 'Google updates constantly. Learn how to build a content strategy that is resilient to algorithm changes and adapts quickly when they happen.', author: 'Akshay VR', date: '2026-07-01', readTime: '7 min' },
  { slug: 'add-experience-ai-content', cat: 'Content Strategy', title: 'Add First-Hand Experience to AI Content: 6-Step Guide', excerpt: 'Learn how to add first-hand experience to AI content and boost E-E-A-T signals. A 6-step guide with the Experience Injection Method for higher rankings…', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: 'aeo-vs-seo', cat: 'SEO Tips', title: 'AEO vs SEO: What Changed and How to Optimize for Both', excerpt: 'AEO vs SEO explained with data. Learn how answer engine optimization differs from SEO, which strategies overlap, and where to invest. Updated March 2026.', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: 'agency-business-model', cat: 'SEO Tips', title: 'Digital Marketing Agency Business Model: Complete 20...', excerpt: 'Build a profitable digital marketing agency business model. Covers pricing structures, revenue streams, profit benchmarks, team scaling, and cash flow…', author: 'Akshay VR', date: '2026-07-01', readTime: '7 min' },
  { slug: 'agency-pricing-models', cat: 'SEO Tips', title: 'Agency Pricing Models: The Complete Guide for 2026', excerpt: 'Agency pricing models explained: 8 structures from hourly to value-based, with real rate ranges, margin benchmarks, and formulas to set profitable…', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: 'agency-pricing-models-seo-services', cat: 'SEO Tips', title: 'SEO Agency Pricing Models (2026): Retainers, Hourly ...', excerpt: 'SEO agency pricing models explained: monthly retainers ($1,500-$10,000+), hourly rates ($75-$300), project fees, and value-based pricing. Real numbers…', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: 'agentic-ai-marketing', cat: 'SEO Tips', title: 'Agentic AI Marketing (2026): Strategies, Tactics & E...', excerpt: 'agentic ai marketing strategies for 2026: proven tactics, real case studies, tools, and metrics to drive growth and ROI.', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: 'ai-agent-adoption-statistics', cat: 'AI Search', title: 'AI Agent Adoption Statistics 2026: $10.9B Market, 79...', excerpt: '40+ AI agent adoption statistics for 2026: $10.9 billion market size, 79% organizational adoption, enterprise deployment rates, ROI data, and…', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: 'ai-agent-adoption-statistics-2026', cat: 'AI Search', title: 'AI Agent Adoption Statistics 2026: 52 Facts and Figures', excerpt: '52 AI agent adoption stats for 2026. Market size, enterprise deployment, ROI, industry breakdowns, and failure rates. Sourced. Updated May 2026.', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' },
  { slug: 'ai-agent-orchestration-marketing', cat: 'AI Search', title: 'AI Agent Orchestration for Marketing (2026): Guide', excerpt: 'ai agent orchestration marketing strategies for 2026: proven tactics, real case studies, tools, and metrics to drive growth and ROI.', author: 'Siddharth Gangal', date: '2026-07-01', readTime: '7 min' }
];

const fmtDate = (s) => new Date(s).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Blog · 481 articles</span>
    <h1 class="h-display">SEO playbooks <span class="accent">& AI growth tactics.</span></h1>
    <p class="hero-sub">Operator-to-operator tactics from the team that publishes 30+ articles a month for 127 customers. Tested. Shipped. Ranked.</p>
    <div class="hero-ctas">
      <a href="/audit/" class="btn btn-primary"><span>Run free SEO audit <span class="arrow">→</span></span></a>
      <a href="/checkout/" class="btn btn-secondary">Start your $1 trial</a>
    </div>
  </section>

  <!-- CATEGORY PILLS -->
  <section style="padding: 32px; background: white; border-bottom: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;">
      {categories.map((c, i) => (
        <span class="label-pill" style={i === 0 ? 'background: var(--brand-softer); border-color: var(--brand-soft);' : ''}>{c}</span>
      ))}
    </div>
  </section>

  <!-- FEATURED POST -->
  <section style="padding: 64px 32px 32px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <a href={`/blog/${featured.slug}/`} class="bento-card bento-feature" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; padding: 40px;">
        <div>
          <div class="bento-title" style="margin-bottom: 16px;">Featured · {featured.cat}</div>
          <h2 class="h-md" style="margin-bottom: 16px;">{featured.title}</h2>
          <p class="bento-desc" style="font-size: 16px; margin-bottom: 24px;">{featured.excerpt}</p>
          <div style="display: flex; gap: 16px; align-items: center; font-size: 13px; color: var(--text-3); margin-bottom: 22px; flex-wrap: wrap;">
            <span><strong style="color: var(--text-1);">{featured.author}</strong></span>
            <span>·</span>
            <span>{fmtDate(featured.date)}</span>
            <span>·</span>
            <span>{featured.readTime} read</span>
          </div>
          <div class="bento-cta">Read the playbook <span class="arrow">→</span></div>
        </div>
        <div style="background: linear-gradient(135deg, var(--brand-soft), var(--brand-softer)); min-height: 280px; display: grid; place-items: center; border: 1px solid var(--brand-soft);">
          <svg viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.6" style="color: var(--brand);"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
      </a>
    </div>
  </section>

  <!-- POSTS GRID -->
  <section style="padding: 32px 32px 96px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div class="posts-grid">
        {posts.map((p) => (
          <a href={`/blog/${p.slug}/`} class="bento-card" style="padding: 0;">
            <div style="height: 160px; background: linear-gradient(135deg, var(--brand-soft), var(--brand-softer)); display: grid; place-items: center; border-bottom: 1px solid var(--border);">
              <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.6" style="color: var(--brand);"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div style="padding: 24px;">
              <div class="bento-title" style="margin-bottom: 10px;">{p.cat}</div>
              <h3 class="h-sm" style="margin-bottom: 10px;">{p.title}</h3>
              <p class="bento-desc">{p.excerpt}</p>
              <div style="margin-top: 16px; display: flex; gap: 10px; align-items: center; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); flex-wrap: wrap;">
                <span>{p.author}</span>
                <span>·</span>
                <span>{fmtDate(p.date)}</span>
                <span>·</span>
                <span>{p.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- PAGINATION -->
      <div style="margin-top: 56px; text-align: center; font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--text-3);">
        Browse the latest playbooks above. More articles coming to the archive soon.
      </div>
    </div>
  </section>

  <!-- LITE FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Read it. Then <span class="accent">ship it.</span></h2>
        <p class="final-sub">Try theStacc — $1 for 30 days. First article live in 24 hours.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    @media (max-width: 900px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .posts-grid { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
