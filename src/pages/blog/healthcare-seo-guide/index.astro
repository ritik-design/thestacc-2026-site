<td>/services/primary-care</td>
<td>"primary care doctor [city]"</td>
</tr>
<tr>
<td>Cardiology</td>
<td>/services/cardiology</td>
<td>"cardiologist [city]"</td>
</tr>
<tr>
<td>Orthopedics</td>
