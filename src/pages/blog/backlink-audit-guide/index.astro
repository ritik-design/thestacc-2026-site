<td></td>
<td></td>
<td></td>
<td></td>
</tr>
<tr>
<td>Referring domains</td>
<td></td>
<td></td>
<td></td>
<td></td>
</tr>
<tr>
<td>Domain Rating</td>
<td></td>
<td></td>
<td></td>
<td></td>
</tr>
<tr>
<td>Dofollow ratio</td>
<td></td>
<td></td>
<td></td>
<td></td>
</tr>
<tr>
<td>Avg. linking DR</td>
<td></td>
<td></td>
