<thead>
<tr>
<th>Service</th>
<th>Page URL</th>
<th>Target Keyword</th>
</tr>
</thead>
<tbody>
<tr>
<td>Dental Implants</td>
<td>/services/dental-implants</td>
<td>"dental implants [city]"</td>
</tr>
<tr>
<td>Teeth Whitening</td>
<td>/services/teeth-whitening</td>
<td>"teeth whitening [city]"</td>
</tr>
<tr>
