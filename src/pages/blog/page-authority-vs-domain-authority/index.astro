  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false" aria-controls="should-i-focus-on-pa-or-da-first">
      <span class="faq-q-text">Should I focus on PA or DA first?</span>
      <span class="faq-toggle"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span>
    </button>
