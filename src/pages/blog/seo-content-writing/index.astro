<thead>
<tr>
<th>Metric</th>
<th>Target Range</th>
</tr>
</thead>
<tbody>
<tr>
<td>Monthly search volume</td>
<td>100 to 10,000</td>
</tr>
<tr>
<td>Keyword difficulty</td>
<td>Under 40 for newer sites</td>
</tr>
<tr>
<td>Search intent</td>
<td>Informational or commercial</td>
</tr>
