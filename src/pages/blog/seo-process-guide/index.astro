      <div class="meta-item"><span class="meta-label">Published</span><span class="meta-value">May 27, 2026</span></div>
      <div class="meta-divider"></div>
      <div class="meta-item"><span class="meta-label">Read</span><span class="meta-value">11 min</span></div>
    </div>
