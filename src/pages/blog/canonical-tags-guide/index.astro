<thead>
<tr>
<th>Scenario</th>
<th>Example</th>
<th>Canonical Points To</th>
</tr>
</thead>
<tbody>
<tr>
<td><strong>URL parameters</strong></td>
<td><code>/products?color=red</code> and <code>/products?color=blue</code> show similar content</td>
<td><code>/products</code></td>
</tr>
<tr>
<td><strong>Tracking parameters</strong></td>
<td><code>/page?utm_source=facebook</code></td>
<td><code>/page</code></td>
</tr>
<tr>
<td><strong>Session IDs in URLs</strong></td>
<td><code>/page?sessionid=abc123</code></td>
<td><code>/page</code></td>
</tr>
<tr>
<td><strong>WWW vs non-WWW</strong></td>
