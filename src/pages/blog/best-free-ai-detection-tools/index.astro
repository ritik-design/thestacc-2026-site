<td>300-1,500 words per scan</td>
</tr>
<tr>
<td>Scans per day</td>
<td>3-10 scans</td>
</tr>
<tr>
<td>Model coverage</td>
<td>Older models only (GPT-3, not GPT-4)</td>
</tr>
<tr>
<td>Batch analysis</td>
<td>Not available on free plans</td>
</tr>
<tr>
<td>API access</td>
<td>Paid only</td>
</tr>
<tr>
<td>Detailed reports</td>
<td>Paid only</td>
</tr>
</tbody>
