    .author-avatar-hero { width: 120px; height: 120px; margin: 0 auto 28px; background: linear-gradient(135deg, var(--brand), var(--brand-deep)); color: white; display: grid; place-items: center; font-weight: 700; font-size: 38px; letter-spacing: -0.03em; border-radius: 50% !important; box-shadow: 0 22px 44px -16px var(--brand-glow); position: relative; }
