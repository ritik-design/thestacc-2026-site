<BaseLayout seo={seo}>
  <style>
    .author-hero { padding: 72px 32px 40px; max-width: 880px; margin: 0 auto; text-align: center; }
    .author-breadcrumb { display: inline-flex; gap: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 28px; flex-wrap: wrap; justify-content: center; }
