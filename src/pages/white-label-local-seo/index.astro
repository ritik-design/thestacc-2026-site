            <div class="step-card-row"><span class="step-card-key">Logo</span><span class="step-card-val">northwind-mark.svg ✓</span></div>
            <div class="step-card-row"><span class="step-card-key">Colors</span><span class="step-card-val">#0a2540 · #f7a000</span></div>
            <div class="step-card-row highlight"><span class="step-card-key">Status</span><span class="step-card-val"><strong>Clients see Northwind only</strong></span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid reverse">
