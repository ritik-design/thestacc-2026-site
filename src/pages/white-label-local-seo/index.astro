          <div class="step-card-2">
            <div class="step-card-header"><span class="step-card-tag">CLIENT 14 · LIVE</span><span class="step-card-status">● Auto</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 09:00</span><span class="step-feed-text">Bayside Dental · onboarded</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Tue 06:00</span><span class="step-feed-text">First GBP post live</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Tue 09:14</span><span class="step-feed-text">Citations · 38 built, 22 cleaned</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Wed 11:18</span><span class="step-feed-text">5-star review replied · in brand voice</span></div>
            <div class="step-feed-item"><span class="step-feed-dot live"></span><span class="step-feed-time">Now</span><span class="step-feed-text">Daily auto-run for 22 client accounts</span></div>
          </div>
