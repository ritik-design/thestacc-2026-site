      <div class="ws-col bad">
        <div class="ws-col-tag">GBP-ONLY TOOLS</div>
        <div class="ws-col-price">$89<span>/client</span></div>
        <ul>
          <li><span class="ws-check">✓</span>Rank tracking</li>
          <li><span class="ws-check">✓</span>GBP post queue</li>
          <li><span class="ws-x">✗</span>Daily posts written</li>
          <li><span class="ws-x">✗</span>Citation building</li>
          <li><span class="ws-x">✗</span>Review replies</li>
          <li><span class="ws-x">✗</span>Branded reports</li>
        </ul>
      </div>
      <div class="ws-col mid">
        <div class="ws-col-tag">CITATION SERVICES</div>
        <div class="ws-col-price">$59<span>/client</span></div>
        <ul>
          <li><span class="ws-x">✗</span>Rank tracking</li>
          <li><span class="ws-x">✗</span>GBP post queue</li>
          <li><span class="ws-x">✗</span>Daily posts written</li>
          <li><span class="ws-check">✓</span>Citation building</li>
          <li><span class="ws-x">✗</span>Review replies</li>
          <li><span class="ws-x">✗</span>Branded reports</li>
        </ul>
      </div>
      <div class="ws-col good">
        <div class="ws-col-tag brand">THESTACC</div>
        <div class="ws-col-price brand">$49<span>/client</span></div>
        <ul>
          <li><span class="ws-check brand">✓</span>Rank tracking</li>
          <li><span class="ws-check brand">✓</span>GBP post queue</li>
          <li><span class="ws-check brand">✓</span>Daily posts written</li>
