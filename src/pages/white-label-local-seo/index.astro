            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Map Pack + GBP + citations stitched</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Your brand on every page</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-3">
            <div class="step-card-header"><span class="step-card-tag">REPORTS SENT · NOV 1</span><span class="step-card-status">● Sent</span></div>
            <div class="step-stat-big">
              <span class="step-stat-num">22/22</span>
              <span class="step-stat-label">Client reports shipped</span>
              <span class="step-stat-delta">100% on-time, your brand</span>
            </div>
            <div class="step-stat-row">
              <div><strong>22</strong> clients</div>
              <div><strong>$49</strong> each</div>
              <div><strong>96%</strong> margin</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="faq-grid">
      <div class="faq-left">
        <span class="label-pill">03 · FAQ</span>
        <h2 class="h-md">White label local SEO, <span class="accent">answered.</span></h2>
        <p>More questions? Email <a href="mailto:founder@thestacc.com">founder@thestacc.com</a> — we reply within 24 hours.</p>
