---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'White-Label SEO Dashboard — Your Brand, Zero theStacc | theStacc',
  description: 'White-label dashboard with your logo, your domain, your colors. Clients see your brand. theStacc is invisible. $1 trial. Cancel anytime.',
  canonical: 'https://thestacc.com/features/white-label-dashboard/',
  ogImage: '/og/features-white-label-dashboard.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc White-Label Dashboard",
    "description": "White-label dashboard for agencies. Custom domain, custom logo, custom colors. No theStacc marks anywhere. Sell SEO as your own.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/features/white-label-dashboard/",
    "image": "https://thestacc.com/og/features-white-label-dashboard.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/blog/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · Custom domain SSL is one click</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Your brand. <span class="accent">Zero theStacc marks.</span></h1>
    <p class="hero-sub">Your logo top-left. Your domain in the URL bar. Your colors on every chart. Your email address on every report. Clients see your agency. They never see ours. That's the whole point.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">W</div><div class="av">L</div><div class="av">B</div><div class="av">L</div></div>
        <span><strong>340+</strong> agencies white-labelling</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">White-labelling for</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">0<span class="accent">×</span></div><div class="stat-label">theStacc marks · in client view</div></div>
      <div class="stat-cell"><div class="stat-num">5<span class="accent">m</span></div><div class="stat-label">Setup time · custom domain live</div></div>
      <div class="stat-cell"><div class="stat-num">340<span class="accent">+</span></div><div class="stat-label">Agencies · white-labelling now</div></div>
      <div class="stat-cell"><div class="stat-num">$3.5<span class="accent">k</span></div><div class="stat-label">Margin per client per month · avg</div></div>
    </div>
  </section>

  <!-- BENTO -->
  <section class="modules-bento" id="features">
    <div class="modules-tabs-header">
      <span class="label-pill">What you get</span>
      <h2 class="h-lg">Your domain. <span class="accent">Your logo. Your wins.</span></h2>
      <p class="lede">A white-label that's actually white. No tiny "powered by" in the footer. No theStacc email in the headers. No theStacc logo on the login page. You are the agency. We are the engine.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/modules/local-seo/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <h3 class="bento-title">Custom domain</h3>
        <h4 class="bento-sub">app.<span class="accent">your-agency.com</span>. SSL on by default.</h4>
        <p class="bento-desc">Point a CNAME at theStacc. Pick the subdomain — app, dashboard, reports, whatever fits your brand. SSL is auto-issued and renewed. Clients see only your URL. Always.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>1-click SSL · zero certificate work</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Unlimited subdomains · per-client option</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Email from <strong>reports@your-agency.com</strong></li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Custom favicon · custom OG image</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">DOMAIN · app.reed-marketing.com</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">SSL · A+ · Issued 4 min ago</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">Live</span>
            <span class="bento-mock-tag">Auto-renew</span>
            <span class="bento-mock-tag brand">Email ready</span>
          </div>
        </div>
        <div class="bento-cta">Explore Local SEO <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/case-studies/">
        <div class="bento-num">02</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"/><path d="M2 6h20"/><path d="M2 18h20"/></svg>
        </div>
        <h3 class="bento-title">Brand color theming</h3>
        <h4 class="bento-sub">Two colors. <span class="accent">Whole app re-skinned.</span></h4>
        <p class="bento-desc">Pick a primary hex code. Pick a secondary. Upload your logo. theStacc re-skins every chart, every button, every email. Your client thinks you built it. You did not tell them. They never know.</p>
        <div class="bento-mock bento-mock-grid">
          <div class="bento-grid-pin top3">A</div>
          <div class="bento-grid-pin top3">B</div>
          <div class="bento-grid-pin top3">C</div>
          <div class="bento-grid-pin top3">D</div>
          <div class="bento-grid-pin top3">E</div>
          <div class="bento-grid-pin top3">F</div>
          <div class="bento-grid-pin top3">G</div>
          <div class="bento-grid-pin top3">H</div>
          <div class="bento-grid-pin top3">I</div>
          <div class="bento-grid-pin top3">J</div>
          <div class="bento-grid-pin top3">K</div>
          <div class="bento-grid-pin top3">L</div>
          <div class="bento-grid-pin top3">M</div>
          <div class="bento-grid-pin top3">N</div>
          <div class="bento-grid-pin top3">O</div>
          <div class="bento-grid-pin top3">P</div>
        </div>
        <div class="bento-cta">Read agency stories <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/pricing/">
        <div class="bento-num">03</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
        </div>
        <h3 class="bento-title">Client logins under your brand</h3>
        <h4 class="bento-sub">They see your agency. <span class="accent">Always.</span></h4>
        <p class="bento-desc">Clients log in at app.your-agency.com. Reset emails come from your address. Onboarding screens carry your tone. There is no "theStacc" anywhere on the journey. Sell SEO as a product you built.</p>
        <div class="bento-mock bento-mock-social">
          <div class="bento-social-row"><span class="bento-social-icon">LGN</span><span class="bento-social-text">Login at app.reed-marketing.com</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">RST</span><span class="bento-social-text">Reset email · noreply@reed-marketing.com</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">PDF</span><span class="bento-social-text">Reports signed "Reed Marketing"</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">UI</span><span class="bento-social-text">Purple swapped to Reed orange</span><span class="bento-social-status">●</span></div>
        </div>
        <div class="bento-cta">See pricing <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- UNIQUE: Side-by-side before/after rebrand -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">Before + after</span>
      <h2 class="h-lg">Drop your logo. <span class="accent">Watch the rebrand.</span></h2>
      <p class="lede">Two screenshots from the same dashboard. Left: theStacc default. Right: Reed Marketing white-label. Same app. Different brand. 5 minutes to set up.</p>
    </div>

    <div style="max-width: 1040px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
      <!-- BEFORE -->
      <div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.08em; margin-bottom: 10px;">BEFORE · DEFAULT THESTACC</div>
        <div style="background: white; border: 1px solid var(--border);">
          <div style="background: var(--bg-soft); padding: 12px 16px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="background: var(--brand); color: white; padding: 4px 10px; font-weight: 700; font-size: 11px; font-family: 'Geist Mono', monospace;">theStacc</span>
              <span style="font-size: 11px; color: var(--text-3);">app.thestacc.com</span>
            </div>
            <div style="font-size: 11px; color: var(--text-3);">●●●</div>
          </div>
          <div style="padding: 24px 20px;">
            <div style="font-size: 12px; font-family: 'Geist Mono', monospace; color: var(--brand); margin-bottom: 6px; letter-spacing: 0.08em;">WEEKLY REPORT</div>
            <div style="font-size: 18px; font-weight: 700; color: var(--text-1); margin-bottom: 18px;">Oak Dental · Week 28</div>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
              <div style="background: #ede9fe; padding: 12px;">
                <div style="font-size: 22px; font-weight: 700; color: var(--brand);">+11</div>
                <div style="font-size: 10px; font-family: 'Geist Mono', monospace; color: var(--text-3);">RANK MOVES</div>
              </div>
              <div style="background: #ede9fe; padding: 12px;">
                <div style="font-size: 22px; font-weight: 700; color: var(--brand);">$8.4k</div>
                <div style="font-size: 10px; font-family: 'Geist Mono', monospace; color: var(--text-3);">REVENUE</div>
              </div>
            </div>
            <div style="margin-top: 18px; font-size: 10px; color: var(--text-3); font-family: 'Geist Mono', monospace;">POWERED BY THESTACC · 4.9★</div>
          </div>
        </div>
      </div>

      <!-- AFTER -->
      <div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); letter-spacing: 0.08em; margin-bottom: 10px;">AFTER · WHITE-LABEL FOR REED MARKETING</div>
        <div style="background: white; border: 1px solid var(--border);">
          <div style="background: #fff7ed; padding: 12px 16px; border-bottom: 1px solid #fed7aa; display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="background: #f97316; color: white; padding: 4px 10px; font-weight: 700; font-size: 11px; font-family: 'Geist Mono', monospace;">Reed Marketing</span>
              <span style="font-size: 11px; color: var(--text-3);">app.reed-marketing.com</span>
            </div>
            <div style="font-size: 11px; color: var(--text-3);">●●●</div>
          </div>
          <div style="padding: 24px 20px;">
            <div style="font-size: 12px; font-family: 'Geist Mono', monospace; color: #f97316; margin-bottom: 6px; letter-spacing: 0.08em;">WEEKLY REPORT</div>
            <div style="font-size: 18px; font-weight: 700; color: var(--text-1); margin-bottom: 18px;">Oak Dental · Week 28</div>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
              <div style="background: #fff7ed; padding: 12px;">
                <div style="font-size: 22px; font-weight: 700; color: #f97316;">+11</div>
                <div style="font-size: 10px; font-family: 'Geist Mono', monospace; color: var(--text-3);">RANK MOVES</div>
              </div>
              <div style="background: #fff7ed; padding: 12px;">
                <div style="font-size: 22px; font-weight: 700; color: #f97316;">$8.4k</div>
                <div style="font-size: 10px; font-family: 'Geist Mono', monospace; color: var(--text-3);">REVENUE</div>
              </div>
            </div>
            <div style="margin-top: 18px; font-size: 10px; color: var(--text-3); font-family: 'Geist Mono', monospace;">REED MARKETING · TRUSTED SEO PARTNER</div>
          </div>
        </div>
      </div>
    </div>

    <div style="max-width: 1040px; margin: 32px auto 0; text-align: center; font-size: 14px; color: var(--text-3);">
      Same data. Same numbers. <strong style="color: var(--text-1);">Different agency.</strong> Same 5-minute setup.
    </div>
  </section>

  <!-- HOW THIS SAVES YOU TIME / MONEY -->
  <section class="benefits-section">
    <div class="howitworks-header">
      <span class="label-pill">Why this matters</span>
      <h2 class="h-lg">Sell SEO at $3,500/mo. <span class="accent">Pay theStacc $99.</span></h2>
      <p class="lede">Reed Marketing in Chicago charges clients $3,500/mo for managed SEO. They pay theStacc $99/mo per client. The dashboard is white-labelled. Clients think it's a custom build. Margin is 97%.</p>
    </div>
    <div class="b-stagger">
      <div class="benefit-cell">
        <div class="stat-num">$3.5<span class="accent">k</span></div>
        <div class="stat-label">Avg sell price · per client · per month</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">$99<span class="accent">/mo</span></div>
        <div class="stat-label">theStacc cost · per client</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">97<span class="accent">%</span></div>
        <div class="stat-label">Margin · before agency overhead</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">5<span class="accent">m</span></div>
        <div class="stat-label">Setup time · domain + logo + colors</div>
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="integrations-section">
    <div class="integrations-header">
      <span class="label-pill">Integrations</span>
      <h2 class="h-lg">Wires into <span class="accent">your agency stack.</span></h2>
      <p class="lede">Stripe for billing, your CRM for handoff, Slack for alerts. theStacc fits the tools you already pay for. No rip-and-replace.</p>
      <div class="integrations-meta">
        <span><strong>5 min</strong> setup time</span>
        <span class="dot"></span>
        <span><strong>SOC 2</strong> Type 2 ready</span>
        <span class="dot"></span>
        <span><strong>SSO + SAML</strong> available</span>
      </div>
    </div>
    <div class="integrations-grid">
      <div class="integration-cell" title="Stripe"><img src="https://cdn.simpleicons.org/stripe" alt="Stripe" loading="lazy"/><span class="tip">Stripe</span></div>
      <div class="integration-cell" title="HubSpot"><img src="https://cdn.simpleicons.org/hubspot" alt="HubSpot" loading="lazy"/><span class="tip">HubSpot</span></div>
      <div class="integration-cell" title="Salesforce"><img src="https://cdn.simpleicons.org/salesforce" alt="Salesforce" loading="lazy"/><span class="tip">Salesforce</span></div>
      <div class="integration-cell" title="Slack"><img src="https://cdn.simpleicons.org/slack" alt="Slack" loading="lazy"/><span class="tip">Slack</span></div>
      <div class="integration-cell" title="Google Workspace"><img src="https://cdn.simpleicons.org/google" alt="Google" loading="lazy"/><span class="tip">Google Workspace</span></div>
      <div class="integration-cell" title="Microsoft 365"><img src="https://cdn.simpleicons.org/microsoft" alt="Microsoft" loading="lazy"/><span class="tip">Microsoft 365</span></div>
      <div class="integration-cell" title="Zapier"><img src="https://cdn.simpleicons.org/zapier" alt="Zapier" loading="lazy"/><span class="tip">Zapier</span></div>
      <div class="integration-cell custom" title="Custom">
        <div class="custom-label">
          <span class="custom-label-mono">CUSTOM</span>
          <span class="custom-label-title">REST API</span>
        </div>
        <span class="tip">Build anything</span>
      </div>
    </div>
  </section>

  <!-- GUARANTEE STRIP -->
  <section class="guarantee-section">
    <div class="guarantee-grid">
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>30-day money-back</h4>
          <p>Not happy in your first 30 days? Full refund. No forms. No questions asked.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>Zero brand leakage</h4>
          <p>No "powered by" footer. No theStacc email headers. No theStacc favicon. We sign an NDA.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg><use href="#i-check"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>No contract, no lock-in</h4>
          <p>Month-to-month. Cancel on your next billing date. Zero penalty, zero hassle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor"/>
        </pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Live in 5 minutes</span>
        <h2 class="final-headline">Your domain. <span class="accent">Your brand.</span><br/>Our engine. Invisible.</h2>
        <p class="final-sub">Custom domain. Custom colors. Custom emails. $1 trial. Cancel anytime.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>340+ agencies white-labelling</span> · <span>$1 trial</span> · <span>Cancel anytime</span></div>
        <p class="final-ps"><strong>P.S.</strong> Your client thinks you built the dashboard yourself. <span class="accent">We're fine with that.</span></p>
      </div>
    </div>
  </section>
</BaseLayout>
