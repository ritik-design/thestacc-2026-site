---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Multi-Location SEO Reporting — Portfolio View | theStacc',
  description: 'Multi-location reporting that shows every store, every clinic, every branch on one screen. Roll-up + drill-down. $1 trial. Cancel anytime.',
  canonical: 'https://thestacc.com/features/multi-location-reporting/',
  ogImage: '/og/features-multi-location-reporting.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Multi-Location Reporting",
    "description": "Portfolio reporting for chains and franchises. Roll up every location's rankings, reviews, traffic, and revenue into one screen. Drill into any branch.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/features/multi-location-reporting/",
    "image": "https://thestacc.com/og/features-multi-location-reporting.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/blog/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · Heatmap rollup view is live</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Every location. <span class="accent">One screen.</span></h1>
    <p class="hero-sub">Run 8 dental clinics? 47 storage units? 300 quick-lube shops? theStacc shows every site's rankings, reviews, traffic, and leads on one portfolio page. Drill into any location in one click.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">N</div><div class="av">S</div><div class="av">E</div><div class="av">W</div></div>
        <span><strong>14,200+</strong> locations tracked</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Portfolio view for</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">500<span class="accent">+</span></div><div class="stat-label">Locations · per single dashboard</div></div>
      <div class="stat-cell"><div class="stat-num">1<span class="accent">↑</span></div><div class="stat-label">Login · for every branch</div></div>
      <div class="stat-cell"><div class="stat-num">12<span class="accent">m</span></div><div class="stat-label">Weekly review · top + bottom 10</div></div>
      <div class="stat-cell"><div class="stat-num">$28<span class="accent">k</span></div><div class="stat-label">Saved each year · vs Yext multi-loc</div></div>
    </div>
  </section>

  <!-- BENTO -->
  <section class="modules-bento" id="features">
    <div class="modules-tabs-header">
      <span class="label-pill">What you get</span>
      <h2 class="h-lg">Roll up. <span class="accent">Drill down.</span> Move on.</h2>
      <p class="lede">The CEO sees the chain. The regional manager sees their 12 branches. The store owner sees one. Same data. Three views. Built in.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/modules/local-seo/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <h3 class="bento-title">Portfolio view</h3>
        <h4 class="bento-sub">Every location. <span class="accent">Ranked.</span> Sorted. Compared.</h4>
        <p class="bento-desc">A single table. Every location is a row. Map Pack rank, review average, weekly leads, monthly revenue. Sort by any column. The top 10 are obvious. So are the bottom 10.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Tag by region · brand · franchisee</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Filter to regions, states, or one team</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Top 10 + bottom 10 weekly digest</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>One CSV export of everything</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">PORTFOLIO · 47 LOCATIONS · WEEK 28</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">Top: Phoenix #2 · Worst: Detroit #28</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">Drill in →</span>
            <span class="bento-mock-tag">Sort by leads</span>
            <span class="bento-mock-tag brand">CSV all</span>
          </div>
        </div>
        <div class="bento-cta">Explore Local SEO <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/case-studies/">
        <div class="bento-num">02</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="bento-title">National heatmap</h3>
        <h4 class="bento-sub">A US map. <span class="accent">Green pins.</span> Red pins. Action.</h4>
        <p class="bento-desc">See your whole chain on a map. Green pins are winning the Map Pack. Red pins are losing. Click a red pin and see why — wrong category, no recent reviews, broken hours. Fix it. Pin turns green.</p>
        <div class="bento-mock bento-mock-grid">
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin">●</div>
          <div class="bento-grid-pin">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin">●</div>
          <div class="bento-grid-pin top3">●</div>
          <div class="bento-grid-pin top3">●</div>
        </div>
        <div class="bento-cta">Read customer stories <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/pricing/">
        <div class="bento-num">03</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><path d="M22 11h-6"/><path d="M22 15h-6"/></svg>
        </div>
        <h3 class="bento-title">Per-team logins</h3>
        <h4 class="bento-sub">Each store sees <span class="accent">only their data.</span></h4>
        <p class="bento-desc">The Phoenix manager logs in and only sees Phoenix. The regional VP sees their 12 stores. The CEO sees all 47. One platform, three permission tiers. No exports to spreadsheets.</p>
        <div class="bento-mock bento-mock-social">
          <div class="bento-social-row"><span class="bento-social-icon">CEO</span><span class="bento-social-text">Sees all 47 · roll-up dashboard</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">VP</span><span class="bento-social-text">Sees 12 · Southwest region</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">MGR</span><span class="bento-social-text">Sees 1 · Phoenix · drilldown</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">AGY</span><span class="bento-social-text">Sees client's 8 · white-label brand</span><span class="bento-social-status">●</span></div>
        </div>
        <div class="bento-cta">See pricing <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- UNIQUE: Portfolio leaderboard table -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">The leaderboard</span>
      <h2 class="h-lg">Who's winning. <span class="accent">Who needs help.</span></h2>
      <p class="lede">Every Monday, this table updates. Sort by leads. Sort by rank. Sort by review count. The branch that needs your attention is right at the bottom.</p>
    </div>

    <div style="max-width: 980px; margin: 0 auto; padding: 32px; background: var(--bg-soft); border: 1px solid var(--border);">
      <div style="display: flex; justify-content: space-between; padding-bottom: 16px; border-bottom: 1px solid var(--border); margin-bottom: 16px;">
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.08em;">LEADERBOARD · 47 LOCATIONS · SORTED BY LEADS</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 600;">● LIVE</div>
      </div>
      <div style="display: grid; grid-template-columns: 32px 2fr 80px 80px 100px 100px 80px; gap: 8px; font-size: 13px;">
        <div style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); padding: 8px 0;">#</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); padding: 8px 0;">LOCATION</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); padding: 8px 0; text-align: center;">RANK</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); padding: 8px 0; text-align: center;">★</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); padding: 8px 0; text-align: center;">CALLS</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); padding: 8px 0; text-align: center;">REVENUE</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); padding: 8px 0; text-align: center;">TREND</div>

        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 700; color: var(--brand);">1</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 500;">Phoenix · AZ</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; background: #dcfce7; color: #166534; font-weight: 600;">#2</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center;">4.8</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">412</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">$94k</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; color: #166534; font-weight: 700;">↑ 18%</div>

        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 700;">2</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 500;">Austin · TX</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; background: #dcfce7; color: #166534; font-weight: 600;">#1</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center;">4.9</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">389</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">$88k</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; color: #166534; font-weight: 700;">↑ 12%</div>

        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 700;">3</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 500;">Dallas · TX</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; background: #dcfce7; color: #166534; font-weight: 600;">#3</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center;">4.7</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">317</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">$72k</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; color: #166534; font-weight: 700;">↑ 9%</div>

        <div style="padding: 12px 0; border-top: 1px solid var(--border); color: var(--text-3); text-align: center;">⋮</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); color: var(--text-3);">42 more locations · scroll for full list</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border);"></div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border);"></div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border);"></div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border);"></div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border);"></div>

        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 700; color: #991b1b;">46</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 500;">Cleveland · OH</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; background: #fef3c7; color: #92400e; font-weight: 600;">#19</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center;">3.8</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">42</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">$11k</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; color: #991b1b; font-weight: 700;">↓ 22%</div>

        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 700; color: #991b1b;">47</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); font-weight: 500;">Detroit · MI</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; background: #fee2e2; color: #991b1b; font-weight: 600;">#28</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center;">3.6</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">29</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; font-weight: 600;">$7k</div>
        <div style="padding: 12px 0; border-top: 1px solid var(--border); text-align: center; color: #991b1b; font-weight: 700;">↓ 31%</div>
      </div>
      <div style="margin-top: 24px; padding-top: 16px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; font-size: 13px;">
        <span><strong>47</strong> locations · <strong>$1.4M</strong> total revenue</span>
        <span style="color: var(--brand); font-weight: 600;">Fix bottom 2 → projected +$22k/mo</span>
      </div>
    </div>
  </section>

  <!-- HOW THIS SAVES YOU TIME / MONEY -->
  <section class="benefits-section">
    <div class="howitworks-header">
      <span class="label-pill">Why this matters</span>
      <h2 class="h-lg">Pull the weak branches up. <span class="accent">The whole chain grows.</span></h2>
      <p class="lede">A storage chain with 47 locations spotted 6 sites stuck below #15 in their Map Pack. theStacc showed the gaps in 4 hours. Six weeks later, 5 of 6 were in the top 5. Revenue per branch up $4,800/mo.</p>
    </div>
    <div class="b-stagger">
      <div class="benefit-cell">
        <div class="stat-num">$4.8<span class="accent">k</span></div>
        <div class="stat-label">Lift per branch · storage chain case</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">5<span class="accent">/6</span></div>
        <div class="stat-label">Weak branches saved · 6 weeks</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">$28<span class="accent">k</span></div>
        <div class="stat-label">Saved each year · vs Yext multi-loc</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">4<span class="accent">h</span></div>
        <div class="stat-label">To spot the gaps · vs 3 weeks of audits</div>
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="integrations-section">
    <div class="integrations-header">
      <span class="label-pill">Integrations</span>
      <h2 class="h-lg">Pulls signal from <span class="accent">every branch's tools.</span></h2>
      <p class="lede">GBP, GA4, your POS, your CRM, your booking tool — wired together so every branch's numbers feed the portfolio dashboard.</p>
      <div class="integrations-meta">
        <span><strong>1 sync</strong> across all branches</span>
        <span class="dot"></span>
        <span><strong>500+</strong> locations supported</span>
        <span class="dot"></span>
        <span><strong>100%</strong> no-code</span>
      </div>
    </div>
    <div class="integrations-grid">
      <div class="integration-cell" title="Google Business"><img src="https://cdn.simpleicons.org/google" alt="Google Business" loading="lazy"/><span class="tip">Google Business</span></div>
      <div class="integration-cell" title="GA4"><img src="https://cdn.simpleicons.org/googleanalytics" alt="GA4" loading="lazy"/><span class="tip">GA4</span></div>
      <div class="integration-cell" title="Square POS"><img src="https://cdn.simpleicons.org/square" alt="Square" loading="lazy"/><span class="tip">Square POS</span></div>
      <div class="integration-cell" title="Toast POS"><img src="https://cdn.simpleicons.org/toast" alt="Toast" loading="lazy"/><span class="tip">Toast POS</span></div>
      <div class="integration-cell" title="HubSpot"><img src="https://cdn.simpleicons.org/hubspot" alt="HubSpot" loading="lazy"/><span class="tip">HubSpot</span></div>
      <div class="integration-cell" title="Salesforce"><img src="https://cdn.simpleicons.org/salesforce" alt="Salesforce" loading="lazy"/><span class="tip">Salesforce</span></div>
      <div class="integration-cell" title="Slack"><img src="https://cdn.simpleicons.org/slack" alt="Slack" loading="lazy"/><span class="tip">Slack</span></div>
      <div class="integration-cell custom" title="Custom">
        <div class="custom-label">
          <span class="custom-label-mono">CUSTOM</span>
          <span class="custom-label-title">CSV / API</span>
        </div>
        <span class="tip">Any tool</span>
      </div>
    </div>
  </section>

  <!-- GUARANTEE STRIP -->
  <section class="guarantee-section">
    <div class="guarantee-grid">
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>30-day money-back</h4>
          <p>Not happy in your first 30 days? Full refund. No forms. No questions asked.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
