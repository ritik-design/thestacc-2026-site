---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Citation Management — Listed on 50+ Directories | theStacc',
  description: 'Citation management that lists your business on 50+ directories and keeps the data clean. Yelp, Apple, Bing, Facebook, and 47 more. $1 trial. Cancel anytime.',
  canonical: 'https://thestacc.com/features/citation-management/',
  ogImage: '/og/features-citation-management.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Citation Management",
    "description": "Citation management software that lists your business on 50+ directories, fixes wrong info, and keeps every listing in sync.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/features/citation-management/",
    "image": "https://thestacc.com/og/features-citation-management.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/blog/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · Apple Maps + Bing Places added</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Get listed on <span class="accent">50+ directories.</span> In one day.</h1>
    <p class="hero-sub">Yelp, Apple Maps, Bing, Facebook, Foursquare, and 45 more. theStacc submits your name, address, phone, and hours to every one. Then it watches them. If anything changes, it fixes it.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">B</div><div class="av">K</div><div class="av">L</div><div class="av">T</div></div>
        <span><strong>127+</strong> businesses listed</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Listing businesses everywhere</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">52<span class="accent">+</span></div><div class="stat-label">Directories submitted · per business</div></div>
      <div class="stat-cell"><div class="stat-num">24<span class="accent">h</span></div><div class="stat-label">From signup to live listings</div></div>
      <div class="stat-cell"><div class="stat-num">98<span class="accent">%</span></div><div class="stat-label">Listings stay clean · auto-corrected</div></div>
      <div class="stat-cell"><div class="stat-num">3<span class="accent">×</span></div><div class="stat-label">More Map Pack views · 60 days</div></div>
    </div>
  </section>

  <!-- BENTO: 3 features -->
  <section class="modules-bento" id="features">
    <div class="modules-tabs-header">
      <span class="label-pill">What you get</span>
      <h2 class="h-lg">Three jobs. <span class="accent">All on auto.</span></h2>
      <p class="lede">Submit to every directory that matters. Watch for changes. Fix mistakes the same day. You never log into Yelp again. You never miss a listing edit.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/modules/local-seo/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3 class="bento-title">Bulk submission</h3>
        <h4 class="bento-sub">52 directories. <span class="accent">One form.</span> One day.</h4>
        <p class="bento-desc">Fill in your name, address, phone, hours, and categories once. theStacc submits the same data to Yelp, Apple, Bing, Facebook, Foursquare, BBB, and 46 more. Most go live in 24 hours.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Top 52 US + UK + AU directories</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Industry-specific sites · Avvo, Houzz, OpenTable</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Logos, photos, services synced</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Live status per directory · in dashboard</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">SUBMITTING · BATCH 1 OF 3</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">47 of 52 live · 5 pending review</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">Yelp ●</span>
            <span class="bento-mock-tag brand">Apple ●</span>
            <span class="bento-mock-tag">Bing ●</span>
          </div>
        </div>
        <div class="bento-cta">Explore Local SEO <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/case-studies/">
        <div class="bento-num">02</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <h3 class="bento-title">Listing watch</h3>
        <h4 class="bento-sub">Wrong hours on Yelp? <span class="accent">Fixed by noon.</span></h4>
        <p class="bento-desc">A scraper checks every listing every week. If Yelp lists your old phone number, theStacc files a fix the same day. You see a green check in the dashboard. The customer calls the right line.</p>
        <div class="bento-mock bento-mock-grid">
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin">!</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin">!</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
          <div class="bento-grid-pin top3">✓</div>
        </div>
        <div class="bento-cta">Read customer stories <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/pricing/">
        <div class="bento-num">03</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="bento-title">Duplicate killer</h3>
        <h4 class="bento-sub">Two Yelp pages? <span class="accent">Merged.</span> Old address? Gone.</h4>
        <p class="bento-desc">Old listings drag your ranking down. theStacc finds them — the wrong address from your last office, the duplicate from when a customer added one. It files takedowns. They disappear.</p>
        <div class="bento-mock bento-mock-social">
          <div class="bento-social-row"><span class="bento-social-icon">YLP</span><span class="bento-social-text">Old address · 2017 · removed</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">FB</span><span class="bento-social-text">Duplicate page · merged to main</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">BNG</span><span class="bento-social-text">Wrong phone · fixed</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">FSQ</span><span class="bento-social-text">Misspelled name · corrected</span><span class="bento-social-status">●</span></div>
        </div>
        <div class="bento-cta">See pricing <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- UNIQUE: Directory wall -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">The 52 directories</span>
      <h2 class="h-lg">Every place customers <span class="accent">might find you.</span></h2>
      <p class="lede">Most agencies stop at the top 10. We do not. The other 42 are where the cheap, easy citations sit. They build trust with Google. They send real calls.</p>
    </div>

    <div style="max-width: 980px; margin: 0 auto; padding: 32px; background: var(--bg-soft); border: 1px solid var(--border);">
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;">
        {[
          ['Google Business', 'Live'], ['Apple Maps', 'Live'], ['Bing Places', 'Live'], ['Yelp', 'Live'],
          ['Facebook', 'Live'], ['Foursquare', 'Live'], ['Yellow Pages', 'Live'], ['BBB', 'Live'],
          ['Houzz', 'Live'], ['Angi', 'Live'], ['Avvo', 'Live'], ['HomeAdvisor', 'Live'],
          ['Thumbtack', 'Live'], ['OpenTable', 'Live'], ['Healthgrades', 'Live'], ['Zocdoc', 'Live'],
          ['Trustpilot', 'Live'], ['Glassdoor', 'Live'], ['MapQuest', 'Live'], ['Citysearch', 'Live'],
          ['Superpages', 'Live'], ['Manta', 'Live'], ['Hotfrog', 'Live'], ['Brownbook', 'Live'],
          ['eLocal', 'Live'], ['Cylex', 'Live'], ['Tupalo', 'Live'], ['EZlocal', 'Live'],
          ['LocalStack', 'Live'], ['n49', 'Live'], ['Chamberofcommerce', 'Live'], ['Yellowbot', 'Live'],
        ].map(([name, status]) => (
          <div style="background: white; border: 1px solid var(--border); padding: 14px 12px; display: flex; flex-direction: column; gap: 6px;">
            <div style="font-size: 13px; font-weight: 600; color: var(--text-1);">{name}</div>
            <div style="display: flex; align-items: center; gap: 6px; font-family: 'Geist Mono', monospace; font-size: 10px; color: #10b981;">
              <span style="display: inline-block; width: 6px; height: 6px; background: #10b981;"></span>
              {status}
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border); text-align: center; font-size: 13px; color: var(--text-3);">
        <strong style="color: var(--text-1);">+ 20 more</strong> · industry-specific directories pulled per niche
      </div>
    </div>
  </section>

  <!-- HOW THIS SAVES YOU TIME / MONEY -->
  <section class="benefits-section">
    <div class="howitworks-header">
      <span class="label-pill">Why this matters</span>
      <h2 class="h-lg">Lost calls cost real money. <span class="accent">Fix the listings. Get the calls.</span></h2>
      <p class="lede">A dental office in Phoenix had 11 directory listings with the old phone number. Every wrong listing = a missed lead. After theStacc cleaned them up, calls went up 38% in 6 weeks.</p>
    </div>
    <div class="b-stagger">
      <div class="benefit-cell">
        <div class="stat-num">38<span class="accent">%</span></div>
        <div class="stat-label">More calls · 6 weeks · dentist case</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">11<span class="accent">+</span></div>
        <div class="stat-label">Wrong listings found · average new customer</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">$1.2<span class="accent">k</span></div>
        <div class="stat-label">Saved each month · vs Yext + BrightLocal</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">0<span class="accent">h</span></div>
        <div class="stat-label">You spend on listing edits</div>
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="integrations-section">
    <div class="integrations-header">
      <span class="label-pill">Integrations</span>
      <h2 class="h-lg">Pulls business data from <span class="accent">where you keep it.</span></h2>
      <p class="lede">Google Business Profile, your CRM, your booking tool — wired in so a change of hours updates every directory the same day.</p>
      <div class="integrations-meta">
        <span><strong>90 sec</strong> avg connect time</span>
        <span class="dot"></span>
        <span><strong>52</strong> directories live</span>
        <span class="dot"></span>
        <span><strong>100%</strong> no-code</span>
      </div>
    </div>
    <div class="integrations-grid">
      <div class="integration-cell" title="WordPress"><img src="https://cdn.simpleicons.org/wordpress" alt="WordPress" loading="lazy"/><span class="tip">WordPress</span></div>
      <div class="integration-cell" title="Webflow"><img src="https://cdn.simpleicons.org/webflow" alt="Webflow" loading="lazy"/><span class="tip">Webflow</span></div>
      <div class="integration-cell" title="Shopify"><img src="https://cdn.simpleicons.org/shopify" alt="Shopify" loading="lazy"/><span class="tip">Shopify</span></div>
      <div class="integration-cell" title="Ghost"><img src="https://cdn.simpleicons.org/ghost" alt="Ghost" loading="lazy"/><span class="tip">Ghost</span></div>
      <div class="integration-cell" title="Wix"><img src="https://cdn.simpleicons.org/wix" alt="Wix" loading="lazy"/><span class="tip">Wix</span></div>
      <div class="integration-cell" title="Squarespace"><img src="https://cdn.simpleicons.org/squarespace" alt="Squarespace" loading="lazy"/><span class="tip">Squarespace</span></div>
      <div class="integration-cell" title="HubSpot"><img src="https://cdn.simpleicons.org/hubspot" alt="HubSpot" loading="lazy"/><span class="tip">HubSpot</span></div>
      <div class="integration-cell custom" title="Custom CMS">
        <div class="custom-label">
          <span class="custom-label-mono">CUSTOM</span>
          <span class="custom-label-title">Any CMS</span>
        </div>
        <span class="tip">Webhook · API</span>
      </div>
    </div>
  </section>

  <!-- GUARANTEE STRIP -->
  <section class="guarantee-section">
    <div class="guarantee-grid">
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>30-day money-back</h4>
          <p>Not happy in your first 30 days? Full refund. No forms. No questions asked.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>You own the listings</h4>
          <p>We list under your accounts, not ours. Cancel theStacc and the listings stay live forever.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg><use href="#i-check"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>No contract, no lock-in</h4>
          <p>Month-to-month. Cancel on your next billing date. Zero penalty, zero hassle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor"/>
        </pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Live in 24 hours</span>
        <h2 class="final-headline">52 directories. <span class="accent">One submission.</span><br/>Calls from day one.</h2>
        <p class="final-sub">Bulk submit. Auto-fix. Duplicate kill. $1 trial. Cancel anytime.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>84 businesses started this week</span> · <span>52+ directories live</span> · <span>$1 trial</span> · <span>Cancel anytime</span></div>
        <p class="final-ps"><strong>P.S.</strong> A wrong phone number on Yelp costs you a customer every week. <span class="accent">theStacc finds it. Fixes it. Today.</span></p>
      </div>
    </div>
  </section>
</BaseLayout>
