---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Rank Tracking Software — Daily Keyword + Map Pack Tracking | theStacc',
  description: 'Rank tracking software that watches your keywords, Map Pack positions, and AI-search citations daily. Reports land Friday. $1 trial, no contract.',
  canonical: 'https://thestacc.com/features/rank-tracking/',
  ogImage: '/og/features-rank-tracking.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Rank Tracking",
    "description": "Rank tracking software built into theStacc — daily keyword tracking, Map Pack monitoring, AI-search citation tracking, and a Friday report that ties rankings to revenue.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/features/rank-tracking/",
    "image": "https://thestacc.com/og/features-rank-tracking.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/blog/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · AI-search citation tracking is live</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Rank tracking software that <span class="accent">runs while you sleep.</span></h1>
    <p class="hero-sub">Daily checks on every keyword, every Map Pack position, and every AI-search citation — across <strong>Google, ChatGPT, Perplexity, and Gemini</strong>. One dashboard. One Friday report. Zero spreadsheet duty.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">R</div><div class="av">M</div><div class="av">S</div><div class="av">J</div></div>
        <span><strong>127+</strong> businesses tracking</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Tracking rankings for</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">24<span class="accent">h</span></div><div class="stat-label">Rank checks · every keyword</div></div>
      <div class="stat-cell"><div class="stat-num">47<span class="accent">+</span></div><div class="stat-label">Tracked keywords · per business</div></div>
      <div class="stat-cell"><div class="stat-num">92<span class="accent">%</span></div><div class="stat-label">Hit Map Pack top 3 · 90 days</div></div>
      <div class="stat-cell"><div class="stat-num">4<span class="accent">×</span></div><div class="stat-label">AI engines tracked for citations</div></div>
    </div>
  </section>

  <!-- BENTO: 3 features -->
  <section class="modules-bento" id="features">
    <div class="modules-tabs-header">
      <span class="label-pill">What you track</span>
      <h2 class="h-lg">Three views. <span class="accent">One source of truth.</span></h2>
      <p class="lede">Classic keyword ranks, Map Pack positions, and AI-search citations — checked daily, plotted on one timeline, attributed to the article that moved them.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/modules/content-seo/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h3 class="bento-title">Daily keyword tracking</h3>
        <h4 class="bento-sub">Every keyword. <span class="accent">Every day.</span> Plotted against the article that moved it.</h4>
        <p class="bento-desc">theStacc checks every tracked keyword in your target locale, every 24 hours, and overlays the chart with the day each article went live. You stop guessing which post earned the bump.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Desktop + mobile · per-country / per-city</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Featured snippet, PAA, sitelinks tracked</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Article-to-keyword attribution baked in</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Friday report · every win, every slip</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">KEYWORD · "dental implants austin"</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">#42 → #6 in 60 days</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">+36 positions</span>
            <span class="bento-mock-tag">8 articles published</span>
            <span class="bento-mock-tag brand">PAA captured</span>
          </div>
        </div>
        <div class="bento-cta">Explore Content SEO <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/modules/local-seo/">
        <div class="bento-num">02</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="bento-title">Map Pack tracking</h3>
        <h4 class="bento-sub">Where you sit on Maps — <span class="accent">grid-scanned</span> across your service area.</h4>
        <p class="bento-desc">A 5×5 geo-grid samples your Map Pack position from every corner of your trade area, daily. You see the heatmap of where you rank, where you don't, and which GBP post fixed it.</p>
        <div class="bento-mock bento-mock-grid">
          <div class="bento-grid-pin top3">1</div>
          <div class="bento-grid-pin top3">2</div>
          <div class="bento-grid-pin top3">3</div>
          <div class="bento-grid-pin">5</div>
          <div class="bento-grid-pin">7</div>
          <div class="bento-grid-pin top3">2</div>
          <div class="bento-grid-pin">8</div>
          <div class="bento-grid-pin">4</div>
          <div class="bento-grid-pin top3">1</div>
          <div class="bento-grid-pin top3">3</div>
          <div class="bento-grid-pin">6</div>
          <div class="bento-grid-pin top3">2</div>
          <div class="bento-grid-pin">5</div>
          <div class="bento-grid-pin top3">3</div>
          <div class="bento-grid-pin">9</div>
          <div class="bento-grid-pin top3">1</div>
        </div>
        <div class="bento-cta">Explore Local SEO <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/glossary/">
        <div class="bento-num">03</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <h3 class="bento-title">AI-search citation tracking</h3>
        <h4 class="bento-sub">Track every time <span class="accent">ChatGPT, Perplexity, Gemini, or Copilot</span> quotes you.</h4>
        <p class="bento-desc">theStacc runs your target prompts against the major generative engines weekly and logs every citation. You finally know whether the LLMs see you as a source — and which articles they pick.</p>
        <div class="bento-mock bento-mock-social">
          <div class="bento-social-row"><span class="bento-social-icon">GPT</span><span class="bento-social-text">"best dentist austin" · cited 3× this week</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">PPX</span><span class="bento-social-text">"dental implants cost" · cited 5× this week</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">GEM</span><span class="bento-social-text">"invisalign vs braces" · cited 2× this week</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">COP</span><span class="bento-social-text">"sedation dentistry" · cited 1× this week</span><span class="bento-social-status">●</span></div>
        </div>
        <div class="bento-cta">Browse 690+ glossary terms <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">How it works</span>
      <h2 class="h-lg">Set it up once. <span class="accent">Read the Friday report.</span></h2>
      <p class="lede">No daily check-ins. No exporting CSVs at 11pm. theStacc tracks what matters and summarises it once a week.</p>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">01</span><span class="step-day">Day 1 · 3 minutes</span></div>
          <h3 class="h-md">Drop in your keywords <span class="accent">and locations.</span></h3>
          <p>Paste your target keywords or import them from Search Console. Pick the city, region, or country you care about. theStacc starts checking that night.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>GSC import · 1-click sync of your real winners</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Up to 500 keywords on the bundle plan</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Multi-location · per-city tracking for chains</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-1">
            <div class="step-card-header">
              <span class="step-card-tag">SETUP · 3 MIN</span>
              <span class="step-card-status">● Complete</span>
            </div>
            <div class="step-card-row"><span class="step-card-key">Keywords</span><span class="step-card-val">47 imported · GSC</span></div>
            <div class="step-card-row"><span class="step-card-key">Locations</span><span class="step-card-val">Austin TX · Round Rock TX</span></div>
            <div class="step-card-row"><span class="step-card-key">Device</span><span class="step-card-val">Desktop + Mobile</span></div>
            <div class="step-card-row"><span class="step-card-key">Engines</span><span class="step-card-val">Google · Maps · 4 AI engines</span></div>
            <div class="step-card-row highlight"><span class="step-card-key">First check</span><span class="step-card-val"><strong>Tonight at 03:00 local</strong></span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid reverse">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">02</span><span class="step-day">Daily · Auto-pilot</span></div>
          <h3 class="h-md">Track daily. <span class="accent">Forget about it.</span></h3>
          <p>Every night at 3am local, theStacc re-checks every keyword, every grid point, and every LLM prompt. Movement shows up on the chart by breakfast — no app to open.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Slack + email alerts for top-3 wins and top-10 drops</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Cannibalisation alerts when two pages compete</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>SERP-feature alerts · PAA, snippet, AI Overview</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-2">
            <div class="step-card-header">
              <span class="step-card-tag">THIS WEEK · LIVE FEED</span>
              <span class="step-card-status">● Auto</span>
            </div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 03:14</span><span class="step-feed-text">+6 positions · <strong>"dental implants austin"</strong></span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Tue 03:09</span><span class="step-feed-text">Map Pack #2 · <strong>"emergency dentist"</strong></span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Wed 03:11</span><span class="step-feed-text">Featured snippet won · <strong>"cost of invisalign"</strong></span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Thu 03:07</span><span class="step-feed-text">ChatGPT citation · <strong>"sedation dentistry"</strong></span></div>
            <div class="step-feed-item"><span class="step-feed-dot live"></span><span class="step-feed-time">Fri 08:00</span><span class="step-feed-text">Weekly report · queued to send</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">03</span><span class="step-day">Friday · Report</span></div>
          <h3 class="h-md">A Friday report that <span class="accent">ties rankings to revenue.</span></h3>
          <p>Every Friday at 8am, an email lands: every keyword that moved this week, every article that earned the move, and the leads attributed to each. No dashboard hunting required.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Top movers · top losers · why they moved</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Revenue per ranked keyword (GA4 wired in)</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>PDF export · branded for client reporting</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-3">
            <div class="step-card-header">
              <span class="step-card-tag">FRIDAY REPORT · WEEK 12</span>
              <span class="step-card-status">● Sent</span>
            </div>
            <div class="step-stat-big">
              <span class="step-stat-num">+18</span>
              <span class="step-stat-label">Keywords moved into top 10</span>
              <span class="step-stat-delta">↑ 218% vs Week 1</span>
            </div>
            <div class="step-stat-row">
              <div><strong>47</strong> KW tracked</div>
              <div><strong>#2</strong> Map Pack</div>
              <div><strong>$3.2k</strong> attributed</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="integrations-section">
    <div class="integrations-header">
      <span class="label-pill">Integrations</span>
      <h2 class="h-lg">Pulls signal from <span class="accent">where you already work.</span></h2>
      <p class="lede">Search Console, GA4, GBP, and your CMS — wired together so every rank movement is attributed to an article and a dollar.</p>
      <div class="integrations-meta">
        <span><strong>90 sec</strong> avg connect time</span>
        <span class="dot"></span>
        <span><strong>8</strong> CMS supported</span>
        <span class="dot"></span>
        <span><strong>100%</strong> no-code</span>
      </div>
    </div>
    <div class="integrations-grid">
      <div class="integration-cell" title="WordPress"><img src="https://cdn.simpleicons.org/wordpress" alt="WordPress" loading="lazy"/><span class="tip">WordPress</span></div>
      <div class="integration-cell" title="Webflow"><img src="https://cdn.simpleicons.org/webflow" alt="Webflow" loading="lazy"/><span class="tip">Webflow</span></div>
      <div class="integration-cell" title="Shopify"><img src="https://cdn.simpleicons.org/shopify" alt="Shopify" loading="lazy"/><span class="tip">Shopify</span></div>
      <div class="integration-cell" title="Ghost"><img src="https://cdn.simpleicons.org/ghost" alt="Ghost" loading="lazy"/><span class="tip">Ghost</span></div>
      <div class="integration-cell" title="Wix"><img src="https://cdn.simpleicons.org/wix" alt="Wix" loading="lazy"/><span class="tip">Wix</span></div>
      <div class="integration-cell" title="Squarespace"><img src="https://cdn.simpleicons.org/squarespace" alt="Squarespace" loading="lazy"/><span class="tip">Squarespace</span></div>
      <div class="integration-cell" title="HubSpot"><img src="https://cdn.simpleicons.org/hubspot" alt="HubSpot" loading="lazy"/><span class="tip">HubSpot</span></div>
      <div class="integration-cell custom" title="Custom CMS">
        <div class="custom-label">
          <span class="custom-label-mono">CUSTOM</span>
          <span class="custom-label-title">Any CMS</span>
        </div>
        <span class="tip">Webhook · API</span>
      </div>
    </div>
  </section>

  <!-- GUARANTEE STRIP -->
  <section class="guarantee-section">
    <div class="guarantee-grid">
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>30-day money-back</h4>
          <p>Not happy in your first 30 days? Full refund. No forms. No questions asked.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>Data stays yours</h4>
          <p>Export your full ranking history any time. CSV, PDF, or API — your data is never locked in.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg><use href="#i-check"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>No contract, no lock-in</h4>
          <p>Month-to-month. Cancel on your next billing date. Zero penalty, zero hassle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor"/>
        </pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Start in 90 seconds</span>
        <h2 class="final-headline">Stop guessing <span class="accent">your rankings.</span><br/>Start reading them.</h2>
        <p class="final-sub">Daily checks. Friday report. $1 trial. Cancel anytime.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>84 businesses started this week</span> · <span>47k keywords tracked this month</span> · <span>$1 trial</span> · <span>Cancel anytime</span></div>
        <p class="final-ps"><strong>P.S.</strong> The ranking you check by hand on Friday already moved on Monday. <span class="accent">theStacc saw it. You didn't.</span></p>
      </div>
    </div>
  </section>
</BaseLayout>
