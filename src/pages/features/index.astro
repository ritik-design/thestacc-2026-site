---
import BaseLayout from '../../layouts/BaseLayout.astro';
const seo = {
  title: 'Features — Every theStacc capability in one place',
  description: 'Every feature on theStacc — rank tracking, content automation, GBP automation, reviews, social scheduling, AI engine, integrations, white-label, multi-location, reporting.',
  canonical: 'https://thestacc.com/features/',
  ogImage: '/og/features.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "theStacc features",
    "url": "https://thestacc.com/features/"
  }
};

const features = [
  { slug: 'rank-tracking', name: 'Rank tracking', module: 'Local SEO', desc: 'Track Map Pack and organic ranks for every keyword, every day, across every location.', icon: 'chart' },
  { slug: 'content-automation', name: 'Content automation', module: 'Content SEO', desc: '30 SEO-scored articles a month — researched, written, and published to your CMS.', icon: 'doc' },
  { slug: 'gbp-automation', name: 'GBP automation', module: 'Local SEO', desc: 'Google Business Profile posts, photos, and Q&A — all published on autopilot.', icon: 'pin' },
  { slug: 'review-management', name: 'Review management', module: 'Local SEO', desc: 'New reviews replied to in 3 minutes — in your brand voice, across every platform.', icon: 'star' },
  { slug: 'social-scheduling', name: 'Social scheduling', module: 'Social Media', desc: '30+ posts a month across IG, LinkedIn, X, Facebook — scheduled or auto-published.', icon: 'share' },
  { slug: 'ai-engine', name: 'AI engine', module: 'Core', desc: 'The model trained on your brand voice, your products, and your real customer language.', icon: 'spark' },
  { slug: 'integrations', name: 'Integrations', module: 'Core', desc: 'WordPress, Webflow, Shopify, Ghost, Wix, Squarespace, HubSpot, custom CMS via webhook.', icon: 'plug' },
  { slug: 'white-label', name: 'White-label', module: 'Agency', desc: 'Run theStacc under your own brand for clients. Custom domain, custom emails, custom reports.', icon: 'tag' },
  { slug: 'multi-location', name: 'Multi-location', module: 'Local SEO', desc: 'Manage 5 to 5,000 locations from one dashboard. Bulk-publish per region, per franchise.', icon: 'map' },
  { slug: 'reporting', name: 'Reporting', module: 'Core', desc: 'Weekly progress emails, monthly client-ready PDFs, live dashboards for every stakeholder.', icon: 'graph' },
  { slug: 'citation-building', name: 'Citation building', module: 'Local SEO', desc: 'Built and synced across 50+ directories — NAP consistency monitored in real time.', icon: 'list' },
  { slug: 'schema-generator', name: 'Schema generator', module: 'Content SEO', desc: 'JSON-LD schema generated for every article — FAQ, How-to, Article, Product, LocalBusiness.', icon: 'code' },
];

const iconMap = {
  chart: '<path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/>',
  doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
  pin: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  star: '<polygon points="12 2 15 9 22 9 17 14 19 22 12 18 5 22 7 14 2 9 9 9"/>',
  share: '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>',
  spark: '<path d="M12 2 L15 9 L22 12 L15 15 L12 22 L9 15 L2 12 L9 9 Z"/>',
  plug: '<path d="M9 2v6M15 2v6M5 8h14v4a7 7 0 0 1-14 0z"/>',
  tag: '<path d="M20.59 13.41L13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="1.5"/>',
  map: '<polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>',
  graph: '<path d="M3 3v18h18"/><path d="M7 12l3-3 3 3 5-5"/>',
  list: '<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1.5"/><circle cx="4" cy="12" r="1.5"/><circle cx="4" cy="18" r="1.5"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Features · The full list</span>
    <h1 class="h-display">Every feature, <span class="accent">in one place.</span></h1>
    <p class="hero-sub">From rank tracking to white-label reporting — every capability theStacc ships, grouped by module. Click any feature to read the deep dive.</p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
  </section>

  <!-- FILTER PILLS -->
  <section style="padding: 32px; background: white; border-bottom: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;">
      <span class="label-pill" style="background: var(--brand-softer); border-color: var(--brand-soft);">All features</span>
      <span class="label-pill">Content SEO</span>
      <span class="label-pill">Local SEO</span>
      <span class="label-pill">Social Media</span>
      <span class="label-pill">Core</span>
      <span class="label-pill">Agency</span>
    </div>
  </section>

  <!-- FEATURES GRID -->
  <section style="padding: 80px 32px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
        {features.map((f) => (
          <a href={`/features/${f.slug}/`} class="bento-card" style="padding: 28px;">
            <div class="bento-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconMap[f.icon]} />
            </div>
            <div class="bento-title" style="margin-bottom: 8px;">{f.module}</div>
            <h3 class="h-sm" style="margin-bottom: 10px;">{f.name}</h3>
            <p class="bento-desc">{f.desc}</p>
            <div class="bento-cta" style="margin-top: 18px;">Read the deep dive <span class="arrow">→</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- LITE FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Try every feature for <span class="accent">$1.</span></h2>
        <p class="final-sub">Cancel anytime. Content stays forever.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    @media (max-width: 900px) {
      section[style*="grid-template-columns: repeat(3, 1fr)"] > div {
        grid-template-columns: 1fr 1fr !important;
      }
    }
    @media (max-width: 600px) {
      section[style*="grid-template-columns: repeat(3, 1fr)"] > div {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</BaseLayout>
