---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Social Scheduling — Auto-Post to 8 Platforms | theStacc',
  description: 'Social scheduling that writes the post, picks the image, and ships it to Instagram, LinkedIn, X, Facebook, TikTok, and 3 more. $1 trial. Cancel anytime.',
  canonical: 'https://thestacc.com/features/social-scheduling/',
  ogImage: '/og/features-social-scheduling.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Social Scheduling",
    "description": "Social scheduling that writes the post, picks the image, and auto-publishes to Instagram, LinkedIn, X, Facebook, TikTok, Threads, Pinterest, and YouTube Shorts.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/features/social-scheduling/",
    "image": "https://thestacc.com/og/features-social-scheduling.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/blog/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · TikTok auto-publishing is live</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Auto-post to <span class="accent">8 platforms.</span> Every week.</h1>
    <p class="hero-sub">Instagram, LinkedIn, X, Facebook, TikTok, Threads, Pinterest, and YouTube Shorts. theStacc writes the post, picks the image, picks the time. You hit approve once. It ships for the next 30 days.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">I</div><div class="av">L</div><div class="av">X</div><div class="av">T</div></div>
        <span><strong>127+</strong> businesses posting</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Posting every week for</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">8<span class="accent">+</span></div><div class="stat-label">Platforms · one approval</div></div>
      <div class="stat-cell"><div class="stat-num">120<span class="accent">+</span></div><div class="stat-label">Posts shipped · per month</div></div>
      <div class="stat-cell"><div class="stat-num">15<span class="accent">m</span></div><div class="stat-label">Approval time · per week</div></div>
      <div class="stat-cell"><div class="stat-num">3.4<span class="accent">×</span></div><div class="stat-label">More reach · vs once-a-week</div></div>
    </div>
  </section>

  <!-- BENTO -->
  <section class="modules-bento" id="features">
    <div class="modules-tabs-header">
      <span class="label-pill">What you get</span>
      <h2 class="h-lg">Write once. <span class="accent">Ship to eight.</span></h2>
      <p class="lede">A single article becomes 15 posts. Each one shaped for the platform it lands on. Each one auto-published at the best hour for your audience. No more "I forgot to post this week."</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/modules/social-media/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h3 class="bento-title">One post, eight cuts</h3>
        <h4 class="bento-sub">An article on Monday. <span class="accent">15 posts by Friday.</span></h4>
        <p class="bento-desc">You publish one article. theStacc turns it into a LinkedIn carousel, an Instagram reel, an X thread, a Facebook post, a TikTok script, a Pinterest pin, a Threads update, and a Shorts caption. All in your tone.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Re-shaped per platform · not just resized</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Hashtags + handles auto-picked</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Images, carousels, captions · all generated</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>You approve in a single calendar view</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">QUEUED · WEEK OF JUL 7</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">15 posts ready · 0 missed days</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">IG ●</span>
            <span class="bento-mock-tag brand">LI ●</span>
            <span class="bento-mock-tag">TT ●</span>
          </div>
        </div>
        <div class="bento-cta">Explore Social Media <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/modules/content-seo/">
        <div class="bento-num">02</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h3 class="bento-title">Best-time auto-pick</h3>
        <h4 class="bento-sub">8:14 Tuesday on LinkedIn. <span class="accent">3:02 Wednesday on TikTok.</span></h4>
        <p class="bento-desc">theStacc reads your past engagement and ships each post at the minute your audience is awake. No more guessing if 9am is better than noon. The algorithm does the math.</p>
        <div class="bento-mock bento-mock-grid">
          <div class="bento-grid-pin top3">M</div>
          <div class="bento-grid-pin top3">T</div>
          <div class="bento-grid-pin top3">W</div>
          <div class="bento-grid-pin top3">T</div>
          <div class="bento-grid-pin top3">F</div>
          <div class="bento-grid-pin">S</div>
          <div class="bento-grid-pin">S</div>
          <div class="bento-grid-pin top3">M</div>
          <div class="bento-grid-pin top3">T</div>
          <div class="bento-grid-pin top3">W</div>
          <div class="bento-grid-pin top3">T</div>
          <div class="bento-grid-pin top3">F</div>
          <div class="bento-grid-pin">S</div>
          <div class="bento-grid-pin">S</div>
          <div class="bento-grid-pin top3">M</div>
          <div class="bento-grid-pin top3">T</div>
        </div>
        <div class="bento-cta">Explore Content SEO <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/case-studies/">
        <div class="bento-num">03</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="bento-title">Recycle the winners</h3>
        <h4 class="bento-sub">A post that hit big? <span class="accent">Re-ship it. Different angle.</span></h4>
        <p class="bento-desc">A post that got 14k views in March deserves another run. theStacc spots your top 5 each month and rewrites them — fresh hook, fresh image — and queues them for next quarter.</p>
        <div class="bento-mock bento-mock-social">
          <div class="bento-social-row"><span class="bento-social-icon">IG</span><span class="bento-social-text">Mar 12 · 14k views · re-cut for July</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">LI</span><span class="bento-social-text">Apr 3 · 2.1k likes · re-shaped for Aug</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">TT</span><span class="bento-social-text">May 8 · 42k plays · re-hooked for Sep</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">X</span><span class="bento-social-text">May 21 · 1.4k reposts · re-queued</span><span class="bento-social-status">●</span></div>
        </div>
        <div class="bento-cta">Read customer stories <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- UNIQUE: Month calendar mockup -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">The month view</span>
      <h2 class="h-lg">A full month. <span class="accent">Approved in 15 minutes.</span></h2>
      <p class="lede">Every dot is a post. Every color is a platform. Hover any cell to see the caption. Click to swap an image. Hit approve once and walk away.</p>
    </div>

    <div style="max-width: 980px; margin: 0 auto; padding: 32px; background: var(--bg-soft); border: 1px solid var(--border);">
      <div style="display: flex; justify-content: space-between; padding-bottom: 16px; border-bottom: 1px solid var(--border); margin-bottom: 20px;">
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.08em;">JULY 2026 · 124 POSTS QUEUED</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 600;">● 0 GAPS</div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px;">
        {['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map(d => (
          <div style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); text-align: center; padding: 8px 0;">{d}</div>
        ))}
        {Array.from({length: 28}, (_, i) => {
          const day = i + 1;
          const posts = (day % 3 === 0) ? 5 : (day % 2 === 0) ? 4 : 3;
          const colors = ['#4f39f6', '#0a66c2', '#000000', '#1877f2', '#ff0050', '#e1306c', '#bd081c'];
          return (
            <div style={`background: white; border: 1px solid var(--border); padding: 10px 8px; min-height: 80px; display: flex; flex-direction: column; gap: 6px;`}>
              <div style="font-size: 11px; color: var(--text-3); font-weight: 600;">{day}</div>
              <div style="display: flex; flex-wrap: wrap; gap: 3px;">
                {Array.from({length: posts}, (_, j) => (
                  <span style={`width: 8px; height: 8px; background: ${colors[j % colors.length]}; display: inline-block; border-radius: 50% !important;`}></span>
                ))}
              </div>
              <div style="font-size: 10px; color: var(--text-3); margin-top: auto;">{posts}p</div>
            </div>
          );
        })}
      </div>

      <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border); display: flex; gap: 16px; flex-wrap: wrap; font-size: 12px;">
        <span style="display: flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; background: #4f39f6; border-radius: 50% !important;"></span> Instagram</span>
        <span style="display: flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; background: #0a66c2; border-radius: 50% !important;"></span> LinkedIn</span>
        <span style="display: flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; background: #000000; border-radius: 50% !important;"></span> X</span>
        <span style="display: flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; background: #1877f2; border-radius: 50% !important;"></span> Facebook</span>
        <span style="display: flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; background: #ff0050; border-radius: 50% !important;"></span> TikTok</span>
        <span style="display: flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; background: #e1306c; border-radius: 50% !important;"></span> Threads</span>
        <span style="display: flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; background: #bd081c; border-radius: 50% !important;"></span> Pinterest</span>
      </div>
    </div>
  </section>

  <!-- HOW THIS SAVES YOU TIME / MONEY -->
  <section class="benefits-section">
    <div class="howitworks-header">
      <span class="label-pill">Why this matters</span>
      <h2 class="h-lg">Showing up beats <span class="accent">going viral.</span></h2>
      <p class="lede">A roofer in Denver was paying a social agency $1,400/mo for 8 posts. Switched to theStacc. Ships 30 posts a month. The agency budget went to a Google Ads test. Bookings up 19% in 90 days.</p>
    </div>
    <div class="b-stagger">
      <div class="benefit-cell">
        <div class="stat-num">$1.4<span class="accent">k</span></div>
        <div class="stat-label">Saved each month · roofer case</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">15<span class="accent">m</span></div>
        <div class="stat-label">Approval time · vs 6 hours / week</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">19<span class="accent">%</span></div>
        <div class="stat-label">More bookings · 90 days · roofer</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">8<span class="accent">×</span></div>
        <div class="stat-label">Platforms covered · without 8 logins</div>
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="integrations-section">
    <div class="integrations-header">
      <span class="label-pill">Integrations</span>
      <h2 class="h-lg">Plugs into <span class="accent">every account you already have.</span></h2>
      <p class="lede">One click connects each platform. theStacc never holds your password — it uses official APIs. You can revoke access in your platform settings any time.</p>
      <div class="integrations-meta">
        <span><strong>90 sec</strong> avg connect time</span>
        <span class="dot"></span>
        <span><strong>8</strong> platforms supported</span>
        <span class="dot"></span>
        <span><strong>OAuth only</strong> no passwords</span>
      </div>
    </div>
    <div class="integrations-grid">
      <div class="integration-cell" title="Instagram"><img src="https://cdn.simpleicons.org/instagram" alt="Instagram" loading="lazy"/><span class="tip">Instagram</span></div>
      <div class="integration-cell" title="LinkedIn"><img src="https://cdn.simpleicons.org/linkedin" alt="LinkedIn" loading="lazy"/><span class="tip">LinkedIn</span></div>
      <div class="integration-cell" title="X"><img src="https://cdn.simpleicons.org/x" alt="X" loading="lazy"/><span class="tip">X</span></div>
      <div class="integration-cell" title="Facebook"><img src="https://cdn.simpleicons.org/facebook" alt="Facebook" loading="lazy"/><span class="tip">Facebook</span></div>
      <div class="integration-cell" title="TikTok"><img src="https://cdn.simpleicons.org/tiktok" alt="TikTok" loading="lazy"/><span class="tip">TikTok</span></div>
      <div class="integration-cell" title="Threads"><img src="https://cdn.simpleicons.org/threads" alt="Threads" loading="lazy"/><span class="tip">Threads</span></div>
      <div class="integration-cell" title="Pinterest"><img src="https://cdn.simpleicons.org/pinterest" alt="Pinterest" loading="lazy"/><span class="tip">Pinterest</span></div>
      <div class="integration-cell" title="YouTube"><img src="https://cdn.simpleicons.org/youtube" alt="YouTube" loading="lazy"/><span class="tip">YouTube</span></div>
    </div>
  </section>

  <!-- GUARANTEE STRIP -->
  <section class="guarantee-section">
    <div class="guarantee-grid">
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>30-day money-back</h4>
          <p>Not happy in your first 30 days? Full refund. No forms. No questions asked.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>Posts stay live</h4>
          <p>Cancel theStacc and every post you shipped stays live on every platform. Forever.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg><use href="#i-check"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>No contract, no lock-in</h4>
          <p>Month-to-month. Cancel on your next billing date. Zero penalty, zero hassle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor"/>
        </pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Start in 90 seconds</span>
        <h2 class="final-headline">Show up every day. <span class="accent">Without showing up.</span><br/>theStacc posts for you.</h2>
        <p class="final-sub">8 platforms. 120+ posts/mo. 15 min approval. $1 trial. Cancel anytime.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>84 businesses started this week</span> · <span>14k posts shipping today</span> · <span>$1 trial</span> · <span>Cancel anytime</span></div>
        <p class="final-ps"><strong>P.S.</strong> Your rivals posted 4 times this week. <span class="accent">You posted zero. theStacc fixes that on Monday.</span></p>
      </div>
    </div>
  </section>
</BaseLayout>
