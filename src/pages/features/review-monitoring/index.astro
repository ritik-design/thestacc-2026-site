---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Review Monitoring — Instant Alerts from 30+ Sites | theStacc',
  description: 'Review monitoring with instant alerts the moment a new review lands. Google, Yelp, Facebook, Trustpilot, and 27 more. AI reply drafts. $1 trial.',
  canonical: 'https://thestacc.com/features/review-monitoring/',
  ogImage: '/og/features-review-monitoring.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Review Monitoring",
    "description": "Review monitoring software with instant alerts, AI reply drafts, and one dashboard for every site customers leave reviews on.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/features/review-monitoring/",
    "image": "https://thestacc.com/og/features-review-monitoring.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/blog/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · SMS alerts now live in the US</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">A new review just landed. <span class="accent">You'll know in 60 seconds.</span></h1>
    <p class="hero-sub">theStacc watches Google, Yelp, Facebook, Trustpilot, and 27 more sites all day. The minute a review hits, you get a ping on Slack, SMS, or email. A reply draft is already written. You hit send.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">G</div><div class="av">Y</div><div class="av">F</div><div class="av">T</div></div>
        <span><strong>127+</strong> businesses replying</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Watching reviews for</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">60<span class="accent">s</span></div><div class="stat-label">From new review to your phone</div></div>
      <div class="stat-cell"><div class="stat-num">31<span class="accent">+</span></div><div class="stat-label">Review sites watched · per business</div></div>
      <div class="stat-cell"><div class="stat-num">94<span class="accent">%</span></div><div class="stat-label">Of bad reviews replied · same day</div></div>
      <div class="stat-cell"><div class="stat-num">0.7<span class="accent">★</span></div><div class="stat-label">Avg rating lift · 90 days</div></div>
    </div>
  </section>

  <!-- BENTO -->
  <section class="modules-bento" id="features">
    <div class="modules-tabs-header">
      <span class="label-pill">What you get</span>
      <h2 class="h-lg">Hear the review. <span class="accent">Reply on the spot.</span></h2>
      <p class="lede">A bad review left up for a week kills more deals than the bad review itself. theStacc cuts the gap from days to seconds. A reply draft is waiting before you finish reading.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/modules/local-seo/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <h3 class="bento-title">Instant alerts</h3>
        <h4 class="bento-sub">Slack, SMS, email — <span class="accent">within 60 seconds.</span></h4>
        <p class="bento-desc">A 1-star landed. You're on a call. Your phone buzzes. The full review is right there. You step out, hit Reply, and the customer sees a calm fix within minutes. Other shoppers see it too.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Slack, SMS, email, Teams, push</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Tag a teammate · auto-route by site</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Only 1 + 2-star alerts? Easy filter</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Quiet hours · no 3am buzzes</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">NEW REVIEW · 2 SECS AGO · YELP</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">★ "Waited 40 min for a table"</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">Reply in app →</span>
            <span class="bento-mock-tag">Draft ready</span>
            <span class="bento-mock-tag brand">Tag manager</span>
          </div>
        </div>
        <div class="bento-cta">Explore Local SEO <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/modules/social-media/">
        <div class="bento-num">02</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <h3 class="bento-title">AI reply drafts</h3>
        <h4 class="bento-sub">A reply ready <span class="accent">before you read the review.</span></h4>
        <p class="bento-desc">theStacc writes the reply in your voice. Calm. Specific. Names the problem. Offers a fix. You read it, change a word if you want, and hit Send. Most owners send it as-is.</p>
        <div class="bento-mock bento-mock-grid">
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
          <div class="bento-grid-pin top3">★</div>
        </div>
        <div class="bento-cta">Explore Social Media <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/case-studies/">
        <div class="bento-num">03</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h3 class="bento-title">Review requests</h3>
        <h4 class="bento-sub">Ask happy customers. <span class="accent">By text. Today.</span></h4>
        <p class="bento-desc">After a sale, theStacc texts the customer a one-tap link to leave a review. The link goes to Google or Yelp based on what your business needs most. Stars climb. So does the Map Pack rank.</p>
        <div class="bento-mock bento-mock-social">
          <div class="bento-social-row"><span class="bento-social-icon">SMS</span><span class="bento-social-text">Sent to Janet R. · 2 hours after visit</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">SMS</span><span class="bento-social-text">Sent to Mark D. · job closed today</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">GMB</span><span class="bento-social-text">Janet left ★★★★★ · 12 min ago</span><span class="bento-social-status">●</span></div>
          <div class="bento-social-row"><span class="bento-social-icon">YLP</span><span class="bento-social-text">Mark left ★★★★★ · just now</span><span class="bento-social-status">●</span></div>
        </div>
        <div class="bento-cta">Read customer stories <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- UNIQUE: Live inbox mockup -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">The review inbox</span>
      <h2 class="h-lg">One screen. <span class="accent">Every review. Every site.</span></h2>
      <p class="lede">No more flipping between 8 dashboards. Every review lands here. You scan, reply, archive. Done in under a minute a day.</p>
    </div>

    <div style="max-width: 980px; margin: 0 auto; padding: 28px; background: var(--bg-soft); border: 1px solid var(--border);">
      <div style="display: flex; justify-content: space-between; padding-bottom: 16px; border-bottom: 1px solid var(--border); margin-bottom: 16px;">
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.08em;">INBOX · 4 NEW · 14 THIS WEEK</div>
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 600;">● ALL CAUGHT UP</div>
      </div>

      <div style="display: flex; flex-direction: column; gap: 12px;">
        <div style="background: white; border: 1px solid var(--border); padding: 16px; display: grid; grid-template-columns: 60px 1fr 120px; gap: 16px; align-items: center;">
          <div style="font-family: 'Geist Mono', monospace; font-weight: 700; font-size: 13px; color: #991b1b; background: #fee2e2; padding: 6px 10px; text-align: center;">★ 1</div>
          <div>
            <div style="font-size: 11px; font-family: 'Geist Mono', monospace; color: var(--text-3); margin-bottom: 4px;">YELP · 4 MIN AGO · MIKE T.</div>
            <div style="font-size: 14px; color: var(--text-1); font-weight: 500; margin-bottom: 6px;">"Waited 40 minutes for a table even with a reservation. Server was nice though."</div>
            <div style="font-size: 12px; color: var(--brand); font-weight: 600;">Reply drafted ↓</div>
          </div>
          <div style="background: var(--brand); color: white; padding: 8px 12px; text-align: center; font-size: 12px; font-weight: 600; cursor: pointer;">Reply now →</div>
        </div>

        <div style="background: white; border: 1px solid var(--border); padding: 16px; display: grid; grid-template-columns: 60px 1fr 120px; gap: 16px; align-items: center;">
          <div style="font-family: 'Geist Mono', monospace; font-weight: 700; font-size: 13px; color: #166534; background: #dcfce7; padding: 6px 10px; text-align: center;">★ 5</div>
          <div>
            <div style="font-size: 11px; font-family: 'Geist Mono', monospace; color: var(--text-3); margin-bottom: 4px;">GOOGLE · 12 MIN AGO · LAURA P.</div>
            <div style="font-size: 14px; color: var(--text-1); font-weight: 500; margin-bottom: 6px;">"Best invisalign experience in Phoenix. Dr. Cole walked me through every step."</div>
            <div style="font-size: 12px; color: var(--brand); font-weight: 600;">Thank-you drafted ↓</div>
          </div>
          <div style="background: white; border: 1px solid var(--border-strong); color: var(--text-1); padding: 8px 12px; text-align: center; font-size: 12px; font-weight: 600; cursor: pointer;">Send thanks →</div>
        </div>

        <div style="background: white; border: 1px solid var(--border); padding: 16px; display: grid; grid-template-columns: 60px 1fr 120px; gap: 16px; align-items: center;">
          <div style="font-family: 'Geist Mono', monospace; font-weight: 700; font-size: 13px; color: #92400e; background: #fef3c7; padding: 6px 10px; text-align: center;">★ 3</div>
          <div>
            <div style="font-size: 11px; font-family: 'Geist Mono', monospace; color: var(--text-3); margin-bottom: 4px;">FACEBOOK · 1 HR AGO · SAM R.</div>
            <div style="font-size: 14px; color: var(--text-1); font-weight: 500; margin-bottom: 6px;">"Service was fine but the wait was longer than they said it would be."</div>
            <div style="font-size: 12px; color: var(--brand); font-weight: 600;">Reply drafted ↓</div>
          </div>
          <div style="background: var(--brand); color: white; padding: 8px 12px; text-align: center; font-size: 12px; font-weight: 600; cursor: pointer;">Reply now →</div>
        </div>

        <div style="background: white; border: 1px solid var(--border); padding: 16px; display: grid; grid-template-columns: 60px 1fr 120px; gap: 16px; align-items: center;">
          <div style="font-family: 'Geist Mono', monospace; font-weight: 700; font-size: 13px; color: #166534; background: #dcfce7; padding: 6px 10px; text-align: center;">★ 5</div>
          <div>
            <div style="font-size: 11px; font-family: 'Geist Mono', monospace; color: var(--text-3); margin-bottom: 4px;">TRUSTPILOT · 2 HRS AGO · NINA K.</div>
            <div style="font-size: 14px; color: var(--text-1); font-weight: 500; margin-bottom: 6px;">"Sent the SMS link and it worked first try. Refund came in 24 hours."</div>
            <div style="font-size: 12px; color: var(--brand); font-weight: 600;">Thank-you drafted ↓</div>
          </div>
          <div style="background: white; border: 1px solid var(--border-strong); color: var(--text-1); padding: 8px 12px; text-align: center; font-size: 12px; font-weight: 600; cursor: pointer;">Send thanks →</div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW THIS SAVES YOU TIME / MONEY -->
  <section class="benefits-section">
    <div class="howitworks-header">
      <span class="label-pill">Why this matters</span>
      <h2 class="h-lg">A bad review costs you <span class="accent">31 customers.</span> Unless you reply.</h2>
      <p class="lede">Harvard found 1 star up = 5–9% more revenue. A salon in Miami had a 3.8★ rating and 11 unanswered 1-star reviews. theStacc replied to all 11 in a week. The rating hit 4.6★ in 60 days. Bookings up 22%.</p>
    </div>
    <div class="b-stagger">
      <div class="benefit-cell">
        <div class="stat-num">22<span class="accent">%</span></div>
        <div class="stat-label">More bookings · 60 days · salon case</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">3.8<span class="accent">★</span></div>
        <div class="stat-label">Starting rating · before theStacc</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">4.6<span class="accent">★</span></div>
        <div class="stat-label">Ending rating · 60 days later</div>
      </div>
      <div class="benefit-cell">
        <div class="stat-num">$280<span class="accent">/mo</span></div>
        <div class="stat-label">Saved · no Birdeye + Podium combo</div>
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="integrations-section">
    <div class="integrations-header">
      <span class="label-pill">Integrations</span>
      <h2 class="h-lg">Plugs into <span class="accent">where reviews already live.</span></h2>
      <p class="lede">Google Business Profile, Slack, your CRM — wired together so reviews land in the inbox and the reply ships back to the right site.</p>
      <div class="integrations-meta">
        <span><strong>90 sec</strong> avg connect time</span>
        <span class="dot"></span>
        <span><strong>31</strong> review sites supported</span>
        <span class="dot"></span>
        <span><strong>100%</strong> no-code</span>
      </div>
    </div>
    <div class="integrations-grid">
      <div class="integration-cell" title="Google"><img src="https://cdn.simpleicons.org/google" alt="Google" loading="lazy"/><span class="tip">Google</span></div>
      <div class="integration-cell" title="Yelp"><img src="https://cdn.simpleicons.org/yelp" alt="Yelp" loading="lazy"/><span class="tip">Yelp</span></div>
      <div class="integration-cell" title="Facebook"><img src="https://cdn.simpleicons.org/facebook" alt="Facebook" loading="lazy"/><span class="tip">Facebook</span></div>
      <div class="integration-cell" title="Trustpilot"><img src="https://cdn.simpleicons.org/trustpilot" alt="Trustpilot" loading="lazy"/><span class="tip">Trustpilot</span></div>
      <div class="integration-cell" title="Slack"><img src="https://cdn.simpleicons.org/slack" alt="Slack" loading="lazy"/><span class="tip">Slack</span></div>
      <div class="integration-cell" title="HubSpot"><img src="https://cdn.simpleicons.org/hubspot" alt="HubSpot" loading="lazy"/><span class="tip">HubSpot</span></div>
      <div class="integration-cell" title="Foursquare"><img src="https://cdn.simpleicons.org/foursquare" alt="Foursquare" loading="lazy"/><span class="tip">Foursquare</span></div>
      <div class="integration-cell custom" title="Custom">
        <div class="custom-label">
          <span class="custom-label-mono">CUSTOM</span>
          <span class="custom-label-title">Webhook</span>
        </div>
        <span class="tip">Any review site</span>
      </div>
    </div>
  </section>

  <!-- GUARANTEE STRIP -->
  <section class="guarantee-section">
    <div class="guarantee-grid">
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>30-day money-back</h4>
          <p>Not happy in your first 30 days? Full refund. No forms. No questions asked.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>Review history is yours</h4>
          <p>Export every review and reply as CSV any time. Take your record with you.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg><use href="#i-check"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>No contract, no lock-in</h4>
          <p>Month-to-month. Cancel on your next billing date. Zero penalty, zero hassle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor"/>
        </pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Live in 60 seconds</span>
        <h2 class="final-headline">Hear every review. <span class="accent">Reply in seconds.</span><br/>Watch the stars climb.</h2>
        <p class="final-sub">Instant alerts. AI drafts. SMS review requests. $1 trial. Cancel anytime.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>84 businesses started this week</span> · <span>14,200 reviews watched today</span> · <span>$1 trial</span> · <span>Cancel anytime</span></div>
        <p class="final-ps"><strong>P.S.</strong> The 1-star you noticed Friday already cost you 31 calls. <span class="accent">Catch the next one in 60 seconds.</span></p>
      </div>
    </div>
  </section>
</BaseLayout>
