          <div class="bento-mock-title">8,100 / mo · they rank #3 · you rank · none</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">Easy win</span>
            <span class="bento-mock-tag">Buying intent</span>
            <span class="bento-mock-tag brand">Send to writer</span>
          </div>
        </div>
        <div class="bento-cta">Explore Content SEO <span class="arrow">→</span></div>
      </a>

