---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Keyword Research Software — Find Gaps Daily | theStacc',
  description: 'Keyword research that finds the searches your competitors miss. Pulled fresh every week, mapped to articles, ready to publish. $1 trial. Cancel anytime.',
  canonical: 'https://thestacc.com/features/keyword-research/',
  ogImage: '/og/features-keyword-research.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Keyword Research",
    "description": "Keyword research software that finds the searches your competitors miss. Weekly gap reports, intent tags, and one-click handoff to the writer.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/features/keyword-research/",
    "image": "https://thestacc.com/og/features-keyword-research.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/blog/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · Weekly gap reports land every Monday</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Find the keywords your <span class="accent">competitors miss.</span></h1>
    <p class="hero-sub">theStacc scans every page on your 5 closest rivals. It pulls the searches they rank for that <strong>you don't</strong>. Then it hands the list to the writer. You wake up to drafts on Monday.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">A</div><div class="av">N</div><div class="av">D</div><div class="av">P</div></div>
        <span><strong>127+</strong> businesses publishing</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
