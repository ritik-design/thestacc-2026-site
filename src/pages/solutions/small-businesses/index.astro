---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'SEO Software for Small Business — Rank Without an Agency | theStacc',
  description: 'SEO software for small business owners — dentists, plumbers, lawyers, salons. Daily local content, GBP posts, review replies. $49/mo. $1 trial. No agency required.',
  canonical: 'https://thestacc.com/solutions/small-businesses/',
  ogImage: '/og/solutions-small-businesses.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "Solutions", "item": "https://thestacc.com/solutions/" },
          { "@type": "ListItem", "position": 3, "name": "Small Businesses", "item": "https://thestacc.com/solutions/small-businesses/" }
        ]
      },
      {
        "@type": "Service",
        "name": "theStacc for Small Businesses",
        "provider": { "@type": "Organization", "name": "theStacc", "url": "https://thestacc.com/" },
        "serviceType": "SEO Software for Small Business",
        "areaServed": "Worldwide",
        "description": "Local SEO automation for solo owner-operators — dentists, plumbers, lawyers, salons. Daily GBP, content, and review replies for $49/month."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "Do I need to know SEO to use this?", "acceptedAnswer": { "@type": "Answer", "text": "No. theStacc handles every step — keyword picks, writing, publishing, GBP posts, review replies. You answer 6 questions during setup. Content ships the next day." }},
          { "@type": "Question", "name": "Is this cheaper than a local SEO agency?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Most local SEO agencies charge $1,500 to $3,500 a month. theStacc is $49 a month for a small business plan and covers content, GBP, and reviews." }},
          { "@type": "Question", "name": "How long until I see rankings?", "acceptedAnswer": { "@type": "Answer", "text": "Most businesses see Map Pack movement in 30 days. Top-3 rank in 60 to 90 days for non-saturated city queries. The compounding starts the day you turn it on." }},
          { "@type": "Question", "name": "What if I run a one-person shop?", "acceptedAnswer": { "@type": "Answer", "text": "Built for it. The default plan is for solo owner-operators — dentists, plumbers, lawyers, electricians, salons. One location, one phone, one GBP. Daily content runs without you." }},
          { "@type": "Question", "name": "Can I cancel any time?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Cancel from your dashboard. Your content stays live on your site. Your GBP goes back to manual control. No contract, no clawback." }},
          { "@type": "Question", "name": "Will Google penalize AI-written content?", "acceptedAnswer": { "@type": "Answer", "text": "No. Google rewards helpful content, not human-typed content. Every article passes the AI Humanizer + SME review + schema layer. 4M+ words shipped, zero penalties." }}
        ]
      }
    ]
  }
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <a href="/local-seo-software/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>For dentists, plumbers, lawyers, salons — solo owners</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">SEO software for small business <span class="accent">that runs without you.</span></h1>
    <p class="hero-sub">For <strong>solo owner-operators</strong> — the dentist, the plumber, the lawyer, the salon — get found on Google, rank in the Map Pack, and reply to every review. Daily content. Daily GBP posts. No agency. <strong>$49 a month. $1 to try.</strong></p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Watch 60-sec demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">D</div><div class="av">P</div><div class="av">L</div><div class="av">S</div></div>
        <span><strong>127+</strong> small businesses on theStacc</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 127 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Trusted by solo owner-operators across 12 industries</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">$49</div><div class="stat-label">Per month, all in</div></div>
      <div class="stat-cell"><div class="stat-num">60<span class="accent">d</span></div><div class="stat-label">Avg time to Map Pack top-3</div></div>
      <div class="stat-cell"><div class="stat-num">$40k<span class="accent">+</span></div><div class="stat-label">Avg saved vs agency per year</div></div>
      <div class="stat-cell"><div class="stat-num">0</div><div class="stat-label">Hours of marketing work</div></div>
    </div>
  </section>

  <!-- BEFORE / AFTER -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">01 · The small business problem</span>
      <h2 class="h-lg">You opened a shop. <span class="accent">Not a marketing agency.</span></h2>
      <p>Every small business owner hits the same wall. Patients call your competitor first. The chair sits empty at 3pm. You don't have time to learn SEO. Here's what changes when theStacc runs your local presence.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">Before theStacc</span>
          <h3 class="ba-title">Calls come from the wrong shop.</h3>
          <p class="ba-sub">Where most solo owners stay stuck.</p>
        </div>
        <ul class="ba-list">
          <li><span class="ba-num">01</span><div><h4>Ranked #6 in the Map Pack</h4><p>Three competitors above you. The ones who paid an agency. Your phone barely rings on the 3pm slot.</p></div></li>
          <li><span class="ba-num">02</span><div><h4>The agency wants $3,500 a month</h4><p>They send a 4-page PDF every quarter. Most of the work? They outsource it overseas. You still feel ripped off.</p></div></li>
          <li><span class="ba-num">03</span><div><h4>GBP hasn't been touched in 8 weeks</h4><p>You meant to post. You ran the front desk instead. Last post is from October.</p></div></li>
          <li><span class="ba-num">04</span><div><h4>1-star review still live</h4><p>The angry patient from 5 weeks ago. Still on top of your reviews. Every new patient reads it first.</p></div></li>
          <li><span class="ba-num">05</span><div><h4>You can't grow because you're already maxed</h4><p>Front desk, callbacks, payroll, taxes. There's no room for marketing in the day.</p></div></li>
        </ul>
      </div>
      <div class="ba-divider"><span>→</span></div>
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">With theStacc</span>
          <h3 class="ba-title">You're the first call.</h3>
          <p class="ba-sub">Where you land in 60 to 90 days.</p>
        </div>
        <ul class="ba-list">
          <li><span class="ba-num">01</span><div><h4>Top-3 Map Pack</h4><p>"Dentist near me" rings your phone. The 3pm slot fills up. New patients up 30%.</p></div></li>
          <li><span class="ba-num">02</span><div><h4>$49 a month. All in.</h4><p>Content, GBP, reviews — one bill. Cancel any time. Save $40k a year vs the agency.</p></div></li>
          <li><span class="ba-num">03</span><div><h4>Daily GBP posts, on brand</h4><p>You don't write a thing. theStacc posts every morning at 6am. New photo, new offer, new question answered.</p></div></li>
          <li><span class="ba-num">04</span><div><h4>Every review answered in 3 minutes</h4><p>theStacc replies in your tone. The 1-star gets a calm, factual reply. New patients see your professionalism.</p></div></li>
          <li><span class="ba-num">05</span><div><h4>You stay in the chair</h4><p>You run the practice. theStacc runs the marketing. Both grow.</p></div></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- UNIQUE SECTION: SERP BATTLE -->
  <section class="serp-section">
    <div class="serp-header">
      <span class="label-pill">Live SERP</span>
      <h2 class="h-lg">From <span class="accent">page 2</span> to the first call.</h2>
      <p>Real shift after 90 days running theStacc — for a solo dental practice in Austin.</p>
    </div>
    <div class="serp-grid">
      <div class="serp-mock">
        <div class="serp-bar">
          <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
          <div class="search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            dentist near me · Austin
          </div>
          <span class="live-pill">Live</span>
        </div>
        <div class="serp-results">
          <div class="serp-result you">
            <span class="rank">#1 · Map Pack</span>
            <span class="you-badge">Your practice</span>
            <div class="url">drsmith-dental.com · Austin, TX</div>
            <div class="title">Family dentist Austin · same-day appointments</div>
            <div class="snippet">Trusted family dental care in Austin since 2014. New patient slots open this week. Same-day emergency...</div>
          </div>
          <div class="serp-result competitor">
            <span class="rank">#2</span>
            <div class="url">competitor-dental.com</div>
            <div class="title">Austin Dental · cosmetic and family</div>
            <div class="snippet">Cosmetic and family dentistry in Austin. Veneers, implants, and routine cleanings...</div>
          </div>
          <div class="serp-result competitor">
            <span class="rank">#3</span>
            <div class="url">austin-smile-co.com</div>
            <div class="title">Austin Smile Co. · downtown</div>
            <div class="snippet">Downtown Austin dental practice serving families since 2009...</div>
          </div>
          <div class="serp-page-jump">— After 90 days on theStacc —</div>
          <div class="serp-result competitor" style="opacity:0.55;">
            <span class="rank">#6 · old rank</span>
            <div class="url">drsmith-dental.com</div>
            <div class="title">Dr Smith Dental · Austin family practice</div>
            <div class="snippet">Family dental care in Austin. Insurance accepted...</div>
          </div>
        </div>
        <div class="serp-footer">
          <span>map pack visibility</span>
          <span class="right">+520% queries · 90d</span>
        </div>
      </div>
      <div class="serp-copy">
        <h3>The Map Pack moved <span class="accent">from #6 to #1.</span></h3>
        <p>Daily GBP posts. Weekly local article ("Best family dentist in Austin", "Same-day dental appointments 78704"). Reviews answered in 3 minutes. 90 days later, the phone rings for "dentist near me" instead of the practice across the street.</p>
        <div class="serp-stats-row">
          <div class="serp-stat-cell"><div class="v">#1</div><div class="l">Map Pack rank</div></div>
          <div class="serp-stat-cell"><div class="v">+47</div><div class="l">keywords / 90d</div></div>
          <div class="serp-stat-cell"><div class="v">+30%</div><div class="l">new patients</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- SOLUTION INTRO -->
  <section class="solution-section">
    <div class="solution-grid">
      <div class="solution-left">
        <span class="label-pill">02 · The solution</span>
        <h2 class="h-lg">Your shop. <span class="accent hl-highlight">Their first call.</span><br/>Without the agency.</h2>
      </div>
      <div class="solution-right">
        theStacc runs <strong>content, Google Business Profile, and review replies</strong> for solo owner-operators. Daily posts, weekly articles, 3-minute review replies. You answer 6 setup questions in 4 minutes. Content ships the next day. Top-3 Map Pack rank in 60 to 90 days.
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">How small businesses run it</span>
      <h2 class="h-lg">From setup to <span class="accent">first new patient,</span> in 3 steps.</h2>
      <p class="lede">No marketing degree. No agency calls. Set it up in 4 minutes and let it run.</p>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">01</span><span class="step-day">Day 1 · 4 minutes</span></div>
          <h3 class="h-md">Answer 6 questions <span class="accent">about your shop.</span></h3>
          <p>Industry, city, services, target patients, hours, your brand voice. That's it. theStacc generates the keyword map and 90-day plan before you finish your coffee.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>One form — 6 questions</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>1-click Google Business Profile connect</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Site connect if you have one (or skip)</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-1">
            <div class="step-card-header"><span class="step-card-tag">SETUP · 4 MIN</span><span class="step-card-status">● Live</span></div>
            <div class="step-card-row"><span class="step-card-key">Shop</span><span class="step-card-val">Dr Smith Dental · Austin</span></div>
            <div class="step-card-row"><span class="step-card-key">Voice</span><span class="step-card-val">Warm · Trusted · Local</span></div>
            <div class="step-card-row"><span class="step-card-key">Keyword map</span><span class="step-card-val">68 terms · 90-day plan</span></div>
            <div class="step-card-row highlight"><span class="step-card-key">First post</span><span class="step-card-val"><strong>Tomorrow 6am</strong></span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid reverse">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">02</span><span class="step-day">Every day · Auto-pilot</span></div>
          <h3 class="h-md">Content ships <span class="accent">while you work.</span></h3>
          <p>You see patients. theStacc posts to GBP at 6am. Writes a local article each Tuesday. Replies to every review within 3 minutes. Your phone keeps ringing.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Daily GBP post · in your voice</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>1 local article per week</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>3-min review replies</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-2">
            <div class="step-card-header"><span class="step-card-tag">YOUR FEED · TODAY</span><span class="step-card-status">● Auto</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 06:00</span><span class="step-feed-text">GBP post live · "Same-day cleanings open"</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 09:12</span><span class="step-feed-text">5-star review replied · Maria H.</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 11:08</span><span class="step-feed-text">Article live · "Best family dentist Austin"</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 14:25</span><span class="step-feed-text">2-star reply sent · calm and factual</span></div>
            <div class="step-feed-item"><span class="step-feed-dot live"></span><span class="step-feed-time">Now</span><span class="step-feed-text">Map Pack rank check · #2 (was #6)</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">03</span><span class="step-day">1st of every month</span></div>
          <h3 class="h-md">One simple report <span class="accent">to your inbox.</span></h3>
          <p>What ranked. What ranked higher. What ranked from page 2 to page 1. New patients estimated. No jargon. Read it in 90 seconds.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Plain-English monthly report</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Map Pack rank for top 20 keywords</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>New patient call estimate</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-3">
            <div class="step-card-header"><span class="step-card-tag">REPORT · MONTH 3</span><span class="step-card-status">● Sent</span></div>
            <div class="step-stat-big">
              <span class="step-stat-num">+47</span>
              <span class="step-stat-label">Keywords ranked top-10</span>
              <span class="step-stat-delta">↑ from 12 last quarter</span>
            </div>
            <div class="step-stat-row">
              <div><strong>#1</strong> map pack</div>
              <div><strong>+30%</strong> new patients</div>
              <div><strong>$49</strong> /mo</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="benefits-section">
    <div class="benefits-header">
      <span class="label-pill">03 · Why small owners switch</span>
      <h2 class="h-lg">Grow the shop. <span class="accent">Without an agency.</span></h2>
      <p class="lede">Average outcomes across the 127 small businesses running theStacc today.</p>
    </div>
    <div class="benefits-grid">
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-trend"/></svg></div>
        <h3 class="h-sm">Top-3 in the Map Pack.</h3>
        <p>Most shops hit top-3 for "near me" queries in 60 to 90 days. The phone keeps ringing.</p>
        <div class="benefit-stat"><div class="benefit-stat-num">60<span class="accent">d</span></div><div class="benefit-stat-label">AVG TIME TO TOP-3</div></div>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-dollar"/></svg></div>
        <h3 class="h-sm">Save $40,000 a year.</h3>
        <p>Vs the $3,500-a-month agency. Same outputs. Sharper rank. One bill.</p>
        <div class="benefit-stat"><div class="benefit-stat-num">$40k<span class="accent">+</span></div><div class="benefit-stat-label">SAVED PER YEAR</div></div>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-clock"/></svg></div>
        <h3 class="h-sm">Zero hours of marketing work.</h3>
        <p>You set it up in 4 minutes. After that, you don't open the dashboard unless you want to.</p>
        <div class="benefit-stat"><div class="benefit-stat-num">0<span class="accent">h</span></div><div class="benefit-stat-label">PER WEEK YOU SPEND</div></div>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-target"/></svg></div>
        <h3 class="h-sm">More new patients.</h3>
        <p>Owners on theStacc report +30% new customer calls within 90 days. The chair fills up.</p>
        <div class="benefit-stat"><div class="benefit-stat-num">+30<span class="accent">%</span></div><div class="benefit-stat-label">NEW CUSTOMER CALLS</div></div>
      </div>
    </div>
  </section>

  <!-- COST COMPARISON -->
  <section class="cost-section">
    <div class="cost-header">
      <span class="label-pill">The owner-operator math</span>
      <h2 class="h-lg">$3,500/mo agency. <span class="accent">$49/mo theStacc.</span></h2>
      <p>What it costs to rank your shop — the agency way vs. theStacc.</p>
    </div>
    <div class="cost-table">
      <div class="cost-row head">
        <div class="cost-cell head-cell">Per month</div>
        <div class="cost-cell head-cell">Local SEO agency</div>
        <div class="cost-cell head-cell">Freelancer + tools</div>
        <div class="cost-cell head-cell brand">theStacc</div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Daily GBP posts</div><div class="price" style="font-size:15px;font-weight:600;">In your voice</div></div>
        <div class="cost-cell"><div class="price crossed">$800</div><div class="per">per month</div></div>
        <div class="cost-cell"><div class="price crossed">$400</div><div class="per">per month</div></div>
        <div class="cost-cell brand"><div class="price brand">incl.</div><div class="per">in $49</div></div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Weekly local articles</div><div class="price" style="font-size:15px;font-weight:600;">SEO-scored</div></div>
        <div class="cost-cell"><div class="price crossed">$1,400</div><div class="per">per month</div></div>
        <div class="cost-cell"><div class="price crossed">$700</div><div class="per">per month</div></div>
        <div class="cost-cell brand"><div class="price brand">incl.</div><div class="per">in $49</div></div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">3-min review replies</div><div class="price" style="font-size:15px;font-weight:600;">All reviews</div></div>
        <div class="cost-cell"><div class="price crossed">$600</div><div class="per">per month</div></div>
        <div class="cost-cell"><div class="price crossed">$250</div><div class="per">per month</div></div>
