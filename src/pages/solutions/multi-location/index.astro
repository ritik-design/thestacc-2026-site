  <style>
    /* Unique: Live store grid */
    .store-grid-section { padding: 96px 32px; background: var(--bg-soft); }
    .store-grid-header { text-align: center; max-width: 720px; margin: 0 auto 48px; }
    .store-grid-header .label-pill { margin-bottom: 24px; }
    .store-grid-header h2 { margin-bottom: 16px; }
    .store-grid-wrap { max-width: 1180px; margin: 0 auto; background: white; border: 1px solid var(--border); box-shadow: 0 24px 60px -16px rgba(15,15,30,0.12); overflow: hidden; }
    .store-grid-toolbar { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid var(--border); background: var(--bg-soft); flex-wrap: wrap; gap: 12px; }
    .store-grid-tabs { display: flex; gap: 8px; flex-wrap: wrap; }
    .sg-tab { padding: 6px 14px; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); border: 1px solid var(--border); background: white; letter-spacing: 0.06em; text-transform: uppercase; }
    .sg-tab.active { background: var(--brand); color: white; border-color: var(--brand); }
    .store-grid-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; }
    .store-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
    .store-card { padding: 20px; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .store-card:nth-child(4n) { border-right: none; }
    .sg-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
    .sg-name { font-size: 14px; font-weight: 600; color: var(--text-1); letter-spacing: -0.01em; }
    .sg-rank { font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 700; padding: 3px 10px; }
    .sg-rank.good { background: rgba(16,185,129,0.1); color: var(--accent-emerald); }
    .sg-rank.warn { background: rgba(245,158,11,0.12); color: var(--accent-amber); }
    .store-card.warn { background: rgba(245,158,11,0.04); }
    .sg-stats { display: flex; gap: 14px; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.04em; }
    .store-grid-footer { padding: 16px 20px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--text-3); flex-wrap: wrap; gap: 12px; }
    .store-grid-footer .brand { color: var(--brand); }
    @media (max-width: 900px) { .store-grid { grid-template-columns: repeat(2, 1fr); } .store-card:nth-child(4n) { border-right: 1px solid var(--border); } .store-card:nth-child(2n) { border-right: none; } }
