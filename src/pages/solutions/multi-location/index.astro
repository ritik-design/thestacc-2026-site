        <div class="benefit-stat"><div class="benefit-stat-num">100<span class="accent">%</span></div><div class="benefit-stat-label">ON-BRAND OUTPUT</div></div>
      </div>
    </div>
  </section>

  <!-- COST COMPARISON -->
  <section class="cost-section">
    <div class="cost-header">
      <span class="label-pill">The multi-location math</span>
      <h2 class="h-lg">50 stores. <span class="accent">$2,450 a month.</span></h2>
      <p>What it costs to run local SEO for 50 locations — agency vs. in-house team vs. theStacc.</p>
    </div>
    <div class="cost-table">
      <div class="cost-row head">
        <div class="cost-cell head-cell">Per location · monthly</div>
        <div class="cost-cell head-cell">Local SEO agency</div>
        <div class="cost-cell head-cell">In-house marketing team</div>
        <div class="cost-cell head-cell brand">theStacc</div>
      </div>
