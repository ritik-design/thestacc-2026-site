          <div class="sg-stats"><span>12 posts</span><span>4.8★</span><span>0 open</span></div>
        </div>
        <div class="store-card good">
          <div class="sg-row"><span class="sg-name">Dallas · Uptown</span><span class="sg-rank good">#2</span></div>
          <div class="sg-stats"><span>11 posts</span><span>4.9★</span><span>0 open</span></div>
        </div>
        <div class="store-card good">
          <div class="sg-row"><span class="sg-name">Houston · Heights</span><span class="sg-rank good">#1</span></div>
          <div class="sg-stats"><span>12 posts</span><span>4.7★</span><span>1 open</span></div>
        </div>
        <div class="store-card warn">
          <div class="sg-row"><span class="sg-name">San Antonio · Pearl</span><span class="sg-rank warn">#4</span></div>
          <div class="sg-stats"><span>9 posts</span><span>4.5★</span><span>3 open</span></div>
        </div>
        <div class="store-card good">
          <div class="sg-row"><span class="sg-name">Fort Worth · West 7th</span><span class="sg-rank good">#2</span></div>
          <div class="sg-stats"><span>12 posts</span><span>4.8★</span><span>0 open</span></div>
        </div>
        <div class="store-card good">
          <div class="sg-row"><span class="sg-name">Denver · LoDo</span><span class="sg-rank good">#1</span></div>
          <div class="sg-stats"><span>11 posts</span><span>4.9★</span><span>0 open</span></div>
        </div>
        <div class="store-card warn">
          <div class="sg-row"><span class="sg-name">Phoenix · Camelback</span><span class="sg-rank warn">#5</span></div>
          <div class="sg-stats"><span>8 posts</span><span>4.4★</span><span>4 open</span></div>
        </div>
        <div class="store-card good">
          <div class="sg-row"><span class="sg-name">Tucson · 4th Ave</span><span class="sg-rank good">#3</span></div>
          <div class="sg-stats"><span>12 posts</span><span>4.7★</span><span>0 open</span></div>
        </div>
        <div class="store-card good">
          <div class="sg-row"><span class="sg-name">Vegas · Arts District</span><span class="sg-rank good">#1</span></div>
          <div class="sg-stats"><span>12 posts</span><span>4.8★</span><span>1 open</span></div>
        </div>
        <div class="store-card good">
          <div class="sg-row"><span class="sg-name">Reno · Midtown</span><span class="sg-rank good">#2</span></div>
