---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: '404 — Page not found | theStacc',
  description: 'The page you are looking for does not exist. Return to the homepage or explore our SEO guides and free tools.',
  canonical: 'https://thestacc.com/404/',
  ogImage: '/og-default.png',
  noindex: true,
  schemaData: {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "404 — Page not found",
    "url": "https://thestacc.com/404/"
  }
};
---
<BaseLayout seo={seo} bodyClass="error-page">
  <main style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 64px 24px;">
    <div style="max-width: 640px; text-align: center;">
      <span class="label-pill" style="margin-bottom: 16px; display: inline-block;">404</span>
      <h1 class="h-xl" style="margin-bottom: 16px;">Page not found.</h1>
      <p style="font-size: 18px; color: var(--text-2); line-height: 1.6; margin-bottom: 32px;">
        The URL you requested does not exist or has moved. Try one of the links below, or head back home.
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 32px;">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/blog/" class="btn-secondary">Read the blog</a>
      </div>
      <nav aria-label="Popular pages">
        <ul style="list-style: none; padding: 0; display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; color: var(--text-2);">
          <li><a href="/pricing/" style="color: var(--brand); text-decoration: underline;">Pricing</a></li>
          <li><a href="/tools/seo-audit/" style="color: var(--brand); text-decoration: underline;">Free SEO audit</a></li>
          <li><a href="/contact/" style="color: var(--brand); text-decoration: underline;">Contact</a></li>
        </ul>
      </nav>
    </div>
  </main>
</BaseLayout>
