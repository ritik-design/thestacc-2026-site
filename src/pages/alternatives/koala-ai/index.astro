              <div class="price">$30<span style="font-size: 14px; color: var(--text-3);">/mo</span></div>
              <div class="per">Annual billing</div>
            </div>
          </div>
          <div class="tool-card-body">
            <div>
              <h5>What it does better</h5>
              <ul class="yes-list">
                <li>GEO article creation tuned for AI search visibility</li>
