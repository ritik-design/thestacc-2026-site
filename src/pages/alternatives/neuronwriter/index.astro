---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: '8 Best NeuronWriter Alternatives in 2026 (Ranked and Reviewed)',
  description: 'Looking for NeuronWriter alternatives? We compared 8 tools with better optimization, more features, and done-for-you options from $19 to $99/mo.',
  canonical: 'https://thestacc.com/alternatives/neuronwriter/',
  ogImage: '/og/alternatives-neuronwriter.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Alternatives", "item": "https://thestacc.com/alternatives/" },
        { "@type": "ListItem", "position": 3, "name": "NeuronWriter Alternatives", "item": "https://thestacc.com/alternatives/neuronwriter/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "8 Best NeuronWriter Alternatives in 2026",
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "numberOfItems": 8,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "theStacc", "url": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Surfer SEO" },
        { "@type": "ListItem", "position": 3, "name": "Frase" },
        { "@type": "ListItem", "position": 4, "name": "Scalenut" },
        { "@type": "ListItem", "position": 5, "name": "Clearscope" },
        { "@type": "ListItem", "position": 6, "name": "Page Optimizer Pro" },
        { "@type": "ListItem", "position": 7, "name": "Dashword" },
        { "@type": "ListItem", "position": 8, "name": "Outranking" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the best NeuronWriter alternative in 2026?",
          "acceptedAnswer": { "@type": "Answer", "text": "For businesses that want completed content delivery, theStacc ranks highest — it writes, optimizes, and publishes 30 articles per month for $99. Teams prioritizing optimization depth should consider Surfer SEO ($99/mo), while budget-conscious users benefit from Scalenut's annual pricing at $30/mo." }
        },
        {
          "@type": "Question",
          "name": "Are there free NeuronWriter alternatives?",
          "acceptedAnswer": { "@type": "Answer", "text": "Koala AI provides 5,000 words monthly on a free tier. MarketMuse offers a free plan with 10–35 queries per month. Machined AI includes a limited free plan. NeuronWriter's AppSumo lifetime deal (~$267 one-time) is the lowest long-term cost if you can catch it." }
        },
        {
          "@type": "Question",
          "name": "Is NeuronWriter's $23/month worth it?",
          "acceptedAnswer": { "@type": "Answer", "text": "For solo bloggers needing basic scoring on a tight budget, yes. But its unreliable AI generation, plan-gated WordPress publishing (Gold+ only at $69/mo), and shallow SERP analysis mean most users outgrow it once they start scaling." }
        },
        {
          "@type": "Question",
          "name": "Which NeuronWriter alternative has the most affordable pricing?",
          "acceptedAnswer": { "@type": "Answer", "text": "Outranking starts at $19/mo. Scalenut runs $30/mo on annual billing. Koala AI starts at $9/mo annually. NeuronWriter itself remains one of the cheapest optimization tools — but cheap doesn't mean the ceiling isn't low." }
        },
        {
          "@type": "Question",
          "name": "Can I migrate from NeuronWriter to theStacc?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. theStacc consolidates NeuronWriter, your freelance writers, and your publishing workflow into a single $99/mo subscription. $1 trial available — first article live in 24 hours." }
        },
        {
          "@type": "Question",
          "name": "Does NeuronWriter offer a free trial?",
          "acceptedAnswer": { "@type": "Answer", "text": "No free trial exists. AppSumo lifetime deals (~$267) are the only way to test before committing to a recurring plan. Frase, Scalenut, and Koala AI all offer free trials or free tiers if you want to compare before paying." }
        }
      ]
    }
  ]
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <a href="/alternatives/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Alternatives roundup · Q2 2026 update</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">8 Best <span class="accent">NeuronWriter Alternatives</span> in 2026</h1>
    <p class="hero-sub">NeuronWriter covers the basics at $23/mo. But once you need WordPress publishing, reliable AI generation, and SERP analysis that actually moves rankings — you'll hit its ceiling fast. We tested 8 alternatives that go further. Winner: theStacc.</p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Try the #1 alternative — $1 <span class="arrow">→</span></span></a>
      <a href="#ranked-list" class="btn btn-secondary">See all 8 alternatives</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span><strong>8 alternatives</strong> tested across content + SEO</span>
      </div>
      <div class="hero-meta-item">
        <span><strong>$1 trial</strong> · No contract</span>
      </div>
      <div class="hero-meta-item">
        <span>Last updated <strong>Q2 2026</strong></span>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Used by teams that moved on from NeuronWriter</p>
      <div class="trust-rating">
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- WHY PEOPLE LEAVE NEURONWRITER -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">Why teams leave NeuronWriter</span>
      <h2 class="h-lg">NeuronWriter hits a <span class="accent">ceiling fast</span> — here's where.</h2>
      <p>NeuronWriter is a genuine budget pick — $23/mo for basic content scoring isn't nothing. But after testing it against alternatives and digging through user feedback, six friction points come up repeatedly.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">The NeuronWriter gap</span>
          <h3 class="ba-title">Six reasons teams switch.</h3>
          <p class="ba-sub">Heard consistently across user reviews and switch interviews.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Feature scope is constrained</h4>
              <p>No content auditing, visibility tracking, internal linking analysis, or content planning — features competitors offer at the same or lower cost.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>WordPress publishing is paywalled</h4>
              <p>Bronze and Silver plans can't publish to WordPress. You need Gold+ at $69/mo to unlock CMS integration — more than 3× the entry price.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>AI generation is unreliable</h4>
              <p>The content generator produces factual errors and stops midway on longer articles. You end up rewriting more than you generated.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>SERP analysis is shallow</h4>
              <p>NeuronWriter's scoring doesn't match Surfer's 500-factor approach or Clearscope's grading accuracy. Good enough for basics, not enough for competitive terms.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>No trial access</h4>
              <p>You pay before you test. AppSumo lifetime deals (~$267) are the only workaround, and they're not always available.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">06</span>
            <div>
              <h4>Limited ecosystem</h4>
              <p>Smaller community, fewer tutorials, and thinner documentation than established tools. When something breaks, you're on your own.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">What teams want instead</span>
          <h3 class="ba-title">More than a score — finished work.</h3>
          <p class="ba-sub">Not just optimization data. Published content.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Publishing included on every plan</h4>
              <p>Direct push to WordPress, Webflow, Ghost — without an upgrade gate.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>Reliable AI generation</h4>
              <p>Full articles that don't cut off halfway. Factually grounded, not hallucinated.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Deep SERP analysis or done-for-you output</h4>
              <p>Either Surfer-grade scoring for teams who want to drive, or a service that handles the whole thing.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FEATURED #1 ALTERNATIVE -->
  <section class="modules-bento" id="ranked-list">
    <div class="modules-tabs-header">
      <span class="label-pill">#1 alternative</span>
      <h2 class="h-lg">The winner: <span class="accent">theStacc.</span></h2>
      <p class="lede">Where NeuronWriter gives you a score, theStacc gives you 30 published articles. Same monthly commitment. Completely different output.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3 class="bento-title">theStacc — the #1 NeuronWriter alternative for 2026</h3>
        <h4 class="bento-sub">Writes, SEO-optimizes, and <span class="accent">publishes 30 articles</span> directly to your site. $99/mo.</h4>
        <p class="bento-desc">theStacc doesn't score your writing — it does the writing. 30 SEO articles per month, written, scored, and published to WordPress, Webflow, Ghost, or your custom CMS. Google Business Profile posts included. Social repurposing included. One platform, one bill.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>30 fully written articles per month — not drafts</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Auto-published to your CMS — zero copy-paste</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>SEO scoring + schema + internal links built in</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>$1 trial · No contract · 24-hour setup</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">THESTACC · #1 PICK · $99/MO</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">30 articles/mo, written + scored + published</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">$99/mo</span>
            <span class="bento-mock-tag">SEO 90+</span>
            <span class="bento-mock-tag brand">Auto-publish</span>
          </div>
        </div>
        <div class="bento-cta">Start the $1 trial <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- RANKED LIST 2-8 -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">Alternatives #2–8</span>
      <h2 class="h-lg">7 more <span class="accent">NeuronWriter alternatives</span> worth knowing.</h2>
      <p>Each entry: rank, name, price, what it does well, and where it falls short. Pick the one that matches your job-to-be-done.</p>
    </div>

    <div class="ba-grid">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#2 · $99/MO ($99 ANNUAL) · MONTHLY</span>
          <h3 class="ba-title">Surfer SEO — for teams that need deep SERP analysis</h3>
          <p class="ba-sub">The natural upgrade from NeuronWriter's shallow scoring.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 16px;">Surfer's 500-factor SERP analysis is a different league from NeuronWriter's basic scoring. If you have writers and just need the data layer — internal linking, cannibalization analysis, real-time scoring — Surfer is the best tool in that category.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>500-factor SERP content evaluation</h4><p>The deepest analysis in the market — head and shoulders above NeuronWriter.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Internal linking and cannibalization analysis</h4><p>Available on Pro tier — catches problems NeuronWriter can't see.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>WordPress integration on all plans</h4><p>No Gold+ paywall. Every plan publishes to WordPress.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: 4× NeuronWriter's annual price</h4><p>And you still need writers — Surfer scores, it doesn't create.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" style="margin-top: 40px;">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#3 · $49/MO ($39 ANNUAL) · MONTHLY</span>
          <h3 class="ba-title">Frase — for SEO content briefs and research</h3>
          <p class="ba-sub">SERP data turned into structured briefs, fast.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 16px;">Frase transforms SERP analysis into one-click content briefs — the part NeuronWriter skips entirely. The research workflow is faster, GEO optimization for AI search is included, and there's a 7-day free trial. It's still DIY, but smarter DIY.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Best content-brief builder in the category</h4><p>SERP data into a structured brief in one click.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>GEO optimization for AI search visibility</h4><p>Optimizes for ChatGPT, Perplexity, Google AIO — NeuronWriter doesn't.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>7-day free trial, no card required</h4><p>Lets you compare before committing.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: still a DIY workflow</h4><p>Frase researches and scores. You still write and publish.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" style="margin-top: 40px;">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#4 · $59/MO ($30 ANNUAL) · MONTHLY</span>
          <h3 class="ba-title">Scalenut — budget upgrade with writing and publishing</h3>
          <p class="ba-sub">More features than NeuronWriter at a comparable annual price.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 16px;">Scalenut bundles AI writing, content optimization, GEO features, and WordPress publishing — all things NeuronWriter either paywalls or skips. At $30/mo on annual billing, it's only $7 more than NeuronWriter's Bronze plan. The trade-off is output quality that needs editing.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>$30/mo annual — barely more than NeuronWriter Bronze</h4><p>Way more features for the price bump.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>WordPress auto-publish on all plans</h4><p>No upgrade gate. No copy-paste.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>GEO article creation and AI visibility tracking</h4><p>Optimizes for ChatGPT, Google AIO, Perplexity.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: content quality is formulaic</h4><p>Output needs editing. Some users report ranking drops.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" style="margin-top: 40px;">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#5 · $129/MO · MONTHLY</span>
          <h3 class="ba-title">Clearscope — for enterprise editorial teams</h3>
          <p class="ba-sub">Simplified content grading built for scale and collaboration.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 16px;">Clearscope's A++ grading scale is considered more reliable than numeric scoring for editorial teams with many writers. Unlimited users across all plans, strong Google Docs integration, and zero learning curve. If you run Conde Nast-style editorial volume, Clearscope fits. If you're an SMB, it's overkill at 5.6× NeuronWriter's price.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>A++ grading — simpler than numeric scores for writers</h4><p>Reduces confusion in editorial teams with varying SEO knowledge.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Unlimited users on all plans</h4><p>No per-seat pricing headaches.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Strong Google Docs integration</h4><p>Writers stay in Docs — no platform switching.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: 5.6× NeuronWriter's cost, optimization only</h4><p>No AI writing. No auto-publishing. No free trial.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" style="margin-top: 40px;">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#6 · $40/MO · MONTHLY</span>
          <h3 class="ba-title">Page Optimizer Pro — for technical on-page SEO practitioners</h3>
          <p class="ba-sub">Granular keyword placement data with a patented scoring method.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 16px;">Page Optimizer Pro's patented scoring gives technical SEOs surgical precision on keyword placement, E-E-A-T guidance, and schema recommendations. It's only $17 more than NeuronWriter per month. But it's built for practitioners — non-technical writers find it overwhelming, and it doesn't help you plan or create content from scratch.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Patented scoring methodology</h4><p>Precise keyword placement recommendations that NeuronWriter can't match.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>E-E-A-T and schema guidance</h4><p>Useful for competitive niches where technical signals matter.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Only $17 more than NeuronWriter Bronze</h4><p>Reasonable step-up for teams that want precision over breadth.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: steep learning curve, credits expire monthly</h4><p>Not for content writers new to technical SEO.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" style="margin-top: 40px;">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#7 · $99/MO ($79 ANNUAL) · MONTHLY</span>
          <h3 class="ba-title">Dashword — for teams that want a clean, minimal optimizer</h3>
          <p class="ba-sub">Simple interface, content briefs, multilingual support.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 16px;">Dashword strips content optimization down to the essentials — a clean score, a brief builder, and multilingual support. The free sample report lets you test before paying. It costs 4× NeuronWriter and doesn't auto-publish, so it's hard to justify unless the clean UX really matters to your team.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Minimal interface — nothing to learn</h4><p>New writers get up to speed in minutes.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Free sample report on signup</h4><p>Test the scoring quality before you commit.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Multilingual support</h4><p>Strong for non-English content optimization.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: 4× NeuronWriter's price, no auto-publish</h4><p>Limited AI capabilities and no CMS integration at $99/mo is a tough sell.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" style="margin-top: 40px;">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#8 · $19/MO · MONTHLY</span>
          <h3 class="ba-title">Outranking — budget AI writing with WordPress included</h3>
          <p class="ba-sub">Same price range as NeuronWriter, with AI writing and auto-publish.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 16px;">Outranking starts at $19/mo — cheaper than NeuronWriter Bronze — and includes WordPress publishing plus automatic internal linking. The multi-source analysis (50+ sources) improves factual accuracy. The trade-off is a shaky platform: Trustpilot 3.0/5, reported outages, and a learning curve that trips up new users.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Cheaper than NeuronWriter at $19/mo</h4><p>More accessible entry point for budget-conscious teams.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>WordPress publishing included</h4><p>No $69/mo Gold+ upgrade gate like NeuronWriter.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>50+ source analysis for factual accuracy</h4><p>Reduces AI hallucination on research-heavy topics.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: platform reliability is poor</h4><p>Trustpilot 3.0/5, reported outages, steep learning curve, and weak multilingual output.</p></div></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="cost-section">
    <div class="cost-header">
      <span class="label-pill">Side-by-side comparison</span>
      <h2 class="h-lg">All 8 <span class="accent">NeuronWriter alternatives</span>, one table.</h2>
