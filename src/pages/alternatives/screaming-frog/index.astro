            <div class="tool-rank">04</div>
            <div class="tool-card-info">
              <div class="tool-card-name">Sitebulb</div>
              <div class="tool-card-tag">Best cloud-based technical crawler</div>
            </div>
            <div class="tool-card-price">
              <div class="price">$35<span style="font-size: 14px; color: var(--text-3);">/mo</span></div>
