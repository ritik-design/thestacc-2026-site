        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">07</div>
            <div class="tool-card-info">
              <div class="tool-card-name">Page Optimizer Pro</div>
              <div class="tool-card-tag">Most granular on-page SEO</div>
            </div>
            <div class="tool-card-price">
              <div class="price">$40<span style="font-size: 14px; color: var(--text-3);">/mo</span></div>
              <div class="per">Basic plan</div>
            </div>
          </div>
          <div class="tool-card-body">
            <div>
              <h5>What it does better</h5>
              <ul class="yes-list">
                <li>US-patented ranking factor scoring</li>
                <li>POP Watchdog SERP monitoring</li>
                <li>E-E-A-T and schema recommendations</li>
