---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const seo = {
  title: 'Alternatives — to every major SEO tool · theStacc',
  description: "Looking to switch off Ahrefs, Semrush, Surfer, Jasper, Frase, Clearscope, or Copy.ai? Side-by-side alternatives with pricing, pros, cons, and verdicts.",
  canonical: 'https://thestacc.com/alternatives/',
  ogImage: '/og/alternatives.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "theStacc SEO software alternatives",
    "url": "https://thestacc.com/alternatives/"
  }
};

const altsDir = path.resolve('./src/pages/alternatives');
const slugs = fs.readdirSync(altsDir, { withFileTypes: true })
  .filter(d => d.isDirectory())
  .map(d => d.name)
  .sort();

const SLUG_NAME = {
  'ahrefs': 'Ahrefs', 'anyword': 'Anyword', 'clearscope': 'Clearscope',
  'content-at-scale': 'Content at Scale', 'copy-ai': 'Copy.ai', 'dashword': 'Dashword',
  'frase': 'Frase', 'jasper': 'Jasper', 'junia-ai': 'Junia AI', 'koala-ai': 'Koala AI',
  'longshot': 'Longshot', 'machined': 'Machined', 'mangools': 'Mangools',
  'marketmuse': 'MarketMuse', 'moz': 'Moz', 'neuronwriter': 'NeuronWriter',
  'outranking': 'Outranking', 'page-optimizer-pro': 'Page Optimizer Pro',
  'rankability': 'Rankability', 'rytr': 'Rytr', 'scalenut': 'Scalenut',
  'screaming-frog': 'Screaming Frog', 'semrush': 'Semrush', 'seo-ai': 'SEO.AI',
  'se-ranking': 'SE Ranking', 'serpstat': 'Serpstat', 'spyfu': 'SpyFu',
  'surfer-seo': 'Surfer SEO', 'ubersuggest': 'Ubersuggest', 'writesonic': 'Writesonic'
};

const categoryFor = (slug) => {
  if (['ahrefs','semrush','moz','screaming-frog','seo-ai','se-ranking','serpstat','spyfu','mangools','ubersuggest'].includes(slug)) return 'SEO Platforms';
  if (['surfer-seo','clearscope','frase','marketmuse','neuronwriter','outranking','rankability','dashword','page-optimizer-pro'].includes(slug)) return 'Content Optimization';
  return 'AI Writers';
};

const alts = slugs.map(slug => ({
  slug,
  name: SLUG_NAME[slug] || slug,
  category: categoryFor(slug)
}));

const categories = ['All', ...new Set(alts.map(a => a.category))];
const totalCount = alts.length;
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Alternatives · {totalCount} tools</span>
    <h1 class="h-display">Alternatives to every <span class="accent">major SEO tool.</span></h1>
    <p class="hero-sub">If you're leaving Ahrefs, Semrush, Surfer, Jasper, Frase, Clearscope, or Copy.ai — start here. Side-by-side pricing, pros, cons, and our verdict on what to switch to.</p>
    <div class="hero-ctas">
      <a href="/alternatives/ahrefs/" class="btn btn-primary"><span>Top alt: vs Ahrefs <span class="arrow">→</span></span></a>
      <a href="/reviews/" class="btn btn-secondary">See all reviews</a>
    </div>
  </section>

  <!-- CATEGORY PILLS -->
  <section style="padding: 32px; background: white; border-bottom: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;">
      {categories.map((c, i) => (
        <button class="cat-pill label-pill" data-cat={c} style={i === 0 ? 'background: var(--brand-softer); border-color: var(--brand-soft);' : ''}>{c}</button>
      ))}
    </div>
  </section>

  <!-- ALTS GRID -->
  <section style="padding: 64px 32px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div class="alts-grid">
        {alts.map((a) => (
          <a href={`/alternatives/${a.slug}/`} class="alt-card" data-cat={a.category}>
            <span class="alt-cat">{a.category}</span>
            <h3 class="alt-title">Best {a.name} alternatives</h3>
            <span class="alt-cta">See the ranking <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
      <div class="alts-empty" style="display: none; text-align: center; padding: 80px 20px; color: var(--text-3);">No alternatives in this category yet.</div>
    </div>
  </section>

  <!-- LITE FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Cancel the others. <span class="accent">Run theStacc.</span></h2>
        <p class="final-sub">$1 trial. Migration guide included.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    .alts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    @media (max-width: 1100px) { .alts-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 800px) { .alts-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .alts-grid { grid-template-columns: 1fr; } }
    .alt-card { display: flex; flex-direction: column; gap: 12px; padding: 24px; background: white; border: 1px solid var(--border); transition: all 0.18s; text-decoration: none; color: inherit; min-height: 160px; }
    .alt-card:hover { transform: translateY(-2px); border-color: var(--brand); box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18); }
    .alt-cat { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); font-weight: 600; }
    .alt-title { font-size: 16px; font-weight: 600; line-height: 1.3; letter-spacing: -0.015em; color: var(--text-1); margin: 0; flex: 1; }
    .alt-cta { font-size: 13px; color: var(--brand); font-weight: 600; margin-top: auto; }
    .cat-pill { cursor: pointer; user-select: none; transition: all 0.15s; border: 1px solid var(--border); background: white; }
    .cat-pill:hover { border-color: var(--brand); color: var(--brand); }
    .cat-pill.active { background: var(--brand-softer) !important; border-color: var(--brand-soft) !important; color: var(--brand); }
    .alt-card.hidden { display: none; }
  </style>

  <script is:inline>
    const pills = document.querySelectorAll('.cat-pill');
    const cards = document.querySelectorAll('.alt-card');
    const empty = document.querySelector('.alts-empty');
    pills.forEach(p => p.addEventListener('click', () => {
      const cat = p.getAttribute('data-cat');
      pills.forEach(x => x.classList.toggle('active', x === p));
      let visible = 0;
      cards.forEach(c => {
        const show = cat === 'All' || c.getAttribute('data-cat') === cat;
        c.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
    }));
    if (pills[0]) pills[0].classList.add('active');
  </script>
</BaseLayout>
