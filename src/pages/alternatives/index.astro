---
import BaseLayout from '../../layouts/BaseLayout.astro';
const seo = {
  title: 'Alternatives — to every major SEO tool · theStacc',
  description: 'Looking to switch off Ahrefs, Semrush, Surfer, Jasper, Frase, Clearscope, or Copy.ai? Side-by-side alternatives with pricing, pros, cons, and verdicts.',
  canonical: 'https://thestacc.com/alternatives/',
  ogImage: '/og/alternatives.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "theStacc SEO software alternatives",
    "url": "https://thestacc.com/alternatives/"
  }
};

const categories = ['All', 'SEO Platforms', 'AI Writers', 'Content Optimization', 'Local SEO'];

const alts = [
  { slug: 'ahrefs', name: 'Ahrefs', tagline: 'Save $1,500/year vs Ahrefs Standard.', n: 7 },
  { slug: 'semrush', name: 'Semrush', tagline: 'Lighter, faster, and publishes for you.', n: 8 },
  { slug: 'surfer', name: 'Surfer SEO', tagline: 'Surfer scores. theStacc publishes.', n: 6 },
  { slug: 'jasper', name: 'Jasper', tagline: 'AI articles that actually rank in 60 days.', n: 9 },
  { slug: 'frase', name: 'Frase', tagline: 'Briefs are great. Published articles are better.', n: 5 },
  { slug: 'clearscope', name: 'Clearscope', tagline: 'Enterprise quality without the $170/mo price tag.', n: 7 },
  { slug: 'marketmuse', name: 'MarketMuse', tagline: 'Topical authority — built and shipped, not just planned.', n: 6 },
  { slug: 'anyword', name: 'Anyword', tagline: 'Beyond marketing copy: full SEO publishing.', n: 5 },
  { slug: 'content-at-scale', name: 'Content at Scale', tagline: 'Lower cost per article + native CMS publishing.', n: 8 },
  { slug: 'copy-ai', name: 'Copy.ai', tagline: 'Long-form that ranks, not just short-form snippets.', n: 5 },
  { slug: 'dashword', name: 'Dashword', tagline: 'Cheaper, faster, and ships to your CMS.', n: 4 },
  { slug: 'junia', name: 'Junia', tagline: 'Higher-quality drafts + native publishing.', n: 5 },
  { slug: 'koala', name: 'Koala', tagline: 'Brand-voice trained articles, not generic AI prose.', n: 6 },
  { slug: 'longshot', name: 'Longshot', tagline: 'AI articles with research that\'s actually current.', n: 5 },
  { slug: 'machined', name: 'Machined', tagline: 'Programmatic SEO that doesn\'t look programmatic.', n: 6 },
  { slug: 'scalenut', name: 'Scalenut', tagline: 'Same scoring + automated CMS publishing.', n: 5 },
];
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Alternatives · 30+ tools</span>
    <h1 class="h-display">Alternatives to every <span class="accent">major SEO tool.</span></h1>
    <p class="hero-sub">If you\'re leaving Ahrefs, Semrush, Surfer, Jasper, Frase, Clearscope, or Copy.ai — start here. Side-by-side pricing, pros, cons, and our verdict on what to switch to.</p>
    <div class="hero-ctas">
      <a href="/alternatives/ahrefs/" class="btn btn-primary"><span>Top alt: vs Ahrefs <span class="arrow">→</span></span></a>
      <a href="/reviews/" class="btn btn-secondary">See all reviews</a>
    </div>
  </section>

  <!-- CATEGORY PILLS -->
  <section style="padding: 32px; background: white; border-bottom: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;">
      {categories.map((c, i) => (
        <span class="label-pill" style={i === 0 ? 'background: var(--brand-softer); border-color: var(--brand-soft);' : ''}>{c}</span>
      ))}
    </div>
  </section>

  <!-- ALTS GRID -->
  <section style="padding: 80px 32px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div class="alts-grid">
        {alts.map((a) => (
          <a href={`/alternatives/${a.slug}/`} class="bento-card">
            <div class="bento-title" style="margin-bottom: 12px;">{a.n} alternatives</div>
            <h3 class="h-sm" style="margin-bottom: 10px;">Best {a.name} alternatives</h3>
            <p class="bento-desc">{a.tagline}</p>
            <div class="bento-cta" style="margin-top: 18px;">See the ranking <span class="arrow">→</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- LITE FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Cancel the others. <span class="accent">Run theStacc.</span></h2>
        <p class="final-sub">$1 trial. Migration guide included.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    .alts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    @media (max-width: 1100px) { .alts-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 800px) { .alts-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .alts-grid { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
