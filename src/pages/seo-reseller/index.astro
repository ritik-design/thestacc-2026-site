    .mc-val { font-size: 28px; font-weight: 700; color: var(--text-1); letter-spacing: -0.02em; }
    .mc-val.mc-locked { color: var(--brand); }
    .mc-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); margin-top: 4px; }
    .mc-output { background: var(--bg-dark); color: white; padding: 28px; display: flex; flex-direction: column; gap: 14px; }
    .mc-line { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed rgba(255,255,255,0.1); font-size: 14px; }
    .mc-line.big { font-size: 18px; padding-top: 16px; }
    .mc-val-out { font-weight: 600; font-family: 'Geist', sans-serif; }
    .mc-val-out.neg { color: #f87171; }
    .mc-val-out.brand { color: var(--brand-bright); }
    .mc-val-out.big { font-size: 22px; font-weight: 700; }
    .mc-margin-bar { margin-top: 18px; background: rgba(255,255,255,0.08); height: 32px; position: relative; padding: 8px 12px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; }
    .mc-margin-fill { position: absolute; left: 0; top: 0; bottom: 0; background: linear-gradient(90deg, var(--brand), var(--brand-bright)); transition: width 0.3s; z-index: 0; }
    .mc-margin-bar span { position: relative; z-index: 1; }
    .mc-margin-bar strong { color: white; font-weight: 700; }
    @media (max-width: 880px) { .margin-calc { grid-template-columns: 1fr; padding: 28px; } }
