---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'SEO Reseller Program — Resell SEO at 96% Margin | theStacc',
  description: 'SEO reseller program for agencies and consultants. White-label content, GBP, citations, reports. Per-client billing at $49. Charge $1,500. Keep 96%. $1 trial.',
  canonical: 'https://thestacc.com/seo-reseller/',
  ogImage: '/og/seo-reseller.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "SEO Reseller", "item": "https://thestacc.com/seo-reseller/" }
        ]
      },
      {
        "@type": "Service",
        "name": "SEO Reseller Program",
        "provider": { "@type": "Organization", "name": "theStacc" },
        "serviceType": "SEO Reseller Program",
        "description": "An SEO reseller program for agencies and consultants. Resell content, local SEO, and reporting under your brand. Per-client billing, white-label, 96% margins."
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "What is an SEO reseller program?", "acceptedAnswer": { "@type": "Answer", "text": "An SEO reseller program lets agencies and consultants resell SEO services under their own brand without hiring writers or building tools. theStacc handles the work; you handle the client." }},
          { "@type": "Question", "name": "How much do I pay vs charge?", "acceptedAnswer": { "@type": "Answer", "text": "You pay theStacc $49 to $99 per client account per month. You charge clients $750 to $3,500 per month. Margins run 93% to 97%." }},
          { "@type": "Question", "name": "Is there a minimum number of clients?", "acceptedAnswer": { "@type": "Answer", "text": "No minimum. Start with one client for $1 trial. Add more as you sell them. Cancel any account on next billing date." }},
          { "@type": "Question", "name": "What's the difference between a reseller and a white-label partner?", "acceptedAnswer": { "@type": "Answer", "text": "Reseller = you bill clients on your terms. White-label = your brand on the dashboard, reports, and emails. theStacc is both. Most agencies use both." }},
          { "@type": "Question", "name": "Do I get reseller training?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The reseller playbook ships in your dashboard on day 1 — pricing templates, sales decks, onboarding emails, and the SLA your team can copy." }},
          { "@type": "Question", "name": "What support is included?", "acceptedAnswer": { "@type": "Answer", "text": "Direct Slack channel for reseller partners, monthly partner office hours, and 24-hour email reply from theStacc founders." }},
          { "@type": "Question", "name": "Can I resell to other agencies?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Agencies of agencies are welcome. Set per-tier pricing. Each downstream agency gets their own white-label dashboard." }}
        ]
      }
    ]
  }
};
---
<BaseLayout seo={seo}>

  <section class="hero-section">
    <a href="/white-label-seo/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>SEO reseller program · 22 agencies live</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">SEO reseller program <span class="accent">built for 96% margins.</span></h1>
    <p class="hero-sub">Resell <strong>content SEO, local SEO, and monthly reports</strong> under your brand. Per-client billing at $49. Charge clients $1,500. Keep the rest. White-label dashboard. Reseller playbook included. <strong>One seat. Sixty clients.</strong></p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Talk to reseller team</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">N</div><div class="av">M</div><div class="av">A</div><div class="av">C</div></div>
        <span><strong>22+</strong> agencies in the reseller program</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 127 reviews on G2</span>
      </div>
    </div>
  </section>

  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">SEO reseller program · 22 agencies · 600+ client accounts</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <section class="solution-section">
    <div class="solution-grid">
      <div class="solution-left">
        <span class="label-pill">Definition</span>
        <h2 class="h-lg">What is an <span class="accent hl-highlight">SEO reseller program?</span></h2>
      </div>
      <div class="solution-right">
        <strong>An SEO reseller program lets agencies and consultants resell SEO services under their own brand without hiring writers or building tools.</strong> theStacc handles the production — content, GBP, citations, reports — and bills you per active client account at $49 to $99. You handle the client and the bill. Most resellers charge $750 to $3,500 per client per month. The margin is yours.
      </div>
    </div>
  </section>

  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">$49</div><div class="stat-label">Reseller cost per client</div></div>
      <div class="stat-cell"><div class="stat-num">$1,500</div><div class="stat-label">Avg reseller bill rate</div></div>
      <div class="stat-cell"><div class="stat-num">96<span class="accent">%</span></div><div class="stat-label">Gross margin per account</div></div>
      <div class="stat-cell"><div class="stat-num">60<span class="accent">+</span></div><div class="stat-label">Clients per seat</div></div>
    </div>
  </section>

  <!-- WHY MOST RESELLER PROGRAMS FAIL -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">01 · The problem</span>
      <h2 class="h-lg">Most SEO reseller programs <span class="accent">are just affiliate links.</span></h2>
      <p>The market is full of "reseller programs" that ship you a 20% kickback. Here's what real reselling looks like — and how theStacc handles the work.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">Other reseller programs</span>
          <h3 class="ba-title">Affiliate link. 20% kickback.</h3>
          <p class="ba-sub">Where most "reseller programs" stop.</p>
        </div>
        <ul class="ba-list">
          <li><span class="ba-num">01</span><div><h4>No real branding</h4><p>Client signs up at vendor's URL. Sees vendor's logo. You get 20%. They get 80%.</p></div></li>
          <li><span class="ba-num">02</span><div><h4>You still source the work</h4><p>Vendor sells the tool. You're still hiring writers, building reports, fielding tickets.</p></div></li>
          <li><span class="ba-num">03</span><div><h4>Per-seat pricing burns the margin</h4><p>$500 per seat. Add a client, lose margin. Add 30 clients, you're underwater.</p></div></li>
          <li><span class="ba-num">04</span><div><h4>Reports look like the vendor</h4><p>Client sees the vendor's brand on the cover. Why are they paying you again?</p></div></li>
          <li><span class="ba-num">05</span><div><h4>Cancellation = clawback</h4><p>Client leaves, you lose the kickback. Sometimes vendor claws back past commissions.</p></div></li>
        </ul>
      </div>
      <div class="ba-divider"><span>→</span></div>
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">theStacc reseller program</span>
          <h3 class="ba-title">Real reselling. Per-client billing.</h3>
          <p class="ba-sub">Where you land in 30 days.</p>
        </div>
        <ul class="ba-list">
          <li><span class="ba-num">01</span><div><h4>Your brand. Your domain.</h4><p>Client logs in at seo.youragency.com. Sees only your brand. No theStacc anywhere.</p></div></li>
          <li><span class="ba-num">02</span><div><h4>theStacc ships the work</h4><p>Content, GBP, citations, reports — all done. You sell, onboard, and bill.</p></div></li>
          <li><span class="ba-num">03</span><div><h4>$49 per client account</h4><p>No seat fees. Add a client, gain margin. Add 60 clients, your margin compounds.</p></div></li>
          <li><span class="ba-num">04</span><div><h4>Reports = your brand</h4><p>Logo, colors, email domain — all yours. Clients see exactly what you sold them.</p></div></li>
          <li><span class="ba-num">05</span><div><h4>Cancel one account, keep the rest</h4><p>Client leaves? Drop that account. The other 21 keep running. No clawback.</p></div></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- UNIQUE SECTION: MARGIN CALCULATOR -->
  <section class="margin-calc-section">
    <div class="margin-calc-header">
      <span class="label-pill">Reseller margin calculator</span>
      <h2 class="h-lg">Your reseller P&amp;L. <span class="accent">At a glance.</span></h2>
      <p class="lede">Pick how many clients and your bill rate. See your monthly profit.</p>
    </div>
    <div class="margin-calc">
      <div class="mc-controls">
        <div class="mc-control">
          <label>Clients</label>
          <input type="range" id="mc-clients" min="1" max="60" value="22" oninput="updateMargin()"/>
          <div class="mc-val" id="mc-clients-val">22</div>
        </div>
        <div class="mc-control">
          <label>Bill per client / mo</label>
          <input type="range" id="mc-bill" min="500" max="3500" value="1500" step="100" oninput="updateMargin()"/>
          <div class="mc-val">$<span id="mc-bill-val">1500</span></div>
        </div>
        <div class="mc-control">
          <label>Cost per client / mo</label>
          <div class="mc-val mc-locked">$49</div>
          <div class="mc-meta">Locked at theStacc base rate</div>
        </div>
      </div>
      <div class="mc-output">
        <div class="mc-line">
          <span>Monthly revenue</span>
          <span class="mc-val-out" id="mc-rev">$33,000</span>
        </div>
        <div class="mc-line">
          <span>Monthly cost</span>
          <span class="mc-val-out neg" id="mc-cost">-$1,078</span>
        </div>
        <div class="mc-line big">
          <span>Monthly profit</span>
          <span class="mc-val-out brand" id="mc-profit">$31,922</span>
        </div>
        <div class="mc-line">
          <span>Annual profit</span>
          <span class="mc-val-out brand big" id="mc-annual">$383,064</span>
        </div>
        <div class="mc-margin-bar">
          <div class="mc-margin-fill" id="mc-margin-fill" style="width:96%"></div>
          <span>Gross margin · <strong id="mc-margin">96%</strong></span>
        </div>
      </div>
    </div>
    <script is:inline>
      function updateMargin() {
        const c = parseInt(document.getElementById('mc-clients').value);
        const b = parseInt(document.getElementById('mc-bill').value);
        const cost = 49 * c;
        const rev = b * c;
        const profit = rev - cost;
        const margin = ((profit / rev) * 100).toFixed(1);
        document.getElementById('mc-clients-val').textContent = c;
        document.getElementById('mc-bill-val').textContent = b;
        document.getElementById('mc-rev').textContent = '$' + rev.toLocaleString();
        document.getElementById('mc-cost').textContent = '-$' + cost.toLocaleString();
        document.getElementById('mc-profit').textContent = '$' + profit.toLocaleString();
        document.getElementById('mc-annual').textContent = '$' + (profit * 12).toLocaleString();
        document.getElementById('mc-margin').textContent = margin + '%';
        document.getElementById('mc-margin-fill').style.width = margin + '%';
      }
    </script>
  </section>

  <!-- WHAT YOU GET -->
  <section class="benefits-section">
    <div class="benefits-header">
      <span class="label-pill">02 · What's in the program</span>
      <h2 class="h-lg">Everything you need <span class="accent">to resell at margin.</span></h2>
      <p class="lede">Tooling, playbook, and partner support — all included with your seat.</p>
    </div>
    <div class="benefits-grid">
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-trend"/></svg></div>
        <h3 class="h-sm">White-label dashboard.</h3>
        <p>Custom domain, logo, colors. Clients log in at your URL. Zero engineering needed.</p>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-dollar"/></svg></div>
        <h3 class="h-sm">Per-client billing.</h3>
        <p>$49 per active client account. No seat fees. No minimum. Cancel single accounts anytime.</p>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-clock"/></svg></div>
        <h3 class="h-sm">Reseller playbook.</h3>
        <p>Pricing templates, sales decks, onboarding emails, SLA you can copy. Ship from day 1.</p>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-target"/></svg></div>
        <h3 class="h-sm">Partner support.</h3>
        <p>Direct Slack channel. Monthly partner office hours. 24-hour email reply from founders.</p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">How resellers run it</span>
      <h2 class="h-lg">From sales call <span class="accent">to monthly margin,</span> in 3 steps.</h2>
      <p class="lede">No onboarding calls with theStacc. No editorial kickoff. Brand the platform, add a client, bill them.</p>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">01</span><span class="step-day">Day 1 · 10 minutes</span></div>
          <h3 class="h-md">Brand the platform <span class="accent">as yours.</span></h3>
          <p>Upload logo, set colors, point your subdomain. Reseller playbook unlocks in your dashboard.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>White-label setup in 10 minutes</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Reseller playbook + sales deck</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Partner Slack invite</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-1">
            <div class="step-card-header"><span class="step-card-tag">RESELLER SETUP · 8 MIN</span><span class="step-card-status">● Live</span></div>
            <div class="step-card-row"><span class="step-card-key">Domain</span><span class="step-card-val">seo.northwind.agency</span></div>
            <div class="step-card-row"><span class="step-card-key">Brand kit</span><span class="step-card-val">Logo + colors ✓</span></div>
            <div class="step-card-row"><span class="step-card-key">Playbook</span><span class="step-card-val">Unlocked · 14 templates</span></div>
            <div class="step-card-row highlight"><span class="step-card-key">Status</span><span class="step-card-val"><strong>Ready to onboard clients</strong></span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid reverse">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">02</span><span class="step-day">Per client · 5 minutes</span></div>
          <h3 class="h-md">Add a client. <span class="accent">$49 starts. $1,500 collects.</span></h3>
          <p>You bill the client your way. theStacc bills you $49 per account. Margin lands on day 1.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>5-min client onboarding</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>You bill clients on your terms</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>First content in 24h</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-2">
            <div class="step-card-header"><span class="step-card-tag">CLIENTS ADDED · 22</span><span class="step-card-status">● Auto</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mo 1</span><span class="step-feed-text">3 clients onboarded · $4,500 MRR</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mo 2</span><span class="step-feed-text">11 clients · $16,500 MRR</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mo 3</span><span class="step-feed-text">17 clients · $25,500 MRR</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mo 4</span><span class="step-feed-text">22 clients · $33,000 MRR</span></div>
            <div class="step-feed-item"><span class="step-feed-dot live"></span><span class="step-feed-time">Now</span><span class="step-feed-text">96% margin compounding monthly</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">03</span><span class="step-day">1st of every month</span></div>
          <h3 class="h-md">Branded reports <span class="accent">close every client.</span></h3>
          <p>Each client gets a branded PDF on the 1st. Rank, traffic, what shipped — all yours. Renewals tick up.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Auto-PDF on the 1st</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Your brand on every cover</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Renewal-ready evidence</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-3">
            <div class="step-card-header"><span class="step-card-tag">RESELLER P&amp;L</span><span class="step-card-status">● Live</span></div>
            <div class="step-stat-big">
              <span class="step-stat-num">$31,922</span>
              <span class="step-stat-label">Monthly profit · 22 clients</span>
              <span class="step-stat-delta">96% gross margin</span>
            </div>
            <div class="step-stat-row">
              <div><strong>22</strong> clients</div>
              <div><strong>$49</strong> each</div>
              <div><strong>96%</strong> margin</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="faq-grid">
      <div class="faq-left">
        <span class="label-pill">03 · FAQ</span>
        <h2 class="h-md">SEO reseller program, <span class="accent">answered.</span></h2>
        <p>More questions? Email <a href="mailto:founder@thestacc.com">founder@thestacc.com</a> — we reply within 24 hours.</p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">What is an SEO reseller program?</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner">An SEO reseller program lets agencies and consultants resell SEO services under their own brand without hiring writers or building tools. theStacc handles the work; you handle the client. <a href="/white-label-seo/">See white-label →</a></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">How much do I pay vs charge?</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner">You pay theStacc $49 to $99 per client account per month. You charge clients $750 to $3,500 per month. Margins run 93% to 97%. <a href="/pricing/">See pricing →</a></div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">Is there a minimum number of clients?</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner">No minimum. Start with one client for $1 trial. Add more as you sell them. Cancel any account on next billing date.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">Reseller vs white-label — what's the difference?</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner">Reseller = you bill clients on your terms. White-label = your brand on the dashboard, reports, and emails. theStacc is both. Most agencies use both.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">Do I get reseller training?</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner">Yes. The reseller playbook ships in your dashboard on day 1 — pricing templates, sales decks, onboarding emails, and the SLA your team can copy.</div>
        </div>
        <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">What support is included?</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
