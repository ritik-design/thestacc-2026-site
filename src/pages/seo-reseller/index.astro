    .margin-calc { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 32px; background: white; border: 1px solid var(--border); padding: 40px; box-shadow: 0 24px 60px -16px rgba(15,15,30,0.12); }
    .mc-controls { display: flex; flex-direction: column; gap: 28px; }
    .mc-control label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-3); margin-bottom: 10px; }
