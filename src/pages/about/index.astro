---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'About — Built by operators who got tired of bad SEO | theStacc',
  description: 'theStacc was built by Siddharth Gangal to help small businesses rank in Google and AI search without hiring a $3,500/mo agency. Meet the team, our investors, and the story behind the product.',
  canonical: 'https://thestacc.com/about/',
  ogImage: '/og/about.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "About", "item": "https://thestacc.com/about/" }
        ]
      },
      {
        "@type": "Organization",
        "name": "theStacc",
        "url": "https://thestacc.com/",
        "logo": "https://thestacc.com/button.flex.svg",
        "founder": {
          "@type": "Person",
          "name": "Siddharth Gangal",
          "jobTitle": "Founder & CEO"
        },
        "foundingDate": "2024-01-01",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Jaipur",
          "addressRegion": "Rajasthan",
          "addressCountry": "IN"
        },
        "sameAs": [
          "https://linkedin.com/company/thestacc",
          "https://twitter.com/thestacc"
        ]
      }
    ]
  }
};

const team = [
  { name: 'Siddharth Gangal', role: 'Founder & CEO', bio: 'Sold SEO software to 200+ SMBs before building theStacc. Sales-led founder.', initials: 'SG', color: 'purple' },
  { name: 'Ritik Sharma', role: 'Head of Engineering', bio: 'Shipped the publishing engine that ran 4M+ words through Google.', initials: 'RS', color: 'cyan' },
  { name: 'Aman Verma', role: 'Head of AI', bio: 'Trained the brand-voice model. Built the AI Humanizer that beats every detector.', initials: 'AV', color: 'orange' },
  { name: 'Priya Mehta', role: 'Head of Growth', bio: 'Ran SEO at a Series-B SaaS. Knows what 127 customers need before they ask.', initials: 'PM', color: 'pink' },
  { name: 'Karthik Iyer', role: 'Customer Success', bio: 'Onboards every new customer in 24 hours. Reads every support email.', initials: 'KI', color: 'emerald' },
  { name: 'Neha Kapoor', role: 'Content Lead', bio: 'Reviews 10% of every article we publish. Keeps the brand voice sharp.', initials: 'NK', color: 'purple' },
];

const values = [
  { n: '01', t: 'Ship the work, not the meeting', d: 'We publish more articles than we hold internal calls. Output beats slides.' },
  { n: '02', t: 'Plain words win', d: 'If a dentist cannot read it, we rewrite it. No jargon. Ever.' },
  { n: '03', t: 'Customers are right twice', d: 'Once when they sign up. Once when they cancel. Both moments teach us.' },
  { n: '04', t: 'Compound the boring stuff', d: 'Publish daily. Rank weekly. Win quarterly. Small loops, repeated forever.' },
];

const investors = [
  { name: 'Sequoia Surge', tier: 'Seed' },
  { name: 'Y Combinator', tier: 'Seed' },
  { name: 'Tanglin Ventures', tier: 'Pre-seed' },
  { name: 'Operator Collective', tier: 'Angel' },
  { name: 'SaaS Angels', tier: 'Angel' },
];

const press = [
  'TechCrunch', 'Product Hunt', 'Indie Hackers', 'SaaStr', 'The Information', 'Times of India',
];

const roles = [
  { title: 'Senior Frontend Engineer', loc: 'Jaipur / Remote', team: 'Engineering' },
  { title: 'Customer Success Lead — North America', loc: 'Remote', team: 'Success' },
  { title: 'Performance Marketing Manager', loc: 'Jaipur', team: 'Growth' },
];
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">About theStacc</span>
    <h1 class="h-display">We build SEO that <span class="accent">small businesses</span> can actually afford.</h1>
    <p class="hero-sub">theStacc was started in 2024. The goal was simple. Replace the $3,500/mo agency with a $99/mo subscription that ships more, ranks faster, and never sleeps. We're a team of 14 in Jaipur, India.</p>
    <div class="hero-ctas">
      <a href="/demo/" class="btn btn-primary"><span>Talk to the founder <span class="arrow">→</span></span></a>
      <a href="#open-roles" class="btn btn-secondary">See open roles</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item"><span><strong>127+</strong> paying customers</span></div>
      <div class="hero-meta-item"><span><strong>4M+</strong> words shipped</span></div>
      <div class="hero-meta-item"><span><strong>14</strong> people</span></div>
    </div>
  </section>

  <!-- FOUNDER STORY -->
  <section style="padding: 96px 32px; background: var(--bg-soft);">
    <div style="max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 320px 1fr; gap: 64px; align-items: start;">

      <!-- Founder photo + card -->
      <div class="founder-card">
        <div class="founder-photo" aria-hidden="true">SG</div>
        <div class="founder-name">Siddharth Gangal</div>
        <div class="founder-role">Founder &amp; CEO · theStacc</div>
        <div class="founder-links">
          <a href="https://linkedin.com/in/siddharth-gangal" target="_blank" rel="noopener">LinkedIn</a>
          <span class="dot">·</span>
          <a href="https://twitter.com/sgangal" target="_blank" rel="noopener">Twitter</a>
          <span class="dot">·</span>
          <a href="mailto:founder@thestacc.com">Email</a>
        </div>
      </div>

      <!-- Story -->
      <div>
        <span class="label-pill" style="margin-bottom: 20px;">Founder story</span>
        <h2 class="h-lg" style="margin-bottom: 24px;">I built theStacc because I was tired of <span class="accent">selling SEO that didn't ship.</span></h2>
        <div class="founder-story">
          <p>For seven years I sold SEO software to small business owners. Dentists. Plumbers. Law firms. The product was good. The pitch was good. The problem was the work after the sale.</p>
          <p>Every customer hit the same wall. They paid $3,500 a month to an agency. They got 2 articles. Maybe 4 blog posts a quarter. The Google Business Profile sat empty for weeks. The reviews went unanswered. The Map Pack rank slipped.</p>
          <p>I watched the same story play out 200 times. The same owner. The same agency invoice. The same flat traffic chart at the end of the year.</p>
          <p>So in January 2024 I quit. I called Ritik, who I'd known since college. He'd just shipped a publishing engine that could push 4,000 words an hour to WordPress without a hiccup. I called Aman, who had trained a brand-voice model that fooled every AI detector we threw at it.</p>
          <p>We picked one promise. <strong>Ship more SEO work in 30 days than your agency ships in 90.</strong> For one tenth the cost. That was the whole brief.</p>
          <p>Eighteen months later, theStacc has 127 paying customers. We have published 4 million words. We have answered 12,000 Google reviews. Customers like Elena at Routehub replaced their entire $8,000/mo freelancer line with our $99/mo plan.</p>
          <p>We are still small. We are still in Jaipur. We still read every support email. If you want to talk, my address is below.</p>
          <p class="founder-signoff">— Siddharth</p>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section style="padding: 96px 32px;">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div style="text-align: center; max-width: 720px; margin: 0 auto 56px;">
        <span class="label-pill" style="margin-bottom: 20px;">How we work</span>
        <h2 class="h-lg" style="margin-bottom: 16px;">Four rules. <span class="accent">No exceptions.</span></h2>
        <p class="lede">Every hire reads these on day one. Every product call comes back to them.</p>
      </div>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value-card">
            <div class="value-num">{v.n}</div>
            <h3 class="h-sm" style="margin-bottom: 10px;">{v.t}</h3>
            <p>{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section style="padding: 96px 32px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1.4fr; gap: 64px; align-items: start; margin-bottom: 56px;">
        <div>
          <span class="label-pill" style="margin-bottom: 20px;">The team</span>
          <h2 class="h-lg" style="margin-bottom: 16px;">14 people. <span class="accent">One city. Zero meetings.</span></h2>
        </div>
        <div>
          <p class="lede">We work from one office in Jaipur. We ship every weekday. We do one all-hands a month. The rest of the time we publish, code, and answer customer email.</p>
        </div>
      </div>
      <div class="team-grid">
        {team.map((m) => (
          <div class="team-card">
            <div class={`t-avatar ${m.color}`}>{m.initials}</div>
            <div class="team-name">{m.name}</div>
            <div class="team-role">{m.role}</div>
            <p class="team-bio">{m.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INVESTORS -->
  <section style="padding: 96px 32px;">
    <div style="max-width: 1080px; margin: 0 auto; text-align: center;">
      <span class="label-pill" style="margin-bottom: 20px;">Backed by</span>
      <h2 class="h-lg" style="margin-bottom: 16px;">Operators who have <span class="accent">built and sold</span> their own SaaS.</h2>
      <p class="lede" style="margin-bottom: 56px;">We took $2.4M to keep the team small and the runway long. Every check came from a founder who has shipped a real product.</p>
      <div class="investors-strip">
        {investors.map((inv) => (
          <div class="investor-cell">
            <div class="investor-name">{inv.name}</div>
            <div class="investor-tier">{inv.tier}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRESS -->
  <section style="padding: 80px 32px; background: var(--bg-soft); border-top: 1px solid var(--border);">
    <div style="max-width: 1080px; margin: 0 auto; text-align: center;">
      <p class="trust-label" style="margin-bottom: 32px;">As seen in</p>
      <div class="press-strip">
        {press.map((p) => (
          <div class="press-logo">{p}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- OPEN ROLES -->
  <section id="open-roles" style="padding: 96px 32px;">
    <div style="max-width: 1080px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1.4fr; gap: 64px; align-items: start; margin-bottom: 48px;">
        <div>
          <span class="label-pill" style="margin-bottom: 20px;">Hiring</span>
          <h2 class="h-lg">3 open roles. <span class="accent">Read on.</span></h2>
        </div>
        <div>
          <p class="lede">We hire people who ship in the first week. No 8-stage interview. One call with Siddharth. One pair-coding round. A two-day paid trial. Then an offer.</p>
          <p style="margin-top: 16px;">Want to apply? Email <a href="mailto:jobs@thestacc.com" style="color: var(--brand); font-weight: 500;">jobs@thestacc.com</a> with the role name in the subject line.</p>
        </div>
      </div>
      <div class="roles-list">
        {roles.map((r) => (
          <a href="mailto:jobs@thestacc.com" class="role-row">
            <div class="role-main">
              <div class="role-title">{r.title}</div>
              <div class="role-meta">{r.team} · {r.loc}</div>
            </div>
            <div class="role-cta">Apply <span class="arrow">→</span></div>
          </a>
        ))}
      </div>
      <p style="text-align: center; margin-top: 40px; color: var(--text-3); font-size: 14px;">Not seeing your role? <a href="/contact/" style="color: var(--brand);">Pitch us anyway →</a></p>
    </div>
  </section>

  <!-- CROSS-LINK STRIP -->
  <section style="padding: 64px 32px; background: var(--bg-soft); border-top: 1px solid var(--border);">
    <div style="max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
      <a href="/case-studies/" class="cross-card">
        <div class="cross-eyebrow">Proof</div>
        <div class="cross-title">Read customer wins →</div>
      </a>
      <a href="/pricing/" class="cross-card">
        <div class="cross-eyebrow">Pricing</div>
        <div class="cross-title">$1 for the first 30 days →</div>
      </a>
      <a href="/modules/" class="cross-card">
        <div class="cross-eyebrow">Product</div>
        <div class="cross-title">See every module →</div>
      </a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse"><circle cx="1" cy="1" r="1" fill="currentColor"/></pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%"><stop offset="0%" stop-color="white" stop-opacity="1"/><stop offset="100%" stop-color="white" stop-opacity="0"/></radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Built for the small business</span>
        <h2 class="final-headline">Stop paying agencies. <span class="accent">Start ranking.</span></h2>
        <p class="final-sub">$1 trial. 24-hour setup. Content stays forever, even if you cancel.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>127+ businesses</span> · <span>4.9 ★ on G2</span> · <span>$1 trial</span> · <span>Cancel anytime</span></div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─────── FOUNDER STORY ─────── */
  .founder-card {
    background: white;
    border: 1px solid var(--border);
    padding: 28px;
    text-align: center;
    position: sticky;
    top: 96px;
  }
  .founder-photo {
    width: 180px;
    height: 180px;
    margin: 0 auto 20px;
    background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%);
    color: white;
    display: grid;
    place-items: center;
    font-size: 56px;
    font-weight: 700;
    letter-spacing: -0.04em;
    box-shadow: 0 18px 36px -14px var(--brand-glow);
  }
  .founder-name { font-size: 19px; font-weight: 600; color: var(--text-1); letter-spacing: -0.015em; margin-bottom: 4px; }
  .founder-role { font-size: 13px; color: var(--text-3); margin-bottom: 18px; }
  .founder-links { display: flex; justify-content: center; gap: 8px; font-size: 13px; color: var(--brand); }
  .founder-links a { color: var(--brand); font-weight: 500; }
  .founder-links a:hover { color: var(--brand-deep); }
  .founder-links .dot { color: var(--text-4); }
  .founder-story p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-2);
    margin-bottom: 18px;
  }
  .founder-story p strong { color: var(--text-1); font-weight: 600; }
  .founder-signoff {
    font-family: 'Geist', sans-serif;
    font-size: 18px;
    color: var(--text-1);
    font-style: italic;
    margin-top: 32px;
  }

  /* ─────── VALUES ─────── */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .value-card {
    background: white;
    border: 1px solid var(--border);
    padding: 28px;
    transition: all 0.2s cubic-bezier(.2,.8,.2,1);
  }
  .value-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18);
  }
  .value-num {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--brand);
    font-weight: 600;
    letter-spacing: 0.14em;
    margin-bottom: 18px;
  }
  .value-card p { font-size: 14.5px; line-height: 1.55; color: var(--text-2); }

  /* ─────── TEAM ─────── */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .team-card {
    background: white;
    border: 1px solid var(--border);
    padding: 28px;
    transition: all 0.2s cubic-bezier(.2,.8,.2,1);
  }
  .team-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18);
  }
  .t-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50% !important;
    display: grid;
    place-items: center;
    font-size: 18px;
    font-weight: 600;
    color: white;
    margin-bottom: 18px;
    letter-spacing: -0.01em;
  }
  .t-avatar.purple { background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%); }
  .t-avatar.cyan { background: linear-gradient(135deg, var(--accent-cyan) 0%, #0e7490 100%); }
  .t-avatar.orange { background: linear-gradient(135deg, #f97316 0%, #c2410c 100%); }
  .t-avatar.pink { background: linear-gradient(135deg, var(--accent-pink) 0%, #be185d 100%); }
  .t-avatar.emerald { background: linear-gradient(135deg, var(--accent-emerald) 0%, #047857 100%); }
  .team-name { font-size: 17px; font-weight: 600; color: var(--text-1); letter-spacing: -0.015em; margin-bottom: 2px; }
  .team-role { font-family: 'Geist Mono', monospace; font-size: 11px; text-transform: uppercase; color: var(--brand); letter-spacing: 0.12em; font-weight: 600; margin-bottom: 14px; }
  .team-bio { font-size: 14px; line-height: 1.55; color: var(--text-2); }

  /* ─────── INVESTORS ─────── */
  .investors-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border: 1px solid var(--border);
  }
  .investor-cell {
    padding: 32px 20px;
    text-align: center;
    border-right: 1px solid var(--border);
  }
  .investor-cell:last-child { border-right: none; }
  .investor-name { font-size: 16px; font-weight: 600; color: var(--text-1); letter-spacing: -0.01em; margin-bottom: 4px; }
  .investor-tier { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); letter-spacing: 0.14em; text-transform: uppercase; font-weight: 500; }

  /* ─────── PRESS ─────── */
  .press-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 56px;
    flex-wrap: wrap;
  }
  .press-logo {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-3);
    letter-spacing: -0.015em;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .press-logo:hover { opacity: 1; color: var(--text-1); }

  /* ─────── ROLES ─────── */
  .roles-list {
    border-top: 1px solid var(--border);
  }
  .role-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-1);
    transition: padding 0.2s;
  }
  .role-row:hover { padding-left: 8px; }
  .role-row:hover .role-cta { color: var(--brand); }
  .role-title { font-size: 19px; font-weight: 600; color: var(--text-1); letter-spacing: -0.015em; margin-bottom: 4px; }
  .role-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.12em; text-transform: uppercase; }
  .role-cta { font-size: 14px; font-weight: 500; color: var(--text-2); display: inline-flex; align-items: center; gap: 8px; transition: color 0.2s; }
  .role-cta .arrow { transition: transform 0.2s; }
  .role-row:hover .role-cta .arrow { transform: translateX(4px); }

  /* ─────── CROSS-LINK ─────── */
  .cross-card {
    background: white;
    border: 1px solid var(--border);
    padding: 24px;
    transition: all 0.2s cubic-bezier(.2,.8,.2,1);
  }
  .cross-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18);
  }
  .cross-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--brand);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .cross-title { font-size: 17px; font-weight: 600; color: var(--text-1); letter-spacing: -0.015em; }
  .cross-card:hover .cross-title { color: var(--brand); }

  /* ─────── RESPONSIVE ─────── */
  @media (max-width: 1000px) {
    section[style*="grid-template-columns: 320px 1fr"] > div:first-child,
    section[style*="grid-template-columns: 1fr 1.4fr"] > div:first-child {
      grid-template-columns: 1fr !important;
    }
    .founder-card { position: static; max-width: 320px; margin: 0 auto; }
    .values-grid { grid-template-columns: repeat(2, 1fr); }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
    .investors-strip { grid-template-columns: repeat(2, 1fr); }
    .investor-cell { border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  }
  @media (max-width: 1000px) {
    section[style*="grid-template-columns: 320px 1fr"],
    section[style*="grid-template-columns: 1fr 1.4fr"] > div[style*="grid-template-columns: 1fr 1.4fr"] {
      display: block !important;
    }
  }
  @media (max-width: 700px) {
    .values-grid, .team-grid { grid-template-columns: 1fr; }
    .investors-strip { grid-template-columns: 1fr; }
    .press-strip { gap: 24px; }
    section[style*="grid-template-columns: repeat(3, 1fr)"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
