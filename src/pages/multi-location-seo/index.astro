  <style>
    .heatmap-section { padding: 96px 32px; background: var(--bg-soft); }
    .heatmap-header { text-align: center; max-width: 720px; margin: 0 auto 48px; }
    .heatmap-header .label-pill { margin-bottom: 24px; }
    .heatmap-header h2 { margin-bottom: 16px; }
    .heatmap-wrap { max-width: 880px; margin: 0 auto; background: white; border: 1px solid var(--border); padding: 32px; box-shadow: 0 24px 60px -16px rgba(15,15,30,0.12); }
    .heatmap-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; }
    .hm-cell { aspect-ratio: 1.4; display: grid; place-items: center; font-family: 'Geist Mono', monospace; font-size: 14px; font-weight: 700; letter-spacing: -0.02em; transition: transform 0.2s; }
    .hm-cell:hover { transform: scale(1.05); }
    .hm-cell.g { background: linear-gradient(135deg, #ecfdf5 0%, #a7f3d0 100%); color: #047857; }
    .hm-cell.w { background: linear-gradient(135deg, #fef3c7 0%, #fcd34d 100%); color: #92400e; }
    .heatmap-legend { display: flex; justify-content: space-between; align-items: center; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--border); font-size: 13px; color: var(--text-2); flex-wrap: wrap; gap: 12px; }
    .heatmap-legend > div { display: flex; align-items: center; gap: 8px; }
    .hm-key { display: inline-block; width: 16px; height: 16px; }
    .hm-key.g { background: linear-gradient(135deg, #ecfdf5 0%, #a7f3d0 100%); }
    .hm-key.w { background: linear-gradient(135deg, #fef3c7 0%, #fcd34d 100%); }
    .hm-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); text-transform: uppercase; letter-spacing: 0.06em; }
    @media (max-width: 600px) { .heatmap-grid { grid-template-columns: repeat(4, 1fr); } }
  </style>

</BaseLayout>
