---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'Affiliate program — 30% recurring on every referral | theStacc',
  description: 'Earn 30% recurring commission for the life of every customer you refer to theStacc. Cookie lasts 90 days. Paid monthly. No cap.',
  canonical: 'https://thestacc.com/affiliates/',
  ogImage: '/og/affiliates.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "Affiliates", "item": "https://thestacc.com/affiliates/" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How much do I earn per referral?",
            "acceptedAnswer": { "@type": "Answer", "text": "30% of every payment, every month, for the life of the customer. On a Bundle plan ($167/mo) you earn $50.10 every month until they cancel." }
          },
          {
            "@type": "Question",
            "name": "How long does the cookie last?",
            "acceptedAnswer": { "@type": "Answer", "text": "90 days. If someone clicks your link today and signs up within 90 days, the commission is yours." }
          },
          {
            "@type": "Question",
            "name": "When do I get paid?",
            "acceptedAnswer": { "@type": "Answer", "text": "On the 5th of every month for the previous month's revenue. Paid via PayPal, Wise, or direct bank transfer above $50." }
          },
          {
            "@type": "Question",
            "name": "Is there a minimum payout?",
            "acceptedAnswer": { "@type": "Answer", "text": "$50. Anything below that rolls over to the next month." }
          },
          {
            "@type": "Question",
            "name": "Can I run paid ads on the theStacc brand keyword?",
            "acceptedAnswer": { "@type": "Answer", "text": "No. Bidding on 'thestacc' or any variation is the one rule that gets you removed from the program." }
          },
          {
            "@type": "Question",
            "name": "Do you offer custom commission deals?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes — for affiliates who send 10+ paying customers a month, we negotiate 40% rates. Email partners@thestacc.com." }
          }
        ]
      }
    ]
  }
};

const topAffiliates = [
  { name: 'SEO Sandra', niche: 'YouTube · SEO tutorials', monthly: '$4,820' },
  { name: 'Marcus @ AgencyOps', niche: 'Newsletter · Agency owners', monthly: '$3,640' },
  { name: 'Local SEO Lab', niche: 'Course creator · 18k students', monthly: '$2,910' },
  { name: 'The Solo Founder', niche: 'Podcast · 80k downloads', monthly: '$2,180' },
];
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Affiliate program</span>
    <h1 class="h-display">Earn 30% <span class="accent">every month.</span> Forever.</h1>
    <p class="hero-sub">Refer a customer. Get paid 30% of every dollar they pay theStacc. <strong>Every month. For as long as they stay.</strong> Cookie lasts 90 days. No cap on earnings.</p>
    <div class="hero-ctas">
      <a href="#apply" class="btn btn-primary"><span>Apply to the program <span class="arrow">→</span></span></a>
      <a href="#how-it-works" class="btn btn-secondary">See how it works</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item"><span><strong>30%</strong> recurring</span></div>
      <div class="hero-meta-item"><span><strong>90-day</strong> cookie</span></div>
      <div class="hero-meta-item"><span><strong>$50.10</strong> per Bundle / mo</span></div>
    </div>
  </section>

  <!-- EARNINGS STRIP -->
  <section style="padding: 80px 32px; background: var(--bg-soft);">
    <div style="max-width: 1080px; margin: 0 auto;">
      <div style="text-align: center; max-width: 720px; margin: 0 auto 56px;">
        <span class="label-pill" style="margin-bottom: 20px;">Real earnings, last 30 days</span>
        <h2 class="h-lg" style="margin-bottom: 16px;">Top affiliates already <span class="accent">earning rent money.</span></h2>
        <p class="lede">Numbers below are from our top 4 partners in the last 30 days. We pay on the 5th of every month.</p>
      </div>
      <div class="earnings-grid">
        {topAffiliates.map((a, i) => (
          <div class="earnings-card">
            <div class="earnings-rank">#{i + 1}</div>
            <div class="earnings-name">{a.name}</div>
            <div class="earnings-niche">{a.niche}</div>
            <div class="earnings-amount">{a.monthly}</div>
            <div class="earnings-label">last 30 days</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" style="padding: 96px 32px;">
    <div style="max-width: 1080px; margin: 0 auto;">
      <div style="text-align: center; max-width: 720px; margin: 0 auto 56px;">
        <span class="label-pill" style="margin-bottom: 20px;">How it works</span>
        <h2 class="h-lg" style="margin-bottom: 16px;">Three steps. <span class="accent">No fine print.</span></h2>
      </div>
      <div class="how-grid">
        <div class="how-card">
          <div class="how-num">01</div>
          <h3 class="h-sm" style="margin-bottom: 10px;">Apply in 2 minutes</h3>
          <p>Tell us where you have an audience. We approve most applications within 24 hours. No follower minimums for niche creators.</p>
          <div class="how-meta">Approval · within 24 hours</div>
        </div>
        <div class="how-card">
          <div class="how-num">02</div>
          <h3 class="h-sm" style="margin-bottom: 10px;">Share your link</h3>
          <p>Get a custom dashboard. Drop your link in newsletters, YouTube descriptions, blog posts, podcast show notes. Track every click in real time.</p>
          <div class="how-meta">Cookie · 90 days</div>
        </div>
        <div class="how-card">
          <div class="how-num">03</div>
          <h3 class="h-sm" style="margin-bottom: 10px;">Get paid monthly</h3>
          <p>30% of every payment from every customer you refer. Forever. Paid by PayPal, Wise, or bank transfer on the 5th of every month.</p>
          <div class="how-meta">Min payout · $50</div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMISSION TABLE -->
  <section style="padding: 96px 32px; background: var(--bg-soft);">
    <div style="max-width: 1080px; margin: 0 auto;">
      <div style="text-align: center; max-width: 720px; margin: 0 auto 48px;">
        <span class="label-pill" style="margin-bottom: 20px;">Commission math</span>
        <h2 class="h-lg" style="margin-bottom: 16px;">What you earn per <span class="accent">paying customer.</span></h2>
        <p class="lede">30% on every plan, every month. The longer they stay, the more you earn.</p>
      </div>
      <div class="commission-table">
        <div class="commission-row head">
          <div>Plan</div>
          <div>Customer pays / mo</div>
          <div>You earn / mo</div>
          <div>Year 1 total</div>
        </div>
        <div class="commission-row">
          <div class="plan-name">Local SEO</div>
          <div>$49</div>
          <div class="earn">$14.70</div>
          <div>$176</div>
        </div>
        <div class="commission-row">
          <div class="plan-name">Social Media</div>
          <div>$49</div>
          <div class="earn">$14.70</div>
          <div>$176</div>
        </div>
        <div class="commission-row">
          <div class="plan-name">Blog SEO</div>
          <div>$99</div>
          <div class="earn">$29.70</div>
          <div>$356</div>
        </div>
        <div class="commission-row featured">
          <div class="plan-name">Bundle (all 3) <span class="featured-pill">MOST REFERRED</span></div>
          <div>$167</div>
          <div class="earn brand">$50.10</div>
          <div class="brand-big">$601</div>
        </div>
        <div class="commission-row foot">
          <div colspan="4" style="grid-column: 1 / -1; text-align: center; font-size: 14px; color: var(--text-3); padding: 18px;">
            Refer 10 Bundle customers and earn <strong style="color: var(--brand);">$6,012/year</strong>. Refer 50, earn $30,060.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section style="padding: 96px 32px;">
    <div style="max-width: 1080px; margin: 0 auto;">
      <div style="text-align: center; max-width: 720px; margin: 0 auto 48px;">
        <span class="label-pill" style="margin-bottom: 20px;">Best fit</span>
        <h2 class="h-lg">Who this program <span class="accent">works for.</span></h2>
      </div>
      <div class="fit-grid">
        <div class="fit-card">
          <div class="fit-icon">📣</div>
          <h3 class="h-sm">SEO creators</h3>
          <p>You run a YouTube channel, blog, or newsletter for SEO operators, marketers, or small business owners.</p>
        </div>
        <div class="fit-card">
          <div class="fit-icon">🛠️</div>
          <h3 class="h-sm">Web designers</h3>
          <p>You build sites for dentists, lawyers, contractors, or local shops. Bundle theStacc with every project.</p>
        </div>
        <div class="fit-card">
          <div class="fit-icon">🎙️</div>
          <h3 class="h-sm">Podcasters</h3>
          <p>Your audience is solo founders or marketing leads. They need cheap SEO they can run themselves.</p>
        </div>
        <div class="fit-card">
          <div class="fit-icon">🧑‍🏫</div>
          <h3 class="h-sm">Course creators</h3>
          <p>You teach SEO, local marketing, or small business growth. theStacc is the tool you wish existed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="faq-grid">
      <div class="faq-left">
        <span class="label-pill">FAQ</span>
        <h2 class="h-md" style="margin-top:16px;">Affiliate questions, <span class="accent">answered.</span></h2>
        <p style="margin-top:16px;">Have something else? Email <a href="mailto:partners@thestacc.com">partners@thestacc.com</a>.</p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">How much do I earn per referral?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">30% of every payment, every month, for the life of the customer. On the Bundle plan ($167/mo) you earn $50.10 every month until they cancel.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">How long does the cookie last?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">90 days. If someone clicks your link today and signs up within 90 days, the commission is yours — even if they sign up from a different device.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">When do I get paid?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">On the 5th of every month for the previous month's revenue. Paid via PayPal, Wise, or direct bank transfer above $50.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Is there a minimum payout?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">$50. Anything below rolls over to the next month. Most active affiliates clear this in 2 referrals.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Can I run paid ads on the theStacc brand keyword?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">No. Bidding on "thestacc" or any close variation is the one rule that gets you removed from the program. Paid ads on generic SEO keywords are fine.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Can I refer my own clients?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">Yes. Agencies refer clients all the time. You can also run theStacc under your own brand — see <a href="/white-label-seo/">white label SEO</a> for that option.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Do you offer custom commission deals?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">Yes — for affiliates who send 10+ paying customers a month, we negotiate 40% rates. Email <a href="mailto:partners@thestacc.com">partners@thestacc.com</a>.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">What marketing assets do I get?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">A creator dashboard, swipe files for email, banners in 6 sizes, demo videos you can embed, customer case studies, and access to our Slack for affiliates.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">How do I track my referrals?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">A real-time dashboard shows clicks, sign-ups, trial conversions, and recurring revenue. We never hide a number from you.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Do you accept affiliates outside the US?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">Yes. We pay affiliates in 50+ countries via Wise. India, US, UK, EU, Canada, Australia, Brazil, Philippines and more — all supported.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- APPLY CTA -->
  <section id="apply" class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse"><circle cx="1" cy="1" r="1" fill="currentColor"/></pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%"><stop offset="0%" stop-color="white" stop-opacity="1"/><stop offset="100%" stop-color="white" stop-opacity="0"/></radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Apply in 2 minutes</span>
        <h2 class="final-headline">30% forever. <span class="accent">Starting today.</span></h2>
        <p class="final-sub">Approval inside 24 hours. Your first commission can hit before the end of the month.</p>
        <a href="mailto:partners@thestacc.com?subject=Affiliate%20application" class="final-cta-btn">Apply to the program <span class="arrow">→</span></a>
        <div class="final-trust"><span>30% recurring</span> · <span>90-day cookie</span> · <span>No cap</span> · <span>Monthly payout</span></div>
        <p class="final-ps"><strong>P.S.</strong> See <a href="/pricing/" style="color: white;">pricing</a> for plan details, the <a href="/white-label-seo/" style="color: white;">white label option</a> for agencies, or <a href="/case-studies/" style="color: white;">customer stories</a> to share with your audience.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─────── EARNINGS GRID ─────── */
  .earnings-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .earnings-card {
    background: white;
    border: 1px solid var(--border);
    padding: 28px;
    position: relative;
    transition: all 0.2s cubic-bezier(.2,.8,.2,1);
  }
  .earnings-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18);
  }
  .earnings-rank {
    position: absolute;
    top: 14px;
    right: 18px;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-4);
    letter-spacing: 0.1em;
    font-weight: 600;
  }
  .earnings-name { font-size: 16px; font-weight: 600; color: var(--text-1); letter-spacing: -0.015em; margin-bottom: 4px; }
  .earnings-niche { font-size: 12px; color: var(--text-3); margin-bottom: 18px; }
  .earnings-amount {
    font-size: 36px;
    font-weight: 700;
    color: var(--brand);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 4px;
  }
  .earnings-label {
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    color: var(--text-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ─────── HOW IT WORKS ─────── */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .how-card {
    background: white;
    border: 1px solid var(--border);
    padding: 32px;
    transition: all 0.2s cubic-bezier(.2,.8,.2,1);
  }
  .how-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18);
  }
  .how-num {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--brand);
    font-weight: 600;
    letter-spacing: 0.14em;
    margin-bottom: 18px;
  }
  .how-card p { font-size: 15px; line-height: 1.6; color: var(--text-2); margin-bottom: 16px; }
  .how-meta {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }

  /* ─────── COMMISSION TABLE ─────── */
  .commission-table {
    background: white;
    border: 1px solid var(--border);
  }
  .commission-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 0;
    border-bottom: 1px solid var(--border);
  }
  .commission-row:last-child { border-bottom: none; }
  .commission-row > div {
    padding: 20px 24px;
    font-size: 15px;
    color: var(--text-2);
    border-right: 1px solid var(--border);
    display: flex;
    align-items: center;
  }
  .commission-row > div:last-child { border-right: none; }
  .commission-row.head > div {
    background: var(--bg-soft);
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    padding: 16px 24px;
  }
  .plan-name { font-weight: 600; color: var(--text-1); display: flex; align-items: center; gap: 10px; }
  .featured-pill {
    font-family: 'Geist Mono', monospace;
    font-size: 9px;
    background: var(--brand-softer);
    color: var(--brand);
    padding: 3px 8px;
    border-radius: 100px !important;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
  .commission-row .earn { color: var(--text-1); font-weight: 600; }
  .commission-row .earn.brand { color: var(--brand); }
  .brand-big { font-weight: 700; color: var(--brand); font-size: 18px; }
  .commission-row.featured > div { background: var(--brand-softer); }

  /* ─────── FIT GRID ─────── */
  .fit-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .fit-card {
    background: white;
    border: 1px solid var(--border);
    padding: 28px;
    transition: all 0.2s cubic-bezier(.2,.8,.2,1);
  }
  .fit-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18);
  }
  .fit-icon { font-size: 32px; margin-bottom: 18px; line-height: 1; }
  .fit-card h3 { margin-bottom: 10px; }
  .fit-card p { font-size: 14px; line-height: 1.55; color: var(--text-2); }

  /* ─────── RESPONSIVE ─────── */
  @media (max-width: 1000px) {
    .earnings-grid { grid-template-columns: repeat(2, 1fr); }
    .how-grid { grid-template-columns: 1fr; }
    .fit-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 700px) {
    .earnings-grid { grid-template-columns: 1fr; }
    .fit-grid { grid-template-columns: 1fr; }
    .commission-row { grid-template-columns: 1fr 1fr; }
    .commission-row > div { padding: 14px; font-size: 13px; }
  }
</style>
