---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'Pricing — Plans from $49/mo · $1 trial, no contract | theStacc',
  description: 'theStacc plans from $49/month. Blog SEO ($99), Local SEO ($49), Social Media ($49) — pick one or bundle all three at 15% off. $1 trial, cancel anytime.',
  canonical: 'https://thestacc.com/pricing/',
  ogImage: '/og-default.png',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "Pricing", "item": "https://thestacc.com/pricing/" }
        ]
      },
      {
        "@type": "SoftwareApplication",
        "name": "theStacc",
        "description": "AI SEO automation platform — blog content, local SEO, and social media.",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "offers": [
          { "@type": "Offer", "name": "Blog SEO", "price": "99", "priceCurrency": "USD", "url": "https://thestacc.com/pricing/" },
          { "@type": "Offer", "name": "Local SEO", "price": "49", "priceCurrency": "USD", "url": "https://thestacc.com/pricing/" },
          { "@type": "Offer", "name": "Social Media", "price": "49", "priceCurrency": "USD", "url": "https://thestacc.com/pricing/" }
        ]
      }
    ]
  }
};
---
<BaseLayout seo={seo}>

<!-- HERO -->
<section class="pricing-hero">
  <div class="pricing-hero-bg" aria-hidden="true"></div>
  <div class="pricing-hero-glow" aria-hidden="true"></div>
  <div class="pricing-hero-inner">
    <span class="pricing-eyebrow">TRANSPARENT PRICING</span>
    <h1 class="pricing-h1">
      Pick your modules.<br/>
      <span class="accent">Pay only for what you use.</span>
    </h1>
    <p class="pricing-sub">Blog SEO, Local SEO, and Social Media. Start with one or bundle all three and save 15%.</p>
  </div>
</section>

<!-- TOOLBAR + SOFTWARE PANEL -->
<section class="pricing-section-2" id="pricing-modules">
  <div class="pricing-toolbar">
    <div class="path-wrap">
      <span class="path-label">SELECT YOUR PATH ↓</span>
      <div class="path-toggle" role="group" aria-label="Pricing path">
        <button id="path-software" class="path-btn active" type="button" aria-pressed="true">Software</button>
        <button id="path-services" class="path-btn" type="button" aria-pressed="false">Services</button>
      </div>
    </div>
    <div id="billing-controls" class="billing-wrap" role="group" aria-label="Billing period">
      <span id="mod-billing-label" class="billing-label">Billed yearly</span>
      <button id="mod-billing-toggle" class="billing-toggle on" type="button" aria-label="Toggle annual billing">
        <span id="mod-billing-dot" class="billing-dot"></span>
      </button>
      <span id="mod-save-badge" class="save-badge">Save 17%</span>
    </div>
  </div>

  <!-- SOFTWARE PANEL -->
  <div id="panel-software">
    <div class="section-eyebrow">SOFTWARE PRICING</div>
    <div class="mod-grid">

      <!-- Blog SEO -->
      <div class="mod-card" id="mod-blog" data-module="blog">
        <div class="mod-icon mod-icon-purple">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <h3 class="mod-name">Blog SEO</h3>
        <p class="mod-desc">SEO articles researched, written, and published daily.</p>
        <div class="mod-price-row">
          <span class="currency-symbol mod-currency">$</span><span class="mod-price" id="mod-blog-price">82</span>
          <span class="period-suffix">/mo</span>
        </div>
        <p class="mod-saving" id="mod-blog-saving">You're saving <span class="currency-symbol">$</span><span id="mod-blog-saving-amt">204</span>/yr</p>
        <div class="tier-row" role="radiogroup" aria-label="Blog SEO article count">
          <button data-mod-tier="blog" data-tier-idx="0" class="tier-btn active" role="radio" aria-checked="true">30 articles</button>
          <button data-mod-tier="blog" data-tier-idx="1" class="tier-btn" role="radio" aria-checked="false">50 articles</button>
          <button data-mod-tier="blog" data-tier-idx="2" class="tier-btn" role="radio" aria-checked="false">80 articles</button>
        </div>
        <ul class="mod-features">
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Keyword research &amp; competitor analysis</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Auto-publishing to your site</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>WordPress, Webflow, Ghost &amp; more</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>SEO-optimized &amp; in your brand voice</li>
        </ul>
        <a href="/demo/" class="mod-cta">Book a Demo</a>
      </div>

      <!-- Local SEO -->
      <div class="mod-card" id="mod-local" data-module="local">
        <div class="mod-icon mod-icon-green">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="mod-name">Local SEO</h3>
        <p class="mod-desc">Google Business Profile posts, reviews, and local tracking.</p>
        <div class="mod-price-row">
          <span class="currency-symbol mod-currency">$</span><span class="mod-price" id="mod-local-price">41</span>
          <span class="period-suffix">/mo</span>
        </div>
        <p class="mod-saving" id="mod-local-saving">You're saving <span class="currency-symbol">$</span><span id="mod-local-saving-amt">96</span>/yr</p>
        <div class="tier-row" role="radiogroup" aria-label="Local SEO post count">
          <button data-mod-tier="local" data-tier-idx="0" class="tier-btn active" role="radio" aria-checked="true">30 posts</button>
          <button data-mod-tier="local" data-tier-idx="1" class="tier-btn" role="radio" aria-checked="false">60 posts</button>
          <button data-mod-tier="local" data-tier-idx="2" class="tier-btn" role="radio" aria-checked="false">80 posts</button>
        </div>
        <ul class="mod-features">
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Automated GBP posts</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>AI review responses</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Local keyword tracking</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Multi-location support</li>
        </ul>
        <a href="/demo/" class="mod-cta">Book a Demo</a>
      </div>

      <!-- Social Media -->
      <div class="mod-card" id="mod-social" data-module="social">
        <span class="mod-tag">New</span>
        <div class="mod-icon mod-icon-amber">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        </div>
        <h3 class="mod-name">Social Media</h3>
        <p class="mod-desc">AI posts across Facebook, Instagram, LinkedIn, and X.</p>
        <div class="mod-price-row">
          <span class="currency-symbol mod-currency">$</span><span class="mod-price" id="mod-social-price">41</span>
          <span class="period-suffix">/mo</span>
        </div>
        <p class="mod-saving" id="mod-social-saving">You're saving <span class="currency-symbol">$</span><span id="mod-social-saving-amt">96</span>/yr</p>
        <div class="tier-row" role="radiogroup" aria-label="Social Media post count">
          <button data-mod-tier="social" data-tier-idx="0" class="tier-btn active" role="radio" aria-checked="true">30 posts</button>
          <button data-mod-tier="social" data-tier-idx="1" class="tier-btn" role="radio" aria-checked="false">60 posts</button>
          <button data-mod-tier="social" data-tier-idx="2" class="tier-btn" role="radio" aria-checked="false">120 posts</button>
        </div>
        <ul class="mod-features">
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Auto-posting &amp; scheduling</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Multi-platform analytics</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>On-brand content creation</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>4 platforms included</li>
        </ul>
        <a href="/demo/" class="mod-cta">Book a Demo</a>
      </div>
    </div>
    <div class="bundle-hint">
      Pick 2 or more modules and get <strong>15% off your total</strong>. All modules work together out of the box.
    </div>
  </div>

  <!-- MANAGED SERVICES PANEL -->
  <div id="panel-services" class="services-section">
    <div class="services-header">
      <p class="section-eyebrow">MANAGED SERVICES</p>
      <h2 class="services-h2">We handle your entire marketing.</h2>
      <p class="services-sub">AI does the work. A dedicated manager handles QA, strategy, and your monthly check-in. You show up and review results.</p>
    </div>
    <div class="mod-grid">
      <!-- Local Growth -->
      <div class="mod-card">
        <h3 class="mod-name">Local Growth</h3>
        <p class="mod-desc">Content + Local SEO, fully managed.</p>
        <div class="mod-price-row">
          <span class="managed-currency-symbol mod-currency">$</span><span class="managed-price mod-price" data-usd="749" data-inr="70000">749</span>
          <span class="period-suffix">/mo</span>
        </div>
        <p class="managed-annual-line">or <span class="managed-annual-currency">$</span><span class="managed-annual-price" data-usd="625" data-inr="58000">625</span>/mo billed annually</p>
        <ul class="mod-features svc">
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>30 blog articles published/month</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>30 GBP posts/month</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Daily review monitoring &amp; responses</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Weekly performance reports</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Monthly strategy video call</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>1 location included (+$150/ea extra)</li>
        </ul>
        <a href="/demo/" class="mod-cta">Subscribe Now</a>
      </div>
      <!-- Growth Pro -->
      <div class="mod-card svc-featured">
        <span class="mod-tag">Most Popular</span>
        <h3 class="mod-name">Growth Pro</h3>
        <p class="mod-desc">Content + Local SEO + Social Media.</p>
        <div class="mod-price-row">
          <span class="managed-currency-symbol mod-currency">$</span><span class="managed-price mod-price" data-usd="999" data-inr="90000">999</span>
          <span class="period-suffix">/mo</span>
        </div>
        <p class="managed-annual-line">or <span class="managed-annual-currency">$</span><span class="managed-annual-price" data-usd="835" data-inr="75000">835</span>/mo billed annually</p>
        <ul class="mod-features svc">
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Everything in Local Growth</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>60 social posts/month across 6 platforms</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Platform-specific content &amp; hashtags</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Optimized posting schedule</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Daily engagement monitoring</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Monthly analytics + strategy call</li>
        </ul>
        <a href="/demo/" class="mod-cta">Subscribe Now</a>
      </div>
      <!-- Growth Complete -->
      <div class="mod-card">
        <h3 class="mod-name">Growth Complete</h3>
        <p class="mod-desc">Everything. Blog, local, social, website.</p>
        <div class="mod-price-row">
          <span class="managed-currency-symbol mod-currency">$</span><span class="managed-price mod-price" data-usd="1299" data-inr="110000">1299</span>
          <span class="period-suffix">/mo</span>
        </div>
        <p class="managed-annual-line">or <span class="managed-annual-currency">$</span><span class="managed-annual-price" data-usd="999" data-inr="85000">999</span>/mo billed annually</p>
        <ul class="mod-features svc">
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Everything in Growth Pro</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>AI-built website, hosted &amp; managed</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Monthly site updates &amp; SEO tuning</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Speed monitoring &amp; security patches</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>Weekly reports + monthly strategy call</li>
          <li><svg class="mod-check" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>US-based operations team</li>
        </ul>
        <div class="svc-compare">Compare: a part-time marketing hire costs <strong>$2,500–$4,000/mo</strong>. An agency retainer runs <strong>$3,000–$10,000/mo</strong>.</div>
        <a href="/demo/" class="mod-cta">Subscribe Now</a>
      </div>
    </div>
  </div>
</section>

<!-- WHAT YOU ACTUALLY GET -->
<section class="compare-section" id="compare">
  <div class="compare-head">
    <p class="section-eyebrow">WHAT YOU ACTUALLY GET</p>
    <h2 class="compare-h2">Every module replaces 2–3 tools you're paying for today.</h2>
    <p class="compare-sub">Less software. Less overhead. Better results.</p>
  </div>
  <div class="compare-tabs" role="tablist">
    <button class="compare-tab active" role="tab" data-tab="blog">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      Blog SEO
    </button>
    <button class="compare-tab" role="tab" data-tab="local">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Local SEO
    </button>
    <button class="compare-tab" role="tab" data-tab="social">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      Social Media
    </button>
  </div>

  <div class="compare-panel active" data-panel="blog">
    <div class="compare-grid">
      <div>
        <h3 class="compare-h3">Blog SEO</h3>
        <p class="compare-replaces">Replaces: <s>SEO tool</s> + <s>freelance writers</s> + <s>content calendar</s></p>
        <p class="compare-body">Most businesses publish 1–4 blog posts per month. The ones ranking on Google publish 20–30. theStacc writes, optimizes, and publishes articles to your site every day. No writers to manage. No briefs. No missed deadlines.</p>
      </div>
      <div class="compare-stats">
        <div class="stat-row">
          <div class="stat-label-row"><span class="stat-name">Content velocity</span><span class="stat-value purple">30 articles/mo</span></div>
          <div class="stat-track"><div class="stat-bar purple" data-width="85"></div></div>
        </div>
        <div class="stat-row">
          <div class="stat-label-row"><span class="stat-name">Cost vs. freelancers</span><span class="stat-value green">90% less</span></div>
          <div class="stat-track"><div class="stat-bar green" data-width="90"></div></div>
        </div>
        <div class="stat-row">
          <div class="stat-label-row"><span class="stat-name">Time to first rankings</span><span class="stat-value amber">60–90 days</span></div>
          <div class="stat-track"><div class="stat-bar amber" data-width="65"></div></div>
