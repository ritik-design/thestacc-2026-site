  .growth-x-axis { display: flex; justify-content: space-between; margin-top: 12px; padding: 0 4px; font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--text-3); }
  .growth-milestones { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; max-width: 800px; margin: 0 auto; }
  .milestone { background: white; border: 1px solid var(--border); padding: 20px; text-align: center; }
  .m-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.16em; color: var(--brand-bright); }
  .m-num { font-size: 28px; font-weight: 700; letter-spacing: -0.025em; color: var(--text-1); margin-top: 8px; }
  .m-lbl { font-size: 13px; color: var(--text-3); margin-top: 4px; }

  /* FAQ */
  .faq-section-pricing { padding: 80px 32px; border-top: 1px solid var(--border); background: white; }
  .faq-section-pricing .faq-list { max-width: 800px; margin: 40px auto 0; }

  /* FINAL CTA */
  .pricing-final-cta { padding: 64px 32px; text-align: center; background: white; border-top: 1px solid var(--border); }
  .pricing-final-cta .section-eyebrow { color: var(--brand); }
  .final-h3 { font-size: 26px; font-weight: 700; letter-spacing: -0.02em; color: var(--text-1); margin: 12px 0 0; }
  .final-sub-pricing { max-width: 440px; margin: 12px auto 0; font-size: 15px; color: var(--text-2); }
  .final-cta-pricing { display: inline-flex; align-items: center; gap: 6px; height: 46px; margin-top: 28px; padding: 0 32px; background: var(--brand-bright); color: white; border: 1px solid var(--brand); text-decoration: none; font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; transition: background 0.2s; }
  .final-cta-pricing:hover { background: var(--brand); }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .mod-grid { grid-template-columns: 1fr; }
    .compare-grid { grid-template-columns: 1fr; gap: 24px; }
    .compound-stats, .growth-milestones { grid-template-columns: 1fr; }
    .pricing-toolbar { flex-direction: column; align-items: flex-start; }
  }
</style>

<script is:inline>
(function() {
  // Pricing data
  const blogTiers = [{price: 99}, {price: 149}, {price: 199}];
  const localTiers = [{price: 49}, {price: 79}, {price: 99}];
  const socialTiers = [{price: 49}, {price: 79}, {price: 129}];
  const tiers = { blog: blogTiers, local: localTiers, social: socialTiers };

  let selectedTier = { blog: 0, local: 0, social: 0 };
  let yearly = true;
  let currency = '$';
  let isINR = false;

  function fmt(n) {
    const t = String(Math.round(n));
    if (t.length <= 3) return t;
    let last3 = t.substring(t.length - 3);
    return t.substring(0, t.length - 3).replace(/\B(?=(\d{2})+(?!\d))/g, ',') + ',' + last3;
  }

  function modulePrice(mod) {
    const t = tiers[mod][selectedTier[mod]].price;
    if (isINR) {
      const v = yearly ? t * 87 * 12 : t * 95;
      return Math.round(v / 1000) * 1000;
    }
    return yearly ? Math.round(t * 0.83) : t;
  }

  function moduleSaving(mod) {
    const t = tiers[mod][selectedTier[mod]].price;
    if (isINR) {
      const monthly = Math.round(t * 95 / 1000) * 1000 * 12;
      const annual = Math.round(t * 87 * 12 / 1000) * 1000;
      return monthly - annual;
    }
    return t * 12 - Math.round(t * 0.83) * 12;
  }

  function updateCurrencyDOM() {
    document.querySelectorAll('.currency-symbol').forEach(el => { el.textContent = currency; });
    document.querySelectorAll('.period-suffix').forEach(el => { el.textContent = (isINR && yearly) ? '/yr' : '/mo'; });
  }

  function render() {
    ['blog', 'local', 'social'].forEach(m => {
      const priceEl = document.getElementById('mod-' + m + '-price');
      const saveEl = document.getElementById('mod-' + m + '-saving');
      const saveAmt = document.getElementById('mod-' + m + '-saving-amt');
      if (priceEl) priceEl.textContent = isINR ? fmt(modulePrice(m)) : String(modulePrice(m));
      if (saveAmt) saveAmt.textContent = isINR ? fmt(moduleSaving(m)) : String(moduleSaving(m));
      if (saveEl) saveEl.style.display = yearly ? '' : 'none';
    });

    document.querySelectorAll('.managed-price').forEach(el => {
      const usd = el.getAttribute('data-usd'); const inr = el.getAttribute('data-inr');
      if (usd && inr) el.textContent = isINR ? fmt(Number(inr)) : usd;
    });
    document.querySelectorAll('.managed-annual-price').forEach(el => {
      const usd = el.getAttribute('data-usd'); const inr = el.getAttribute('data-inr');
      if (usd && inr) el.textContent = isINR ? fmt(Number(inr)) : usd;
    });
    document.querySelectorAll('.managed-currency-symbol').forEach(el => { el.textContent = isINR ? '₹' : '$'; });
    document.querySelectorAll('.managed-annual-currency').forEach(el => { el.textContent = isINR ? '₹' : '$'; });
    document.querySelectorAll('.managed-annual-line').forEach(el => { el.style.display = isINR ? 'none' : ''; });

    updateCurrencyDOM();

    const toggle = document.getElementById('mod-billing-toggle');
    const lbl = document.getElementById('mod-billing-label');
    const badge = document.getElementById('mod-save-badge');
    if (toggle) toggle.classList.toggle('on', yearly);
    if (lbl) lbl.textContent = yearly ? 'Billed yearly' : 'Billed monthly';
    if (badge) badge.style.display = yearly ? '' : 'none';
  }

  function switchPath(p) {
    const sw = document.getElementById('path-software');
    const sv = document.getElementById('path-services');
    if (p === 'software') {
      sw.classList.add('active'); sw.setAttribute('aria-pressed', 'true');
      sv.classList.remove('active'); sv.setAttribute('aria-pressed', 'false');
      document.getElementById('pricing-modules').scrollIntoView({behavior: 'smooth'});
    } else {
      sv.classList.add('active'); sv.setAttribute('aria-pressed', 'true');
      sw.classList.remove('active'); sw.setAttribute('aria-pressed', 'false');
      document.getElementById('panel-services').scrollIntoView({behavior: 'smooth'});
    }
  }

  async function detectGeo() {
    try {
      const r = await fetch('https://ipinfo.io/json');
      if (!r.ok) return;
      const d = await r.json();
      if (d.country === 'IN') {
        isINR = true; currency = '₹';
        render();
      }
    } catch (e) {}
  }

  document.getElementById('path-software')?.addEventListener('click', () => switchPath('software'));
  document.getElementById('path-services')?.addEventListener('click', () => switchPath('services'));
  document.getElementById('mod-billing-toggle')?.addEventListener('click', () => { yearly = !yearly; render(); });
  document.getElementById('mod-billing-label')?.addEventListener('click', () => { yearly = !yearly; render(); });

  ['blog', 'local', 'social'].forEach(mod => {
    document.querySelectorAll('[data-mod-tier="' + mod + '"]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedTier[mod] = parseInt(btn.getAttribute('data-tier-idx') || '0');
        document.querySelectorAll('[data-mod-tier="' + mod + '"]').forEach((b, i) => {
          b.classList.toggle('active', i === selectedTier[mod]);
          b.setAttribute('aria-checked', i === selectedTier[mod] ? 'true' : 'false');
        });
        render();
      });
    });
  });

  render();
  detectGeo();

  // Compare tabs
  document.querySelectorAll('.compare-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab');
      document.querySelectorAll('.compare-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.compare-panel').forEach(p => p.classList.remove('active'));
      const panel = document.querySelector('[data-panel="' + tab + '"]');
      if (panel) {
        panel.classList.add('active');
        panel.querySelectorAll('.stat-bar').forEach(bar => {
          bar.style.width = bar.getAttribute('data-width') + '%';
        });
      }
    });
  });

  // Animate first compare panel stat bars when in view
  const compareObs = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.stat-bar').forEach(bar => {
          bar.style.width = bar.getAttribute('data-width') + '%';
        });
        compareObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.compare-panel').forEach(p => compareObs.observe(p));

  // Growth chart animation
  const growthObs = new IntersectionObserver(es => {
    es.forEach(e => {
      if (e.isIntersecting) {
        const line = e.target.querySelector('.growth-line');
        const area = e.target.querySelector('.growth-area');
        line && line.classList.add('animate');
        area && area.classList.add('animate');
        growthObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  const gc = document.getElementById('growth-chart');
  if (gc) growthObs.observe(gc);

})();
</script>

</BaseLayout>
