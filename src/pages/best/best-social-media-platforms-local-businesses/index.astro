        { "@type": "Question", "name": "Does social media help with local SEO?", "acceptedAnswer": { "@type": "Answer", "text": "Indirectly. Social does not directly affect Google rankings, but it drives branded searches, review volume, and brand mentions that do improve local SEO. Active profiles signal to Google that your business is alive." }},
