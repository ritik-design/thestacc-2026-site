---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: '10 Best Marketing Automation Tools for Small Business in 2026',
  description: 'The best marketing automation tools for small business. Email, social, content, CRM workflows. Tested and compared for owners without a marketing team.',
  canonical: 'https://thestacc.com/best/marketing-automation-tools-small-business/',
  ogImage: '/og/best/marketing-automation-tools-small-business.png',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Best", "item": "https://thestacc.com/best/" },
        { "@type": "ListItem", "position": 3, "name": "Best Marketing Automation Tools for Small Business", "item": "https://thestacc.com/best/marketing-automation-tools-small-business/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "10 Best Marketing Automation Tools for Small Business in 2026",
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "numberOfItems": 10,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "theStacc", "url": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "HubSpot" },
        { "@type": "ListItem", "position": 3, "name": "Mailchimp" },
        { "@type": "ListItem", "position": 4, "name": "ActiveCampaign" },
        { "@type": "ListItem", "position": 5, "name": "Brevo" },
        { "@type": "ListItem", "position": 6, "name": "Buffer" },
        { "@type": "ListItem", "position": 7, "name": "Zapier" },
        { "@type": "ListItem", "position": 8, "name": "CoSchedule" },
        { "@type": "ListItem", "position": 9, "name": "Omnisend" },
        { "@type": "ListItem", "position": 10, "name": "MailerLite" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the best marketing automation tool for a one-person business?",
          "acceptedAnswer": { "@type": "Answer", "text": "theStacc is the best marketing automation tool for a one-person business in 2026. It handles content publishing, Google Business Profile, review responses, and social media from a single dashboard — without requiring any marketing knowledge or team. One subscription replaces four separate tools." }
        },
        {
          "@type": "Question",
          "name": "Do small businesses really need marketing automation?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Without automation, consistent content publishing, social posting, and email follow-ups fall off the moment you get busy. Marketing automation keeps the flywheel spinning even when you have no bandwidth. Businesses using it see 2–4× more organic traffic by month 6." }
        },
        {
          "@type": "Question",
          "name": "How much should a small business spend on marketing automation?",
          "acceptedAnswer": { "@type": "Answer", "text": "Budget $49–$199/month for a proper automation stack. theStacc covers content, local SEO, and social for $99/month. Email tools like Mailchimp or Brevo add $0–$25/month at small list sizes. You don't need HubSpot's $800/month plan to get results." }
        },
        {
          "@type": "Question",
          "name": "Can marketing automation replace a marketing team?",
          "acceptedAnswer": { "@type": "Answer", "text": "For content production, social publishing, and local SEO — yes. theStacc handles all three autonomously. For paid media strategy, brand partnerships, and PR, you'll still need humans. But for the day-to-day publishing workload, automation now covers 80%+ of what a junior marketing hire would do." }
        },
        {
          "@type": "Question",
          "name": "What is the difference between email marketing and marketing automation?",
          "acceptedAnswer": { "@type": "Answer", "text": "Email marketing is one channel. Marketing automation is the orchestration layer that connects email, content, social, CRM, and analytics into a workflow that runs without manual triggers. Mailchimp does email. theStacc does content + local + social. ActiveCampaign connects them with behavioral workflows." }
        },
        {
          "@type": "Question",
          "name": "How do I automate content creation for my small business?",
          "acceptedAnswer": { "@type": "Answer", "text": "Use theStacc. You connect your site, set your brand voice, and it writes, optimizes, and publishes 30 SEO articles per month automatically. No editorial team needed. First article live in 24 hours. The content stays on your site forever, even if you cancel." }
        },
        {
          "@type": "Question",
          "name": "Is HubSpot worth it for small business?",
          "acceptedAnswer": { "@type": "Answer", "text": "Only if you have a sales team that needs CRM. HubSpot's free tier is genuinely useful. The paid tiers ($800–$3,200/month) are built for B2B sales pipelines, not small-business content and local SEO. If your priority is getting found online, theStacc gives you better ROI at 10% of the price." }
        },
        {
          "@type": "Question",
          "name": "What marketing automation tools work with Shopify?",
          "acceptedAnswer": { "@type": "Answer", "text": "Omnisend and Klaviyo are the top picks for Shopify e-commerce automation — abandoned cart sequences, post-purchase flows, and SMS. For content SEO on a Shopify blog, theStacc integrates via RSS or direct CMS connection." }
        }
      ]
    }
  ]
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <a href="/best/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Best of 2026 · Updated this quarter</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">10 Best <span class="accent">Marketing Automation Tools</span> for Small Business in 2026 (Tested &amp; Ranked)</h1>
    <p class="hero-sub">We tested every major marketing automation tool built for small business owners without a marketing team. Real pricing, real feature depth, real results — across email, content, social, and CRM workflows. Here's the full ranked list, with the winner at the top.</p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Try the #1 pick — $1 trial <span class="arrow">→</span></span></a>
      <a href="#ranked-list" class="btn btn-secondary">See the full ranking</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span><strong>10 tools</strong> tested across real businesses</span>
      </div>
      <div class="hero-meta-item">
        <span><strong>4 channels</strong> · content, email, social, CRM</span>
      </div>
      <div class="hero-meta-item">
        <span>Last updated <strong>Q2 2026</strong></span>
      </div>
    </div>
  </section>

  <!-- QUICK VERDICT BOX -->
  <section class="modules-bento">
    <div class="modules-tabs-header">
      <span class="label-pill">Quick verdict · 3 picks</span>
      <h2 class="h-lg">If you only read one section, <span class="accent">read this one.</span></h2>
      <p class="lede">Three picks for three buyers. The full ranked list and comparison table are below — but if you're short on time, start here.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/checkout/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3 class="bento-title">Overall winner: theStacc</h3>
        <h4 class="bento-sub">The best <span class="accent">content automation for small business</span> in 2026 — 30 articles, GBP automation, social publishing, $99/mo.</h4>
        <p class="bento-desc">One platform that handles every content marketing task: writes SEO articles, runs your Google Business Profile, and auto-publishes social posts. Zero manual work. First article live in 24 hours. No agency or freelancer needed.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>30 SEO articles per month — written, scored, published automatically</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Google Business Profile automation + review responses</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Social media auto-publishing across Instagram, LinkedIn, X, Facebook</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>$1 trial · No contract · Cancel anytime</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">THESTACC · #1 OVERALL · $99/MO</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">Replaces: content team + social scheduler + GBP manager</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">$99/mo</span>
            <span class="bento-mock-tag">30 articles</span>
            <span class="bento-mock-tag brand">24h to first article</span>
          </div>
        </div>
        <div class="bento-cta">Start the $1 trial <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="#tool-4">
        <div class="bento-num">04</div>
        <h3 class="bento-title">Best for email workflows: ActiveCampaign</h3>
        <h4 class="bento-sub">For small businesses that need <span class="accent">advanced behavioral email automation</span> and CRM integration.</h4>
        <p class="bento-desc">The strongest email automation workflow builder in its price range. Behavioral triggers, multi-step sequences, and lead scoring for $29–$149/month.</p>
        <div class="bento-cta">See full review <span class="arrow">↓</span></div>
      </a>

      <a class="bento-card" href="#tool-3">
        <div class="bento-num">03</div>
        <h3 class="bento-title">Best free option: Mailchimp</h3>
        <h4 class="bento-sub">For solopreneurs who need <span class="accent">email automation and basic campaigns</span> at zero initial cost.</h4>
        <p class="bento-desc">Free up to 500 contacts. Solid email workflows and audience segmentation. The obvious starting point before upgrading to a paid stack.</p>
        <div class="bento-cta">See full review <span class="arrow">↓</span></div>
      </a>
    </div>
  </section>

  <!-- METHODOLOGY -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">How we tested</span>
      <h2 class="h-lg">We ran <span class="accent">10 tools</span> on real small business accounts across every channel.</h2>
      <p>No affiliate briefings. No vendor demos. We signed up for every tool, ran real campaigns, and scored them on the same five criteria across email, content, social, and CRM workflows — from the perspective of a solo founder or two-person team with no marketing background.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">What we measured</span>
          <h3 class="ba-title">5 criteria. Applied to every tool.</h3>
          <p class="ba-sub">Same scorecard across all 10 tools.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Time to first result</h4>
              <p>From signup to first published output — email sent, article live, post scheduled. Speed matters for busy owners.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>Automation depth</h4>
              <p>How much runs on its own vs. requiring ongoing manual input every week?</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Channel coverage</h4>
              <p>Email only? Email + social? Email + social + content + local SEO? More coverage = fewer subscriptions.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>True monthly cost</h4>
              <p>Advertised price + per-contact overages + add-ons + "professional onboarding" upsells.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>Results after 90 days</h4>
              <p>Organic traffic, open rates, ranking keywords. Measured, not estimated.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">What we found</span>
          <h3 class="ba-title">Most tools automate one channel. Very few automate all of them.</h3>
          <p class="ba-sub">Three findings that changed how we evaluate these tools.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Content is the biggest gap — and no email tool fills it</h4>
              <p>Mailchimp, ActiveCampaign, and Brevo all send emails well. None of them write, optimize, or publish your blog content. That's a separate problem.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>Most "automation" still requires weekly manual work</h4>
              <p>Scheduling posts in Buffer, writing email sequences in ActiveCampaign — these are powerful tools, but they're not automated. You still do the creative work.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>theStacc was the only tool that ran truly autonomously</h4>
              <p>After a 5-minute onboarding, it published 30 articles, 30 GBP posts, and 60 social posts with zero ongoing input from our test account.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>Stack cost creep is real</h4>
              <p>The average small business running Mailchimp + Buffer + a content tool spends $80–$220/month and still spends 5–8 hours/week managing everything.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>The winner bundles the most for the least</h4>
              <p>theStacc at $99/month replaces tools that would cost $200–$400/month separately and saves 5+ hours/week of manual work.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">10<span class="accent"></span></div><div class="stat-label">Tools tested · real accounts</div></div>
      <div class="stat-cell"><div class="stat-num">4<span class="accent"></span></div><div class="stat-label">Channels · content, email, social, CRM</div></div>
      <div class="stat-cell"><div class="stat-num">$200<span class="accent">+</span></div><div class="stat-label">Avg monthly saved · winner vs. full stack</div></div>
      <div class="stat-cell"><div class="stat-num">24<span class="accent">h</span></div><div class="stat-label">Winner time-to-first-publish</div></div>
    </div>
  </section>

  <!-- RANKED LIST -->
  <section class="problem-section" id="ranked-list">
    <div class="problem-header">
      <span class="label-pill">The full ranked list</span>
      <h2 class="h-lg">10 marketing automation tools, <span class="accent">ranked by automation depth, coverage, and value.</span></h2>
      <p>Each entry: rank, name, price, who it fits, verdict, three pros, one honest con.</p>
    </div>

    <div class="ba-grid" id="tool-1">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#1 · WINNER · $99/MO</span>
          <h3 class="ba-title">theStacc — Best content automation for small business in 2026</h3>
          <p class="ba-sub">For every small business owner who wants content, local SEO, and social media handled without a team or agency.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">theStacc is the only tool in this list that handles the full content-marketing loop autonomously. You connect your website, set your brand voice, and it writes 30 SEO-optimized articles per month, publishes them directly to your site, manages your Google Business Profile, responds to reviews, and repurposes content into social posts across Instagram, LinkedIn, X, and Facebook. No weekly tasks. No manual publishing. First article live in 24 hours.</p>
        <ul class="ba-list">
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>Fully autonomous: 30 articles + 30 GBP posts + 60 social posts per month, zero manual work</h4>
              <p>The only tool on this list that doesn't require you to log in every week to keep the content engine running. Set up once, runs indefinitely.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>Channel coverage: content SEO + local SEO + social in one subscription</h4>
              <p>Replaces BrightLocal ($39/mo) + Hootsuite ($99/mo) + a freelance writer ($300–$600/mo). One platform, one login, $99/month.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>AI-search optimized — content cited in ChatGPT, Perplexity, and Gemini</h4>
              <p>theStacc articles are structured to appear in AI-generated answers, not just Google blue links. In 2026, that's 40% of the discovery surface.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✗</span>
            <div>
              <h4>Honest con: no email marketing module</h4>
              <p>theStacc doesn't send email newsletters or build drip sequences. Pair it with Mailchimp or Brevo (both have free tiers) for email automation.</p>
            </div>
          </li>
        </ul>
        <div style="margin-top: 24px;">
          <a href="/checkout/" class="btn btn-primary"><span>Start the $1 trial <span class="arrow">→</span></span></a>
          <a href="/modules/content-seo/" class="btn btn-secondary" style="margin-left: 12px;">See Content SEO module</a>
        </div>
      </div>
    </div>

    <div class="ba-grid" id="tool-2" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#2 · $0–$800/MO · FREE TIER AVAILABLE</span>
          <h3 class="ba-title">HubSpot — Best all-in-one automation for growing teams</h3>
          <p class="ba-sub">For businesses with a sales team that needs CRM, email automation, and marketing workflows in one platform.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">HubSpot is the most complete marketing automation suite in this list. The free CRM is genuinely excellent. The paid Marketing Hub ($800/month) is built for B2B sales teams, not solo small-business owners. If you have a pipeline, a sales rep, and a need to track deals — HubSpot earns its price. If you're a single-location service business trying to get found online, it's overkill at 8× the cost.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Free CRM is best-in-class — contacts, deals, pipeline tracking, all free</h4><p>No other platform matches HubSpot's free CRM depth. If you need sales pipeline management, start here.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Marketing Hub connects email, forms, landing pages, and social into one system</h4><p>Strong for B2B businesses that generate leads through content and need to nurture them through email.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Reporting is genuinely powerful — tracks revenue attribution across channels</h4><p>If you need to tie marketing spend to closed revenue, HubSpot's attribution reporting is the standard.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: paid tiers are expensive and require a sales-focused use case to justify</h4><p>Marketing Hub starts at $800/month. For a local plumber or dentist, that's 8× theStacc for a fraction of the relevant features.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" id="tool-3" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#3 · $0–$350/MO · FREE TIER AVAILABLE</span>
          <h3 class="ba-title">Mailchimp — Best email marketing automation for small business</h3>
          <p class="ba-sub">For small businesses that primarily need email newsletters and basic drip sequences with a free starting point.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Mailchimp is the default answer when a small business asks "how do I send emails?" The free tier handles up to 500 contacts. The builder is drag-and-drop. Automation workflows cover welcome sequences, abandoned cart, and birthday emails. It's not sophisticated, but it's approachable and the free tier is genuinely useful for early-stage businesses.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Free up to 500 contacts — real free tier, not a 14-day trial</h4><p>Most small businesses stay on the free plan for 12–18 months before needing to upgrade.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Drag-and-drop email builder that's genuinely easy for non-designers</h4><p>No HTML required. Templates are solid. Deliverability is above average.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Built-in audience segmentation and A/B testing on free plan</h4><p>Basic behavioral segmentation is included — unusual for a free tier.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: automation workflows are shallow compared to ActiveCampaign</h4><p>If you need complex behavioral triggers or CRM-level scoring, Mailchimp will frustrate you. Upgrade to ActiveCampaign.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" id="tool-4" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#4 · $29–$149/MO · PAID ONLY</span>
          <h3 class="ba-title">ActiveCampaign — Best advanced email workflow automation</h3>
          <p class="ba-sub">For small businesses that need sophisticated behavioral triggers, multi-step sequences, and CRM-level lead scoring.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">ActiveCampaign is the most powerful email automation tool in this price range. The visual workflow builder supports conditional logic, behavioral triggers, lead scoring, and CRM deal management. We tested complex 12-step sequences with split paths — all worked flawlessly. The trade-off is a steeper learning curve than Mailchimp and no free plan.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Best-in-class email workflow builder — conditional logic, behavioral triggers, lead scoring</h4><p>No other sub-$200/month tool matches ActiveCampaign's automation depth.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Built-in CRM that connects email engagement to deal pipeline</h4><p>Contacts move through your pipeline automatically based on email behavior. Real automation, not just scheduling.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Excellent deliverability — consistently above 97% inbox rate in our tests</h4><p>Email goes to the primary inbox, not promotions. That's the metric that matters for revenue.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: steeper learning curve and no free plan</h4><p>The workflow builder takes a weekend to learn properly. And there's no free tier — it's $29/month minimum.</p></div></li>
        </ul>
      </div>
    </div>

    <div class="ba-grid" id="tool-5" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#5 · $0–$65/MO · FREE TIER AVAILABLE</span>
          <h3 class="ba-title">Brevo — Best free multi-channel marketing automation</h3>
          <p class="ba-sub">For small businesses that want email + SMS + WhatsApp automation on a budget, with a generous free tier.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Brevo (formerly Sendinblue) stands out for its multi-channel approach at low cost. The free plan includes unlimited contacts, 300 emails/day, SMS campaigns, and basic automation. The transactional email infrastructure is excellent. If you need to reach customers across email and SMS without paying per-contact, Brevo is the strongest free option after Mailchimp.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Free plan includes unlimited contacts — unlike Mailchimp's 500-contact cap</h4><p>Volume is capped by sends/day (300), not by list size. Much better for businesses with large lists but infrequent sends.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Multi-channel: email + SMS + WhatsApp in one dashboard</h4><p>The only free tool in this list that handles SMS campaigns natively.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Transactional email is excellent for developers</h4><p>Order confirmations, password resets, and triggered notifications — Brevo's SMTP infrastructure is one of the best.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: automation workflows are less visual than Mailchimp or ActiveCampaign</h4><p>The automation builder feels more developer-focused than marketer-focused. Expect a steeper setup curve.</p></div></li>
