    <div class="cover-frame">
      <div class="cover-content">
        <div class="cover-mono">Buyer's Guide · Content Autopilot · 2026</div>
        <div class="cover-title">Content <span style="opacity:0.6">·</span> Autopilot</div>
        <div class="cover-sub">10 Tested · $19 → $499/mo · 90-day window</div>
      </div>
    </div>
  </section>

