---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const seo = {
  title: 'Best-of guides — 118 curated SEO software lists · theStacc',
  description: '118 best-of guides on SEO tools, AI writers, local SEO, content optimization, GBP management, and more. Tested, scored, and ranked.',
  canonical: 'https://thestacc.com/best/',
  ogImage: '/og/best.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "theStacc best-of guides",
    "url": "https://thestacc.com/best/"
  }
};

// Dynamic — read every subdirectory in src/pages/best/
const bestDir = path.resolve('./src/pages/best');
const slugs = fs.readdirSync(bestDir, { withFileTypes: true })
  .filter(d => d.isDirectory())
  .map(d => d.name)
  .sort();

// Slug → readable title (keeps acronyms uppercase)
const ACRONYMS = new Set(['seo', 'ai', 'gbp', 'wp', 'cms', 'crm', 'roi', 'cro', 'b2b', 'b2c', 'saas', 'cta']);
const titleize = (slug) => slug
  .split('-')
  .map(w => ACRONYMS.has(w.toLowerCase()) ? w.toUpperCase() : w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');

// Category bucketing for the filter pills
const categoryFor = (slug) => {
  if (slug.includes('local') || slug.includes('gbp') || slug.includes('google-my-business') || slug.includes('google-maps') || slug.includes('citation') || slug.includes('listing')) return 'Local SEO';
  if (slug.includes('social-media') || slug.includes('instagram')) return 'Social Media';
  if (slug.includes('blog') || slug.includes('writer') || slug.includes('writing') || slug.includes('content')) return 'Content & Writing';
  if (slug.includes('keyword')) return 'Keyword Research';
  if (slug.includes('review') || slug.includes('reputation')) return 'Reviews';
  if (slug.includes('automation') || slug.includes('autopilot') || slug.includes('auto-')) return 'Automation';
  if (slug.includes('agency') || slug.includes('reseller') || slug.includes('white-label')) return 'Agencies';
  if (slug.includes('for-') || slug.includes('small-business') || slug.includes('startups') || slug.includes('solopreneurs')) return 'Vertical / Small Biz';
  if (slug.includes('audit') || slug.includes('on-page')) return 'Technical SEO';
  if (slug.includes('email')) return 'Email Marketing';
  if (slug.includes('link') || slug.includes('backlink')) return 'Link Building';
  if (slug.includes('marketing')) return 'Marketing';
  if (slug.includes('seo')) return 'SEO Tools';
  return 'Other';
};

const guides = slugs.map(slug => ({
  slug,
  title: titleize(slug),
  category: categoryFor(slug)
}));

const categories = ['All', ...new Set(guides.map(g => g.category))].sort((a, b) => a === 'All' ? -1 : b === 'All' ? 1 : a.localeCompare(b));
const totalCount = guides.length;
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Best-of · {totalCount} guides</span>
    <h1 class="h-display">{totalCount} curated <span class="accent">"best of" guides.</span></h1>
    <p class="hero-sub">Honest, tested, and ranked. Every guide has a methodology section, a comparison table, and a clear winner pick — no affiliate-spam ordering.</p>
    <div class="hero-ctas">
      <a href="/best/ai-seo-tools/" class="btn btn-primary"><span>Top guide: Best AI SEO Tools <span class="arrow">→</span></span></a>
      <a href="/checkout/" class="btn btn-secondary">Skip the comparison shopping</a>
    </div>
  </section>

  <!-- CATEGORY PILLS -->
  <section style="padding: 32px; background: white; border-bottom: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;">
      {categories.map((c, i) => (
        <button class="cat-pill label-pill" data-cat={c} style={i === 0 ? 'background: var(--brand-softer); border-color: var(--brand-soft);' : ''}>{c}</button>
      ))}
    </div>
  </section>

  <!-- BEST GRID -->
  <section style="padding: 64px 32px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div class="best-grid">
        {guides.map((g) => (
          <a href={`/best/${g.slug}/`} class="best-card" data-cat={g.category}>
            <span class="best-cat">{g.category}</span>
            <h3 class="best-title">{g.title}</h3>
            <span class="best-cta">Read the guide <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
      <div class="best-empty" style="display: none; text-align: center; padding: 80px 20px; color: var(--text-3);">
        No guides in this category yet.
      </div>
    </div>
  </section>

  <!-- LITE FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Skip the comparison. <span class="accent">Try theStacc.</span></h2>
        <p class="final-sub">$1 trial. Replaces 3 tools. Cancel anytime.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    .best-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    @media (max-width: 1100px) { .best-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 800px) { .best-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .best-grid { grid-template-columns: 1fr; } }
    .best-card { display: flex; flex-direction: column; gap: 12px; padding: 24px; background: white; border: 1px solid var(--border); transition: all 0.18s; text-decoration: none; color: inherit; min-height: 160px; }
    .best-card:hover { transform: translateY(-2px); border-color: var(--brand); box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18); }
    .best-cat { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); font-weight: 600; }
    .best-title { font-size: 16px; font-weight: 600; line-height: 1.3; letter-spacing: -0.015em; color: var(--text-1); margin: 0; flex: 1; }
    .best-cta { font-size: 13px; color: var(--brand); font-weight: 600; margin-top: auto; }
    .cat-pill { cursor: pointer; user-select: none; transition: all 0.15s; border: 1px solid var(--border); background: white; }
    .cat-pill:hover { border-color: var(--brand); color: var(--brand); }
    .cat-pill.active { background: var(--brand-softer) !important; border-color: var(--brand-soft) !important; color: var(--brand); }
    .best-card.hidden { display: none; }
  </style>

  <script is:inline>
    const pills = document.querySelectorAll('.cat-pill');
    const cards = document.querySelectorAll('.best-card');
    const empty = document.querySelector('.best-empty');
    pills.forEach(p => p.addEventListener('click', () => {
      const cat = p.getAttribute('data-cat');
      pills.forEach(x => x.classList.toggle('active', x === p));
      let visible = 0;
      cards.forEach(c => {
        const show = cat === 'All' || c.getAttribute('data-cat') === cat;
        c.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
    }));
    // Activate first pill by default
    if (pills[0]) pills[0].classList.add('active');
  </script>
</BaseLayout>
