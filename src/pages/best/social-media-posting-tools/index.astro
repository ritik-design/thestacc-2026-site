            <a href="https://later.com" target="_blank" rel="noopener" class="tool-cta-btn">View pricing →</a>
          </div>
        </div>

        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">05</div>
            <div class="tool-card-info">
              <div class="tool-card-name">Publer</div>
              <div class="tool-card-tag">Best budget posting tool</div>
            </div>
            <div class="tool-card-price">
              <div class="price">$12<span style="font-size: 14px; color: var(--text-3);">/mo</span></div>
