          <div class="stat-cell"><div class="stat-num">4</div><div class="stat-lbl">SEO Jobs Covered</div><div class="stat-delta">Content · technical · local · monitoring</div></div>
          <div class="stat-cell"><div class="stat-num">4</div><div class="stat-lbl">Scoring Criteria</div><div class="stat-delta">Autonomy · output · safety · price</div></div>
        </div>

