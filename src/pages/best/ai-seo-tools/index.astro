        <div class="stat-grid">
          <div class="stat-cell">
            <div class="stat-num">12</div>
            <div class="stat-lbl">Tools tested</div>
            <div class="stat-delta">Paid plans</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">90</div>
            <div class="stat-lbl">Day window</div>
            <div class="stat-delta">Mar–May 2026</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">60</div>
            <div class="stat-lbl">Articles produced</div>
            <div class="stat-delta">5 per tool</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">$7.3K</div>
            <div class="stat-lbl">Total spend</div>
            <div class="stat-delta">Across all tools</div>
          </div>
        </div>

        <div class="inline-cta dark">
          <div class="cta-copy">
