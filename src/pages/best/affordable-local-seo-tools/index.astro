              <ul class="no-list">
                <li>Keyword-focused — no GBP, no citations, no reviews</li>
                <li>Daily limits on the entry tier feel tight at scale</li>
              </ul>
            </div>
          </div>
          <div class="tool-card-foot">
            <div class="tool-best-for"><strong>Best for:</strong> Beginners who want clean keyword research at a low price.</div>
            <a href="https://mangools.com/" class="tool-cta-btn" rel="noopener" target="_blank">Visit Mangools →</a>
          </div>
        </div>

        <!-- #8 Ubersuggest -->
        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">08</div>
            <div class="tool-card-info">
              <div class="tool-card-name">Ubersuggest</div>
              <div class="tool-card-tag">Best budget SEO overview tool</div>
            </div>
            <div class="tool-card-price">
              <div class="price">$12<span style="font-size: 14px; color: var(--text-3);">/mo</span></div>
              <div class="per">Individual plan</div>
            </div>
          </div>
          <div class="tool-card-body">
            <div>
              <h5>What it does better</h5>
              <ul class="yes-list">
                <li>Lifetime deal at $120 one-time is the cheapest paid SEO tool</li>
