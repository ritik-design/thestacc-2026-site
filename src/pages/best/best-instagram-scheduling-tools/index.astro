            <div class="stat-num">480</div>
            <div class="stat-lbl">Posts shipped</div>
            <div class="stat-delta">12/mo × 4 × 10 tools</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">$2.9K</div>
            <div class="stat-lbl">Total spend</div>
            <div class="stat-delta">Across all plans</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">4</div>
