          <div class="tool-card-head">
            <div class="tool-rank">01</div>
            <div class="tool-card-info">
              <div class="tool-card-name">theStacc <span class="winner-badge">Editor's Pick</span></div>
              <div class="tool-card-tag">For Startups That Want Zero Effort</div>
            </div>
            <div class="tool-card-price"><span class="price">$99/mo</span><span class="per">Content SEO plan</span></div>
          </div>
          <div class="tool-card-body">
            <div>
              <h5>What it does well</h5>
