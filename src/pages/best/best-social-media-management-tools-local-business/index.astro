          </div>
          <div class="tool-card-foot">
            <div class="tool-best-for"><strong>Best for:</strong> Small teams that need a clean approval pipeline.</div>
            <a href="https://loomly.com" target="_blank" rel="noopener" class="tool-cta-btn">View pricing →</a>
          </div>
        </div>

        <!-- Card 7 -->
        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">07</div>
            <div class="tool-card-info">
              <div class="tool-card-name">SocialBee</div>
              <div class="tool-card-tag">Evergreen content recycling</div>
            </div>
            <div class="tool-card-price">
              <div class="price">$29<span style="font-size: 14px; color: var(--text-3);">/mo</span></div>
