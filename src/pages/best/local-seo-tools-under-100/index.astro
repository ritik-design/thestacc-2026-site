      <div class="stat-cell"><div class="stat-num">$108<span class="accent">/mo</span></div><div class="stat-label">Best three-tool stack · content + tracking + listings</div></div>
      <div class="stat-cell"><div class="stat-num">30<span class="accent">/mo</span></div><div class="stat-label">Articles published by winner · zero writing required</div></div>
    </div>
  </section>

