            <a href="https://lowfruits.io/" class="tool-cta-btn" rel="noopener" target="_blank">Visit LowFruits →</a>
          </div>
        </div>

        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">08</div>
            <div class="tool-card-info">
              <div class="tool-card-name">RankMath</div>
              <div class="tool-card-tag">Best free on-page SEO plugin</div>
            </div>
