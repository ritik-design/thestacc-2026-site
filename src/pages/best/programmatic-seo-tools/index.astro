            <a href="https://whalesync.com" target="_blank" rel="noopener" class="tool-cta-btn">View pricing →</a>
          </div>
        </div>

        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">04</div>
            <div class="tool-card-info">
