              </ul>
            </div>
          </div>
          <div class="tool-card-foot">
            <div class="tool-best-for"><strong>Best for:</strong> Webflow-native teams running pSEO directly on the platform.</div>
            <a href="https://typemat.com" target="_blank" rel="noopener" class="tool-cta-btn">View pricing →</a>
          </div>
        </div>

        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">07</div>
            <div class="tool-card-info">
              <div class="tool-card-name">SEOmatic</div>
              <div class="tool-card-tag">Best data-driven page generator</div>
            </div>
            <div class="tool-card-price">
              <div class="price">$49<span style="font-size: 14px; color: var(--text-3);">/mo</span></div>
              <div class="per">Starter plan</div>
            </div>
          </div>
          <div class="tool-card-body">
            <div>
              <h5>What it delivers</h5>
