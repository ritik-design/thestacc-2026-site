        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">08</div>
            <div class="tool-card-info">
              <div class="tool-card-name">Bardeen</div>
              <div class="tool-card-tag">Best no-code SEO workflow</div>
            </div>
