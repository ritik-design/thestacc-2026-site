---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: '10 Best Marketing Tools for Local Businesses in 2026 (Tested & Ranked)',
  description: 'We tested 10 marketing tools for local businesses — blog automation, GBP management, email marketing, review management, and listing sync. Winner: theStacc from $49/mo.',
  canonical: 'https://thestacc.com/best/marketing-tools-local-businesses/',
  ogImage: '/og/best-marketing-tools-local-businesses.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Best", "item": "https://thestacc.com/best/" },
        { "@type": "ListItem", "position": 3, "name": "Best Marketing Tools for Local Businesses", "item": "https://thestacc.com/best/marketing-tools-local-businesses/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "10 Best Marketing Tools for Local Businesses in 2026",
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "numberOfItems": 10,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "theStacc", "url": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "BrightLocal" },
        { "@type": "ListItem", "position": 3, "name": "Mailchimp" },
        { "@type": "ListItem", "position": 4, "name": "Google Business Profile" },
        { "@type": "ListItem", "position": 5, "name": "Yext" },
        { "@type": "ListItem", "position": 6, "name": "Birdeye" },
        { "@type": "ListItem", "position": 7, "name": "Canva" },
        { "@type": "ListItem", "position": 8, "name": "SE Ranking" },
        { "@type": "ListItem", "position": 9, "name": "Podium" },
        { "@type": "ListItem", "position": 10, "name": "Moz Local" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the best marketing tool for a single-location local business?",
          "acceptedAnswer": { "@type": "Answer", "text": "For single-location businesses, theStacc Blog + Local bundle (~$126/mo) covers website content and GBP activity. Add Mailchimp (free) for email retention and BrightLocal ($39/mo) for rank tracking. Start with Google Business Profile (free) if you haven't claimed your listing yet." }
        },
        {
          "@type": "Question",
          "name": "Do local businesses really need blog content?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Local businesses publishing blog content rank for 3-5x more keywords than businesses with homepage and services pages only. Blog posts targeting 'best [service] in [city],' how-to guides, and local comparisons build topical authority and drive organic traffic beyond GBP alone." }
        },
        {
          "@type": "Question",
          "name": "How much should a local business spend on marketing tools per month?",
          "acceptedAnswer": { "@type": "Answer", "text": "A reasonable budget is $100-200/month, covering automated content creation (theStacc at $99-167/mo) or a tracking suite (BrightLocal at $39-59/mo) plus email marketing (Mailchimp free tier). Don't spend over $300/month on tools until you've maximized GBP and established consistent content publishing." }
        },
        {
          "@type": "Question",
          "name": "Are free marketing tools enough for local businesses?",
          "acceptedAnswer": { "@type": "Answer", "text": "Google Business Profile (free), Mailchimp free tier, and Canva free tier provide a starting point. However, free tools don't create blog content at scale, track Maps rankings, or manage reviews. Most local businesses see ROI spending $100-200/month on 1-2 paid tools addressing specific gaps." }
        },
        {
          "@type": "Question",
          "name": "How long does it take for local marketing to show results?",
          "acceptedAnswer": { "@type": "Answer", "text": "GBP optimizations show local pack improvements within 2-4 weeks. Blog content takes 60-90 days to rank with 3-6 months generating consistent traffic. Email campaigns produce immediate repeat customer results. Review accumulation is ongoing — each review slightly improves rankings with compounding impact over months." }
        },
        {
          "@type": "Question",
          "name": "What is more important: SEO or social media for local businesses?",
          "acceptedAnswer": { "@type": "Answer", "text": "SEO drives customers actively searching for your service now. Social media builds brand awareness over time. For most local businesses, SEO produces higher-intent traffic. A customer searching 'emergency plumber [city]' is ready to buy. Start with SEO, add social once search presence is established." }
        },
        {
          "@type": "Question",
          "name": "Can a local business do marketing without hiring an agency?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. A business owner spending $167/month can automate content creation with theStacc, get email marketing from Mailchimp (free), create visuals with Canva (free), and maintain an active GBP without an agency. Agencies charge $2,000-5,000/month for services these tools replicate at a fraction of the cost." }
        },
        {
          "@type": "Question",
          "name": "What is the best marketing tool for local businesses on a tight budget?",
          "acceptedAnswer": { "@type": "Answer", "text": "Start with Google Business Profile (free) and Mailchimp (free). Add theStacc Local SEO at $49/month for 30 GBP posts. That's $49/month for active Google presence and email marketing. When budget allows, upgrade to Blog + Local bundle at ~$126/month for full content automation." }
        }
      ]
    }
  ]
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <a href="/best/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Best of 2026 · Updated this quarter</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">10 Best <span class="accent">Marketing Tools for Local Businesses</span> in 2026 (Tested &amp; Ranked)</h1>
    <p class="hero-sub">The best marketing tools for local businesses solve one problem: getting found by customers in your area. In practice, that means managing a Google Business Profile, publishing blog content that ranks for "[service] near me" keywords, sending emails, collecting reviews, and keeping directory listings accurate — all while running the actual business. We tested 10 tools that cover each of those jobs.</p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Try the #1 pick — $1 trial <span class="arrow">→</span></span></a>
      <a href="#ranked-list" class="btn btn-secondary">See the full ranking</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span><strong>10 tools</strong> tested across local business verticals</span>
      </div>
      <div class="hero-meta-item">
        <span><strong>70+ industries</strong> · dentists, HVAC, restaurants, law firms</span>
      </div>
      <div class="hero-meta-item">
        <span>Pricing verified <strong>March 2026</strong></span>
      </div>
    </div>
  </section>

  <!-- QUICK VERDICT BENTO -->
  <section class="modules-bento">
    <div class="modules-tabs-header">
      <span class="label-pill">Quick verdict · 4 picks</span>
      <h2 class="h-lg">If you only read one section, <span class="accent">read this one.</span></h2>
      <p class="lede">Four picks for four buyers. The full ranked list and comparison table are below — but if you're short on time, start here.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/checkout/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3 class="bento-title">Overall winner: theStacc</h3>
        <h4 class="bento-sub">The best <span class="accent">all-in-one local marketing automation</span> platform — blog, GBP posts, and social from $49/mo.</h4>
        <p class="bento-desc">Automates blog publishing (30 articles/month), Google Business Profile posts (30/month), and social media content across three platforms. Topics researched by industry and service area. Content scores 92% average on SEO audits. You connect your site, pick a brand voice, and theStacc takes over.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>30 articles + 30 GBP posts + 30 social posts per month</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>92% average SEO score across all published content</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Works across WordPress, Webflow, Ghost, and custom sites</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>$1 trial · No contract · Cancel anytime</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">THESTACC · #1 OVERALL · FROM $49/MO</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">90 pieces of content monthly at ~$1.86 per piece</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">$49-167/mo</span>
            <span class="bento-mock-tag">30 articles</span>
            <span class="bento-mock-tag brand">Zero manual work</span>
          </div>
        </div>
        <div class="bento-cta">Start the $1 trial <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="#tool-2">
        <div class="bento-num">02</div>
        <h3 class="bento-title">Best rank tracking: BrightLocal</h3>
        <h4 class="bento-sub">For local businesses that need <span class="accent">geo-grid Maps rankings</span> and citation audits from $39/mo.</h4>
        <p class="bento-desc">Geo-grid rank tracker shows block-by-block Maps positioning. Citation audit across 80+ directories for NAP consistency. Review monitoring from Google, Yelp, and Facebook.</p>
        <div class="bento-cta">See full review <span class="arrow">↓</span></div>
      </a>

      <a class="bento-card" href="#tool-6">
        <div class="bento-num">06</div>
        <h3 class="bento-title">Best review platform: Birdeye</h3>
        <h4 class="bento-sub">For businesses managing reviews across <span class="accent">150+ platforms</span> with automated request campaigns.</h4>
        <p class="bento-desc">Aggregates reviews from 150+ platforms, sends automated review requests that increase volume 3-5x, and provides sentiment analysis by topic.</p>
        <div class="bento-cta">See full review <span class="arrow">↓</span></div>
      </a>
    </div>
  </section>

  <!-- METHODOLOGY -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">How we tested</span>
      <h2 class="h-lg">We publish <span class="accent">3,500+ articles per month</span> across 70+ industries. Here's what we found.</h2>
      <p>The local businesses that grow fastest aren't the ones using the fanciest tools. They're the ones producing content consistently. We measured each tool against five criteria that actually move local rankings.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">What we measured</span>
          <h3 class="ba-title">5 criteria. No exceptions.</h3>
          <p class="ba-sub">Same scorecard across all 10 tools.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Local search visibility</h4>
              <p>Does it help rank in the local 3-pack and Maps? 46% of Google searches have local intent.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>Content creation</h4>
              <p>Blog posts, GBP posts, social content, or email? Fresh content signals activity and drives long-tail traffic.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Customer communication</h4>
              <p>Email, SMS, or review response capability? Repeat customers spend 67% more — communication retains them.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>Ease of use</h4>
              <p>Can non-marketing business owners use it? Most local businesses have zero marketing staff.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>Price-to-value ratio</h4>
              <p>Value per dollar for a single-location business. Local businesses operate on tight margins.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">What we found</span>
          <h3 class="ba-title">No single tool does everything. But one comes closest.</h3>
          <p class="ba-sub">Three patterns repeated across the field.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Most tools are single-channel</h4>
              <p>BrightLocal tracks rankings. Mailchimp sends emails. Birdeye manages reviews. Only theStacc covers blog, GBP, and social in one subscription.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>Content is the gap no one fills cheaply</h4>
              <p>Agencies charge $2,000-5,000/month for blog content. theStacc delivers 30 articles/month for $99. The gap is real.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Free tools get you started, not ranked</h4>
              <p>GBP, Mailchimp, and Canva are all free — and useful. But none of them publish content at the volume needed to build topical authority.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>The $49-167/mo stack beats agencies</h4>
              <p>theStacc + BrightLocal + Mailchimp = ~$185/mo. That's 30 articles + geo-grid tracking + email retention. An agency charges 10-30x that.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">10<span class="accent"></span></div><div class="stat-label">Tools tested · March 2026</div></div>
      <div class="stat-cell"><div class="stat-num">70<span class="accent">+</span></div><div class="stat-label">Industries · dental, HVAC, law, restaurants</div></div>
      <div class="stat-cell"><div class="stat-num">$40<span class="accent">k+</span></div><div class="stat-label">Avg saved/year vs. agency approach</div></div>
      <div class="stat-cell"><div class="stat-num">$49<span class="accent">/mo</span></div><div class="stat-label">Winner starting price</div></div>
    </div>
  </section>

  <!-- RANKED LIST -->
  <section class="problem-section" id="ranked-list">
    <div class="problem-header">
      <span class="label-pill">The full ranked list</span>
      <h2 class="h-lg">10 local marketing tools, <span class="accent">ranked by output, coverage, and price.</span></h2>
      <p>Each entry: rank, name, price, who it fits, one-paragraph verdict, three pros, one honest con. No hedging.</p>
    </div>

    <!-- #1 theStacc -->
    <div class="ba-grid" id="tool-1">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#1 · WINNER · FROM $49/MO</span>
          <h3 class="ba-title">theStacc — Best all-in-one local marketing automation</h3>
          <p class="ba-sub">For every local business that wants blog content, GBP posts, and social media on autopilot without hiring an agency or a freelancer.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">theStacc produces 90 pieces of content monthly — 30 blog articles, 30 Google Business Profile posts, and 30 social posts across Instagram, LinkedIn, X, and Facebook — at roughly $1.86 per piece. Topics are researched based on your industry, service area, and local keyword gaps. Content scores 92% on average across SEO audits. You connect your site, pick a brand voice, and the platform handles the rest. $1 trial available, no contract.</p>
        <ul class="ba-list">
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>Breadth: blog + GBP + social in one subscription</h4>
              <p>No other tool at this price point covers all three channels. Most tools specialize in one. theStacc covers all of them automatically.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>Output: 30 articles/month at 92% average SEO score</h4>
              <p>We've published 3,500+ articles monthly across 70+ industries using the same system. The content is optimized on-page, not just keyword-stuffed.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>Price: $49 Local / $99 Blog / ~$167 full stack — no setup fees</h4>
              <p>Bundle any two modules for a 15% discount. Cancel anytime. Content stays on your site forever.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✗</span>
            <div>
              <h4>Honest con: no review management or directory sync</h4>
              <p>theStacc doesn't manage reviews or sync listings across directories. You'll need BrightLocal or Birdeye alongside it for those functions.</p>
            </div>
          </li>
        </ul>
        <div style="margin-top: 24px;">
          <a href="/checkout/" class="btn btn-primary"><span>Start the $1 trial <span class="arrow">→</span></span></a>
          <a href="/modules/content-seo/" class="btn btn-secondary" style="margin-left: 12px;">See Content SEO module</a>
        </div>
      </div>
    </div>

    <!-- #2 BrightLocal -->
    <div class="ba-grid" id="tool-2" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#2 · $39-59/MO · 14-DAY TRIAL</span>
          <h3 class="ba-title">BrightLocal — Best local SEO tracking and auditing</h3>
          <p class="ba-sub">For local businesses that need to see exactly where they rank in Maps, block by block.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">BrightLocal is the standard for local SEO measurement. The geo-grid rank tracker shows your Maps position at every block in your service area — not just your city average. Citation audits catch NAP inconsistencies across 80+ directories. Review monitoring pulls Google, Yelp, Facebook, and TripAdvisor into one dashboard. It doesn't create content, but it tells you exactly what's working.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Geo-grid rank tracker shows block-by-block Maps positioning</h4><p>The most useful local ranking visualization in the market. See exactly where you dominate and where you're invisible.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Citation audit across 80+ directories for NAP consistency</h4><p>Inconsistent name, address, and phone data is a quiet ranking killer. BrightLocal surfaces every mismatch.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Review monitoring from major platforms in one dashboard</h4><p>Google, Yelp, Facebook, and more. White-label reporting for agencies included.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: no content creation</h4><p>BrightLocal tells you what to fix but doesn't publish anything. You'll still need theStacc or a content tool alongside it.</p></div></li>
        </ul>
      </div>
    </div>

    <!-- #3 Mailchimp -->
    <div class="ba-grid" id="tool-3" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#3 · FREE-$350/MO · FREE PLAN AVAILABLE</span>
          <h3 class="ba-title">Mailchimp — Best email marketing for local businesses</h3>
          <p class="ba-sub">For local businesses that want to reach existing customers with promotions, newsletters, and automated sequences.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Mailchimp's free plan covers up to 500 contacts with 1,000 emails per month — enough to run a solid local retention program without spending a dollar. The drag-and-drop builder needs no coding. Automation workflows handle welcome sequences, birthday offers, and re-engagement campaigns. It doesn't touch SEO or GBP, but for keeping existing customers coming back, there's no cheaper starting point.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Free plan supports 500 contacts with 1,000 emails monthly</h4><p>Most local businesses fit comfortably on the free tier for years. The paid plans ($13-20/mo) unlock automations and remove Mailchimp branding.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Automation workflows for welcome, birthday, and re-engagement</h4><p>Set up once. Runs forever. Bring back lapsed customers without lifting a finger.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Audience segmentation by purchase history, location, and engagement</h4><p>Send the right message to the right customer. A/B testing available on paid plans.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: email-only with no SEO, GBP, or directory features</h4><p>Mailchimp nurtures customers you already have. It won't find new ones searching Google.</p></div></li>
        </ul>
      </div>
    </div>

    <!-- #4 Google Business Profile -->
    <div class="ba-grid" id="tool-4" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#4 · FREE · ALL FEATURES INCLUDED</span>
          <h3 class="ba-title">Google Business Profile — Best free local marketing foundation</h3>
          <p class="ba-sub">The starting point for every local business before any paid tool. If it's not claimed and complete, nothing else works properly.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Google Business Profile is the most important free marketing tool a local business can use. Businesses with 100+ photos get 520% more calls according to Google's own data. The Posts feature keeps your profile active daily. Q&A pre-answers common questions. Review responses build trust. The catch: everything is manual. No scheduling, no automation, no bulk updates. That's why tools like theStacc exist — to automate the 30 GBP posts per month that would otherwise take hours.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Completely free — no paid tiers, no feature limits</h4><p>Direct control over your search result appearance in Google Maps and local search. You have no excuse not to claim it.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Photos, posts, Q&amp;A, review responses, booking links, and more</h4><p>A fully optimized GBP regularly outranks competitors with better websites. It's the highest-ROI free task in local marketing.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Messaging, product catalogs, and service menus</h4><p>Customers can contact you directly through search results. Reduces friction from search to inquiry.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: entirely manual with no automation</h4><p>Google can edit your profile without notification. User-submitted edits can change your data. Combine with a GBP automation tool to stay on top of it.</p></div></li>
        </ul>
      </div>
    </div>

    <!-- #5 Yext -->
    <div class="ba-grid" id="tool-5" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#5 · $499/YR ($42/MO) · 30-DAY GUARANTEE</span>
          <h3 class="ba-title">Yext — Best directory and listing management</h3>
          <p class="ba-sub">For businesses with complex hours, multiple locations, or directory data that's been a mess for years.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Yext's Knowledge Graph creates a single source of truth for your business data and syncs it to 200+ partner directories automatically. Holiday hours, special event schedules, seasonal changes — update once, Yext pushes everywhere. It also suppresses duplicate listings from previous owners or scrapers that quietly hurt local rankings. The biggest catch: if you cancel, listings can revert.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Updates across 200+ partner directories from one entry</h4><p>The broadest directory coverage in the category. Apple Maps, Google, Facebook, Bing, Yelp, and 195+ more.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Suppresses duplicate listings from previous owners or scrapers</h4><p>Duplicate listings split ranking signals and confuse customers. Yext finds and removes them.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Handles regular, holiday, and special event hours automatically</h4><p>No more manually updating 20 directories every time you close for a holiday.</p></div></li>
