---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: '10 Best AI Writing Tools for Small Business in 2026 (Tested & Ranked)',
  description: 'We tested 10 AI writing tools for small business — blog posts, emails, social media, ad copy. Ranked by versatility, output quality, and real pricing. Winner: theStacc, from $49/mo.',
  canonical: 'https://thestacc.com/best/ai-writing-tools-small-business/',
  ogImage: '/og/best-ai-writing-tools-small-business.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Best", "item": "https://thestacc.com/best/" },
        { "@type": "ListItem", "position": 3, "name": "Best AI Writing Tools for Small Business", "item": "https://thestacc.com/best/ai-writing-tools-small-business/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "10 Best AI Writing Tools for Small Business in 2026",
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "numberOfItems": 10,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "theStacc", "url": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Jasper" },
        { "@type": "ListItem", "position": 3, "name": "Copy.ai" },
        { "@type": "ListItem", "position": 4, "name": "Writesonic" },
        { "@type": "ListItem", "position": 5, "name": "Koala.sh" },
        { "@type": "ListItem", "position": 6, "name": "Frase" },
        { "@type": "ListItem", "position": 7, "name": "Rytr" },
        { "@type": "ListItem", "position": 8, "name": "ChatGPT Plus" },
        { "@type": "ListItem", "position": 9, "name": "Surfer SEO" },
        { "@type": "ListItem", "position": 10, "name": "Canva Magic Write" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the best AI writing tool for small business in 2026?",
          "acceptedAnswer": { "@type": "Answer", "text": "theStacc ranks as the top all-in-one solution — automatically publishing blog articles, social posts, and Google Business Profile content from $49/month. For multi-format writing tools you operate yourself, Jasper ($49/month) provides the broadest template coverage with brand voice training. Budget-conscious businesses should look at Writesonic ($19/month) for maximum format coverage per dollar." }
        },
        {
          "@type": "Question",
          "name": "Can AI writing tools replace a content team?",
          "acceptedAnswer": { "@type": "Answer", "text": "Depending on the tool, yes. theStacc functionally replaces blog writers, social media managers, and local SEO specialists through automated publishing across three channels. DIY tools like Jasper and Copy.ai reduce team requirements but still demand human involvement in editing, formatting, and publishing." }
        },
        {
          "@type": "Question",
          "name": "Are AI writing tools worth it for a small business?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Freelance writers charge $80–$250 per article; social media managers cost $500–$2,000 monthly. AI writing tools range $0–$167/month. Even accounting for editing time, the cost savings reach 70–90% compared to hiring people for the same output." }
        },
        {
          "@type": "Question",
          "name": "Do AI-written blog posts rank on Google?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes, when properly optimized. Google accepts AI-generated content that provides genuine value. Tools like theStacc, Surfer, Koala, and Frase build SEO optimization into the generation process. Tools like ChatGPT leave optimization to the user. The tool you choose matters less than how well the output is optimized." }
        },
        {
          "@type": "Question",
          "name": "How many pieces of content should a small business publish per month?",
          "acceptedAnswer": { "@type": "Answer", "text": "Research shows businesses publishing 16+ monthly blog posts receive 3.5x the traffic of those publishing 0–4 pieces. Combining consistent social media (3–5 weekly posts) and weekly Google Business Profile updates compounds the results. Most small businesses fall short due to time constraints — which is the exact problem AI writing tools solve." }
        },
        {
          "@type": "Question",
          "name": "What's the difference between an AI writing tool and an AI content service?",
          "acceptedAnswer": { "@type": "Answer", "text": "Writing tools generate text that you edit, format, and publish yourself. Content services like theStacc manage the entire workflow — writing, optimization, formatting, publishing — automatically. Most tools on this list are writing tools; theStacc is a writing service. The distinction matters a lot when it comes to how much time you actually spend." }
        },
        {
          "@type": "Question",
          "name": "Can I use ChatGPT as my only writing tool?",
          "acceptedAnswer": { "@type": "Answer", "text": "Technically yes, but it's labor-intensive. ChatGPT lacks SEO optimization, auto-publishing, format-specific templates, and content calendars. It requires you to decide on topics, structure, publishing location, and timing. Experienced writers find it powerful; most business owners find purpose-built tools save substantially more time." }
        }
      ]
    }
  ]
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <a href="/best/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Best of 2026 · Updated this quarter</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">10 Best <span class="accent">AI Writing Tools for Small Business</span> in 2026 (Tested &amp; Ranked)</h1>
    <p class="hero-sub">Small businesses don't have content teams. Owners write the blogs, draft the emails, manage social media, and update Google Business profiles themselves — while competing against companies with bigger budgets. We tested 10 AI writing tools to find which ones let one person do what used to require a full team.</p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Try the #1 pick — $1 trial <span class="arrow">→</span></span></a>
      <a href="#ranked-list" class="btn btn-secondary">See the full ranking</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span><strong>10 tools</strong> tested over 8 weeks</span>
      </div>
      <div class="hero-meta-item">
        <span><strong>5 formats</strong> · blog, email, social, ads, GBP</span>
      </div>
      <div class="hero-meta-item">
        <span>Last updated <strong>Q1 2026</strong></span>
      </div>
    </div>
  </section>

  <!-- QUICK VERDICT -->
  <section class="modules-bento">
    <div class="modules-tabs-header">
      <span class="label-pill">Quick verdict · 3 picks</span>
      <h2 class="h-lg">If you only read one section, <span class="accent">read this one.</span></h2>
      <p class="lede">Three picks for three buyer types. Full list and comparison table below.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/checkout/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3 class="bento-title">Overall winner: theStacc</h3>
        <h4 class="bento-sub">Best <span class="accent">AI writing tool for small business owners</span> who want content published without doing it themselves.</h4>
        <p class="bento-desc">theStacc automates blog articles, Google Business Profile posts, and social media across three channels simultaneously. You set it up once. Content publishes every month without you. First article live in 24 hours. From $49/month.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Blog, GBP, and social — all three channels automated</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>SEO optimization built into every piece of content</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Auto-publishes to WordPress, Webflow, Ghost</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>$1 trial · No contract · Cancel anytime</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">THESTACC · #1 OVERALL · FROM $49/MO</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">Blog + GBP + Social · published automatically every month</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">From $49/mo</span>
            <span class="bento-mock-tag">3 channels</span>
            <span class="bento-mock-tag brand">24h to first article</span>
          </div>
        </div>
        <div class="bento-cta">Start the $1 trial <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="#tool-2">
        <div class="bento-num">02</div>
        <h3 class="bento-title">Best brand tool: Jasper</h3>
        <h4 class="bento-sub">For businesses that need <span class="accent">brand-consistent copy</span> across blog, email, and ads.</h4>
        <p class="bento-desc">Brand voice training, 50+ templates, campaign generation. Best pick for businesses producing multi-format content and managing a distinct brand tone.</p>
        <div class="bento-cta">See full review <span class="arrow">↓</span></div>
      </a>

      <a class="bento-card" href="#tool-4">
        <div class="bento-num">04</div>
        <h3 class="bento-title">Best budget pick: Writesonic</h3>
        <h4 class="bento-sub">For small businesses needing <span class="accent">multi-format coverage at $19/mo</span>.</h4>
        <p class="bento-desc">Blog, ads, email, social, and product descriptions from one subscription. SERP analysis included. Cheapest multi-format option that actually delivers.</p>
        <div class="bento-cta">See full review <span class="arrow">↓</span></div>
      </a>
    </div>
  </section>

  <!-- HOW WE TESTED -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">How we tested</span>
      <h2 class="h-lg">We tested <span class="accent">10 tools over 8 weeks</span> on the same topics across all formats.</h2>
      <p>No marketing demos. No vendor briefings. We subscribed to every tool, generated identical content on the same topics, and scored each output on five criteria specific to small business needs.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">What we measured</span>
          <h3 class="ba-title">5 criteria. Small-business specific.</h3>
          <p class="ba-sub">Same scorecard across all 10 tools.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Content Versatility</h4>
              <p>How many writing formats does each tool handle effectively — blog, email, social, ads, product descriptions?</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>Output Quality</h4>
              <p>Could the content publish without substantial rewriting? We evaluated grammar, tone, depth, and accuracy.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Ease of Use</h4>
              <p>Could a non-marketing professional operate the tool within 15 minutes without a tutorial?</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>Pricing Transparency</h4>
              <p>Are actual dollar amounts clear? We checked for credit caps, per-word fees, and "unlimited" claims that aren't.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>Time Saved</h4>
              <p>Minutes genuinely removed from weekly content workflows — not estimated, measured.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">What we found</span>
          <h3 class="ba-title">Hidden time costs eat most of the savings.</h3>
          <p class="ba-sub">The finding that changed our rankings.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Publishing is the step nobody accounts for</h4>
              <p>Topic selection through publishing a single piece takes 60–110 minutes. At 30 pieces per month, that's 30–55 hours of hidden labor.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>At $30/hour, hidden costs exceed most subscriptions</h4>
              <p>Tools that generate but don't publish cost $900–$1,650/month in hidden labor at realistic volume. That's more than agency pricing.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Most tools require more skill than advertised</h4>
              <p>ChatGPT and Copy.ai need strong prompting skills to produce usable output. Small business owners without marketing backgrounds hit this wall fast.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>theStacc was the only tool that eliminated the hidden costs</h4>
              <p>Full automation across research, writing, optimization, and publishing. Zero hours required per month at any volume.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">10<span class="accent"></span></div><div class="stat-label">Tools tested · 8 weeks each</div></div>
      <div class="stat-cell"><div class="stat-num">3<span class="accent">×</span></div><div class="stat-label">Channels automated · blog, GBP, social</div></div>
      <div class="stat-cell"><div class="stat-num">70<span class="accent">%</span></div><div class="stat-label">Avg cost savings vs freelancers</div></div>
      <div class="stat-cell"><div class="stat-num">24<span class="accent">h</span></div><div class="stat-label">Time to first published article</div></div>
    </div>
  </section>

  <!-- RANKED LIST -->
  <section class="problem-section" id="ranked-list">
    <div class="problem-header">
      <span class="label-pill">The full ranked list</span>
      <h2 class="h-lg">10 AI writing tools for small business, <span class="accent">ranked by who they actually fit.</span></h2>
      <p>Each entry: rank, best use case, price, pros, one honest con.</p>
    </div>

    <!-- #1 theStacc -->
    <div class="ba-grid" id="tool-1">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#1 · WINNER · FROM $49/MO</span>
          <h3 class="ba-title">theStacc — Best AI writing tool for small business owners in 2026</h3>
          <p class="ba-sub">For small businesses that want content across blog, Google Business Profile, and social media — published automatically without anyone on staff doing it.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">theStacc is the only tool on this list that publishes content automatically across three channels. Blog articles go live on your site. Google Business Profile gets weekly posts. Social media updates go out across Instagram, LinkedIn, X, and Facebook. You set up the brand voice once. theStacc handles everything after that. At $49/month for Local or Social, or $99/month for Blog, it replaces the work of a blog writer, social media manager, and local SEO specialist — for less than a single month's freelancer invoice.</p>
        <ul class="ba-list">
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>Covers three critical organic growth channels simultaneously</h4>
              <p>Blog, Google Business Profile, and social media — all automated from one platform. No other tool on this list covers all three channels with real automation.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>Blog output quality stands above every tool we tested</h4>
              <p>SEO optimization is built in, not bolted on. Articles publish with proper heading structure, keyword coverage, meta descriptions, and internal links already in place.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✓</span>
            <div>
              <h4>Content publishes automatically — zero hours from you</h4>
              <p>The only tool that removes the publishing step entirely. Most tools generate drafts you still have to format, upload, and schedule. theStacc does that too.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">✗</span>
            <div>
              <h4>Honest con: limited to blog, social, and GBP — no email or ad copy</h4>
              <p>If you need email campaigns or ad copy generation, theStacc doesn't cover those formats. You'd need a separate tool for email marketing.</p>
            </div>
          </li>
        </ul>
        <div style="margin-top: 24px;">
          <a href="/checkout/" class="btn btn-primary"><span>Start the $1 trial <span class="arrow">→</span></span></a>
          <a href="/modules/content-seo/" class="btn btn-secondary" style="margin-left: 12px;">See Content SEO module</a>
        </div>
      </div>
    </div>

    <!-- #2 Jasper -->
    <div class="ba-grid" id="tool-2" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#2 · $49/MO · BEST BRAND CONSISTENCY</span>
          <h3 class="ba-title">Jasper — Best AI writing tool for brand consistency across channels</h3>
          <p class="ba-sub">For small businesses with a strong brand voice that needs to stay consistent across blog, email, ads, and social media.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Jasper's Brand Voice feature trains on your existing content and maintains consistent tone across 50+ templates. Blog posts, email sequences, ad copy, social captions — all sound like they came from the same person. The Campaign feature generates multiple assets from a single brief. The limitation: no native SEO optimization and no auto-publishing. Every piece still needs manual formatting and CMS upload.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Brand Voice training learns from your existing content</h4><p>Upload your best articles or brand guidelines. Jasper maintains that voice across every template and every piece. Best brand consistency in this roundup.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>50+ templates across every format</h4><p>Blog posts, email sequences, Facebook ads, Instagram captions, product descriptions — all from one subscription.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Campaign feature generates 5+ assets from one brief</h4><p>Write a campaign brief once. Jasper generates the blog post, email, LinkedIn update, Twitter post, and ad copy simultaneously.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: no native SEO optimization and no auto-publishing</h4><p>Adding the Surfer SEO integration pushes cost to $138+/month. Every article still needs manual upload. Factor both into the real price comparison.</p></div></li>
        </ul>
      </div>
    </div>

    <!-- #3 Copy.ai -->
    <div class="ba-grid" id="tool-3" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#3 · $49/MO · BEST WORKFLOW AUTOMATION</span>
          <h3 class="ba-title">Copy.ai — Best for automated multi-step content workflows</h3>
          <p class="ba-sub">For small businesses that want to automate multi-step content processes — research, outline, draft, social post — from a single trigger.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Copy.ai's Workflow feature chains multiple AI actions together. You trigger one workflow and it researches the topic, builds an outline, writes the draft, and creates social posts — all automatically. The Infobase stores accurate company information so every output reflects your actual business. No auto-publishing to CMS, and blog post quality isn't the strongest on this list.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>Workflows automate multi-step content creation</h4><p>The most sophisticated workflow automation on this list. Chain research, briefing, drafting, and social post creation into a single triggered sequence.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Infobase stores accurate company facts</h4><p>Every output references real product details, pricing, and positioning — not hallucinated placeholders. Reduces the review burden significantly.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>90+ templates across marketing formats</h4><p>The broadest template library for short-form marketing copy. Strong for e-commerce brands or multi-channel marketing teams.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: blog post quality is weaker than purpose-built blog tools</h4><p>No auto-publishing to CMS. Workflow setup takes 30–60 minutes. Free plan removed — minimum $49/month with no trial.</p></div></li>
        </ul>
      </div>
    </div>

    <!-- #4 Writesonic -->
    <div class="ba-grid" id="tool-4" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#4 · $19/MO · BEST BUDGET MULTI-FORMAT</span>
          <h3 class="ba-title">Writesonic — Best budget AI writing tool for small business</h3>
          <p class="ba-sub">For small businesses wanting multi-format AI writing coverage at the lowest price on this list.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Writesonic's Article Writer 6.0 runs SERP analysis before generating articles, giving outputs a competitive structure that most budget tools skip. It covers blogs, ads, emails, social posts, and product descriptions from a single subscription at $19/month. Output quality requires review but the breadth-per-dollar ratio is unmatched. No auto-publishing — manual upload required.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>$19/month covers five content formats</h4><p>Blog, ads, email, social, and product descriptions from one subscription. The most format coverage per dollar of any paid tool on this list.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>SERP analysis before every article</h4><p>Competitor data informs article structure before writing starts. Most budget tools skip this step entirely.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>60-second article generation</h4><p>Fast enough to use without blocking your workflow. Chatsonic handles ad-hoc writing questions without disrupting the main editor.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: output requires review and credit system creates hidden caps</h4><p>Surface-level SEO optimization only. "Unlimited" plans have fair-use limits that can catch volume users off guard.</p></div></li>
        </ul>
      </div>
    </div>

    <!-- #5 Koala.sh -->
    <div class="ba-grid" id="tool-5" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#5 · $9/MO · BEST BLOG-FIRST</span>
          <h3 class="ba-title">Koala.sh — Best AI writing tool for blog-first small businesses</h3>
          <p class="ba-sub">For small businesses where the blog is the primary growth channel and budget is the primary constraint.</p>
        </div>
        <p style="color: var(--text-2); margin: 0 0 20px;">Koala analyzes the top Google results for your keyword before writing, building article structure around what's already ranking. Its internal linking engine has created 10M+ links across user sites — the strongest auto-linking on this list. Amazon affiliate integration makes it the obvious pick for product review sites. Starts at $9/month. Blog-only; no email, social, or GBP features.</p>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>SERP-driven structure — articles built to compete</h4><p>Analyzes top 20 results before writing. Every article has the heading structure and topic coverage that's already ranking on page 1.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Strongest auto-internal-linking in the field</h4><p>10M+ internal links created automatically across user sites. Most tools leave this step entirely to you.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Amazon affiliate integration for roundup content</h4><p>Purpose-built templates for product reviews and comparison articles. The best blog tool for affiliate or e-commerce content strategies.</p></div></li>
          <li><span class="ba-num">✗</span><div><h4>Honest con: blog-only capability, no auto-publishing pipeline</h4><p>No email, social, or GBP features. 1-click WordPress export isn't true autopublishing — formatting and review steps remain.</p></div></li>
        </ul>
      </div>
    </div>

    <!-- #6 Frase -->
    <div class="ba-grid" id="tool-6" style="margin-top: 48px;">
      <div class="ba-col before" style="grid-column: 1 / -1;">
        <div class="ba-head">
          <span class="ba-label">#6 · $15/MO · BEST SEO RESEARCH</span>
