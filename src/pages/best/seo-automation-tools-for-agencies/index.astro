            <div class="tool-rank">01</div>
            <div class="tool-card-info">
              <div class="tool-card-name">theStacc Managed Services <span class="winner-badge">★ Editor's Pick · Fulfillment</span></div>
              <div class="tool-card-tag">White-label content + local SEO under your brand</div>
            </div>
            <div class="tool-card-price">
              <div class="price">$99<span style="font-size: 14px; color: var(--text-3);">/mo</span></div>
              <div class="per">per client · cancel anytime</div>
            </div>
          </div>
          <div class="tool-card-body">
            <div>
