    <div class="cover-frame">
      <div class="cover-content">
        <div class="cover-mono">Buyer's Guide · WordPress AI Writers · 2026</div>
        <div class="cover-title">AI Blog Writers <span style="opacity:0.6">·</span> WordPress</div>
        <div class="cover-sub">10 Reviewed · Auto-publishing · Schema · Internal links · 90-day window</div>
      </div>
    </div>
  </section>

