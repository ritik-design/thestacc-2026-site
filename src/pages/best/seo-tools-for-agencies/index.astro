            <a href="https://agencyanalytics.com" target="_blank" rel="noopener" class="tool-cta-btn">View pricing →</a>
          </div>
        </div>

        <div class="tool-card">
          <div class="tool-card-head">
            <div class="tool-rank">07</div>
            <div class="tool-card-info">
              <div class="tool-card-name">Screaming Frog</div>
              <div class="tool-card-tag">Technical SEO audits at any site size</div>
            </div>
            <div class="tool-card-price">
              <div class="price">$259<span style="font-size: 14px; color: var(--text-3);">/yr</span></div>
