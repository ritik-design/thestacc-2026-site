          <div class="stat-cell">
            <div class="stat-num">10</div>
            <div class="stat-lbl">Tools tested</div>
            <div class="stat-delta">Paid plans only</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">90</div>
            <div class="stat-lbl">Day window</div>
            <div class="stat-delta">Mar–May 2026</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">24</div>
            <div class="stat-lbl">Test drafts</div>
            <div class="stat-delta">4 niches</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">$4.2K</div>
