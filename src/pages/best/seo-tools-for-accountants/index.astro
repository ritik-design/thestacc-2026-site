        { "@type": "Question", "name": "What accounting keywords should I target first?", "acceptedAnswer": { "@type": "Answer", "text": "Start with high-intent local terms: \"accountant near me\", \"CPA [your city]\", \"tax preparation [your city]\", \"bookkeeper [your city]\". Then expand to informational queries: \"small business tax deductions\", \"quarterly tax deadlines\", \"when to hire a bookkeeper\", \"year-end tax planning strategies\"." }},
