      <div class="stat-cell"><div class="stat-num">10<span class="accent"></span></div><div class="stat-label">Tools evaluated for real estate agents</div></div>
      <div class="stat-cell"><div class="stat-num">360<span class="accent">/yr</span></div><div class="stat-label">Neighborhood articles published by theStacc annually</div></div>
      <div class="stat-cell"><div class="stat-num">84<span class="accent">%</span></div><div class="stat-label">Buyers who trust reviews as much as referrals</div></div>
      <div class="stat-cell"><div class="stat-num">~$126<span class="accent">/mo</span></div><div class="stat-label">Blog + Local bundle · 60 pieces of content/month</div></div>
    </div>
  </section>

  <!-- RANKED LIST -->
  <section class="problem-section" id="ranked-list">
    <div class="problem-header">
      <span class="label-pill">The full ranked list</span>
      <h2 class="h-lg">10 SEO tools for real estate agents, <span class="accent">ranked by content output, local coverage, and ROI.</span></h2>
