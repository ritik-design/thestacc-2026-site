          <div class="stat-cell">
            <div class="stat-num">10</div>
            <div class="stat-lbl">Tools tested</div>
            <div class="stat-delta">Free → $99/mo</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">14</div>
            <div class="stat-lbl">Small businesses</div>
            <div class="stat-delta">4 industries</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">$1.9K</div>
            <div class="stat-lbl">Total spend</div>
            <div class="stat-delta">Apr–Jun 2026</div>
          </div>
          <div class="stat-cell">
            <div class="stat-num">+34%</div>
            <div class="stat-lbl">Avg rank lift</div>
            <div class="stat-delta">Map Pack over 90 days</div>
