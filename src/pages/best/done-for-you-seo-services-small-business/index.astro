---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: '8 Best Done-For-You SEO Services for Small Business 2026 | theStacc',
  description: 'Reviewed 8 done-for-you SEO services for small businesses. Pricing from $49 to $4,000/mo. Real performance data, traffic lifts, and who they actually fit.',
  canonical: 'https://thestacc.com/best/done-for-you-seo-services-small-business/',
  ogImage: '/og/best/done-for-you-seo-services-small-business.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Best", "item": "https://thestacc.com/best/" },
        { "@type": "ListItem", "position": 3, "name": "Done-For-You SEO Services", "item": "https://thestacc.com/best/done-for-you-seo-services-small-business/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "8 Best Done-For-You SEO Services for Small Business",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "theStacc" },
        { "@type": "ListItem", "position": 2, "name": "Victorious" },
        { "@type": "ListItem", "position": 3, "name": "WebFX" },
        { "@type": "ListItem", "position": 4, "name": "Searchbloom" },
        { "@type": "ListItem", "position": 5, "name": "Ignite Visibility" },
        { "@type": "ListItem", "position": 6, "name": "Straight North" },
        { "@type": "ListItem", "position": 7, "name": "BrightLocal" },
        { "@type": "ListItem", "position": 8, "name": "Loganix" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is a done-for-you SEO service?", "acceptedAnswer": { "@type": "Answer", "text": "A done-for-you SEO service handles the strategy, execution, and reporting for you — typically including keyword research, content creation, on-page optimisation, link building, and monthly reporting. Pricing ranges from $49/mo (productised) to $5,000+/mo (full-service agency)." }},
        { "@type": "Question", "name": "How much does done-for-you SEO cost for a small business?", "acceptedAnswer": { "@type": "Answer", "text": "Productised platforms like theStacc start at $49/mo. Mid-tier agencies charge $1,500–$4,000/mo. Premium agencies (Victorious, WebFX) start around $2,500/mo and go up. The sweet spot for under-$1M businesses is $49–$1,500/mo." }},
        { "@type": "Question", "name": "How long does it take done-for-you SEO to work?", "acceptedAnswer": { "@type": "Answer", "text": "Local SEO (GBP optimisation) shows results in 30–60 days. Content-driven national SEO takes 4–8 months for meaningful traffic. Anyone promising results in 30 days for competitive national keywords is lying." }},
        { "@type": "Question", "name": "What is the difference between a platform and an agency?", "acceptedAnswer": { "@type": "Answer", "text": "A platform (theStacc, BrightLocal) gives you software + automation at $49–$199/mo. An agency (Victorious, WebFX) gives you humans + strategy at $1,500–$5,000/mo. Platforms win on cost; agencies win on customisation." }},
        { "@type": "Question", "name": "Can I cancel a done-for-you SEO service?", "acceptedAnswer": { "@type": "Answer", "text": "Platforms are usually monthly with no contract. Agencies typically require 3–6 month contracts; some lock you in for 12 months. Always read the cancellation terms before signing." }}
      ]
    }
  ]
};
---
<BaseLayout seo={seo}>
  <style>
    .post-hero { padding: 56px 32px 40px; max-width: 1200px; margin: 0 auto; }
    .breadcrumb { display: flex; gap: 8px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 24px; flex-wrap: wrap; }
    .breadcrumb a { color: var(--text-3); transition: color 0.15s; }
    .breadcrumb a:hover { color: var(--brand); }
    .breadcrumb .sep { color: var(--border-strong); }
    .breadcrumb .current { color: var(--text-1); font-weight: 600; }
    .post-cat { display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; background: var(--brand-softer); border: 1px solid var(--brand-soft); border-radius: 100px; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); font-weight: 600; margin-bottom: 24px; }
    .post-cat::before { content: ''; width: 6px; height: 6px; background: var(--brand); border-radius: 50%; }
    .post-hero h1 { font-size: clamp(36px, 4.8vw, 58px); font-weight: 700; line-height: 1.05; letter-spacing: -0.035em; color: var(--text-1); margin-bottom: 24px; max-width: 22ch; }
    .post-hero .description { font-size: 19px; line-height: 1.55; color: var(--text-2); max-width: 60ch; margin-bottom: 32px; }
    .post-hero .description strong { color: var(--text-1); font-weight: 600; }
    .post-meta { display: flex; align-items: center; gap: 20px; padding: 20px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); flex-wrap: wrap; }
    .meta-author { display: flex; align-items: center; gap: 12px; }
    .meta-avatar { width: 40px; height: 40px; background: linear-gradient(135deg, var(--brand), var(--brand-deep)); color: white; display: grid; place-items: center; font-weight: 700; font-size: 15px; border-radius: 50% !important; }
    .meta-author-info { display: flex; flex-direction: column; gap: 2px; }
    .meta-author-name { font-size: 14px; font-weight: 600; color: var(--text-1); }
    .meta-author-role { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); }
    .meta-divider { width: 1px; height: 32px; background: var(--border); }
    .meta-item { display: flex; flex-direction: column; gap: 2px; }
    .meta-label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); }
    .meta-value { font-size: 14px; font-weight: 600; color: var(--text-1); }
    .meta-tools-tested { margin-left: auto; display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-3); }
    .meta-tools-tested strong { color: var(--brand); font-weight: 700; font-size: 18px; }

    .post-cover { max-width: 1200px; margin: 0 auto 48px; padding: 0 32px; }
    .cover-frame { aspect-ratio: 21/9; background: linear-gradient(135deg, #0a0e1a 0%, #1a2540 50%, #4f39f6 100%); border: 1px solid var(--border); position: relative; overflow: hidden; display: grid; place-items: center; }
    .cover-frame::before { content: ''; position: absolute; inset: 0; opacity: 0.4; background-image: linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 32px 32px; }
    .cover-content { position: relative; text-align: center; padding: 0 32px; }
    .cover-mono { font-family: 'Geist Mono', monospace; font-size: 12px; letter-spacing: 0.2em; color: rgba(255,255,255,0.6); text-transform: uppercase; margin-bottom: 16px; }
    .cover-title { font-size: clamp(32px, 4vw, 52px); font-weight: 700; color: white; letter-spacing: -0.03em; line-height: 1; }
    .cover-sub { font-size: 14px; color: rgba(255,255,255,0.7); margin-top: 14px; }

    .post-body-wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px 64px; }
    .post-grid { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 64px; align-items: start; }
    .post-grid > * { min-width: 0; }
    @media (max-width: 1024px) { .post-grid { grid-template-columns: 1fr; gap: 40px; } .post-sidebar { position: static; max-height: none; } }
    @media (max-width: 700px) {
      .post-hero { padding: 32px 20px 28px; }
      .post-hero h1 { font-size: clamp(28px, 7vw, 38px); }
      .post-cover { padding: 0 20px; margin-bottom: 32px; }
      .post-body-wrap { padding: 0 20px 48px; }
      .post-meta { gap: 12px; }
      .meta-divider { display: none; }
      .meta-tools-tested { margin-left: 0; }
      .post-content p, .post-content ul li, .post-content ol li { font-size: 16px; }
      .post-content .lede-p { font-size: 18px; }
      .post-content h2 { margin-top: 40px; }
      .stat-num { font-size: 24px; }
      .stat-cell { padding: 18px 14px; }
      .tool-card-head { flex-wrap: wrap; }
      .tool-rank { width: 100%; height: 56px; }
      .tool-card-price { border-left: none; border-top: 1px solid var(--border); text-align: left; padding: 14px 18px; flex-direction: row; align-items: baseline; gap: 8px; min-width: 0; }
      .tool-card-info { padding: 16px 18px; }
      .tool-card-body { padding: 18px; }
      .bar-row { grid-template-columns: 110px 1fr 60px; gap: 10px; }
      .bar-label { font-size: 12px; }
      .line-svg { height: 160px; }
      .related-posts { padding: 48px 20px; }
    }

    .post-content { font-family: 'Geist', sans-serif; color: var(--text-2); }
    .post-content > * + * { margin-top: 20px; }
    .post-content p { font-size: 17px; line-height: 1.7; color: var(--text-2); }
    .post-content p strong { color: var(--text-1); font-weight: 600; }
    .post-content p a { color: var(--brand); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px; }
    .post-content .lede-p { font-size: 21px; line-height: 1.55; color: var(--text-1); margin-bottom: 32px; font-weight: 400; letter-spacing: -0.005em; }
    .post-content h2 { font-size: clamp(26px, 3vw, 34px); font-weight: 700; line-height: 1.15; letter-spacing: -0.025em; color: var(--text-1); margin: 56px 0 16px; scroll-margin-top: 96px; }
    .post-content h2:first-child { margin-top: 0; }
    .post-content h3 { font-size: 22px; font-weight: 600; line-height: 1.25; letter-spacing: -0.015em; color: var(--text-1); margin: 36px 0 12px; scroll-margin-top: 96px; }
    .post-content h4 { font-size: 17px; font-weight: 600; color: var(--text-1); margin: 24px 0 8px; }

    .post-content ul, .post-content ol { margin: 16px 0 24px; padding-left: 0; list-style: none; }
    .post-content ul li, .post-content ol li { font-size: 17px; line-height: 1.65; color: var(--text-2); padding-left: 32px; position: relative; margin-bottom: 12px; }
    .post-content ul li::before { content: ''; position: absolute; left: 4px; top: 11px; width: 8px; height: 8px; background: var(--brand); transform: rotate(45deg); }
    .post-content ol { counter-reset: olist; }
    .post-content ol li { counter-increment: olist; }
    .post-content ol li::before { content: counter(olist, decimal-leading-zero); position: absolute; left: 0; top: 2px; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 600; color: var(--brand); letter-spacing: 0.04em; }
    .post-content ul li strong, .post-content ol li strong { color: var(--text-1); font-weight: 600; }

    .callout { padding: 20px 24px; margin: 28px 0; border-left: 4px solid; background: var(--bg-soft); }
    .callout-tldr { border-color: var(--brand); background: var(--brand-softer); }
    .callout-warn { border-color: #f59e0b; background: #fffbeb; }
    .callout-success { border-color: #10b981; background: #ecfdf5; }
    .callout-info { border-color: #06b6d4; background: #ecfeff; }
    .callout-label { font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 8px; }
    .callout-tldr .callout-label { color: var(--brand); }
    .callout-warn .callout-label { color: #b45309; }
    .callout-success .callout-label { color: #047857; }
    .callout-info .callout-label { color: #0e7490; }
    .callout p { font-size: 16px; line-height: 1.6; margin: 0; color: var(--text-1); }

    .post-figure { margin: 32px 0; }
    .post-figure .figure-frame { aspect-ratio: 16/9; background: linear-gradient(135deg, var(--brand-softer), white); border: 1px solid var(--border); display: grid; place-items: center; position: relative; overflow: hidden; }
    .post-figure .figure-frame::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(79,57,246,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(79,57,246,0.08) 1px, transparent 1px); background-size: 24px 24px; }
    .post-figure .figure-label { position: relative; font-family: 'Geist Mono', monospace; font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--brand); font-weight: 600; }
    .post-figure figcaption { font-size: 13px; color: var(--text-3); margin-top: 12px; padding-left: 12px; border-left: 2px solid var(--border); }

    .post-content .table-wrap { margin: 28px 0; overflow-x: auto; border: 1px solid var(--border); }
    .post-content table { width: 100%; border-collapse: collapse; font-size: 14px; min-width: 700px; }
    .post-content thead { background: var(--bg-soft); }
    .post-content th { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); padding: 14px 16px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
    .post-content td { padding: 14px 16px; border-bottom: 1px solid var(--border); color: var(--text-2); vertical-align: top; }
    .post-content tr:last-child td { border-bottom: none; }
    .post-content td strong { color: var(--text-1); font-weight: 600; }
    .post-content .cell-yes { color: #047857; font-weight: 600; }
    .post-content .cell-no { color: #b91c1c; font-weight: 600; }
    .post-content .cell-meh { color: #b45309; font-weight: 600; }
    .post-content .row-highlight { background: var(--brand-softer); }
    .post-content .row-highlight td:first-child { font-weight: 700; color: var(--brand); }

    /* TOOL RANK CARD */
    .tool-card { margin: 32px 0; border: 1px solid var(--border); background: white; padding: 0; overflow: hidden; }
    .tool-card.featured { border: 2px solid var(--brand); }
    .tool-card-head { display: flex; align-items: stretch; padding: 0; border-bottom: 1px solid var(--border); }
    .tool-rank { width: 88px; flex-shrink: 0; background: var(--bg-soft); display: grid; place-items: center; font-family: 'Geist Mono', monospace; font-size: 28px; font-weight: 800; color: var(--text-3); letter-spacing: -0.02em; }
    .tool-card.featured .tool-rank { background: var(--brand); color: white; }
    .tool-card-info { padding: 20px 24px; flex: 1; display: flex; flex-direction: column; gap: 6px; }
    .tool-card-name { font-size: 22px; font-weight: 700; color: var(--text-1); letter-spacing: -0.02em; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .winner-badge { padding: 4px 10px; background: #fef3c7; color: #b45309; border: 1px solid #fde68a; font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
    .tool-card-tag { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.06em; text-transform: uppercase; }
    .tool-card-price { padding: 20px 24px; border-left: 1px solid var(--border); text-align: right; display: flex; flex-direction: column; justify-content: center; min-width: 140px; }
    .tool-card-price .price { font-size: 22px; font-weight: 700; color: var(--text-1); letter-spacing: -0.02em; }
    .tool-card-price .per { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; }
    .tool-card-body { padding: 24px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    @media (max-width: 700px) { .tool-card-body { grid-template-columns: 1fr; } .tool-card-head { flex-wrap: wrap; } .tool-card-price { border-left: none; border-top: 1px solid var(--border); text-align: left; padding: 16px 24px; flex-direction: row; align-items: baseline; gap: 8px; } }
    .tool-card-body h5 { font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-3); margin-bottom: 8px; }
    .tool-card-body .yes-list, .tool-card-body .no-list { list-style: none; padding: 0; margin: 0; }
    .tool-card-body .yes-list li { padding-left: 20px; position: relative; font-size: 13px; line-height: 1.5; color: var(--text-1); margin-bottom: 6px; }
    .tool-card-body .yes-list li::before { content: '✓'; position: absolute; left: 0; top: 0; color: #047857; font-weight: 700; background: none; width: auto; height: auto; transform: none; }
    .tool-card-body .no-list li { padding-left: 20px; position: relative; font-size: 13px; line-height: 1.5; color: var(--text-2); margin-bottom: 6px; }
    .tool-card-body .no-list li::before { content: '✗'; position: absolute; left: 0; top: 0; color: #b91c1c; font-weight: 700; background: none; width: auto; height: auto; transform: none; }
    .tool-card-foot { padding: 14px 24px; background: var(--bg-soft); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
    .tool-best-for { font-size: 13px; color: var(--text-2); }
    .tool-best-for strong { color: var(--text-1); font-weight: 600; }
    .tool-cta-btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: var(--text-1); color: white; font-size: 13px; font-weight: 600; }
    .tool-card.featured .tool-cta-btn { background: var(--brand); }
    .tool-cta-btn:hover { background: var(--brand); }

    /* STAT GRID */
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin: 28px 0; border: 1px solid var(--border); }
    @media (max-width: 700px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-cell { padding: 24px 20px; border-right: 1px solid var(--border); }
    .stat-cell:last-child { border-right: none; }
    @media (max-width: 700px) { .stat-cell:nth-child(2n) { border-right: none; } .stat-cell { border-bottom: 1px solid var(--border); } }
    .stat-num { font-size: 32px; font-weight: 700; color: var(--brand); letter-spacing: -0.02em; line-height: 1; }
    .stat-lbl { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-top: 8px; }
    .stat-delta { font-size: 11px; color: var(--text-2); margin-top: 4px; }

    /* CHART */
    .chart-card { padding: 28px; border: 1px solid var(--border); background: white; margin: 32px 0; }
    .chart-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border); flex-wrap: wrap; gap: 12px; }
    .chart-title { font-size: 17px; font-weight: 600; color: var(--text-1); letter-spacing: -0.015em; }
    .chart-sub { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-top: 4px; }
    .chart-legend { display: flex; gap: 14px; font-size: 11px; color: var(--text-3); }
    .chart-legend span { display: inline-flex; align-items: center; gap: 6px; }
    .chart-legend span::before { content: ''; width: 10px; height: 10px; }
    .chart-legend .lg-1::before { background: var(--brand); }
    .chart-legend .lg-2::before { background: #d6d3d1; }
    .bar-rows { display: flex; flex-direction: column; gap: 14px; }
    .bar-row { display: grid; grid-template-columns: 140px 1fr 72px; gap: 16px; align-items: center; }
    .bar-label { font-size: 13px; color: var(--text-1); font-weight: 500; }
    .bar-track { height: 14px; background: #f5f5f4; position: relative; overflow: hidden; }
    .bar-fill { height: 100%; background: linear-gradient(90deg, var(--brand), var(--brand-bright)); }
    .bar-fill.alt { background: #d6d3d1; }
    .bar-value { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-1); font-weight: 600; text-align: right; }

    /* LINE CHART (CSS-only growth curve) */
    .line-chart { padding: 28px; border: 1px solid var(--border); background: white; margin: 32px 0; }
    .line-chart-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
    .line-svg { width: 100%; height: 200px; }
    .line-svg .grid-line { stroke: var(--border); stroke-dasharray: 2 4; }
    .line-svg .axis-text { font-family: 'Geist Mono', monospace; font-size: 10px; fill: var(--text-3); }
    .line-svg .line-path { fill: none; stroke: var(--brand); stroke-width: 2.5; }
    .line-svg .line-path-alt { fill: none; stroke: #a8a29e; stroke-width: 2; stroke-dasharray: 4 4; }
    .line-svg .area { fill: url(#area-grad); opacity: 0.2; }
    .line-svg .point { fill: var(--brand); stroke: white; stroke-width: 2; }

    /* PROS / CONS */
    .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 32px 0; }
    @media (max-width: 700px) { .pros-cons { grid-template-columns: 1fr; } }
    .pros-card, .cons-card { padding: 24px; border: 1px solid var(--border); }
    .pros-card { background: #f0fdf4; border-color: #bbf7d0; }
    .cons-card { background: #fef2f2; border-color: #fecaca; }
    .pros-cons h4 { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 14px; }
    .pros-card h4 { color: #047857; }
    .cons-card h4 { color: #b91c1c; }
    .pros-cons ul { margin: 0; padding: 0; list-style: none; }
    .pros-cons ul li { font-size: 15px; line-height: 1.55; color: var(--text-1); padding-left: 24px; position: relative; margin-bottom: 10px; }
    .pros-card ul li::before { content: '+'; position: absolute; left: 4px; top: -1px; color: #047857; font-weight: 700; font-size: 18px; background: none; width: auto; height: auto; transform: none; }
    .cons-card ul li::before { content: '–'; position: absolute; left: 4px; top: -1px; color: #b91c1c; font-weight: 700; font-size: 18px; background: none; width: auto; height: auto; transform: none; }

    /* BLOCKQUOTE */
    blockquote.pull { margin: 36px 0; padding: 28px 32px; border-left: 4px solid var(--brand); background: var(--bg-cream); font-size: 22px; line-height: 1.4; color: var(--text-1); letter-spacing: -0.015em; font-weight: 500; }
    blockquote.pull cite { display: block; margin-top: 16px; font-style: normal; font-size: 13px; color: var(--text-3); font-family: 'Geist Mono', monospace; letter-spacing: 0.06em; text-transform: uppercase; }

    /* CHECKLIST */
    .checklist-block { padding: 28px; border: 1px solid var(--border); background: white; margin: 32px 0; }
