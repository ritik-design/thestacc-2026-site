---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/review-post.css';

const seo = {
  title: '301 Redirect: Definition, How It Works, and Best Practices | theStacc Glossary',
  description: 'A 301 redirect is a permanent HTTP status code that tells search engines a page has moved to a new URL. Full definition, examples, and 2026 best practices.',
  canonical: 'https://thestacc.com/glossary/301-redirect/',
  ogImage: '/og/glossary/301-redirect.webp',
  noindex: true,
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Glossary", "item": "https://thestacc.com/glossary/" },
        { "@type": "ListItem", "position": 3, "name": "301 Redirect", "item": "https://thestacc.com/glossary/301-redirect/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "DefinedTerm",
      "name": "301 Redirect",
      "description": "A 301 redirect is a permanent HTTP status code that tells browsers and search engines a page has moved to a new URL. The redirect passes 90–99% of link equity to the destination and is the SEO-safe way to move URLs.",
      "inDefinedTermSet": "https://thestacc.com/glossary/",
      "termCode": "301-redirect",
      "url": "https://thestacc.com/glossary/301-redirect/"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Does a 301 redirect pass SEO value?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. A 301 redirect passes roughly 90–99% of link equity (PageRank) from the old URL to the new one. Google has confirmed 301s consolidate ranking signals to the destination." }},
        { "@type": "Question", "name": "How long does a 301 redirect take to be recognized by Google?", "acceptedAnswer": { "@type": "Answer", "text": "Google typically recognizes a 301 within days to a few weeks, depending on crawl frequency. Small sites may take longer; well-crawled sites see the redirect honored within 24–72 hours." }},
        { "@type": "Question", "name": "What's the difference between a 301 and a 302 redirect?", "acceptedAnswer": { "@type": "Answer", "text": "A 301 is permanent — Google eventually replaces the old URL with the new one in its index. A 302 is temporary — Google keeps the old URL and treats the new one as a short-term alternative." }},
        { "@type": "Question", "name": "Can I chain multiple 301 redirects?", "acceptedAnswer": { "@type": "Answer", "text": "Technically yes, but avoid it. Google stops following redirect chains after 5 hops. Each hop leaks a small amount of link equity, so always redirect directly to the final destination." }}
      ]
    }
  ]
};
