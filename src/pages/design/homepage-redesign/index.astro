---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Homepage redesign — 10 options',
  description: 'Internal design preview: 5 layouts for the modules section + 5 layouts for the before/after problem section.',
  canonical: 'https://thestacc.com/design/homepage-redesign/',
  noindex: true
};
---
<BaseLayout seo={seo}>
  <style>
    .design-preview { max-width: 1280px; margin: 0 auto; padding: 64px 32px; }
    .design-preview h1 { font-size: 38px; font-weight: 700; letter-spacing: -0.025em; color: var(--text-1); margin-bottom: 8px; }
    .design-preview .preview-sub { font-size: 16px; color: var(--text-3); margin-bottom: 48px; }
    .preview-section-header { padding: 28px 32px; background: linear-gradient(135deg, var(--brand-softer), white); border: 2px solid var(--brand); margin: 80px 0 32px; }
    .preview-section-header h2 { font-size: 24px; font-weight: 700; color: var(--brand); letter-spacing: -0.02em; margin: 0 0 4px; }
    .preview-section-header p { font-size: 14px; color: var(--text-2); margin: 0; }
    .option-divider { margin: 80px 0 24px; padding: 20px 24px; background: var(--bg-dark); color: white; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .option-divider h3 { font-size: 19px; font-weight: 700; letter-spacing: -0.015em; margin: 0; }
    .option-divider .option-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: rgba(255,255,255,0.5); letter-spacing: 0.08em; text-transform: uppercase; }
    .option-divider .option-tag { display: inline-block; padding: 4px 10px; background: var(--brand-bright); color: white; font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; margin-right: 12px; }

    /* ═══════════════════════════════════════════════
       MODULES SECTION — OPTION A: Clean bento (refined current)
       ═══════════════════════════════════════════════ */
    .mA-section { padding: 80px 32px; background: white; }
    .mA-head { text-align: center; max-width: 720px; margin: 0 auto 56px; }
    .mA-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--brand); font-weight: 700; margin-bottom: 14px; display: block; }
    .mA-head h2 { font-size: clamp(32px, 4vw, 48px); font-weight: 700; letter-spacing: -0.025em; line-height: 1.05; color: var(--text-1); margin-bottom: 16px; }
    .mA-head p { font-size: 17px; line-height: 1.55; color: var(--text-2); }
    .mA-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 1200px; margin: 0 auto; }
    @media (max-width: 900px) { .mA-grid { grid-template-columns: 1fr; } }
    .mA-card { background: white; border: 1px solid var(--border); padding: 32px; transition: all 0.25s; position: relative; overflow: hidden; }
    .mA-card:hover { border-color: var(--brand); transform: translateY(-2px); box-shadow: 0 24px 48px -20px rgba(79,57,246,0.15); }
    .mA-card .mA-num { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 700; letter-spacing: 0.1em; }
    .mA-card .mA-name { font-size: 22px; font-weight: 700; color: var(--text-1); letter-spacing: -0.02em; margin: 8px 0 12px; }
    .mA-card .mA-price { display: inline-block; padding: 4px 10px; background: var(--bg-soft); border: 1px solid var(--border); font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-2); font-weight: 600; margin-bottom: 16px; }
    .mA-card .mA-tagline { font-size: 15px; line-height: 1.5; color: var(--text-1); font-weight: 500; margin-bottom: 20px; }
    .mA-card ul { list-style: none; padding: 0; margin: 0 0 24px; }
    .mA-card li { font-size: 13px; color: var(--text-2); padding-left: 20px; position: relative; margin-bottom: 8px; line-height: 1.45; }
    .mA-card li::before { content: '✓'; position: absolute; left: 0; top: 0; color: var(--brand); font-weight: 700; }
    .mA-card .mA-cta { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; color: var(--brand); font-weight: 600; }
    .mA-card .mA-cta::after { content: '→'; transition: transform 0.2s; }
    .mA-card:hover .mA-cta::after { transform: translateX(4px); }

    /* ═══════════════════════════════════════════════
       MODULES SECTION — OPTION B: Sticky-scroll left rail + detail
       ═══════════════════════════════════════════════ */
    .mB-section { padding: 80px 0 0; background: var(--bg-soft); }
    .mB-head { max-width: 880px; margin: 0 auto 48px; padding: 0 32px; text-align: center; }
    .mB-head h2 { font-size: clamp(32px, 4vw, 48px); font-weight: 700; letter-spacing: -0.025em; color: var(--text-1); margin-bottom: 16px; }
    .mB-grid { max-width: 1200px; margin: 0 auto; padding: 0 32px 80px; display: grid; grid-template-columns: 280px 1fr; gap: 56px; align-items: start; }
    @media (max-width: 900px) { .mB-grid { grid-template-columns: 1fr; } }
    .mB-rail { position: sticky; top: 96px; padding: 8px 0; }
    .mB-rail-item { display: block; padding: 18px 20px; cursor: pointer; border-left: 3px solid var(--border); transition: all 0.2s; }
    .mB-rail-item.active { border-left-color: var(--brand); background: var(--brand-softer); }
    .mB-rail-item .mB-rail-num { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); letter-spacing: 0.1em; }
    .mB-rail-item .mB-rail-name { font-size: 17px; font-weight: 600; color: var(--text-1); margin-top: 4px; letter-spacing: -0.015em; }
    .mB-rail-item .mB-rail-tag { font-size: 12px; color: var(--text-3); margin-top: 2px; }
    .mB-rail-item.active .mB-rail-name { color: var(--brand); }
    .mB-panels { background: white; border: 1px solid var(--border); padding: 0; }
    .mB-panel { display: none; padding: 40px; }
    .mB-panel.active { display: block; }
    .mB-panel .mB-eyebrow { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--brand); font-weight: 700; margin-bottom: 12px; }
    .mB-panel h3 { font-size: 28px; font-weight: 700; color: var(--text-1); letter-spacing: -0.02em; margin-bottom: 14px; }
    .mB-panel .mB-tagline { font-size: 17px; line-height: 1.5; color: var(--text-2); margin-bottom: 24px; }
    .mB-panel ul { list-style: none; padding: 0; margin: 0 0 28px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px 24px; }
    @media (max-width: 700px) { .mB-panel ul { grid-template-columns: 1fr; } }
    .mB-panel li { font-size: 14px; color: var(--text-1); padding-left: 24px; position: relative; line-height: 1.45; }
    .mB-panel li::before { content: '✓'; position: absolute; left: 0; top: 0; width: 16px; height: 16px; background: var(--brand-softer); color: var(--brand); display: grid; place-items: center; font-size: 10px; font-weight: 700; border-radius: 50%; }
    .mB-mock { background: var(--bg-soft); border: 1px solid var(--border); padding: 24px; margin-bottom: 20px; font-family: 'Geist Mono', monospace; font-size: 13px; color: var(--text-2); }
    .mB-mock .mB-mock-label { font-size: 10px; color: var(--brand); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px; }
    .mB-mock strong { color: var(--text-1); font-weight: 600; }
    .mB-panel .mB-cta-row { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    .mB-panel .mB-cta { display: inline-flex; align-items: center; gap: 8px; padding: 12px 22px; background: var(--text-1); color: white; font-size: 14px; font-weight: 600; transition: all 0.2s; }
    .mB-panel .mB-cta:hover { background: var(--brand); }
    .mB-panel .mB-price { font-family: 'Geist Mono', monospace; font-size: 13px; color: var(--text-3); font-weight: 500; }

    /* ═══════════════════════════════════════════════
       MODULES SECTION — OPTION C: Magazine — feature + 2 stacked
       ═══════════════════════════════════════════════ */
    .mC-section { padding: 80px 32px; background: white; }
    .mC-head { max-width: 880px; margin: 0 auto 48px; }
    .mC-head h2 { font-size: clamp(32px, 4vw, 48px); font-weight: 700; letter-spacing: -0.025em; color: var(--text-1); margin-bottom: 16px; }
    .mC-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.4fr 1fr; gap: 20px; }
    @media (max-width: 900px) { .mC-grid { grid-template-columns: 1fr; } }
    .mC-feature { padding: 48px; background: linear-gradient(135deg, #0a0a14 0%, #1f1640 100%); color: white; position: relative; overflow: hidden; min-height: 480px; display: flex; flex-direction: column; justify-content: flex-end; }
    .mC-feature::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 600px 400px at 80% 0%, rgba(109,94,248,0.4) 0%, transparent 60%); pointer-events: none; }
    .mC-feature > * { position: relative; }
    .mC-feature .mC-num { font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--brand-bright); font-weight: 700; letter-spacing: 0.12em; }
    .mC-feature h3 { font-size: 40px; font-weight: 700; color: white; letter-spacing: -0.025em; margin: 8px 0 14px; line-height: 1.05; }
    .mC-feature .mC-tag { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.5; margin-bottom: 28px; max-width: 32ch; }
    .mC-feature .mC-stats { display: flex; gap: 24px; margin-bottom: 28px; flex-wrap: wrap; }
    .mC-feature .mC-stat { font-family: 'Geist Mono', monospace; }
    .mC-feature .mC-stat strong { display: block; font-size: 22px; color: var(--brand-bright); letter-spacing: -0.02em; }
    .mC-feature .mC-stat span { font-size: 11px; color: rgba(255,255,255,0.6); letter-spacing: 0.06em; text-transform: uppercase; }
    .mC-feature .mC-cta { display: inline-flex; align-items: center; gap: 8px; padding: 13px 22px; background: var(--brand-bright); color: white; font-size: 14px; font-weight: 600; align-self: flex-start; }
    .mC-side { display: grid; grid-template-rows: 1fr 1fr; gap: 20px; }
    .mC-mini { padding: 32px; background: white; border: 1px solid var(--border); position: relative; transition: all 0.2s; display: flex; flex-direction: column; }
    .mC-mini:hover { border-color: var(--brand); transform: translateY(-2px); }
    .mC-mini .mC-mini-num { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 700; letter-spacing: 0.1em; }
    .mC-mini h4 { font-size: 22px; font-weight: 700; color: var(--text-1); letter-spacing: -0.02em; margin: 8px 0 10px; }
    .mC-mini p { font-size: 14px; line-height: 1.5; color: var(--text-2); margin-bottom: 16px; flex: 1; }
    .mC-mini .mC-mini-bullets { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.04em; display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
    .mC-mini .mC-mini-cta { font-size: 13px; color: var(--brand); font-weight: 600; margin-top: auto; }

    /* ═══════════════════════════════════════════════
       MODULES SECTION — OPTION D: Stacked rows (full-width per module)
       ═══════════════════════════════════════════════ */
    .mD-section { background: white; }
    .mD-head { padding: 80px 32px 40px; text-align: center; max-width: 760px; margin: 0 auto; }
    .mD-head h2 { font-size: clamp(32px, 4vw, 48px); font-weight: 700; letter-spacing: -0.025em; color: var(--text-1); margin-bottom: 16px; }
    .mD-row { padding: 64px 32px; border-top: 1px solid var(--border); }
    .mD-row:nth-child(odd) { background: var(--bg-soft); }
    .mD-row-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
    .mD-row:nth-child(even) .mD-row-inner > :first-child { order: 2; }
    @media (max-width: 900px) { .mD-row-inner { grid-template-columns: 1fr; } .mD-row:nth-child(even) .mD-row-inner > :first-child { order: 0; } }
    .mD-num { display: inline-block; padding: 6px 14px; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; margin-bottom: 18px; }
    .mD-name { font-size: 36px; font-weight: 700; color: var(--text-1); letter-spacing: -0.025em; margin: 0 0 14px; }
    .mD-tag { font-size: 18px; line-height: 1.5; color: var(--text-1); margin-bottom: 24px; font-weight: 500; }
    .mD-desc { font-size: 15px; line-height: 1.65; color: var(--text-2); margin-bottom: 24px; }
    .mD-meta-row { display: flex; gap: 24px; flex-wrap: wrap; margin-bottom: 28px; }
    .mD-meta-row .mD-meta { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.06em; }
    .mD-meta strong { color: var(--text-1); font-weight: 700; }
    .mD-cta-row { display: flex; gap: 12px; align-items: center; }
    .mD-cta { display: inline-flex; align-items: center; gap: 8px; padding: 12px 22px; background: var(--text-1); color: white; font-size: 14px; font-weight: 600; transition: all 0.2s; }
    .mD-cta:hover { background: var(--brand); }
    .mD-price { font-family: 'Geist Mono', monospace; font-size: 13px; color: var(--text-3); }
    .mD-visual { aspect-ratio: 4/3; background: linear-gradient(135deg, var(--brand-softer), white); border: 1px solid var(--border); display: grid; place-items: center; padding: 24px; }
    .mD-visual.dark { background: linear-gradient(135deg, #0a0a14, #2d2150); color: white; }
    .mD-mock { font-family: 'Geist Mono', monospace; font-size: 13px; line-height: 1.7; }
    .mD-mock strong { color: var(--brand); font-weight: 700; }
    .mD-visual.dark .mD-mock { color: rgba(255,255,255,0.8); }
    .mD-visual.dark .mD-mock strong { color: var(--brand-bright); }

    /* ═══════════════════════════════════════════════
       MODULES SECTION — OPTION E: Tabs with big detail panel
       ═══════════════════════════════════════════════ */
    .mE-section { padding: 80px 32px; background: var(--bg-cream); }
    .mE-head { max-width: 720px; margin: 0 auto 40px; text-align: center; }
    .mE-head h2 { font-size: clamp(32px, 4vw, 48px); font-weight: 700; letter-spacing: -0.025em; color: var(--text-1); margin-bottom: 16px; }
    .mE-tabs { max-width: 1100px; margin: 0 auto; }
    .mE-tabs-nav { display: flex; gap: 0; border-bottom: 1px solid var(--border-strong); margin-bottom: 0; }
    @media (max-width: 700px) { .mE-tabs-nav { flex-direction: column; } }
    .mE-tab-btn { flex: 1; padding: 24px 28px; background: white; border: 1px solid var(--border-strong); border-bottom: none; cursor: pointer; text-align: left; transition: all 0.2s; font-family: inherit; }
    .mE-tab-btn + .mE-tab-btn { margin-left: -1px; }
    .mE-tab-btn .mE-tab-num { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.12em; font-weight: 700; }
    .mE-tab-btn .mE-tab-name { font-size: 18px; font-weight: 700; color: var(--text-1); letter-spacing: -0.015em; margin-top: 6px; }
    .mE-tab-btn .mE-tab-price { font-size: 12px; color: var(--text-3); font-family: 'Geist Mono', monospace; margin-top: 4px; }
    .mE-tab-btn.active { background: white; border-bottom: 1px solid white; position: relative; top: 1px; box-shadow: 0 -3px 0 0 var(--brand) inset; }
    .mE-tab-btn.active .mE-tab-name { color: var(--brand); }
    .mE-tab-btn:hover:not(.active) { background: var(--bg-soft); }
    .mE-panel { display: none; background: white; border: 1px solid var(--border-strong); border-top: none; padding: 48px; }
    .mE-panel.active { display: grid; grid-template-columns: 1.2fr 1fr; gap: 48px; align-items: center; }
    @media (max-width: 900px) { .mE-panel.active { grid-template-columns: 1fr; } }
    .mE-panel h3 { font-size: 32px; font-weight: 700; color: var(--text-1); letter-spacing: -0.025em; margin-bottom: 14px; line-height: 1.1; }
    .mE-panel .mE-tag { font-size: 17px; line-height: 1.5; color: var(--text-2); margin-bottom: 24px; }
    .mE-panel ul { list-style: none; padding: 0; margin: 0 0 28px; }
    .mE-panel li { padding-left: 26px; position: relative; font-size: 15px; line-height: 1.55; color: var(--text-1); margin-bottom: 10px; }
    .mE-panel li::before { content: '→'; position: absolute; left: 0; top: 0; color: var(--brand); font-weight: 700; }
    .mE-panel .mE-cta-row { display: flex; gap: 16px; align-items: center; }
    .mE-panel .mE-cta { display: inline-flex; align-items: center; gap: 8px; padding: 13px 24px; background: var(--text-1); color: white; font-size: 14px; font-weight: 600; }
    .mE-panel .mE-cta:hover { background: var(--brand); }
    .mE-visual { aspect-ratio: 4/3; background: linear-gradient(135deg, var(--bg-cream), white); border: 1px solid var(--border); padding: 24px; display: grid; place-items: center; }
    .mE-vis-content { font-family: 'Geist Mono', monospace; font-size: 13px; color: var(--text-2); line-height: 1.7; text-align: center; }
    .mE-vis-content strong { color: var(--brand); display: block; font-size: 36px; margin-bottom: 6px; font-weight: 700; letter-spacing: -0.02em; }

    /* ═══════════════════════════════════════════════
       PROBLEM SECTION — OPTION 1: Compact 5-row alternating
       ═══════════════════════════════════════════════ */
    .p1-section { padding: 80px 32px; background: white; }
    .p1-head { max-width: 720px; margin: 0 auto 48px; text-align: center; }
    .p1-head h2 { font-size: clamp(32px, 4vw, 48px); font-weight: 700; letter-spacing: -0.025em; color: var(--text-1); margin-bottom: 16px; }
    .p1-rows { max-width: 1080px; margin: 0 auto; }
    .p1-header-row { display: grid; grid-template-columns: 60px 1fr 1fr; gap: 20px; padding: 16px 24px; background: var(--bg-soft); border: 1px solid var(--border); border-bottom: none; }
    .p1-header-row .p1-h-label { font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); }
    .p1-header-row .p1-h-label.before { color: #b91c1c; }
    .p1-header-row .p1-h-label.after { color: #047857; }
    .p1-row { display: grid; grid-template-columns: 60px 1fr 1fr; gap: 20px; padding: 24px; border: 1px solid var(--border); border-top: none; align-items: start; }
    @media (max-width: 700px) { .p1-row, .p1-header-row { grid-template-columns: 50px 1fr; } .p1-row > :last-child, .p1-header-row > :last-child { grid-column: 2; } .p1-row > :nth-child(2) { padding-bottom: 16px; border-bottom: 1px dashed var(--border); } }
    .p1-row .p1-num { font-family: 'Geist Mono', monospace; font-size: 18px; font-weight: 800; color: var(--brand); }
    .p1-row .p1-before { color: var(--text-2); font-size: 14px; line-height: 1.5; }
    .p1-row .p1-before strong { color: #b91c1c; font-weight: 600; }
    .p1-row .p1-after { color: var(--text-1); font-size: 14px; line-height: 1.5; }
    .p1-row .p1-after strong { color: #047857; font-weight: 700; }
    .p1-row:nth-child(odd) { background: var(--bg-soft); }

    /* ═══════════════════════════════════════════════
       PROBLEM SECTION — OPTION 2: Big toggle slider
       ═══════════════════════════════════════════════ */
    .p2-section { padding: 80px 32px; background: var(--bg-dark); color: white; }
    .p2-head { max-width: 720px; margin: 0 auto 32px; text-align: center; }
    .p2-head h2 { font-size: clamp(32px, 4vw, 48px); font-weight: 700; color: white; letter-spacing: -0.025em; margin-bottom: 16px; }
    .p2-head p { font-size: 16px; color: rgba(255,255,255,0.7); }
    .p2-toggle-row { display: flex; justify-content: center; margin-bottom: 32px; }
    .p2-toggle { display: inline-flex; padding: 4px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); }
    .p2-toggle-btn { padding: 12px 28px; background: transparent; color: rgba(255,255,255,0.6); border: none; cursor: pointer; font-family: inherit; font-size: 14px; font-weight: 600; transition: all 0.2s; }
    .p2-toggle-btn.active { background: white; color: var(--text-1); }
    .p2-toggle-btn:hover:not(.active) { color: white; }
    .p2-panel { max-width: 880px; margin: 0 auto; padding: 48px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); display: none; }
    .p2-panel.active { display: block; }
    .p2-panel .p2-eyebrow { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; margin-bottom: 16px; }
    .p2-panel.before-panel .p2-eyebrow { color: #fca5a5; }
    .p2-panel.after-panel .p2-eyebrow { color: #6ee7b7; }
    .p2-panel h3 { font-size: 28px; font-weight: 700; color: white; letter-spacing: -0.02em; margin-bottom: 28px; line-height: 1.15; }
    .p2-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 16px; }
    .p2-item { display: grid; grid-template-columns: 32px 1fr; gap: 16px; padding: 18px; background: rgba(255,255,255,0.03); border-left: 3px solid; }
    .p2-panel.before-panel .p2-item { border-left-color: #ef4444; }
    .p2-panel.after-panel .p2-item { border-left-color: #10b981; }
    .p2-item .p2-num { font-family: 'Geist Mono', monospace; font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.4); }
    .p2-item .p2-title { font-size: 15px; font-weight: 600; color: white; margin-bottom: 4px; }
    .p2-item .p2-desc { font-size: 13px; line-height: 1.55; color: rgba(255,255,255,0.65); }

    /* ═══════════════════════════════════════════════
