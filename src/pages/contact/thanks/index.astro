---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Thanks — Message received | theStacc',
  description: 'Your message has been sent. We read every message and reply within 4 hours on work days.',
  canonical: 'https://thestacc.com/contact/thanks/',
  ogImage: '/og-default.png',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Thanks — Message received",
    "url": "https://thestacc.com/contact/thanks/"
  }
};
---
<BaseLayout seo={seo} bodyClass="thanks-page">
  <main style="min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 64px 24px;">
    <div style="max-width: 640px; text-align: center;">
      <span class="label-pill" style="margin-bottom: 16px; display: inline-block;">Sent</span>
      <h1 class="h-xl" style="margin-bottom: 16px;">We got your message.</h1>
      <p style="font-size: 18px; color: var(--text-2); line-height: 1.6; margin-bottom: 32px;">
        We read every message and reply within 4 hours on work days. If it is urgent, email <a href="mailto:hello@thestacc.com" style="color: var(--brand); text-decoration: underline;">hello@thestacc.com</a> directly.
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/pricing/" class="btn-secondary">See pricing</a>
      </div>
    </div>
  </main>
</BaseLayout>
