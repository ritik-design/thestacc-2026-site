---
import BaseLayout from '../layouts/BaseLayout.astro';
const seo = {
  title: 'theStacc — AI SEO automation that publishes for you',
  description: 'Get found everywhere customers search — Google, ChatGPT, and Maps. AI that writes, ranks, and publishes content. $1 trial. From $49/mo.',
  canonical: 'https://thestacc.com/',
  ogImage: '/og-default.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "theStacc",
    "url": "https://thestacc.com/",
    "logo": "https://thestacc.com/button.flex.svg",
    "sameAs": ["https://twitter.com/thestacc", "https://www.linkedin.com/company/thestacc"]
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO (centered) -->
  <section class="hero-section">
    <a href="#" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · WordPress plugin is live</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Get Found Everywhere <span class="accent">Customers Search.</span></h1>
    <p class="hero-sub">For <strong>SaaS, local businesses, bloggers, agencies</strong> and any team that lives off organic — AI that writes, publishes, and ranks content on <strong>Google</strong>, gets you cited in <strong>ChatGPT</strong>, and grows your visibility while you focus on the work.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">R</div><div class="av">M</div><div class="av">S</div><div class="av">J</div></div>
        <span><strong>127+</strong> businesses</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- HERO VIDEO -->
  <section class="video-section" id="heroVideoSection">
    <div class="video-shell" id="heroVideoShell">
      <div class="browser-chrome">
        <div class="browser-dots"><span></span><span></span><span></span></div>
        <div class="browser-url">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          thestacc.com
        </div>
      </div>
      <div class="video-frame" aria-label="theStacc demo">
        <video class="video-poster" data-src="/hero-demo.mp4" poster="/hero-poster.jpg" muted loop playsinline preload="none"></video>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Trusted by growing businesses</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- MODULES — Magazine layout (Option C) -->
  <section class="modules-mag" id="features">
    <div class="mag-head">
      <span class="label-pill">Three modules · One platform</span>
      <h2 class="h-lg">One platform. <span class="accent">All of it. Done.</span></h2>
      <p class="lede">Three jobs that used to cost three agencies. Now one platform writes your content, wins your local search, and keeps your brand top-of-mind — for the price of one freelancer.</p>
    </div>
    <div class="mag-grid">
      <a class="mag-feature" href="/modules/content-seo/">
        <div class="mag-num">01 · CONTENT SEO · $99/MO</div>
        <h3>30 articles that rank — and get cited by AI.</h3>
        <p class="mag-tag">SEO-scored 90+ for Google. Structured so ChatGPT, Perplexity, Gemini, Claude, and Copilot quote you as the source.</p>
        <div class="mag-stats">
          <div class="mag-stat"><strong>60d</strong><span>Avg time to page 1</span></div>
          <div class="mag-stat"><strong>5</strong><span>AI engines cite you</span></div>
          <div class="mag-stat"><strong>24h</strong><span>First article live</span></div>
        </div>
        <span class="mag-cta">Explore Content SEO <span class="arrow">→</span></span>
      </a>
      <div class="mag-side">
        <a class="mag-mini" href="/modules/local-seo/">
          <div class="mag-mini-num">02 · LOCAL SEO · $49/MO</div>
          <h4>Be the business customers call first.</h4>
          <p>Map Pack rankings, auto-managed GBP, instant review replies — when someone searches "near me," they find you.</p>
          <div class="mag-mini-bullets"><span>· GBP</span><span>· Map Pack</span><span>· Reviews</span><span>· Citations</span></div>
          <span class="mag-mini-cta">Explore Local SEO <span class="arrow">→</span></span>
        </a>
        <a class="mag-mini" href="/modules/social-media/">
          <div class="mag-mini-num">03 · SOCIAL MEDIA · $49/MO</div>
          <h4>Top-of-mind without posting yourself.</h4>
          <p>Daily, on-brand posts to Instagram, LinkedIn, X, and Facebook — one tap to approve, or full autopilot.</p>
          <div class="mag-mini-bullets"><span>· IG</span><span>· LinkedIn</span><span>· X</span><span>· Facebook</span></div>
          <span class="mag-mini-cta">Explore Social Media <span class="arrow">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- LEGACY BENTO (replaced by Option C above) -->
  <section style="display:none">
    <div class="bento-grid">
      <!-- Featured: Content SEO (spans full height left) -->
      <a class="bento-card bento-feature" href="/modules/content-seo/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
        </div>
        <h3 class="bento-title">Content SEO</h3>
        <h4 class="bento-sub">SEO-optimized. <span class="accent">AI-optimized.</span> Built to rank in Google and get cited across every AI search engine.</h4>
        <p class="bento-desc">Every article is engineered for both worlds of search: scored 90+ for classic Google ranking, and structured so ChatGPT, Perplexity, Gemini, Claude, and Copilot quote you as the source.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Rank on page 1 — average 60 days</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Cited across every major AI search engine</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Sounds like you wrote it (brand-voice trained)</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Live on your site in 24 hours — zero copy-paste</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">ARTICLE #128 · JUST PUBLISHED</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">Dental Implants in Austin: The Complete 2026 Guide</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">SEO 94/100</span>
            <span class="bento-mock-tag">2,847 words</span>
            <span class="bento-mock-tag brand">Cited in 4 AI engines</span>
          </div>
        </div>
        <div class="bento-cta">Explore Content SEO <span class="arrow">→</span></div>
      </a>

      <!-- Local SEO -->
      <a class="bento-card" href="/modules/local-seo/">
        <div class="bento-num">02</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="bento-title">Local SEO</h3>
        <h4 class="bento-sub">Be the business customers <span class="accent">call first</span> — on Maps, Google, AI search.</h4>
        <p class="bento-desc">Map Pack rankings, auto-managed Google Business Profile, instant review responses — so when someone searches "near me," they find you.</p>
        <div class="bento-mock bento-mock-grid">
          <div class="bento-grid-pin top3">1</div>
          <div class="bento-grid-pin top3">2</div>
          <div class="bento-grid-pin top3">3</div>
          <div class="bento-grid-pin">5</div>
          <div class="bento-grid-pin">7</div>
          <div class="bento-grid-pin top3">2</div>
          <div class="bento-grid-pin">8</div>
          <div class="bento-grid-pin">4</div>
          <div class="bento-grid-pin top3">1</div>
          <div class="bento-grid-pin top3">3</div>
          <div class="bento-grid-pin">6</div>
          <div class="bento-grid-pin top3">2</div>
          <div class="bento-grid-pin">5</div>
          <div class="bento-grid-pin top3">3</div>
          <div class="bento-grid-pin">9</div>
          <div class="bento-grid-pin top3">1</div>
        </div>
        <div class="bento-cta">Explore Local SEO <span class="arrow">→</span></div>
      </a>

      <!-- Social Media -->
      <a class="bento-card" href="/modules/social-media/">
        <div class="bento-num">03</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        </div>
        <h3 class="bento-title">Social Media</h3>
        <h4 class="bento-sub">Stay top-of-mind <span class="accent">without posting yourself.</span></h4>
        <p class="bento-desc">Daily, on-brand posts published across Instagram, LinkedIn, X, and Facebook — one tap to approve, or full autopilot.</p>
        <div class="bento-mock bento-mock-social">
          <div class="bento-social-row">
            <span class="bento-social-icon">IG</span>
            <span class="bento-social-text">Carousel · 5 slides · scheduled Mon 9 AM</span>
            <span class="bento-social-status">●</span>
          </div>
          <div class="bento-social-row">
            <span class="bento-social-icon">in</span>
            <span class="bento-social-text">Article · 1,200 words · scheduled Tue 11 AM</span>
            <span class="bento-social-status">●</span>
          </div>
          <div class="bento-social-row">
            <span class="bento-social-icon">X</span>
            <span class="bento-social-text">Thread · 7 posts · scheduled Wed 2 PM</span>
            <span class="bento-social-status">●</span>
          </div>
          <div class="bento-social-row">
            <span class="bento-social-icon">f</span>
            <span class="bento-social-text">Post + image · scheduled Thu 10 AM</span>
            <span class="bento-social-status">●</span>
          </div>
        </div>
        <div class="bento-cta">Explore Social Media <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">92<span class="accent">%</span></div><div class="stat-label">Rank top 3 in Map Pack · 90 days</div></div>
      <div class="stat-cell"><div class="stat-num">47<span class="accent">+</span></div><div class="stat-label">Keywords ranked · per business</div></div>
      <div class="stat-cell"><div class="stat-num">3,000<span class="accent">+</span></div><div class="stat-label">Words per article</div></div>
      <div class="stat-cell"><div class="stat-num">$40<span class="accent">k+</span></div><div class="stat-label">Saved/year vs agency</div></div>
    </div>
  </section>

  <!-- SERP BATTLE: What's actually happening on Google -->
  <section class="serp-section">
    <div class="serp-header">
      <span class="label-pill">Live · Right now</span>
      <h2 class="h-lg">Your competitors are <span class="accent">getting your searches.</span></h2>
      <p>Every search your customer runs is a chance for someone else to answer that call. Here's what Google shows them right now.</p>
    </div>
    <div class="serp-grid">
      <div class="serp-mock" id="serpMock">
        <div class="serp-bar">
          <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
          <div class="search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span id="serpQuery">best dentist near me</span>
          </div>
          <span class="live-pill">Live</span>
        </div>
        <div class="serp-results" id="serpResults">
          <div class="serp-result competitor">
            <span class="rank">#1</span>
            <div class="url">austindentalpros.com › ...</div>
            <div class="title">Best Dentist in Austin · Award-Winning Care 2026</div>
            <div class="snippet">5-star rated practice with 200+ Google reviews. Same-day implants, family dentistry…</div>
          </div>
          <div class="serp-result competitor">
            <span class="rank">#2</span>
            <div class="url">smilesofaustin.com › about</div>
            <div class="title">Top-Rated Dentist Austin TX · 30-Year Practice</div>
            <div class="snippet">Trusted by 12,000 Austin families since 1994. Insurance accepted, evening hours…</div>
          </div>
          <div class="serp-result competitor">
            <span class="rank">#3</span>
            <div class="url">brightsmiledental.com</div>
            <div class="title">Brightsmile Dental · Best of Austin 2025 Winner</div>
            <div class="snippet">Cosmetic, family & emergency dentistry. New patient specials starting at $99…</div>
          </div>
          <div class="serp-page-jump">Page 1 · Page 2 · Page 3 · ⋯</div>
          <div class="serp-result you">
            <span class="rank">#42</span>
            <span class="you-badge">← You</span>
            <div class="url">yourdentalpractice.com</div>
            <div class="title">Welcome to Our Dental Practice</div>
            <div class="snippet">Quality dental care for the whole family. Located in Austin, Texas…</div>
          </div>
        </div>
        <div class="serp-footer">
          <span>1,247 searches today in your area</span>
          <span class="right">You're losing 94% of them</span>
        </div>
      </div>

      <div class="serp-copy">
        <h3>Google rewards <span class="accent">consistency.</span> The business that publishes 30+ articles this month will own those terms <span class="accent">for years.</span></h3>
        <p>Your competitor doesn't have a better practice. They just have a better SEO engine — publishing daily, answering review questions, posting to GBP. theStacc gives you that engine for $99.</p>
        <div class="serp-stats-row">
          <div class="serp-stat-cell"><div class="v">1,247</div><div class="l">Searches/day in your market</div></div>
          <div class="serp-stat-cell"><div class="v">73%</div><div class="l">Click only the top 3 results</div></div>
          <div class="serp-stat-cell"><div class="v">$0</div><div class="l">You're capturing today</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 01 - PROBLEM (before / after) -->
  <!-- PROBLEM / SOLUTION — Journey arrow (Option 4) -->
  <section class="journey-section">
    <div class="journey-head">
      <span class="label-pill">01 · The Problem</span>
      <h2 class="h-lg">Where most teams are today. <span class="accent">Where you land in 30 days.</span></h2>
      <p>Whether you're a SaaS team, an agency, an ecom brand or a local business — the SEO game punishes anyone without a content team. Here's what changes when theStacc takes over.</p>
    </div>
    <div class="journey-grid">
      <div class="journey-side journey-before">
        <div class="journey-eyebrow">✗ Before theStacc</div>
        <h3>Stuck. Slow. Expensive.</h3>
        <div class="journey-sub">Five things that punish anyone without a content team.</div>
        <ol class="journey-list">
          <li><strong>Scattered tools, no system</strong><p>Semrush for keywords. ChatGPT for drafts. Surfer for scoring. Hootsuite for social. Nothing connects.</p></li>
          <li><strong>15+ hr/week of manual work</strong><p>Researching, writing, scoring, posting. Half the time the article never goes live.</p></li>
          <li><strong>$3.5k/mo for slow output</strong><p>Agencies charge thousands and deliver 4 articles. Freelancers ghost. Quality varies week to week.</p></li>
          <li><strong>Invisible in AI search</strong><p>ChatGPT, Perplexity, and Gemini cite your competitors. You're not on the list.</p></li>
          <li><strong>No clarity on what works</strong><p>Rankings up, traffic flat, leads silent. You can't connect any article to any dollar.</p></li>
        </ol>
      </div>
      <div class="journey-arrow-col"><div class="journey-arrow">→</div></div>
      <div class="journey-side journey-after">
        <div class="journey-eyebrow">✓ With theStacc · 30 days in</div>
        <h3>One platform. All of it. Done.</h3>
        <div class="journey-sub">Five outcomes that change the same week you start.</div>
        <ol class="journey-list">
          <li><strong>One engine, all connected</strong><p>Keywords, drafting, scoring, publishing, GBP, social, reviews — running from one dashboard, in real time.</p></li>
          <li><strong>0 minutes from you</strong><p>Articles, posts, replies, and reports just appear. You're in control, but you don't have to be involved.</p></li>
          <li><strong>$99/mo · 30+ articles</strong><p>One platform replaces your agency, your freelancers, and your tool stack. Same outcome — 35× cheaper.</p></li>
          <li><strong>Cited by every AI engine</strong><p>Articles structured so ChatGPT, Perplexity, Gemini, Claude, and Copilot quote you as the source.</p></li>
          <li><strong>Friday clarity reports</strong><p>Which keywords ranked, which articles drove leads, which dollars came from where. Clarity replaces guessing.</p></li>
        </ol>
      </div>
    </div>
  </section>

  <!-- LEGACY BA-GRID (replaced by Option 4 above) -->
  <section style="display:none">
    <div class="ba-grid">
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">Before theStacc</span>
          <h3 class="ba-title">Stuck, slow, expensive.</h3>
          <p class="ba-sub">Where most teams are today.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
