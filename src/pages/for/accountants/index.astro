        <div class="cost-cell head-cell">Local SEO agency</div>
        <div class="cost-cell head-cell">Freelancer</div>
        <div class="cost-cell head-cell brand">theStacc</div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Solo CPA</div><div class="price" style="font-size:15px;font-weight:600;">Single location</div></div>
        <div class="cost-cell"><div class="price crossed">$2,500</div><div class="per">per month</div></div>
        <div class="cost-cell"><div class="price crossed">$1,000</div><div class="per">part-time</div></div>
