---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Consulting SEO | Rank for High-Intent Keywords That Drive Clients | theStacc',
  description: "Stacc publishes 30 SEO blog posts to your consulting firm's website every month — thought leadership, case studies, and service keyword content that ranks and drives inbound leads. $99/month.",
  canonical: 'https://thestacc.com/for/consulting/',
  ogImage: '/og/for-consulting.webp'
};

const faqs = [
  {
    q: "How long until my consulting firm's blog starts ranking?",
    a: "Most consulting firms see meaningful ranking movement within 3–6 months of consistent publishing. Individual articles can rank faster for long-tail keywords. The compounding effect — where each article raises your domain authority, which lifts all articles — becomes most visible around month 3–4.",
  },
  {
    q: "What topics and keywords does Stacc write about for consulting?",
    a: "Stacc targets service + outcome combinations calibrated to your specialties — 'how to improve operational efficiency,' 'digital transformation consulting,' 'go-to-market strategy for SaaS,' 'revenue operations consulting.' Also competitor comparison and alternative searches that capture high-intent prospects.",
  },
  {
    q: "How does Stacc know what to write for my specific consulting niche?",
    a: "During setup, Stacc audits your existing content, analyzes the top-ranking content in your niche, and identifies the keyword gaps between what your competitors rank for and what you don't. The content calendar is built from this gap analysis.",
  },
  {
    q: "Which CMS platforms does Stacc integrate with?",
    a: "Stacc publishes to WordPress, Webflow, HubSpot, Ghost, Squarespace, and custom CMSes. If your CMS accepts content via API or scheduled publishing, we support it. Setup takes under 10 minutes.",
  },
  {
    q: "Can I review articles before they publish?",
    a: "Yes. You can set an approval workflow where articles queue for your review before publishing, or enable fully automated publishing. Most firms start with review-on and switch to auto-publish after seeing the quality.",
  },
  {
    q: "How is Stacc different from a content marketing agency?",
    a: "A content marketing agency charges $5,000–$15,000/month for 4–8 articles, requires onboarding calls, and involves account managers between you and the writers. Stacc is fully automated — research, writing, publishing — for $99/month. The output volume is 3–7× higher.",
  },
  {
    q: "Will the articles sound like our firm's voice?",
    a: "Yes. During setup, Stacc learns your firm's tone, preferred frameworks, and terminology. Articles are written to match your voice — not generic AI content. Most consulting clients find minimal editing needed within the first 2–3 months.",
  },
  {
    q: "Does Stacc also handle GBP/local SEO for consulting firms?",
    a: "Stacc's Blog SEO module handles content publishing and organic rankings. If your firm has a physical office location and you want to rank in Google Maps for local consulting searches, you can add the Local SEO module at $49/month. Many consulting firms with physical offices use both.",
  },
];
---
<BaseLayout seo={seo}>

  
  <main>

    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Consulting SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            30 SEO articles that position your firm as the expert.<br />
            <span style="color:#4f39f6;">Published every month.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Consulting clients Google their problems before they know who to hire. Firms that publish 30 SEO articles a month — addressing those exact problems — capture inbound leads before a competitor even gets on their radar. Stacc researches, writes, and publishes 30 SEO-optimized articles every month targeting the searches your future clients are making right now.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No contracts · 30+ blog posts published monthly
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '30',   num: 30,  prefix: '',  suffix: '',  decimals: 0, from: 0, label: 'SEO articles published per month' },
              { value: '87%',  num: 87,  prefix: '',  suffix: '%', decimals: 0, from: 0, label: 'B2B buyers research online before engaging' },
              { value: '3yr',  num: 3,   prefix: '',  suffix: 'yr',decimals: 0, from: 0, label: 'Average article ranking lifespan' },
              { value: '$99',  num: 99,  prefix: '$', suffix: '',  decimals: 0, from: 0, label: 'per month, fully managed' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Consulting firms growing with Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 from 127 reviews</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Strategy Consulting Group — New York, NY','Operations Advisory — Chicago, IL','Growth Consulting Partners — Austin, TX','Digital Transformation Advisors — San Francisco, CA','Revenue Consulting Group — Boston, MA','Leadership Advisory Firm — Denver, CO','Marketing Consulting Studio — Seattle, WA','Strategy Consulting Group — New York, NY','Operations Advisory — Chicago, IL','Growth Consulting Partners — Austin, TX','Digital Transformation Advisors — San Francisco, CA','Revenue Consulting Group — Boston, MA','Leadership Advisory Firm — Denver, CO','Marketing Consulting Studio — Seattle, WA'].map((name, i) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Your competitor is ranking for the searches<br />your ideal clients are making right now.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Content is the moat in B2B consulting. The firm that answers the question gets the relationship.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Your consulting firm's website has 8 blog posts. Your competitor has 350.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Content volume is a competitive moat in consulting. A firm with 350 SEO-optimized articles ranks for hundreds of buyer-intent searches — problem-awareness terms, solution-comparison searches, and 'how to' content that positions them as the expert before a prospect ever picks up the phone. Every month without consistent publishing, that moat gets deeper on their side.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Prospects are Googling your exact service offering and landing on your competitor's case studies.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Before engaging a consulting firm, prospects research extensively online — searching 'how to improve operational efficiency,' 'digital transformation roadmap,' and '[your specialty] consulting [city].' If your website doesn't rank for those searches, a competitor's thought leadership content answers those questions and captures the relationship you should be having.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">You have a great deck. Your competitor has 300 articles ranking on page 1.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Presentations close deals. Content generates the pipeline. A consulting firm with consistent SEO publishing captures prospects 6–18 months before they're ready to engage — when they're still in the problem-awareness phase. When they're finally ready to issue an RFP, your firm is already the one they've been reading for a year.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does for consulting firms</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Every lever that builds inbound pipeline for consulting. Handled.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Blog SEO for consulting firms requires consistent article publishing, competitor gap analysis, and thought leadership formatting — every single month. Stacc handles all of it automatically.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Blog Content Publishing',
              body: '30 SEO-optimized articles per month — thought leadership, problem-solution content, case study formats, industry trend analysis, and service keyword targeting. Published on schedule automatically.',
              icon: 'M12 20h9 M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z',
            },
            {
              title: 'Consulting Keyword Research',
              body: 'Service + outcome combinations — operational efficiency, digital transformation, go-to-market strategy, leadership development. Calibrated to your specialties and ideal client industries.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Thought Leadership Content',
              body: 'Articles that position your firm as the definitive expert in your niche — "how to" guides, frameworks, benchmarks, and industry analysis that prospects share and cite internally.',
              icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
            },
            {
              title: 'CMS Publishing',
              body: 'Integrates with WordPress, Webflow, HubSpot, Squarespace, or custom CMS. Articles publish directly to your site on schedule.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Competitor Content Gap Analysis',
              body: 'Identify which keywords and topics your direct competitors rank for that you don\'t — and build the content calendar to close those gaps first.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'Monthly Content Calendar',
              body: '30-article plan with keyword targets, article titles, intent mapping, and publication schedule. Full visibility into what\'s being published and why.',
              icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connect once. Stacc publishes 30+ blog posts to your<br />consulting site every month from that day forward.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            No keyword research. No writing posts. No manually scheduling content. Set it up once and your consulting blog runs itself — so you can focus on client work.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connect your CMS and define your specialties</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Stacc audits your existing content, analyzes competitor blogs, and identifies the keyword gaps — the problem-solution searches your ideal clients are making when they're researching firms like yours.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">AI researches and writes 30 SEO articles per month</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Each article targets a specific buyer stage and keyword — from problem-awareness content ('how to reduce customer churn') to solution-comparison content ('operational consulting vs management consulting') to high-intent service keywords. All formatted for ranking.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Articles publish. Rankings build. Inbound leads increase.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30+ blog posts go live on your site every month. Domain authority builds. Organic traffic compounds. Your firm appears in searches your ideal clients are making — months before they're ready to engage, positioning you as the obvious choice when they are.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── RESULTS METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">By the numbers</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
            What the data says about consulting<br />firms and content marketing.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed" style="color:#6b7280;">
            The content gap between consulting firms is larger than most realize — and most competitors aren't closing it consistently yet.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px overflow-hidden rounded-2xl bg-white/5 sm:grid-cols-2 md:grid-cols-4" style="border:1px solid rgba(255,255,255,0.08);">
          {[
            { value: '30',   num: 30,  prefix: '',  suffix: '',   decimals: 0, from: 0, label: 'SEO articles published per month',          sub: 'problem-solution content your clients search' },
            { value: '87%',  num: 87,  prefix: '',  suffix: '%',  decimals: 0, from: 0, label: 'B2B buyers research online before engaging', sub: 'your blog is your pipeline'                   },
