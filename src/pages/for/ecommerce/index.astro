---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: "How long until our ecommerce blog starts driving sales?",
    a: "Most ecommerce brands see their first meaningful organic ranking improvements at 3–6 months, with significant revenue impact by month 9–12. The key is publishing volume — 30+ blog posts per month for 6 months is 180 buyer-intent articles, each capturing a different search. Rankings compound and traffic builds month over month. Every article published is a permanent sales asset that works without ad spend.",
  },
  {
    q: "What types of articles does Stacc write for ecommerce?",
    a: "Stacc focuses on buyer-intent content: buying guides ('best yoga mats for beginners'), product comparisons ('bamboo vs cotton sheets'), how-to content ('how to choose a standing desk'), category reviews, and problem-aware content that leads to a product purchase. Articles are internally linked to your product pages so every article drives buyers toward a sale.",
  },
  {
    q: "Which platforms does Stacc publish to?",
    a: "Stacc publishes directly to Shopify, WooCommerce, BigCommerce, and custom ecommerce platforms. Setup takes under 10 minutes. After the initial connection, articles are published on schedule every month without manual uploads.",
  },
  {
    q: "How does Stacc target buyer-intent keywords for our specific products?",
    a: "During setup, Stacc audits your product catalog, identifies your top categories, and maps those categories to the buyer-intent searches that lead to purchases. 'Best [your product] under $50,' '[product] for [use case],' and '[your category] comparison' — the searches your customers type before they decide where to buy.",
  },
  {
    q: "Can we review articles before they go live?",
    a: "Yes. You can choose an approval workflow where articles are sent for review before publishing, or a fully automated workflow where articles publish on schedule. Most ecommerce brands start with approval for the first month and switch to fully automated once they see the quality is consistent.",
  },
  {
    q: "How is Stacc different from a content agency?",
    a: "A content marketing agency that publishes 30 buyer-intent articles a month for an ecommerce brand charges $3,000–$10,000/month. Stacc automates every part of that process — keyword research, article writing, CMS publishing, internal linking to product pages, meta optimization — for $99/month. The output is comparable. The cost is 30–100x less.",
  },
  {
    q: "Should we focus on blog content or product page SEO?",
    a: "Both matter, but for different reasons. Product pages rank for branded and specific product searches. Blog content ranks for problem-aware and solution-comparison searches — the 'best yoga mat for beginners' and 'bamboo vs cotton sheets' searches that happen before a buyer has decided where to buy. Without blog content, you're capturing only a fraction of your available buyer traffic.",
  },
  {
    q: "We're on Shopify. Can Stacc publish directly to our blog?",
    a: "Yes. Stacc connects to your Shopify store and publishes articles directly to your Shopify blog on schedule. Every article includes internal links to your product pages, optimized meta titles and descriptions, and proper heading structure. Setup takes under 10 minutes.",
  },
];
const seo = {
  title: 'Ecommerce SEO | Rank for Buyer-Intent Keywords | theStacc',
  description: 'Stacc publishes 30 SEO blog posts to your ecommerce store every month — buying guides, product comparisons, and how-to articles that rank and drive sales. $99/month.',
  canonical: 'https://thestacc.com/for/ecommerce/',
  ogImage: '/og/for-ecommerce.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "For", "item": "https://thestacc.com/for/" },
          { "@type": "ListItem", "position": 3, "name": "Ecommerce", "item": "https://thestacc.com/for/ecommerce/" }
        ]
      },
      {
        "@type": "Service",
        "name": "SEO for Ecommerce",
        "provider": { "@type": "Organization", "name": "theStacc" },
        "areaServed": "United States",
        "audience": { "@type": "Audience", "audienceType": "Ecommerce Companies" }
      }
    ]
  }
};
---
<BaseLayout seo={seo}>
    <!-- ─── HERO ─── -->
    <section class="relative overflow-hidden" style="background:#ffffff;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(15,23,42,0.05) 1px,transparent 1px),linear-gradient(to bottom,rgba(15,23,42,0.05) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);-webkit-mask-image:radial-gradient(ellipse at 50% 0%,black 45%,transparent 90%);" aria-hidden="true"></div>
      <div class="pointer-events-none absolute inset-x-0 top-0 h-[600px]" style="background:radial-gradient(ellipse at 50% -10%, rgba(79,57,246,0.18) 0%, transparent 60%);" aria-hidden="true"></div>

      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-[780px] text-center">

          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e7e5e4] bg-white px-3 py-1.5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#4f39f6]"></span>
            <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.14em] text-[#79716b]">Ecommerce SEO · Powered by Stacc</span>
          </div>

          <h1 class="font-sans text-[2.4rem] font-semibold leading-[1.12] tracking-[-0.04em] text-[#292524] md:text-[3.5rem]">
            30 SEO articles that drive product sales.<br />
            <span style="color:#4f39f6;">Published every month.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-[580px] font-sans text-[1.05rem] leading-[1.7]" style="color:#6b7280;">
            Ecommerce buyers search 12+ times before purchasing. Brands that answer those searches with blog content capture buyers earlier in the funnel — and convert them at lower cost than ads. Stacc publishes 30 SEO articles to your store every month targeting the searches that lead to sales.
          </p>

          <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a
              href="/demo/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 items-center gap-2 rounded-xl bg-[#4f39f6] px-6 font-sans text-[14px] font-semibold text-white transition-colors hover:bg-[#5b4bff]"
            >
              Start for $1 today
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a
              href="#how-it-works"
              class="inline-flex h-11 items-center gap-2 rounded-xl border border-[#e7e5e4] bg-white px-6 font-sans text-[14px] font-medium text-[#57534e] transition-colors hover:bg-[#f5f3ff]"
            >
              See how it works
            </a>
          </div>

          <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.18em] text-[#79716b]">
            No contracts · 30+ blog posts published monthly
          </p>

          <!-- Trust stats -->
          <div class="mx-auto mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
            {[
              { value: '30',  num: 30, prefix: '', suffix: '',   decimals: 0, from: 0, label: 'SEO articles published per month' },
              { value: '12×', num: 12, prefix: '', suffix: '×',  decimals: 0, from: 0, label: 'More content than avg ecommerce brand' },
              { value: '3yr', num: 3,  prefix: '', suffix: 'yr', decimals: 0, from: 0, label: 'Average article ranking lifespan' },
              { value: '$99', num: 99, prefix: '$', suffix: '',  decimals: 0, from: 0, label: 'per month, fully managed' },
            ].map(s => (
              <div class="text-center">
                <p class="font-sans text-[1.4rem] font-semibold leading-none text-[#292524]"
                   data-count-up data-target={s.num} data-from={s.from} data-prefix={s.prefix} data-suffix={s.suffix} data-decimals={s.decimals}>{s.value}</p>
                <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]" style="color:#4b5563;">{s.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SOCIAL PROOF STRIP ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-6">
        <div class="mb-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#79716b]">Ecommerce brands publishing with Stacc</p>
          <div class="flex items-center gap-1.5">
            <div class="flex">
              {[1,2,3,4,5].map(() => (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="#4f39f6" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="font-mono text-[11px] text-[#6b7280]">4.9 from 127 reviews</span>
          </div>
        </div>
        <div class="relative overflow-hidden">
          <div class="pointer-events-none absolute left-0 top-0 z-10 h-full w-16 bg-gradient-to-r from-white to-transparent"></div>
          <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-16 bg-gradient-to-l from-white to-transparent"></div>
          <div class="flex animate-marquee gap-0">
            {['Home Goods Brand — DTC', 'Beauty & Skincare Store — Online', 'Outdoor Gear Brand — Ecommerce', 'Pet Supplies Store — DTC', 'Fitness Equipment Brand — Online', 'Kitchen & Cooking Store — DTC', 'Apparel Brand — Ecommerce', 'Home Goods Brand — DTC', 'Beauty & Skincare Store — Online', 'Outdoor Gear Brand — Ecommerce', 'Pet Supplies Store — DTC', 'Fitness Equipment Brand — Online', 'Kitchen & Cooking Store — DTC', 'Apparel Brand — Ecommerce'].map((name) => (
              <div class="flex shrink-0 items-center gap-2 mx-8">
                <div class="h-7 w-7 rounded-full bg-[#f5f3ff] border border-[#c7c0fc] flex items-center justify-center">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                </div>
                <span class="font-mono text-[13px] font-medium text-[#374151] whitespace-nowrap">{name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ─── PAIN AGITATION ─── -->
    <section class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">The problem</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Buyers are landing on your competitor's blog.<br />Not your product pages.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            80% of purchase journeys start with a Google search — often a buying guide, comparison, or "how to choose" article. Without blog content, you're invisible at the most important moment.
          </p>
        </div>

        <div class="mx-auto mt-12 grid max-w-5xl grid-cols-1 gap-px bg-[#e7e5e4] overflow-hidden rounded-2xl border border-[#e7e5e4] md:grid-cols-3">
          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Your ad costs went up 40% last year. Your organic search revenue is still zero.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">CPCs are rising every year. A brand that depends entirely on paid ads is at the mercy of algorithm changes and auction competition. SEO blog content is the only channel that gets cheaper over time — an article that ranks for "best [product] under $50" captures buyer traffic for 3 years without another dollar spent.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">Buyers are Googling "best [your product category]" and landing on your competitor's blog.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">80% of purchase journeys start with a Google search — often a buying guide, comparison, or "how to choose" article. If your store doesn't have that content, the buyer finds it on a competitor's blog, gets influenced by their recommendations, and buys from them. You paid acquisition costs to be invisible at the most important moment.</p>
          </div>

          <div class="bg-white px-8 py-10">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-xl border border-[#fca5a5] bg-[#fff1f2]">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </div>
            <p class="font-sans text-[1rem] font-semibold text-[#111827]">You have product pages but no blog. Your competitor has 300 articles driving buyers to theirs.</p>
            <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#57534e]">Product pages rank for branded searches. Blog content ranks for problem-aware and solution-comparison searches — the "best yoga mat for beginners" and "bamboo vs cotton sheets" searches that happen before a buyer has decided where to buy. Without blog content, you're competing for a fraction of the available buyer traffic.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── SERVICES GRID ─── -->
    <section class="border-b border-[#e7e5e4] bg-white">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">What Stacc does for ecommerce brands</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            30 buyer-intent articles a month. Every lever that drives organic sales. Handled.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            Ranking for the buying guides and comparison articles your customers search requires consistent content publishing, keyword research, and CMS execution — every single month. Stacc handles all of it automatically.
          </p>
        </div>

        <div class="mx-auto mt-12 max-w-5xl grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              title: 'Blog Content Publishing',
              body: '30 buyer-intent articles published to your store every month — buying guides, product comparisons, how-to content, and category reviews. All targeted to searches that lead to purchases.',
              icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
            },
            {
              title: 'Ecommerce Keyword Research',
              body: 'Buyer-intent keywords for every stage of the purchase journey — awareness searches, comparison queries, and high-intent "best X for Y" terms that indicate a buyer is close to purchasing.',
              icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
            },
            {
              title: 'Product Category Content',
              body: 'Articles that rank for category + intent combinations — "best standing desk under $500," "ergonomic office chair comparison," and "how to choose a yoga mat." Captures buyers before they decide where to buy.',
              icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
            },
            {
              title: 'CMS Publishing',
              body: 'Direct publishing to Shopify, WooCommerce, BigCommerce, or your custom platform. No copy-pasting, no manual uploads. Articles go live on your store automatically, on schedule.',
              icon: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
            },
            {
              title: 'Internal Linking to Product Pages',
              body: 'Every article is internally linked to your most relevant product pages. Buyers reading a buying guide are guided naturally toward a purchase. Ranking articles also pass authority to your product pages.',
              icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
            },
            {
              title: 'Monthly Content Calendar',
              body: 'Monthly content calendar with keyword targets, search volume, buying stage, and priority scoring. You know exactly what is being published, why it is being targeted, and what buyer intent it captures.',
              icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
            },
          ].map(f => (
            <div class="bg-white px-7 py-8">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={f.icon}/>
                </svg>
              </div>
              <p class="mt-5 font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-[#292524]">{f.title}</p>
              <p class="mt-2 font-sans text-[13px] leading-[1.65] text-[#79716b]">{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─── HOW IT WORKS ─── -->
    <section id="how-it-works" class="border-b border-[#e7e5e4] bg-[#fafaf9]">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em] text-[#4f39f6]">How it works</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#111827] md:text-[2.4rem]">
            Connect once. 30 buyer-intent articles publish to your<br />store every month from there.
          </h2>
          <p class="mt-4 font-sans text-[1rem] leading-relaxed text-[#57534e]">
            No content briefs to write. No writers to manage. No manual Shopify uploads. Set it up once and your store's blog runs itself.
          </p>
        </div>

        <div class="mx-auto mt-14 max-w-5xl">
          <div class="grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-[#e7e5e4] bg-[#e7e5e4] md:grid-cols-3">
            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">01</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Connect your store and CMS</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Stacc audits your existing content, analyzes competitor blogs, and identifies the buyer-intent keyword gaps — the buying guides, comparison articles, and how-to content your customers search before they buy.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">02</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">AI researches and writes 30 buyer-intent articles</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">Each article targets a specific buying stage — awareness (what is X), consideration (best X for Y), and decision (X vs Y). Content is internally linked to your product pages so every article drives buyers toward a purchase.</p>
            </div>

            <div class="bg-white px-8 py-10">
              <div class="mb-6 flex items-center justify-between">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl border border-[#e7e5e4] bg-[#f5f3ff]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f39f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="font-mono text-[2.2rem] font-bold text-[#e7e5e4]">03</span>
              </div>
              <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.1em] text-[#292524]">Articles publish to your store. Rankings build. Sales increase.</p>
              <p class="mt-2 font-sans text-[14px] leading-[1.65] text-[#79716b]">30+ blog posts go live on your store every month. Rankings build over 3–6 months and compound. Organic traffic grows month over month. You capture buyers before they find your competitor — without paying for another click.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─── RESULTS METRICS ─── -->
    <section class="border-b border-[#e7e5e4]" style="background:#ffffff;">
      <div class="container-x py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.16em]" style="color:#818cf8;">By the numbers</span>
          <h2 class="mt-3 font-sans text-[1.9rem] font-semibold leading-[1.2] tracking-[-0.025em] text-[#292524] md:text-[2.4rem]">
