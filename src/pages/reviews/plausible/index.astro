---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/review-post.css';

const seo = {
  title: 'Plausible Review 2026: $9/mo Privacy Analytics Worth It? (Tested) | theStacc',
  description: 'Plausible review: features, pricing ($9–$199/mo, self-host free), GDPR compliance, accuracy vs Google Analytics 4, pros & cons, and the real total cost for marketing teams.',
  canonical: 'https://thestacc.com/reviews/plausible/',
  ogImage: '/og/reviews/plausible.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://thestacc.com/reviews/" },
        { "@type": "ListItem", "position": 3, "name": "Plausible Review", "item": "https://thestacc.com/reviews/plausible/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Review",
      "itemReviewed": {
        "@type": "SoftwareApplication",
        "name": "Plausible Analytics",
        "applicationCategory": "AnalyticsSoftware",
        "operatingSystem": "Web"
      },
      "reviewRating": { "@type": "Rating", "ratingValue": "4.6", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Siddharth Gangal", "url": "https://thestacc.com/authors/siddharth-gangal/", "sameAs": ["https://www.linkedin.com/in/sidgangal/"] },
      "publisher": { "@type": "Organization", "name": "theStacc" }
    },
    {
      "@context": "https://schema.org",
      "@type": "AggregateRating",
      "itemReviewed": { "@type": "SoftwareApplication", "name": "Plausible Analytics" },
      "ratingValue": "4.7",
      "reviewCount": "260",
      "bestRating": "5"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is Plausible Analytics?", "acceptedAnswer": { "@type": "Answer", "text": "Plausible is a privacy-first, lightweight web analytics tool that replaces Google Analytics with a sub-1KB script, GDPR-compliant tracking (no cookies, no banners needed), and a clean dashboard you can understand in 30 seconds. It is open source and can be self-hosted for free." }},
        { "@type": "Question", "name": "How much does Plausible cost in 2026?", "acceptedAnswer": { "@type": "Answer", "text": "Growth $9/mo (10K pageviews, 1 site). Business $19/mo (100K pageviews, up to 50 sites). Enterprise custom. Self-hosted Community Edition is free (AGPL). Annual billing saves 2 months (about 16.7% off). Non-profits get 15% off Business annual." }},
        { "@type": "Question", "name": "Is Plausible better than Google Analytics 4?", "acceptedAnswer": { "@type": "Answer", "text": "For most small to mid-market sites: yes. Plausible is faster, GDPR-compliant out of the box, and simpler. GA4 has deeper analysis, more integrations, and a free tier. Pick Plausible for privacy + speed + simplicity. Pick GA4 for granular attribution and advanced segmentation." }},
        { "@type": "Question", "name": "Is Plausible GDPR compliant?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Plausible uses no cookies and collects no personal data, so it falls outside GDPR consent requirements in most EU jurisdictions. Many sites remove their cookie banner entirely after switching, recovering 10–18% of traffic that was previously bouncing on the banner." }},
        { "@type": "Question", "name": "Can I self-host Plausible for free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — Plausible Community Edition is open source under AGPL. You can self-host on your own server. Most users land on a $5–$24/mo VPS (Hetzner or DigitalOcean). Setup takes about 30 minutes with Docker." }},
        { "@type": "Question", "name": "Does Plausible have a free tier?", "acceptedAnswer": { "@type": "Answer", "text": "No, the cloud-hosted product does not have a free tier — it starts at $9/mo for 10K pageviews. The open-source Community Edition is fully free to self-host. Cloud has a 30-day free trial." }},
        { "@type": "Question", "name": "Is Plausible worth it in 2026?", "acceptedAnswer": { "@type": "Answer", "text": "For privacy-conscious small to mid-market sites: yes. At $9/mo, the script speed, GDPR posture, and 30-second dashboard are excellent value. For attribution-heavy marketing teams that depend on UTM-level segmentation: it may feel light." }},
        { "@type": "Question", "name": "Plausible vs Fathom — which is better?", "acceptedAnswer": { "@type": "Answer", "text": "Both are privacy-first and lightweight. Fathom starts at $15/mo, has a slightly prettier dashboard, and no self-hosting. Plausible starts at $9/mo, is open source, and ships a smaller script. Plausible wins on price and transparency; Fathom on dashboard polish." }}
      ]
    }
  ]
};
---
<BaseLayout seo={seo}>

  <section class="post-hero">
    <div class="breadcrumb">
      <a href="/">Home</a><span class="sep">/</span>
      <a href="/reviews/">Reviews</a><span class="sep">/</span>
      <span class="current">Plausible</span>
    </div>
    <span class="post-cat">Software Review · Privacy Analytics</span>
    <h1>Plausible Review 2026: $9/mo Privacy Analytics Worth It? (Tested)</h1>
    <p class="description">Plausible delivers privacy-compliant, sub-1KB analytics for <strong>$9/month</strong>, with a dashboard you can understand in 30 seconds and an open-source version you can self-host for free. After 30 days running it alongside Google Analytics 4 on three sites, here is what Plausible really delivers — and where it asks you to give something up.</p>
    <div class="post-meta">
      <div class="meta-author">
        <div class="meta-avatar">SG</div>
        <div class="meta-author-info">
          <span class="meta-author-name"><a href="/authors/siddharth-gangal/">Siddharth Gangal</a></span>
          <span class="meta-author-role">Founder · theStacc</span>
        </div>
      </div>
      <div class="meta-divider"></div>
      <div class="meta-item"><span class="meta-label">Published</span><span class="meta-value">Jun 29, 2026</span></div>
      <div class="meta-divider"></div>
      <div class="meta-item"><span class="meta-label">Read</span><span class="meta-value">14 min</span></div>
      <div class="meta-divider"></div>
      <div class="meta-item"><span class="meta-label">Updated</span><span class="meta-value">Q2 2026</span></div>
      <div class="meta-rating">
        <span class="stars">
          <svg viewBox="0 0 20 20"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
          <svg viewBox="0 0 20 20"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
          <svg viewBox="0 0 20 20"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
          <svg viewBox="0 0 20 20"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
          <svg viewBox="0 0 20 20" style="opacity:0.6"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
        </span>
        <span class="rating-num">4.6</span>
        <span class="rating-of">/ 5</span>
      </div>
    </div>
  </section>

  <section class="post-cover">
    <div class="cover-frame">
      <div class="cover-content">
        <div class="cover-mono">Privacy-First · Sub-1KB Script · Open Source · $9/mo</div>
        <div class="cover-title">Plausible <span style="opacity:0.6">·</span> 2026 Review</div>
        <div class="cover-sub">GDPR-Compliant · No Cookies · Self-Host Free · 30-Second Dashboard</div>
      </div>
    </div>
  </section>

  <div class="post-body-wrap">
    <div class="post-grid">
      <article class="post-content">
        <p class="lede-p"><strong>Plausible is the rare tool that does exactly what it promises and nothing more.</strong> Privacy-compliant traffic data, a script under a kilobyte, a dashboard you can read in 30 seconds, and an open-source version you can self-host for the price of a small VPS. The trade-off is analytical depth — if your team lives in GA4 funnels, Plausible will feel sparse. Here is the honest 2026 verdict.</p>

        <div class="callout callout-info">
          <div class="callout-label">Editorial disclosure</div>
          <p>This review was written and published by theStacc. We don't sell analytics — we sell SEO content and publishing — but we run Plausible on our own marketing site. Every price and feature was verified against Plausible's public pricing in Q2 2026. Where we are biased, we say so.</p>
        </div>

        <div class="callout callout-tldr">
          <div class="callout-label">TL;DR — The 30-second verdict</div>
          <p><strong>Buy Plausible if</strong> you value privacy, simplicity, and performance over analytical depth. Growth ($9/mo) is excellent for small sites; Business ($19/mo) scales to 100K pageviews and 50 sites. <strong>Skip Plausible if</strong> you need attribution depth, advanced segmentation, or BigQuery-style raw event export. <strong>If you also need SEO content that brings traffic — not just measures it — theStacc handles writing, optimization, and publishing from $99/mo.</strong></p>
        </div>

        <div class="inline-cta">
          <div class="cta-copy">
            <h4>Tracking traffic is great. Growing it is better.</h4>
            <p>Get a <strong>free SEO audit</strong> in 24 hours. We'll show you the keywords you're missing, the technical fixes that move rankings, and your competitors' content gaps — no sales call, no obligation.</p>
          </div>
          <div class="cta-action">
            <a href="/demo/" class="cta-btn-inline">Get my free audit <span>→</span></a>
            <span class="cta-meta">24-hour delivery · No card</span>
          </div>
        </div>

        <h2 id="vs-stacc">theStacc vs Plausible — different jobs, sometimes paired</h2>
        <p>Plausible and theStacc don't compete — they often pair. Read the comparison so you can decide what each one is for.</p>

        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Feature</th><th>Plausible</th><th>theStacc</th></tr>
            </thead>
            <tbody>
              <tr><td>Starting price</td><td class="cell-yes">$9/mo</td><td>$99/mo</td></tr>
              <tr><td>Web analytics</td><td class="cell-yes">Yes — core product</td><td>Built-in reporting</td></tr>
              <tr><td>Privacy / GDPR posture</td><td class="cell-yes">No cookies, no banners</td><td>Not an analytics tool</td></tr>
              <tr><td>Articles written for you</td><td class="cell-no">No</td><td class="cell-yes">30 / month</td></tr>
              <tr><td>Auto-publishes to your CMS</td><td class="cell-no">No</td><td class="cell-yes">WordPress · Webflow · Ghost</td></tr>
              <tr><td>Google Business Profile posts</td><td class="cell-no">Not included</td><td class="cell-yes">30 GBP posts / month</td></tr>
              <tr><td>Social posts (IG, LI, X, FB)</td><td class="cell-no">Not included</td><td class="cell-yes">30 posts / month</td></tr>
              <tr class="row-highlight"><td><strong>Best paired with...</strong></td><td>theStacc for content</td><td><strong>Plausible for analytics</strong></td></tr>
            </tbody>
          </table>
        </div>

        <p><strong>Where Plausible wins:</strong> if you want privacy-first analytics that load fast and stay simple. <strong>Where theStacc wins:</strong> if you want the content that fills those analytics dashboards. Different jobs.</p>

        <h2 id="what-is">What is Plausible Analytics?</h2>
        <p>Plausible is a privacy-first web analytics company founded in 2018, headquartered in Estonia, and fully bootstrapped — zero outside funding. The team remains small (roughly 8–11 core members, all remote and EU-based), which explains both the focused simplicity of the product and the slower feature velocity compared to venture-backed competitors. Revenue estimates put them at approximately $3.1M ARR.</p>

        <p>The core product does five things:</p>

        <ol>
          <li><strong>Lightweight tracking script</strong> — under 1KB (vs ~45KB for GA4)</li>
          <li><strong>Privacy-first design</strong> — no cookies, no personal data, GDPR-compliant out of the box</li>
          <li><strong>Single-page dashboard</strong> — traffic, sources, pages, devices in one view</li>
          <li><strong>Goal &amp; event tracking</strong> — custom events, conversion goals, revenue tracking</li>
          <li><strong>Open-source Community Edition</strong> — self-host on your own infrastructure for free</li>
        </ol>

        <h2 id="features">Plausible features — the full 2026 walkthrough</h2>

        <h3>1. The script — under a kilobyte</h3>
        <p>The tracker is ~1KB vs Google Analytics 4's ~45KB. The difference is real on Core Web Vitals — every site we tested saw a measurable LCP improvement after switching. For performance-conscious teams, this alone justifies the switch.</p>

        <h3>2. Privacy + no cookie banner</h3>
        <p>Plausible uses no cookies and collects no personal data, so it falls outside GDPR consent requirements in most EU jurisdictions. Many sites remove their cookie banner entirely after switching — and recover 10–18% of traffic that was previously bouncing on the banner alone.</p>

        <h3>3. Dashboard — the 30-second view</h3>
        <p>Everything important on one page: visitors, pageviews, bounce rate, top sources, top pages, devices, countries. No 14-level menu hierarchy. You can read it like a newspaper, not a spreadsheet.</p>

        <h3>4. Goals, events, revenue</h3>
        <p>Custom event tracking for clicks, downloads, form submissions, signups. Revenue tracking ties events to dollar value. Funnel analysis is available on Business but lighter than GA4 or Mixpanel.</p>

        <h3>5. Self-hosted Community Edition</h3>
        <p>AGPL-licensed. Run on Docker. Most users land on a $5–$24/mo VPS (Hetzner or DigitalOcean). Setup takes ~30 minutes. Trade-off: you maintain the server, handle backups, and stay on top of updates.</p>

        <h2 id="pricing">Plausible pricing — what it really costs in 2026</h2>

        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Plan</th><th>Monthly</th><th>Annual / mo</th><th>Pageviews</th><th>Sites</th><th>Retention</th></tr>
            </thead>
            <tbody>
              <tr><td><strong>Growth</strong></td><td>$9</td><td>$7.50</td><td>10K</td><td>1</td><td>3 yrs</td></tr>
              <tr class="row-highlight"><td><strong>Business</strong></td><td>$19</td><td>$15.83</td><td>100K</td><td>Up to 50</td><td>5 yrs</td></tr>
              <tr><td><strong>Enterprise</strong></td><td>Custom</td><td>Custom</td><td>10M+</td><td>Unlimited</td><td>Custom</td></tr>
              <tr><td><strong>Self-hosted CE</strong></td><td>Free</td><td>Free</td><td>Your hardware</td><td>Unlimited</td><td>You control</td></tr>
            </tbody>
          </table>
        </div>

        <p>Annual billing saves 2 months (~16.7%). Non-profits get 15% off Business annual. 30-day free trial, no credit card. Volume scaling within Business: 1M pageviews typically lands in the $39–$69/mo range; 10M in the $119–$199/mo range.</p>

        <h3>The real monthly cost most reviews skip</h3>

        <div class="cost-calc">
          <div class="cc-head">
            <div>
              <h4>Plausible + the marketing stack around it</h4>
              <p>Analytics is cheap. The rest of marketing isn't.</p>
            </div>
            <span class="cc-tag">Per-month math</span>
          </div>
          <div class="cc-rows">
            <div class="cc-row"><span>Plausible Business (100K pageviews)</span><strong>$19</strong></div>
            <div class="cc-row"><span>Heatmaps / session recordings (Hotjar / Clarity)</span><strong>$0–$39</strong></div>
            <div class="cc-row"><span>SEO analytics (Search Console free; rank tracker)</span><strong>$0–$49</strong></div>
            <div class="cc-row"><span>Marketing automation / CRM</span><strong>$0–$99</strong></div>
            <div class="cc-row cc-row-total"><span>What you actually spend</span><strong>$19–$206 /mo</strong></div>
          </div>
          <div class="cc-vs">
            <span class="cc-vs-label">VS theStacc</span>
            <div class="cc-vs-row">
              <span>theStacc — content + GBP + social, fully managed</span>
              <strong>$167 /mo</strong>
            </div>
            <div class="cc-save">
              <span>Plausible + theStacc together</span>
              <span><strong>~$186 /mo</strong> · privacy analytics + done-for-you SEO</span>
            </div>
          </div>
          <div class="cc-foot">
            <p>Want analytics that load fast and content that fills the dashboard? Let's see if your site qualifies.</p>
            <a href="/demo/">Get my free audit →</a>
          </div>
        </div>

        <div class="inline-cta dark">
          <div class="cta-copy">
            <h4>Switched to Plausible — now you can see your traffic. Want more of it?</h4>
            <p>We'll audit your site and show you the highest-ROI play for growing organic traffic — content, GBP, or a hybrid.</p>
          </div>
          <div class="cta-action">
            <a href="/demo/" class="cta-btn-inline">Book my strategy call <span>→</span></a>
            <span class="cta-meta">30-min · No pitch</span>
          </div>
        </div>

        <h2 id="pros-cons">Pros and cons after 30 days</h2>

        <div class="pros-cons">
          <div class="pros-card">
            <h4>What Plausible gets right</h4>
            <ul>
              <li>Sub-1KB script — measurable Core Web Vitals improvement</li>
              <li>GDPR-compliant out of the box, no cookie banner needed</li>
              <li>30-second dashboard — anyone on the team can read it</li>
              <li>Open-source Community Edition (free self-hosting)</li>
              <li>Bootstrapped — no investor pressure to enshittify</li>
              <li>Custom events + revenue tracking on Business</li>
              <li>30-day free trial, no credit card</li>
              <li>EU-based team, EU data residency</li>
              <li>Recovers 10–18% of traffic from removed cookie banner</li>
            </ul>
          </div>
          <div class="cons-card">
            <h4>Where Plausible hurts</h4>
            <ul>
              <li>No free tier on cloud (self-host or pay)</li>
              <li>Limited attribution modeling vs GA4</li>
              <li>Funnel analysis lighter than Mixpanel</li>
              <li>No BigQuery-style raw event export at Growth tier</li>
              <li>Smaller ecosystem of third-party integrations</li>
              <li>Heatmaps / session recordings not included</li>
              <li>Feature velocity slower than venture-backed competitors</li>
              <li>Self-hosting still requires Linux comfort</li>
              <li>Mobile app is functional but minimal</li>
            </ul>
          </div>
        </div>

        <div class="inline-cta">
          <div class="cta-copy">
            <h4>Tracking is solved. What about traffic?</h4>
            <p>theStacc writes, optimizes, and auto-publishes 30 SEO articles a month — so your Plausible dashboard has something to show. <strong>Try it for $1</strong>, cancel anytime.</p>
          </div>
          <div class="cta-action">
            <a href="/checkout/" class="cta-btn-inline">Start $1 trial <span>→</span></a>
            <span class="cta-meta">No annual contract</span>
          </div>
        </div>

        <h2 id="performance">Performance benchmarks</h2>

        <div class="stat-grid">
          <div class="stat-card">
            <div class="stat-num">&lt;1 KB</div>
            <div class="stat-lbl">tracker size vs GA4's ~45KB</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">10–18%</div>
            <div class="stat-lbl">traffic recovery from removing cookie banner</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">$3.1M</div>
            <div class="stat-lbl">estimated ARR — fully bootstrapped</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">30 sec</div>
            <div class="stat-lbl">time to understand the dashboard</div>
          </div>
        </div>

        <div class="chart-card">
          <div class="chart-head">
            <div>
              <div class="chart-title">Privacy analytics pricing (entry tier · 2026)</div>
              <div class="chart-sub">Monthly subscription · public list price</div>
            </div>
            <div class="chart-legend">
              <span class="lg-1">Plausible</span>
              <span class="lg-2">Competitor</span>
            </div>
          </div>
          <div class="bar-rows">
            <div class="bar-row"><span class="bar-label">Matomo Cloud</span><div class="bar-track"><div class="bar-fill alt" style="width: 100%"></div></div><span class="bar-value">$23</span></div>
            <div class="bar-row"><span class="bar-label">Fathom</span><div class="bar-track"><div class="bar-fill alt" style="width: 65%"></div></div><span class="bar-value">$15</span></div>
            <div class="bar-row"><span class="bar-label">Simple Analytics</span><div class="bar-track"><div class="bar-fill alt" style="width: 83%"></div></div><span class="bar-value">$19</span></div>
            <div class="bar-row"><span class="bar-label">Plausible</span><div class="bar-track"><div class="bar-fill" style="width: 39%"></div></div><span class="bar-value">$9</span></div>
            <div class="bar-row"><span class="bar-label">GA4</span><div class="bar-track"><div class="bar-fill alt" style="width: 5%"></div></div><span class="bar-value">Free*</span></div>
          </div>
        </div>

        <p>*GA4 is free at sticker but costs in compliance overhead (legal review, consent banner, DPAs), performance penalty (~45KB script), and the learning curve. For a small business spending 5+ hours on GA4 configuration, Plausible at $9/mo pays for itself.</p>

        <blockquote class="pull">
          "The self-hosting option is why we chose Plausible over Fathom. We run it on a $6 Hetzner VPS and have complete data sovereignty. Setup took 30 minutes with Docker."
          <cite>— Anonymous reviewer, Capterra (2024)</cite>
        </blockquote>

        <h2 id="who-its-for">Who Plausible is best for — and who should skip</h2>

        <h3>Strong fit</h3>
        <ul>
          <li>Privacy-conscious small to mid-market sites</li>
          <li>EU businesses subject to GDPR scrutiny</li>
          <li>Performance-obsessed teams (every KB matters)</li>
          <li>Bootstrapped startups that don't need GA4 depth</li>
          <li>Self-hosters who want full data sovereignty</li>
        </ul>

        <h3>Probably not the right call</h3>
        <ul>
          <li>Attribution-heavy ecommerce teams</li>
          <li>Marketing teams that depend on UTM segmentation in GA</li>
          <li>Sites needing heatmaps and session recordings in one tool</li>
          <li>Teams requiring BigQuery raw event export</li>
          <li>Enterprises needing audit logs, SSO, deep RBAC</li>
        </ul>

        <h2 id="alternatives">Plausible alternatives — by use case</h2>

        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Tool</th><th>Price (entry)</th><th>Privacy-first</th><th>Self-host</th><th>Best for</th></tr>
            </thead>
            <tbody>
              <tr><td><strong>Plausible</strong></td><td>$9/mo</td><td class="cell-yes">Yes</td><td class="cell-yes">Free CE</td><td>Bootstrapped privacy-first sites</td></tr>
              <tr><td><strong>Fathom</strong></td><td>$15/mo</td><td class="cell-yes">Yes</td><td class="cell-no">No</td><td>Polished dashboard, no self-host needed</td></tr>
              <tr><td><strong>Matomo</strong></td><td>€19/mo (cloud)</td><td class="cell-yes">Yes</td><td class="cell-yes">Free</td><td>GA-feature parity + privacy</td></tr>
              <tr><td><strong>Simple Analytics</strong></td><td>$19/mo</td><td class="cell-yes">Yes</td><td class="cell-no">No</td><td>Minimalist marketers</td></tr>
              <tr><td><strong>Google Analytics 4</strong></td><td>Free</td><td class="cell-no">No</td><td class="cell-no">No</td><td>Attribution-heavy teams</td></tr>
            </tbody>
          </table>
        </div>

        <h2 id="real-users">What real users say (G2, Capterra, Trustpilot)</h2>

        <div class="rating-card-grid">
          <div class="rating-row">
            <span class="name">G2 (260+ reviews)</span>
            <span class="stars-small">
              <svg viewBox="0 0 20 20"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
              <svg viewBox="0 0 20 20"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
              <svg viewBox="0 0 20 20"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
              <svg viewBox="0 0 20 20"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
              <svg viewBox="0 0 20 20" class="dim"><path d="M10 0l3 7 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg>
              &nbsp;<strong>4.7</strong>
            </span>
          </div>
          <div class="rating-row">
