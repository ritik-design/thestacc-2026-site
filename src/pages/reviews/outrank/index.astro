      "@type": "AggregateRating",
      "itemReviewed": { "@type": "SoftwareApplication", "name": "Outrank.so" },
      "ratingValue": "4.3",
      "reviewCount": "95",
      "bestRating": "5"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is Outrank.so?", "acceptedAnswer": { "@type": "Answer", "text": "Outrank.so is an automated blog SEO platform that writes, optimizes, and publishes articles directly to your CMS. The Standard plan is $99/month for 30 articles auto-published. CMS support includes WordPress, Shopify, Notion, Wix, and Framer." }},
