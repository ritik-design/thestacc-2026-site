        { "@type": "Question", "name": "Frase vs Surfer SEO — which is better?", "acceptedAnswer": { "@type": "Answer", "text": "Frase has the better brief builder. Surfer has the better content optimization score (0.28 ranking correlation vs Frase's 0.10). Most professional teams use both — Frase for research, Surfer for scoring." }},
        { "@type": "Question", "name": "Does Frase offer a free trial?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Frase offers a 5-day trial for $1. Full feature access. You can cancel before the trial ends without further charges." }},
