---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const seo = {
  title: 'SEO software reviews — 43 honest verdicts · theStacc',
  description: 'In-depth SEO software reviews — Ahrefs, Semrush, Surfer, Jasper, Frase, Clearscope, Copy.ai, Scalenut, and more. Honest verdicts from a daily user.',
  canonical: 'https://thestacc.com/reviews/',
  ogImage: '/og/reviews.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "theStacc SEO reviews",
    "url": "https://thestacc.com/reviews/"
  }
};

const reviewsDir = path.resolve('./src/pages/reviews');
const slugs = fs.readdirSync(reviewsDir, { withFileTypes: true })
  .filter(d => d.isDirectory())
  .map(d => d.name)
  .sort();

const SLUG_META = {
  'ahrefs': { name: 'Ahrefs', price: '$129/mo', rating: 4.3, category: 'SEO Platforms' },
  'aioseo': { name: 'AIOSEO', price: '$49/yr', rating: 4.4, category: 'WordPress SEO' },
  'aiseo': { name: 'AISEO', price: '$15/mo', rating: 4.0, category: 'AI Writers' },
  'anyword': { name: 'Anyword', price: '$39/mo', rating: 4.1, category: 'AI Writers' },
  'brandwell': { name: 'BrandWell', price: '$49/mo', rating: 4.0, category: 'AI Writers' },
  'clearscope': { name: 'Clearscope', price: '$170/mo', rating: 4.5, category: 'Content Optimization' },
  'copy-ai': { name: 'Copy.ai', price: '$49/mo', rating: 3.9, category: 'AI Writers' },
  'deepcrawl': { name: 'DeepCrawl', price: '$30k/yr', rating: 4.4, category: 'Technical SEO' },
  'frase': { name: 'Frase', price: '$45/mo', rating: 4.4, category: 'Content Optimization' },
  'gptzero': { name: 'GPTZero', price: '$15/mo', rating: 4.0, category: 'AI Detectors' },
  'grammarly': { name: 'Grammarly', price: '$30/mo', rating: 4.7, category: 'Writing & Editing' },
  'jasper-ai': { name: 'Jasper', price: '$59/mo', rating: 4.1, category: 'AI Writers' },
  'junia-ai': { name: 'Junia AI', price: '$29/mo', rating: 4.0, category: 'AI Writers' },
  'koala-ai': { name: 'Koala AI', price: '$25/mo', rating: 4.0, category: 'AI Writers' },
  'longshot': { name: 'Longshot', price: '$19/mo', rating: 4.1, category: 'AI Writers' },
  'machined': { name: 'Machined', price: '$99/mo', rating: 4.0, category: 'AI Writers' },
  'majestic': { name: 'Majestic', price: '$50/mo', rating: 4.4, category: 'SEO Platforms' },
  'mangools': { name: 'Mangools', price: '$49/mo', rating: 4.5, category: 'SEO Platforms' },
  'marketmuse': { name: 'MarketMuse', price: '$149/mo', rating: 4.3, category: 'Content Optimization' },
  'moz': { name: 'Moz', price: '$99/mo', rating: 4.2, category: 'SEO Platforms' },
  'neuronwriter': { name: 'NeuronWriter', price: '$23/mo', rating: 4.4, category: 'Content Optimization' },
  'nightwatch': { name: 'Nightwatch', price: '$39/mo', rating: 4.3, category: 'Rank Tracking' },
  'originality-ai': { name: 'Originality.ai', price: '$15/mo', rating: 4.2, category: 'AI Detectors' },
  'outrank': { name: 'Outrank', price: '$99/mo', rating: 4.1, category: 'AI Writers' },
  'outranking': { name: 'Outranking', price: '$29/mo', rating: 4.2, category: 'Content Optimization' },
  'plausible': { name: 'Plausible', price: '$9/mo', rating: 4.6, category: 'Analytics' },
  'prowritingaid': { name: 'ProWritingAid', price: '$10/mo', rating: 4.2, category: 'Writing & Editing' },
  'quillbot': { name: 'QuillBot', price: '$5/mo', rating: 4.1, category: 'Writing & Editing' },
  'rankability': { name: 'Rankability', price: '$49/mo', rating: 4.3, category: 'Content Optimization' },
  'rankmath': { name: 'RankMath', price: '$8/mo', rating: 4.7, category: 'WordPress SEO' },
  'scalenut': { name: 'Scalenut', price: '$59/mo', rating: 4.3, category: 'AI Writers' },
  'screaming-frog': { name: 'Screaming Frog', price: '£239/yr', rating: 4.5, category: 'Technical SEO' },
  'se-ranking': { name: 'SE Ranking', price: '$55/mo', rating: 4.4, category: 'SEO Platforms' },
  'semrush': { name: 'Semrush', price: '$139/mo', rating: 4.5, category: 'SEO Platforms' },
  'seo-ai': { name: 'SEO.AI', price: '$149/mo', rating: 4.2, category: 'AI Writers' },
  'seo-ai-review': { name: 'SEO.AI (Detailed)', price: '$149/mo', rating: 4.2, category: 'AI Writers' },
  'serpstat': { name: 'Serpstat', price: '$69/mo', rating: 4.3, category: 'SEO Platforms' },
  'spyfu': { name: 'SpyFu', price: '$39/mo', rating: 4.0, category: 'SEO Platforms' },
  'surfer-seo': { name: 'Surfer SEO', price: '$119/mo', rating: 4.3, category: 'Content Optimization' },
  'ubersuggest': { name: 'Ubersuggest', price: '$29/mo', rating: 4.1, category: 'SEO Platforms' },
  'wordtune': { name: 'Wordtune', price: '$10/mo', rating: 4.3, category: 'Writing & Editing' },
  'writesonic': { name: 'Writesonic', price: '$49/mo', rating: 4.1, category: 'AI Writers' },
  'yoast-seo': { name: 'Yoast SEO', price: '$99/yr', rating: 4.6, category: 'WordPress SEO' }
};

const titleize = (slug) => slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

const reviews = slugs.map(slug => {
  const meta = SLUG_META[slug] || { name: titleize(slug), price: '—', rating: 4.2, category: 'Other' };
  return { slug, ...meta };
});

const categories = ['All', ...new Set(reviews.map(r => r.category))].sort((a, b) => a === 'All' ? -1 : b === 'All' ? 1 : a.localeCompare(b));
const totalCount = reviews.length;

const Stars = (r) => {
  const full = Math.floor(r);
  const half = r - full >= 0.5;
  return Array.from({ length: 5 }, (_, i) => i < full ? '★' : (i === full && half ? '½' : '☆')).join('');
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Reviews · {totalCount} software verdicts</span>
    <h1 class="h-display">{totalCount} in-depth <span class="accent">SEO software reviews.</span></h1>
    <p class="hero-sub">Daily-user verdicts on every major SEO platform. Pros, cons, pricing, and a 1-sentence verdict — plus where each tool wins against theStacc.</p>
    <div class="hero-ctas">
      <a href="/reviews/ahrefs/" class="btn btn-primary"><span>Most popular: Ahrefs review <span class="arrow">→</span></span></a>
      <a href="/alternatives/" class="btn btn-secondary">See alternatives</a>
    </div>
  </section>

  <!-- CATEGORY PILLS -->
  <section style="padding: 32px; background: white; border-bottom: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;">
      {categories.map((c, i) => (
        <button class="cat-pill label-pill" data-cat={c} style={i === 0 ? 'background: var(--brand-softer); border-color: var(--brand-soft);' : ''}>{c}</button>
      ))}
    </div>
  </section>

  <!-- REVIEWS GRID -->
  <section style="padding: 64px 32px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div class="reviews-grid">
        {reviews.map((r) => (
          <a href={`/reviews/${r.slug}/`} class="review-card" data-cat={r.category}>
            <div class="review-card-head">
              <div>
                <h3 class="review-name">{r.name}</h3>
                <div class="review-price">{r.price}</div>
              </div>
              <div class="review-rating">
                <div class="review-rating-num">{r.rating}</div>
                <div class="review-stars">{Stars(r.rating)}</div>
              </div>
            </div>
            <span class="review-cat">{r.category}</span>
            <span class="review-cta">Read the full review <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
      <div class="reviews-empty" style="display: none; text-align: center; padding: 80px 20px; color: var(--text-3);">No reviews in this category yet.</div>
    </div>
  </section>

  <!-- LITE FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Read the reviews. <span class="accent">Then try theStacc.</span></h2>
        <p class="final-sub">$1 for 30 days. Replaces 3 of these tools.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    .reviews-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    @media (max-width: 1100px) { .reviews-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 800px) { .reviews-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .reviews-grid { grid-template-columns: 1fr; } }
    .review-card { display: flex; flex-direction: column; gap: 14px; padding: 24px; background: white; border: 1px solid var(--border); transition: all 0.18s; text-decoration: none; color: inherit; min-height: 180px; }
    .review-card:hover { transform: translateY(-2px); border-color: var(--brand); box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18); }
    .review-card-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
    .review-name { font-size: 17px; font-weight: 600; color: var(--text-1); letter-spacing: -0.015em; margin: 0 0 4px; }
    .review-price { font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); letter-spacing: 0.04em; }
    .review-rating { text-align: right; flex-shrink: 0; }
    .review-rating-num { font-size: 17px; font-weight: 700; color: var(--text-1); letter-spacing: -0.02em; }
    .review-stars { color: #f59e0b; font-size: 11px; letter-spacing: 0.05em; }
    .review-cat { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); font-weight: 600; }
    .review-cta { font-size: 13px; color: var(--brand); font-weight: 600; margin-top: auto; }
    .cat-pill { cursor: pointer; user-select: none; transition: all 0.15s; border: 1px solid var(--border); background: white; }
    .cat-pill:hover { border-color: var(--brand); color: var(--brand); }
    .cat-pill.active { background: var(--brand-softer) !important; border-color: var(--brand-soft) !important; color: var(--brand); }
    .review-card.hidden { display: none; }
  </style>

  <script is:inline>
    const pills = document.querySelectorAll('.cat-pill');
    const cards = document.querySelectorAll('.review-card');
    const empty = document.querySelector('.reviews-empty');
    pills.forEach(p => p.addEventListener('click', () => {
      const cat = p.getAttribute('data-cat');
      pills.forEach(x => x.classList.toggle('active', x === p));
      let visible = 0;
      cards.forEach(c => {
        const show = cat === 'All' || c.getAttribute('data-cat') === cat;
        c.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
    }));
    if (pills[0]) pills[0].classList.add('active');
  </script>
</BaseLayout>
