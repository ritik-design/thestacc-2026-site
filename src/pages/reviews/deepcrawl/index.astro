              <tr><td>Content writing + publishing</td><td class="cell-no">No</td><td class="cell-yes">30 articles/mo, auto-publish</td></tr>
              <tr><td>Google Business Profile</td><td class="cell-no">No</td><td class="cell-yes">Included</td></tr>
              <tr><td>Rank tracking</td><td class="cell-no">No</td><td class="cell-yes">Included</td></tr>
