              <div class="chart-sub">Same 2.3M-URL JavaScript-heavy ecommerce site · Q2 2026</div>
            </div>
            <div class="chart-legend">
              <span class="lg-1">DeepCrawl</span>
              <span class="lg-2">Competitor</span>
            </div>
          </div>
          <div class="bar-rows">
            <div class="bar-row"><span class="bar-label">DeepCrawl (Lumar)</span><div class="bar-track"><div class="bar-fill" style="width: 100%"></div></div><span class="bar-value">2.3M</span></div>
            <div class="bar-row"><span class="bar-label">OnCrawl</span><div class="bar-track"><div class="bar-fill alt" style="width: 95%"></div></div><span class="bar-value">2.2M</span></div>
