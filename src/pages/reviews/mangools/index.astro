  ogImage: '/og/reviews/mangools.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://thestacc.com/reviews/" },
        { "@type": "ListItem", "position": 3, "name": "Mangools Review", "item": "https://thestacc.com/reviews/mangools/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Review",
      "itemReviewed": { "@type": "SoftwareApplication", "name": "Mangools", "applicationCategory": "SEOSoftware", "operatingSystem": "Web" },
      "reviewRating": { "@type": "Rating", "ratingValue": "4.4", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Siddharth Gangal", "url": "https://thestacc.com/authors/siddharth-gangal/", "sameAs": ["https://www.linkedin.com/in/sidgangal/"] },
      "publisher": { "@type": "Organization", "name": "theStacc" }
    },
    {
      "@context": "https://schema.org",
      "@type": "AggregateRating",
      "itemReviewed": { "@type": "SoftwareApplication", "name": "Mangools" },
      "ratingValue": "4.6", "reviewCount": "340", "bestRating": "5"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is Mangools?", "acceptedAnswer": { "@type": "Answer", "text": "Mangools is a 5-tool SEO suite — KWFinder, SERPChecker, SERPWatcher, LinkMiner, and SiteProfiler — built for beginners, bloggers, and small agencies. Started as KWFinder in 2014 by Peter Hrbáčik in Bratislava, the suite launched in 2016 and now serves 1.1M+ users in 160+ countries." }},
