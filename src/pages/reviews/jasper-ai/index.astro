        { "@type": "ListItem", "position": 3, "name": "Jasper AI Review", "item": "https://thestacc.com/reviews/jasper-ai/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Review",
      "itemReviewed": {
        "@type": "SoftwareApplication",
        "name": "Jasper AI",
        "applicationCategory": "BusinessApplication",
