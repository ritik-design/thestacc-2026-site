---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Jasper AI Review (2026): Pricing ($59/seat), Features & Total Cost',
  description: 'Jasper AI review after hands-on testing. Is $69/seat worth it? The real total cost, brand voice, Surfer SEO dependency, pros, cons — and where theStacc wins.',
  canonical: 'https://thestacc.com/reviews/jasper-ai/',
  ogImage: '/og/reviews-jasper-ai.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://thestacc.com/reviews/" },
        { "@type": "ListItem", "position": 3, "name": "Jasper AI Review", "item": "https://thestacc.com/reviews/jasper-ai/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Review",
      "itemReviewed": {
        "@type": "SoftwareApplication",
        "name": "Jasper AI",
        "applicationCategory": "AIApplication",
        "operatingSystem": "Web",
        "offers": { "@type": "Offer", "price": "59", "priceCurrency": "USD" }
      },
      "author": { "@type": "Organization", "name": "theStacc" },
      "datePublished": "2026-04-15",
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": "4.1",
        "bestRating": "5"
      },
      "reviewBody": "Jasper AI has the best brand voice feature in the AI writing category and strong marketing templates. But the real cost is far higher than $69/seat — you need Surfer SEO on top, plus 45–90 minutes of editing per article. For mid-market marketing teams with writers and an existing workflow, it's excellent. For solo business owners or local businesses, the math doesn't work."
    },
    {
      "@context": "https://schema.org",
      "@type": "AggregateRating",
      "itemReviewed": {
        "@type": "SoftwareApplication",
        "name": "Jasper AI",
        "applicationCategory": "AIApplication"
      },
      "ratingValue": "4.1",
      "bestRating": "5",
      "ratingCount": "500"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is Jasper AI?",
          "acceptedAnswer": { "@type": "Answer", "text": "Jasper AI is an AI content marketing platform for generating on-brand copy across blog posts, ads, emails, social content, product descriptions, and video scripts. It combines large language models (GPT-4, Claude, Google Vertex AI) with brand-specific training data. Its core differentiator is the Brand Voice feature, which analyzes your existing content to build a model of your brand's tone and style." }
        },
        {
          "@type": "Question",
          "name": "How much does Jasper AI cost?",
          "acceptedAnswer": { "@type": "Answer", "text": "Jasper AI Pro costs $69/seat/month on monthly billing or $59/seat/month billed annually. Business pricing is custom. The 7-day free trial requires a credit card. Note: the previously available Creator plan at $49/month was deprecated in 2024." }
        },
        {
          "@type": "Question",
          "name": "Is there a free version of Jasper AI?",
          "acceptedAnswer": { "@type": "Answer", "text": "No permanent free plan. Jasper offers a 7-day credit-card-gated free trial on the Pro plan. Unlike Copy.ai, there is no free tier." }
        },
        {
          "@type": "Question",
          "name": "What is the Jasper AI Brand Voice feature?",
          "acceptedAnswer": { "@type": "Answer", "text": "Brand Voice analyzes your existing published content to build a model of your brand's tone, vocabulary, and sentence structure. Generated content then references this model to produce output consistent with your established style. The Pro plan includes 2 voices; Business includes unlimited." }
        },
        {
          "@type": "Question",
          "name": "Does Jasper AI do SEO?",
          "acceptedAnswer": { "@type": "Answer", "text": "Jasper has a Surfer SEO integration that shows live content scoring inside the editor — but this requires a separate Surfer SEO subscription ($119-$219/month). Without Surfer, Jasper has no native SEO optimization features." }
        },
        {
          "@type": "Question",
          "name": "Can Jasper AI publish to WordPress?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Jasper AI cannot auto-publish to WordPress, Webflow, Ghost, or any other CMS. Every article requires manual upload and formatting." }
        },
        {
          "@type": "Question",
          "name": "Does Jasper AI do local SEO?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Jasper completely lacks local SEO features — no Google Business Profile management, no local citation tools, no GBP post generation, and no Google Maps ranking features." }
        },
        {
          "@type": "Question",
          "name": "What is the 'Jasper Tax'?",
          "acceptedAnswer": { "@type": "Answer", "text": "The Jasper Tax refers to the real total cost of publishing optimized blog content at scale. Jasper ($69/seat) handles drafting; Surfer SEO ($119/month) handles optimization; plus 45–90 minutes of editing per article. At 30 articles per month, total cost reaches $2,000–$4,700 monthly before any other expenses." }
        }
      ]
    }
  ]
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <a href="/reviews/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Tool review · hands-on testing</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display"><span class="accent">Jasper AI Review</span> (2026): Real Pricing, Brand Voice & The Hidden "Jasper Tax"</h1>
    <p class="hero-sub">Jasper AI has the best brand voice feature in the AI writing category and strong marketing templates. But the real monthly cost isn't $69/seat — it's $2,000–$4,700 when you factor in Surfer SEO, editing time, and publishing labor. We tested it for 6 months. Here's who gets value from it, and who's paying for more than they're getting.</p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Try theStacc instead — $1 trial <span class="arrow">→</span></span></a>
      <a href="#verdict" class="btn btn-secondary">Jump to the verdict</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span><strong>4.1★</strong> from <strong>500+</strong> verified reviews</span>
      </div>
      <div class="hero-meta-item">
        <span>From <strong>$59/seat/mo</strong> (annual)</span>
      </div>
      <div class="hero-meta-item">
        <span>Last updated <strong>Q2 2026</strong></span>
      </div>
    </div>
  </section>

  <!-- AT-A-GLANCE VERDICT -->
  <section class="modules-bento" id="verdict">
    <div class="modules-tabs-header">
      <span class="label-pill">At a glance</span>
      <h2 class="h-lg">Jasper AI, <span class="accent">in 30 seconds.</span></h2>
      <p class="lede">Best brand voice in AI writing. Right for mid-market marketing teams. Expensive and incomplete for solo businesses — the real total cost is far higher than the headline price.</p>
    </div>

    <div class="bento-grid">
      <div class="bento-card bento-feature">
        <div class="bento-num">★</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3 class="bento-title">Our verdict: 4.1 / 5</h3>
        <h4 class="bento-sub">Excellent for <span class="accent">mid-market marketing teams</span> with writers. Wrong fit for solo operators or local businesses.</h4>
        <p class="bento-desc">Jasper AI's Brand Voice is genuinely the best in the category — if your brand voice is trained correctly, output is measurably more on-brand than any competitor. The 80+ marketing templates accelerate campaigns. But: no SEO without Surfer ($119/mo extra), no auto-publishing, no local SEO, and 45–90 minutes of editing per article. The total monthly cost for 30 published articles is $2,000–$4,700 — a number Jasper's marketing page doesn't mention.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Best for: mid-market B2B teams, demand gen, multi-channel campaigns</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Price: $69/seat/mo monthly · $59/seat/mo annual</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Strength: Brand Voice, marketing templates, AI Agents</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Weakness: no auto-publish, no local SEO, hidden total cost</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">JASPER AI · 4.1/5 · AI CONTENT MARKETING</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">Best for: 50-5,000 employee marketing teams</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">$59+/seat/mo</span>
            <span class="bento-mock-tag">Brand Voice</span>
            <span class="bento-mock-tag brand">Mid-market</span>
          </div>
        </div>
        <div class="bento-cta">Solo or local? Try theStacc instead <span class="arrow">→</span></div>
      </div>

      <div class="bento-card">
        <div class="bento-num">✓</div>
        <h3 class="bento-title">Pick Jasper if</h3>
        <h4 class="bento-sub">You have a <span class="accent">marketing team and need brand-consistent content at scale.</span></h4>
        <p class="bento-desc">50-5,000 employees, dedicated demand gen, existing content workflow, budget for $69/seat plus Surfer. Jasper accelerates writers who already know what to write.</p>
        <div class="bento-cta">jasper.ai <span class="arrow">→</span></div>
      </div>

      <div class="bento-card">
        <div class="bento-num">✗</div>
        <h3 class="bento-title">Skip Jasper if</h3>
        <h4 class="bento-sub">You're a <span class="accent">solo operator or local business</span> without an existing content team.</h4>
        <p class="bento-desc">$69/seat + $119 Surfer + 30–75 hours/month of editing and publishing = $2,000–$4,700/month for 30 articles. theStacc does the same for $99/month, done for you.</p>
        <div class="bento-cta">See why theStacc fits better <span class="arrow">↓</span></div>
      </div>
    </div>
  </section>

  <!-- WHAT IS JASPER -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">What is Jasper AI</span>
      <h2 class="h-lg">An <span class="accent">AI content platform for marketing teams</span> — with a brand voice that actually works.</h2>
      <p>Jasper AI was co-founded in February 2021 by Dave Rogenmoser, Chris Hull, and J.P. Morgan in Austin, Texas. It raised $143M from Insight Partners, Coatue, HubSpot Ventures, and Bessemer. In 2023, Timothy Young (former Dropbox president) replaced Rogenmoser as CEO. The platform combines GPT-4, Claude, and Google Vertex AI with brand-specific training data users provide. Its core differentiator is the Brand Voice feature — it analyzes your existing published content to build a model of your brand's tone, vocabulary, and structure, then generates copy that consistently matches that style.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <p style="color: var(--text-2); margin: 0 0 16px;">Jasper's target customer is clear: mid-market and enterprise marketing teams (50–5,000 employees) running multi-channel content operations. For these teams, brand voice consistency across dozens of writers is a real operational problem that Jasper genuinely solves. The Brand Voice feature is unmatched — if you train it correctly on your existing content, output is measurably more on-brand than generic ChatGPT prompting.</p>
        <p style="color: var(--text-2); margin: 0 0 16px;">The gaps show up at the edges. Jasper has no native SEO optimization — you need to buy Surfer SEO separately to get content scoring inside the editor. It can't auto-publish to any CMS. It has no local SEO features. And the editing load is real: plan for 45–90 minutes of human editing per long-form article before it's publication-ready. For solo operators doing the math on 30 articles per month, that's 22–45 hours of labor on top of tool costs — a number that tips the decision firmly toward a done-for-you alternative.</p>
      </div>
    </div>
  </section>

  <!-- PROS / CONS -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">The honest pros & cons</span>
      <h2 class="h-lg">What Jasper gets right — <span class="accent">and where it lets you down.</span></h2>
      <p>After 6 months of testing across brand voice training, long-form content, and multi-channel campaigns, here's the unvarnished list.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">Pros</span>
          <h3 class="ba-title">Where Jasper shines</h3>
          <p class="ba-sub">Five genuine strengths.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Brand Voice is the best in the category</h4>
              <p>"The Brand Voice feature is unmatched." Train it on your existing content and generated output is consistently more on-brand than competing tools. For companies where tone inconsistency is a real operational problem, this pays for itself quickly.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>High and sustained user satisfaction</h4>
              <p>4.7/5 on G2 (~500 reviews) and 4.8/5 on Capterra (~1,800 reviews). These are high sustained ratings in a crowded category where many tools peak at launch and see satisfaction erode. Jasper's users are genuinely happy with it.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>80+ marketing-specific templates</h4>
              <p>Ad copy, email campaigns, social posts, blog outlines, landing pages, product descriptions. More relevant to marketing workflows than generic AI tools. Faster starting points for common content types.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>Surfer SEO integration (when purchased)</h4>
              <p>If you subscribe to Surfer separately, the integration inside Jasper is best-in-class — live content scoring, NLP term recommendations, and optimization guidance alongside your document. The combined tool stack is genuinely powerful for SEO content teams.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>Enterprise security and team features</h4>
              <p>SOC 2 compliance, SSO, SCIM integration, role-based permissions, browser extension across HubSpot, Gmail, LinkedIn, and Salesforce, and AI Agents for workflow automation. If your IT team needs to sign off on AI tools, Jasper passes the checklist.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">Cons</span>
          <h3 class="ba-title">Where Jasper falls short</h3>
          <p class="ba-sub">Five honest weaknesses.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Expensive for solo users — and the math gets worse</h4>
              <p>$69/seat/month is just the starting point. Add Surfer SEO ($119/month) for content scoring, and you're at $188/month before writing a single word. For solo operators, this is a hard starting cost to justify.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>45–90 minutes of editing per article</h4>
              <p>Long-form blog output is a starting point, not a finished product. Plan for significant editorial time per piece before anything is publication-ready. At 30 articles a month, that's 22–45 hours of editing labor.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>No publishing automation</h4>
              <p>Jasper cannot auto-publish to WordPress, Webflow, Ghost, or any CMS. Every article requires manual upload, formatting, and scheduling. For small teams doing this 30 times a month, it's a real operational burden.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>SEO requires a separate tool</h4>
              <p>No native keyword research, no SERP analysis, no content optimization scoring without buying Surfer. If you skip Surfer, Jasper writes content that may not rank. If you buy Surfer, your monthly cost jumps by $119.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>Zero local SEO features</h4>
              <p>No Google Business Profile management, no GBP post generation, no local citation tools, no Maps ranking features. Local service businesses get nothing from Jasper's tool set.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">4.7<span class="accent">/5</span></div><div class="stat-label">G2 rating · 500+ reviews</div></div>
      <div class="stat-cell"><div class="stat-num">$69<span class="accent">/seat</span></div><div class="stat-label">Pro plan · monthly billing</div></div>
      <div class="stat-cell"><div class="stat-num">$4,700<span class="accent">+</span></div><div class="stat-label">Real cost · 30 articles/mo at scale</div></div>
      <div class="stat-cell"><div class="stat-num">80<span class="accent">+</span></div><div class="stat-label">Marketing templates included</div></div>
    </div>
  </section>

  <!-- FEATURES IN DEPTH -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">Features in depth</span>
      <h2 class="h-lg">Every major <span class="accent">Jasper AI feature</span>, tested.</h2>
      <p>What's in the box — and what each feature actually does in 6 months of daily use.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Brand Voice</h4>
              <p>The flagship feature. Upload samples of your existing content — blog posts, emails, landing pages — and Jasper builds a model of your vocabulary, sentence structure, and tone. Generated content then references this model. The Pro plan includes 2 voices; Business includes unlimited. When trained correctly, output is measurably more on-brand than ChatGPT. The key word is "correctly" — a poorly trained voice produces generic results indistinguishable from any other AI tool.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>Knowledge Base</h4>
              <p>Upload product specs, pricing sheets, brand guidelines, and FAQ documents that Jasper references during content generation. Reduces hallucinations and keeps factual details accurate. Useful for teams creating content about complex products or services.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Canvas Editor</h4>
              <p>Document workspace with an AI assistance panel for generating, rewriting, and expanding longer-form content. Structured outline creation, tone adjustment, and section-by-section expansion. Output typically needs 45–90 minutes of editing before publication — plan for this in your workflow estimates.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>AI Agents</h4>
              <p>Essential Agents (Pro plan) handle SEO briefs and social calendars. Advanced Agents (Business plan) orchestrate full campaigns across blog, email, social, and ads. For marketing teams running multi-channel campaigns, Agents can automate meaningful coordination tasks — though each output still requires human review.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>Surfer SEO integration</h4>
              <p>If you subscribe to Surfer separately, the in-editor integration is the best in the market — live NLP term recommendations, content scoring, and optimization guidance appear alongside your document. This is what makes Jasper genuinely viable for SEO content. Without it, Jasper is blind to what Google rewards.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">06</span>
            <div>
              <h4>Browser extension</h4>
              <p>Brings Brand Voice, Knowledge Base, and 60+ templates to external platforms: Gmail, HubSpot, LinkedIn, Salesforce, and Webflow. Useful for teams that spend significant time in these platforms and want Jasper's brand consistency everywhere they write.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">07</span>
            <div>
              <h4>What's not there</h4>
              <p>No auto-publish to any CMS. No native SEO optimization without Surfer. No Google Business Profile management. No local SEO. No rank tracking. No social auto-publishing. If any of these are on your requirements list, you're building a tool stack — not using a single platform.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="cost-section">
    <div class="cost-header">
      <span class="label-pill">Pricing</span>
      <h2 class="h-lg">What Jasper AI <span class="accent">actually costs.</span></h2>
      <p>The headline price is $69/seat/month. The real cost — including Surfer, editing time, and publishing — is $2,000–$4,700/month for 30 published articles. Here's the full breakdown.</p>
    </div>
    <div class="cost-table">
      <div class="cost-row head">
        <div class="cost-cell head-cell">Tier</div>
        <div class="cost-cell head-cell">Jasper AI</div>
        <div class="cost-cell head-cell">Key features</div>
        <div class="cost-cell head-cell brand">theStacc equivalent</div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Pro</div><div class="price" style="font-size:15px;font-weight:600;">1–5 seats</div></div>
        <div class="cost-cell"><div class="price">$69</div><div class="per">per seat/mo</div></div>
        <div class="cost-cell"><div class="price" style="font-size:15px;font-weight:600;">2 Brand Voices · 5 Knowledge Assets · Essential Agents · image gen</div></div>
        <div class="cost-cell brand"><div class="price brand">$49</div><div class="per">starter · all-in</div></div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Business</div><div class="price" style="font-size:15px;font-weight:600;">Enterprise</div></div>
        <div class="cost-cell"><div class="price">Custom</div><div class="per">contact sales</div></div>
        <div class="cost-cell"><div class="price" style="font-size:15px;font-weight:600;">Unlimited Brand Voices · Advanced Agents · Jasper Grid · API · SSO</div></div>
        <div class="cost-cell brand"><div class="price brand">$99</div><div class="per">pro · all-in</div></div>
      </div>
      <div class="cost-savings">
        <div class="big">The "Jasper Tax" is real: $69 + $119 Surfer + editing labor = $2,000–$4,700/month for 30 articles.</div>
        <div class="lbl">theStacc publishes 30 optimized articles per month for $99. No editing, no Surfer, no separate publishing step.</div>
      </div>
      <div class="cost-footnote">*Annual billing saves ~15% on Jasper Pro ($59/seat/mo). theStacc is month-to-month with no lock-in and starts at $49/month.</div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">Who it's for</span>
      <h2 class="h-lg">Who should buy Jasper AI — <span class="accent">and who shouldn't.</span></h2>
      <p>The clearest filter we found after 6 months of testing.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">Buy Jasper if</span>
          <h3 class="ba-title">You're a mid-market marketing team.</h3>
          <p class="ba-sub">Three signals it's the right fit.</p>
        </div>
        <ul class="ba-list">
          <li><span class="ba-num">✓</span><div><h4>You have a dedicated content team (50–5,000 employees)</h4><p>Jasper accelerates writers who already exist. For teams running multi-channel campaigns across blog, email, social, and ads, the Brand Voice and AI Agents are genuine force multipliers.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>Brand voice consistency is a real operational problem</h4><p>Multiple writers, inconsistent tone, off-brand output. Jasper's Brand Voice training is the best solution in the market for this specific problem.</p></div></li>
          <li><span class="ba-num">✓</span><div><h4>You can budget $188+/month per seat (Jasper + Surfer)</h4><p>And absorb 45–90 minutes of editing per article on top. If the math works, the tool stack is powerful.</p></div></li>
        </ul>
      </div>
      <div class="ba-col before">
        <div class="ba-head">
