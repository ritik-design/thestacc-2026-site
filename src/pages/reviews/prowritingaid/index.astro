        { "@type": "Question", "name": "Does ProWritingAid have an API?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — ProWritingAid offers an Enterprise API for embedding their grammar engine into other applications. Pricing is custom and aimed at platforms with high-volume usage." }},
