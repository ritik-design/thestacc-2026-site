  ogImage: '/og/reviews/writesonic.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://thestacc.com/reviews/" },
        { "@type": "ListItem", "position": 3, "name": "Writesonic Review", "item": "https://thestacc.com/reviews/writesonic/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Review",
      "itemReviewed": {
        "@type": "SoftwareApplication",
        "name": "Writesonic",
        "applicationCategory": "WritingSoftware",
        "operatingSystem": "Web"
