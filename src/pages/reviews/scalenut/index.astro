---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Scalenut Review (2026): Honest In-Depth Verdict (After Testing It)',
  description: 'Honest Scalenut review after deep testing. Cruise Mode, NLP scoring, pricing, pros, cons, who it fits, and where theStacc wins. Updated Q2 2026.',
  canonical: 'https://thestacc.com/reviews/scalenut/',
  ogImage: '/og/reviews-scalenut.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
        { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://thestacc.com/reviews/" },
        { "@type": "ListItem", "position": 3, "name": "Scalenut Review", "item": "https://thestacc.com/reviews/scalenut/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "Review",
      "itemReviewed": {
        "@type": "SoftwareApplication",
        "name": "Scalenut",
        "applicationCategory": "SEOApplication",
        "operatingSystem": "Web",
        "offers": { "@type": "Offer", "price": "30", "priceCurrency": "USD" }
      },
      "author": { "@type": "Organization", "name": "theStacc" },
      "datePublished": "2026-04-15",
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": "4.0",
        "bestRating": "5"
      },
      "reviewBody": "Scalenut's Cruise Mode is the fastest keyword-to-draft workflow in the AI SEO content category. The promotional pricing at $45/month for 30 article drafts is genuinely compelling. But AI output needs 45–90 minutes of editing per article, has no local SEO features, and the 15,000+ G2 reviews raise credibility questions. Small businesses without content teams should look at done-for-you alternatives."
    },
    {
      "@context": "https://schema.org",
      "@type": "AggregateRating",
      "itemReviewed": {
        "@type": "SoftwareApplication",
        "name": "Scalenut",
        "applicationCategory": "SEOApplication"
      },
      "ratingValue": "4.7",
      "bestRating": "5",
      "ratingCount": "15000"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is Scalenut?",
          "acceptedAnswer": { "@type": "Answer", "text": "Scalenut is an AI SEO content platform combining keyword research, content creation, on-page optimization, content auditing, and AI visibility tracking. Founded in 2020 in Gurugram, India by Gaurav Goyal, Mayank Jain, and Saurabh Wadhawan. Raised $3.53M in funding. Its flagship feature, Cruise Mode, guides users through a structured keyword-to-draft process in 5–15 minutes of active input." }
        },
        {
          "@type": "Question",
          "name": "How much does Scalenut cost?",
          "acceptedAnswer": { "@type": "Answer", "text": "Published prices: $59/month (Starter), $89/month (Plus), $199/month (Professional). An ongoing 50% promotional discount reduces active pricing to approximately $30, $45, and $100/month respectively. A 7-day free trial is available with no credit card required." }
        },
        {
          "@type": "Question",
          "name": "Is there a free version of Scalenut?",
          "acceptedAnswer": { "@type": "Answer", "text": "No free plan exists, but a 7-day free trial requires no credit card. More accessible than Surfer SEO ($119/month, no trial) or Clearscope ($129/month, no trial). The trial grants access to Cruise Mode and the Content Optimizer." }
        },
        {
          "@type": "Question",
          "name": "Does Scalenut write content for you?",
          "acceptedAnswer": { "@type": "Answer", "text": "Scalenut generates AI drafts via Cruise Mode requiring significant post-generation editing. Plan on 45–90 minutes editing per 1,500-word article. The platform does not automatically operate your content workflow — you drive every step." }
        },
        {
          "@type": "Question",
          "name": "What is Scalenut's Cruise Mode?",
          "acceptedAnswer": { "@type": "Answer", "text": "Cruise Mode is a guided step-by-step article creation workflow: input keyword → AI generates title options → outline generation → section-by-section writing → optimization review. The process takes 5–15 minutes of active input — the fastest keyword-to-draft workflow in the category. Output requires editing before publication." }
        },
        {
          "@type": "Question",
          "name": "How does Scalenut's NLP scoring compare to Surfer SEO?",
          "acceptedAnswer": { "@type": "Answer", "text": "Both analyze top-ranking SERP pages and recommend NLP term inclusion. Surfer has a documented 0.28 ranking correlation from independent analysis; Scalenut has not published comparable data. Surfer's Content Editor is considered more accurate by professional users, though Scalenut offers competitive functionality at a lower price point." }
        },
        {
          "@type": "Question",
          "name": "Does Scalenut do local SEO?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Scalenut has zero Google Business Profile management, local citation tools, or Google Maps ranking features. It's focused entirely on website content optimization. Local service businesses needing both website SEO and Maps ranking need to look elsewhere." }
        },
        {
          "@type": "Question",
          "name": "Is Scalenut worth it for small businesses?",
          "acceptedAnswer": { "@type": "Answer", "text": "Depends on whether you have a content team. At $45/month for 30 drafts, the sticker price looks attractive. But 30 articles demands 22–45 monthly editing hours at market rates of $770–$2,250. Small businesses without content teams should consider done-for-you alternatives like theStacc, which publishes 30 articles for $49/month with no editing required." }
        },
        {
          "@type": "Question",
          "name": "What are the best Scalenut alternatives?",
          "acceptedAnswer": { "@type": "Answer", "text": "DIY tools: Surfer SEO ($119/month, best optimization quality), Frase.io ($49/month, fast brief-building), Jasper AI ($49/month, strongest AI writing). Done-for-you: theStacc ($49/month, 30 auto-published articles to WordPress/Webflow/Shopify/Ghost) handles writing and publishing automatically." }
        },
        {
          "@type": "Question",
          "name": "Who owns Scalenut?",
          "acceptedAnswer": { "@type": "Answer", "text": "Founded 2020 by Gaurav Goyal, Mayank Jain, and Saurabh Wadhawan in Gurugram, India. Raised $3.53M across two seed rounds backed by Titan Capital and Maple Capital. Operates independently with approximately $10M ARR." }
        },
        {
          "@type": "Question",
          "name": "Has Scalenut's pricing changed over time?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes, significantly. Scalenut launched with a now-removed free tier. Pricing increased as features expanded. The company introduced aggressive promotional discounts originally marketed as Black Friday sales that have since been extended indefinitely. Always verify current promotional terms on the official pricing page." }
        },
        {
          "@type": "Question",
          "name": "What does Scalenut's G2 rating actually reflect?",
          "acceptedAnswer": { "@type": "Answer", "text": "4.7/5 on G2 with 15,000+ reviews — among the largest review counts in the AI SEO category. The volume is roughly 30x more than significantly larger competitors, raising questions about potentially incentivized campaigns. Individual reviews remain credible; the aggregate count warrants contextual skepticism." }
        }
      ]
    }
  ]
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <a href="/reviews/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Tool review · Cruise Mode tested end-to-end</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display"><span class="accent">Scalenut Review</span> (2026): Honest In-Depth Verdict (After Testing It)</h1>
    <p class="hero-sub">Scalenut's Cruise Mode is genuinely the fastest keyword-to-draft workflow we've tested. The promotional pricing at $45/month for 30 article drafts is compelling. But there's a hidden cost most reviews don't mention — and it changes the math completely for small businesses without content teams.</p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Try theStacc instead — $1 trial <span class="arrow">→</span></span></a>
      <a href="#verdict" class="btn btn-secondary">Jump to the verdict</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <span><strong>4.0★</strong> overall · <strong>4.7/5</strong> G2</span>
      </div>
      <div class="hero-meta-item">
        <span>From <strong>$30/mo</strong> (promo pricing)</span>
      </div>
      <div class="hero-meta-item">
        <span>Last updated <strong>Q2 2026</strong></span>
      </div>
    </div>
  </section>

  <!-- AT-A-GLANCE VERDICT -->
  <section class="modules-bento" id="verdict">
    <div class="modules-tabs-header">
      <span class="label-pill">At a glance</span>
      <h2 class="h-lg">Scalenut, <span class="accent">in 30 seconds.</span></h2>
      <p class="lede">Fastest keyword-to-draft workflow in the category. Strong promotional pricing. AI output needs heavy editing. No local SEO. Wrong fit for businesses without content teams.</p>
    </div>

    <div class="bento-grid">
      <div class="bento-card bento-feature">
        <div class="bento-num">★</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <h3 class="bento-title">Our verdict: 4.0 / 5</h3>
        <h4 class="bento-sub">The fastest <span class="accent">keyword-to-draft AI workflow</span> on the market — and a significant editing burden for anyone without dedicated writing staff.</h4>
        <p class="bento-desc">Founded in 2020 by Gaurav Goyal, Mayank Jain, and Saurabh Wadhawan in Gurugram, India. $3.53M funded, ~$10M ARR. Cruise Mode produces 1,500-word drafts in 5–15 minutes of active input — faster than anything else we tested. The challenge: every draft needs 45–90 minutes of editing before it's publish-ready. At 30 articles/month, that's 22–45 hours of editing time the promotional pricing doesn't include.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Best for: content marketing teams with editing staff</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Price: $30–$100/mo (promo) · $59–$199/mo (full price)</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Strength: Cruise Mode is the fastest draft workflow tested</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Weakness: 45–90 min editing per article, no local SEO</li>
        </ul>
        <div class="bento-mock">
          <div class="bento-mock-bar">
            <div class="bento-mock-meta">SCALENUT · 4.0/5 · AI CONTENT PLATFORM</div>
            <span class="bento-mock-pulse"></span>
          </div>
          <div class="bento-mock-title">Best for: content teams producing 10–30 articles monthly</div>
          <div class="bento-mock-tags">
            <span class="bento-mock-tag brand">$45/mo (promo Plus)</span>
            <span class="bento-mock-tag">Cruise Mode</span>
            <span class="bento-mock-tag brand">7-day free trial</span>
          </div>
        </div>
        <div class="bento-cta">Need zero editing? Try theStacc instead <span class="arrow">→</span></div>
      </div>

      <div class="bento-card">
        <div class="bento-num">✓</div>
        <h3 class="bento-title">Pick Scalenut if</h3>
        <h4 class="bento-sub">You have a <span class="accent">content team</span> that can edit AI drafts and wants the fastest brief-to-draft workflow available.</h4>
        <p class="bento-desc">Content marketing team of 5–20 people, SEO professional managing 3–10 client sites, or freelance writer wanting faster production with NLP guidance built in. The Semrush data integration without a Semrush subscription is a real money-saver.</p>
        <div class="bento-cta">scalenut.com <span class="arrow">→</span></div>
      </div>

      <div class="bento-card">
        <div class="bento-num">✗</div>
        <h3 class="bento-title">Skip Scalenut if</h3>
        <h4 class="bento-sub">You're a <span class="accent">small business without content staff</span> or you need local SEO capabilities.</h4>
        <p class="bento-desc">30 articles at 45–90 min editing each = 22–45 hours/month. At market rates that's $770–$2,250 in hidden labor cost. theStacc publishes 30 articles for $49 with no editing required.</p>
        <div class="bento-cta">See why theStacc fits better <span class="arrow">↓</span></div>
      </div>
    </div>
  </section>

  <!-- WHAT IS SCALENUT -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">What is Scalenut</span>
      <h2 class="h-lg">An integrated AI content platform with <span class="accent">the fastest draft workflow we've tested.</span></h2>
      <p>Scalenut is an AI SEO content platform merging keyword research, content creation, on-page optimization, content auditing, and AI visibility tracking into one workspace. Founded in 2020 in Gurugram, India. $3.53M funded, approximately $10M ARR.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <p style="color: var(--text-2); margin: 0 0 16px;">Cruise Mode is the headline feature — a five-stage guided workflow from keyword input to draft completion. You input a keyword, select a title, approve or edit the AI-generated outline, watch Scalenut write section by section, then run an optimization pass. Total active input time: 5–15 minutes. Total time to something publishable: add 45–90 minutes of editing on top.</p>
        <p style="color: var(--text-2); margin: 0 0 16px;">The platform also integrates Semrush data across all plans — letting you access professional keyword volumes and difficulty scores without a separate Semrush subscription at $119–$229/month. The Content Audit module scans published pages against current SERP benchmarks and flags content decay. AI visibility tracking monitors brand appearance in ChatGPT and Google AI Overviews. Where it falls completely flat: no Google Business Profile management, no local citation tools, and no auto-publishing without manual intervention.</p>
      </div>
    </div>
  </section>

  <!-- PROS / CONS -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">The honest pros & cons</span>
      <h2 class="h-lg">What Scalenut gets right — <span class="accent">and where it lets you down.</span></h2>
      <p>After running Cruise Mode on 20+ articles across different niches and testing the full optimization and audit workflow, here's the unvarnished list.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">Pros</span>
          <h3 class="ba-title">Where Scalenut shines</h3>
          <p class="ba-sub">Five genuine differentiators worth knowing.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Fastest keyword-to-draft workflow in the category</h4>
              <p>Cruise Mode delivers 1,500-word drafts in 5–15 minutes of active input — significantly faster than tools requiring separate steps across different platforms. Nothing else we tested matches this speed for the full brief-to-draft cycle.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>All-in-one platform reduces tool-switching</h4>
              <p>Single workspace for research, writing, and optimization. Users report canceling 3+ separate subscriptions (Semrush, Jasper, Surfer) after adopting Scalenut's consolidated approach. Real consolidation value for teams managing multiple subscriptions.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Semrush data integration without the Semrush price tag</h4>
              <p>Professional-grade keyword data — volume, keyword difficulty, CPC, topic clustering — available across all plans without paying Semrush's standalone $119–$229/month fee. That's a meaningful budget saving for content teams.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>Content audit with cannibalization analysis</h4>
              <p>Few tools at this price tier offer keyword overlap identification. Professional plan covers 1,000 pages monthly. Genuinely useful for growing content libraries where old articles are competing with new ones.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>Strong promotional pricing with an accessible trial</h4>
              <p>Seven-day free trial with no credit card removes the barrier to testing. Promotional $45/month for 30 article drafts (Plus plan) delivers the best price-to-draft-volume ratio in the category.</p>
            </div>
          </li>
        </ul>
      </div>
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">Cons</span>
          <h3 class="ba-title">Where Scalenut falls short</h3>
          <p class="ba-sub">Five honest weaknesses most reviews skip over.</p>
        </div>
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>AI output requires 45–90 minutes of editing per article</h4>
              <p>Every 1,500-word article contains filler sentences, loose structure, and unnatural phrasing. At 30 articles/month, that's 22–45 hours of editing — at market editing rates of $35–$50/hour, that's $770–$2,250 the promotional pricing doesn't account for.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>Generic content quality and keyword forcing</h4>
              <p>Cruise Mode output averages competitor structures without identifying differentiation opportunities. The tool forces target keywords unnaturally in some sections, creating awkward phrasing you have to edit out during revision.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Keyword research less accurate than dedicated tools</h4>
              <p>Functional for content planning, insufficient for competitive strategy. Serious gap analysis, backlink-informed difficulty, and SERP feature analysis still require Ahrefs or a standalone Semrush subscription.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>G2 review count raises credibility questions</h4>
              <p>15,000+ G2 reviews — roughly 30x more than significantly larger competitors like Surfer SEO. The volume is unusual enough to warrant skepticism about incentivized review campaigns, even if individual reviews are credible.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>No local SEO or Google Business Profile features</h4>
              <p>Complete absence of GBP management, local citation tools, or Google Maps optimization. Disqualifies it for service-based local businesses and multi-location operations needing unified local strategy.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">5<span class="accent">–15</span></div><div class="stat-label">Minutes to draft via Cruise Mode</div></div>
      <div class="stat-cell"><div class="stat-num">$45<span class="accent">/mo</span></div><div class="stat-label">Plus plan (promo) · 30 drafts/mo</div></div>
      <div class="stat-cell"><div class="stat-num">4.7<span class="accent">/5</span></div><div class="stat-label">G2 rating · 15,000+ reviews</div></div>
      <div class="stat-cell"><div class="stat-num">$10M<span class="accent"> ARR</span></div><div class="stat-label">Estimated annual revenue · 2026</div></div>
    </div>
  </section>

  <!-- FEATURES IN DEPTH -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">Features in depth</span>
      <h2 class="h-lg">Every major <span class="accent">Scalenut feature</span>, tested.</h2>
      <p>What's actually in the platform and how each module performed in our testing.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col after" style="grid-column: 1 / -1;">
        <ul class="ba-list">
          <li>
            <span class="ba-num">01</span>
            <div>
              <h4>Cruise Mode</h4>
              <p>Five-stage guided workflow: keyword input → title selection → outline generation → section-by-section AI writing → optimization pass. Produces 1,500-word drafts in 5–15 minutes of active input. The fastest keyword-to-draft workflow we've tested. Generate section by section rather than all at once — it produces better output and creates manageable editing checkpoints.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">02</span>
            <div>
              <h4>SEO Hub / Content Optimizer</h4>
              <p>Real-time NLP-based scoring analyzing top-10 SERP pages. Recommends term insertion, identifies keyword density gaps, provides competitor content comparison. Comparable to mid-tier alternatives like Frase. Run the optimization pass last, not during drafting — mid-draft term insertion interrupts flow and creates awkward phrasing.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">03</span>
            <div>
              <h4>Keyword Planner</h4>
              <p>Integrated keyword research with Semrush data integration across all plans. Supplies volume, keyword difficulty, CPC metrics, and topic clustering. Solid for content planning and volume estimation; insufficient for serious competitive gap analysis. Treat it as supplemental, not primary keyword research.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">04</span>
            <div>
              <h4>Content Audit</h4>
              <p>Scans published pages, scores them against current SERP benchmarks, identifies content decay, and surfaces refresh opportunities. Plus plan covers 200 pages monthly; Professional covers 1,000 pages. Cannibalization analysis available on Professional tier only — useful for sites with 100+ published articles.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">05</span>
            <div>
              <h4>AI Visibility Tracking</h4>
              <p>Monitors brand and content appearance in ChatGPT answers and Google AI Overviews (added 2024). Starter tracks 10 prompts weekly; Professional tracks 100. Directionally useful as AI search expands. Doesn't yet provide clear optimization pathways for improving AI search performance.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">06</span>
            <div>
              <h4>Auto-Publish to WordPress</h4>
              <p>Available on Plus and Professional plans. Publishes directly to WordPress preserving formatting, saving 10–15 minutes per article. Use this instead of manual export — it's the one place Scalenut removes friction from the end of the workflow. Note: still requires you to have driven Cruise Mode for each article.</p>
            </div>
          </li>
          <li>
            <span class="ba-num">07</span>
            <div>
              <h4>What's missing</h4>
              <p>Google Business Profile management, local citation tools, Google Maps optimization, true done-for-you publishing (Cruise Mode still requires active operator per article), best-in-class keyword research, and social distribution. For local businesses or anyone who wants content without managing the process, Scalenut isn't the fit.</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="cost-section">
    <div class="cost-header">
      <span class="label-pill">Pricing</span>
      <h2 class="h-lg">What Scalenut <span class="accent">actually costs.</span></h2>
      <p>Published prices vs promotional prices vs the real total cost once you factor in editing labor.</p>
    </div>
    <div class="cost-table">
      <div class="cost-row head">
        <div class="cost-cell head-cell">Tier</div>
        <div class="cost-cell head-cell">Scalenut (promo)</div>
        <div class="cost-cell head-cell">Articles / month</div>
        <div class="cost-cell head-cell brand">theStacc equivalent</div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Starter</div><div class="price" style="font-size:15px;font-weight:600;">Solo use</div></div>
        <div class="cost-cell"><div class="price">$30</div><div class="per">per month · promo · ($59 full price)</div></div>
        <div class="cost-cell"><div class="price" style="font-size:15px;font-weight:600;">5 drafts · 1 workspace</div></div>
        <div class="cost-cell brand"><div class="price brand">$49</div><div class="per">starter · 30 articles · all-in</div></div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Plus</div><div class="price" style="font-size:15px;font-weight:600;">Best value</div></div>
        <div class="cost-cell"><div class="price">$45</div><div class="per">per month · promo · ($89 full price)</div></div>
        <div class="cost-cell"><div class="price" style="font-size:15px;font-weight:600;">30 drafts · auto-publish · internal linking</div></div>
        <div class="cost-cell brand"><div class="price brand">$49</div><div class="per">starter · 30 articles · no editing</div></div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Professional</div><div class="price" style="font-size:15px;font-weight:600;">Teams</div></div>
        <div class="cost-cell"><div class="price">$100</div><div class="per">per month · promo · ($199 full price)</div></div>
        <div class="cost-cell"><div class="price" style="font-size:15px;font-weight:600;">75 drafts · 1,000-page audit · cannibalization</div></div>
        <div class="cost-cell brand"><div class="price brand">$99</div><div class="per">pro · 30 articles · no editing</div></div>
