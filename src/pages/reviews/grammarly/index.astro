const seo = {
  title: 'Grammarly Review 2026: Best Editor — But It Won\'t Rank Your Site | theStacc',
  description: 'Grammarly review: features, pricing ($0–$15/mo Pro, $25/seat Business), Premium vs Free, and why the best editor in the world still can\'t move your SEO rankings.',
  canonical: 'https://thestacc.com/reviews/grammarly/',
  ogImage: '/og/reviews/grammarly.webp',
  schemaData: [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
