          </div>
          <div class="bar-rows">
            <div class="bar-row"><span class="bar-label">Semrush</span><div class="bar-track"><div class="bar-fill alt" style="width: 100%"></div></div><span class="bar-value">26B</span></div>
            <div class="bar-row"><span class="bar-label">Ahrefs</span><div class="bar-track"><div class="bar-fill alt" style="width: 88%"></div></div><span class="bar-value">23B</span></div>
