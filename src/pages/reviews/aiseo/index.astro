            </div>
            <div class="chart-legend">
              <span class="lg-1">AISEO</span>
              <span class="lg-2">Competitor</span>
            </div>
          </div>
          <div class="bar-rows">
            <div class="bar-row"><span class="bar-label">Undetectable AI</span><div class="bar-track"><div class="bar-fill alt" style="width: 72%"></div></div><span class="bar-value">68%</span></div>
            <div class="bar-row"><span class="bar-label">StealthGPT</span><div class="bar-track"><div class="bar-fill alt" style="width: 60%"></div></div><span class="bar-value">56%</span></div>
            <div class="bar-row"><span class="bar-label">AISEO Bypass</span><div class="bar-track"><div class="bar-fill" style="width: 50%"></div></div><span class="bar-value">47%</span></div>
            <div class="bar-row"><span class="bar-label">QuillBot</span><div class="bar-track"><div class="bar-fill alt" style="width: 36%"></div></div><span class="bar-value">34%</span></div>
