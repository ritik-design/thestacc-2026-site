      "mainEntity": [
        { "@type": "Question", "name": "What is Nightwatch?", "acceptedAnswer": { "@type": "Answer", "text": "Nightwatch is a visual rank tracker built for SEO agencies and in-house teams. It tracks keyword positions across Google (desktop and mobile), Google Maps, YouTube, and Amazon, with hyper-local tracking down to ZIP code, white-label client reports, and a generous SERP-features layer." }},
