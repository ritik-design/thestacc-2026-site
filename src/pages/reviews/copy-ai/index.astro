      "reviewRating": { "@type": "Rating", "ratingValue": "4.2", "bestRating": "5" },
      "author": { "@type": "Person", "name": "Siddharth Gangal", "url": "https://thestacc.com/authors/siddharth-gangal/", "sameAs": ["https://www.linkedin.com/in/sidgangal/"] },
      "publisher": { "@type": "Organization", "name": "theStacc" }
    },
    {
      "@context": "https://schema.org",
      "@type": "AggregateRating",
      "itemReviewed": { "@type": "SoftwareApplication", "name": "Copy.ai" },
      "ratingValue": "4.7",
      "reviewCount": "180",
      "bestRating": "5"
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is Copy.ai?", "acceptedAnswer": { "@type": "Answer", "text": "Copy.ai is an AI writing and workflow automation platform founded in 2020. Originally a short-form AI copywriter, it pivoted in 2023 to a 'GTM AI Platform' for sales and marketing teams, adding Workflows (multi-step AI pipelines), Infobase (brand knowledge), and sales-focused features." }},
