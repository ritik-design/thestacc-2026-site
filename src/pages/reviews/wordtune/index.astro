            <div class="bar-row"><span class="bar-label">Wordtune</span><div class="bar-track"><div class="bar-fill" style="width: 90%"></div></div><span class="bar-value">9.0</span></div>
            <div class="bar-row"><span class="bar-label">ChatGPT-4</span><div class="bar-track"><div class="bar-fill alt" style="width: 87%"></div></div><span class="bar-value">8.7</span></div>
            <div class="bar-row"><span class="bar-label">Grammarly Premium</span><div class="bar-track"><div class="bar-fill alt" style="width: 75%"></div></div><span class="bar-value">7.5</span></div>
            <div class="bar-row"><span class="bar-label">QuillBot</span><div class="bar-track"><div class="bar-fill alt" style="width: 70%"></div></div><span class="bar-value">7.0</span></div>
