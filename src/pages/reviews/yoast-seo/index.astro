            <div class="stat-lbl">Continuous development</div>
          </div>
        </div>

        <h3>WordPress SEO plugin market share</h3>

        <div class="chart-card">
          <div class="chart-head">
            <div>
              <div class="chart-title">Active WordPress installs (millions · 2026)</div>
              <div class="chart-sub">WordPress.org plugin directory data · cross-checked vs vendor claims</div>
            </div>
            <div class="chart-legend">
              <span class="lg-1">Yoast</span>
