---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Facebook Integration — Daily Posts on Autopilot | theStacc',
  description: 'Facebook integration that writes and ships posts to your Page every day. Connect once in 60 seconds. $1 trial. Cancel anytime.',
  canonical: 'https://thestacc.com/integrations/facebook/',
  ogImage: '/og/integrations-facebook.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Facebook Integration",
    "description": "Facebook integration for theStacc — daily Page posts, comment monitoring, and lead-form sync, all on autopilot.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/integrations/facebook/",
    "image": "https://thestacc.com/og/integrations-facebook.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/modules/social-media/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>New · 60-second Facebook connect</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Facebook integration that <span class="accent">posts for you every day.</span></h1>
    <p class="hero-sub">Connect your Page once. theStacc writes a fresh post each day in your voice. Photos. Offers. Updates. Your business stays in the feed without you opening Facebook.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">R</div><div class="av">M</div><div class="av">S</div><div class="av">J</div></div>
        <span><strong>127+</strong> Pages on autopilot</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Posting daily for</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">60<span class="accent">s</span></div><div class="stat-label">Setup · OAuth + pick Page</div></div>
      <div class="stat-cell"><div class="stat-num">30<span class="accent">+</span></div><div class="stat-label">Posts per month · per Page</div></div>
      <div class="stat-cell"><div class="stat-num">3<span class="accent">×</span></div><div class="stat-label">Reach vs posting once a week</div></div>
      <div class="stat-cell"><div class="stat-num">0<span class="accent">hr</span></div><div class="stat-label">Your time spent each week</div></div>
    </div>
  </section>

  <!-- WHAT CONNECTING DOES (unique side-by-side: before / after) -->
  <section class="modules-bento" style="padding: 96px 32px;">
    <div class="modules-tabs-header">
      <span class="label-pill">What changes for you</span>
      <h2 class="h-lg">Before vs after <span class="accent">you connect.</span></h2>
      <p class="lede">A small switch in your week. A big switch in what shows up on your Page.</p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 1080px; margin: 40px auto 0; padding: 0 16px;">
      <div style="background: var(--bg-soft); border: 1px solid var(--border); padding: 32px;">
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); margin-bottom: 16px;">Before</div>
        <h3 class="h-sm" style="margin-bottom: 16px;">You forget. The Page goes quiet.</h3>
        <ul style="list-style: none; padding: 0; display: grid; gap: 12px;">
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--text-3);">—</span>Your last post was 3 weeks ago.</li>
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--text-3);">—</span>You buy stock photos. You write captions late at night.</li>
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--text-3);">—</span>Customers search your Page. They see crickets.</li>
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--text-3);">—</span>Comments sit unread for days.</li>
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--text-3);">—</span>Reach drops. The algorithm forgets you.</li>
        </ul>
      </div>
      <div style="background: white; border: 1px solid var(--brand-soft); padding: 32px; box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18);">
        <div style="font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); margin-bottom: 16px;">After · day 1</div>
        <h3 class="h-sm" style="margin-bottom: 16px;">A new post lands. Every day. Without you.</h3>
        <ul style="list-style: none; padding: 0; display: grid; gap: 12px;">
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--brand);">+</span>Fresh post live at 9 AM local — every weekday.</li>
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--brand);">+</span>Photos pulled from your library. No stock junk.</li>
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--brand);">+</span>Caption in your voice. Built from your last 20 posts.</li>
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--brand);">+</span>Comments flagged. You reply when you want to.</li>
          <li style="display: flex; gap: 10px; font-size: 15px; color: var(--text-2);"><span style="color: var(--brand);">+</span>Reach climbs. Customers find you again.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- HOW THE INTEGRATION WORKS -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">The connect flow</span>
      <h2 class="h-lg">Connect once. <span class="accent">Post forever.</span></h2>
      <p class="lede">One Facebook login. One picked Page. theStacc takes it from there.</p>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">01</span><span class="step-day">Setup · 60 seconds</span></div>
          <h3 class="h-md">Log in with <span class="accent">Facebook.</span></h3>
          <p>Click "Connect Facebook". Sign in. Pick the Page you want managed. theStacc reads your last 20 posts to learn your voice — short, warm, salesy, whatever you sound like.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Official Meta Graph API · no scraping, no risk</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Pick 1 Page or 100 · agencies welcome</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Voice locked from your real past posts</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-1">
            <div class="step-card-header">
              <span class="step-card-tag">CONNECT · 60 SEC</span>
              <span class="step-card-status">● Complete</span>
            </div>
            <div class="step-card-row"><span class="step-card-key">Meta OAuth</span><span class="step-card-val">Connected ✓</span></div>
            <div class="step-card-row"><span class="step-card-key">Page</span><span class="step-card-val">Bright Smile Dental</span></div>
            <div class="step-card-row"><span class="step-card-key">Voice</span><span class="step-card-val">Friendly · short · emoji-light</span></div>
            <div class="step-card-row"><span class="step-card-key">Schedule</span><span class="step-card-val">Mon–Fri · 9 AM local</span></div>
            <div class="step-card-row highlight"><span class="step-card-key">First post</span><span class="step-card-val"><strong>Tomorrow 09:00</strong></span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid reverse">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">02</span><span class="step-day">Daily · auto-pilot</span></div>
          <h3 class="h-md">Posts ship. <span class="accent">You don't lift a finger.</span></h3>
          <p>Every morning at 9 AM local, a new post goes live on your Page. Photo from your library. Caption in your voice. You approve, edit, or set it to full autopilot.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>5 posts a week · or your custom cadence</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Approve from email · one tap to ship</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Auto-pilot mode · ships without you</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-2">
            <div class="step-card-header">
              <span class="step-card-tag">THIS WEEK</span>
              <span class="step-card-status">● Auto</span>
            </div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 09:00</span><span class="step-feed-text">Post live · <strong>"Patient of the month"</strong></span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Tue 09:00</span><span class="step-feed-text">Post live · <strong>"Same-day crowns now open"</strong></span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Wed 09:00</span><span class="step-feed-text">Post live · <strong>"Meet Dr. Sara"</strong></span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Thu 09:00</span><span class="step-feed-text">Post live · <strong>"Whitening week — $99"</strong></span></div>
            <div class="step-feed-item"><span class="step-feed-dot live"></span><span class="step-feed-time">Fri 09:00</span><span class="step-feed-text">Scheduled · <strong>"Friday office hours"</strong></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW THIS WORKS IN REAL LIFE -->
  <section style="padding: 96px 32px; background: var(--bg-soft);">
    <div style="max-width: 920px; margin: 0 auto;">
      <span class="label-pill">A real customer</span>
      <h2 class="h-lg" style="margin: 20px 0 24px;">Meet <span class="accent">Mike's HVAC.</span> One man. One van. One Page.</h2>
      <p class="lede" style="margin-bottom: 32px;">Mike runs an HVAC business in Phoenix. He fixes ACs all day. His Facebook Page was last posted to in 2024. Here's what happened when he connected theStacc.</p>

      <div style="display: grid; grid-template-columns: 80px 1fr; gap: 20px; align-items: start; padding: 24px 0; border-top: 1px solid var(--border);">
        <div style="font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--brand); font-weight: 600;">DAY 1</div>
        <div>
          <h3 class="h-sm" style="margin-bottom: 6px;">Mike connects in 60 seconds.</h3>
          <p>He logs into Facebook. Picks "Mike's HVAC". theStacc reads his old posts and his website. Done. He goes back to a service call.</p>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 80px 1fr; gap: 20px; align-items: start; padding: 24px 0; border-top: 1px solid var(--border);">
        <div style="font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--brand); font-weight: 600;">DAY 2</div>
        <div>
          <h3 class="h-sm" style="margin-bottom: 6px;">First post lives at 9 AM.</h3>
          <p>"Phoenix summer is here. Book a tune-up before July — $89." Photo of his van. Mike sees it from his phone. He smiles. He keeps driving.</p>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 80px 1fr; gap: 20px; align-items: start; padding: 24px 0; border-top: 1px solid var(--border);">
        <div style="font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--brand); font-weight: 600;">DAY 14</div>
        <div>
          <h3 class="h-sm" style="margin-bottom: 6px;">First call from the Page.</h3>
          <p>A neighbor saw his "$89 tune-up" post. She calls. Mike books her in for Friday. Cost of the post: zero of his time.</p>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 80px 1fr; gap: 20px; align-items: start; padding: 24px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
        <div style="font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--brand); font-weight: 600;">DAY 90</div>
        <div>
          <h3 class="h-sm" style="margin-bottom: 6px;">Page reach up 3.4×. 11 calls tracked back.</h3>
          <p>Three months in, Mike's Page is busier than it has ever been. He paid $49/month. He earned $4,200 in jobs that started on Facebook. He still hasn't written a post himself.</p>
        </div>
      </div>

      <div style="margin-top: 32px; padding: 24px; background: white; border: 1px solid var(--brand-soft);">
        <p style="font-style: italic; color: var(--text-1); font-size: 17px; line-height: 1.5;">"I don't open Facebook. I fix ACs. theStacc opens it for me. That math works."</p>
        <p style="margin-top: 12px; font-size: 13px; color: var(--text-3);">— Mike R., Mike's HVAC, Phoenix AZ</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="faq-grid">
      <div class="faq-left">
        <span class="label-pill">FAQ</span>
        <h2 class="h-md">Facebook integration, <span class="accent">answered.</span></h2>
        <p>The common questions, in plain English. Email <a href="mailto:founder@thestacc.com">founder@thestacc.com</a> for anything else.</p>
        <p style="margin-top: 24px;">See also: <a href="/modules/social-media/" class="accent">Social Media module</a>, <a href="/integrations/instagram/" class="accent">Instagram integration</a>, <a href="/pricing/" class="accent">pricing</a>.</p>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">How long does the Facebook connect take?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">About 60 seconds. You log in with Facebook, pick the Page you want, and theStacc takes it from there. No code. No copy-paste.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Will posts sound like a robot?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">No. theStacc reads your last 20 posts before writing the first one. If you sound warm and short, it sounds warm and short. You can edit any post before it ships.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Can I approve posts before they go live?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">Yes. Two modes. Auto-pilot ships posts on a schedule. Approval mode emails you a draft — one tap to ship, one tap to skip. Mix and match by day.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Where do the photos come from?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">Your Facebook photo library, your Google Drive, or a folder you upload. We never use stock photos. If you need new ones, the AI can mock them for you.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Can I manage many Pages?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">Yes. Agencies and multi-location brands can plug in any number of Pages. Each gets its own voice, schedule, and approval flow.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">What happens if I disconnect?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">Every post stays on your Page. Forever. You own it. Disconnecting just stops new posts from being scheduled.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">Does it work with Facebook ads?<span class="faq-icon"><svg><use href="#i-plus"/></svg></span></button>
          <div class="faq-answer">Yes. Any organic post can be boosted from your Meta Ads Manager. theStacc surfaces your best posts each week so you know which to boost.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- GUARANTEE STRIP -->
  <section class="guarantee-section">
    <div class="guarantee-grid">
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>30-day money-back</h4>
          <p>Not happy in your first 30 days? Full refund. No forms. No questions asked.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>You own every post</h4>
          <p>Disconnect any time. Every post stays on your Page. It's yours, forever.</p>
        </div>
      </div>
      <div class="guarantee-card">
        <div class="guarantee-icon">
          <svg><use href="#i-check"/></svg>
        </div>
        <div class="guarantee-text">
          <h4>No contract, no lock-in</h4>
          <p>Month-to-month. Cancel on your next billing date. Zero penalty.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor"/>
        </pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Connect in 60 seconds</span>
        <h2 class="final-headline">Your Page, <span class="accent">posting every day.</span><br/>Without you opening Facebook.</h2>
        <p class="final-sub">Daily posts. Your voice. $1 trial. Cancel anytime.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>84 businesses started this week</span> · <span>$1 trial</span> · <span>Cancel anytime</span></div>
        <p class="final-ps"><strong>P.S.</strong> The Page that posted today will outrank the one that went silent. <span class="accent">Showing up every day is the whole game.</span></p>
      </div>
    </div>
  </section>
</BaseLayout>
