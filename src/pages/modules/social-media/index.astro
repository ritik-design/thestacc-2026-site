---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Social Media Module — Stay Top-of-Mind Without Posting | theStacc',
  description: 'Social media module that posts to Instagram, LinkedIn, X, and Facebook every day. Stay top-of-mind without posting yourself. $1 trial.',
  canonical: 'https://thestacc.com/modules/social-media/',
  ogImage: '/og/modules-social-media.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Social Media",
    "description": "Social media module that publishes daily posts to Instagram, LinkedIn, X, and Facebook in your brand voice — keeping you top-of-mind without posting yourself.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/modules/social-media/",
    "image": "https://thestacc.com/og/modules-social-media.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/integrations/instagram/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Social Media module · $49/mo</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Social media that <span class="accent">stays top-of-mind without posting yourself.</span></h1>
    <p class="hero-sub">For <strong>founders, agencies, and local businesses</strong> who know they should be posting daily but don't have the hours. Instagram. LinkedIn. X. Facebook. theStacc writes and ships in your voice — every day.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">R</div><div class="av">M</div><div class="av">S</div><div class="av">J</div></div>
        <span><strong>127+</strong> accounts on autopilot</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Posting daily for</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">120<span class="accent">+</span></div><div class="stat-label">Posts per month · across 4 networks</div></div>
      <div class="stat-cell"><div class="stat-num">4<span class="accent">×</span></div><div class="stat-label">Reach vs posting once a week</div></div>
      <div class="stat-cell"><div class="stat-num">15<span class="accent">min</span></div><div class="stat-label">Your time per week · max</div></div>
      <div class="stat-cell"><div class="stat-num">$3.4<span class="accent">k</span></div><div class="stat-label">Saved/mo vs hiring a social manager</div></div>
    </div>
  </section>

  <!-- THE 4 PLATFORMS BENTO -->
  <section class="modules-bento" id="features">
    <div class="modules-tabs-header">
      <span class="label-pill">Networks covered</span>
      <h2 class="h-lg">Four networks. <span class="accent">One brain.</span></h2>
      <p class="lede">Each post is shaped for the network it ships on. Not a copy-paste. A real per-platform post.</p>
    </div>

    <div class="bento-grid">
      <a class="bento-card bento-feature" href="/integrations/instagram/">
        <div class="bento-num">01</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </div>
        <h3 class="bento-title">Instagram</h3>
        <h4 class="bento-sub">Feed posts. Carousels. <span class="accent">Reels. Stories.</span></h4>
        <p class="bento-desc">A full Instagram mix every week — not just one boring photo. The format is picked by what your audience opens. Hashtags written fresh per post.</p>
        <ul class="bento-list">
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>5 posts a week · auto format mix</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Reels built from your footage</li>
          <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>Hashtags picked per post · not recycled</li>
        </ul>
        <div class="bento-cta">See Instagram integration <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="/integrations/facebook/">
        <div class="bento-num">02</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </div>
        <h3 class="bento-title">Facebook</h3>
        <h4 class="bento-sub">Daily Page posts. <span class="accent">Local offers.</span></h4>
        <p class="bento-desc">Your Page stays in the feed. Offers, updates, behind-the-scenes. Comments flagged. You reply when you want to.</p>
        <div class="bento-cta">See Facebook integration <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="#linkedin">
        <div class="bento-num">03</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </div>
        <h3 class="bento-title">LinkedIn</h3>
        <h4 class="bento-sub">Founder-mode posts. <span class="accent">Built to land in feed.</span></h4>
        <p class="bento-desc">Short, sharp posts that LinkedIn rewards. Carousels for hot takes. Your voice — the one that already gets engagement.</p>
        <div class="bento-cta">Learn more <span class="arrow">→</span></div>
      </a>

      <a class="bento-card" href="#x">
        <div class="bento-num">04</div>
        <div class="bento-icon">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </div>
        <h3 class="bento-title">X (Twitter)</h3>
        <h4 class="bento-sub">Threads + replies. <span class="accent">In your voice.</span></h4>
        <p class="bento-desc">Daily posts and weekly threads. Sourced from your blog, your podcast, or your week. Built to be shared — not just shipped.</p>
        <div class="bento-cta">Learn more <span class="arrow">→</span></div>
      </a>
    </div>
  </section>

  <!-- UNIQUE: WEEKLY POST CALENDAR MOCKUP -->
  <section style="padding: 96px 32px; background: var(--bg-soft);">
    <div style="max-width: 1080px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 48px;">
        <span class="label-pill">Your week, on autopilot</span>
        <h2 class="h-lg" style="margin: 20px 0 16px;">A real <span class="accent">posting calendar.</span></h2>
        <p class="lede" style="max-width: 700px; margin: 0 auto;">Not a content "ideas" list. Real posts. Scheduled. Shipping. Every day.</p>
      </div>

      <div style="background: white; border: 1px solid var(--border); overflow: hidden;">
        <div style="display: grid; grid-template-columns: 100px repeat(5, 1fr); padding: 16px 20px; background: var(--text-1); color: white; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600;">
          <div></div>
          <div>Mon</div>
          <div>Tue</div>
          <div>Wed</div>
          <div>Thu</div>
          <div>Fri</div>
        </div>

        <div style="display: grid; grid-template-columns: 100px repeat(5, 1fr); padding: 16px 20px; border-bottom: 1px solid var(--border); align-items: center;">
          <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;">Instagram</div>
          <div style="background: var(--brand-softer); border: 1px solid var(--brand-soft); padding: 10px; font-size: 12px;"><strong style="color: var(--brand);">Reel</strong><br/><span style="color: var(--text-2);">"Behind the chair"</span></div>
          <div style="background: var(--brand-softer); border: 1px solid var(--brand-soft); padding: 10px; font-size: 12px;"><strong style="color: var(--brand);">Carousel</strong><br/><span style="color: var(--text-2);">"5 whitening tips"</span></div>
          <div style="background: var(--brand-softer); border: 1px solid var(--brand-soft); padding: 10px; font-size: 12px;"><strong style="color: var(--brand);">Feed</strong><br/><span style="color: var(--text-2);">"Patient win"</span></div>
          <div style="background: var(--brand-softer); border: 1px solid var(--brand-soft); padding: 10px; font-size: 12px;"><strong style="color: var(--brand);">Story</strong><br/><span style="color: var(--text-2);">"Office hours poll"</span></div>
          <div style="background: var(--brand-softer); border: 1px solid var(--brand-soft); padding: 10px; font-size: 12px;"><strong style="color: var(--brand);">Reel</strong><br/><span style="color: var(--text-2);">"Friday tip · 15s"</span></div>
        </div>

        <div style="display: grid; grid-template-columns: 100px repeat(5, 1fr); padding: 16px 20px; border-bottom: 1px solid var(--border); align-items: center;">
          <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;">Facebook</div>
          <div style="background: var(--bg-soft); border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"New patient special"</span></div>
          <div style="background: var(--bg-soft); border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"Same-day crowns"</span></div>
          <div style="background: var(--bg-soft); border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"Meet Dr. Sara"</span></div>
          <div style="background: var(--bg-soft); border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"Whitening week"</span></div>
          <div style="background: var(--bg-soft); border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Offer</strong><br/><span style="color: var(--text-2);">"Friday $99 cleaning"</span></div>
        </div>

        <div style="display: grid; grid-template-columns: 100px repeat(5, 1fr); padding: 16px 20px; border-bottom: 1px solid var(--border); align-items: center;">
          <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;">LinkedIn</div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"Why we redid scheduling"</span></div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px; opacity: 0.4;">—</div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Carousel</strong><br/><span style="color: var(--text-2);">"3 lessons running a clinic"</span></div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px; opacity: 0.4;">—</div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"Friday founder note"</span></div>
        </div>

        <div style="display: grid; grid-template-columns: 100px repeat(5, 1fr); padding: 16px 20px; align-items: center;">
          <div style="font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--brand); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;">X (Twitter)</div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"Monday tip"</span></div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Thread</strong><br/><span style="color: var(--text-2);">"8 dental myths"</span></div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"Patient FAQ"</span></div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"What we learned"</span></div>
          <div style="background: white; border: 1px solid var(--border); padding: 10px; font-size: 12px;"><strong>Post</strong><br/><span style="color: var(--text-2);">"Weekend hours"</span></div>
        </div>
      </div>

      <div style="margin-top: 24px; text-align: center;">
        <p style="font-size: 14px; color: var(--text-3);"><strong style="color: var(--brand);">24 posts shipped this week.</strong> Time you spent: 0 minutes. Time you spent approving: 8 minutes (optional).</p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="howitworks-section" id="linkedin">
    <div class="howitworks-header">
      <span class="label-pill">How it works</span>
      <h2 class="h-lg">Connect once. <span class="accent">Post forever.</span></h2>
      <p class="lede">One Meta OAuth. One LinkedIn. One X. theStacc handles the four feeds.</p>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">01</span><span class="step-day">Day 1 · 3-minute setup</span></div>
          <h3 class="h-md">Log in to each <span class="accent">network you care about.</span></h3>
          <p>OAuth Instagram and Facebook via Meta. OAuth LinkedIn. Paste an X API key. Pick a posting cadence per network. theStacc reads your last 50 posts to learn your voice.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Official Meta, LinkedIn, X APIs</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Voice trained on your real posts</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Per-network cadence · daily / weekly</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-1">
            <div class="step-card-header">
              <span class="step-card-tag">CONNECT · 3 MIN</span>
              <span class="step-card-status">● Complete</span>
            </div>
            <div class="step-card-row"><span class="step-card-key">Instagram</span><span class="step-card-val">@brightsmile.dental ✓</span></div>
            <div class="step-card-row"><span class="step-card-key">Facebook</span><span class="step-card-val">Bright Smile Dental ✓</span></div>
            <div class="step-card-row"><span class="step-card-key">LinkedIn</span><span class="step-card-val">Dr. Patel ✓</span></div>
            <div class="step-card-row"><span class="step-card-key">X</span><span class="step-card-val">@brightsmilesatx ✓</span></div>
            <div class="step-card-row highlight"><span class="step-card-key">First batch</span><span class="step-card-val"><strong>Tomorrow 09:00</strong></span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block" id="x">
      <div class="step-grid reverse">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">02</span><span class="step-day">Daily · the feed runs</span></div>
          <h3 class="h-md">Posts shape per network. <span class="accent">Ship per schedule.</span></h3>
          <p>One core idea per day. Reshaped for each network — short on X, sharp on LinkedIn, visual on Instagram, casual on Facebook. Each one feels native, because each one is.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>One idea · reshaped per network</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Native to each platform · not copy-paste</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Approve from email · one tap to ship</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-2">
            <div class="step-card-header">
              <span class="step-card-tag">TODAY · ONE IDEA · 4 SHIPS</span>
              <span class="step-card-status">● Live</span>
            </div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">IG · Reel</span><span class="step-feed-text"><strong>15s</strong> · "How a crown gets fitted"</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">FB · Post</span><span class="step-feed-text">Photo + offer · "Same-day crowns open"</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">LI · Carousel</span><span class="step-feed-text">5 slides · "Why we switched to same-day"</span></div>
            <div class="step-feed-item"><span class="step-feed-dot live"></span><span class="step-feed-time">X · Thread</span><span class="step-feed-text">6 tweets · "Same-day crowns explained"</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">03</span><span class="step-day">Day 90 · the result</span></div>
          <h3 class="h-md">Top-of-mind <span class="accent">without you.</span></h3>
          <p>Three months in, your audience has seen you 120+ times. Reach climbs. DMs pick up. People know your name before they need you. That's how social actually works.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>4× reach vs posting once a week</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>2.8× follower growth · average customer</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Weekly report · what to do more of</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-3">
            <div class="step-card-header">
              <span class="step-card-tag">90-DAY OUTCOME</span>
              <span class="step-card-status">● Live</span>
            </div>
            <div class="step-stat-big">
              <span class="step-stat-num">2.8×</span>
              <span class="step-stat-label">Follower growth vs Day 1</span>
              <span class="step-stat-delta">↑ 1,420 net new followers</span>
            </div>
            <div class="step-stat-row">
              <div><strong>120+</strong> posts / mo</div>
              <div><strong>4×</strong> reach</div>
              <div><strong>15 min</strong> / week</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW THIS WORKS IN REAL LIFE -->
  <section style="padding: 96px 32px; background: var(--bg-soft);">
    <div style="max-width: 920px; margin: 0 auto;">
      <span class="label-pill">A real customer</span>
      <h2 class="h-lg" style="margin: 20px 0 24px;">Meet <span class="accent">Rachel at FitForge.</span> Solo founder. Four networks.</h2>
      <p class="lede" style="margin-bottom: 32px;">Rachel runs a fitness coaching SaaS. She was posting to Instagram once a week and ignoring LinkedIn. Here's what happened in 90 days on theStacc.</p>

      <div style="display: grid; grid-template-columns: 80px 1fr; gap: 20px; align-items: start; padding: 24px 0; border-top: 1px solid var(--border);">
        <div style="font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--brand); font-weight: 600;">DAY 1</div>
        <div>
          <h3 class="h-sm" style="margin-bottom: 6px;">3-minute setup, four networks.</h3>
          <p>Rachel OAuths Meta. OAuths LinkedIn. Pastes her X key. Uploads a folder of training videos. theStacc reads her last 50 posts. Done.</p>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 80px 1fr; gap: 20px; align-items: start; padding: 24px 0; border-top: 1px solid var(--border);">
        <div style="font-family: 'Geist Mono', monospace; font-size: 12px; color: var(--brand); font-weight: 600;">DAY 2</div>
        <div>
          <h3 class="h-sm" style="margin-bottom: 6px;">First batch of 4 posts ships.</h3>
