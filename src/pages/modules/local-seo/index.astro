---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const seo = {
  title: 'Local SEO Module — Dominate the Map Pack & "Near Me" | theStacc',
  description: 'Local SEO module that wins the Map Pack and "near me" searches. GBP posts, reviews, citations, rank tracking. $1 trial. Cancel anytime.',
  canonical: 'https://thestacc.com/modules/local-seo/',
  ogImage: '/og/modules-local-seo.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "theStacc Local SEO",
    "description": "Local SEO module that wins the Map Pack and 'near me' searches — daily GBP posts, instant review replies, citations, rank tracking, all on autopilot.",
    "brand": { "@type": "Brand", "name": "theStacc" },
    "url": "https://thestacc.com/modules/local-seo/",
    "image": "https://thestacc.com/og/modules-local-seo.webp",
    "offers": {
      "@type": "Offer",
      "price": "49",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": "https://thestacc.com/checkout/"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "127"
    }
  }
};
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <a href="/integrations/google-business-profile/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Local SEO module · $49/mo</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">Local SEO software that <span class="accent">wins the Map Pack and "near me."</span></h1>
    <p class="hero-sub">For <strong>dentists, plumbers, lawyers, HVAC, real estate, and any business with a service area.</strong> theStacc posts to Google Business Profile every day, replies to reviews in minutes, builds citations, and tracks your rank — so customers find you first.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">R</div><div class="av">M</div><div class="av">S</div><div class="av">J</div></div>
        <span><strong>127+</strong> local businesses ranking</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST LOGOS -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Ranking local businesses for</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">92<span class="accent">%</span></div><div class="stat-label">Hit Map Pack top 3 · 90 days</div></div>
      <div class="stat-cell"><div class="stat-num">3<span class="accent">min</span></div><div class="stat-label">Average review-reply time</div></div>
      <div class="stat-cell"><div class="stat-num">+47<span class="accent"></span></div><div class="stat-label">Keywords ranked · 90 days</div></div>
      <div class="stat-cell"><div class="stat-num">$40<span class="accent">k+</span></div><div class="stat-label">Saved/year vs agency</div></div>
    </div>
  </section>

  <!-- THE 4 LOCAL SEO JOBS BENTO -->
  <section class="modules-bento" id="features">
    <div class="modules-tabs-header">
      <span class="label-pill">What this module does</span>
      <h2 class="h-lg">Four local SEO jobs. <span class="accent">One platform.</span></h2>
      <p class="lede">GBP posts, reviews, citations, and rank tracking — running every day, in your voice, with your approval rules.</p>
