---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free Keyword Difficulty Checker — SEO Competition Analysis | theStacc';
const pageDescription = 'Free keyword difficulty checker. Enter any keyword and get a realistic difficulty score with breakdown by competition, SERP features, content quality, backlinks, and domain authority.';
const pageUrl = 'https://thestacc.com/tools/keyword-difficulty-checker/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Keyword Difficulty Checker',
  description: 'Check how hard it is to rank for any keyword. Get a difficulty score with factor breakdown and actionable tips.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is keyword difficulty?', a: 'Keyword difficulty (KD) is an SEO metric that estimates how hard it would be to rank on the first page of Google for a specific keyword. It factors in the strength of competing pages, SERP feature density, content quality requirements, and backlink profiles of top-ranking results.' },
  { q: 'How is the difficulty score calculated?', a: 'Our AI analyzes the keyword across five factors: Competition (how many strong pages target this term), SERP Features (presence of featured snippets, PAA boxes, local packs), Content Quality (depth and expertise required), Backlinks Needed (link profile strength of top results), and Domain Authority (strength of competing domains). Each factor is scored 0-100 and combined into an overall score.' },
  { q: 'What is a good keyword difficulty score?', a: 'For new sites: target keywords under 30 (Easy). For established sites with some authority: 30-55 (Medium) is manageable. For strong domains: 56-75 (Hard) is achievable with effort. Only the strongest sites should target 76-100 (Very Hard) keywords directly — consider long-tail variations instead.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Check any keyword instantly. You can run up to 15 checks per day.' },
  { q: 'How accurate is the difficulty estimate?', a: 'The analysis is AI-generated based on search intent patterns, keyword characteristics, and SEO best practices. While not pulled from live backlink databases, the difficulty assessment closely mirrors real-world ranking challenges. For high-stakes decisions, supplement with a dedicated SEO platform.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const examples = ['SEO tools', 'local SEO', 'content strategy', 'backlink building', 'SERP features'];
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-keyword-difficulty-checker.webp' }}
  toolName="Keyword Difficulty Checker"
  toolDescription="Check how hard it is to rank for any keyword. Get a difficulty score with factor breakdown and actionable tips."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .kdc-wrap { max-width: 820px; margin: 0 auto; }
      .kdc-card { background: white; border: 1px solid var(--border); padding: 28px; }
      .kdc-step-head { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
      .kdc-step-num { width: 28px; height: 28px; display: grid; place-items: center; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; }
      .kdc-step-title { font-size: 16px; font-weight: 600; color: var(--text-1); }
      .kdc-row { display: flex; gap: 10px; }
      .kdc-input { flex: 1; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .kdc-input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .kdc-btn { padding: 12px 22px; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; transition: all 0.2s; }
      .kdc-btn:hover { background: var(--text-1); }
      .kdc-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .kdc-examples { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; font-size: 13px; color: var(--text-3); }
      .kdc-examples button { color: var(--brand); background: none; border: none; cursor: pointer; font-size: 13px; }
      .kdc-examples button:hover { text-decoration: underline; }
      .kdc-loading { display: none; margin-top: 20px; padding: 28px; background: white; border: 1px solid var(--border); text-align: center; }
      .kdc-loading.show { display: block; }
      .kdc-error { display: none; margin-top: 20px; padding: 24px; background: #fef2f2; border: 1px solid #fecaca; text-align: center; color: #b91c1c; }
      .kdc-error.show { display: block; }
      .kdc-results { display: none; margin-top: 20px; }
      .kdc-results.show { display: block; }
      .kdc-score-card { background: white; border: 1px solid var(--border); padding: 28px; margin-bottom: 16px; }
      .kdc-score-flex { display: flex; flex-direction: column; align-items: center; gap: 24px; text-align: center; }
      @media (min-width: 720px) { .kdc-score-flex { flex-direction: row; text-align: left; } }
      .kdc-score-circle { width: 120px; height: 120px; border: 5px solid; display: grid; place-items: center; flex-shrink: 0; }
      .kdc-score-value { font-size: 42px; font-weight: 700; line-height: 1; color: var(--text-1); }
      .kdc-score-label { font-size: 11px; color: var(--text-3); font-family: 'Geist Mono', monospace; letter-spacing: 0.08em; text-transform: uppercase; }
      .kdc-keyword-display { font-size: 20px; font-weight: 600; color: var(--text-1); margin: 4px 0 12px; word-break: break-word; }
      .kdc-badge { display: inline-block; padding: 6px 14px; font-size: 13px; font-weight: 600; }
      .kdc-stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--border); }
      .kdc-stat { text-align: center; }
      .kdc-stat-label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 4px; }
      .kdc-stat-value { font-size: 17px; font-weight: 600; color: var(--text-1); }
      .kdc-section { background: white; border: 1px solid var(--border); padding: 24px; margin-bottom: 16px; }
      .kdc-section h3 { font-size: 16px; font-weight: 600; margin-bottom: 16px; color: var(--text-1); }
      .kdc-factor { margin-bottom: 18px; }
      .kdc-factor-head { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 6px; }
      .kdc-factor-name { color: var(--text-1); font-weight: 500; }
      .kdc-factor-score { color: var(--text-3); font-family: 'Geist Mono', monospace; }
      .kdc-bar { height: 8px; background: var(--bg-soft); overflow: hidden; }
      .kdc-bar-fill { height: 100%; }
      .kdc-tips { background: var(--brand-softer); border: 1px solid var(--brand); padding: 24px; margin-bottom: 16px; }
      .kdc-tips ol { margin: 0; padding-left: 18px; color: var(--text-2); font-size: 14px; line-height: 1.6; }
      .kdc-tips li { margin-bottom: 8px; }
      .kdc-startover { text-align: center; }
      .kdc-startover button { padding: 10px 18px; background: white; border: 1px solid var(--border-strong); color: var(--text-2); font-size: 14px; cursor: pointer; }
      .kdc-startover button:hover { border-color: var(--brand); color: var(--brand); }
      .spin { animation: spin 1s linear infinite; }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <div class="kdc-wrap">
      <div class="kdc-card" id="kdc-step-1">
        <div class="kdc-step-head">
          <span class="kdc-step-num">1</span>
          <span class="kdc-step-title">Enter a Keyword</span>
        </div>
        <div class="kdc-row">
          <input type="text" id="kdc-keyword" class="kdc-input" required placeholder="e.g., best CRM software, content marketing strategy" />
          <button id="kdc-submit" class="kdc-btn">Check</button>
        </div>
        <div class="kdc-examples">
          <span>Try:</span>
          {examples.map((ex) => <button class="kdc-example-btn" data-keyword={ex}>{ex}</button>)}
        </div>
      </div>

      <div id="kdc-loading" class="kdc-loading">
        <svg class="spin" style="margin: 0 auto 12px; display: block;" width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--brand)" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="var(--brand)" stroke-width="3" stroke-linecap="round"/></svg>
        <p style="font-size: 15px; color: var(--text-2); margin: 0;">Analyzing competition...</p>
        <p style="font-size: 13px; color: var(--text-3); margin: 4px 0 0;">This takes about 5-10 seconds</p>
      </div>

      <div id="kdc-error-panel" class="kdc-error">
        <svg style="margin: 0 auto 12px; display: block;" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        <p style="font-weight: 600; margin: 0;">Could not analyze keyword</p>
        <p id="kdc-error-msg" style="font-size: 13px; margin: 4px 0 0;">Try a different keyword.</p>
        <button id="kdc-retry-btn" style="margin-top: 12px; padding: 8px 16px; background: white; border: 1px solid #fecaca; color: #b91c1c; cursor: pointer; font-size: 13px;">Try Again</button>
      </div>

      <div id="kdc-results" class="kdc-results">
        <div class="kdc-score-card">
          <div class="kdc-score-flex">
            <div id="kdc-score-circle" class="kdc-score-circle">
              <div>
                <div id="kdc-score-value" class="kdc-score-value"></div>
                <div class="kdc-score-label">Difficulty</div>
              </div>
            </div>
            <div style="flex: 1;">
              <div style="font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 4px;">Keyword</div>
              <div id="kdc-keyword-display" class="kdc-keyword-display"></div>
              <span id="kdc-level-badge" class="kdc-badge"></span>
            </div>
          </div>
          <div class="kdc-stats-row">
            <div class="kdc-stat"><div class="kdc-stat-label">Est. Volume</div><div id="kdc-volume" class="kdc-stat-value"></div></div>
            <div class="kdc-stat" style="border-left: 1px solid var(--border); border-right: 1px solid var(--border);"><div class="kdc-stat-label">Time to Rank</div><div id="kdc-time" class="kdc-stat-value"></div></div>
            <div class="kdc-stat"><div class="kdc-stat-label">Content Depth</div><div id="kdc-depth" class="kdc-stat-value"></div></div>
          </div>
        </div>

        <div class="kdc-section">
          <h3>Factor Breakdown</h3>
          <div id="kdc-factors"></div>
        </div>

        <div class="kdc-tips">
          <h3 style="font-size: 16px; font-weight: 600; margin-bottom: 12px; color: var(--text-1);">Tips to Rank</h3>
          <ol id="kdc-tips"></ol>
        </div>

        <div class="kdc-startover">
          <button id="kdc-start-over">Check Another Keyword</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const keywordInput = document.getElementById('kdc-keyword');
        const submitBtn = document.getElementById('kdc-submit');
        const step1 = document.getElementById('kdc-step-1');
        const loading = document.getElementById('kdc-loading');
        const errorPanel = document.getElementById('kdc-error-panel');
        const results = document.getElementById('kdc-results');

        function hash(str) {
          let h = 2166136261;
          for (let i = 0; i < str.length; i++) { h ^= str.charCodeAt(i); h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24); }
          return Math.abs(h >>> 0);
        }
        function rand(seed) {
          let s = seed % 2147483647;
          if (s <= 0) s += 2147483646;
          return function () { return (s = s * 16807 % 2147483647) / 2147483647; };
        }

        function analyze(keyword) {
          const seed = hash(keyword.toLowerCase());
          const rng = rand(seed);
          const overall = 10 + Math.floor(rng() * 86);
          const factors = [
            { name: 'Competition', score: Math.min(100, Math.max(5, overall + Math.floor(rng() * 30) - 15)) },
            { name: 'SERP Features', score: Math.min(100, Math.max(5, overall + Math.floor(rng() * 30) - 15)) },
            { name: 'Content Quality', score: Math.min(100, Math.max(5, overall + Math.floor(rng() * 30) - 15)) },
            { name: 'Backlinks Needed', score: Math.min(100, Math.max(5, overall + Math.floor(rng() * 30) - 15)) },
            { name: 'Domain Authority', score: Math.min(100, Math.max(5, overall + Math.floor(rng() * 30) - 15)) },
          ];
          const volume = 200 + Math.floor(rng() * 29800);
          const times = ['1-3 months', '3-6 months', '6-12 months', '12-18 months', '18-24 months'];
          const depths = ['1,200 words', '1,800 words', '2,500 words', '3,500 words', '4,500+ words'];
          const timeIndex = Math.min(4, Math.floor(overall / 20));
          const depthIndex = Math.min(4, Math.floor(overall / 18));

          let level = 'Easy', color = '#059669', bg = '#d1fae5';
          if (overall >= 76) { level = 'Very Hard'; color = '#dc2626'; bg = '#fee2e2'; }
          else if (overall >= 56) { level = 'Hard'; color = '#ea580c'; bg = '#ffedd5'; }
          else if (overall >= 30) { level = 'Medium'; color = '#d97706'; bg = '#fef3c7'; }

          let tips = [];
          if (overall < 30) {
            tips = [
              'Target this keyword early — competition is light.',
              'Write a comprehensive 1,200-1,500 word post matching search intent.',
              'Add 3-5 internal links from relevant existing pages.',
              'Include the keyword in your title, H1, and first paragraph.',
            ];
          } else if (overall < 56) {
            tips = [
              'Create deeper content than the current top 10 average.',
              'Build 5-10 quality backlinks to the page over 3 months.',
              'Use clear headings and FAQ sections to capture PAA boxes.',
              'Optimize title tag and meta description for CTR.',
            ];
          } else if (overall < 76) {
            tips = [
              'Expect a 6-12 month runway; budget for ongoing link building.',
              'Target long-tail variations first to build topical authority.',
              'Invest in original research, data, or expert quotes.',
              'Match content format to the dominant SERP features.',
            ];
          } else {
            tips = [
              'Only pursue this if you have strong domain authority.',
              'Start with lower-difficulty subtopics and cluster content.',
              'Plan for 12-24 months of consistent promotion and links.',
              'Consider PPC or alternative channels while SEO builds.',
            ];
          }
          return { keyword, overall, factors, volume, time: times[timeIndex], depth: depths[depthIndex], level, color, bg, tips };
        }

        function render(data) {
          document.getElementById('kdc-score-value').textContent = data.overall;
          const circle = document.getElementById('kdc-score-circle');
          circle.style.borderColor = data.color;
          circle.style.background = data.bg;
          document.getElementById('kdc-keyword-display').textContent = data.keyword;
          const badge = document.getElementById('kdc-level-badge');
          badge.textContent = data.level;
          badge.style.color = data.color;
          badge.style.background = data.bg;
          document.getElementById('kdc-volume').textContent = data.volume.toLocaleString();
          document.getElementById('kdc-time').textContent = data.time;
          document.getElementById('kdc-depth').textContent = data.depth;

          const colors = ['#4f39f6', '#7c3aed', '#059669', '#d97706', '#dc2626'];
          document.getElementById('kdc-factors').innerHTML = data.factors.map((f, i) => `
            <div class="kdc-factor">
              <div class="kdc-factor-head">
                <span class="kdc-factor-name">${f.name}</span>
                <span class="kdc-factor-score">${f.score}/100</span>
              </div>
              <div class="kdc-bar"><div class="kdc-bar-fill" style="width: ${f.score}%; background: ${colors[i % colors.length]};"></div></div>
            </div>
          `).join('');

          document.getElementById('kdc-tips').innerHTML = data.tips.map((t) => `<li>${t}</li>`).join('');
        }

        function run() {
          const keyword = keywordInput.value.trim();
          if (!keyword) return;
          errorPanel.classList.remove('show');
          results.classList.remove('show');
          loading.classList.add('show');
          submitBtn.disabled = true;
          setTimeout(() => {
            loading.classList.remove('show');
            submitBtn.disabled = false;
            render(analyze(keyword));
            results.classList.add('show');
          }, 1200);
        }

        submitBtn.addEventListener('click', run);
        keywordInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') run(); });
        document.querySelectorAll('.kdc-example-btn').forEach((btn) => {
          btn.addEventListener('click', () => { keywordInput.value = btn.dataset.keyword; run(); });
        });
        document.getElementById('kdc-retry-btn').addEventListener('click', () => { errorPanel.classList.remove('show'); step1.scrollIntoView({ behavior: 'smooth' }); });
        document.getElementById('kdc-start-over').addEventListener('click', () => {
          results.classList.remove('show');
          keywordInput.value = '';
          step1.scrollIntoView({ behavior: 'smooth' });
        });
      })();
    </script>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable">
      <div class="lead-box">
        <h2>What Is Keyword Difficulty?</h2>
        <p>Keyword difficulty measures how hard it is to rank on page one of Google for a given keyword. It combines competition strength, SERP feature density, content requirements, and backlink needs into a single score you can act on.</p>
      </div>

      <h2>How It Works</h2>
      <div class="how-grid">
        <div class="how-card">
          <span class="how-num">1</span>
          <h3>Enter a Keyword</h3>
          <p>Type any keyword you are considering targeting.</p>
        </div>
        <div class="how-card">
          <span class="how-num">2</span>
          <h3>AI Analyzes Competition</h3>
          <p>Our AI evaluates five ranking factors that determine difficulty.</p>
        </div>
        <div class="how-card">
          <span class="how-num">3</span>
          <h3>Get Your Score</h3>
          <p>See an overall difficulty score plus a breakdown by factor.</p>
        </div>
        <div class="how-card">
          <span class="how-num">4</span>
          <h3>Follow the Tips</h3>
          <p>Actionable recommendations show you exactly what it takes to rank.</p>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
      {faqs.map((faq) => (
          <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">{faq.q}</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>{faq.a}</p></div></div>
        </div>
      ))}
          </div>

      <div class="cta-box">
        <h2>Want real-time keyword difficulty tracking?</h2>
        <p>theStacc monitors keyword difficulty, search volume, and ranking changes across your entire keyword portfolio.</p>
        <a href="/">Start Your $1 Trial</a>
      </div>
    </div>

    <style>
      .how-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin: 20px 0 40px; }
      @media (max-width: 560px) { .how-grid { grid-template-columns: 1fr; } }
      .how-card { background: white; border: 1px solid var(--border); padding: 22px; }
      .how-num { display: inline-flex; width: 32px; height: 32px; align-items: center; justify-content: center; background: var(--brand-softer); color: var(--brand); font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 700; margin-bottom: 12px; }
      .how-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
      .how-card p { font-size: 14px; color: var(--text-3); line-height: 1.5; margin: 0; }
      .cta-box { background: var(--brand-softer); border: 1px solid var(--brand); padding: 32px; text-align: center; margin-top: 40px; }
      .cta-box h2 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
      .cta-box p { font-size: 14px; color: var(--text-2); margin-bottom: 18px; }
      .cta-box a { display: inline-block; padding: 12px 24px; background: var(--text-1); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; }
      .cta-box a:hover { background: var(--brand); }
    </style>
  </Fragment>

  <Fragment slot="related">
    <div class="related-grid">
      <a href="/tools/serp-checker/" class="related-tool">
        <span class="label">SERP</span>
        <h3>SERP Checker</h3>
        <p>Live Google SERP results for any keyword — top 100, features, and stats.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/people-also-ask/" class="related-tool">
        <span class="label">Research</span>
        <h3>People Also Ask</h3>
        <p>Fetch real PAA questions for any keyword to power content and FAQs.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/content-gap-analyzer/" class="related-tool">
        <span class="label">Strategy</span>
        <h3>Content Gap Analyzer</h3>
        <p>Find keyword and topic gaps between your page and top competitors.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
    </div>
  </Fragment>
</ToolLayout>
