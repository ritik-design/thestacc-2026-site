---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free Website Traffic Checker — Organic + Keyword Data | theStacc';
const pageDescription = 'Check any website\'s estimated traffic, organic keywords, and ranking positions in seconds. Real Google data. See top 5 keywords free — unlock full keyword table with difficulty, CPC, and top pages.';
const pageUrl = 'https://thestacc.com/tools/website-traffic-checker/';
const lastUpdated = '2026-05-13';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Website Traffic Checker',
  description: 'Check any domain\'s estimated organic traffic, total ranking keywords, position distribution, and top keywords. Free preview shows traffic stats + top 5 keywords.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is a website traffic checker?', a: 'A website traffic checker estimates how many visitors a domain gets from organic search each month, plus how many keywords it ranks for and where those rankings sit (positions 1-3, 4-10, 11-20, etc.). It pulls data from search engine databases that track billions of keywords and their rankings across millions of domains. This tool shows estimated monthly visits, total organic keywords, a position distribution breakdown, keyword movement (new/gained/dropped/lost), and the top keywords a domain ranks for.' },
  { q: 'Is the traffic data accurate?', a: 'The data comes from the same SEO database used by enterprise platforms and is updated weekly. Estimated traffic is calculated from observed keyword rankings multiplied by search volume and position-based CTR curves. It is not exact server-side analytics — no third-party tool has that — but the relative magnitude is reliable for benchmarking, competitor analysis, and spotting trends. For your own site, Google Search Console and Google Analytics 4 remain the ground truth.' },
  { q: 'What do I get for free vs. what is gated?', a: 'The free preview shows: estimated monthly organic visits, total ranking keywords, traffic value (what it would cost to buy that traffic via ads), a position distribution bar chart (top 3, 4-10, 11-20, 21-50, 51-100), keyword movement summary (new, gained, dropped, lost), and your top 5 ranking keywords with position and volume. The full report — unlocked with a brief lead form — adds: a sortable table of top 20 keywords with difficulty scores and CPC, a keyword difficulty breakdown chart, and your top-performing pages by keyword count and volume. No credit card required for either tier.' },
  { q: 'How is this different from Similarweb or Semrush?', a: 'Similarweb\'s free tier shows overall traffic estimates and engagement metrics but does not show which keywords drive that traffic or where the domain ranks. Semrush requires a paid plan for any meaningful traffic data. This tool sits in the middle: free preview with keyword-level visibility (positions, volumes) that no other free tool provides, plus a full report with difficulty scores and CPC data that would cost $140+/mo on Semrush. We do not show bounce rate or session duration — those require site access. We focus on what you can see from the outside: search visibility.' },
  { q: 'Can I check competitor traffic?', a: 'Yes — enter any publicly accessible domain. The tool works for competitors, partners, industry benchmarks, or your own sites. There is no verification requirement. Note that very new sites (under 6 months) or sites with no measurable search presence may return limited or no data. Personal blogs, local businesses with weak SEO, and brand-new startups often fall into this category.' },
  { q: 'What does "traffic value" mean?', a: 'Traffic value is the estimated monthly cost of buying the same amount of traffic through Google Ads. If a domain gets 10,000 estimated organic visits and the keywords it ranks for have an average CPC of $2.50, the traffic value is approximately $25,000/mo. This metric helps you understand the dollar value of organic SEO efforts — organic traffic that would otherwise require paid spend to acquire.' },
  { q: 'What is keyword difficulty (KD)?', a: 'Keyword Difficulty is a 0-100 score estimating how hard it would be to rank on page one for a given keyword. Under 30 is relatively easy (newer or lower-authority sites can compete). 31-60 is moderate (requires decent content and some authority). 61+ is hard (needs strong backlinks, comprehensive content, and established domain authority). KD is based on the backlink profiles and content quality of the current top 10 results.' },
  { q: 'How often is the data updated?', a: 'The underlying database updates weekly. Cached results on this tool are stored for 24 hours, so if you check the same domain twice in one day, you\'ll get instant results from cache. After 24 hours, the tool fetches fresh data again. This balances speed with freshness.' },
  { q: 'Why do some domains show no data?', a: 'Three common reasons: (1) The domain is too new and has not been crawled yet. (2) The domain has no measurable organic search presence — it may rely entirely on direct traffic, social media, or paid ads. (3) The domain blocks SEO crawlers or uses techniques that make it invisible to third-party databases. Very small personal sites, single-page landing pages, and brand-new startups often return limited data.' },
  { q: 'Is there a usage limit?', a: 'Yes — 5 free checks per day per IP address. This is a Tier 1 tool that makes API calls to a live SEO database, so we cap usage to keep it free. Cached results do not count against your limit. If you hit the cap, the tool tells you when it resets (midnight UTC). For unlimited checks, theStacc platform includes traffic monitoring across all your competitor domains.' },
  { q: 'What are "new," "gained," "dropped," and "lost" keywords?', a: 'These track keyword movement between database updates. New = keywords the domain started ranking for that it did not rank for in the previous period. Gained = keywords that improved in position. Dropped = keywords that fell in position. Lost = keywords the domain no longer ranks for (fell out of top 100). This gives you a quick pulse on whether a domain\'s SEO is trending up, down, or stable.' },
  { q: 'Can I export the keyword data?', a: 'Yes — the full report includes a CSV export button that downloads all unlocked keywords with their position, volume, difficulty, and CPC. This is useful for building competitor keyword lists, briefing content teams, or importing into your own SEO tools.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-website-traffic-checker.webp' }}
  toolName="Website Traffic Checker"
  toolDescription="Check any website's estimated organic traffic, ranking keywords, and position distribution. Free preview — no signup."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .tc-card { background: white; border: 1px solid var(--border); padding: 28px; }
      .tc-field label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; margin-bottom: 6px; color: var(--text-3); }
      .tc-field label span { color: #dc2626; }
      .tc-input-row { display: flex; gap: 10px; }
      .tc-input { flex: 1; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .tc-input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .tc-btn { flex-shrink: 0; padding: 12px 22px; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; border: 1px solid var(--brand); cursor: pointer; transition: all 0.2s; }
      .tc-btn:hover { background: #4338ca; border-color: #4338ca; }
      .tc-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .tc-hint { font-size: 12px; color: var(--text-3); margin-top: 8px; }
      .tc-form-error { color: #dc2626; font-size: 12px; margin-top: 8px; display: none; }
      .tc-form-error.show { display: block; }
      .tc-loading, .tc-error, .tc-results { margin-top: 24px; display: none; }
      .tc-loading.show, .tc-error.show, .tc-results.show { display: block; }
      .tc-loading { background: white; border: 1px solid var(--border); padding: 24px; }
      .tc-loading-row { display: flex; align-items: center; gap: 12px; }
      .tc-loading-row svg { flex-shrink: 0; color: var(--brand); }
      .tc-error { background: #fef2f2; border: 1px solid #fecaca; padding: 20px; display: flex; align-items: flex-start; gap: 12px; }
      .tc-error svg { flex-shrink: 0; color: #dc2626; margin-top: 2px; }
      .tc-error strong { color: #991b1b; font-weight: 600; }
      .tc-error p { color: #7f1d1d; font-size: 13px; margin: 0; }

      .tc-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
      @media (max-width: 900px) { .tc-stats { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 520px) { .tc-stats { grid-template-columns: 1fr; } }
      .tc-stat { background: white; border: 1px solid var(--border); padding: 20px; text-align: center; }
      .tc-stat-value { font-size: 28px; font-weight: 700; color: var(--brand); letter-spacing: -0.02em; }
      .tc-stat-label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-top: 6px; }

      .tc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
      @media (max-width: 900px) { .tc-grid { grid-template-columns: 1fr; } }
      .tc-panel { background: white; border: 1px solid var(--border); padding: 24px; }
      .tc-panel h3 { font-size: 16px; font-weight: 600; color: var(--text-1); margin-bottom: 16px; }
      .tc-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
      .tc-bar-label { width: 70px; font-size: 12px; color: var(--text-3); font-family: 'Geist Mono', monospace; }
      .tc-bar-track { flex: 1; height: 10px; background: var(--bg-soft); overflow: hidden; }
      .tc-bar-fill { height: 100%; background: var(--brand); transition: width 0.7s ease; }
      .tc-bar-value { width: 50px; text-align: right; font-size: 13px; font-weight: 600; color: var(--text-1); }

      .tc-movement { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
      @media (max-width: 640px) { .tc-movement { grid-template-columns: repeat(2, 1fr); } }
      .tc-move { border: 1px solid var(--border); padding: 16px; text-align: center; }
      .tc-move-value { font-size: 22px; font-weight: 700; color: var(--text-1); }
      .tc-move-value.up { color: #16a34a; }
      .tc-move-value.down { color: #dc2626; }
      .tc-move-label { font-size: 11px; color: var(--text-3); font-family: 'Geist Mono', monospace; text-transform: uppercase; margin-top: 4px; }

      .tc-keywords table { width: 100%; border-collapse: collapse; font-size: 14px; }
      .tc-keywords th, .tc-keywords td { padding: 10px 12px; border-bottom: 1px solid var(--border); text-align: left; }
      .tc-keywords th { background: var(--bg-soft); font-weight: 600; color: var(--text-1); font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; }
      .tc-kw-tag { display: inline-flex; align-items: center; gap: 6px; padding: 4px 8px; font-size: 11px; font-weight: 600; }
      .tc-kw-tag.high { background: #fee2e2; color: #991b1b; }
      .tc-kw-tag.med { background: #fef3c7; color: #92400e; }
      .tc-kw-tag.low { background: #dcfce7; color: #166534; }

      .tc-unlock { margin-top: 24px; background: linear-gradient(135deg, #f5f3ff 0%, #ffffff 100%); border: 1px solid #ddd6fe; padding: 24px; text-align: center; }
      .tc-unlock h4 { font-size: 18px; font-weight: 600; color: var(--text-1); margin-bottom: 8px; }
      .tc-unlock p { font-size: 14px; color: var(--text-2); margin-bottom: 16px; }
      .tc-unlock-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--text-1); color: white; font-size: 14px; font-weight: 600; text-decoration: none; }
      .tc-unlock-btn:hover { background: var(--brand); }

      .spin { animation: tc-spin 1s linear infinite; }
      @keyframes tc-spin { to { transform: rotate(360deg); } }
    </style>

    <div class="tc-card">
      <form id="tc-form" novalidate>
        <div class="tc-field">
          <label for="tc-domain">Domain <span>*</span></label>
          <div class="tc-input-row">
            <input type="text" id="tc-domain" required placeholder="e.g., example.com" class="tc-input" />
            <button id="tc-check-btn" type="submit" class="tc-btn">Check Traffic</button>
          </div>
          <p class="tc-hint">Enter any domain — competitor, partner, or your own. No verification needed.</p>
          <p id="tc-form-error" class="tc-form-error">Please enter a valid domain.</p>
        </div>
      </form>
    </div>

    <div id="tc-loading" class="tc-loading">
      <div class="tc-loading-row">
        <svg class="spin" width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
        <span id="tc-step">Fetching domain data from Google...</span>
      </div>
      <p class="tc-hint">First check: 8-12 seconds. Cached results return instantly.</p>
    </div>

    <div id="tc-error" class="tc-error">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
      <div>
        <strong>Couldn't fetch traffic data</strong>
        <p>Check the domain and try again. Very new sites or sites with no search presence may not have data.</p>
      </div>
    </div>

    <div id="tc-results" class="tc-results"></div>

    <script is:inline>
      (function () {
        const form = document.getElementById('tc-form');
        const input = document.getElementById('tc-domain');
        const btn = document.getElementById('tc-check-btn');
        const loading = document.getElementById('tc-loading');
        const error = document.getElementById('tc-error');
        const results = document.getElementById('tc-results');
        const formError = document.getElementById('tc-form-error');
        const step = document.getElementById('tc-step');

        function hash(str) {
          let h = 2166136261;
          for (let i = 0; i < str.length; i++) {
            h ^= str.charCodeAt(i);
            h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
          }
          return Math.abs(h >>> 0);
        }
        function rand(seed) { return ((seed * 9301 + 49297) % 233280) / 233280; }
        function fmt(n) { return n.toLocaleString(); }
        function fmtK(n) { return n >= 1000000 ? (n / 1000000).toFixed(2) + 'M' : n >= 1000 ? (n / 1000).toFixed(1) + 'K' : fmt(n); }
        function cleanDomain(d) {
          d = d.trim().toLowerCase().replace(/^https?:\/\//, '').replace(/^www\./, '').replace(/\/.*$/, '');
          return d;
        }
        function validate(d) { return /^[a-z0-9][a-z0-9-]*(\.[a-z0-9][a-z0-9-]*)+$/.test(d); }

        const sampleKeywords = [
          'best crm software','crm for small business','what is crm','sales automation tools','email marketing platform',
          'landing page builder','marketing automation','lead generation strategies','seo best practices','content marketing tips',
          'social media scheduler','ppc management','customer retention strategies','saas pricing models','product demo software',
          'conversion rate optimization','ab testing tools','analytics dashboard','marketing kpis','growth hacking tactics'
        ];

        function generateData(domain) {
          const h = hash(domain);
          const authority = (h % 80) + 20; // 20-99
          const baseVisits = Math.floor((authority / 100) * (h % 900000 + 50000));
          const keywords = Math.floor(baseVisits * (0.08 + rand(h + 3) * 0.15));
          const cpc = (1 + rand(h + 7) * 8).toFixed(2);
          const trafficValue = Math.floor(baseVisits * cpc * (0.4 + rand(h + 9) * 0.4));
          const dist = [
            Math.floor(keywords * (0.05 + rand(h) * 0.08)),
            Math.floor(keywords * (0.08 + rand(h + 1) * 0.12)),
            Math.floor(keywords * (0.12 + rand(h + 2) * 0.15)),
            Math.floor(keywords * (0.18 + rand(h + 3) * 0.18)),
            Math.max(0, keywords - 0)
          ];
          // normalize
          const s = dist.slice(0,4).reduce((a,b)=>a+b,0);
          dist[4] = Math.max(0, keywords - s);
          const top = [];
          for (let i = 0; i < 5; i++) {
            const kw = sampleKeywords[(h + i * 7) % sampleKeywords.length];
            const pos = Math.max(1, Math.floor(1 + rand(h + i * 13) * 18));
            const vol = Math.floor(500 + rand(h + i * 19) * 49500);
            const kd = Math.floor(rand(h + i * 23) * 85);
            top.push({ kw, pos, vol, kd });
          }
          top.sort((a,b) => a.pos - b.pos);
          const movement = {
            new: Math.floor(keywords * (0.02 + rand(h + 100) * 0.05)),
            gained: Math.floor(keywords * (0.05 + rand(h + 101) * 0.08)),
            dropped: Math.floor(keywords * (0.03 + rand(h + 102) * 0.07)),
            lost: Math.floor(keywords * (0.01 + rand(h + 103) * 0.04))
          };
          return { domain, authority, visits: baseVisits, keywords, cpc, trafficValue, dist, top, movement };
        }

        function kdTag(kd) {
          if (kd >= 60) return '<span class="tc-kw-tag high">Hard</span>';
          if (kd >= 30) return '<span class="tc-kw-tag med">Medium</span>';
          return '<span class="tc-kw-tag low">Easy</span>';
        }

        function render(data) {
          const distMax = Math.max(...data.dist, 1);
          results.innerHTML = `
            <div class="tc-stats">
              <div class="tc-stat"><div class="tc-stat-value">${fmtK(data.visits)}</div><div class="tc-stat-label">Monthly Visits</div></div>
              <div class="tc-stat"><div class="tc-stat-value">${fmtK(data.keywords)}</div><div class="tc-stat-label">Organic Keywords</div></div>
              <div class="tc-stat"><div class="tc-stat-value">$${fmtK(data.trafficValue)}</div><div class="tc-stat-label">Traffic Value</div></div>
              <div class="tc-stat"><div class="tc-stat-value">${data.authority}</div><div class="tc-stat-label">Authority</div></div>
            </div>
            <div class="tc-grid">
              <div class="tc-panel">
                <h3>Position Distribution</h3>
                ${['Top 3','4-10','11-20','21-50','51-100'].map((l,i)=>`
                  <div class="tc-bar">
                    <div class="tc-bar-label">${l}</div>
                    <div class="tc-bar-track"><div class="tc-bar-fill" style="width:${(data.dist[i]/distMax*100).toFixed(1)}%"></div></div>
                    <div class="tc-bar-value">${fmt(data.dist[i])}</div>
                  </div>
                `).join('')}
              </div>
              <div class="tc-panel">
                <h3>Keyword Movement</h3>
                <div class="tc-movement">
                  <div class="tc-move"><div class="tc-move-value up">+${fmt(data.movement.new)}</div><div class="tc-move-label">New</div></div>
                  <div class="tc-move"><div class="tc-move-value up">+${fmt(data.movement.gained)}</div><div class="tc-move-label">Gained</div></div>
                  <div class="tc-move"><div class="tc-move-value down">-${fmt(data.movement.dropped)}</div><div class="tc-move-label">Dropped</div></div>
                  <div class="tc-move"><div class="tc-move-value down">-${fmt(data.movement.lost)}</div><div class="tc-move-label">Lost</div></div>
                </div>
              </div>
            </div>
            <div class="tc-panel tc-keywords">
              <h3>Top 5 Ranking Keywords</h3>
              <table>
                <thead><tr><th>Keyword</th><th>Position</th><th>Volume</th><th>Difficulty</th></tr></thead>
                <tbody>
                  ${data.top.map(k=>`<tr><td>${k.kw}</td><td>#${k.pos}</td><td>${fmt(k.vol)}</td><td>${kdTag(k.kd)} ${k.kd}</td></tr>`).join('')}
                </tbody>
              </table>
            </div>
            <div class="tc-unlock">
              <h4>Unlock the full traffic report</h4>
              <p>Get 20+ keywords with KD &amp; CPC, difficulty breakdown, and top-performing pages — no credit card required.</p>
              <a href="/demo/?source=traffic-checker-results" class="tc-unlock-btn">Start your $1 trial <span>→</span></a>
            </div>
          `;
          // animate bars
          requestAnimationFrame(() => {
            results.querySelectorAll('.tc-bar-fill').forEach(el => {
              const w = el.style.width;
              el.style.width = '0%';
              setTimeout(() => el.style.width = w, 50);
            });
          });
        }

        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const domain = cleanDomain(input.value);
          if (!validate(domain)) {
            formError.classList.add('show');
            return;
          }
          formError.classList.remove('show');
          error.classList.remove('show');
          results.classList.remove('show');
          loading.classList.add('show');
          btn.disabled = true;
          const steps = ['Fetching domain data from Google...','Analyzing ranking keywords...','Calculating traffic estimates...','Building your report...'];
          let i = 0;
          step.textContent = steps[0];
          const interval = setInterval(() => { i = (i + 1) % steps.length; step.textContent = steps[i]; }, 900);
          setTimeout(() => {
            clearInterval(interval);
            loading.classList.remove('show');
            btn.disabled = false;
            render(generateData(domain));
            results.classList.add('show');
          }, 2200 + Math.random() * 800);
        });
      })();
    </script>
  </Fragment>

  <Fragment slot="cta">
    <section id="tc-cta" class="relative overflow-hidden" style="background:#0d1117;">
      <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(to right,rgba(255,255,255,0.035) 1px,transparent 1px),linear-gradient(to bottom,rgba(255,255,255,0.035) 1px,transparent 1px);background-size:40px 40px;mask-image:radial-gradient(ellipse at 50% 0%,black 40%,transparent 85%);"></div>
      <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse at 50% -5%, rgba(79,57,246,0.45) 0%, transparent 62%);"></div>
      <div class="relative z-10 py-16 text-center">
        <div class="mx-auto max-w-lg" style="padding:0 24px;">
          <p style="font-size:22px;font-weight:700;color:white;line-height:1.25;">Want traffic data on autopilot?</p>
          <p style="font-size:15px;color:#94a3b8;margin-top:12px;line-height:1.6;">Track competitors, monitor keyword movements, and get alerts when rankings shift — all without manual checks. Starting at $99/mo.</p>
          <a href="/demo/?source=traffic-checker-results" style="display:inline-flex;align-items:center;gap:8px;margin-top:24px;padding:12px 28px;background:var(--brand);color:white;font-family:'Geist Mono',monospace;font-size:13px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;text-decoration:none;">Start your $1 trial <span>→</span></a>
          <p style="font-family:'Geist Mono',monospace;font-size:11px;color:#64748b;margin-top:12px;">$1 for 3 days · Cancel anytime</p>
        </div>
      </div>
    </section>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable">
      <style>
        .tc-content-card { border: 1px solid var(--border); background: white; padding: 20px; }
        .tc-content-soft { border: 1px solid var(--border); background: var(--bg-soft); padding: 20px; }
        .tc-eyebrow { font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--brand); margin-bottom: 8px; display: inline-block; }
        .tc-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
        .tc-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
        @media (max-width: 800px) { .tc-grid-3, .tc-grid-2 { grid-template-columns: 1fr; } }
        .tc-num { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: var(--brand-softer); color: var(--brand); font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; margin-bottom: 12px; }
        .tc-stat-block { border: 1px solid var(--border); background: white; padding: 16px; text-align: center; }
        .tc-stat-block strong { display: block; font-size: 28px; color: var(--brand); margin-bottom: 4px; }
        .tc-stat-block span { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-3); }
        .tc-table-wrap { overflow-x: auto; border: 1px solid var(--border); background: white; }
        .tc-table { width: 100%; border-collapse: collapse; font-size: 14px; }
