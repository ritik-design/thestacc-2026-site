---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free SERP Checker — Live Google Results + Feature Analysis | theStacc';
const pageDescription = 'Check live Google SERP results for any keyword. See top 100 rankings, SERP feature detection (featured snippets, PAA, local pack, videos), keyword stats, and domain frequency analysis. Free, instant.';
const pageUrl = 'https://thestacc.com/tools/serp-checker/';
const lastUpdated = '2026-05-13';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free SERP Checker',
  description: 'Check live Google SERP results for any keyword. See top 100 organic rankings, detect SERP features (featured snippets, People Also Ask, local pack, images, videos, knowledge graph), keyword stats (volume, difficulty, CPC, intent), and domain frequency analysis. Free preview shows top 10 + all features.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is a SERP checker?', a: 'A SERP (Search Engine Results Page) checker shows you exactly what appears on Google for any keyword — the organic rankings, featured snippets, People Also Ask boxes, local packs, images, videos, knowledge panels, and more. This tool fetches live Google SERP data and presents it in a clean, readable format with keyword stats (search volume, difficulty, CPC, intent) and a domain frequency analysis showing which sites dominate the results.' },
  { q: 'Is the SERP data live and accurate?', a: 'Yes — the data comes directly from Google search results via the DataForSEO API, which pulls fresh SERP snapshots. The results you see reflect what Google is showing right now for that keyword in the selected location. Data updates in real-time on each check (cached for 24 hours for repeat searches to keep the tool fast).' },
  { q: 'How many results can I see?', a: 'The free view shows the top 10 organic results plus all detected SERP features (featured snippets, People Also Ask, local pack, images, videos, knowledge graph, related searches, top stories, shopping). Click "Show All Results" to expand the full top 100 organic rankings, domain frequency chart, and CSV export. No email or signup required to expand.' },
  { q: 'What SERP features does this tool detect?', a: 'The tool detects 9 SERP feature types: Featured Snippet (with title, description, and URL preview), People Also Ask (with question count and answer previews), Local Pack (with business names and ratings), Images, Videos, Knowledge Graph, Related Searches (with term list), Top Stories, and Shopping results. Each feature is shown as a color-coded badge so you can see the full SERP landscape at a glance.' },
  { q: 'How is this different from Mangools or Ahrefs SERP checker?', a: 'Mangools SERPChecker shows position tracking and SERP features but is limited on the free plan. Ahrefs requires a paid subscription for any meaningful SERP data. This tool offers something neither free competitor provides: live top 100 organic results with all SERP feature detection, keyword difficulty, CPC, and search intent in a single view — with no account required. The domain frequency analysis (showing which domains appear most often in the top 100) is unique to this tool.' },
  { q: 'What locations are supported?', a: 'United States, United Kingdom, Canada, Australia, and India. Each location uses the correct Google search engine and local ranking signals. More locations can be added on request — the underlying API supports 50+ countries.' },
  { q: 'What does the domain frequency chart show?', a: 'When you expand the full results, the domain frequency chart shows which domains appear most often in the top 100 results for your keyword. For example, if Wikipedia ranks for 8 different positions, it shows "Wikipedia — 8 results — best position #2." This helps you identify SERP dominance patterns and understand which competitors you are really up against.' },
  { q: 'What is keyword difficulty (KD)?', a: 'Keyword Difficulty is a 0-100 score estimating how hard it would be to rank on page one for the given keyword. Under 30 is relatively easy for newer sites. 31-60 is moderate and requires decent content and authority. 61+ is hard and needs strong backlinks and comprehensive content. KD is calculated from the backlink profiles and content quality of the current top 10 results.' },
  { q: 'What does "search intent" mean?', a: 'Search intent classifies what the user is trying to accomplish: Informational (learn something), Transactional (buy something), Navigational (find a specific site), or Commercial (compare options before buying). Understanding intent helps you create content that matches what Google is already rewarding. This tool shows the dominant intent for your keyword based on analysis of the top-ranking pages.' },
  { q: 'Why do some keywords show no data?', a: 'Three common reasons: (1) The keyword is brand-new or has extremely low search volume and has not been indexed by third-party databases yet. (2) The keyword contains special characters or is too long (over 100 characters). (3) The location selected does not have sufficient data coverage for that keyword. Try a broader or more common variant of the keyword.' },
  { q: 'Is there a usage limit?', a: 'Yes — 5 free checks per day per IP address. This prevents API abuse and keeps the tool free for everyone. Cached results (checking the same keyword + location within 24 hours) do not count against your limit. For unlimited SERP checks and automated monitoring, theStacc platform includes rank tracking across all your target keywords.' },
  { q: 'Can I export the results?', a: 'Yes — the expanded full results include a CSV export button that downloads all organic rankings with position, title, URL, domain, and description. This is useful for competitor analysis, client reporting, and building your own tracking spreadsheets.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const locations = [
  { value: 'us', label: 'United States' },
  { value: 'uk', label: 'United Kingdom' },
  { value: 'ca', label: 'Canada' },
  { value: 'au', label: 'Australia' },
  { value: 'in', label: 'India' },
];
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-serp-checker.webp' }}
  toolName="SERP Checker"
  toolDescription="Check live Google SERP results for any keyword. Top 100 rankings, SERP feature detection, keyword stats, and domain analysis. Free."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .serp-card { background: white; border: 1px solid var(--border); padding: 28px; max-width: 880px; margin: 0 auto; }
      .serp-card h2 { font-size: 22px; font-weight: 600; margin-bottom: 4px; }
      .serp-card .sub { font-size: 13px; color: var(--text-3); margin-bottom: 20px; }
      .serp-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: stretch; }
      .serp-field { flex: 1 1 240px; display: flex; flex-direction: column; gap: 6px; }
      .serp-field label { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-1); }
      .serp-field input, .serp-field select { width: 100%; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .serp-field input:focus, .serp-field select:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .serp-btn { padding: 12px 22px; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; transition: all 0.2s; }
      .serp-btn:hover { background: var(--text-1); }
      .serp-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .serp-help { font-size: 12px; color: var(--text-3); margin-top: 8px; }
      .serp-error { margin-top: 20px; padding: 16px; background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; display: none; align-items: flex-start; gap: 12px; }
      .serp-error.show { display: flex; }
      .serp-loading { margin-top: 20px; padding: 20px; background: white; border: 1px solid var(--border); display: none; align-items: center; gap: 14px; }
      .serp-loading.show { display: flex; }
      .serp-results { margin-top: 24px; display: none; }
      .serp-results.show { display: block; }
      .serp-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
      @media (max-width: 720px) { .serp-stats { grid-template-columns: repeat(2, 1fr); } }
      .serp-stat { background: white; border: 1px solid var(--border); padding: 16px; text-align: center; }
      .serp-stat .label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 6px; }
      .serp-stat .value { font-size: 22px; font-weight: 700; color: var(--text-1); }
      .serp-features { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
      .serp-feature { padding: 6px 12px; border: 1px solid var(--border); font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; }
      .serp-feature.active { background: var(--brand-softer); color: var(--brand); border-color: var(--brand-softer); }
      .serp-feature.inactive { color: var(--text-3); background: var(--bg-soft); }
      .serp-table-wrap { overflow-x: auto; background: white; border: 1px solid var(--border); }
      .serp-table { width: 100%; min-width: 640px; border-collapse: collapse; font-size: 14px; }
      .serp-table th, .serp-table td { padding: 12px; border-bottom: 1px solid var(--border); text-align: left; vertical-align: top; }
      .serp-table th { background: var(--bg-soft); font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); }
      .serp-table .pos { font-weight: 700; color: var(--text-1); }
      .serp-table .pos.top { color: #059669; }
      .serp-table .pos.purple { color: var(--brand); }
      .serp-table .title { font-weight: 600; color: var(--text-1); margin-bottom: 4px; }
      .serp-table .url { font-size: 12px; color: var(--brand); word-break: break-all; }
      .serp-table .desc { font-size: 13px; color: var(--text-2); line-height: 1.45; }
      .serp-actions { display: flex; gap: 10px; margin: 16px 0 24px; flex-wrap: wrap; }
      .serp-actions button { padding: 10px 16px; font-size: 13px; font-weight: 600; cursor: pointer; }
      .serp-actions .primary { background: var(--text-1); color: white; border: none; }
      .serp-actions .primary:hover { background: var(--brand); }
      .serp-actions .secondary { background: white; color: var(--text-1); border: 1px solid var(--border-strong); }
      .serp-actions .secondary:hover { border-color: var(--brand); color: var(--brand); }
      .serp-domain-chart { display: none; background: white; border: 1px solid var(--border); padding: 20px; margin-bottom: 20px; }
      .serp-domain-chart.show { display: block; }
      .serp-domain-chart h3 { font-size: 16px; font-weight: 600; margin-bottom: 12px; }
      .serp-domain { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
      .serp-expand { display: none; }
    </style>

    <div class="serp-card">
      <h2>Check live Google SERPs</h2>
      <p class="sub">Enter a keyword and location. Demo mode runs in your browser with realistic sample data.</p>
      <form id="sc-form" novalidate>
        <div class="serp-row">
          <div class="serp-field">
            <label for="sc-keyword">Keyword</label>
            <input type="text" id="sc-keyword" required placeholder="e.g., best dentist in austin" />
          </div>
          <div class="serp-field" style="flex: 0 0 180px;">
            <label for="sc-location">Location</label>
            <select id="sc-location">
              {locations.map((loc) => <option value={loc.value}>{loc.label}</option>)}
            </select>
          </div>
          <button type="submit" id="sc-check-btn" class="serp-btn">Check SERP</button>
        </div>
        <p class="serp-help">Enter any keyword — head term or long-tail. Choose a location for local rankings.</p>
      </form>
    </div>

    <div id="sc-loading" class="serp-loading">
      <svg class="spin" width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--brand)" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="var(--brand)" stroke-width="3" stroke-linecap="round"/></svg>
      <div>
        <p style="font-size: 15px; color: var(--text-2); margin: 0;">Fetching live Google SERP data...</p>
        <p style="font-size: 12px; color: var(--text-3); margin: 4px 0 0;">This takes 5-10 seconds for fresh data. Cached results return instantly.</p>
      </div>
    </div>

    <div id="sc-error" class="serp-error">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="1.6"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
      <div>
        <p style="font-weight: 600; margin: 0;">Couldn't fetch SERP data</p>
        <p style="margin: 4px 0 0; font-size: 13px;">Check the keyword and try again. Very new or low-volume keywords may not have data.</p>
      </div>
    </div>

    <div id="sc-results" class="serp-results"></div>

    <style>
      @keyframes spin { to { transform: rotate(360deg); } }
      .spin { animation: spin 1s linear infinite; }
    </style>

    <script is:inline>
      (function () {
        const form = document.getElementById('sc-form');
        const keywordInput = document.getElementById('sc-keyword');
        const locationInput = document.getElementById('sc-location');
        const loading = document.getElementById('sc-loading');
        const error = document.getElementById('sc-error');
        const results = document.getElementById('sc-results');

        const domains = [
          'en.wikipedia.org', 'www.reddit.com', 'www.forbes.com', 'www.amazon.com',
          'www.shopify.com', 'www.wordstream.com', 'neilpatel.com', 'moz.com',
          'backlinko.com', 'www.semrush.com', 'ahrefs.com', 'blog.hubspot.com',
          'www.searchenginejournal.com', 'www.bigcommerce.com', 'www.wix.com',
          'www.squarespace.com', 'support.google.com', 'www.yelp.com', 'www.healthline.com',
          'www.indeed.com', 'www.glassdoor.com', 'www.coursera.org', 'www.udemy.com',
          'www.nytimes.com', 'www.businessinsider.com', 'www.techradar.com',
          'www.pcmag.com', 'www.cnet.com', 'www.zdnet.com', 'www.wired.com'
        ];

        const prefixes = [
          'The complete guide to', 'What is', 'How to use', 'Best', 'Top 10',
          'Everything you need to know about', 'A beginner\'s guide to', 'Why',
          'The ultimate review of', 'How to choose', 'vs : which is better?',
          '2026 trends in', 'Professional tips for', 'Common mistakes with'
        ];

        function hash(str) {
          let h = 2166136261;
          for (let i = 0; i < str.length; i++) {
            h ^= str.charCodeAt(i);
            h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
          }
          return Math.abs(h >>> 0);
        }

        function rand(seed) {
          let s = seed % 2147483647;
          if (s <= 0) s += 2147483646;
          return function () { return (s = s * 16807 % 2147483647) / 2147483647; };
        }

        function fmtNum(n) { return n.toLocaleString(); }

        function generateResults(keyword, location) {
          const seed = hash(keyword.toLowerCase() + '|' + location);
          const rng = rand(seed);
          const k = keyword.toLowerCase();

          const volume = 300 + Math.floor(rng() * 19700);
          const kd = 5 + Math.floor(rng() * 90);
          const cpc = (0.20 + rng() * 9).toFixed(2);

          let intent = 'Informational';
          if (/buy|purchase|order|cheap|deal|discount/.test(k)) intent = 'Transactional';
          else if (/best|top|vs|compare|review/.test(k)) intent = 'Commercial';
          else if (/how to|what is|why does|guide|tutorial/.test(k)) intent = 'Informational';
          else if (/brand|login|app|website/.test(k)) intent = 'Navigational';
          else if (rng() > 0.6) intent = 'Commercial';

          const features = [
            { key: 'featured_snippet', label: 'Featured Snippet', active: intent === 'Informational' || rng() > 0.55 },
            { key: 'paa', label: 'People Also Ask', active: true },
            { key: 'local_pack', label: 'Local Pack', active: /near|in |local|dentist|plumber|lawyer|restaurant/.test(k) || rng() > 0.75 },
            { key: 'images', label: 'Images', active: rng() > 0.35 },
            { key: 'videos', label: 'Videos', active: rng() > 0.5 },
            { key: 'knowledge_graph', label: 'Knowledge Graph', active: rng() > 0.8 },
            { key: 'related_searches', label: 'Related Searches', active: true },
            { key: 'top_stories', label: 'Top Stories', active: rng() > 0.75 },
            { key: 'shopping', label: 'Shopping', active: /buy|price|best/.test(k) || rng() > 0.8 },
          ];

          const organic = [];
          const usedDomains = [];
          for (let i = 0; i < 100; i++) {
            const domainIndex = Math.floor(rng() * domains.length);
            const domain = domains[domainIndex];
            const prefix = prefixes[Math.floor(rng() * prefixes.length)];
            const title = prefix.replace('?', keyword).replace(':', keyword + ':') + (rng() > 0.5 ? ' [' + new Date().getFullYear() + ']' : '');
            const path = keyword.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '') || 'result';
            const url = 'https://' + domain + '/' + path + (i > 0 ? '-' + (i + 1) : '') + '.html';
            const desc = 'Learn about ' + keyword + '. This ' + (i + 1) + '-ranked result covers ' + (rng() > 0.5 ? 'best practices, examples, and expert tips.' : 'key strategies, comparisons, and actionable advice.');
            organic.push({ position: i + 1, title, url, domain, desc });
            usedDomains.push(domain);
          }

          const freq = {};
          usedDomains.forEach((d) => freq[d] = (freq[d] || 0) + 1);
          const topDomains = Object.entries(freq)
            .sort((a, b) => b[1] - a[1])
            .slice(0, 8)
            .map(([domain, count]) => {
              const best = organic.find((r) => r.domain === domain).position;
              return { domain, count, best };
            });

          return { keyword, location, volume, kd, cpc, intent, features, organic, topDomains, lastUpdated: new Date().toISOString().slice(0, 10) };
        }

        function escapeHtml(text) {
          return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function renderTop10(data) {
          return data.organic.slice(0, 10).map((r) => {
            const posClass = r.position <= 3 ? 'top' : (r.position <= 10 ? 'purple' : '');
            return `<tr>
              <td class="pos ${posClass}">#${r.position}</td>
              <td>
                <div class="title">${escapeHtml(r.title)}</div>
                <div class="url">${escapeHtml(r.url)}</div>
                <div class="desc">${escapeHtml(r.desc)}</div>
              </td>
              <td style="font-size: 12px; color: var(--text-3);">${escapeHtml(r.domain)}</td>
            </tr>`;
          }).join('');
        }

        function renderAll(data) {
          return data.organic.map((r) => `<tr>
            <td class="pos">#${r.position}</td>
            <td>
              <div class="title">${escapeHtml(r.title)}</div>
              <div class="url">${escapeHtml(r.url)}</div>
              <div class="desc">${escapeHtml(r.desc)}</div>
            </td>
            <td style="font-size: 12px; color: var(--text-3);">${escapeHtml(r.domain)}</td>
          </tr>`).join('');
        }

        function render(data) {
          const featureBadges = data.features.map((f) =>
            `<span class="serp-feature ${f.active ? 'active' : 'inactive'}">${f.active ? '●' : '○'} ${f.label}</span>`
          ).join('');

          results.innerHTML = `
            <div class="serp-stats">
              <div class="serp-stat"><div class="label">Volume</div><div class="value">${fmtNum(data.volume)}</div></div>
              <div class="serp-stat"><div class="label">Difficulty</div><div class="value">${data.kd}</div></div>
              <div class="serp-stat"><div class="label">CPC</div><div class="value">$${data.cpc}</div></div>
              <div class="serp-stat"><div class="label">Intent</div><div class="value" style="font-size: 16px;">${data.intent}</div></div>
            </div>
            <div class="serp-features">${featureBadges}</div>
            <div class="serp-actions">
              <button id="sc-toggle-all" class="primary">Show All Results</button>
              <button id="sc-csv" class="secondary">Download CSV</button>
            </div>
            <div class="serp-domain-chart" id="sc-domain-chart">
              <h3>Domain frequency (top 100)</h3>
              ${data.topDomains.map((d) => `<div class="serp-domain"><span>${escapeHtml(d.domain)}</span><span>${d.count} results · best #${d.best}</span></div>`).join('')}
            </div>
            <div class="serp-table-wrap">
              <table class="serp-table">
                <thead>
                  <tr><th>Position</th><th>Result</th><th>Domain</th></tr>
                </thead>
                <tbody id="sc-table-body">
                  ${renderTop10(data)}
                </tbody>
              </table>
            </div>
          `;

          let expanded = false;
          document.getElementById('sc-toggle-all').addEventListener('click', function () {
            expanded = !expanded;
            document.getElementById('sc-table-body').innerHTML = expanded ? renderAll(data) : renderTop10(data);
            document.getElementById('sc-domain-chart').classList.toggle('show', expanded);
            this.textContent = expanded ? 'Show Top 10' : 'Show All Results';
          });

          document.getElementById('sc-csv').addEventListener('click', function () {
            const rows = [['Position', 'Title', 'URL', 'Domain', 'Description']];
            data.organic.forEach((r) => rows.push([r.position, r.title, r.url, r.domain, r.desc]));
            const csv = rows.map((row) => row.map((cell) => '"' + String(cell).replace(/"/g, '""') + '"').join(',')).join('\n');
            const blob = new Blob([csv], { type: 'text/csv' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = 'serp-' + data.keyword.toLowerCase().replace(/[^a-z0-9]+/g, '-') + '.csv';
            a.click();
          });
        }

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          const keyword = keywordInput.value.trim();
          if (!keyword) return;
          error.classList.remove('show');
          results.classList.remove('show');
          loading.classList.add('show');
          form.querySelector('button').disabled = true;

          setTimeout(() => {
            loading.classList.remove('show');
            form.querySelector('button').disabled = false;
            const data = generateResults(keyword, locationInput.value);
            render(data);
            results.classList.add('show');
          }, 1400);
        });
      })();
    </script>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable">
      <div class="lead-box">
        <span class="tldr-label">TL;DR</span>
        <p>Enter any keyword and see the live Google SERP — top 100 organic rankings, all detected SERP features (featured snippets, People Also Ask, local pack, images, videos, knowledge graph), keyword difficulty, search volume, CPC, and search intent. The domain frequency chart shows which sites dominate the results. Free. No signup.</p>
      </div>

      <h2>What This SERP Checker Shows You</h2>
      <p>Most SERP checkers give you a list of URLs. This tool gives you the full picture — what Google is actually showing on the page, who dominates the rankings, and what it takes to compete.</p>

      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon" style="background: #f5f3ff; color: var(--brand);"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg></div>
          <h3>Live Top 100 Rankings</h3>
          <p>See all organic results with position, title, URL, domain, and description. Top 3 highlighted in green. Positions 4-10 in purple.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon" style="background: #fffbeb; color: #b45309;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
          <h3>SERP Feature Detection</h3>
          <p>Detects 9 feature types: featured snippets, PAA, local pack, images, videos, knowledge graph, related searches, top stories, and shopping.</p>
        </div>
        <div class="feature-card">
