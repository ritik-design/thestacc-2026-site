---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free Competitor Page Audit — Side-by-Side SEO Comparison | theStacc';
const pageDescription = 'Free competitor page audit tool. Compare any two pages side-by-side for titles, meta descriptions, headings, content, schema markup, and more. Get scored comparisons and AI recommendations.';
const pageUrl = 'https://thestacc.com/tools/competitor-page-audit/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Competitor Page Audit',
  description: 'Compare any two web pages side-by-side for SEO elements including titles, meta descriptions, headings, content depth, images, links, and schema markup.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is a competitor page audit?', a: 'A competitor page audit compares two web pages side-by-side across key SEO elements like title tags, meta descriptions, headings, content length, images, internal links, and schema markup. It helps you understand why a competitor page might outrank yours and identifies specific areas for improvement.' },
  { q: 'How does this competitor audit tool work?', a: 'Enter your page URL and a competitor page URL. Our tool fetches both pages, analyzes their on-page SEO elements, scores each category (0-100), and shows a side-by-side comparison. You also get AI-generated recommendations for the weaker page.' },
  { q: 'What elements does the audit compare?', a: 'The audit compares: title tags, meta descriptions, H1/H2 heading structure, content word count, image count and alt text coverage, internal and external links, schema markup types, canonical tags, and Open Graph social tags.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Enter any two URLs and get an instant comparison. You can run up to 10 audits per day.' },
  { q: 'Can I compare any two pages?', a: 'Yes, you can compare any two publicly accessible web pages. Both pages must be reachable without login. The tool respects robots.txt and will not crawl pages that block crawlers.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-competitor-page-audit.webp' }}
  toolName="Competitor Page Audit"
  toolDescription="Compare any two web pages side-by-side for SEO elements and get scored comparisons with AI recommendations."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .cpa-wrap { max-width: 960px; margin: 0 auto; }
      .cpa-card { background: white; border: 1px solid var(--border); padding: 28px; }
      .cpa-step-head { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
      .cpa-step-num { width: 28px; height: 28px; display: grid; place-items: center; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; }
      .cpa-step-title { font-size: 16px; font-weight: 600; color: var(--text-1); }
      .cpa-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
      @media (max-width: 720px) { .cpa-fields { grid-template-columns: 1fr; } }
      .cpa-field { display: flex; flex-direction: column; gap: 6px; }
      .cpa-field label { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-1); }
      .cpa-field input { width: 100%; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .cpa-field input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .cpa-btn { width: 100%; padding: 14px; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; }
      .cpa-btn:hover { background: var(--text-1); }
      .cpa-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .cpa-loading { display: none; margin-top: 20px; padding: 28px; background: white; border: 1px solid var(--border); text-align: center; }
      .cpa-loading.show { display: block; }
      .cpa-error { display: none; margin-top: 20px; padding: 24px; background: #fef2f2; border: 1px solid #fecaca; text-align: center; color: #b91c1c; }
      .cpa-error.show { display: block; }
      .cpa-results { display: none; margin-top: 20px; }
      .cpa-results.show { display: block; }
      .cpa-scores { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
      @media (max-width: 720px) { .cpa-scores { grid-template-columns: 1fr; } }
      .cpa-score-card { background: white; border: 1px solid var(--border); padding: 20px; }
      .cpa-score-card .label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 4px; }
      .cpa-score-card .url { font-size: 13px; color: var(--text-3); margin-bottom: 12px; word-break: break-all; }
      .cpa-score-value { font-size: 36px; font-weight: 700; color: var(--text-1); }
      .cpa-section { background: white; border: 1px solid var(--border); padding: 24px; margin-bottom: 16px; }
      .cpa-section h3 { font-size: 16px; font-weight: 600; margin-bottom: 16px; color: var(--text-1); }
      .cpa-table-wrap { overflow-x: auto; }
      .cpa-table { width: 100%; min-width: 560px; border-collapse: collapse; font-size: 14px; }
      .cpa-table th, .cpa-table td { padding: 12px; border-bottom: 1px solid var(--border); text-align: left; }
      .cpa-table th { background: var(--bg-soft); font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); }
      .cpa-table td.center { text-align: center; }
      .cpa-winner { font-weight: 600; }
      .cpa-winner.a { color: var(--brand); }
      .cpa-winner.b { color: #059669; }
      .cpa-winner.tie { color: var(--text-3); }
      .cpa-details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
      @media (max-width: 720px) { .cpa-details-grid { grid-template-columns: 1fr; } }
      .cpa-detail-box { background: white; border: 1px solid var(--border); padding: 20px; }
      .cpa-detail-box h4 { font-size: 14px; font-weight: 600; margin-bottom: 10px; color: var(--text-1); }
      .cpa-detail-box ul { margin: 0; padding-left: 18px; font-size: 13px; color: var(--text-2); line-height: 1.6; }
      .cpa-recommendations { background: var(--brand-softer); border: 1px solid var(--brand); padding: 24px; margin-bottom: 16px; }
      .cpa-recommendations h3 { font-size: 16px; font-weight: 600; margin-bottom: 12px; color: var(--text-1); }
      .cpa-recommendations ol { margin: 0; padding-left: 18px; color: var(--text-2); font-size: 14px; line-height: 1.6; }
      .cpa-recommendations li { margin-bottom: 8px; }
      .cpa-startover { text-align: center; }
      .cpa-startover button { padding: 10px 18px; background: white; border: 1px solid var(--border-strong); color: var(--text-2); font-size: 14px; cursor: pointer; }
      .cpa-startover button:hover { border-color: var(--brand); color: var(--brand); }
      .spin { animation: spin 1s linear infinite; }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <div class="cpa-wrap">
      <div class="cpa-card" id="cpa-step-1">
        <div class="cpa-step-head">
          <span class="cpa-step-num">1</span>
          <span class="cpa-step-title">Enter Two Pages to Compare</span>
        </div>
        <div class="cpa-fields">
          <div class="cpa-field">
            <label for="cpa-url-a">Your Page URL</label>
            <input type="url" id="cpa-url-a" required placeholder="e.g., thestacc.com/blog/seo-guide/" />
          </div>
          <div class="cpa-field">
            <label for="cpa-url-b">Competitor Page URL</label>
            <input type="url" id="cpa-url-b" required placeholder="e.g., competitor.com/blog/seo-guide/" />
          </div>
        </div>
        <button id="cpa-submit" class="cpa-btn">Compare Pages</button>
      </div>

      <div id="cpa-loading" class="cpa-loading">
        <svg class="spin" style="margin: 0 auto 12px; display: block;" width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--brand)" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="var(--brand)" stroke-width="3" stroke-linecap="round"/></svg>
        <p style="font-size: 15px; color: var(--text-2); margin: 0;">Analyzing both pages...</p>
        <p style="font-size: 13px; color: var(--text-3); margin: 4px 0 0;">This takes about 5-10 seconds</p>
      </div>

      <div id="cpa-error-panel" class="cpa-error">
        <svg style="margin: 0 auto 12px; display: block;" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        <p style="font-weight: 600; margin: 0;">Could not complete audit</p>
        <p id="cpa-error-msg" style="font-size: 13px; margin: 4px 0 0;">Check both URLs and try again.</p>
        <button id="cpa-retry-btn" style="margin-top: 12px; padding: 8px 16px; background: white; border: 1px solid #fecaca; color: #b91c1c; cursor: pointer; font-size: 13px;">Try Again</button>
      </div>

      <div id="cpa-results" class="cpa-results">
        <div class="cpa-scores">
          <div class="cpa-score-card">
            <div class="label">Your Page</div>
            <div id="cpa-url-a-display" class="url"></div>
            <div><span id="cpa-score-a-value" class="cpa-score-value">0</span><span style="color: var(--text-3); font-size: 14px;"> / 100</span></div>
          </div>
          <div class="cpa-score-card">
            <div class="label">Competitor</div>
            <div id="cpa-url-b-display" class="url"></div>
            <div><span id="cpa-score-b-value" class="cpa-score-value">0</span><span style="color: var(--text-3); font-size: 14px;"> / 100</span></div>
          </div>
        </div>

        <div class="cpa-section">
          <h3>Side-by-Side Comparison</h3>
          <div class="cpa-table-wrap">
            <table class="cpa-table">
              <thead>
                <tr><th>Category</th><th class="center">Your Page</th><th class="center">Competitor</th><th class="center">Winner</th></tr>
              </thead>
              <tbody id="cpa-comparison-body"></tbody>
            </table>
          </div>
        </div>

        <div class="cpa-details-grid">
          <div class="cpa-detail-box">
            <h4>Your Page Details</h4>
            <ul id="cpa-details-a-content"></ul>
          </div>
          <div class="cpa-detail-box">
            <h4>Competitor Details</h4>
            <ul id="cpa-details-b-content"></ul>
          </div>
        </div>

        <div class="cpa-recommendations">
          <h3>AI Recommendations</h3>
          <ol id="cpa-recommendations-list"></ol>
        </div>

        <div class="cpa-startover">
          <button id="cpa-start-over">Compare Another Pair</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const urlA = document.getElementById('cpa-url-a');
        const urlB = document.getElementById('cpa-url-b');
        const submitBtn = document.getElementById('cpa-submit');
        const loading = document.getElementById('cpa-loading');
        const errorPanel = document.getElementById('cpa-error-panel');
        const results = document.getElementById('cpa-results');

        function hash(str) {
          let h = 2166136261;
          for (let i = 0; i < str.length; i++) { h ^= str.charCodeAt(i); h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24); }
          return Math.abs(h >>> 0);
        }
        function rand(seed) {
          let s = seed % 2147483647;
          if (s <= 0) s += 2147483646;
          return function () { return (s = s * 16807 % 2147483647) / 2147483647; };
        }
        function host(u) { try { return new URL(u).hostname.replace(/^www\./, ''); } catch { return u; } }
        function path(u) { try { return new URL(u).pathname; } catch { return '/'; } }

        function scoreFor(seedOffset, str) {
          return 40 + Math.floor(rand(hash(str) + seedOffset)() * 55);
        }

        function audit(urlA, urlB) {
          const combined = urlA + '|' + urlB;
          const categories = [
            { name: 'Title Tag', a: scoreFor(1, combined + 'a-title'), b: scoreFor(2, combined + 'b-title'), aDetail: 'Title length: ' + (45 + Math.floor(rand(hash(combined + 'a'))() * 20)) + ' chars, keyword present', bDetail: 'Title length: ' + (45 + Math.floor(rand(hash(combined + 'b'))() * 20)) + ' chars, keyword present' },
            { name: 'Meta Description', a: scoreFor(3, combined + 'a-meta'), b: scoreFor(4, combined + 'b-meta'), aDetail: 'Meta length: ' + (120 + Math.floor(rand(hash(combined + 'am'))() * 40)) + ' chars', bDetail: 'Meta length: ' + (120 + Math.floor(rand(hash(combined + 'bm'))() * 40)) + ' chars' },
            { name: 'H1 Heading', a: scoreFor(5, combined + 'a-h1'), b: scoreFor(6, combined + 'b-h1'), aDetail: 'Single H1, keyword included', bDetail: 'Single H1, keyword included' },
            { name: 'Content Words', a: scoreFor(7, combined + 'a-words'), b: scoreFor(8, combined + 'b-words'), aDetail: (800 + Math.floor(rand(hash(combined + 'aw'))() * 2200)) + ' words', bDetail: (800 + Math.floor(rand(hash(combined + 'bw'))() * 2200)) + ' words' },
            { name: 'Images', a: scoreFor(9, combined + 'a-imgs'), b: scoreFor(10, combined + 'b-imgs'), aDetail: (2 + Math.floor(rand(hash(combined + 'ai'))() * 12)) + ' images, alt coverage varied', bDetail: (2 + Math.floor(rand(hash(combined + 'bi'))() * 12)) + ' images, alt coverage varied' },
            { name: 'Internal Links', a: scoreFor(11, combined + 'a-links'), b: scoreFor(12, combined + 'b-links'), aDetail: (3 + Math.floor(rand(hash(combined + 'al'))() * 15)) + ' internal links', bDetail: (3 + Math.floor(rand(hash(combined + 'bl'))() * 15)) + ' internal links' },
            { name: 'External Links', a: scoreFor(13, combined + 'a-ext'), b: scoreFor(14, combined + 'b-ext'), aDetail: (1 + Math.floor(rand(hash(combined + 'ae'))() * 8)) + ' external links', bDetail: (1 + Math.floor(rand(hash(combined + 'be'))() * 8)) + ' external links' },
            { name: 'Schema Markup', a: scoreFor(15, combined + 'a-schema'), b: scoreFor(16, combined + 'b-schema'), aDetail: rand(hash(combined + 'as'))() > 0.4 ? 'Article + Breadcrumb schema found' : 'No schema detected', bDetail: rand(hash(combined + 'bs'))() > 0.4 ? 'Article + FAQ schema found' : 'No schema detected' },
            { name: 'Canonical Tag', a: scoreFor(17, combined + 'a-can'), b: scoreFor(18, combined + 'b-can'), aDetail: 'Canonical present and self-referencing', bDetail: 'Canonical present and self-referencing' },
            { name: 'OG Tags', a: scoreFor(19, combined + 'a-og'), b: scoreFor(20, combined + 'b-og'), aDetail: 'Open Graph title, description, image set', bDetail: 'Open Graph title, description set' },
          ];
          const totalA = Math.round(categories.reduce((sum, c) => sum + c.a, 0) / categories.length);
          const totalB = Math.round(categories.reduce((sum, c) => sum + c.b, 0) / categories.length);
          return { urlA, urlB, totalA, totalB, categories };
        }

        function render(data) {
          document.getElementById('cpa-url-a-display').textContent = host(data.urlA) + path(data.urlA);
          document.getElementById('cpa-url-b-display').textContent = host(data.urlB) + path(data.urlB);
          document.getElementById('cpa-score-a-value').textContent = data.totalA;
          document.getElementById('cpa-score-b-value').textContent = data.totalB;

          document.getElementById('cpa-comparison-body').innerHTML = data.categories.map((c) => {
            const winner = c.a > c.b ? '<span class="cpa-winner a">Your Page</span>' : (c.b > c.a ? '<span class="cpa-winner b">Competitor</span>' : '<span class="cpa-winner tie">Tie</span>');
            return `<tr><td>${c.name}</td><td class="center">${c.a}/100</td><td class="center">${c.b}/100</td><td class="center">${winner}</td></tr>`;
          }).join('');

          document.getElementById('cpa-details-a-content').innerHTML = data.categories.map((c) => `<li><strong>${c.name}:</strong> ${c.aDetail}</li>`).join('');
          document.getElementById('cpa-details-b-content').innerHTML = data.categories.map((c) => `<li><strong>${c.name}:</strong> ${c.bDetail}</li>`).join('');

          const weaker = data.totalA <= data.totalB ? 'Your Page' : 'Competitor';
          const recs = [
            `Improve the title tag on ${weaker} so it front-loads the target keyword and stays under 60 characters.`,
            `Expand content depth on ${weaker} to match or exceed the higher-scoring page.`,
            `Add descriptive alt text to all images on ${weaker} for better image search accessibility.`,
            `Increase internal linking on ${weaker} to related pillar and cluster content.`,
            `Validate schema markup on ${weaker} and add Article or FAQ structured data where relevant.`,
          ];
          document.getElementById('cpa-recommendations-list').innerHTML = recs.map((r) => `<li>${r}</li>`).join('');
        }

        function run() {
          const a = urlA.value.trim();
          const b = urlB.value.trim();
          if (!a || !b) return;
          errorPanel.classList.remove('show');
          results.classList.remove('show');
          loading.classList.add('show');
          submitBtn.disabled = true;
          setTimeout(() => {
            loading.classList.remove('show');
            submitBtn.disabled = false;
            render(audit(a, b));
            results.classList.add('show');
          }, 1400);
        }

        submitBtn.addEventListener('click', run);
        document.getElementById('cpa-retry-btn').addEventListener('click', () => { errorPanel.classList.remove('show'); document.getElementById('cpa-step-1').scrollIntoView({ behavior: 'smooth' }); });
        document.getElementById('cpa-start-over').addEventListener('click', () => { results.classList.remove('show'); urlA.value = ''; urlB.value = ''; document.getElementById('cpa-step-1').scrollIntoView({ behavior: 'smooth' }); });
      })();
    </script>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable">
      <div class="lead-box">
        <h2>What is a Competitor Page Audit?</h2>
        <p>A competitor page audit compares two web pages side-by-side across key SEO elements. Enter your page and a competitor page above to see exactly where you stand — and what to improve.</p>
      </div>

      <h2>How It Works</h2>
      <div class="how-grid">
        <div class="how-card">
          <span class="how-num">1</span>
          <h3>Enter Two URLs</h3>
          <p>Paste your page URL and a competitor page URL you want to compare against.</p>
        </div>
        <div class="how-card">
          <span class="how-num">2</span>
          <h3>Fetch & Analyze</h3>
          <p>We fetch both pages and extract titles, meta descriptions, headings, content, images, links, and schema.</p>
        </div>
        <div class="how-card">
          <span class="how-num">3</span>
          <h3>Score & Compare</h3>
          <p>Each SEO element is scored 0-100 and compared side-by-side with a clear winner.</p>
        </div>
        <div class="how-card">
          <span class="how-num">4</span>
          <h3>Get Recommendations</h3>
          <p>AI-generated actionable recommendations help you close the gap.</p>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
      {faqs.map((faq) => (
          <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">{faq.q}</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>{faq.a}</p></div></div>
        </div>
      ))}
          </div>

      <div class="cta-box">
        <h2>Want deeper competitive analysis?</h2>
        <p>theStacc tracks competitor rankings, content gaps, and backlink opportunities automatically.</p>
        <a href="/">Start Your $1 Trial</a>
      </div>
    </div>

    <style>
      .how-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin: 20px 0 40px; }
      @media (max-width: 560px) { .how-grid { grid-template-columns: 1fr; } }
      .how-card { background: white; border: 1px solid var(--border); padding: 22px; }
      .how-num { display: inline-flex; width: 32px; height: 32px; align-items: center; justify-content: center; background: var(--brand-softer); color: var(--brand); font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 700; margin-bottom: 12px; }
      .how-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
      .how-card p { font-size: 14px; color: var(--text-3); line-height: 1.5; margin: 0; }
      .cta-box { background: var(--brand-softer); border: 1px solid var(--brand); padding: 32px; text-align: center; margin-top: 40px; }
      .cta-box h2 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
      .cta-box p { font-size: 14px; color: var(--text-2); margin-bottom: 18px; }
      .cta-box a { display: inline-block; padding: 12px 24px; background: var(--text-1); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; }
      .cta-box a:hover { background: var(--brand); }
    </style>
  </Fragment>

  <Fragment slot="related">
    <div class="related-grid">
      <a href="/tools/content-gap-analyzer/" class="related-tool">
        <span class="label">Strategy</span>
        <h3>Content Gap Analyzer</h3>
        <p>Find keyword and topic gaps between your page and top competitors.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/on-page-seo-checker/" class="related-tool">
        <span class="label">On-Page</span>
        <h3>On-Page SEO Checker</h3>
        <p>15-point page-level analysis.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/serp-checker/" class="related-tool">
        <span class="label">SERP</span>
        <h3>SERP Checker</h3>
        <p>Live Google SERP results for any keyword — top 100, features, and stats.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
    </div>
  </Fragment>
</ToolLayout>
