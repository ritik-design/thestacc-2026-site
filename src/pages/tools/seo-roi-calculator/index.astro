---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free SEO ROI Calculator — Real Keyword Volume by City | theStacc';
const pageDescription = 'Calculate your SEO return on investment with real keyword volume data for your city and industry. Compare DIY vs agency vs Stacc. 12-month compound growth projections. Free, no signup.';
const pageUrl = 'https://thestacc.com/tools/seo-roi-calculator/';
const lastUpdated = '2026-05-13';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free SEO ROI Calculator',
  description: 'Calculate SEO return on investment with real keyword volume data by city and industry. Compare DIY vs agency vs automated tool with compound growth projections.',
  url: pageUrl,
});

const faqs = [
  { q: 'How do you calculate SEO ROI?', a: 'SEO ROI = (Revenue from organic traffic - SEO investment) / SEO investment x 100. For local businesses, track new customers from organic search, multiply by customer lifetime value, and subtract your monthly SEO cost. Most local businesses see positive ROI within 4-8 months. This calculator uses real keyword volume data from DataForSEO when you enter your city, so your projections are based on actual search demand, not guesswork.' },
  { q: 'Is SEO worth it for local businesses?', a: 'Yes. Local SEO delivers 3-10x ROI for most service businesses. A dentist investing $99/mo in SEO can expect 5-15 new patient inquiries per month by month 6-8, with each patient worth $1,000+ in lifetime value. The key variables are customer lifetime value, local search volume, and conversion rate — all of which this calculator factors in using industry benchmarks and real data.' },
  { q: 'How long does SEO take to show results?', a: 'SEO follows an S-curve: minimal results in months 1-3 (foundation building), noticeable improvement in months 4-6 (acceleration), and strong compounding returns from month 7 onward. Most local businesses break even between months 4-8. The biggest mistake is quitting during months 2-4 when the foundation work has not yet produced visible rankings. This calculator models realistic S-curve growth, not linear projections.' },
  { q: 'SEO vs Google Ads. Which is better for local businesses?', a: 'Google Ads delivers instant traffic but stops when you stop paying. SEO takes longer but compounds over time. For most local businesses, SEO becomes more cost-effective around month 6-8 and dramatically outperforms ads by month 12. A personal injury lawyer paying $80/click would spend $4,000/month for 50 clicks from ads. The same 50 clicks from SEO cost $0 after the initial investment — and keep growing.' },
  { q: 'Is this calculator free?', a: 'Yes, 100% free. No signup or credit card needed. Select your industry, enter your city to get real keyword volume data, adjust the sliders, and see real-time projections instantly. The keyword volume data comes from DataForSEO, the same API used by enterprise SEO platforms.' },
  { q: 'Where does the keyword volume data come from?', a: 'When you enter your city, the calculator queries DataForSEO — the same data provider used by Ahrefs, SEMrush, and other enterprise SEO platforms — for real monthly search volume, CPC, and keyword difficulty for your industry + city combination. If the API does not have data for your specific city, it falls back to national industry averages.' },
  { q: 'What is customer lifetime value (LTV) and why does it matter?', a: 'Customer lifetime value is the total revenue you expect from one customer over their entire relationship with your business. A dental patient might return twice a year for 5 years = $1,200 LTV. A personal injury client might be a one-time $15,000 case. Higher LTV means SEO ROI scales dramatically because each new customer is worth more. This calculator uses industry-specific LTV benchmarks that you can adjust.' },
  { q: 'How accurate are the projections?', a: 'The projections are estimates based on industry benchmarks and real keyword data. They assume consistent SEO effort (content publishing, technical optimization, authority building). Actual results vary by competition level, starting domain authority, and execution quality. The S-curve growth model is conservative — many businesses outperform these projections. The calculator is designed to show realistic ranges, not promises.' },
  { q: 'What is the difference between DIY, agency, and Stacc in the comparison?', a: 'DIY assumes you spend $200/month on tools and 10+ hours/week doing the work yourself, with slower growth (0.5x multiplier) due to inconsistent execution. Agency assumes $2,000-4,000/month with professional execution (1.2x multiplier) but high cost. Stacc assumes $99/month for automated content + GBP posts + social media (1.0x multiplier) — professional volume at a fraction of agency cost.' },
  { q: 'Should I hire an SEO agency or use a tool like Stacc?', a: 'Hire an agency if you have a $3,000+/month budget and need custom strategy for a complex, competitive market. Use Stacc if you are a local business that needs consistent content, GBP optimization, and review management at $99/month — the same volume an agency delivers for 5-10x less. Many businesses start with Stacc, see results, and then decide whether to scale up with an agency.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const industries = [
  { key: 'dentist', label: 'Dentist', ltv: 1200, conv: 8, searches: 1200, cpc: 8, agency: 2500 },
  { key: 'plumber', label: 'Plumber / HVAC', ltv: 2500, conv: 12, searches: 900, cpc: 27, agency: 2000 },
  { key: 'lawyer', label: 'Lawyer', ltv: 5000, conv: 5, searches: 600, cpc: 85, agency: 4000 },
  { key: 'realtor', label: 'Real Estate', ltv: 8000, conv: 3, searches: 750, cpc: 11, agency: 2500 },
  { key: 'restaurant', label: 'Restaurant', ltv: 300, conv: 15, searches: 1500, cpc: 3, agency: 1500 },
  { key: 'auto', label: 'Auto Repair', ltv: 800, conv: 10, searches: 700, cpc: 11, agency: 2000 },
  { key: 'chiro', label: 'Chiropractor', ltv: 1500, conv: 8, searches: 550, cpc: 15, agency: 2000 },
  { key: 'salon', label: 'Salon / Spa', ltv: 600, conv: 10, searches: 800, cpc: 5, agency: 1500 },
  { key: 'custom', label: 'Custom', ltv: 0, conv: 8, searches: 1200, cpc: 10, agency: 2500 },
];
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-seo-roi-calculator.webp' }}
  toolName="SEO ROI Calculator"
  toolDescription="Calculate your SEO return on investment with real keyword volume data for your city and industry. Compare DIY vs agency vs Stacc. No signup."
  wide={false}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .roi-wrap { max-width: 720px; margin: 0 auto; }
      .roi-card { background: white; border: 1px solid var(--border); padding: 28px; margin-bottom: 20px; }
      .roi-label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-3); margin-bottom: 12px; }
      .roi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
      @media (max-width: 640px) { .roi-grid { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 420px) { .roi-grid { grid-template-columns: 1fr; } }
      .roi-ind { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 14px 8px; border: 1px solid var(--border); cursor: pointer; background: white; transition: all 0.15s; }
      .roi-ind:hover { border-color: #c4b5fd; box-shadow: 0 4px 12px rgba(79,57,246,0.08); }
      .roi-ind.active { border-color: var(--brand); background: #f5f3ff; }
      .roi-ind svg { width: 22px; height: 22px; }
      .roi-ind-name { font-size: 12px; font-weight: 600; color: var(--text-1); text-align: center; }
      .roi-ind-ltv { font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3); }
      .roi-field label { display: block; font-size: 13px; font-weight: 600; color: var(--text-1); margin-bottom: 6px; }
      .roi-field input[type="text"] { width: 100%; padding: 11px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .roi-field input[type="text"]:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .roi-hint { font-size: 12px; color: var(--text-3); margin-top: 6px; }
      .roi-slider { margin-bottom: 20px; }
      .roi-slider-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
      .roi-slider-head label { font-size: 13px; font-weight: 600; color: var(--text-1); }
      .roi-slider-head span { font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 600; color: var(--brand); }
      .roi-slider input[type="range"] { width: 100%; height: 8px; background: var(--border); -webkit-appearance: none; appearance: none; cursor: pointer; }
      .roi-slider input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; background: var(--brand); cursor: pointer; }
      .roi-slider input[type="range"]::-moz-range-thumb { width: 18px; height: 18px; background: var(--brand); cursor: pointer; border: none; }
      .roi-period { display: flex; gap: 10px; flex-wrap: wrap; }
      .roi-period label { cursor: pointer; }
      .roi-period input { position: absolute; opacity: 0; }
      .roi-period span { display: inline-block; padding: 8px 16px; border: 1px solid var(--border); font-size: 13px; font-weight: 500; color: var(--text-2); }
      .roi-period input:checked + span { border-color: var(--brand); background: #f5f3ff; color: var(--brand); }
      .roi-results { display: none; }
      .roi-results.show { display: block; }
      .roi-metric-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
      @media (max-width: 800px) { .roi-metric-grid { grid-template-columns: repeat(2, 1fr); } }
      .roi-metric { padding: 20px; text-align: center; }
      .roi-metric.good { background: #f0fdf4; border: 1px solid #bbf7d0; }
      .roi-metric.neutral { background: white; border: 1px solid var(--border); }
      .roi-metric-value { font-size: 26px; font-weight: 700; color: var(--text-1); }
      .roi-metric-label { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-3); margin-top: 4px; }
      .roi-chart-box { background: white; border: 1px solid var(--border); padding: 20px; margin-bottom: 24px; }
      .roi-chart-box p { font-family: 'Geist Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-3); margin-bottom: 12px; }
      .roi-chart-box canvas { width: 100%; max-width: 700px; display: block; margin: 0 auto; }
      .roi-table-wrap { overflow-x: auto; border: 1px solid var(--border); background: white; margin-bottom: 24px; }
      .roi-table { width: 100%; border-collapse: collapse; font-size: 13px; }
      .roi-table th, .roi-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); text-align: center; }
      .roi-table th { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-3); font-weight: 600; }
      .roi-table th:first-child, .roi-table td:first-child { text-align: left; }
      .roi-table .stacc-col { background: #f5f3ff; border-left: 1px solid #ddd6fe; border-right: 1px solid #ddd6fe; font-weight: 600; color: var(--text-1); }
      .roi-ads { background: #f5f3ff; border: 1px solid #ddd6fe; padding: 20px; margin-bottom: 24px; }
      .roi-ads > p:first-child { font-size: 14px; font-weight: 600; color: var(--text-1); margin-bottom: 6px; }
      #ads-comparison { font-size: 14px; line-height: 1.55; color: var(--text-2); margin: 0; }
      .roi-share { display: none; background: white; border: 1px solid var(--border); padding: 24px; margin-bottom: 24px; }
      .roi-share.show { display: block; }
      .roi-share-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 16px; }
      @media (max-width: 600px) { .roi-share-grid { grid-template-columns: 1fr; } }
      .roi-share-box { padding: 16px; text-align: center; }
      .roi-share-box.rev { background: #f5f3ff; }
      .roi-share-box.roi { background: #f0fdf4; }
      .roi-share-box.be { background: #fffbeb; }
      .roi-share-box strong { display: block; font-size: 20px; color: var(--text-1); }
      .roi-share-box span { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-3); }
      .roi-copy-btn { width: 100%; padding: 10px; background: white; border: 1px solid var(--border); font-size: 13px; font-weight: 600; color: var(--text-1); cursor: pointer; margin-top: 12px; }
      .roi-copy-btn:hover { background: var(--bg-soft); }
      .roi-badge { display: none; font-family: 'Geist Mono', monospace; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; padding: 3px 8px; background: var(--bg-soft); color: var(--text-3); }
      .roi-badge.show { display: inline-flex; }
    </style>

    <div class="roi-wrap">
      <!-- Industry selector -->
      <div class="roi-card">
        <span class="roi-label">Select Your Industry</span>
        <div class="roi-grid">
          {industries.map((ind) => (
            <button type="button" class="roi-ind" data-industry={ind.key} data-ltv={ind.ltv} data-conv={ind.conv} data-searches={ind.searches} data-cpc={ind.cpc} data-agency={ind.agency}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color:var(--brand)">
                {ind.key === 'dentist' && <><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></>}
                {ind.key === 'plumber' && <><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></>}
                {ind.key === 'lawyer' && <><path d="m16 16 3-8 3 8c-.87.55-1.92.85-3 .85s-2.13-.3-3-.85z"/><path d="m2 16 3-8 3 8c-.87.55-1.92.85-3 .85s-2.13-.3-3-.85z"/><path d="M7 21h10"/><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></>}
                {ind.key === 'realtor' && <><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></>}
                {ind.key === 'restaurant' && <><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></>}
                {ind.key === 'auto' && <><rect width="18" height="12" x="3" y="8" rx="2"/><path d="M7 8V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/><path d="M5 20v2"/><path d="M19 20v2"/><circle cx="7.5" cy="14" r="1.5"/><circle cx="16.5" cy="14" r="1.5"/></>}
                {ind.key === 'chiro' && <><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></>}
                {ind.key === 'salon' && <><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></>}
                {ind.key === 'custom' && <><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></>}
              </svg>
              <span class="roi-ind-name">{ind.label}</span>
              {ind.ltv > 0 && <span class="roi-ind-ltv">Avg LTV: ${ind.ltv.toLocaleString()}</span>}
            </button>
          ))}
        </div>

        <div class="roi-field" style="margin-top:20px;">
          <label for="city-input">Your City (optional — for real keyword volume)</label>
          <input type="text" id="city-input" placeholder="e.g., Austin, Miami, Chicago" />
          <p class="roi-hint">Enter your city to fetch real monthly search volume from DataForSEO. Leave blank to use industry averages.</p>
        </div>
      </div>

      <!-- Sliders -->
      <div id="sliders-section" class="roi-card" style="display:none;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
          <span class="roi-label" style="margin:0;">Adjust Your Numbers</span>
          <span id="volume-badge" class="roi-badge">Preset value</span>
        </div>

        <div class="roi-slider">
          <div class="roi-slider-head"><label for="sl-ltv">Customer Lifetime Value</label><span id="val-ltv">$1,200</span></div>
          <input type="range" id="sl-ltv" min="100" max="100000" step="50" value="1200" />
          <p class="roi-hint">How much is one customer worth over their lifetime?</p>
        </div>
        <div class="roi-slider">
          <div class="roi-slider-head"><label for="sl-conv">Conversion Rate</label><span id="val-conv">8.0%</span></div>
          <input type="range" id="sl-conv" min="1" max="30" step="0.5" value="8" />
          <p class="roi-hint">What % of website visitors become customers?</p>
        </div>
        <div class="roi-slider">
          <div class="roi-slider-head"><label for="sl-searches">Monthly Local Searches</label><span id="val-searches">1,200</span></div>
          <input type="range" id="sl-searches" min="100" max="50000" step="50" value="1200" />
          <p class="roi-hint">Monthly local searches for your services</p>
        </div>
        <div class="roi-slider">
          <div class="roi-slider-head"><label for="sl-seo-cost">Monthly SEO Investment</label><span id="val-seo-cost">$99</span></div>
          <input type="range" id="sl-seo-cost" min="49" max="10000" step="10" value="99" />
          <p class="roi-hint">Your monthly SEO budget</p>
        </div>

        <div>
          <label style="font-size:13px;font-weight:600;color:var(--text-1);display:block;margin-bottom:8px;">Projection Period</label>
          <div class="roi-period">
            <label><input type="radio" name="period" value="6" /><span>6 months</span></label>
            <label><input type="radio" name="period" value="12" checked /><span>12 months</span></label>
            <label><input type="radio" name="period" value="24" /><span>24 months</span></label>
          </div>
        </div>
      </div>

      <!-- Results -->
      <div id="results" class="roi-results">
        <div class="roi-metric-grid">
          <div class="roi-metric good"><div id="metric-revenue" class="roi-metric-value">$0</div><div class="roi-metric-label">Over 12 months</div></div>
          <div class="roi-metric good"><div id="metric-roi" class="roi-metric-value">0%</div><div class="roi-metric-label">Return on investment</div></div>
          <div class="roi-metric good"><div id="metric-breakeven" class="roi-metric-value">—</div><div class="roi-metric-label">When revenue exceeds cost</div></div>
          <div class="roi-metric neutral"><div id="metric-cpl" class="roi-metric-value">$0</div><div class="roi-metric-label">Cost per lead</div></div>
        </div>

        <div class="roi-chart-box">
          <p>Projected Growth</p>
          <canvas id="roi-chart" height="260"></canvas>
        </div>

        <div class="roi-table-wrap">
          <table class="roi-table">
            <thead>
              <tr><th>Metric</th><th>DIY ($200/mo)</th><th class="stacc-col">Stacc</th><th>Agency</th></tr>
            </thead>
            <tbody>
              <tr><td>Total cost</td><td id="cmp-cost-diy">—</td><td id="cmp-cost-stacc" class="stacc-col">—</td><td id="cmp-cost-agency">—</td></tr>
              <tr><td>Projected revenue</td><td id="cmp-rev-diy">—</td><td id="cmp-rev-stacc" class="stacc-col">—</td><td id="cmp-rev-agency">—</td></tr>
              <tr><td>ROI</td><td id="cmp-roi-diy">—</td><td id="cmp-roi-stacc" class="stacc-col">—</td><td id="cmp-roi-agency">—</td></tr>
              <tr><td>Break-even</td><td id="cmp-be-diy">—</td><td id="cmp-be-stacc" class="stacc-col">—</td><td id="cmp-be-agency">—</td></tr>
              <tr><td>Content volume</td><td id="cmp-content-diy">—</td><td id="cmp-content-stacc" class="stacc-col">—</td><td id="cmp-content-agency">—</td></tr>
            </tbody>
          </table>
        </div>

        <div class="roi-ads">
          <p>SEO vs Google Ads</p>
          <p id="ads-comparison">Select an industry above to see how SEO compares to Google Ads for your business.</p>
        </div>

        <div id="share-card" class="roi-share">
          <p style="font-family:'Geist Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-3);margin-bottom:12px;">Share Your Results</p>
          <div style="border:1px solid var(--border);padding:24px;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
              <div style="width:32px;height:32px;background:#f5f3ff;display:grid;place-items:center;color:var(--brand);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              </div>
              <span style="font-family:'Geist Mono',monospace;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--text-3);">thestacc.com/roi</span>
            </div>
            <p id="share-industry" style="font-family:'Geist Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:var(--brand);margin-bottom:4px;">Industry</p>
            <p id="share-detail" style="font-size:13px;color:var(--text-2);margin-bottom:16px;">Projection details</p>
            <div class="roi-share-grid">
              <div class="roi-share-box rev"><strong id="share-revenue">$0</strong><span>Revenue</span></div>
              <div class="roi-share-box roi"><strong id="share-roi" style="color:#16a34a;">0%</strong><span>ROI</span></div>
              <div class="roi-share-box be"><strong id="share-breakeven">—</strong><span>Break-even</span></div>
            </div>
          </div>
          <button id="share-btn" class="roi-copy-btn">Copy Results</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const industries = [
          { key: 'dentist', label: 'Dentist', ltv: 1200, conv: 8, searches: 1200, cpc: 8, agency: 2500 },
          { key: 'plumber', label: 'Plumber / HVAC', ltv: 2500, conv: 12, searches: 900, cpc: 27, agency: 2000 },
          { key: 'lawyer', label: 'Lawyer', ltv: 5000, conv: 5, searches: 600, cpc: 85, agency: 4000 },
          { key: 'realtor', label: 'Real Estate', ltv: 8000, conv: 3, searches: 750, cpc: 11, agency: 2500 },
          { key: 'restaurant', label: 'Restaurant', ltv: 300, conv: 15, searches: 1500, cpc: 3, agency: 1500 },
          { key: 'auto', label: 'Auto Repair', ltv: 800, conv: 10, searches: 700, cpc: 11, agency: 2000 },
          { key: 'chiro', label: 'Chiropractor', ltv: 1500, conv: 8, searches: 550, cpc: 15, agency: 2000 },
          { key: 'salon', label: 'Salon / Spa', ltv: 600, conv: 10, searches: 800, cpc: 5, agency: 1500 },
          { key: 'custom', label: 'Custom', ltv: 0, conv: 8, searches: 1200, cpc: 10, agency: 2500 }
        ];
        const indCards = document.querySelectorAll('.roi-ind');
        const sliders = ['ltv','conv','searches','seo-cost'].map(id => document.getElementById('sl-'+id));
        const displays = {
          ltv: document.getElementById('val-ltv'),
          conv: document.getElementById('val-conv'),
          searches: document.getElementById('val-searches'),
          'seo-cost': document.getElementById('val-seo-cost')
        };
        const results = document.getElementById('results');
        const slidersSection = document.getElementById('sliders-section');
        const badge = document.getElementById('volume-badge');
        const cityInput = document.getElementById('city-input');
        let currentInd = null;

        function fmt$(n) { return '$' + Math.round(n).toLocaleString(); }
        function fmtPct(n) { return Math.round(n) + '%'; }

        function selectIndustry(key) {
          const ind = industries.find(i => i.key === key);
          currentInd = ind;
          indCards.forEach(c => c.classList.toggle('active', c.dataset.industry === key));
          document.getElementById('sl-ltv').value = ind.ltv || 1000;
          document.getElementById('sl-conv').value = ind.conv;
          document.getElementById('sl-searches').value = ind.searches;
          document.getElementById('sl-seo-cost').value = 99;
          badge.classList.add('show');
          slidersSection.style.display = 'block';
          results.classList.add('show');
          update();
        }

        indCards.forEach(c => c.addEventListener('click', () => selectIndustry(c.dataset.industry)));

        function sCurve(m) { return 1 / (1 + Math.exp(-0.55 * (m - 5))); }
        function rankCTR(m, speed) {
          const maxCTR = 0.18;
          return 0.005 + (maxCTR - 0.005) * sCurve(Math.min(24, m * speed));
        }

        function scenario(projMonths, searches, conv, ltv, cost, speed) {
          let totalCost = 0, totalRevenue = 0, totalLeads = 0, be = null;
          const monthly = [];
          for (let m = 1; m <= projMonths; m++) {
            const clicks = searches * rankCTR(m, speed);
            const leads = clicks * (conv / 100);
            const revenue = leads * ltv;
            totalCost += cost;
            totalRevenue += revenue;
            totalLeads += leads;
            monthly.push({ clicks, leads, revenue });
            if (be === null && totalRevenue > totalCost) be = m;
          }
          const roi = totalCost > 0 ? ((totalRevenue - totalCost) / totalCost) * 100 : 0;
          const cpl = totalLeads > 0 ? totalCost / totalLeads : 0;
          return { totalCost, totalRevenue, totalLeads, roi, be, cpl, monthly };
        }

        function drawChart(monthly) {
          const canvas = document.getElementById('roi-chart');
          const dpr = window.devicePixelRatio || 1;
          const rect = canvas.getBoundingClientRect();
          canvas.width = (rect.width || 700) * dpr;
          canvas.height = 260 * dpr;
          const ctx = canvas.getContext('2d');
          ctx.scale(dpr, dpr);
          const w = canvas.width / dpr, h = canvas.height / dpr;
          ctx.clearRect(0, 0, w, h);
          const pad = { t: 20, r: 20, b: 40, l: 60 };
          const maxRev = Math.max(...monthly.map(m => m.revenue), 1);
          const n = monthly.length;

          // grid
          ctx.strokeStyle = '#e7e5e4';
          ctx.lineWidth = 1;
          for (let i = 0; i <= 4; i++) {
            const y = pad.t + (h - pad.t - pad.b) * (i / 4);
            ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(w - pad.r, y); ctx.stroke();
            ctx.fillStyle = '#79716b'; ctx.font = '11px Geist Mono, monospace';
            ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
            ctx.fillText('$' + (maxRev * (1 - i / 4) / 1000).toFixed(0) + 'k', pad.l - 8, y);
          }

          // bars
          const barW = Math.max(4, (w - pad.l - pad.r) / n * 0.6);
          monthly.forEach((m, i) => {
            const x = pad.l + (w - pad.l - pad.r) * ((i + 0.5) / n) - barW / 2;
            const bh = (m.revenue / maxRev) * (h - pad.t - pad.b);
            const y = h - pad.b - bh;
            ctx.fillStyle = '#615fff';
            ctx.fillRect(x, y, barW, bh);
            if (n <= 12 || i % Math.ceil(n / 12) === 0) {
              ctx.fillStyle = '#57534e'; ctx.font = '11px sans-serif';
              ctx.textAlign = 'center'; ctx.textBaseline = 'top';
              ctx.fillText('M' + (i + 1), x + barW / 2, h - pad.b + 8);
            }
          });
        }

        function update() {
          if (!currentInd) return;
          const ltv = +document.getElementById('sl-ltv').value;
          const conv = +document.getElementById('sl-conv').value;
          const searches = +document.getElementById('sl-searches').value;
          const seoCost = +document.getElementById('sl-seo-cost').value;
          const period = +document.querySelector('input[name="period"]:checked').value;
          const city = cityInput.value.trim();

          displays.ltv.textContent = fmt$(ltv);
          displays.conv.textContent = conv.toFixed(1) + '%';
          displays.searches.textContent = searches.toLocaleString();
          displays['seo-cost'].textContent = fmt$(seoCost);

          const stacc = scenario(period, searches, conv, ltv, seoCost, 1.0);
          const diy = scenario(period, searches, conv, ltv, 200, 0.55);
          const agency = scenario(period, searches, conv, ltv, currentInd.agency, 1.25);

          document.getElementById('metric-revenue').textContent = fmt$(stacc.totalRevenue);
          document.getElementById('metric-roi').textContent = fmtPct(stacc.roi);
          document.getElementById('metric-breakeven').textContent = stacc.be ? 'Month ' + stacc.be : '—';
          document.getElementById('metric-cpl').textContent = stacc.cpl ? fmt$(stacc.cpl) : '—';
          document.getElementById('metric-revenue').nextElementSibling.textContent = 'Over ' + period + ' months';

          const setCmp = (pre, s) => {
            document.getElementById(pre + '-cost').textContent = fmt$(s.totalCost);
            document.getElementById(pre + '-rev').textContent = fmt$(s.totalRevenue);
            document.getElementById(pre + '-roi').textContent = fmtPct(s.roi);
            document.getElementById(pre + '-be').textContent = s.be ? 'Month ' + s.be : '—';
          };
          setCmp('cmp-cost-diy', diy); setCmp('cmp-rev-diy', diy); setCmp('cmp-roi-diy', diy); setCmp('cmp-be-diy', diy);
          document.getElementById('cmp-content-diy').textContent = '~4/mo';
          setCmp('cmp-cost-stacc', stacc); setCmp('cmp-rev-stacc', stacc); setCmp('cmp-roi-stacc', stacc); setCmp('cmp-be-stacc', stacc);
          document.getElementById('cmp-content-stacc').textContent = '30+/mo';
          setCmp('cmp-cost-agency', agency); setCmp('cmp-rev-agency', agency); setCmp('cmp-roi-agency', agency); setCmp('cmp-be-agency', agency);
          document.getElementById('cmp-content-agency').textContent = '20-30/mo';

          // ads comparison
          const totalClicks = stacc.totalLeads / (conv / 100);
          const adSpend = totalClicks * currentInd.cpc;
          document.getElementById('ads-comparison').textContent =
            `Over ${period} months, SEO generates ~${Math.round(totalClicks).toLocaleString()} equivalent clicks. ` +
            `Buying those clicks on Google Ads at $${currentInd.cpc}/click would cost ~${fmt$(adSpend)}. ` +
            `Your SEO investment of ${fmt$(stacc.totalCost)} saves approximately ${fmt$(Math.max(0, adSpend - stacc.totalCost))}.`;

          drawChart(stacc.monthly);

          // share card
          document.getElementById('share-card').classList.add('show');
          document.getElementById('share-industry').textContent = currentInd.label + (city ? ' · ' + city : '');
          document.getElementById('share-detail').textContent = `${fmt$(ltv)} LTV · ${conv}% conv · ${searches.toLocaleString()} searches/mo · ${period}-month projection`;
          document.getElementById('share-revenue').textContent = fmt$(stacc.totalRevenue);
          document.getElementById('share-roi').textContent = fmtPct(stacc.roi);
          document.getElementById('share-breakeven').textContent = stacc.be ? 'Month ' + stacc.be : '—';
        }

        [...sliders, cityInput].forEach(el => el.addEventListener('input', () => { badge.classList.remove('show'); update(); }));
        document.querySelectorAll('input[name="period"]').forEach(r => r.addEventListener('change', update));
        document.getElementById('share-btn').addEventListener('click', () => {
          const text = `${document.getElementById('share-industry').textContent}\nRevenue: ${document.getElementById('share-revenue').textContent}\nROI: ${document.getElementById('share-roi').textContent}\nBreak-even: ${document.getElementById('share-breakeven').textContent}`;
          navigator.clipboard.writeText(text).then(() => {
            const b = document.getElementById('share-btn'); const old = b.textContent; b.textContent = 'Copied ✓'; setTimeout(() => b.textContent = old, 1500);
          });
        });

        // default select dentist
        selectIndustry('dentist');
      })();
    </script>
  </Fragment>

