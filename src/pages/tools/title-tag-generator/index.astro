---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free Title Tag Generator — SEO-Optimized Titles in Seconds | theStacc';
const pageDescription = 'Free title tag generator. Enter any keyword and get 8 optimized, click-worthy title tags with scores and character counts. Perfect for blog posts, product pages, and landing pages.';
const pageUrl = 'https://thestacc.com/tools/title-tag-generator/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Title Tag Generator',
  description: 'Generate SEO-optimized title tags for any keyword. Get scored suggestions with character counts and explanations.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is a title tag?', a: 'A title tag is the HTML element that specifies the title of a web page. It appears in search engine results pages (SERPs) as the clickable headline, in browser tabs, and when shared on social media. It is one of the most important on-page SEO elements.' },
  { q: 'What makes a good title tag?', a: 'A good title tag is 50-60 characters long, front-loads the target keyword, is compelling enough to earn clicks, accurately describes the page content, and is unique across your site. Power words, numbers, and emotional triggers can improve click-through rates.' },
  { q: 'How does this title tag generator work?', a: 'Enter your target keyword and select a page type. Our AI analyzes SEO best practices and generates multiple title tag variations with different styles — keyword-front, power words, numbers, questions. Each title gets a score and character count so you can pick the best one.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Enter any keyword and get instant title tag suggestions. You can run up to 15 searches per day.' },
  { q: 'Why do character counts matter?', a: 'Google typically displays the first 50-60 characters of a title tag in search results. Titles longer than 60 characters may be truncated with an ellipsis, hiding important words. Titles shorter than 50 characters may miss opportunities to include secondary keywords or compelling copy.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const pageTypes = [
  { value: 'blog post', label: 'Blog Post' },
  { value: 'product page', label: 'Product Page' },
  { value: 'homepage', label: 'Homepage' },
  { value: 'landing page', label: 'Landing Page' },
  { value: 'category page', label: 'Category Page' },
  { value: 'service page', label: 'Service Page' },
];
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-title-tag-generator.webp' }}
  toolName="Free Title Tag Generator"
  toolDescription="Generate SEO-optimized title tags for any keyword. Get scored suggestions with character counts and explanations."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .ttg-card { background: white; border: 1px solid var(--border); padding: 32px; max-width: 720px; margin: 0 auto; }
      .ttg-card h2 { font-size: 22px; font-weight: 600; margin-bottom: 4px; }
      .ttg-card .sub { font-size: 13px; color: var(--text-3); margin-bottom: 24px; }
      .ttg-field { margin-bottom: 16px; }
      .ttg-field label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; margin-bottom: 6px; color: var(--text-1); }
      .ttg-field input, .ttg-field select { width: 100%; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .ttg-field input:focus, .ttg-field select:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .ttg-btn { width: 100%; padding: 14px 20px; background: var(--text-1); color: white; font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.2s; margin-top: 8px; }
      .ttg-btn:hover { background: var(--brand); }
      .ttg-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .ttg-results { max-width: 720px; margin: 28px auto 0; display: none; }
      .ttg-results.show { display: block; }
      .ttg-result-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
      .ttg-suggestion-list { list-style: none; padding: 0; margin: 0; }
      .ttg-suggestion-body p { margin: 0; }
      .ttg-result-head p { font-size: 14px; color: var(--text-3); }
      .ttg-suggestion { background: white; border: 1px solid var(--border); padding: 18px; margin-bottom: 12px; display: flex; gap: 16px; align-items: flex-start; }
      .ttg-score { flex-shrink: 0; width: 54px; height: 54px; display: grid; place-items: center; background: var(--brand-softer); color: var(--brand); font-weight: 700; font-size: 18px; }
      .ttg-suggestion-body { flex: 1; }
      .ttg-suggestion-title { font-size: 17px; font-weight: 600; color: var(--text-1); margin-bottom: 6px; word-break: break-word; }
      .ttg-meta { font-size: 12px; color: var(--text-3); font-family: 'Geist Mono', monospace; margin-bottom: 4px; }
      .ttg-reason { font-size: 13px; color: var(--text-2); line-height: 1.45; }
      .ttg-copy { padding: 6px 14px; background: var(--bg-soft); border: 1px solid var(--border-strong); font-size: 12px; font-weight: 600; color: var(--text-1); cursor: pointer; }
      .ttg-copy:hover { background: var(--brand); color: white; border-color: var(--brand); }
      .ttg-empty { text-align: center; color: var(--text-3); font-size: 14px; padding: 48px 32px; border: 1px dashed var(--border-strong); background: var(--bg-soft); }
    </style>

    <div class="ttg-card">
      <h2>Enter your keyword</h2>
      <p class="sub">Get 8 scored title tag ideas in one click. Everything runs in your browser.</p>

      <div class="ttg-field">
        <label for="ttg-keyword">Target keyword</label>
        <input type="text" id="ttg-keyword" placeholder="e.g., best CRM software" />
      </div>

      <div class="ttg-field">
        <label for="ttg-page-type">Page type</label>
        <select id="ttg-page-type">
          {pageTypes.map((pt) => <option value={pt.value}>{pt.label}</option>)}
        </select>
      </div>

      <button id="ttg-submit" class="ttg-btn">Generate title tags</button>
    </div>

    <div id="ttg-results" class="ttg-results">
      <div class="ttg-result-head">
        <h3>Suggestions</h3>
        <p id="ttg-meta"></p>
      </div>
      <ul id="ttg-suggestions" class="ttg-suggestion-list"></ul>
    </div>

    <script is:inline>
      (function () {
        const templates = (kw, type) => {
          const K = kw.charAt(0).toUpperCase() + kw.slice(1);
          const year = new Date().getFullYear();
          return [
            `${K}: The Complete Guide for ${year}`,
            `${K} — 7 Proven Tips That Actually Work`,
            `What Is ${K}? A Beginner's Guide + Examples`,
            `Best ${K} in ${year}: Top Picks Reviewed`,
            `How to Choose ${K} (Without the Headache)`,
            `${K} vs Competitors: Which One Wins?`,
            `${K}: Free Tools, Templates & Checklists`,
            `Why ${K} Matters More Than Ever in ${year}`,
          ];
        };

        function score(title, kw) {
          let s = 70;
          const lower = title.toLowerCase();
          const k = kw.toLowerCase();
          if (lower.startsWith(k)) s += 12;
          else if (lower.includes(k)) s += 6;
          const len = title.length;
          if (len >= 50 && len <= 60) s += 14;
          else if (len >= 45 && len <= 65) s += 8;
          else s -= Math.min(20, Math.abs(len - 55) * 1.5);
          if (/\d/.test(title)) s += 3;
          if (/\?/.test(title)) s += 2;
            if (/(best|top|guide|free|proven|complete|ultimate)/i.test(title)) s += 3;
          return Math.min(100, Math.max(0, Math.round(s)));
        }

        function reason(title) {
          const len = title.length;
          if (len >= 50 && len <= 60) return 'Optimal length for SERP display';
          if (len < 50) return 'Short — could be more descriptive';
          return 'Long — may be truncated in SERP';
        }

        function render() {
          const kw = document.getElementById('ttg-keyword').value.trim();
          const type = document.getElementById('ttg-page-type').value;
          if (!kw) return;

          const titles = templates(kw, type).map((t) => ({
            title: t,
            length: t.length,
            score: score(t, kw),
            reason: reason(t),
          })).sort((a, b) => b.score - a.score);

          document.getElementById('ttg-meta').textContent = `Keyword: "${kw}" · ${type}`;
          const list = document.getElementById('ttg-suggestions');
          list.innerHTML = titles.map((t, i) => `
            <li class="ttg-suggestion">
              <div class="ttg-score">${t.score}</div>
              <div class="ttg-suggestion-body">
                <div class="ttg-suggestion-title">${t.title.replace(/</g, '&lt;')}</div>
                <p class="ttg-meta">${t.length} characters · ${t.reason}</p>
                <p class="ttg-reason">${i === 0 ? 'Highest-scoring option. Front-loads the keyword and fits the SERP display window.' : 'Solid variation — test against the top scorer in your CTR experiments.'}</p>
              </div>
              <button class="ttg-copy" data-title="${t.title.replace(/"/g, '&quot;')}">Copy</button>
            </li>
          `).join('');

          document.querySelectorAll('.ttg-copy').forEach((btn) => {
            btn.addEventListener('click', () => {
              const text = btn.getAttribute('data-title') || '';
              navigator.clipboard.writeText(text).then(() => {
                btn.textContent = 'Copied';
                setTimeout(() => (btn.textContent = 'Copy'), 1500);
              });
            });
          });

          document.getElementById('ttg-results').classList.add('show');
        }

        document.getElementById('ttg-submit').addEventListener('click', render);
        document.getElementById('ttg-keyword').addEventListener('keydown', (e) => { if (e.key === 'Enter') render(); });
      })();
    </script>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable">
      <h2>Why title tags matter for SEO</h2>
      <p>Title tags are the single most important on-page SEO element. They tell search engines what your page is about and convince searchers to click. A well-optimized title can be the difference between position 3 with 2% CTR and position 3 with 8% CTR.</p>

      <h2>How this generator works</h2>
      <ol>
        <li><strong>Enter your keyword</strong> — the main term you want the page to rank for.</li>
        <li><strong>Pick a page type</strong> — blog post, product page, service page, etc.</li>
        <li><strong>Get 8 variations</strong> — each one uses a different angle: numbers, questions, power words, and year markers.</li>
        <li><strong>Copy the winner</strong> — each suggestion shows a score and character count so you can pick the best fit.</li>
      </ol>

      <h2>Title tag best practices</h2>
      <ul>
        <li>Keep it between 50–60 characters so Google does not truncate it.</li>
        <li>Front-load the target keyword near the beginning.</li>
        <li>Make every title unique across your site.</li>
        <li>Use power words, numbers, or emotional triggers to lift CTR.</li>
        <li>Match the search intent behind the keyword.</li>
      </ul>

      <h2>Frequently asked questions</h2>
      <div class="faq-list">
      {faqs.map((faq) => (
          <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">{faq.q}</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>{faq.a}</p></div></div>
        </div>
      ))}
          </div>
    </div>
  </Fragment>

  <Fragment slot="related">
    <div class="related-grid">
      <a href="/tools/meta-tag-analyzer/" class="related-tool">
        <span class="label">Meta</span>
        <h3>Meta Tag Analyzer</h3>
        <p>Preview your title, description, and OG tags across search and social.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/headline-analyzer/" class="related-tool">
        <span class="label">Content</span>
        <h3>Headline Analyzer</h3>
        <p>Score headlines on clarity, emotion, SEO strength, and CTR potential.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/on-page-seo-checker/" class="related-tool">
        <span class="label">On-Page</span>
        <h3>On-Page SEO Checker</h3>
        <p>Check keyword placement, headers, and content quality in one scan.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
    </div>
  </Fragment>
</ToolLayout>
