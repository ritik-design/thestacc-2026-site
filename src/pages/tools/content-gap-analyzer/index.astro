---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free Content Gap Analyzer — Find Missing Topics Competitors Skip | theStacc';
const pageDescription = 'Free content gap analyzer. Enter any keyword and discover subtopics and angles your competitors are missing. Get prioritized content gaps with format suggestions and word count estimates.';
const pageUrl = 'https://thestacc.com/tools/content-gap-analyzer/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Content Gap Analyzer',
  description: 'Discover content gaps for any keyword. Find missing subtopics, angles, and formats your competitors overlook.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is a content gap?', a: 'A content gap is a subtopic, angle, or format that searchers want but existing content does not adequately cover. Finding and filling these gaps is one of the fastest ways to outrank competitors — you target what they missed.' },
  { q: 'How does this content gap tool work?', a: 'Enter a keyword and optionally a competitor URL. Our AI analyzes search intent patterns, competitor coverage, and content depth to identify specific subtopics that are underrepresented. Each gap includes priority level, recommended format, and estimated word count.' },
  { q: 'What do I do with the gaps this tool finds?', a: 'Each gap is a content brief waiting to happen. Use them to: expand thin existing content, create new pages that target long-tail queries, build topic clusters around your pillar content, or update old posts with missing sections.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Analyze any keyword and get instant content gaps. You can run up to 15 analyses per day.' },
  { q: 'How accurate are the content gaps?', a: 'The gaps are AI-generated based on semantic analysis, search intent patterns, and content coverage models. While not scraped from live SERP data, the analysis closely mirrors real gaps that SEOs find through manual research. The topics are specific enough to act on immediately.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const examples = ['SEO content', 'local SEO', 'email marketing', 'SaaS pricing', 'content strategy'];
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-content-gap-analyzer.webp' }}
  toolName="Content Gap Analyzer"
  toolDescription="Discover content gaps for any keyword. Find missing subtopics, angles, and formats your competitors overlook."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .cga-wrap { max-width: 840px; margin: 0 auto; }
      .cga-card { background: white; border: 1px solid var(--border); padding: 28px; }
      .cga-step-head { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
      .cga-step-num { width: 28px; height: 28px; display: grid; place-items: center; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; }
      .cga-step-title { font-size: 16px; font-weight: 600; color: var(--text-1); }
      .cga-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
      .cga-field label { font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-1); }
      .cga-field input { width: 100%; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .cga-field input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .cga-btn { width: 100%; padding: 14px; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; }
      .cga-btn:hover { background: var(--text-1); }
      .cga-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .cga-examples { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; font-size: 13px; color: var(--text-3); }
      .cga-examples button { color: var(--brand); background: none; border: none; cursor: pointer; font-size: 13px; }
      .cga-examples button:hover { text-decoration: underline; }
      .cga-loading { display: none; margin-top: 20px; padding: 28px; background: white; border: 1px solid var(--border); text-align: center; }
      .cga-loading.show { display: block; }
      .cga-error { display: none; margin-top: 20px; padding: 24px; background: #fef2f2; border: 1px solid #fecaca; text-align: center; color: #b91c1c; }
      .cga-error.show { display: block; }
      .cga-results { display: none; margin-top: 20px; }
      .cga-results.show { display: block; }
      .cga-summary { background: white; border: 1px solid var(--border); padding: 20px; margin-bottom: 16px; }
      .cga-summary-top { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; margin-bottom: 10px; }
      .cga-keyword-label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); }
      .cga-keyword-display { font-size: 18px; font-weight: 600; color: var(--text-1); margin-top: 4px; }
      .cga-badges { display: flex; gap: 8px; }
      .cga-badge { padding: 4px 10px; font-size: 11px; font-weight: 600; font-family: 'Geist Mono', monospace; }
      .badge-high { background: #fee2e2; color: #b91c1c; }
      .badge-medium { background: #fef3c7; color: #b45309; }
      .badge-low { background: #eff6ff; color: #1d4ed8; }
      .cga-summary-text { font-size: 14px; color: var(--text-2); line-height: 1.6; }
      .cga-filters { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
      .cga-filter { padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; border: 1px solid var(--border); background: white; color: var(--text-2); }
      .cga-filter:hover { border-color: var(--brand); color: var(--brand); }
      .cga-filter.active { background: var(--brand); border-color: var(--brand); color: white; }
      .cga-list { display: flex; flex-direction: column; gap: 10px; }
      .cga-gap { background: white; border: 1px solid var(--border); padding: 18px; }
      .cga-gap-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 8px; }
      .cga-gap-title { font-size: 15px; font-weight: 600; color: var(--text-1); }
      .cga-gap-meta { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 8px; }
      .cga-gap-meta span { font-size: 12px; color: var(--text-3); font-family: 'Geist Mono', monospace; }
      .cga-gap-desc { font-size: 14px; color: var(--text-2); line-height: 1.6; }
      .cga-startover { text-align: center; margin-top: 20px; }
      .cga-startover button { padding: 10px 18px; background: white; border: 1px solid var(--border-strong); color: var(--text-2); font-size: 14px; cursor: pointer; }
      .cga-startover button:hover { border-color: var(--brand); color: var(--brand); }
      .spin { animation: spin 1s linear infinite; }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <div class="cga-wrap">
      <div class="cga-card" id="cga-step-1">
        <div class="cga-step-head">
          <span class="cga-step-num">1</span>
          <span class="cga-step-title">Enter a Keyword</span>
        </div>
        <div class="cga-field">
          <label for="cga-keyword">Target Keyword</label>
          <input type="text" id="cga-keyword" required placeholder="e.g., content marketing strategy, best CRM software" />
        </div>
        <div class="cga-field">
          <label for="cga-competitor">Competitor URL (optional)</label>
          <input type="url" id="cga-competitor" placeholder="e.g., competitor.com/blog/seo-guide/" />
        </div>
        <button id="cga-submit" class="cga-btn">Find Content Gaps</button>
        <div class="cga-examples">
          <span>Try:</span>
          {examples.map((ex) => <button class="cga-example-btn" data-keyword={ex}>{ex}</button>)}
        </div>
      </div>

      <div id="cga-loading" class="cga-loading">
        <svg class="spin" style="margin: 0 auto 12px; display: block;" width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--brand)" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="var(--brand)" stroke-width="3" stroke-linecap="round"/></svg>
        <p style="font-size: 15px; color: var(--text-2); margin: 0;">Analyzing content coverage...</p>
        <p style="font-size: 13px; color: var(--text-3); margin: 4px 0 0;">This takes about 5-10 seconds</p>
      </div>

      <div id="cga-error-panel" class="cga-error">
        <svg style="margin: 0 auto 12px; display: block;" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        <p style="font-weight: 600; margin: 0;">Could not analyze content gaps</p>
        <p id="cga-error-msg" style="font-size: 13px; margin: 4px 0 0;">Try a different keyword.</p>
        <button id="cga-retry-btn" style="margin-top: 12px; padding: 8px 16px; background: white; border: 1px solid #fecaca; color: #b91c1c; cursor: pointer; font-size: 13px;">Try Again</button>
      </div>

      <div id="cga-results" class="cga-results">
        <div class="cga-summary">
          <div class="cga-summary-top">
            <div>
              <div class="cga-keyword-label">Keyword</div>
              <div id="cga-keyword-display" class="cga-keyword-display"></div>
            </div>
            <div class="cga-badges">
              <span id="cga-high-badge" class="cga-badge badge-high"></span>
              <span id="cga-medium-badge" class="cga-badge badge-medium"></span>
              <span id="cga-low-badge" class="cga-badge badge-low"></span>
            </div>
          </div>
          <p id="cga-summary" class="cga-summary-text"></p>
        </div>

        <div class="cga-filters" id="cga-priority-filters">
          <button class="cga-filter active" data-filter="all">All</button>
          <button class="cga-filter" data-filter="High">High</button>
          <button class="cga-filter" data-filter="Medium">Medium</button>
          <button class="cga-filter" data-filter="Low">Low</button>
        </div>

        <div id="cga-gaps-list" class="cga-list"></div>

        <div class="cga-startover">
          <button id="cga-start-over">Analyze Another Keyword</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const keywordInput = document.getElementById('cga-keyword');
        const competitorInput = document.getElementById('cga-competitor');
        const submitBtn = document.getElementById('cga-submit');
        const loading = document.getElementById('cga-loading');
        const errorPanel = document.getElementById('cga-error-panel');
        const results = document.getElementById('cga-results');
        const list = document.getElementById('cga-gaps-list');

        function hash(str) {
          let h = 2166136261;
          for (let i = 0; i < str.length; i++) { h ^= str.charCodeAt(i); h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24); }
          return Math.abs(h >>> 0);
        }
        function rand(seed) {
          let s = seed % 2147483647;
          if (s <= 0) s += 2147483646;
          return function () { return (s = s * 16807 % 2147483647) / 2147483647; };
        }

        const gapTemplates = [
          { title: (kw) => `Beginner's guide to ${kw}`, priority: 'Medium', format: 'Long-form guide', words: '1,800', desc: 'Most top pages assume prior knowledge. A plain-language intro would capture informational searches.' },
          { title: (kw) => `${kw} statistics and benchmarks`, priority: 'Low', format: 'Data roundup', words: '1,200', desc: 'Original data and benchmarks are rarely covered, making this a strong link magnet.' },
          { title: (kw) => `Common ${kw} mistakes`, priority: 'High', format: 'Listicle', words: '1,500', desc: 'Searchers actively look for pitfalls. Current content is thin on practical warnings.' },
          { title: (kw) => `${kw} case studies`, priority: 'Low', format: 'Case study collection', words: '2,000', desc: 'Real-world examples build trust and differentiate from generic explainers.' },
          { title: (kw) => `${kw} checklist`, priority: 'High', format: 'Checklist + downloadable PDF', words: '1,000', desc: 'A practical checklist captures high-intent users and earns featured snippets.' },
          { title: (kw) => `${kw} tools comparison`, priority: 'Medium', format: 'Comparison table', words: '1,600', desc: 'Comparison content is underrepresented and aligns with commercial intent.' },
          { title: (kw) => `How to measure ${kw} ROI`, priority: 'High', format: 'Tutorial', words: '1,700', desc: 'ROI-focused content is missing despite strong buyer intent around this angle.' },
          { title: (kw) => `${kw} trends for ${new Date().getFullYear()}`, priority: 'Low', format: 'Trend report', words: '1,400', desc: 'Fresh, timely trend content can capture spikes in seasonal search interest.' },
          { title: (kw) => `${kw} templates`, priority: 'Medium', format: 'Template hub', words: '1,300', desc: 'Templates and frameworks are popular but not well covered by existing pages.' },
          { title: (kw) => `${kw} expert tips`, priority: 'Medium', format: 'Expert roundup', words: '1,500', desc: 'Quotes and insights from experts add authority and shareability.' },
          { title: (kw) => `${kw} vs alternatives`, priority: 'High', format: 'Comparison page', words: '2,000', desc: 'Comparison queries show strong intent; most competitors only mention their own solution.' },
          { title: (kw) => `How to get started with ${kw}`, priority: 'High', format: 'Step-by-step guide', words: '1,600', desc: 'A clear getting-started guide is missing and would serve early-stage searchers.' },
        ];

        let currentGaps = [];

        function analyze(keyword, competitor) {
          const seed = hash(keyword.toLowerCase() + '|' + (competitor || ''));
          const rng = rand(seed);
          const gaps = [];
          const order = [...gapTemplates];
          for (let i = order.length - 1; i > 0; i--) {
            const j = Math.floor(rng() * (i + 1));
            [order[i], order[j]] = [order[j], order[i]];
          }
          order.slice(0, 8).forEach((t) => {
            gaps.push({
              title: t.title(keyword),
              priority: t.priority,
              format: t.format,
              words: t.words,
              desc: t.desc,
            });
          });
          const counts = { High: 0, Medium: 0, Low: 0 };
          gaps.forEach((g) => counts[g.priority]++);
          return { keyword, gaps, counts, competitor };
        }

        function escapeHtml(text) {
          return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function renderGaps(filter = 'all') {
          list.innerHTML = currentGaps.filter((g) => filter === 'all' || g.priority === filter).map((g) => `
            <div class="cga-gap" data-priority="${g.priority}">
              <div class="cga-gap-head">
                <div class="cga-gap-title">${escapeHtml(g.title)}</div>
                <span class="cga-badge badge-${g.priority.toLowerCase() === 'high' ? 'high' : (g.priority.toLowerCase() === 'medium' ? 'medium' : 'low')}">${g.priority}</span>
              </div>
              <div class="cga-gap-meta">
                <span>Format: ${escapeHtml(g.format)}</span>
                <span>~${g.words} words</span>
              </div>
              <div class="cga-gap-desc">${escapeHtml(g.desc)}</div>
            </div>
          `).join('');
        }

        function render(data) {
          currentGaps = data.gaps;
          document.getElementById('cga-keyword-display').textContent = data.keyword;
          document.getElementById('cga-high-badge').textContent = data.counts.High + ' High';
          document.getElementById('cga-medium-badge').textContent = data.counts.Medium + ' Medium';
          document.getElementById('cga-low-badge').textContent = data.counts.Low + ' Low';
          document.getElementById('cga-summary').textContent = `Analysis found ${data.gaps.length} content gaps around "${data.keyword}". High-priority gaps represent under-covered angles with strong search intent. ${data.competitor ? 'Compared against ' + data.competitor + '.' : ''}`;
          document.querySelectorAll('#cga-priority-filters .cga-filter').forEach((btn) => btn.classList.toggle('active', btn.dataset.filter === 'all'));
          renderGaps('all');
        }

        function run() {
          const keyword = keywordInput.value.trim();
          if (!keyword) return;
          errorPanel.classList.remove('show');
          results.classList.remove('show');
          loading.classList.add('show');
          submitBtn.disabled = true;
          setTimeout(() => {
            loading.classList.remove('show');
            submitBtn.disabled = false;
            render(analyze(keyword, competitorInput.value.trim()));
            results.classList.add('show');
          }, 1300);
        }

        submitBtn.addEventListener('click', run);
        keywordInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') run(); });
        document.querySelectorAll('.cga-example-btn').forEach((btn) => {
          btn.addEventListener('click', () => { keywordInput.value = btn.dataset.keyword; run(); });
        });
        document.getElementById('cga-retry-btn').addEventListener('click', () => { errorPanel.classList.remove('show'); document.getElementById('cga-step-1').scrollIntoView({ behavior: 'smooth' }); });
        document.getElementById('cga-start-over').addEventListener('click', () => { results.classList.remove('show'); keywordInput.value = ''; competitorInput.value = ''; document.getElementById('cga-step-1').scrollIntoView({ behavior: 'smooth' }); });

        document.getElementById('cga-priority-filters').addEventListener('click', function (e) {
          if (!e.target.classList.contains('cga-filter')) return;
          document.querySelectorAll('#cga-priority-filters .cga-filter').forEach((btn) => btn.classList.remove('active'));
          e.target.classList.add('active');
          renderGaps(e.target.dataset.filter);
        });
      })();
    </script>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable">
      <div class="lead-box">
        <h2>What Is a Content Gap?</h2>
        <p>A content gap is a subtopic, question, or angle that your target audience cares about but existing content does not cover well. Finding these gaps lets you create content that ranks faster because you are filling a hole — not fighting for the same ground.</p>
      </div>

      <h2>How It Works</h2>
      <div class="how-grid">
        <div class="how-card">
          <span class="how-num">1</span>
          <h3>Enter a Keyword</h3>
          <p>Type the main keyword you want to rank for.</p>
        </div>
        <div class="how-card">
          <span class="how-num">2</span>
          <h3>AI Analyzes Coverage</h3>
          <p>Our AI evaluates what subtopics are covered vs. missing in existing content.</p>
        </div>
        <div class="how-card">
          <span class="how-num">3</span>
          <h3>Get Prioritized Gaps</h3>
          <p>Receive a list of content gaps sorted by priority with format and length suggestions.</p>
        </div>
        <div class="how-card">
          <span class="how-num">4</span>
          <h3>Create the Content</h3>
          <p>Each gap is a content brief. Create new pages or expand existing ones to fill them.</p>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
      {faqs.map((faq) => (
          <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">{faq.q}</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>{faq.a}</p></div></div>
        </div>
      ))}
          </div>

      <div class="cta-box">
        <h2>Want automated content gap monitoring?</h2>
        <p>theStacc tracks competitor content updates and alerts you when new gaps appear in your keyword space.</p>
        <a href="/">Start Your $1 Trial</a>
      </div>
    </div>

    <style>
      .how-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin: 20px 0 40px; }
      @media (max-width: 560px) { .how-grid { grid-template-columns: 1fr; } }
      .how-card { background: white; border: 1px solid var(--border); padding: 22px; }
      .how-num { display: inline-flex; width: 32px; height: 32px; align-items: center; justify-content: center; background: var(--brand-softer); color: var(--brand); font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 700; margin-bottom: 12px; }
      .how-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
      .how-card p { font-size: 14px; color: var(--text-3); line-height: 1.5; margin: 0; }
      .cta-box { background: var(--brand-softer); border: 1px solid var(--brand); padding: 32px; text-align: center; margin-top: 40px; }
      .cta-box h2 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
      .cta-box p { font-size: 14px; color: var(--text-2); margin-bottom: 18px; }
      .cta-box a { display: inline-block; padding: 12px 24px; background: var(--text-1); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; }
      .cta-box a:hover { background: var(--brand); }
    </style>
  </Fragment>

  <Fragment slot="related">
    <div class="related-grid">
      <a href="/tools/competitor-page-audit/" class="related-tool">
        <span class="label">Competitive</span>
        <h3>Competitor Page Audit</h3>
        <p>Compare a competitor page against your target keyword and find gaps.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/people-also-ask/" class="related-tool">
        <span class="label">Research</span>
        <h3>People Also Ask</h3>
        <p>Fetch real PAA questions for any keyword to power content and FAQs.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/content-brief-generator/" class="related-tool">
        <span class="label">Content</span>
        <h3>Content Brief Generator</h3>
        <p>Generate complete content briefs from any keyword, with titles and outlines.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
    </div>
  </Fragment>
</ToolLayout>
