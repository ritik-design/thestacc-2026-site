          } else {
            box.innerHTML = `
              <div class="ha-preview">
                <p class="ha-preview-label">Email Inbox Preview</p>
                <div class="ha-preview-serp">
                  <p style="font-weight: 600;">${headline.replace(/</g, '&lt;')}</p>
