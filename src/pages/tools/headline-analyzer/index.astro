---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free Headline Analyzer — AI Rewrites + SERP Patterns | theStacc';
const pageDescription = 'Score headlines on 8 dimensions instantly. Get 5 AI-rewritten alternatives, top 10 SERP headline patterns for your keyword, and a qualitative critique. Free, no signup.';
const pageUrl = 'https://thestacc.com/tools/headline-analyzer/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Headline Analyzer',
  description: 'Score blog titles, GBP post headlines, page titles, and email subjects on 8 dimensions including Local SEO scoring. Get 5 AI-rewritten alternatives and top 10 SERP headline patterns for any keyword.',
  url: pageUrl,
});

const faqs = [
  { q: 'What does a headline analyzer do?', a: 'A headline analyzer scores your headline across 8 dimensions: word balance, emotional appeal, SEO strength, length, clarity, power words, sentiment, and local SEO. It gives you a 0-100 score, word-by-word analysis, content previews, specific suggestions, 5 AI-rewritten alternatives, and — if you enter a target keyword — the top 10 headline patterns actually ranking in Google right now.' },
  { q: 'How is this headline analyzer different from CoSchedule or Sharethrough?', a: 'CoSchedule and Sharethrough score headlines on 4-5 dimensions using word-list matching. This tool scores on 8 dimensions including local SEO (city + industry keywords), shows content-type-specific previews (SERP, GBP, email inbox), provides 5 AI-rewritten alternatives with explanations, and extracts real headline patterns from the top 10 Google results for any keyword you enter. The AI critique explains why your headline works or does not work in plain English.' },
  { q: 'How long should a blog post headline be?', a: 'Blog post headlines should be 50-60 characters for optimal SEO. Google truncates titles longer than ~60 characters in search results. GBP posts work well at 40-80 characters, while email subject lines perform best at 30-50 characters. The analyzer adjusts its scoring based on the content type you select.' },
  { q: 'What are power words in headlines?', a: 'Power words are psychologically compelling words that trigger emotion or action. Trust builders like "proven," "guaranteed," and "certified." Urgency drivers like "limited," "instant," and "now." Curiosity triggers like "secret," "exclusive," and "breakthrough." Headlines with power words consistently get 12-25% higher click-through rates.' },
  { q: 'Why does local SEO matter for headlines?', a: 'Including your city name and industry keywords in headlines signals geographic relevance to Google. A headline like "Best Dentist in Austin TX" ranks better for local searches than "Best Dentist" alone. This is critical for service businesses that serve a specific area. GBP posts that include city names and service keywords get more views, clicks, and calls.' },
  { q: 'What are the best headline formulas that actually work?', a: 'Number + list: "7 Ways to Fix a Leaky Faucet." How-to: "How to Whiten Teeth in 30 Days." Question: "Why Is My AC Blowing Hot Air?" Superlative: "The Ultimate Guide to Roof Maintenance." Urgency: "Limited: Free Dental Consultation This Week." Comparison: "Metal Roof vs Shingles: Which Lasts Longer?" The analyzer detects which formula your headline uses and scores it accordingly.' },
  { q: 'How do the AI rewrites work?', a: 'When you enter a headline, the tool sends it to Kimi (an AI writing assistant) along with your content type, industry, and city. Kimi analyzes the headline and returns 5 rewritten alternatives, each with a predicted score and explanation of why it works better. Click any rewrite to instantly test it in the analyzer. The AI call takes 2-4 seconds and happens after your instant score appears.' },
  { q: 'What are SERP headline patterns?', a: 'When you enter a target keyword (like "emergency plumber austin"), the tool fetches the top 10 Google results for that keyword, extracts their headlines, and shows them to you with pattern tags (Number, Question, How-to, Listicle, etc.). This reveals what headline formulas are actually winning for your keyword right now — so you can match or beat them.' },
  { q: 'Is this headline analyzer free?', a: 'Yes, 100% free. No signup, no email gate, no limits. The instant scoring, word-by-word analysis, content previews, and suggestions are all free. The AI rewrites and SERP patterns are also free — they are powered by API calls that happen asynchronously after your score renders.' },
  { q: 'How can I use this for my business?', a: 'Before publishing any blog post, GBP update, email campaign, or page title — paste it into the analyzer. Check the score, review the suggestions, enter your target keyword to see what is ranking, then click one of the AI rewrites if it is stronger. Test 3-5 variations and pick the highest scorer. Over time, you will internalize what makes headlines work.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const industries = [
  { value: 'dentist', label: 'Dentist' },
  { value: 'chiropractor', label: 'Chiropractor' },
  { value: 'plumber', label: 'Plumber' },
  { value: 'hvac', label: 'HVAC' },
  { value: 'electrician', label: 'Electrician' },
  { value: 'roofing', label: 'Roofing' },
  { value: 'landscaping', label: 'Landscaping' },
  { value: 'pest_control', label: 'Pest Control' },
  { value: 'auto_repair', label: 'Auto Repair' },
  { value: 'lawyer', label: 'Lawyer' },
  { value: 'accountant', label: 'Accountant' },
  { value: 'realtor', label: 'Real Estate' },
  { value: 'insurance', label: 'Insurance' },
  { value: 'financial_advisor', label: 'Financial Advisor' },
  { value: 'restaurant', label: 'Restaurant' },
  { value: 'salon', label: 'Salon / Spa' },
  { value: 'gym', label: 'Gym / Fitness' },
  { value: 'veterinarian', label: 'Veterinarian' },
  { value: 'cleaning', label: 'Cleaning' },
  { value: 'moving', label: 'Moving' },
  { value: 'optometrist', label: 'Optometrist' },
  { value: 'orthodontist', label: 'Orthodontist' },
  { value: 'dermatologist', label: 'Dermatologist' },
];
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-headline-analyzer.webp' }}
  toolName="Headline Analyzer"
  toolDescription="Score headlines on 8 dimensions instantly. Get 5 AI-rewritten alternatives, top 10 SERP headline patterns for your keyword, and a qualitative critique. Free, no signup."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .ha-wrap { max-width: 920px; margin: 0 auto; }
      .ha-card { background: white; border: 1px solid var(--border); padding: 28px; margin-bottom: 20px; }
      .ha-field { margin-bottom: 18px; }
      .ha-field label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-1); margin-bottom: 6px; }
      .ha-field label span { text-transform: none; font-weight: 400; color: var(--text-3); }
      .ha-field textarea, .ha-field input, .ha-field select { width: 100%; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .ha-field textarea:focus, .ha-field input:focus, .ha-field select:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .ha-field textarea { resize: none; min-height: 72px; }
      .ha-counter { text-align: right; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); margin-top: 4px; }
      .ha-pills { display: flex; flex-wrap: wrap; gap: 8px; }
      .ha-pill { padding: 8px 14px; border: 1px solid var(--border); background: white; font-size: 13px; font-weight: 500; color: var(--text-2); cursor: pointer; }
      .ha-pill.active { background: var(--brand-softer); color: var(--brand); border-color: var(--brand); font-weight: 600; }
      .ha-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      @media (max-width: 600px) { .ha-row { grid-template-columns: 1fr; } }
      .ha-btn { width: 100%; padding: 14px 20px; background: var(--text-1); color: white; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; font-family: inherit; }
      .ha-btn:hover { background: var(--brand); }
      .ha-hidden { display: none; }
      .ha-results { margin-top: 24px; }
      .ha-result-card { background: white; border: 1px solid var(--border); padding: 28px; margin-bottom: 20px; }
      .ha-gauge-wrap { display: flex; align-items: center; gap: 32px; flex-wrap: wrap; }
      .ha-gauge { position: relative; width: 160px; height: 160px; flex-shrink: 0; }
      .ha-gauge-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; }
      .ha-gauge-score { font-size: 38px; font-weight: 700; font-family: 'Geist Mono', monospace; }
      .ha-gauge-grade { font-size: 15px; font-weight: 600; }
      .ha-bar { margin-bottom: 12px; }
      .ha-bar-head { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-2); margin-bottom: 4px; }
      .ha-bar-track { height: 8px; background: var(--bg-soft); border: 1px solid var(--border); }
      .ha-bar-fill { height: 100%; background: var(--brand); width: 0; transition: width 0.5s ease; }
      .ha-preview { background: var(--bg-soft); border: 1px solid var(--border); padding: 20px; margin-bottom: 20px; }
      .ha-preview-label { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-3); margin-bottom: 10px; }
      .ha-preview-serp { background: white; border: 1px solid var(--border); padding: 16px; }
      .ha-preview-title { font-size: 18px; color: #1a0dab; font-weight: 400; text-decoration: underline; margin-bottom: 6px; }
      .ha-preview-url { font-size: 12px; color: #006621; margin-bottom: 4px; }
      .ha-preview-desc { font-size: 13px; color: var(--text-2); }
      .ha-word { display: inline-block; padding: 2px 4px; margin: 2px; font-size: 14px; background: var(--bg-soft); border: 1px solid var(--border); }
      .ha-word.power { background: #fef3c7; border-color: #f59e0b; }
      .ha-word.emotion { background: #fce7f3; border-color: #ec4899; }
      .ha-word.common { background: #f3f4f6; border-color: #d1d5db; }
      .ha-word.uncommon { background: #ede9fe; border-color: #8b5cf6; }
      .ha-rewrite { background: var(--bg-soft); border: 1px solid var(--border); padding: 16px; margin-bottom: 12px; cursor: pointer; transition: all 0.15s; }
      .ha-rewrite:hover { border-color: var(--brand); }
      .ha-rewrite-title { font-size: 16px; font-weight: 600; color: var(--text-1); margin-bottom: 6px; }
      .ha-rewrite-meta { font-size: 12px; color: var(--text-3); margin-bottom: 6px; }
      .ha-rewrite-reason { font-size: 13px; color: var(--text-2); line-height: 1.5; }
      .ha-serp-item { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 12px 14px; border-bottom: 1px solid var(--border); }
      .ha-serp-item:last-child { border-bottom: none; }
      .ha-serp-title { font-size: 14px; color: var(--text-1); }
      .ha-tag { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; padding: 2px 6px; background: var(--brand-softer); color: var(--brand); }
      .ha-suggestions { background: var(--brand-softer); border: 1px solid var(--brand-soft); padding: 20px; }
      .ha-suggestions ul { margin-top: 10px; }
      .ha-history-item { display: flex; justify-content: space-between; padding: 10px 14px; border: 1px solid var(--border); background: white; margin-bottom: 8px; font-size: 14px; cursor: pointer; }
      .ha-history-item:hover { border-color: var(--brand); }
    </style>

    <div class="ha-wrap">
      <div class="ha-card">
        <div class="ha-field">
          <label for="ha-headline">Your Headline</label>
          <textarea id="ha-headline" maxlength="200" placeholder="Enter your headline, blog title, or subject line..."></textarea>
          <p class="ha-counter" id="ha-char-counter">0/200</p>
        </div>

        <div class="ha-field">
          <label for="ha-keyword">Target Keyword <span>(optional — shows top 10 headline patterns)</span></label>
          <input type="text" id="ha-keyword" maxlength="100" placeholder="e.g., emergency plumber austin" />
        </div>

        <div class="ha-field">
          <label>Content Type</label>
          <div class="ha-pills" id="ha-types">
            <button type="button" class="ha-pill active" data-type="blog">Blog Post</button>
            <button type="button" class="ha-pill" data-type="gbp">GBP Post</button>
            <button type="button" class="ha-pill" data-type="page">Page Title / H1</button>
            <button type="button" class="ha-pill" data-type="email">Email Subject</button>
          </div>
        </div>

        <div class="ha-row">
          <div class="ha-field">
            <label for="ha-industry">Industry <span>(optional)</span></label>
            <select id="ha-industry">
              <option value="">Select industry...</option>
              {industries.map(ind => <option value={ind.value}>{ind.label}</option>)}
            </select>
          </div>
          <div class="ha-field">
            <label for="ha-city">Target City <span>(optional)</span></label>
            <input type="text" id="ha-city" maxlength="60" placeholder="e.g., Austin, TX" />
          </div>
        </div>

        <button id="ha-analyze" class="ha-btn">Analyze Headline</button>
      </div>

      <div id="ha-results" class="ha-results ha-hidden">
        <div class="ha-result-card">
          <div class="ha-gauge-wrap">
            <div class="ha-gauge">
              <svg width="160" height="160" viewBox="0 0 160 160" style="transform: rotate(-90deg);">
                <circle cx="80" cy="80" r="70" fill="none" stroke="var(--border)" stroke-width="10" />
                <circle id="ha-gauge-arc" cx="80" cy="80" r="70" fill="none" stroke="var(--accent-emerald)" stroke-width="10" stroke-linecap="butt" style="stroke-dasharray: 439.82; stroke-dashoffset: 439.82; transition: stroke-dashoffset 0.6s ease, stroke 0.3s ease;" />
              </svg>
              <div class="ha-gauge-text">
                <div class="ha-gauge-score" id="ha-score">0</div>
                <div class="ha-gauge-grade" id="ha-grade">F</div>
              </div>
            </div>
            <div style="flex: 1; min-width: 260px;" id="ha-dimension-bars"></div>
          </div>
        </div>

        <div id="ha-preview-box"></div>

        <div class="ha-result-card">
          <p class="ha-preview-label">Word-by-Word Analysis</p>
          <div id="ha-word-analysis"></div>
        </div>

        <div class="ha-result-card ha-hidden" id="ha-critique-card">
          <p class="ha-preview-label" style="color: var(--brand);">AI Analysis</p>
          <div id="ha-critique-content" style="font-size: 15px; line-height: 1.65; color: var(--text-2);"></div>
        </div>

        <div class="ha-result-card ha-hidden" id="ha-rewrites-card">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <p class="ha-preview-label" style="color: var(--brand);">AI Rewritten Alternatives</p>
            <span style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3);">Powered by Kimi</span>
          </div>
          <div id="ha-rewrites-content"></div>
        </div>

        <div class="ha-result-card ha-hidden" id="ha-serp-card">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <p class="ha-preview-label" style="color: var(--brand);">Top 10 SERP Headline Patterns</p>
            <span style="font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--text-3);">Live data</span>
          </div>
          <p style="font-size: 13px; color: var(--text-3); margin-bottom: 12px;">What headlines are actually ranking for this keyword right now:</p>
          <div id="ha-serp-content"></div>
        </div>

        <div class="ha-suggestions ha-hidden" id="ha-suggestions-box">
          <p class="ha-preview-label" style="color: var(--brand);">Improvement Suggestions</p>
          <ul id="ha-suggestions-list" style="color: var(--text-2); font-size: 14px; line-height: 1.7; padding-left: 20px;"></ul>
        </div>

        <div class="ha-hidden" id="ha-history-card">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
            <p class="ha-preview-label">Headline History</p>
            <button type="button" id="ha-test-another" class="ha-copy" style="padding: 6px 12px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;">Test Another</button>
          </div>
          <div id="ha-history-list"></div>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const headlineEl = document.getElementById('ha-headline');
        const keywordEl = document.getElementById('ha-keyword');
        const cityEl = document.getElementById('ha-city');
        const industryEl = document.getElementById('ha-industry');
        const charCounter = document.getElementById('ha-char-counter');
        const resultsBox = document.getElementById('ha-results');
        const typesBox = document.getElementById('ha-types');
        let contentType = 'blog';

        typesBox.addEventListener('click', (e) => {
          if (!e.target.classList.contains('ha-pill')) return;
          typesBox.querySelectorAll('.ha-pill').forEach(p => p.classList.remove('active'));
          e.target.classList.add('active');
          contentType = e.target.dataset.type;
        });

        headlineEl.addEventListener('input', () => {
          charCounter.textContent = headlineEl.value.length + '/200';
        });

        const powerWords = new Set(['free','proven','guaranteed','certified','trusted','recommended','official','verified','limited','instant','now','today','fast','essential','must','critical','secret','ultimate','exclusive','insider','breakthrough','reveal','hidden','surprising','amazing','brilliant','triumph','avoid','mistake','warning','new','best','top','worst','easy','quick','simple']);
        const emotionalWords = new Set(['amazing','brilliant','triumph','thrilled','excited','worried','afraid','shocked','secret','reveal','hidden','surprising','exclusive','urgent','limited','instant','now','must','critical','essential','free','best','worst','easy']);
        const commonWords = new Set(['the','a','an','and','or','but','in','on','at','to','for','of','with','by','from','is','are','was','were','be','been','being','have','has','had','do','does','did','will','would','could','should','may','might','can','this','that','these','those','i','you','he','she','it','we','they','your','my','our','their','what','how','why','when','where','who']);

        function countSyllables(word) {
          word = word.toLowerCase().replace(/[^a-z]/g, '');
          if (!word) return 0;
          if (word.length <= 3) return 1;
          word = word.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '');
          word = word.replace(/^y/, '');
          const m = word.match(/[aeiouy]{1,2}/g);
          return m ? m.length : 1;
        }

        function analyze(headline) {
          const text = headline.trim();
          const len = text.length;
          const words = text.split(/\s+/).filter(w => w);
          const cleanWords = words.map(w => w.replace(/[^a-zA-Z]/g, '').toLowerCase()).filter(Boolean);

          // Length score
          let idealMin, idealMax;
          if (contentType === 'blog' || contentType === 'page') { idealMin = 50; idealMax = 60; }
          else if (contentType === 'gbp') { idealMin = 40; idealMax = 80; }
          else { idealMin = 30; idealMax = 50; }
          let lengthScore = 0;
          if (len >= idealMin && len <= idealMax) lengthScore = 15;
          else if (len >= idealMin - 10 && len <= idealMax + 15) lengthScore = 10;
          else if (len < idealMin) lengthScore = Math.max(2, Math.round((len / idealMin) * 10));
          else lengthScore = Math.max(2, Math.round(15 - (len - idealMax) * 0.4));

          // Clarity
          const avgSyllables = cleanWords.length ? cleanWords.reduce((s, w) => s + countSyllables(w), 0) / cleanWords.length : 0;
          const clarityScore = Math.min(10, Math.max(2, Math.round(10 - avgSyllables * 1.5 + (cleanWords.length ? 0 : 5))));

          // Power words
          const powerCount = cleanWords.filter(w => powerWords.has(w)).length;
          const powerScore = powerCount >= 3 ? 10 : powerCount === 2 ? 8 : powerCount === 1 ? 5 : 0;

          // Emotional value
          const emotionCount = cleanWords.filter(w => emotionalWords.has(w)).length;
          const emotionScore = Math.min(15, Math.round(emotionCount * 5 + (text.includes('?') ? 3 : 0)));

          // Word balance
          let balanceScore = 8;
          if (cleanWords.some(w => powerWords.has(w))) balanceScore += 3;
          if (cleanWords.some(w => emotionalWords.has(w))) balanceScore += 2;
          if (cleanWords.some(w => !commonWords.has(w) && w.length > 5)) balanceScore += 2;
          balanceScore = Math.min(15, balanceScore);

          // SEO strength
          let seoScore = 0;
          if (/\d/.test(text)) seoScore += 4;
          if (/^(how|what|why|when|where|who|which)\b/i.test(text)) seoScore += 4;
          if (/\b(best|top|ultimate|complete|guide|tips|ways| checklist)\b/i.test(text)) seoScore += 3;
          if (/[\:\-\—]/.test(text)) seoScore += 2;
          if (len >= idealMin && len <= idealMax) seoScore += 2;
          seoScore = Math.min(15, seoScore);

          // Local SEO
          let localScore = 0;
          const city = cityEl.value.trim();
          const ind = industryEl.value;
          if (city && text.toLowerCase().includes(city.split(',')[0].toLowerCase())) localScore += 8;
          if (city && /\b(tx|ca|ny|fl|il|pa|oh|ga|nc|mi|az|ma|wa|co|md|va|nv|or|ky|mo|mn|wi|in|tn|ct|ok|ar|ks|la|ms|al|ia|ut|ne|nm|wv|nh|id|me|mt|ri|de|sd|nd|ak|vt|wy|hi)\b/i.test(text)) localScore += 2;
          if (ind && text.toLowerCase().includes(ind.replace('_', ' '))) localScore += 5;
          localScore = Math.min(15, localScore);

          // Sentiment
          const positive = cleanWords.filter(w => ['amazing','brilliant','triumph','best','great','free','easy','simple','quick','proven','guaranteed'].includes(w)).length;
          const negative = cleanWords.filter(w => ['avoid','mistake','warning','worst','bad','never','don\'t','fail'].includes(w)).length;
          let sentimentScore = 0;
          if (positive && negative) sentimentScore = 5;
          else if (positive || negative) sentimentScore = 3;

          const total = Math.min(100, balanceScore + emotionScore + lengthScore + clarityScore + seoScore + localScore + powerScore + sentimentScore);
          return {
            score: total,
            dimensions: {
              'Word Balance': balanceScore,
              'Emotional Value': emotionScore,
              'Length': lengthScore,
              'Clarity': clarityScore,
              'SEO Strength': seoScore,
              'Local SEO': localScore,
              'Power Words': powerScore,
              'Sentiment': sentimentScore,
            },
            cleanWords, words, text, len
          };
        }

        function grade(score) {
          if (score >= 90) return 'A'; if (score >= 80) return 'B'; if (score >= 70) return 'C'; if (score >= 60) return 'D'; return 'F';
        }

        function color(score) {
          if (score >= 70) return 'var(--accent-emerald)';
          if (score >= 50) return 'var(--accent-amber)';
          return '#ef4444';
        }

        function wordClass(w) {
          const lower = w.toLowerCase().replace(/[^a-z]/g, '');
          if (powerWords.has(lower)) return 'power';
          if (emotionalWords.has(lower)) return 'emotion';
          if (commonWords.has(lower)) return 'common';
          if (lower.length > 5) return 'uncommon';
          return '';
        }

        function renderWordAnalysis(words) {
          const container = document.getElementById('ha-word-analysis');
          container.innerHTML = words.map(w => {
            const cls = wordClass(w);
            return `<span class="ha-word ${cls}">${w.replace(/</g, '&lt;')}</span>`;
          }).join('');
        }

        function renderDimensions(dims) {
          const container = document.getElementById('ha-dimension-bars');
          container.innerHTML = Object.entries(dims).map(([name, val]) => {
            const max = name === 'Sentiment' ? 5 : (name === 'Clarity' ? 10 : 15);
            const pct = Math.round((val / max) * 100);
            return `<div class="ha-bar"><div class="ha-bar-head"><span>${name}</span><span>${val}/${max}</span></div><div class="ha-bar-track"><div class="ha-bar-fill" style="width: 0%; background: ${color(pct)}"></div></div></div>`;
          }).join('');
          setTimeout(() => {
            container.querySelectorAll('.ha-bar-fill').forEach((el, i) => {
              const name = Object.keys(dims)[i];
              const val = dims[name];
              const max = name === 'Sentiment' ? 5 : (name === 'Clarity' ? 10 : 15);
              el.style.width = Math.round((val / max) * 100) + '%';
            });
          }, 50);
