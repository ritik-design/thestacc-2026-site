              <div class="ha-rewrite-reason">${r.reason}</div>
            </div>
          `).join('');
          box.querySelectorAll('.ha-rewrite').forEach(el => {
            el.addEventListener('click', () => {
              headlineEl.value = el.dataset.title;
              charCounter.textContent = headlineEl.value.length + '/200';
              analyzeHeadline();
            });
          });
        }

        function generateSerpPatterns(keyword) {
          const k = keyword;
          const patterns = ['Listicle', 'How-to', 'Question', 'Superlative', 'Urgency', 'Local + Service', 'Comparison'];
          const titles = [
            `7 Best ${k} in ${new Date().getFullYear()}`,
            `How to Choose ${k} (Complete Guide)`,
            `What Is ${k}? A Beginner's Guide`,
            `Top 10 ${k} Ranked & Reviewed`,
            `${k}: Everything You Need to Know`,
            `Why ${k} Is Worth It in ${new Date().getFullYear()}`,
            `${k} vs Competitors: Which Wins?`,
            `The Ultimate Guide to ${k}`,
            `Best ${k} Near Me`,
            `${k}: Proven Tips & Common Mistakes`,
          ];
          return titles.map((t, i) => ({ t, tag: patterns[i % patterns.length] }));
        }

        function renderSerp(keyword) {
          const card = document.getElementById('ha-serp-card');
          const box = document.getElementById('ha-serp-content');
          card.classList.remove('ha-hidden');
          const patterns = generateSerpPatterns(keyword);
          box.innerHTML = patterns.map((p, i) => `
            <div class="ha-serp-item">
              <span class="ha-serp-title">${i + 1}. ${p.t.replace(/</g, '&lt;')}</span>
              <span class="ha-tag">${p.tag}</span>
            </div>
          `).join('');
        }

        function suggestions(data) {
          const list = document.getElementById('ha-suggestions-list');
          const box = document.getElementById('ha-suggestions-box');
          const items = [];
          if (data.dimensions['Length'] < 12) items.push('Lengthen or shorten the headline to fit the ideal range for your content type.');
          if (data.dimensions['Power Words'] < 5) items.push('Add a power word like "Proven," "Free," "Instant," or "Ultimate."');
          if (data.dimensions['SEO Strength'] < 10) items.push('Include a number, question word, or list format.');
          if (data.dimensions['Clarity'] < 7) items.push('Replace jargon with simpler words so it scans in under 2 seconds.');
          if (data.dimensions['Emotional Value'] < 8) items.push('Trigger curiosity or urgency with emotional language.');
          if (cityEl.value && data.dimensions['Local SEO'] < 8) items.push('Include your city and industry keyword to improve local SEO.');
          if (!items.length) items.push('Great headline. Try A/B testing it against one of the AI rewrites above.');
          list.innerHTML = items.map(i => `<li>${i}</li>`).join('');
          box.classList.remove('ha-hidden');
        }

        let history = [];
        function addHistory(title, score) {
          history.unshift({ title, score });
