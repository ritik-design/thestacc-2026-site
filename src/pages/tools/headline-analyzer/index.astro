            </div>
          `).join('');
          list.querySelectorAll('.ha-history-item').forEach(el => {
            el.addEventListener('click', () => {
              headlineEl.value = el.dataset.title;
              charCounter.textContent = headlineEl.value.length + '/200';
              analyzeHeadline();
            });
          });
        }

        function analyzeHeadline() {
          const headline = headlineEl.value.trim();
          if (!headline) return;
          const data = analyze(headline);
          const c = color(data.score);

          const arc = document.getElementById('ha-gauge-arc');
          const scoreEl = document.getElementById('ha-score');
          const gradeEl = document.getElementById('ha-grade');
          arc.style.strokeDashoffset = 439.82 * (1 - data.score / 100);
          arc.style.stroke = c;
          scoreEl.textContent = data.score;
          scoreEl.style.fill = c;
          gradeEl.textContent = grade(data.score);
          gradeEl.style.fill = c;

          renderDimensions(data.dimensions);
          renderPreview(headline, data.score);
          renderWordAnalysis(data.words);

          const critiqueBox = document.getElementById('ha-critique-content');
          critiqueBox.innerHTML = critique(data).split('\n\n').map(p => `<p>${p.replace(/</g, '&lt;')}</p>`).join('');
          document.getElementById('ha-critique-card').classList.remove('ha-hidden');

          const keyword = keywordEl.value.trim();
          if (keyword) renderSerp(keyword);
          else document.getElementById('ha-serp-card').classList.add('ha-hidden');

          const rewrites = generateRewrites(headline, keyword, cityEl.value, industryEl.value);
          renderRewrites(rewrites);
          suggestions(data);
          addHistory(headline, data.score);

          resultsBox.classList.remove('ha-hidden');
        }

        document.getElementById('ha-analyze').addEventListener('click', analyzeHeadline);
        document.getElementById('ha-test-another').addEventListener('click', () => {
          headlineEl.value = '';
          charCounter.textContent = '0/200';
          resultsBox.classList.add('ha-hidden');
        });
      })();
    </script>
