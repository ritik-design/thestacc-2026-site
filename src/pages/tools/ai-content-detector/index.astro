---
import ToolLayout from '../../../layouts/ToolLayout.astro';
const pageUrl = 'https://thestacc.com/tools/ai-content-detector/';
---
<ToolLayout
  seo={{ title: 'AI Content Detector · theStacc', description: 'Detect AI-generated text. Our free AI Humanizer helps you understand and refine AI-written content.', canonical: pageUrl, noindex: true }}
  toolName="AI Content Detector"
  toolDescription="Detect AI-generated text and refine it with our free AI Humanizer."
>
  <section slot="tool" style="text-align: center; padding: 64px 24px;">
    <h2 style="margin-bottom: 16px;">AI Content Detector has moved</h2>
    <p style="margin-bottom: 32px; color: var(--text-2);">Use our free AI Humanizer to analyze and refine AI-generated text.</p>
    <a href="/tools/ai-humanizer/" class="btn btn-primary"><span>Open AI Humanizer <span class="arrow">→</span></span></a>
  </section>
  <meta http-equiv="refresh" content="2;url=/tools/ai-humanizer/" />
</ToolLayout>
