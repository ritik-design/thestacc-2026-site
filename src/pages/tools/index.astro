---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'Free SEO tools — 27 tools, no signup · theStacc',
  description: '27 free SEO and marketing tools — audit, schema, headline analyzer, ROI calculator, GBP post generator, review tools. No signup. No credit card.',
  canonical: 'https://thestacc.com/tools/',
  ogImage: '/og/tools.webp',
  schemaData: {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Free SEO tools',
    url: 'https://thestacc.com/tools/',
  },
};

const tools = [
  { slug: 'seo-audit', name: 'SEO Audit Tool', desc: 'Full site audit in 60 seconds — broken links, slow pages, missing meta.', icon: 'clipboard' },
  { slug: 'website-seo-score', name: 'Website SEO Score', desc: 'A single 0–100 score for any URL, scored against 50 ranking signals.', icon: 'activity' },
  { slug: 'on-page-seo-checker', name: 'On-Page SEO Checker', desc: 'Title, meta, headers, alt text — all checked against the target keyword.', icon: 'check-circle' },
  { slug: 'meta-tag-analyzer', name: 'Meta Tag Analyzer', desc: 'See how your meta title, description, and OG tags render across search engines.', icon: 'tag' },
  { slug: 'schema-markup-generator', name: 'Schema Markup Generator', desc: 'JSON-LD for Article, FAQ, How-to, Product, LocalBusiness — copy-paste ready.', icon: 'code' },
  { slug: 'headline-analyzer', name: 'Headline Analyzer', desc: 'Score any headline for clarity, emotion, and CTR — with rewrites suggested.', icon: 'type' },
  { slug: 'seo-roi-calculator', name: 'SEO ROI Calculator', desc: 'See the dollar value of ranking #1 vs #10 for your top keywords.', icon: 'dollar' },
  { slug: 'gbp-post-generator', name: 'GBP Post Generator', desc: 'AI-written Google Business Profile posts — Offer, Event, Product, Update.', icon: 'pin' },
  { slug: 'review-qr-code-generator', name: 'Review QR Code Generator', desc: 'A printable QR code that takes customers straight to your Google review page.', icon: 'qr' },
  { slug: 'review-request-generator', name: 'Review Request Generator', desc: 'Templates for SMS, email, and in-person review requests that convert.', icon: 'mail' },
  { slug: 'review-response-generator', name: 'Review Response Generator', desc: 'Reply to any review — 5 stars or 1 star — in your brand voice.', icon: 'reply' },
  { slug: 'cms-detector', name: 'CMS Detector', desc: 'Identify the CMS, framework, server, CDN, analytics, and 70+ technologies.', icon: 'cpu' },
  { slug: 'internal-link-suggester', name: 'Internal Link Suggester', desc: 'Discover specific internal linking opportunities with anchor text suggestions.', icon: 'link' },
  { slug: 'ai-visibility-checker', name: 'AI Visibility Checker', desc: 'Check how visible your site is to ChatGPT, Perplexity, Gemini, and AI Overviews.', icon: 'eye' },
  { slug: 'website-traffic-checker', name: 'Website Traffic Checker', desc: 'Estimated organic traffic, ranking keywords, and position distribution.', icon: 'globe' },
  { slug: 'serp-checker', name: 'SERP Checker', desc: 'Live Google SERP results for any keyword — top 100, features, and stats.', icon: 'search' },
  { slug: 'ai-humanizer', name: 'AI Humanizer', desc: 'Transform AI-generated text into natural, human-sounding content.', icon: 'sparkles' },
  { slug: 'paraphraser', name: 'Paraphraser', desc: 'Rewrite any text while preserving meaning. Five modes from Formal to Creative.', icon: 'refresh' },
  { slug: 'content-brief-generator', name: 'Content Brief Generator', desc: 'Generate complete content briefs from any keyword, with titles and outlines.', icon: 'file-text' },
  { slug: 'faq-generator', name: 'FAQ Generator', desc: 'Generate SEO-optimized FAQ sections from any keyword, with schema markup.', icon: 'help-circle' },
  { slug: 'title-tag-generator', name: 'Title Tag Generator', desc: 'Get scored, click-worthy title tags for any keyword and page type.', icon: 'type' },
  { slug: 'sitemap-generator', name: 'Sitemap Generator', desc: 'Build and validate an XML sitemap for any website.', icon: 'map' },
  { slug: 'keyword-difficulty-checker', name: 'Keyword Difficulty Checker', desc: 'Check how hard a keyword is to rank for, plus volume and intent signals.', icon: 'bar-chart' },
  { slug: 'people-also-ask', name: 'People Also Ask', desc: 'Fetch real PAA questions for any keyword to power content and FAQs.', icon: 'message-circle' },
  { slug: 'competitor-page-audit', name: 'Competitor Page Audit', desc: 'Compare a competitor page against your target keyword and find gaps.', icon: 'target' },
  { slug: 'content-gap-analyzer', name: 'Content Gap Analyzer', desc: 'Find keyword and topic gaps between your page and top competitors.', icon: 'layers' },
  { slug: 'llms-txt-generator', name: 'LLMs.txt Generator', desc: 'Generate an LLMs.txt file to control how AI crawlers read your site.', icon: 'file-code' },
];

const iconMap: Record<string, string> = {
