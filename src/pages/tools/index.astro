  activity: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
  'check-circle': '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
  tag: '<path d="M20.59 13.41L13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7" cy="7" r="1.5"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  type: '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>',
  dollar: '<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
  pin: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  qr: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><path d="M14 14h3v3h-3zM18 18h3v3h-3z"/>',
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/>',
  reply: '<polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/>',
  cpu: '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>',
  link: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  eye: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
  globe: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  search: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  sparkles: '<path d="M12 2l2.4 7.2h7.6l-6 4.8 2.4 7.2-6-4.8-6 4.8 2.4-7.2-6-4.8h7.6z"/>',
  refresh: '<polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>',
  'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
  'help-circle': '<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
  map: '<polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>',
  'bar-chart': '<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>',
  'message-circle': '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  layers: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  'file-code': '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><polyline points="9 13 6 16 9 19"/><polyline points="15 13 18 16 15 19"/>',
};
---

<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Free tools · {tools.length} of them</span>
    <h1 class="h-display">27 free SEO tools — <span class="accent">no signup.</span></h1>
    <p class="hero-sub">Audit your site, generate schema, write GBP posts, calculate ROI, check rankings, and more. Every tool runs in your browser. No email. No credit card.</p>
    <div class="hero-ctas">
      <a href="/tools/seo-audit/" class="btn btn-primary"><span>Run a free audit <span class="arrow">→</span></span></a>
      <a href="/checkout/" class="btn btn-secondary">Start your $1 trial</a>
    </div>
  </section>

  <!-- TOOLS GRID -->
  <section style="padding: 80px 32px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div class="tools-grid">
        {tools.map((t) => (
          <a href={`/tools/${t.slug}/`} class="bento-card">
            <div class="bento-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconMap[t.icon]} />
            </div>
            <h3 class="h-sm" style="margin-bottom: 10px;">{t.name}</h3>
            <p class="bento-desc">{t.desc}</p>
            <div class="bento-cta" style="margin-top: 18px;">Open tool <span class="arrow">→</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BENEFIT BAND -->
  <section style="padding: 80px 32px; background: white;">
    <div style="max-width: 1080px; margin: 0 auto; text-align: center;">
      <span class="label-pill" style="margin-bottom: 18px;">Built for the daily SEO grind</span>
      <h2 class="h-lg" style="margin-bottom: 18px;">Use them daily. <span class="accent">For free. Forever.</span></h2>
      <p class="lede" style="max-width: 720px; margin: 0 auto 40px;">Every tool here ships in our paid platform too — except in theStacc, it runs 100× a month, on autopilot, across every page and every keyword you care about.</p>
      <a href="/checkout/" class="btn btn-primary"><span>Use them 100×/month — start $1 trial <span class="arrow">→</span></span></a>
    </div>
  </section>

  <!-- LITE FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Free tools are great. <span class="accent">Automation is better.</span></h2>
        <p class="final-sub">Run these 100× a month on autopilot. From $49/mo.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    .tools-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    @media (max-width: 1100px) { .tools-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 800px) { .tools-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .tools-grid { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
