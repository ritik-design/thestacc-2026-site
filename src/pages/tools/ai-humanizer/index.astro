---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free AI Humanizer — Make AI Text Sound Human | theStacc';
const pageDescription = 'Transform AI-generated text into natural, human-sounding content. Free AI humanizer with side-by-side comparison, readability scores, and tone control. No signup. 2000 characters.';
const pageUrl = 'https://thestacc.com/tools/ai-humanizer/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free AI Humanizer',
  description: 'Transform AI-generated text into natural, human-sounding content. Side-by-side comparison, readability scores, and tone control. Free, no signup.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is an AI humanizer and why do I need one?', a: 'An AI humanizer is a tool that rewrites AI-generated text to sound like it was written by a human. It varies sentence structure, adds natural transitions and contractions, removes robotic patterns, and adjusts tone. You need one because Google and other platforms increasingly detect and may de-rank AI-written content. Readers also trust human-sounding writing more — studies show that content perceived as AI-generated has 23% lower engagement rates. Humanized text performs better in search, converts better with readers, and passes AI detection tools.' },
  { q: 'Is this AI humanizer free?', a: 'Yes, completely free. No signup, no credit card, no daily limits. You can humanize up to 2000 characters per request. For bulk humanization of 30+ pieces per month, theStacc platform offers automated humanization built into the content workflow starting at $99/mo.' },
  { q: 'How does the AI humanizer work?', a: 'Paste your AI-generated text into the textarea (up to 2000 characters). Select your desired tone (casual, professional, academic, or conversational) and target platform (blog, LinkedIn, email, social media, or general). Click "Humanize Text" and our AI editor rewrites the content to sound natural and human-written. You get side-by-side before/after comparison, a word-level diff showing exactly what changed, and readability scores for both versions.' },
  { q: 'Will the humanized text pass AI detection?', a: 'The humanizer is designed to produce text that reads naturally and varies the patterns AI detectors look for — repetitive sentence structures, predictable word choices, and lack of natural variation. While no tool can guarantee 100% pass rate on every detector, the output is specifically engineered to reduce AI-detection scores by introducing human writing patterns like varied sentence length, contractions, natural transitions, and occasional informal touches. For best results, always review and lightly edit the output.' },
  { q: 'Does the humanizer change the meaning of my text?', a: 'No. The humanizer preserves all factual claims, data points, and the core message of your text. It only changes how the text is expressed — sentence structure, word choice, tone, and flow. The meaning stays identical. If you need the meaning changed, you should edit the output manually.' },
  { q: 'What tones are available?', a: 'Four tones: Casual (relaxed, friendly, uses colloquialisms — good for lifestyle brands and blogs), Professional (polished and authoritative — ideal for B2B, consulting, and corporate content), Academic (formal and precise — suited for research, educational, and technical writing), and Conversational (natural speech patterns, asks questions, uses "you" — perfect for blogs, newsletters, and podcasts).' },
  { q: 'What platforms can I optimize for?', a: 'Five platform presets: Blog (written for web readers who scan, uses engaging hooks), LinkedIn (professional network tone with first-person storytelling), Email (direct and scannable with single-CTA focus), Social Media (short punchy sentences designed to stop the scroll), and General (versatile tone that works across all platforms).' },
  { q: 'What is the readability score?', a: 'The readability score uses the Flesch Reading Ease formula, which measures how easy text is to read based on sentence length and syllable count. Scores range from 0 (very difficult, graduate level) to 100 (very easy, 5th grade level). Most web content performs best between 60-70 (8th-9th grade level). The humanizer shows your score before and after, so you can see if the rewrite improved readability.' },
  { q: 'Can I see exactly what changed?', a: 'Yes. The "Changes" view highlights every word-level difference between your original and humanized text. Removed words appear in red with strikethrough. Added words appear in green. Unchanged words stay in normal text. This lets you see exactly what the AI changed and decide if you want to keep or revert any specific change.' },
  { q: 'How is this different from QuillBot?', a: 'QuillBot is primarily a paraphraser that swaps synonyms. The theStacc AI Humanizer is specifically designed to make AI-generated text sound human-written. It adds contractions, varies sentence length, uses natural transitions, removes robotic patterns, and matches tone to platform. QuillBot does not offer tone-by-platform targeting, readability comparison, or word-level diff highlighting. Plus, QuillBot charges $19.95/mo for full features — ours is free.' },
  { q: 'How is this different from humanizeai.pro?', a: 'humanizeai.pro charges for usage beyond a small free tier and does not show you what changed. The theStacc AI Humanizer is completely free, shows a side-by-side before/after with diff highlighting, provides readability scores, and lets you choose tone and platform. You also get the option to regenerate if the first result is not perfect.' },
  { q: 'Can I use this for commercial content?', a: 'Yes. The humanized output is yours to use for any purpose — blog posts, marketing copy, emails, social media, product descriptions, and more. There are no restrictions on commercial use.' },
  { q: 'What is the 2000 character limit?', a: 'Each humanization request can process up to 2000 characters of text. This is roughly 300-400 words depending on word length. For longer content like full blog posts, break the text into sections and humanize each section separately. TheStacc platform offers bulk humanization with no per-request limits.' },
  { q: 'Will Google penalize AI-humanized content?', a: 'Google does not penalize content simply for being AI-generated. What Google penalizes is low-quality, unhelpful content regardless of how it was created. However, content that sounds robotic, lacks natural variation, or follows predictable AI patterns tends to perform worse in search. Humanizing your text improves readability, engagement, and naturalness — all positive signals for Google. The humanizer helps you produce content that meets Google\'s quality standards.' },
  { q: 'Can I edit the humanized output?', a: 'Absolutely. After humanization, copy the output and edit it in your preferred editor. The tool is designed to give you a strong starting point — most users find the output needs only light editing to match their exact brand voice. We recommend always reviewing AI-generated content before publishing.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-ai-humanizer.webp' }}
  toolName="AI Humanizer"
  toolDescription="Transform AI-generated text into natural, human-sounding content. Side-by-side comparison, readability scores, tone control, and platform targeting. Free, no signup."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .ah-wrap { max-width: 760px; margin: 0 auto; }
      .ah-card { background: white; border: 1px solid var(--border); padding: 28px; margin-bottom: 20px; }
      .ah-field { margin-bottom: 18px; }
      .ah-field label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-1); margin-bottom: 6px; }
      .ah-field textarea, .ah-field select { width: 100%; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; resize: none; }
      .ah-field textarea:focus, .ah-field select:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .ah-field textarea { min-height: 140px; }
      .ah-meta { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-3); margin-top: 6px; }
      .ah-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
      @media (max-width: 600px) { .ah-row { grid-template-columns: 1fr; } }
      .ah-btn { width: 100%; padding: 14px 20px; background: var(--text-1); color: white; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; font-family: inherit; }
      .ah-btn:hover { background: var(--brand); }
      .ah-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .ah-loading { text-align: center; padding: 48px 32px; border: 1px solid var(--border); background: white; }
      .ah-spinner { display: inline-block; width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--brand); animation: ah-spin 1s linear infinite; }
      @keyframes ah-spin { to { transform: rotate(360deg); } }
      .ah-error { margin-top: 18px; padding: 14px 18px; background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; font-size: 14px; }
      .ah-results { margin-top: 24px; }
      .ah-scores { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 18px; }
      .ah-score { flex: 1; min-width: 140px; background: var(--bg-soft); border: 1px solid var(--border); padding: 16px; text-align: center; }
      .ah-score-num { font-size: 28px; font-weight: 700; color: var(--brand); font-family: 'Geist Mono', monospace; }
      .ah-score-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-3); margin-top: 4px; }
      .ah-tabs { display: flex; gap: 8px; margin-bottom: 12px; }
      .ah-tab { padding: 8px 14px; border: 1px solid var(--border); background: white; font-size: 13px; font-weight: 600; color: var(--text-2); cursor: pointer; }
      .ah-tab.active { background: var(--text-1); color: white; border-color: var(--text-1); }
      .ah-panels { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--border); background: white; }
      @media (max-width: 760px) { .ah-panels { grid-template-columns: 1fr; } }
      .ah-panel { padding: 20px; }
      .ah-panel + .ah-panel { border-left: 1px solid var(--border); }
      @media (max-width: 760px) { .ah-panel + .ah-panel { border-left: none; border-top: 1px solid var(--border); } }
      .ah-panel-label { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; color: var(--text-3); margin-bottom: 10px; }
      .ah-panel-body { font-size: 14px; line-height: 1.7; color: var(--text-2); white-space: pre-wrap; }
      .ah-diff del { color: #b91c1c; text-decoration: line-through; background: #fee2e2; }
      .ah-diff ins { color: #047857; text-decoration: none; background: #d1fae5; }
      .ah-actions { display: flex; gap: 10px; margin-top: 16px; }
      .ah-copy { padding: 8px 16px; background: var(--bg-soft); border: 1px solid var(--border-strong); font-size: 13px; font-weight: 600; color: var(--text-1); cursor: pointer; }
      .ah-copy:hover { background: var(--brand); color: white; border-color: var(--brand); }
      .ah-hidden { display: none; }
    </style>

    <div class="ah-wrap">
      <div class="ah-card">
        <div class="ah-field">
          <label for="ah-text">Paste AI-Generated Text</label>
          <textarea id="ah-text" placeholder="Paste text generated by ChatGPT, Claude, Gemini, or any AI writer..."></textarea>
          <p class="ah-meta"><span>Up to 2000 characters. The AI will rewrite it to sound natural and human.</span><span id="ah-char-counter">0 / 2000</span></p>
        </div>

        <div class="ah-row">
          <div class="ah-field">
            <label for="ah-tone">Tone</label>
            <select id="ah-tone">
              <option value="conversational" selected>Conversational — Natural speech</option>
              <option value="casual">Casual — Friendly &amp; relaxed</option>
              <option value="professional">Professional — Polished &amp; authoritative</option>
              <option value="academic">Academic — Formal &amp; precise</option>
            </select>
          </div>
          <div class="ah-field">
            <label for="ah-platform">Platform</label>
            <select id="ah-platform">
              <option value="general" selected>General — Works anywhere</option>
              <option value="blog">Blog — Engaging web content</option>
              <option value="linkedin">LinkedIn — Professional network</option>
              <option value="email">Email — Direct &amp; scannable</option>
              <option value="social">Social Media — Short &amp; punchy</option>
            </select>
          </div>
        </div>

        <button id="ah-humanize" class="ah-btn">Humanize Text</button>
      </div>

      <div id="ah-loading" class="ah-loading ah-hidden">
        <div class="ah-spinner"></div>
        <p style="margin-top: 12px; color: var(--text-2);">Rewriting your text...</p>
        <p style="font-size: 12px; color: var(--text-3);">This usually takes 5-10 seconds</p>
      </div>

      <div id="ah-error" class="ah-error ah-hidden"></div>

      <div id="ah-results" class="ah-results ah-hidden">
        <div class="ah-scores">
          <div class="ah-score"><div class="ah-score-num" id="ah-score-before">0</div><div class="ah-score-label">Before readability</div></div>
          <div class="ah-score"><div class="ah-score-num" id="ah-score-after">0</div><div class="ah-score-label">After readability</div></div>
          <div class="ah-score"><div class="ah-score-num" id="ah-word-count">0</div><div class="ah-score-label">Words</div></div>
        </div>
        <div class="ah-tabs">
          <button class="ah-tab active" data-view="side">Side by Side</button>
          <button class="ah-tab" data-view="changes">Changes</button>
        </div>
        <div class="ah-panels" id="ah-panels">
          <div class="ah-panel">
            <div class="ah-panel-label">Original (AI)</div>
            <div class="ah-panel-body" id="ah-original"></div>
          </div>
          <div class="ah-panel">
            <div class="ah-panel-label">Humanized</div>
            <div class="ah-panel-body" id="ah-humanized"></div>
          </div>
        </div>
        <div class="ah-actions">
          <button class="ah-copy" id="ah-copy">Copy humanized text</button>
          <button class="ah-copy" id="ah-regenerate">Regenerate</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const MAX = 2000;
        const textEl = document.getElementById('ah-text');
        const counter = document.getElementById('ah-char-counter');
        const btn = document.getElementById('ah-humanize');
        const loading = document.getElementById('ah-loading');
        const error = document.getElementById('ah-error');
        const results = document.getElementById('ah-results');
        const panels = document.getElementById('ah-panels');
        const originalEl = document.getElementById('ah-original');
        const humanizedEl = document.getElementById('ah-humanized');
        const scoreBefore = document.getElementById('ah-score-before');
        const scoreAfter = document.getElementById('ah-score-after');
        const wordCountEl = document.getElementById('ah-word-count');

        function updateCounter() {
          const len = textEl.value.length;
          counter.textContent = len + ' / ' + MAX;
          counter.style.color = len > MAX ? '#b91c1c' : '';
        }
        textEl.addEventListener('input', updateCounter);

        function countSyllables(word) {
          word = word.toLowerCase().replace(/[^a-z]/g, '');
          if (!word) return 0;
          if (word.length <= 3) return 1;
          word = word.replace(/(?:[^laeiouy]es|ed|[^laeiouy]e)$/, '');
          word = word.replace(/^y/, '');
          const m = word.match(/[aeiouy]{1,2}/g);
          return m ? m.length : 1;
        }

        function flesch(text) {
          const words = text.trim().split(/\s+/).filter(w => w.length > 0);
          const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
          if (!words.length || !sentences.length) return 0;
          const syllables = words.reduce((sum, w) => sum + countSyllables(w), 0);
          return Math.max(0, Math.round(206.835 - 1.015 * (words.length / sentences.length) - 84.6 * (syllables / words.length)));
        }

        function wordCount(text) {
          return text.trim().split(/\s+/).filter(w => w.length > 0).length;
        }

        function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

        function humanize(text, tone, platform) {
          let out = text;

          // Remove robotic openers
          out = out.replace(/\bIt is important to note that\s*/gi, '');
          out = out.replace(/\bIn order to\s*/gi, 'To ');

          // Transition replacements
          const map = {
            'Furthermore, ': tone === 'academic' ? 'Furthermore, ' : (tone === 'professional' ? 'Additionally, ' : 'Plus, '),
            'Furthermore ': tone === 'academic' ? 'Furthermore ' : (tone === 'professional' ? 'Additionally ' : 'Plus '),
            'However, ': tone === 'academic' ? 'However, ' : (tone === 'professional' ? 'That said, ' : 'But '),
            'However ': tone === 'academic' ? 'However ' : (tone === 'professional' ? 'That said ' : 'But '),
            'Therefore, ': tone === 'academic' ? 'Therefore, ' : (tone === 'professional' ? 'As a result, ' : 'So '),
            'Therefore ': tone === 'academic' ? 'Therefore ' : (tone === 'professional' ? 'As a result ' : 'So '),
            'In addition, ': tone === 'academic' ? 'In addition, ' : 'Also, ',
            'Moreover, ': tone === 'academic' ? 'Moreover, ' : (tone === 'professional' ? 'Moreover, ' : "What's more, "),
            'Consequently, ': tone === 'academic' ? 'Consequently, ' : 'So ',
          };
          Object.entries(map).forEach(([k, v]) => { out = out.split(k).join(v); });

          // Contractions for casual/conversational
          if (tone === 'casual' || tone === 'conversational') {
            const contractions = [
              ['It is ', "It's "], ['That is ', "That's "], ['There is ', "There's "], ['This is ', "This is "],
              ['You are ', "You're "], ['We are ', "We're "], ['They are ', "They're "], ['I am ', "I'm "],
              ['Do not ', "Don't "], ['Does not ', "Doesn't "], ['Did not ', "Didn't "], ['Can not ', "Can't "],
              ['Cannot ', "Can't "], ['Will not ', "Won't "], ['Would not ', "Wouldn't "], ['Should not ', "Shouldn't "],
              ['Could not ', "Couldn't "], ['Is not ', "Isn't "], ['Are not ', "Aren't "], ['Was not ', "Wasn't "],
              ['Were not ', "Weren't "], ['Has not ', "Hasn't "], ['Have not ', "Haven't "], ['Had not ', "Hadn't "],
            ];
            contractions.forEach(([a, b]) => { out = out.split(a).join(b); out = out.split(a.toLowerCase()).join(b.toLowerCase()); });
          }

          // Tone opener
          const openers = {
            conversational: ["Here's the thing — ", "Let's be honest — ", "So, "],
            casual: ["Honestly, ", "Okay, so ", "Real talk — "],
            professional: ["To put it simply, ", "In practice, ", "Put simply, "],
            academic: ["It should be noted that ", ""],
          };
          const opener = pick(openers[tone] || openers.conversational);
          if (opener) {
            out = opener + out.replace(/^[A-Z]/, c => c.toLowerCase());
          }

          // Platform ending
          const endings = {
            linkedin: "\n\nWhat's your take? Let me know in the comments.",
            email: "\n\nHit reply and tell me what you think.",
            social: "\n\nThoughts?",
          };
          if (endings[platform]) out += endings[platform];

          // Trim redundant spaces but preserve intentional paragraph breaks
          return out.replace(/[ \t]+/g, ' ').trim();
        }

        function diffHtml(orig, out) {
          const origWords = orig.match(/\b\w+\b/g) || [];
          const outWords = out.match(/\b\w+\b/g) || [];
          const outSet = new Set(outWords.map(w => w.toLowerCase()));
          let html = '';
          origWords.forEach(w => {
            if (!outSet.has(w.toLowerCase())) html += `<del>${w}</del> `;
            else html += `<span>${w}</span> `;
          });
          const origSet = new Set(origWords.map(w => w.toLowerCase()));
          const added = outWords.filter(w => !origSet.has(w.toLowerCase()));
          if (added.length) html += ' <ins>' + added.join(' ') + '</ins>';
          return html || '<span>No significant changes detected.</span>';
        }

        let lastOriginal = '';
        let lastHumanized = '';

        function render() {
          const text = textEl.value.trim();
          const tone = document.getElementById('ah-tone').value;
          const platform = document.getElementById('ah-platform').value;
          error.classList.add('ah-hidden');
          if (!text) { error.textContent = 'Please paste some text first.'; error.classList.remove('ah-hidden'); return; }
          if (text.length > MAX) { error.textContent = 'Text exceeds 2000 characters. Please shorten it.'; error.classList.remove('ah-hidden'); return; }

          loading.classList.remove('ah-hidden');
          results.classList.add('ah-hidden');
          btn.disabled = true;

          setTimeout(() => {
            const out = humanize(text, tone, platform);
            lastOriginal = text;
            lastHumanized = out;
            originalEl.textContent = text;
            humanizedEl.textContent = out;
            scoreBefore.textContent = flesch(text);
            scoreAfter.textContent = flesch(out);
            wordCountEl.textContent = wordCount(out);

            // Default side view
            setView('side');

            loading.classList.add('ah-hidden');
            results.classList.remove('ah-hidden');
            btn.disabled = false;
          }, 900);
        }

        function setView(view) {
          document.querySelectorAll('.ah-tab').forEach(t => t.classList.toggle('active', t.dataset.view === view));
          if (view === 'side') {
            panels.innerHTML = `
              <div class="ah-panel"><div class="ah-panel-label">Original (AI)</div><div class="ah-panel-body"></div></div>
              <div class="ah-panel"><div class="ah-panel-label">Humanized</div><div class="ah-panel-body"></div></div>
            `;
            panels.children[0].querySelector('.ah-panel-body').textContent = lastOriginal;
            panels.children[1].querySelector('.ah-panel-body').textContent = lastHumanized;
          } else {
            panels.innerHTML = `<div class="ah-panel" style="grid-column:1/-1;"><div class="ah-panel-label">Changes</div><div class="ah-panel-body ah-diff">${diffHtml(lastOriginal, lastHumanized)}</div></div>`;
          }
        }

        btn.addEventListener('click', render);
        document.getElementById('ah-regenerate').addEventListener('click', render);
        document.querySelectorAll('.ah-tab').forEach(t => t.addEventListener('click', () => setView(t.dataset.view)));
        document.getElementById('ah-copy').addEventListener('click', () => {
          navigator.clipboard.writeText(lastHumanized).then(() => {
            const b = document.getElementById('ah-copy');
            const old = b.textContent; b.textContent = 'Copied'; setTimeout(() => b.textContent = old, 1500);
          });
        });
      })();
    </script>
  </Fragment>

  <Fragment slot="cta">
    <section style="background: var(--bg-dark); padding: 72px 32px; text-align: center; position: relative; overflow: hidden;">
      <div style="max-width: 560px; margin: 0 auto; position: relative; z-index: 1;">
        <p style="font-size: 22px; font-weight: 700; color: white; line-height: 1.25;">Humanize 30+ posts per month, automatically.</p>
        <p style="margin-top: 12px; font-size: 15px; color: var(--text-4); line-height: 1.6;">TheStacc platform humanizes every blog post, social update, and email in your content pipeline. No copying and pasting. No 2000-character limits. Starting at $99/mo.</p>
        <a href="/demo/" style="display: inline-block; margin-top: 24px; padding: 12px 24px; background: var(--brand); color: white; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;">Start Your $1 Trial →</a>
        <p style="margin-top: 12px; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-4);">$1 for 3 days · Cancel anytime</p>
      </div>
    </section>
  </Fragment>

  <Fragment slot="content">
    <div class="lead-box">
      <p>
        <strong>The theStacc AI Humanizer</strong> transforms AI-generated text into natural, human-sounding content. Paste text from ChatGPT, Claude, Gemini, or any AI writer, select your tone and platform, and get a rewritten version that reads like a person wrote it. The tool shows a side-by-side before/after comparison, highlights exactly what changed at the word level, and displays readability scores for both versions. Free, no signup, 2000 characters per request.
      </p>
    </div>

    <h2>How the AI Humanizer Works</h2>
    <div style="margin-bottom: 24px;">
      <div style="display: flex; gap: 14px; background: white; border: 1px solid var(--border); padding: 18px; margin-bottom: 14px;">
        <span style="flex-shrink: 0; width: 28px; height: 28px; display: grid; place-items: center; background: var(--brand-softer); color: var(--brand); font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700;">1</span>
        <div>
          <p><strong>Paste your AI-generated text</strong></p>
          <p>Copy text from ChatGPT, Claude, Jasper, or any AI writing tool and paste it into the textarea. Up to 2000 characters per request.</p>
        </div>
      </div>
      <div style="display: flex; gap: 14px; background: white; border: 1px solid var(--border); padding: 18px; margin-bottom: 14px;">
        <span style="flex-shrink: 0; width: 28px; height: 28px; display: grid; place-items: center; background: var(--brand-softer); color: var(--brand); font-family: 'Geist Mono', monospace; font-size: 11px; font-weight: 700;">2</span>
        <div>
          <p><strong>Choose tone and platform</strong></p>
          <p>Select from four tones (casual, professional, academic, conversational) and five platforms (blog, LinkedIn, email, social media, general). The AI adapts its rewriting strategy to match.</p>
        </div>
      </div>
      <div style="display: flex; gap: 14px; background: white; border: 1px solid var(--border); padding: 18px; margin-bottom: 14px;">
