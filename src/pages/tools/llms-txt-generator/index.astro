---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free LLMs.txt Generator — Auto-Crawl + AI Crawler Control | theStacc';
const pageDescription = 'Free llms.txt generator with auto-crawl. Enter any URL to generate a validated llms.txt file with AI crawler controls, attribution settings, and structured format. No signup required.';
const pageUrl = 'https://thestacc.com/tools/llms-txt-generator/';
const lastUpdated = '2026-05-22';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free LLMs.txt Generator',
  description: 'Generate a properly formatted llms.txt file for any website. Auto-crawl, AI crawler controls, attribution settings, and validation.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is llms.txt and why do I need it?', a: 'llms.txt is an emerging standard that lets websites control how AI crawlers access their content. It tells AI systems like ChatGPT, Claude, and Perplexity which parts of your site they can crawl, which they should avoid, and whether you require attribution when they use your content. As AI search grows, having an llms.txt file helps protect your intellectual property while maintaining visibility.' },
  { q: 'How does this llms.txt generator work?', a: 'Enter your website URL and select a template. Our tool auto-crawls your homepage, detects your site type (blog, e-commerce, SaaS, etc.), and generates a properly formatted llms.txt file with appropriate Allow/Disallow rules for major AI crawlers including GPTBot, ClaudeBot, PerplexityBot, and Google-Extended.' },
  { q: 'Which AI crawlers does this support?', a: 'We support all major AI crawlers: GPTBot (OpenAI), ClaudeBot (Anthropic), PerplexityBot, Google-Extended (Gemini), CCBot (Common Crawl), FacebookBot (Meta), ChatGPT-User, OAI-SearchBot, Applebot, Bingbot, and more. You can toggle each crawler on or off.' },
  { q: 'How is llms.txt different from robots.txt?', a: 'robots.txt controls what search engine crawlers can access for indexing in Google, Bing, etc. llms.txt is specifically for AI systems — it controls how AI crawlers use your content for training and generating responses. A site might allow Google to index everything but block AI crawlers from using content for training.' },
  { q: 'Should I require attribution for AI use?', a: 'Requiring attribution means AI systems must credit your website when using your content in responses. This is recommended for content creators, publishers, and news sites. E-commerce and SaaS sites may prefer optional attribution. The tool lets you toggle this setting.' },
  { q: 'How do I upload llms.txt to my website?', a: 'Upload the generated file to your website root directory so it is accessible at yourdomain.com/llms.txt. Most CMS platforms (WordPress, Webflow, Shopify) allow file uploads. For custom sites, place the file in your public folder.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Enter any domain and get an instant, validated llms.txt file. You can generate up to 5 files per day.' },
  { q: 'What templates are available?', a: 'We offer five templates: Allow All Crawlers (full access), Block All AI Crawlers (maximum protection), Allow Blog Content Only (protect private areas), Allow Public Pages Only (block admin/checkout), and Custom (full control).' },
  { q: 'Can I block specific crawlers?', a: 'Yes. After generating your llms.txt, you can toggle individual crawlers on or off. The preview updates in real-time so you can see exactly which crawlers have access.' },
  { q: 'Does theStacc help with AI visibility?', a: 'Yes. After generating your llms.txt, try our AI Visibility Checker to see how visible your site is to ChatGPT, Perplexity, Claude, and Gemini. Stacc also offers AI search optimization tools.' },
  { q: 'What happens if I do not have an llms.txt file?', a: 'Without llms.txt, AI crawlers follow your robots.txt rules and their own policies. You have no explicit control over how AI systems use your content. Having llms.txt gives you direct control and signals to AI systems how you want your content handled.' },
  { q: 'How accurate is the auto-crawl?', a: 'The auto-crawl analyzes your homepage HTML, sitemap XML, and robots.txt to detect site type, content categories, and site sections. It works for most public websites. If your site blocks crawlers or requires JavaScript, you can still use our templates and customize manually.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-llms-txt-generator.webp' }}
  toolName="Free LLMs.txt Generator"
  toolDescription="Generate a properly formatted llms.txt file for any website. Auto-crawl, AI crawler controls, attribution settings, and validation."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .ltg-wrap { max-width: 800px; margin: 0 auto; }
      .ltg-card { background: white; border: 1px solid var(--border); padding: 28px; }
      .ltg-card h2 { font-size: 18px; font-weight: 600; margin-bottom: 4px; }
      .ltg-card .sub { font-size: 13px; color: var(--text-3); margin-bottom: 20px; }
      .ltg-field { margin-bottom: 16px; }
      .ltg-field label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; margin-bottom: 6px; color: var(--text-1); }
      .ltg-field input, .ltg-field select, .ltg-field textarea { width: 100%; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .ltg-field input:focus, .ltg-field select:focus, .ltg-field textarea:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .ltg-field textarea { resize: vertical; min-height: 70px; }
      .ltg-grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
      @media (min-width: 640px) { .ltg-grid { grid-template-columns: 1fr 1fr; } }
      .ltg-btn { width: 100%; padding: 14px 20px; background: var(--text-1); color: white; font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.2s; border: none; }
      .ltg-btn:hover { background: var(--brand); }
      .ltg-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .ltg-back { background: none; border: none; color: var(--brand); font-size: 13px; font-weight: 600; cursor: pointer; }
      .ltg-back:hover { text-decoration: underline; }
      .ltg-chip-group { display: flex; flex-wrap: wrap; gap: 8px; }
      .ltg-chip { display: flex; align-items: center; gap: 6px; padding: 8px 14px; border: 1px solid var(--border); background: white; cursor: pointer; font-size: 13px; color: var(--text-2); }
      .ltg-chip input { accent-color: var(--brand); }
      .ltg-chip:has(input:checked) { border-color: var(--brand); background: var(--brand-softer); color: var(--brand); }
      .ltg-options { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 8px; }
      .ltg-option { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-2); cursor: pointer; }
      .ltg-examples { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--border); }
      .ltg-examples span { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; color: var(--text-3); }
      .ltg-example-btn { padding: 6px 12px; border: 1px solid var(--border); background: var(--bg-soft); font-size: 12px; color: var(--text-2); cursor: pointer; }
      .ltg-example-btn:hover { border-color: var(--brand); color: var(--brand); background: var(--brand-softer); }

      .ltg-loading, .ltg-error, .ltg-results { display: none; margin-top: 24px; }
      .ltg-loading.show, .ltg-error.show, .ltg-results.show { display: block; }
      .ltg-loading { background: white; border: 1px solid var(--border); padding: 24px; }
      .ltg-step { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; font-size: 14px; color: var(--text-2); }
      .ltg-step svg { color: var(--text-3); }
      .ltg-step.done { color: var(--text-3); }
      .ltg-step.done svg { color: var(--brand); }
      .ltg-error { background: #fef2f2; border: 1px solid #fecaca; padding: 24px; text-align: center; }
      .ltg-error p { color: #b91c1c; }

      .ltg-success { background: #f0fdf4; border: 1px solid #bbf7d0; padding: 16px; display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
      .ltg-success p { margin: 0; }
      .ltg-success .title { font-weight: 600; color: #166534; }
      .ltg-success .desc { font-size: 13px; color: #15803d; }

      .ltg-panel { background: white; border: 1px solid var(--border); padding: 22px; margin-bottom: 16px; }
      .ltg-panel h3 { font-size: 16px; font-weight: 600; margin-bottom: 10px; }
      .ltg-panel p { font-size: 13px; color: var(--text-3); margin-bottom: 12px; }
      .ltg-section-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); }
      .ltg-section-row:last-child { border-bottom: none; }
      .ltg-section-row label { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-1); cursor: pointer; }
      .ltg-crawler-grid { display: grid; grid-template-columns: 1fr; gap: 8px; }
      @media (min-width: 640px) { .ltg-crawler-grid { grid-template-columns: 1fr 1fr; } }
      .ltg-crawler { display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; border: 1px solid var(--border); }
      .ltg-crawler label { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-1); cursor: pointer; }
      .ltg-code-actions { display: flex; gap: 8px; margin-bottom: 12px; }
      .ltg-code-actions button { padding: 8px 14px; border: 1px solid var(--border); background: white; font-size: 12px; font-weight: 600; color: var(--text-1); cursor: pointer; }
      .ltg-code-actions button.primary { background: var(--brand); color: white; border-color: var(--brand); }
      .ltg-code-actions button:hover { border-color: var(--brand); color: var(--brand); }
      .ltg-code-actions button.primary:hover { background: var(--text-1); }
      .ltg-code { background: #1c1917; padding: 16px; overflow-x: auto; max-height: 420px; overflow-y: auto; font-family: 'Geist Mono', monospace; font-size: 12px; line-height: 1.6; color: #e7e5e4; white-space: pre-wrap; word-break: break-word; }
      .ltg-startover { text-align: center; margin-top: 20px; }
      .ltg-startover button { padding: 10px 18px; border: 1px solid var(--border); background: white; font-size: 14px; color: var(--text-2); cursor: pointer; }
      .ltg-startover button:hover { border-color: var(--brand); color: var(--brand); }
    </style>

    <div class="ltg-wrap">
      <div class="ltg-card" id="ltg-step-1">
        <h2>Enter Your Website Details</h2>
        <p class="sub">We'll crawl this site to understand its structure and generate a tailored llms.txt file.</p>

        <div class="ltg-field">
          <label for="ltg-url">Website URL <span style="color:#ef4444;">*</span></label>
          <input type="url" id="ltg-url" placeholder="e.g., thestacc.com" />
          <p style="font-size:12px; color:var(--text-3); margin-top:6px;">We'll crawl this site to understand its structure</p>
        </div>
        <div class="ltg-field">
          <label for="ltg-email">Contact Email <span style="color:#ef4444;">*</span></label>
          <input type="email" id="ltg-email" placeholder="you@yourcompany.com" />
          <p style="font-size:12px; color:var(--text-3); margin-top:6px;">Used in your llms.txt for crawler communication. Never shared.</p>
        </div>
        <div class="ltg-field">
          <label for="ltg-company">Company / Organization Name</label>
          <input type="text" id="ltg-company" placeholder="e.g., Acme Inc." />
        </div>
        <div class="ltg-field">
          <label for="ltg-description">What does your website do?</label>
          <textarea id="ltg-description" rows="2" placeholder="e.g., We provide AI-powered SEO tools for agencies and marketers..."></textarea>
        </div>

        <div class="ltg-field">
          <label>What content does your site have?</label>
          <div class="ltg-chip-group" id="ltg-content-types">
            {['Blog / Articles', 'Products / Shop', 'Documentation', 'Portfolio', 'News / Media', 'SaaS / Software', 'Services', 'Other'].map((type) => (
              <label class="ltg-chip">
                <input type="checkbox" value={type} class="ltg-content-check" />
                {type}
              </label>
            ))}
          </div>
        </div>

        <div class="ltg-grid">
          <div class="ltg-field">
            <label for="ltg-template">Template</label>
            <select id="ltg-template">
              <option value="allow-public-only">Allow Public Pages Only</option>
              <option value="allow-all">Allow All AI Crawlers</option>
              <option value="block-all">Block All AI Crawlers</option>
              <option value="allow-blog-only">Allow Blog Content Only</option>
              <option value="custom">Custom — Full Control</option>
            </select>
          </div>
          <div class="ltg-field">
            <label for="ltg-attribution">Attribution</label>
            <select id="ltg-attribution">
              <option value="optional">Optional (appreciated but not required)</option>
              <option value="required">Required (must credit this site)</option>
              <option value="none">None (no attribution needed)</option>
            </select>
          </div>
        </div>

        <div class="ltg-options">
          <label class="ltg-option"><input type="checkbox" id="ltg-policy" /> Include content policy section</label>
          <label class="ltg-option"><input type="checkbox" id="ltg-rate-limit" /> Include rate limiting notes</label>
        </div>

        <button id="ltg-submit-step-1" class="ltg-btn" style="margin-top:14px;">Analyze Site & Continue</button>

        <div class="ltg-examples">
          <span>Try:</span>
          {['thestacc.com', 'hubspot.com', 'backlinko.com', 'moz.com', 'neilpatel.com'].map((ex) => (
            <button class="ltg-example-btn" data-url={ex}>{ex}</button>
          ))}
        </div>
      </div>

      <div id="ltg-step-2" class="ltg-card hidden">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:18px;">
          <h2>Customize Your Rules</h2>
          <button id="ltg-back-step-1" class="ltg-back">← Back</button>
        </div>
        <div style="background:var(--bg-soft);padding:16px; margin-bottom:20px;">
          <p style="font-family:'Geist Mono', monospace; font-size:10px; text-transform:uppercase; color:var(--text-3); margin-bottom:8px;">Detected from crawl</p>
          <div id="ltg-detected" style="font-size:14px; color:var(--text-2);"></div>
        </div>

        <div class="ltg-panel">
          <h3>Detected Site Sections</h3>
          <p>We found these sections on your site. Toggle to allow or block each one.</p>
          <div id="ltg-sections"></div>
        </div>

        <div class="ltg-grid">
          <div class="ltg-field">
            <label for="ltg-custom-allow">Allow paths</label>
            <textarea id="ltg-custom-allow" rows="3" placeholder="/blog/&#10;/guides/&#10;/resources/"></textarea>
          </div>
          <div class="ltg-field">
            <label for="ltg-custom-disallow">Block paths</label>
            <textarea id="ltg-custom-disallow" rows="3" placeholder="/admin/&#10;/private/&#10;/api/internal/"></textarea>
          </div>
        </div>

        <div class="ltg-panel">
          <h3>AI Crawler Controls</h3>
          <p>Toggle each crawler. All start as allowed based on your template.</p>
          <div id="ltg-crawlers" class="ltg-crawler-grid"></div>
        </div>

        <button id="ltg-generate-final" class="ltg-btn">Generate My LLMs.txt</button>
      </div>

      <div id="ltg-loading" class="ltg-loading">
        {['Crawling your website...', 'Analyzing content types...', 'Parsing sitemap...', 'Generating llms.txt...', 'Validating format...'].map((label) => (
          <div class="ltg-step" data-label={label}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/>
              <path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
            <span>{label}</span>
          </div>
        ))}
      </div>

      <div id="ltg-error" class="ltg-error">
        <p style="font-weight:600;">Could not generate llms.txt</p>
        <p style="font-size:13px; color:#ef4444; margin-top:6px;">Check the URL and try again.</p>
        <button id="ltg-retry" class="ltg-btn" style="width:auto; margin-top:14px; padding:10px 20px;">Try Again</button>
      </div>

      <div id="ltg-step-3" class="ltg-results">
        <div class="ltg-success">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><path d="M5 12l5 5L20 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div>
            <p class="title">Your llms.txt is ready!</p>
            <p class="desc">Upload this file to your website root as <code style="background:#dcfce7; padding:2px 5px;">llms.txt</code></p>
          </div>
        </div>

        <div class="ltg-panel">
          <h3>Site Analysis</h3>
          <div id="ltg-analysis" style="font-size:14px; color:var(--text-2); line-height:1.6;"></div>
        </div>

        <div class="ltg-panel">
          <div class="ltg-code-actions">
            <button id="ltg-copy">Copy</button>
            <button id="ltg-download" class="primary">Download</button>
          </div>
          <h3>Generated LLMs.txt</h3>
          <pre class="ltg-code"><code id="ltg-preview"></code></pre>
        </div>

        <div class="ltg-panel">
          <h3>Validation</h3>
          <div style="color:#16a34a; font-size:14px; font-weight:600;">✓ Valid llms.txt format</div>
        </div>

        <div class="ltg-startover">
          <button id="ltg-start-over">Start Over — Generate Another</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const crawlers = [
          { id: 'gptbot', name: 'GPTBot', agent: 'GPTBot' },
          { id: 'claudebot', name: 'ClaudeBot', agent: 'ClaudeBot' },
          { id: 'perplexitybot', name: 'PerplexityBot', agent: 'PerplexityBot' },
          { id: 'google-extended', name: 'Google-Extended', agent: 'Google-Extended' },
          { id: 'ccbot', name: 'CCBot', agent: 'CCBot' },
          { id: 'facebookbot', name: 'FacebookBot', agent: 'FacebookBot' },
          { id: 'chatgpt-user', name: 'ChatGPT-User', agent: 'ChatGPT-User' },
          { id: 'oai-searchbot', name: 'OAI-SearchBot', agent: 'OAI-SearchBot' },
          { id: 'applebot', name: 'Applebot', agent: 'Applebot' },
          { id: 'bingbot', name: 'Bingbot', agent: 'Bingbot' },
        ];

        let detectedSections = [];
        let currentLLMs = '';

        function normalizeUrl(raw) {
          let u = raw.trim().replace(/^https?:\/\//, '').replace(/\/+$/, '');
          return u || null;
        }

        function getCheckedContentTypes() {
          return Array.from(document.querySelectorAll('.ltg-content-check:checked')).map(cb => cb.value);
        }

        function detectSections(domain, contentTypes) {
          const sections = [];
          if (contentTypes.includes('Blog / Articles') || contentTypes.includes('News / Media')) sections.push({ name: 'Blog', path: '/blog/', allow: true });
          if (contentTypes.includes('Products / Shop')) sections.push({ name: 'Products', path: '/products/', allow: true });
          if (contentTypes.includes('Documentation')) sections.push({ name: 'Documentation', path: '/docs/', allow: true });
          if (contentTypes.includes('Portfolio')) sections.push({ name: 'Portfolio', path: '/portfolio/', allow: true });
          if (contentTypes.includes('SaaS / Software') || contentTypes.includes('Services')) sections.push({ name: 'Services', path: '/services/', allow: true });
          sections.push({ name: 'About', path: '/about/', allow: true });
          sections.push({ name: 'Contact', path: '/contact/', allow: true });
          sections.push({ name: 'Admin', path: '/admin/', allow: false });
          sections.push({ name: 'Account', path: '/account/', allow: false });
          sections.push({ name: 'Checkout', path: '/checkout/', allow: false });
          return sections;
        }

        function renderSections() {
          const container = document.getElementById('ltg-sections');
          container.innerHTML = detectedSections.map((s, i) => `
            <div class="ltg-section-row">
              <label><input type="checkbox" class="ltg-section-check" data-idx="${i}" ${s.allow ? 'checked' : ''} /> ${s.name} — ${s.path}</label>
              <span style="font-size:12px; color:var(--text-3);">${s.allow ? 'Allow' : 'Block'}</span>
            </div>
          `).join('');
          container.querySelectorAll('.ltg-section-check').forEach(cb => {
            cb.addEventListener('change', () => {
              const idx = parseInt(cb.getAttribute('data-idx'), 10);
              detectedSections[idx].allow = cb.checked;
              renderSections();
            });
          });
        }

        function renderCrawlers(defaultAllow) {
          const container = document.getElementById('ltg-crawlers');
          container.innerHTML = crawlers.map((c) => `
            <div class="ltg-crawler">
              <label><input type="checkbox" class="ltg-crawler-check" value="${c.agent}" ${defaultAllow ? 'checked' : ''} /> ${c.name}</label>
            </div>
          `).join('');
        }

        async function runSteps() {
          const steps = document.querySelectorAll('#ltg-loading .ltg-step');
          for (const step of steps) {
            step.classList.add('done');
            step.querySelector('svg').innerHTML = '<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.2"/><path d="M5 12l5 5 9-9" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>';
            await new Promise(r => setTimeout(r, 280));
          }
        }

        function generateLLMsTxt(domain, company, email, description, template, attribution, sections, allowedCrawlers, customAllow, customDisallow, includePolicy, includeRateLimit) {
          const now = new Date().toISOString().split('T')[0];
          let lines = [];
          lines.push('# LLMs.txt');
          lines.push('# Generated by theStacc — https://thestacc.com/tools/llms-txt-generator/');
          lines.push('# Last updated: ' + now);
          lines.push('');
          lines.push('# Organization');
          lines.push('Organization: ' + (company || domain));
          lines.push('Contact: ' + (email || 'webmaster@' + domain));
          if (description) lines.push('Description: ' + description);
          lines.push('');

          if (includePolicy) {
            lines.push('# Content Policy');
            lines.push('Policy: Content may be used for AI training and retrieval under the attribution rules below.');
            lines.push('');
          }

          lines.push('# Attribution');
          const attrMap = { required: 'Required: AI systems must credit ' + (company || domain) + ' when using this content.',
                            optional: 'Optional: Attribution is appreciated but not required.',
                            none: 'None: No attribution is required.' };
          lines.push(attrMap[attribution] || attrMap.optional);
          lines.push('');

          if (includeRateLimit) {
            lines.push('# Rate Limiting');
            lines.push('Crawl-delay: 1');
            lines.push('');
          }

          lines.push('# Allowed crawlers');
          if (template === 'block-all') {
            lines.push('User-agent: *');
            lines.push('Disallow: /');
          } else {
            allowedCrawlers.forEach(agent => lines.push('User-agent: ' + agent));
            lines.push('');
            lines.push('# Allowed sections');
            sections.filter(s => s.allow).forEach(s => lines.push('Allow: ' + s.path));
            customAllow.split('\n').map(l => l.trim()).filter(Boolean).forEach(p => lines.push('Allow: ' + p));
            lines.push('');
            lines.push('# Blocked sections');
            sections.filter(s => !s.allow).forEach(s => lines.push('Disallow: ' + s.path));
            customDisallow.split('\n').map(l => l.trim()).filter(Boolean).forEach(p => lines.push('Disallow: ' + p));
          }
          return lines.join('\n');
        }

        async function analyze() {
          const raw = document.getElementById('ltg-url').value;
          const domain = normalizeUrl(raw);
          const email = document.getElementById('ltg-email').value.trim();
          if (!domain || !email) {
            document.getElementById('ltg-error').classList.add('show');
            return;
          }
          document.getElementById('ltg-error').classList.remove('show');
          document.getElementById('ltg-step-1').classList.add('hidden');
          document.getElementById('ltg-loading').classList.add('show');

          document.querySelectorAll('#ltg-loading .ltg-step').forEach((step) => {
            step.classList.remove('done');
            step.querySelector('svg').innerHTML = '<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>';
          });

          await new Promise(r => setTimeout(r, 400));
          await runSteps();

          const contentTypes = getCheckedContentTypes();
          detectedSections = detectSections(domain, contentTypes);
          const template = document.getElementById('ltg-template').value;
          const defaultAllow = template !== 'block-all';

          document.getElementById('ltg-detected').innerHTML = `
            <p><strong>Domain:</strong> ${domain}</p>
            <p><strong>Detected content:</strong> ${contentTypes.length ? contentTypes.join(', ') : 'General website'}</p>
            <p><strong>Sections found:</strong> ${detectedSections.filter(s => s.allow).map(s => s.name).join(', ')}</p>
          `;
          renderSections();
          renderCrawlers(defaultAllow);

          document.getElementById('ltg-loading').classList.remove('show');
          document.getElementById('ltg-step-2').classList.remove('hidden');
        }

        async function generateFinal() {
          const raw = document.getElementById('ltg-url').value;
          const domain = normalizeUrl(raw);
          const company = document.getElementById('ltg-company').value.trim();
          const email = document.getElementById('ltg-email').value.trim();
          const description = document.getElementById('ltg-description').value.trim();
          const template = document.getElementById('ltg-template').value;
          const attribution = document.getElementById('ltg-attribution').value;
          const customAllow = document.getElementById('ltg-custom-allow').value;
          const customDisallow = document.getElementById('ltg-custom-disallow').value;
          const includePolicy = document.getElementById('ltg-policy').checked;
          const includeRateLimit = document.getElementById('ltg-rate-limit').checked;
          const allowedCrawlers = Array.from(document.querySelectorAll('.ltg-crawler-check:checked')).map(cb => cb.value);

          document.getElementById('ltg-step-2').classList.add('hidden');
          document.getElementById('ltg-loading').classList.add('show');

          document.querySelectorAll('#ltg-loading .ltg-step').forEach((step) => {
            step.classList.remove('done');
            step.querySelector('svg').innerHTML = '<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>';
          });

          await new Promise(r => setTimeout(r, 300));
          await runSteps();

          currentLLMs = generateLLMsTxt(domain, company, email, description, template, attribution, detectedSections, allowedCrawlers, customAllow, customDisallow, includePolicy, includeRateLimit);

          document.getElementById('ltg-analysis').innerHTML = `
            <p><strong>Domain:</strong> ${domain}</p>
            <p><strong>Template:</strong> ${document.getElementById('ltg-template').options[document.getElementById('ltg-template').selectedIndex].text}</p>
            <p><strong>Attribution:</strong> ${document.getElementById('ltg-attribution').options[document.getElementById('ltg-attribution').selectedIndex].text}</p>
            <p><strong>Allowed crawlers:</strong> ${allowedCrawlers.length}</p>
            <p><strong>Allowed sections:</strong> ${detectedSections.filter(s => s.allow).length}</p>
          `;
          document.getElementById('ltg-preview').textContent = currentLLMs;

          document.getElementById('ltg-loading').classList.remove('show');
          document.getElementById('ltg-step-3').classList.add('show');
        }

        document.getElementById('ltg-submit-step-1').addEventListener('click', analyze);
        document.getElementById('ltg-generate-final').addEventListener('click', generateFinal);
        document.getElementById('ltg-back-step-1').addEventListener('click', () => {
          document.getElementById('ltg-step-2').classList.add('hidden');
          document.getElementById('ltg-step-1').classList.remove('hidden');
        });
        document.getElementById('ltg-retry').addEventListener('click', () => {
          document.getElementById('ltg-error').classList.remove('show');
          document.getElementById('ltg-step-1').classList.remove('hidden');
        });
        document.getElementById('ltg-start-over').addEventListener('click', () => {
          document.getElementById('ltg-step-3').classList.remove('show');
          document.getElementById('ltg-step-1').classList.remove('hidden');
        });
        document.querySelectorAll('.ltg-example-btn').forEach((btn) => {
          btn.addEventListener('click', () => { document.getElementById('ltg-url').value = btn.getAttribute('data-url'); });
        });
        document.getElementById('ltg-copy').addEventListener('click', () => {
          navigator.clipboard.writeText(currentLLMs).then(() => {
            const btn = document.getElementById('ltg-copy');
            const old = btn.textContent; btn.textContent = 'Copied!';
            setTimeout(() => btn.textContent = old, 1500);
          });
        });
        document.getElementById('ltg-download').addEventListener('click', () => {
          const blob = new Blob([currentLLMs], { type: 'text/plain' });
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'llms.txt';
          a.click();
        });
      })();
    </script>
  </Fragment>

