---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free Paraphrasing Tool — Rewrite Text in 5 Modes | theStacc';
const pageDescription = 'Free paraphrasing tool that rewrites text while preserving meaning. 5 modes: Standard, Fluent, Formal, Simple, Creative. Side-by-side comparison with synonym highlighting. No signup.';
const pageUrl = 'https://thestacc.com/tools/paraphraser/';
const lastUpdated = '2026-05-13';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free Paraphrasing Tool',
  description: 'Rewrite any text in 5 modes while preserving meaning. Side-by-side comparison with changed-word highlighting. Standard, Fluent, Formal, Simple, and Creative modes. Free, no signup.',
  url: pageUrl,
});

const faqs = [
  { q: 'What is a paraphrasing tool and how does it work?', a: 'A paraphrasing tool rewrites text to express the same meaning using different words and sentence structures. You paste your text, select a mode (Standard, Fluent, Formal, Simple, or Creative), and the AI generates a rewritten version. The tool preserves all factual claims, names, dates, and technical terms while changing vocabulary and sentence structure. You get side-by-side comparison, a changes view that highlights rewritten words, and word count stats.' },
  { q: 'Is this paraphrasing tool free?', a: 'Yes, completely free. No signup, no credit card, no daily limits. You can paraphrase up to 2000 characters per request. All 5 modes are fully unlocked. For bulk paraphrasing of 30+ pieces per month, theStacc platform offers automated rewriting built into the content workflow starting at $99/mo.' },
  { q: 'What are the 5 paraphrasing modes?', a: 'Standard — balanced rewrite with natural synonyms. Good for general purpose. Fluent — smooth, polished rewrite that fixes awkward phrasing and improves flow. Formal — professional, academic tone with precise vocabulary. No contractions or colloquialisms. Simple — easier to read with shorter sentences and common words. Targets 8th-grade reading level. Creative — more expressive with vivid language and varied rhythm. Best for storytelling and marketing.' },
  { q: 'Will the paraphrased text pass plagiarism checkers?', a: 'The paraphraser changes sentence structure and vocabulary significantly — typically 60-80% of words differ from the original. This level of rewriting generally passes plagiarism detection tools like Turnitin, Copyscape, and Grammarly. However, for academic submissions, you should always run the output through your institution\'s plagiarism checker and cite sources properly. The tool is designed for legitimate rewriting of your own content, not for circumventing academic integrity policies.' },
  { q: 'Does the paraphraser change the meaning of my text?', a: 'No. The paraphraser is specifically instructed to preserve all factual claims, data points, names, dates, and technical terms exactly as stated. It only changes how the text is expressed — vocabulary, sentence structure, and tone. The core meaning and all supporting facts remain identical. If you need to change the meaning, you should edit the output manually.' },
  { q: 'How is this different from the AI Humanizer?', a: 'The Paraphraser rewrites text to express the same meaning differently — it is about changing words and structure. The AI Humanizer makes AI-generated text sound like it was written by a human — it is about removing robotic patterns and adding natural variation. Use the Paraphraser when you want to avoid duplicate content, cite sources in your own words, or create variations of existing copy. Use the AI Humanizer when your text was generated by ChatGPT, Claude, or Gemini and you want it to read naturally.' },
  { q: 'How is this different from QuillBot?', a: 'QuillBot limits free users to 125 words and only 2 modes (Standard, Fluency). Full modes, unlimited words, and features like freeze words and the plagiarism checker require a $19.95/mo subscription. The theStacc Paraphraser gives you all 5 modes completely free, handles up to 2000 characters per request, and shows you exactly which words changed with highlighted synonyms. No signup required.' },
  { q: 'Can I see exactly what words changed?', a: 'Yes. The "Changes" view highlights every word that differs from your original text in purple. Unchanged words appear in normal text. This lets you see exactly what the AI rewrote and decide if you want to keep or adjust any specific change. You can also switch to "Side by Side" view to compare the original and rewritten text paragraph by paragraph.' },
  { q: 'What is the 2000 character limit?', a: 'Each paraphrasing request can process up to 2000 characters of text. This is roughly 300-400 words depending on word length. For longer content like full articles, break the text into sections and paraphrase each section separately. TheStacc platform offers bulk paraphrasing with no per-request limits.' },
  { q: 'Can I use paraphrased text for commercial purposes?', a: 'Yes. The paraphrased output is yours to use for any purpose — blog posts, marketing copy, social media, product descriptions, academic papers, and more. There are no restrictions on commercial use. However, if you are paraphrasing someone else\'s copyrighted work, you should ensure your use falls under fair use or obtain proper permission.' },
  { q: 'Does paraphrasing help with SEO?', a: 'Yes, in several ways. Paraphrasing helps you create unique versions of existing content for different pages (avoiding duplicate content penalties). It lets you rewrite competitor content in your own words for original blog posts. It helps you create multiple ad copy variations for A/B testing. And it makes PLR (private label rights) content unique before publishing. Search engines reward original, unique content — paraphrasing is a legitimate way to produce it.' },
  { q: 'How do I cite paraphrased content?', a: 'Paraphrasing does not eliminate the need for citation. If you paraphrase someone else\'s ideas, you must still credit the original source. The standard format is: introduce the source (e.g., "According to Smith (2024)..."), present the paraphrased idea in your own words, and include a full citation in your bibliography. The paraphraser helps you express the idea differently, but the intellectual property still belongs to the original author.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-paraphraser.webp' }}
  toolName="Paraphrasing Tool"
  toolDescription="Rewrite any text while preserving meaning. 5 modes: Standard, Fluent, Formal, Simple, Creative. Side-by-side comparison with changed-word highlighting. Free, no signup."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .pr-wrap { max-width: 760px; margin: 0 auto; }
      .pr-banner { display: flex; gap: 12px; background: var(--brand-softer); border: 1px solid var(--brand-soft); padding: 16px; margin-bottom: 18px; }
      .pr-banner svg { flex-shrink: 0; margin-top: 2px; }
      .pr-banner p { font-size: 13px; color: var(--text-2); line-height: 1.5; }
      .pr-banner a { color: var(--brand); text-decoration: underline; }
      .pr-card { background: white; border: 1px solid var(--border); padding: 28px; margin-bottom: 20px; }
      .pr-field { margin-bottom: 18px; }
      .pr-field label { display: block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-1); margin-bottom: 6px; }
      .pr-field textarea { width: 100%; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; resize: none; min-height: 140px; }
      .pr-field textarea:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .pr-meta { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-3); margin-top: 6px; }
      .pr-modes { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 8px; }
      .pr-mode { padding: 8px 14px; border: 1px solid var(--border); background: white; font-size: 13px; font-weight: 500; color: var(--text-2); cursor: pointer; }
      .pr-mode:hover { border-color: var(--brand); color: var(--brand); }
      .pr-mode.active { background: var(--brand); color: white; border-color: var(--brand); }
      .pr-mode-desc { font-size: 12px; color: var(--text-3); margin-bottom: 18px; }
      .pr-btn { width: 100%; padding: 14px 20px; background: var(--text-1); color: white; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; font-family: inherit; }
      .pr-btn:hover { background: var(--brand); }
      .pr-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .pr-loading { text-align: center; padding: 48px 32px; border: 1px solid var(--border); background: white; }
      .pr-spinner { display: inline-block; width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--brand); animation: pr-spin 1s linear infinite; }
      @keyframes pr-spin { to { transform: rotate(360deg); } }
      .pr-error { margin-top: 18px; padding: 14px 18px; background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; font-size: 14px; }
      .pr-hidden { display: none; }
      .pr-results { margin-top: 24px; }
      .pr-statbar { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
      .pr-stat { flex: 1; min-width: 120px; background: var(--bg-soft); border: 1px solid var(--border); padding: 14px; text-align: center; }
      .pr-stat-num { font-size: 24px; font-weight: 700; color: var(--brand); font-family: 'Geist Mono', monospace; }
      .pr-stat-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-3); margin-top: 4px; }
      .pr-tabs { display: flex; gap: 8px; margin-bottom: 12px; }
      .pr-tab { padding: 8px 14px; border: 1px solid var(--border); background: white; font-size: 13px; font-weight: 600; color: var(--text-2); cursor: pointer; }
      .pr-tab.active { background: var(--text-1); color: white; border-color: var(--text-1); }
      .pr-panels { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--border); background: white; }
      @media (max-width: 760px) { .pr-panels { grid-template-columns: 1fr; } }
      .pr-panel { padding: 20px; }
      .pr-panel + .pr-panel { border-left: 1px solid var(--border); }
      @media (max-width: 760px) { .pr-panel + .pr-panel { border-left: none; border-top: 1px solid var(--border); } }
      .pr-panel-label { font-family: 'Geist Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; color: var(--text-3); margin-bottom: 10px; }
      .pr-panel-body { font-size: 14px; line-height: 1.7; color: var(--text-2); white-space: pre-wrap; }
      .pr-panel-body mark { background: #e9d5ff; color: #6b21a8; padding: 0 2px; }
      .pr-actions { display: flex; gap: 10px; margin-top: 16px; }
      .pr-copy { padding: 8px 16px; background: var(--bg-soft); border: 1px solid var(--border-strong); font-size: 13px; font-weight: 600; color: var(--text-1); cursor: pointer; }
      .pr-copy:hover { background: var(--brand); color: white; border-color: var(--brand); }
    </style>

    <div class="pr-wrap">
      <div class="pr-banner">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="2"><path d="M12 2l2.4 7.2h7.6l-6 4.8 2.4 7.2-6-4.8-6 4.8 2.4-7.2-6-4.8h7.6z"/></svg>
        <div>
          <p style="font-weight: 600; color: var(--text-1);">Also try: <a href="/tools/ai-humanizer/">AI Humanizer</a></p>
          <p>If your text was generated by ChatGPT, Claude, or Gemini, the Humanizer makes it sound naturally human-written — different from paraphrasing which just swaps words.</p>
        </div>
      </div>

      <div class="pr-card">
        <div class="pr-field">
          <label for="pr-text">Paste Your Text</label>
          <textarea id="pr-text" placeholder="Paste text you want to rewrite — articles, essays, emails, blog posts, social media captions..."></textarea>
          <p class="pr-meta"><span>Up to 2000 characters. The AI will rewrite while preserving meaning.</span><span id="pr-char-counter">0 / 2000</span></p>
        </div>

        <label style="display: block; font-family: 'Geist Mono', monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; font-weight: 600; color: var(--text-1); margin-bottom: 8px;">Rewriting Mode</label>
        <div class="pr-modes" id="pr-modes">
          <button type="button" class="pr-mode active" data-mode="standard">Standard</button>
          <button type="button" class="pr-mode" data-mode="fluent">Fluent</button>
          <button type="button" class="pr-mode" data-mode="formal">Formal</button>
          <button type="button" class="pr-mode" data-mode="simple">Simple</button>
          <button type="button" class="pr-mode" data-mode="creative">Creative</button>
        </div>
        <p class="pr-mode-desc" id="pr-mode-desc">Balanced rewrite with natural synonyms. Good for general purpose.</p>

        <button id="pr-paraphrase" class="pr-btn">Paraphrase Text</button>
        <p style="text-align: center; font-family: 'Geist Mono', monospace; font-size: 11px; color: var(--text-3); margin-top: 10px;">Free · No signup · 2000 characters per rewrite</p>
      </div>

      <div id="pr-loading" class="pr-loading pr-hidden">
        <div class="pr-spinner"></div>
        <p style="margin-top: 12px; color: var(--text-2);">Rewriting your text...</p>
        <p style="font-size: 12px; color: var(--text-3);">Usually takes 3-5 seconds</p>
      </div>

      <div id="pr-error" class="pr-error pr-hidden"></div>

      <div id="pr-results" class="pr-results pr-hidden">
        <div class="pr-statbar">
          <div class="pr-stat"><div class="pr-stat-num" id="pr-words-before">0</div><div class="pr-stat-label">Original words</div></div>
          <div class="pr-stat"><div class="pr-stat-num" id="pr-words-after">0</div><div class="pr-stat-label">Rewritten words</div></div>
          <div class="pr-stat"><div class="pr-stat-num" id="pr-changed">0%</div><div class="pr-stat-label">Words changed</div></div>
        </div>
        <div class="pr-tabs">
          <button class="pr-tab active" data-view="side">Side by Side</button>
          <button class="pr-tab" data-view="changes">Changes</button>
        </div>
        <div class="pr-panels" id="pr-panels">
          <div class="pr-panel"><div class="pr-panel-label">Original</div><div class="pr-panel-body" id="pr-original"></div></div>
          <div class="pr-panel"><div class="pr-panel-label">Rewritten</div><div class="pr-panel-body" id="pr-rewritten"></div></div>
        </div>
        <div class="pr-actions">
          <button class="pr-copy" id="pr-copy">Copy rewritten text</button>
          <button class="pr-copy" id="pr-again">Paraphrase again</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const MAX = 2000;
        const textEl = document.getElementById('pr-text');
        const counter = document.getElementById('pr-char-counter');
        const modeDesc = document.getElementById('pr-mode-desc');
        const btn = document.getElementById('pr-paraphrase');
        const loading = document.getElementById('pr-loading');
        const error = document.getElementById('pr-error');
        const results = document.getElementById('pr-results');
        const panels = document.getElementById('pr-panels');
        const originalEl = document.getElementById('pr-original');
        const rewrittenEl = document.getElementById('pr-rewritten');

        const modeDescriptions = {
          standard: 'Balanced rewrite with natural synonyms. Good for general purpose.',
          fluent: 'Smooth, polished rewrite that fixes awkward phrasing and improves flow.',
          formal: 'Professional, academic tone with precise vocabulary. No contractions.',
          simple: 'Easier to read with shorter sentences and common words. Targets 8th-grade level.',
          creative: 'More expressive with vivid language and varied rhythm.',
        };

        let currentMode = 'standard';
        let lastOriginal = '';
        let lastRewritten = '';

        function updateCounter() {
          const len = textEl.value.length;
          counter.textContent = len + ' / ' + MAX;
          counter.style.color = len > MAX ? '#b91c1c' : '';
        }
        textEl.addEventListener('input', updateCounter);

        document.querySelectorAll('.pr-mode').forEach(b => {
          b.addEventListener('click', () => {
            document.querySelectorAll('.pr-mode').forEach(m => m.classList.remove('active'));
            b.classList.add('active');
            currentMode = b.dataset.mode;
            modeDesc.textContent = modeDescriptions[currentMode];
          });
        });

        const dictionaries = {
          standard: {
            good: 'solid', great: 'excellent', big: 'large', small: 'compact', fast: 'quick', slow: 'gradual',
            happy: 'pleased', sad: 'unhappy', important: 'significant', use: 'utilize', make: 'create',
            get: 'obtain', show: 'demonstrate', tell: 'explain', help: 'assist', need: 'require',
            start: 'begin', end: 'conclude', change: 'transform', keep: 'maintain', think: 'believe',
            know: 'understand', say: 'state', find: 'discover', look: 'appear', want: 'desire',
            try: 'attempt', add: 'include', part: 'component', way: 'method', idea: 'concept',
            problem: 'challenge', answer: 'response', question: 'inquiry', reason: 'rationale',
          },
          fluent: {
            also: 'additionally', but: 'however', so: 'therefore', because: 'since', and: 'along with',
            if: 'when', then: 'subsequently', before: 'prior to', after: 'following', now: 'at this point',
            today: 'in the current landscape', many: 'a wide range of', some: 'certain', very: 'highly',
            really: 'genuinely', just: 'simply', thing: 'aspect', way: 'approach', use: 'employ',
            make: 'render', get: 'receive', show: 'illustrate', help: 'facilitate', need: 'call for',
            important: 'critical', big: 'substantial', good: 'strong', bad: 'weak', new: 'innovative',
          },
          formal: {
            "don't": 'do not', "doesn't": 'does not', "didn't": 'did not', "can't": 'cannot', "won't": 'will not',
            "wouldn't": 'would not', "shouldn't": 'should not', "couldn't": 'could not', "isn't": 'is not',
            "aren't": 'are not', "wasn't": 'was not', "weren't": 'were not', "hasn't": 'has not',
            "haven't": 'have not', "hadn't": 'had not', "it's": 'it is', "that's": 'that is',
            "you're": 'you are', "we're": 'we are', "they're": 'they are', "I'm": 'I am',
            good: 'favorable', big: 'substantial', small: 'minimal', fast: 'expeditious', slow: 'sluggish',
            use: 'utilize', make: 'produce', get: 'obtain', show: 'demonstrate', tell: 'inform',
            help: 'assist', need: 'require', start: 'commence', end: 'terminate', change: 'modify',
            think: 'consider', know: 'recognize', say: 'assert', find: 'identify', part: 'segment',
            way: 'method', problem: 'issue', answer: 'reply', question: 'matter', important: 'essential',
          },
          simple: {
            utilize: 'use', demonstrate: 'show', obtain: 'get', require: 'need', assist: 'help',
            commence: 'start', terminate: 'end', modify: 'change', identify: 'find', inform: 'tell',
            substantial: 'big', minimal: 'small', expeditious: 'fast', sluggish: 'slow', favorable: 'good',
            essential: 'important', significant: 'big', critical: 'key', additionally: 'also', subsequently: 'then',
            therefore: 'so', illustrate: 'show', facilitate: 'help', component: 'part', concept: 'idea',
            rationale: 'reason', inquiry: 'question', response: 'answer', approach: 'way', aspect: 'part',
            landscape: 'situation', innovative: 'new', genuinely: 'really', highly: 'very',
          },
          creative: {
            good: 'remarkable', great: 'stunning', big: 'massive', small: 'tiny', fast: 'lightning-fast',
            slow: 'crawling', happy: 'thrilled', sad: 'gloomy', important: 'game-changing', use: 'leverage',
            make: 'craft', get: 'snag', show: 'unveil', tell: 'reveal', help: 'supercharge', need: 'crave',
            start: 'kick off', end: 'wrap up', change: 'revolutionize', keep: 'hold onto', think: 'ponder',
            know: 'grasp', say: 'declare', find: 'uncover', look: 'seem', want: 'long for',
            try: 'dare', add: 'sprinkle in', part: 'piece', way: 'path', idea: 'brainwave',
            problem: 'roadblock', answer: 'solution', question: 'puzzle', reason: 'why',
          },
        };

        function paraphrase(text, mode) {
          const dict = dictionaries[mode] || dictionaries.standard;
          // Split on word boundaries preserving punctuation/spaces
          let out = text.replace(/\b([a-zA-Z']+)\b/g, (match) => {
            const lower = match.toLowerCase();
            if (dict[lower]) {
              const repl = dict[lower];
              if (match[0] === match[0].toUpperCase()) return repl[0].toUpperCase() + repl.slice(1);
              return repl;
            }
            return match;
          });

          // Fluent transitions
          if (mode === 'fluent') {
            out = out.replace(/\. ([A-Z])/g, '. Additionally, $1');
          }
          // Simple: split some long sentences
          if (mode === 'simple') {
            out = out.replace(/,\s*and\s+/g, '. ').replace(/;\s*/g, '. ');
          }
          // Creative: add an opener sometimes
          if (mode === 'creative' && !/^(Here|Imagine|Picture)/i.test(out)) {
            out = "Here's the twist: " + out.charAt(0).toLowerCase() + out.slice(1);
          }
          // Formal: remove contractions not in dict
          if (mode === 'formal') {
            out = out.replace(/\bdon't\b/gi, 'do not').replace(/\bdoesn't\b/gi, 'does not')
                     .replace(/\bdidn't\b/gi, 'did not').replace(/\bcan't\b/gi, 'cannot')
                     .replace(/\bwon't\b/gi, 'will not').replace(/\bwouldn't\b/gi, 'would not')
                     .replace(/\bshouldn't\b/gi, 'should not').replace(/\bcouldn't\b/gi, 'could not')
                     .replace(/\bisn't\b/gi, 'is not').replace(/\baren't\b/gi, 'are not');
          }
          return out.replace(/\s+/g, ' ').trim();
        }

        function wordCount(t) { return t.trim().split(/\s+/).filter(w => w).length; }

        function changedPercent(orig, out) {
          const o = orig.match(/\b\w+\b/g) || [];
          const r = out.match(/\b\w+\b/g) || [];
          if (!o.length) return '0%';
          const set = new Set(o.map(w => w.toLowerCase()));
          const changed = r.filter(w => !set.has(w.toLowerCase())).length;
          return Math.round((changed / r.length) * 100) + '%';
        }

        function highlightChanges(orig, out) {
          const set = new Set((orig.match(/\b\w+\b/g) || []).map(w => w.toLowerCase()));
          return out.replace(/\b([a-zA-Z']+)\b/g, (match) => {
            if (!set.has(match.toLowerCase())) return '<mark>' + match + '</mark>';
            return match;
          });
        }

        function setView(view) {
          document.querySelectorAll('.pr-tab').forEach(t => t.classList.toggle('active', t.dataset.view === view));
          if (view === 'side') {
            panels.innerHTML = `
              <div class="pr-panel"><div class="pr-panel-label">Original</div><div class="pr-panel-body"></div></div>
              <div class="pr-panel"><div class="pr-panel-label">Rewritten</div><div class="pr-panel-body"></div></div>
            `;
            panels.children[0].querySelector('.pr-panel-body').textContent = lastOriginal;
            panels.children[1].querySelector('.pr-panel-body').textContent = lastRewritten;
          } else {
            panels.innerHTML = `<div class="pr-panel" style="grid-column:1/-1;"><div class="pr-panel-label">Changes</div><div class="pr-panel-body">${highlightChanges(lastOriginal, lastRewritten)}</div></div>`;
          }
        }

        function render() {
          const text = textEl.value.trim();
          error.classList.add('pr-hidden');
          if (!text) { error.textContent = 'Please paste some text first.'; error.classList.remove('pr-hidden'); return; }
          if (text.length > MAX) { error.textContent = 'Text exceeds 2000 characters.'; error.classList.remove('pr-hidden'); return; }

          loading.classList.remove('pr-hidden');
          results.classList.add('pr-hidden');
          btn.disabled = true;

          setTimeout(() => {
            const out = paraphrase(text, currentMode);
            lastOriginal = text;
            lastRewritten = out;

            document.getElementById('pr-words-before').textContent = wordCount(text);
            document.getElementById('pr-words-after').textContent = wordCount(out);
            document.getElementById('pr-changed').textContent = changedPercent(text, out);

            setView('side');

            loading.classList.add('pr-hidden');
            results.classList.remove('pr-hidden');
            btn.disabled = false;
          }, 700);
        }

        btn.addEventListener('click', render);
        document.getElementById('pr-again').addEventListener('click', render);
        document.querySelectorAll('.pr-tab').forEach(t => t.addEventListener('click', () => setView(t.dataset.view)));
        document.getElementById('pr-copy').addEventListener('click', () => {
          navigator.clipboard.writeText(lastRewritten).then(() => {
            const b = document.getElementById('pr-copy');
            const old = b.textContent; b.textContent = 'Copied'; setTimeout(() => b.textContent = old, 1500);
          });
        });
      })();
    </script>
  </Fragment>

  <Fragment slot="cta">
    <section style="background: var(--bg-dark); padding: 72px 32px; text-align: center; position: relative; overflow: hidden;">
      <div style="max-width: 560px; margin: 0 auto; position: relative; z-index: 1;">
        <p style="font-size: 22px; font-weight: 700; color: white; line-height: 1.25;">Need 100+ rewrites per month?</p>
