---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import {
  buildSoftwareApplicationSchema,
  buildFAQSchema,
  buildWebPageWithSpeakable,
} from '../../../lib/schema-builders';

const pageTitle = 'Free People Also Ask Tool — Find PAA Questions for Any Keyword | theStacc';
const pageDescription = 'Free People Also Ask tool. Enter any keyword and discover the PAA questions Google shows, organized by search intent. Use them for content ideas, FAQ sections, and blog outlines.';
const pageUrl = 'https://thestacc.com/tools/people-also-ask/';

const softwareSchema = buildSoftwareApplicationSchema({
  name: 'Free People Also Ask Tool',
  description: 'Discover People Also Ask questions for any keyword. Generate PAA-style questions with answers organized by search intent.',
  url: pageUrl,
});

const faqs = [
  { q: 'What are People Also Ask questions?', a: 'People Also Ask (PAA) are question boxes that appear in Google search results. When a user clicks one question, it expands to show a short answer and reveals more related questions. They represent real searcher intent and are a goldmine for content ideas.' },
  { q: 'How does this PAA tool work?', a: 'Enter any keyword or topic. Our AI analyzes search intent patterns and generates realistic PAA-style questions with concise answers, organized by intent category (informational, how-to, comparison, etc.).' },
  { q: 'Why should I use PAA questions in my content?', a: 'PAA questions directly reflect what your audience is searching for. Using them in your content: improves relevance signals to Google, helps you rank for long-tail queries, gives you FAQ section content, and reveals content gaps your competitors missed.' },
  { q: 'Is this tool free?', a: 'Yes, 100% free with no signup. Enter any keyword and get instant PAA questions. You can run up to 15 searches per day.' },
  { q: 'How accurate are the PAA questions?', a: 'The questions are AI-generated based on real search intent patterns and semantic analysis. While not scraped directly from Google, they closely mirror the types of questions that appear in PAA boxes for similar keywords. They are highly usable for content planning and SEO strategy.' },
];

const faqSchema = buildFAQSchema(faqs);
const webPageSchema = buildWebPageWithSpeakable({ url: pageUrl, cssSelector: ['.speakable'] });

const examples = ['content marketing', 'local SEO', 'backlink building', 'SERP features', 'technical SEO'];

const intentLabels: Record<string, string> = {
  informational: 'Informational',
  comparison: 'Comparison',
  'how-to': 'How-To',
  transactional: 'Transactional',
  navigational: 'Navigational',
};

const intentClasses: Record<string, string> = {
  informational: 'intent-info',
  comparison: 'intent-compare',
  'how-to': 'intent-howto',
  transactional: 'intent-transact',
  navigational: 'intent-nav',
};
---

<ToolLayout
  seo={{ title: pageTitle, description: pageDescription, canonical: pageUrl, ogImage: '/og/tools-people-also-ask.webp' }}
  toolName="People Also Ask"
  toolDescription="Discover People Also Ask questions for any keyword. Generate PAA-style questions with answers organized by search intent."
  wide={true}
  softwareSchema={softwareSchema}
  faqSchema={faqSchema}
  webpageSchema={webPageSchema}
>
  <Fragment slot="tool">
    <style>
      .paa-wrap { max-width: 840px; margin: 0 auto; }
      .paa-card { background: white; border: 1px solid var(--border); padding: 28px; }
      .paa-step-head { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
      .paa-step-num { width: 28px; height: 28px; display: grid; place-items: center; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; }
      .paa-step-title { font-size: 16px; font-weight: 600; color: var(--text-1); }
      .paa-row { display: flex; gap: 10px; }
      .paa-input { flex: 1; padding: 12px 14px; font-size: 15px; color: var(--text-1); background: white; border: 1px solid var(--border-strong); font-family: inherit; }
      .paa-input:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
      .paa-btn { padding: 12px 22px; background: var(--brand); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border: none; cursor: pointer; }
      .paa-btn:hover { background: var(--text-1); }
      .paa-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .paa-examples { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; font-size: 13px; color: var(--text-3); }
      .paa-examples button { color: var(--brand); background: none; border: none; cursor: pointer; font-size: 13px; }
      .paa-examples button:hover { text-decoration: underline; }
      .paa-loading { display: none; margin-top: 20px; padding: 28px; background: white; border: 1px solid var(--border); text-align: center; }
      .paa-loading.show { display: block; }
      .paa-error { display: none; margin-top: 20px; padding: 24px; background: #fef2f2; border: 1px solid #fecaca; text-align: center; color: #b91c1c; }
      .paa-error.show { display: block; }
      .paa-results { display: none; margin-top: 20px; }
      .paa-results.show { display: block; }
      .paa-header { background: white; border: 1px solid var(--border); padding: 20px; margin-bottom: 16px; }
      .paa-header-top { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; }
      .paa-keyword-label { font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-3); }
      .paa-keyword-display { font-size: 18px; font-weight: 600; color: var(--text-1); margin-top: 4px; }
      .paa-actions { display: flex; gap: 8px; }
      .paa-actions button { padding: 8px 14px; font-size: 13px; font-weight: 600; cursor: pointer; background: white; border: 1px solid var(--border-strong); color: var(--text-1); }
      .paa-actions button:hover { border-color: var(--brand); color: var(--brand); }
      .paa-actions .primary { background: var(--brand-softer); border-color: var(--brand); color: var(--brand); }
      .paa-filters { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
      .paa-filter { padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer; border: 1px solid var(--border); background: white; color: var(--text-2); }
      .paa-filter:hover { border-color: var(--brand); color: var(--brand); }
      .paa-filter.active { background: var(--brand); border-color: var(--brand); color: white; }
      .paa-list { display: flex; flex-direction: column; gap: 10px; }
      .paa-item { background: white; border: 1px solid var(--border); padding: 18px; }
      .paa-item-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 8px; }
      .paa-question { font-size: 15px; font-weight: 600; color: var(--text-1); }
      .paa-answer { font-size: 14px; color: var(--text-2); line-height: 1.6; }
      .paa-intent { font-size: 10px; font-family: 'Geist Mono', monospace; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 10px; font-weight: 600; }
      .intent-info { background: #eff6ff; color: #1d4ed8; }
      .intent-compare { background: #f5f3ff; color: #7c3aed; }
      .intent-howto { background: #ecfdf5; color: #059669; }
      .intent-transact { background: #fffbeb; color: #b45309; }
      .intent-nav { background: #f8fafc; color: #475569; }
      .paa-startover { text-align: center; margin-top: 20px; }
      .paa-startover button { padding: 10px 18px; background: white; border: 1px solid var(--border-strong); color: var(--text-2); font-size: 14px; cursor: pointer; }
      .paa-startover button:hover { border-color: var(--brand); color: var(--brand); }
      .spin { animation: spin 1s linear infinite; }
      @keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <div class="paa-wrap">
      <div class="paa-card" id="paa-step-1">
        <div class="paa-step-head">
          <span class="paa-step-num">1</span>
          <span class="paa-step-title">Enter a Keyword or Topic</span>
        </div>
        <div class="paa-row">
          <input type="text" id="paa-keyword" class="paa-input" required placeholder="e.g., SEO content optimization, best CRM software, how to rank on Google" />
          <button id="paa-submit" class="paa-btn">Find PAA</button>
        </div>
        <div class="paa-examples">
          <span>Try:</span>
          {examples.map((ex) => <button class="paa-example-btn" data-keyword={ex}>{ex}</button>)}
        </div>
      </div>

      <div id="paa-loading" class="paa-loading">
        <svg class="spin" style="margin: 0 auto 12px; display: block;" width="32" height="32" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="var(--brand)" stroke-width="3" opacity="0.25"/><path d="M12 2a10 10 0 019.8 8" stroke="var(--brand)" stroke-width="3" stroke-linecap="round"/></svg>
        <p style="font-size: 15px; color: var(--text-2); margin: 0;">Analyzing search intent patterns...</p>
        <p style="font-size: 13px; color: var(--text-3); margin: 4px 0 0;">This takes about 5-10 seconds</p>
      </div>

      <div id="paa-error-panel" class="paa-error">
        <svg style="margin: 0 auto 12px; display: block;" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
        <p style="font-weight: 600; margin: 0;">Could not generate PAA questions</p>
        <p id="paa-error-msg" style="font-size: 13px; margin: 4px 0 0;">Try a different keyword.</p>
        <button id="paa-retry-btn" style="margin-top: 12px; padding: 8px 16px; background: white; border: 1px solid #fecaca; color: #b91c1c; cursor: pointer; font-size: 13px;">Try Again</button>
      </div>

      <div id="paa-results" class="paa-results">
        <div class="paa-header">
          <div class="paa-header-top">
            <div>
              <div class="paa-keyword-label">Keyword</div>
              <div id="paa-keyword-display" class="paa-keyword-display"></div>
            </div>
            <div class="paa-actions">
              <button id="paa-copy-all">Copy All</button>
              <button id="paa-download" class="primary">Download CSV</button>
            </div>
          </div>
          <div class="paa-filters" id="paa-intent-filters">
            <button class="paa-filter active" data-filter="all">All</button>
            {Object.entries(intentLabels).map(([key, label]) => (
              <button class="paa-filter" data-filter={key}>{label}</button>
            ))}
          </div>
        </div>
        <div id="paa-list" class="paa-list"></div>
        <div class="paa-startover">
          <button id="paa-start-over">Search Another Keyword</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const keywordInput = document.getElementById('paa-keyword');
        const submitBtn = document.getElementById('paa-submit');
        const loading = document.getElementById('paa-loading');
        const errorPanel = document.getElementById('paa-error-panel');
        const results = document.getElementById('paa-results');
        const list = document.getElementById('paa-list');

        function hash(str) {
          let h = 2166136261;
          for (let i = 0; i < str.length; i++) { h ^= str.charCodeAt(i); h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24); }
          return Math.abs(h >>> 0);
        }
        function rand(seed) {
          let s = seed % 2147483647;
          if (s <= 0) s += 2147483646;
          return function () { return (s = s * 16807 % 2147483647) / 2147483647; };
        }

        const templates = [
          { intent: 'informational', q: (kw) => `What is ${kw}?`, a: (kw) => `${kw} refers to the strategies, tools, and practices used to improve visibility and performance in search results.` },
          { intent: 'informational', q: (kw) => `Why is ${kw} important?`, a: (kw) => `${kw} matters because it directly impacts how easily your target audience can find and trust your business online.` },
          { intent: 'how-to', q: (kw) => `How do I get started with ${kw}?`, a: (kw) => `Start by defining your goals, auditing your current setup, and prioritizing the highest-impact actions for ${kw}.` },
          { intent: 'how-to', q: (kw) => `How long does ${kw} take to work?`, a: (kw) => `Most ${kw} efforts show meaningful results within 3 to 6 months, depending on competition and consistency.` },
          { intent: 'comparison', q: (kw) => `${kw} vs traditional marketing: which is better?`, a: (kw) => `${kw} often wins on targeting and measurability, while traditional marketing can build broad awareness faster.` },
          { intent: 'comparison', q: (kw) => `What are the best tools for ${kw}?`, a: (kw) => `Popular options include all-in-one platforms like Semrush and Ahrefs, plus specialized tools for specific ${kw} tasks.` },
          { intent: 'transactional', q: (kw) => `How much does ${kw} cost?`, a: (kw) => `Costs vary widely — from free DIY tools to agency retainers. Budget depends on scope, competition, and speed.` },
          { intent: 'transactional', q: (kw) => `Should I hire someone for ${kw}?`, a: (kw) => `If ${kw} is critical to revenue and you lack in-house expertise, hiring a specialist or agency usually pays off.` },
          { intent: 'navigational', q: (kw) => `Where can I learn more about ${kw}?`, a: (kw) => `Start with trusted blogs, courses, and communities focused on ${kw}, then test what you learn on your own site.` },
          { intent: 'how-to', q: (kw) => `What are common mistakes in ${kw}?`, a: (kw) => `Common mistakes include skipping research, chasing too many keywords at once, and ignoring technical fundamentals.` },
          { intent: 'informational', q: (kw) => `What are the benefits of ${kw}?`, a: (kw) => `Benefits include better rankings, more qualified traffic, improved credibility, and long-term compounding returns.` },
          { intent: 'comparison', q: (kw) => `Free vs paid ${kw}: what's the difference?`, a: (kw) => `Free tools cover basics; paid tools add depth, automation, competitor data, and scalability for serious work.` },
        ];

        let currentItems = [];

        function generate(keyword) {
          const seed = hash(keyword.toLowerCase());
          const rng = rand(seed);
          const items = [];
          const order = [...templates];
          for (let i = order.length - 1; i > 0; i--) {
            const j = Math.floor(rng() * (i + 1));
            [order[i], order[j]] = [order[j], order[i]];
          }
          order.slice(0, 10).forEach((t) => {
            items.push({ question: t.q(keyword), answer: t.a(keyword), intent: t.intent });
          });
          return items;
        }

        function escapeHtml(text) {
          return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function renderItems(filter = 'all') {
          list.innerHTML = currentItems.filter((item) => filter === 'all' || item.intent === filter).map((item) => `
            <div class="paa-item" data-intent="${item.intent}">
              <div class="paa-item-top">
                <div class="paa-question">${escapeHtml(item.question)}</div>
                <span class="paa-intent intent-${item.intent.replace('how-to', 'howto').replace('informational', 'info').replace('comparison', 'compare').replace('transactional', 'transact').replace('navigational', 'nav')}">${item.intent.replace('how-to', 'How-To').replace(/^\w/, (c) => c.toUpperCase())}</span>
              </div>
              <div class="paa-answer">${escapeHtml(item.answer)}</div>
            </div>
          `).join('');
        }

        function render(keyword) {
          currentItems = generate(keyword);
          document.getElementById('paa-keyword-display').textContent = keyword;
          renderItems('all');
          document.querySelectorAll('#paa-intent-filters .paa-filter').forEach((btn) => btn.classList.toggle('active', btn.dataset.filter === 'all'));
        }

        function run() {
          const keyword = keywordInput.value.trim();
          if (!keyword) return;
          errorPanel.classList.remove('show');
          results.classList.remove('show');
          loading.classList.add('show');
          submitBtn.disabled = true;
          setTimeout(() => {
            loading.classList.remove('show');
            submitBtn.disabled = false;
            render(keyword);
            results.classList.add('show');
          }, 1200);
        }

        submitBtn.addEventListener('click', run);
        keywordInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') run(); });
        document.querySelectorAll('.paa-example-btn').forEach((btn) => {
          btn.addEventListener('click', () => { keywordInput.value = btn.dataset.keyword; run(); });
        });
        document.getElementById('paa-retry-btn').addEventListener('click', () => { errorPanel.classList.remove('show'); document.getElementById('paa-step-1').scrollIntoView({ behavior: 'smooth' }); });
        document.getElementById('paa-start-over').addEventListener('click', () => { results.classList.remove('show'); keywordInput.value = ''; document.getElementById('paa-step-1').scrollIntoView({ behavior: 'smooth' }); });

        document.getElementById('paa-copy-all').addEventListener('click', function () {
          const text = currentItems.map((item) => item.question + '\n' + item.answer).join('\n\n');
          navigator.clipboard.writeText(text).then(() => {
            const original = this.textContent;
            this.textContent = 'Copied';
            setTimeout(() => this.textContent = original, 1500);
          });
        });

        document.getElementById('paa-download').addEventListener('click', function () {
          const rows = [['Question', 'Answer', 'Intent']];
          currentItems.forEach((item) => rows.push([item.question, item.answer, item.intent]));
          const csv = rows.map((row) => row.map((cell) => '"' + String(cell).replace(/"/g, '""') + '"').join(',')).join('\n');
          const blob = new Blob([csv], { type: 'text/csv' });
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'paa-' + keywordInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-') + '.csv';
          a.click();
        });

        document.getElementById('paa-intent-filters').addEventListener('click', function (e) {
          if (!e.target.classList.contains('paa-filter')) return;
          document.querySelectorAll('#paa-intent-filters .paa-filter').forEach((btn) => btn.classList.remove('active'));
          e.target.classList.add('active');
          renderItems(e.target.dataset.filter);
        });
      })();
    </script>
  </Fragment>

  <Fragment slot="content">
    <div class="speakable">
      <div class="lead-box">
        <h2>What Are People Also Ask Questions?</h2>
        <p>People Also Ask (PAA) are expandable question boxes in Google's search results. They reveal what real searchers want to know about a topic — making them one of the best sources of content ideas and SEO opportunities.</p>
      </div>

      <h2>How It Works</h2>
      <div class="how-grid">
        <div class="how-card">
          <span class="how-num">1</span>
          <h3>Enter a Keyword</h3>
          <p>Type any topic, product, or question into the search box above.</p>
        </div>
        <div class="how-card">
          <span class="how-num">2</span>
          <h3>AI Analyzes Intent</h3>
          <p>Our AI models search behavior patterns to identify the questions people actually ask.</p>
        </div>
        <div class="how-card">
          <span class="how-num">3</span>
          <h3>Get PAA Questions</h3>
          <p>Receive 10+ questions organized by intent type, each with a concise answer.</p>
        </div>
        <div class="how-card">
          <span class="how-num">4</span>
          <h3>Use in Your Content</h3>
          <p>Add them to FAQ sections, blog outlines, or content briefs to capture more search traffic.</p>
        </div>
      </div>

      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
      {faqs.map((faq) => (
          <div class="faq-item">
          <button class="faq-q" onclick="toggleFaq(this)" aria-expanded="false"><span class="faq-q-text">{faq.q}</span><span class="faq-toggle" aria-hidden="true"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner"><p>{faq.a}</p></div></div>
        </div>
      ))}
          </div>

      <div class="cta-box">
        <h2>Want to track PAA rankings for your keywords?</h2>
        <p>theStacc monitors SERP features — including PAA, featured snippets, and rich results — across all your target keywords.</p>
        <a href="/">Start Your $1 Trial</a>
      </div>
    </div>

    <style>
      .how-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin: 20px 0 40px; }
      @media (max-width: 560px) { .how-grid { grid-template-columns: 1fr; } }
      .how-card { background: white; border: 1px solid var(--border); padding: 22px; }
      .how-num { display: inline-flex; width: 32px; height: 32px; align-items: center; justify-content: center; background: var(--brand-softer); color: var(--brand); font-family: 'Geist Mono', monospace; font-size: 13px; font-weight: 700; margin-bottom: 12px; }
      .how-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
      .how-card p { font-size: 14px; color: var(--text-3); line-height: 1.5; margin: 0; }
      .cta-box { background: var(--brand-softer); border: 1px solid var(--brand); padding: 32px; text-align: center; margin-top: 40px; }
      .cta-box h2 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
      .cta-box p { font-size: 14px; color: var(--text-2); margin-bottom: 18px; }
      .cta-box a { display: inline-block; padding: 12px 24px; background: var(--text-1); color: white; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; }
      .cta-box a:hover { background: var(--brand); }
    </style>
  </Fragment>

  <Fragment slot="related">
    <div class="related-grid">
      <a href="/tools/serp-checker/" class="related-tool">
        <span class="label">SERP</span>
        <h3>SERP Checker</h3>
        <p>Live Google SERP results for any keyword — top 100, features, and stats.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/content-gap-analyzer/" class="related-tool">
        <span class="label">Strategy</span>
        <h3>Content Gap Analyzer</h3>
        <p>Find keyword and topic gaps between your page and top competitors.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
      <a href="/tools/faq-generator/" class="related-tool">
        <span class="label">Content</span>
        <h3>FAQ Generator</h3>
        <p>Generate SEO-optimized FAQ sections from any keyword, with schema markup.</p>
        <span class="arrow-link">Open tool →</span>
      </a>
    </div>
  </Fragment>
</ToolLayout>
