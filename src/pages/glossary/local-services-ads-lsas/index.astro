              <tr class="row-highlight"><td><strong>Position in results</strong></td><td><strong>Above all other ads</strong></td><td>Below LSAs</td></tr>
              <tr><td>Trust badge</td><td>Google Guaranteed / Screened</td><td>None</td></tr>
              <tr><td>Targeting</td><td>Automatic by category + service area</td><td>Manual keyword targeting</td></tr>
              <tr><td>Setup complexity</td><td>Low — no keyword management</td><td>High — requires keyword research + bid strategy</td></tr>
              <tr><td>Verification</td><td>Background check + license required</td><td>Credit card only</td></tr>
              <tr><td>Lead quality</td><td>Generally higher (direct contact intent)</td><td>Varies widely</td></tr>
              <tr><td>Business types</td><td>Service businesses with eligible categories only</td><td>Any business</td></tr>
            </tbody>
