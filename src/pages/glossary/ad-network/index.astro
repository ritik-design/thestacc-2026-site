            <div class="tms-label">Category</div>
            <div class="tms-value">Paid Advertising</div>
          </div>
          <div class="tms-cell">
            <div class="tms-label">Network margin</div>
            <div class="tms-value">20-50% of spend</div>
          </div>
          <div class="tms-cell">
