                <td>Yes</td>
                <td>Under 200 characters, benefit-led</td>
              </tr>
              <tr>
                <td><code>og:image</code></td>
                <td>Yes</td>
                <td>1200x630 px, JPG or PNG, under 8MB</td>
              </tr>
              <tr>
                <td><code>og:url</code></td>
                <td>Yes</td>
                <td>Canonical URL, no tracking params</td>
              </tr>
              <tr>
                <td><code>og:type</code></td>
                <td>Recommended</td>
                <td>website, article, product</td>
              </tr>
              <tr>
                <td><code>og:site_name</code></td>
                <td>Optional</td>
