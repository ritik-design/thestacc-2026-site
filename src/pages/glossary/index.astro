---
import BaseLayout from '../../layouts/BaseLayout.astro';
import termsData from '../../data/glossary-terms.json';

const totalCount = termsData.length;

const seo = {
  title: `SEO Glossary — ${totalCount} terms explained · theStacc`,
  description: `${totalCount} SEO, marketing, local SEO, social, and AI search terms — each defined in plain English with examples. The reference every operator needs.`,
  canonical: 'https://thestacc.com/glossary/',
  ogImage: '/og/glossary.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "theStacc SEO glossary",
    "url": "https://thestacc.com/glossary/"
  }
};

const azLetters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const categories = ['All', ...new Set(termsData.map(t => t.cat).filter(Boolean))].sort((a, b) => a === 'All' ? -1 : b === 'All' ? 1 : a.localeCompare(b));
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Glossary · {totalCount} terms</span>
    <h1 class="h-display">{totalCount} SEO, marketing & AI terms — <span class="accent">explained.</span></h1>
    <p class="hero-sub">Every term you'll hit in a daily SEO standup — defined in plain English, with an example, and linked to the next concept you should know.</p>

    <!-- Search bar (HTML only) -->
    <form action="/glossary/search/" method="get" style="max-width: 560px; margin: 32px auto 0; display: flex; gap: 8px;">
      <input type="search" name="q" placeholder={`Search ${totalCount} terms (e.g. canonical, schema, GBP)`} aria-label="Search glossary" style="flex: 1; height: 48px; padding: 0 20px; border: 1px solid var(--border-strong);font-size: 15px; font-family: inherit; background: white; color: var(--text-1);" />
      <button type="submit" class="btn btn-primary" style="padding: 0 24px;"><span>Search <span class="arrow">→</span></span></button>
    </form>
  </section>

  <!-- A–Z ANCHOR LINKS -->
  <section style="padding: 28px 32px; background: white; border-bottom: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: flex; gap: 4px; flex-wrap: wrap; justify-content: center;">
      {azLetters.map((l) => (
        <a href={`#${l}`} style="display: grid; place-items: center; width: 32px; height: 32px; font-family: 'Geist Mono', monospace; font-size: 12px; font-weight: 600; color: var(--text-2); border: 1px solid var(--border); transition: all 0.15s;">{l}</a>
      ))}
    </div>
  </section>

  <!-- CATEGORY TABS -->
  <section style="padding: 28px 32px; background: var(--bg-soft); border-bottom: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;">
      {categories.map((c, i) => (
        <button class="cat-pill label-pill" data-cat={c} style={i === 0 ? 'background: var(--brand-softer); border-color: var(--brand-soft);' : ''}>{c}</button>
      ))}
    </div>
  </section>

  <!-- TERMS GRID -->
  <section style="padding: 64px 32px 96px; background: var(--bg-soft);">
    <div style="max-width: 1180px; margin: 0 auto;">
      <div class="terms-grid">
        {termsData.map((t) => (
          <a href={`/glossary/${t.slug}/`} class="bento-card term-card" data-cat={t.cat} style="padding: 24px;">
            <div class="bento-title" style="margin-bottom: 10px;">{t.cat}</div>
            <h3 class="h-sm" style="margin-bottom: 10px;">{t.term}</h3>
            <p class="bento-desc">{t.def}</p>
            <div class="bento-cta" style="margin-top: 16px;">Read full definition <span class="arrow">→</span></div>
          </a>
        ))}
      </div>
      <div class="terms-empty" style="display: none; text-align: center; padding: 80px 20px; color: var(--text-3);">No terms in this category yet.</div>
    </div>
  </section>

  <!-- LITE FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Know the terms. <span class="accent">Now rank for them.</span></h2>
        <p class="final-sub">$1 trial. First article live in 24 hours.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    .terms-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    @media (max-width: 900px) { .terms-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px) { .terms-grid { grid-template-columns: 1fr; } }
    .cat-pill { cursor: pointer; user-select: none; transition: all 0.15s; border: 1px solid var(--border); background: white; }
    .cat-pill:hover { border-color: var(--brand); color: var(--brand); }
    .cat-pill.active { background: var(--brand-softer) !important; border-color: var(--brand-soft) !important; color: var(--brand); }
    .term-card.hidden { display: none; }
  </style>

  <script is:inline>
    const pills = document.querySelectorAll('.cat-pill');
    const cards = document.querySelectorAll('.term-card');
    const empty = document.querySelector('.terms-empty');
    pills.forEach(p => p.addEventListener('click', () => {
      const cat = p.getAttribute('data-cat');
      pills.forEach(x => x.classList.toggle('active', x === p));
      let visible = 0;
      cards.forEach(c => {
        const show = cat === 'All' || c.getAttribute('data-cat') === cat;
        c.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
    }));
    if (pills[0]) pills[0].classList.add('active');
  </script>
</BaseLayout>
