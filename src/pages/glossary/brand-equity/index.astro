          <div class="faq-item">
            <button class="faq-q" onclick="toggleFaq(this)"><span class="faq-q-text">How long does it take to build brand equity?</span><span class="faq-toggle"><svg viewBox="0 0 12 12"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="2"/></svg></span></button>
