                <td>Per page</td>
                <td>0-100 logarithmic</td>
                <td>Yes (Ahrefs tools)</td>
              </tr>
              <tr>
                <td><strong>Domain Authority (DA)</strong></td>
                <td>Moz</td>
                <td>Per domain</td>
