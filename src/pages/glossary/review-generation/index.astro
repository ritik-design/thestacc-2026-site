                <td>Restaurants, salons, service businesses</td>
                <td>Strong for Yelp-adjacent searches</td>
                <td>High for applicable industries</td>
              </tr>
              <tr>
                <td><strong>Trustpilot</strong></td>
                <td>E-commerce, SaaS, financial services</td>
                <td>Rich results eligibility</td>
                <td>High for DTC and SaaS</td>
              </tr>
              <tr>
                <td><strong>G2 / Capterra</strong></td>
                <td>B2B software</td>
                <td>Category ranking + organic visibility</td>
                <td>High for B2B SaaS</td>
              </tr>
              <tr>
