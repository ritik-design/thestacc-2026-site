                <td>Always shows correct location</td>
              </tr>
              <tr><td><strong>Places API</strong></td>
                <td>API call: <code>place_id=ChIJ...</code></td>
                <td>Retrieves live hours, reviews, photos</td>
              </tr>
              <tr><td><strong>Google Ads local</strong></td>
                <td>Location targeting via Place ID</td>
                <td>Ads tied to correct GBP listing</td>
              </tr>
