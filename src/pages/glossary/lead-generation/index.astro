              <tr><td><strong>Outbound (cold email, ads)</strong></td><td>You contact prospects directly</td><td class="cell-no">High per lead</td><td class="cell-yes">Fast results</td></tr>
              <tr><td><strong>Product-led (free trial)</strong></td><td>Users experience product before purchase</td><td class="cell-yes">Low</td><td class="cell-meh">Medium</td></tr>
              <tr><td><strong>Event-based (webinars)</strong></td><td>High-touch relationship building</td><td class="cell-meh">Medium</td><td class="cell-meh">Medium</td></tr>
              <tr><td><strong>Referral</strong></td><td>Existing customers send new business</td><td class="cell-yes">Very low</td><td class="cell-no">Hard to scale</td></tr>
            </tbody>
          </table>
        </div>

        <h2 id="examples">Real lead generation examples</h2>

