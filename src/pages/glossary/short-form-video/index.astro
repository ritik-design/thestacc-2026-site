              <tr><td><strong>YouTube Shorts</strong></td><td>30-60 seconds</td><td class="cell-meh">Click-through + completion</td><td>Tutorials, tips, reaction</td></tr>
              <tr><td><strong>LinkedIn Video</strong></td><td>30-90 seconds</td><td class="cell-meh">Comments + dwell</td><td>Thought leadership, industry takes</td></tr>
            </tbody>
