                <td>"Your furnace checkup is overdue"</td>
                <td class="cell-yes">+22% open rate</td>
              </tr>
              <tr>
                <td><strong>Ecommerce PDP hero image</strong></td>
                <td>Studio product shot</td>
                <td>In-context lifestyle shot</td>
