                <td>Below top results (sometimes higher)</td>
                <td>Position 0 — above all organic results</td>
              </tr>
              <tr>
                <td><strong>Answers per query</strong></td>
                <td>4+ (expands infinitely)</td>
                <td>1 per query</td>
              </tr>
