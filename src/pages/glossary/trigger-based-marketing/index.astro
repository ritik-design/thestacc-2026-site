                <td>Re-engagement email or offer</td>
                <td>Day 30 of inactivity</td>
                <td>Churn prevention</td>
              </tr>
              <tr>
                <td><strong>Free trial ending</strong></td>
                <td>Upgrade prompt with proof</td>
                <td>3 days before, day of</td>
                <td>Trial-to-paid conversion</td>
              </tr>
              <tr>
