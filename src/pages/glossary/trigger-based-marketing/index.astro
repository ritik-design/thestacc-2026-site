              </tr>
              <tr>
                <td><strong>Cart abandoned</strong></td>
                <td>Cart recovery email (with items)</td>
                <td>1 hour, 24 hours, 72 hours</td>
                <td>Purchase conversion</td>
              </tr>
              <tr>
                <td><strong>First purchase</strong></td>
                <td>Onboarding / cross-sell email</td>
                <td>Immediately after order</td>
                <td>Second purchase, LTV increase</td>
              </tr>
              <tr>
