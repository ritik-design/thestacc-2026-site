---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: '301 Redirect — Definition, How It Works, SEO Impact | theStacc',
  description: 'A 301 redirect is a permanent server response that sends users and search engines from an old URL to a new one — passing nearly all SEO authority.',
  canonical: 'https://thestacc.com/glossary/301-redirect/',
  ogImage: '/og/glossary-301-redirect.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "DefinedTerm",
        "@id": "https://thestacc.com/glossary/301-redirect/#term",
        "name": "301 Redirect",
        "description": "A 301 redirect is a permanent HTTP status code that tells browsers and search engines a page has moved to a new URL, passing nearly all link equity to the destination.",
        "inDefinedTermSet": {
          "@type": "DefinedTermSet",
          "name": "theStacc SEO Glossary",
          "url": "https://thestacc.com/glossary/"
        },
        "url": "https://thestacc.com/glossary/301-redirect/"
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Does a 301 redirect pass all SEO value?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "A 301 redirect passes nearly all link equity to the destination URL. Google's John Mueller has confirmed PageRank is fully passed through 301s, though the destination still needs to match search intent for rankings to hold."
            }
          },
          {
            "@type": "Question",
            "name": "What is the difference between 301 and 302 redirects?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "A 301 is a permanent redirect. A 302 is temporary. 301s tell search engines to update their index to the new URL and pass link equity. 302s tell them to keep the old URL indexed."
            }
          },
          {
            "@type": "Question",
            "name": "How long does a 301 redirect take to update in Google?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Google usually picks up a 301 redirect within a few days to several weeks. Submitting the new URL to Search Console and requesting reindexing speeds the process up."
            }
          },
          {
            "@type": "Question",
            "name": "Can a 301 redirect hurt SEO?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "A correctly implemented 301 redirect almost never hurts SEO. Issues arise when redirects chain (A → B → C), loop back, or point to an unrelated page. Keep chains under two hops and ensure topical relevance."
            }
          },
          {
            "@type": "Question",
            "name": "How do I implement a 301 redirect?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Implement at the server level (Apache .htaccess, Nginx config, or your CMS's redirect manager). Astro supports redirects via the redirects config in astro.config.mjs. WordPress users can use Redirection or Yoast SEO."
            }
          }
        ]
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "Glossary", "item": "https://thestacc.com/glossary/" },
          { "@type": "ListItem", "position": 3, "name": "301 Redirect", "item": "https://thestacc.com/glossary/301-redirect/" }
        ]
      }
    ]
  }
};
