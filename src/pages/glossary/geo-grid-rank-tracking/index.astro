              <tr><td><strong>9 x 9</strong></td><td>81</td><td>Metro-wide service area business</td><td>1 mi</td></tr>
              <tr><td><strong>15 x 15</strong></td><td>225</td><td>Multi-city HVAC, plumbing, restoration</td><td>1.5 mi</td></tr>
