---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await doc.render();

// Extract headings from the raw HTML body (markdown body contains HTML)
const headingRegex = /<h([2-4])[^>]*id=["']([^"']+)["'][^>]*>(.*?)<\/h\1>/gi;
const headings = [];
let match;
while ((match = headingRegex.exec(doc.body)) !== null) {
  const level = parseInt(match[1], 10);
  const id = match[2];
  // Strip any inner HTML (like anchor links) and decode entities
  const text = match[3]
    .replace(/<[^>]+>/g, '')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&nbsp;/g, ' ')
    .replace(/\s*#\s*$/, '')
    .trim();
  if (text && id) {
    headings.push({ level, text, id });
  }
}
---
<DocsLayout
  title={doc.data.title}
  slug={doc.slug}
  headings={headings}
>
  <Content />
</DocsLayout>
