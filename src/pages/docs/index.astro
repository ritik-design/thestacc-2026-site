---
import BaseLayout from '../../layouts/BaseLayout.astro';
const seo = {
  title: 'Docs · theStacc',
  description: 'theStacc documentation, setup guides, and reference material for Blog SEO, Local SEO, and Social Media automation.',
  canonical: 'https://thestacc.com/docs/',
};
const sections = [
  { title: 'Blog SEO', href: '/modules/content-seo/', desc: 'Generate, optimize, and publish AI-written blog posts daily.' },
  { title: 'Local SEO', href: '/modules/local-seo/', desc: 'Rank in the Map Pack with citations, reviews, and GBP posts.' },
  { title: 'Social Media', href: '/modules/social-media/', desc: 'Auto-publish AI-generated posts across every major channel.' },
  { title: 'Free Tools', href: '/tools/', desc: 'SERP checkers, schema generators, audits, and more.' },
  { title: 'Blog', href: '/blog/', desc: 'Operator-to-operator SEO playbooks and growth tactics.' },
  { title: 'Glossary', href: '/glossary/', desc: '200+ SEO terms, plainly explained.' },
];
---
<BaseLayout seo={seo}>
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Documentation</span>
    <h1 class="h-display">Get started with <span class="accent">theStacc.</span></h1>
    <p class="hero-sub">Everything you need to automate SEO — from first setup to advanced workflows.</p>
  </section>
  <section style="padding: 64px 32px; background: var(--bg-soft); border-top: 1px solid var(--border);">
    <div style="max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
      {sections.map((s) => (
        <a href={s.href} class="bento-card" style="padding: 32px; display: block;">
          <h2 class="h-sm" style="margin-bottom: 10px;">{s.title}</h2>
          <p class="bento-desc">{s.desc}</p>
          <div class="bento-cta" style="margin-top: 18px;">Read more <span class="arrow">→</span></div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
