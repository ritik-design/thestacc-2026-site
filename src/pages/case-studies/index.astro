---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'Case studies — Real businesses, real results · theStacc',
  description: 'See how solar, SaaS, and engineering businesses use theStacc to rank higher, win the Map Pack, and turn organic search into a qualified lead channel.',
  canonical: 'https://thestacc.com/case-studies/',
  ogImage: '/og/case-studies.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "theStacc case studies",
    "url": "https://thestacc.com/case-studies/"
  }
};

const allCases = [
  {
    slug: 'solar-engineering-services',
    company: 'Solar Engineering Services',
    vertical: 'Solar engineering · Surat, India',
    quote: 'theStacc turned SEO into an automated growth engine for our business.',
    attribution: 'Design & engineering firm',
    initials: 'S',
    color: 'orange',
    stats: [
      { v: '20+', l: 'Leads / week' },
      { v: '340+', l: 'Page-1 keywords' },
      { v: '85%', l: 'SEO time saved' },
    ],
    featured: true,
  },
  {
    slug: 'vertical-saas-software',
    company: 'Solar Design Software',
    vertical: 'Vertical SaaS · Global (8 languages)',
    quote: 'theStacc stopped the bleeding and rebuilt our highest-traffic pages.',
    attribution: 'Founder & CEO',
    initials: 'S',
    color: 'green',
    stats: [
      { v: '70+', l: 'Leads / month' },
      { v: '12k', l: 'Daily impressions' },
      { v: '850+', l: 'Pages driving clicks' },
    ],
    featured: false,
  },
  {
    slug: 'solar-epc-company',
    company: 'Solar EPC Company',
    vertical: 'Solar EPC · Gujarat, India',
    quote: 'We are now able to generate content while we sleep. Pretty cool.',
    attribution: 'Nirav Dhanani · Director',
    initials: 'N',
    color: 'purple',
    stats: [
      { v: '+248%', l: 'Impressions' },
      { v: '+116%', l: 'Daily clicks' },
      { v: '120+', l: 'Pieces published' },
    ],
    featured: false,
  },
];

const featured = allCases.find((c) => c.featured);
const cases = allCases.filter((c) => !c.featured);
---
<BaseLayout seo={seo}>
  <!-- HERO -->
  <section class="hero-section">
    <span class="label-pill" style="margin-bottom: 24px;">Customer wins</span>
    <h1 class="h-display">Real businesses. <span class="accent">Real results.</span></h1>
    <p class="hero-sub">No hand-wavy "10× growth" claims. Every case has a starting number, an ending number, and the exact theStacc playbook in between.</p>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar-section">
    <div class="trust-bar-wrap">
      <div class="trust-bar-item">
        <div class="trust-bar-num">3</div>
        <div class="trust-bar-label">Featured case studies</div>
      </div>
      <div class="trust-bar-item">
        <div class="trust-bar-num">300+</div>
        <div class="trust-bar-label">Page-1 keywords won</div>
      </div>
      <div class="trust-bar-item">
        <div class="trust-bar-num">90+</div>
        <div class="trust-bar-label">Qualified leads / month</div>
      </div>
      <div class="trust-bar-item">
        <div class="trust-bar-num">4 mo</div>
        <div class="trust-bar-label">Average time to results</div>
      </div>
    </div>
  </section>

  <!-- FEATURED CASE -->
  <section class="featured-section">
    <div class="featured-wrap">
      <div class="section-label-row">
        <span class="label-pill">Featured case study</span>
      </div>
      <a href={`/case-studies/${featured.slug}/`} class="featured-card">
        <div class="featured-main">
          <div class="featured-tag">{featured.vertical}</div>
          <h2 class="h-lg featured-title">{featured.company}</h2>
          <blockquote class="featured-quote">"{featured.quote}"</blockquote>
          <div class="featured-attr">
            <div class={`case-avatar ${featured.color}`}>{featured.initials}</div>
            <div>
              <div class="featured-attr-name">{featured.attribution}</div>
              <div class="featured-attr-role">{featured.company}</div>
            </div>
          </div>
          <span class="featured-cta">Read the full case study <span class="arrow">→</span></span>
        </div>
        <div class="featured-stats">
          {featured.stats.map((s) => (
            <div class="featured-stat">
              <div class="featured-stat-num">{s.v}</div>
              <div class="featured-stat-label">{s.l}</div>
            </div>
          ))}
        </div>
      </a>
    </div>
  </section>

  <!-- MORE CASES -->
  <section class="cases-grid-section">
    <div class="cases-grid-wrap">
      <div class="section-label-row">
        <span class="label-pill">More wins</span>
      </div>
      <div class="cases-grid">
        {cases.map((c) => (
          <a href={`/case-studies/${c.slug}/`} class="case-card">
            <div class="case-card-top">
              <span class="case-card-tag">{c.vertical}</span>
              <div class={`case-avatar ${c.color}`}>{c.initials}</div>
            </div>
            <h3 class="h-sm case-card-title">{c.company}</h3>
            <blockquote class="case-card-quote">"{c.quote}"</blockquote>
            <div class="case-card-stats">
              {c.stats.map((s) => (
                <div class="case-card-stat">
                  <div class="case-card-stat-num">{s.v}</div>
                  <div class="case-card-stat-label">{s.l}</div>
                </div>
              ))}
            </div>
            <span class="case-card-cta">Read the case study <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <div class="final-wrap" style="padding: 80px 32px;">
      <div class="final-content" style="max-width: 720px;">
        <span class="final-label">Your turn</span>
        <h2 class="final-headline" style="font-size: clamp(28px, 3.5vw, 44px); white-space: normal;">Be the next case study. <span class="accent">Start today.</span></h2>
        <p class="final-sub">$1 trial. First article live in 24 hours. No agency lock-in.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
      </div>
    </div>
  </section>

  <style>
    /* ─────── TRUST BAR ─────── */
    .trust-bar-section {
      padding: 32px;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
    }
    .trust-bar-wrap {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
    .trust-bar-item {
      text-align: center;
      padding: 24px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
    }
    .trust-bar-num {
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--brand);
      line-height: 1;
      margin-bottom: 8px;
    }
    .trust-bar-label {
      font-size: 13px;
      color: var(--text-3);
      font-weight: 500;
    }

    /* ─────── FEATURED SECTION ─────── */
    .featured-section {
      padding: 80px 32px 40px;
      background: var(--bg-soft);
    }
    .featured-wrap {
      max-width: 1100px;
      margin: 0 auto;
    }
    .section-label-row {
      margin-bottom: 24px;
    }
    .featured-card {
      display: grid;
      grid-template-columns: 1.25fr 1fr;
      gap: 0;
      background: var(--bg);
      border: 1px solid var(--border);
      overflow: hidden;
      transition: border-color 0.2s, transform 0.2s;
      text-decoration: none;
    }
    .featured-card:hover {
      border-color: var(--brand);
      transform: translateY(-2px);
    }
    .featured-main {
      padding: 48px;
      display: flex;
      flex-direction: column;
    }
    .featured-tag {
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--brand);
      font-weight: 600;
      margin-bottom: 18px;
    }
    .featured-title {
      margin-bottom: 20px;
    }
    .featured-quote {
      font-size: 20px;
      line-height: 1.45;
      color: var(--text-1);
      font-weight: 500;
      letter-spacing: -0.01em;
      margin: 0 0 28px;
      padding: 0;
      border: none;
    }
    .featured-attr {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 32px;
    }
    .featured-attr-name {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-1);
      letter-spacing: -0.01em;
    }
    .featured-attr-role {
      font-size: 13px;
      color: var(--text-3);
      margin-top: 2px;
    }
    .featured-cta {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 15px;
      font-weight: 600;
      color: var(--brand);
    }
    .featured-cta .arrow { transition: transform 0.2s; }
    .featured-card:hover .featured-cta .arrow { transform: translateX(3px); }

    .featured-stats {
      display: grid;
      grid-template-columns: 1fr;
      border-left: 1px solid var(--border);
      background: var(--bg-soft);
    }
    .featured-stat {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 32px;
      border-bottom: 1px solid var(--border);
    }
    .featured-stat:last-child {
      border-bottom: none;
    }
    .featured-stat-num {
      font-size: 42px;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--brand);
      line-height: 1;
      margin-bottom: 10px;
    }
    .featured-stat-label {
      font-family: 'Geist Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-3);
    }

    /* ─────── CASES GRID ─────── */
    .cases-grid-section {
      padding: 40px 32px 96px;
      background: var(--bg-soft);
    }
    .cases-grid-wrap {
      max-width: 1100px;
      margin: 0 auto;
    }
    .cases-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .case-card {
      display: flex;
      flex-direction: column;
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 32px;
      text-decoration: none;
      transition: border-color 0.2s, transform 0.2s;
    }
    .case-card:hover {
      border-color: var(--brand);
      transform: translateY(-2px);
    }
    .case-card-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
    }
    .case-card-tag {
      font-family: 'Geist Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--brand);
      font-weight: 600;
      padding: 6px 12px;
      background: var(--brand-softer);
    }
    .case-card-title {
      margin-bottom: 14px;
    }
    .case-card-quote {
      font-size: 16px;
      line-height: 1.55;
      color: var(--text-2);
      margin: 0 0 24px;
      padding: 0;
      border: none;
    }
    .case-card-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 28px;
      padding: 18px;
      background: var(--bg-soft);
      border: 1px solid var(--border);
    }
    .case-card-stat {
      text-align: center;
    }
    .case-card-stat-num {
      font-size: 22px;
      font-weight: 700;
      color: var(--brand);
      letter-spacing: -0.02em;
      line-height: 1;
      margin-bottom: 6px;
    }
    .case-card-stat-label {
      font-size: 10px;
      color: var(--text-3);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .case-card-cta {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      font-weight: 600;
      color: var(--brand);
    }
    .case-card-cta .arrow { transition: transform 0.2s; }
    .case-card:hover .case-card-cta .arrow { transform: translateX(3px); }

    /* ─────── AVATAR COLOURS ─────── */
    .case-avatar {
      width: 44px;
      height: 44px;
      display: grid;
      place-items: center;
      font-size: 16px;
      font-weight: 600;
      color: white;
      flex-shrink: 0;
    }
    .case-avatar.orange { background: linear-gradient(135deg, #f59e0b, #d97706); }
    .case-avatar.green { background: linear-gradient(135deg, #10b981, #059669); }
    .case-avatar.purple { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }

    /* ─────── RESPONSIVE ─────── */
    @media (max-width: 960px) {
      .featured-card {
        grid-template-columns: 1fr;
      }
      .featured-stats {
        grid-template-columns: repeat(3, 1fr);
        border-left: none;
        border-top: 1px solid var(--border);
      }
      .featured-stat {
        border-bottom: none;
        border-right: 1px solid var(--border);
      }
      .featured-stat:last-child {
        border-right: none;
      }
      .trust-bar-wrap {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 700px) {
      .cases-grid {
        grid-template-columns: 1fr;
      }
      .featured-main {
        padding: 32px;
      }
      .featured-stats {
        grid-template-columns: 1fr;
      }
      .featured-stat {
        border-right: none;
        border-bottom: 1px solid var(--border);
        padding: 24px 32px;
      }
      .featured-stat:last-child {
        border-bottom: none;
      }
      .case-card-stats {
        grid-template-columns: 1fr;
        gap: 14px;
      }
      .case-card-stat {
        display: flex;
        justify-content: space-between;
        align-items: center;
        text-align: left;
      }
      .case-card-stat-num {
        margin-bottom: 0;
      }
    }

    @media (max-width: 480px) {
      .trust-bar-wrap {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
