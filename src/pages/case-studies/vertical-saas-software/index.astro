---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Solar Design Software case study — theStacc',
  description: 'How a vertical SaaS solar design platform went from 5 to 70+ leads per month, unblocked AI crawlers, and turned 5,500 dormant pages into a qualified lead engine with theStacc.',
  canonical: 'https://thestacc.com/case-studies/vertical-saas-software/',
  ogImage: '/og/case-solar-design-software.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "theStacc",
        "url": "https://thestacc.com/",
        "logo": "https://thestacc.com/button.flex.svg"
      },
      {
        "@type": "Article",
        "headline": "Solar Design Software: from 5 to 70+ leads per month with theStacc",
        "description": "A vertical SaaS solar design platform fixed content cannibalization, unblocked AI crawlers, and grew from 5 to 70+ qualified leads per month.",
        "image": "https://thestacc.com/og/case-solar-design-software.webp",
        "datePublished": "2026-06-28",
        "dateModified": "2026-06-28",
        "author": { "@type": "Organization", "name": "theStacc" },
        "publisher": {
          "@type": "Organization",
          "name": "theStacc",
          "logo": { "@type": "ImageObject", "url": "https://thestacc.com/button.flex.svg" }
        },
        "mainEntityOfPage": "https://thestacc.com/case-studies/vertical-saas-software/",
        "about": {
          "@type": "Organization",
          "name": "Solar Design Software"
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "Case studies", "item": "https://thestacc.com/case-studies/" },
          { "@type": "ListItem", "position": 3, "name": "Solar Design Software", "item": "https://thestacc.com/case-studies/vertical-saas-software/" }
        ]
      }
    ]
  }
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <span class="case-eyebrow">VERTICAL SAAS · GLOBAL (8 LANGUAGES)</span>
    <h1 class="h-display case-hero-quote">
      "theStacc <span class="accent">stopped the bleeding</span> and rebuilt our highest-traffic pages."
    </h1>
    <div class="case-hero-attribution">
      <div class="case-avatar green">S</div>
      <div class="case-hero-attr-text">
        <div class="case-hero-name">Founder &amp; CEO</div>
        <div class="case-hero-role">Solar Design Software</div>
      </div>
    </div>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
  </section>

  <!-- AT-A-GLANCE STAT BAR -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">70<span class="accent">+</span></div><div class="stat-label">Leads per month · from 5</div></div>
      <div class="stat-cell"><div class="stat-num">60</div><div class="stat-label">Daily clicks · from 10</div></div>
      <div class="stat-cell"><div class="stat-num">12<span class="accent">k</span></div><div class="stat-label">Daily impressions · from 1,157</div></div>
      <div class="stat-cell"><div class="stat-num">850<span class="accent">+</span></div><div class="stat-label">Pages driving clicks · from 120</div></div>
    </div>
  </section>

  <!-- THE CHALLENGE -->
  <section class="case-narrative-section">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">01 · The challenge</span>
        <h2 class="h-lg">5,500 pages. <span class="accent">Zero visibility.</span></h2>
      </div>
      <div class="case-narrative-body">
        <p>Solar Design Software had built an enormous content library across blogs, reviews, guides, and calculators. The product was loved by 500+ companies in 8 languages. But organic search was effectively broken.</p>
        <p>Only ~120 of 5,500 indexed pages received any clicks. Fifty-one high-value queries were split across competing pages, diluting authority. AI crawlers were blocked in robots.txt. And with zero backlink strategy, competitors like RatedPower and PVcase owned the search real estate.</p>
        <p>The result: one keyword in the top 10, a 0.70% average CTR, and just five qualified leads a month from a site that should have been a lead engine.</p>
      </div>
    </div>
  </section>

  <!-- THE APPROACH -->
  <section class="case-narrative-section alt">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">02 · The approach</span>
        <h2 class="h-lg">Content consolidation. <span class="accent">Programmatic scale.</span></h2>
        <p class="lede">We stopped the site from competing against itself, then rebuilt the highest-traffic pages for clicks, AI retrieval, and global intent.</p>
      </div>
      <div class="case-approach-grid">
        <div class="case-approach-card">
          <div class="case-approach-num">01</div>
          <h3 class="h-sm">Content SEO</h3>
          <p>Rewrote 280+ titles and meta descriptions for CTR, rebuilt internal linking, and added FAQPage and Speakable schema so the best pages finally earned the traffic they deserved.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> 280+ titles, meta descriptions, and headers rewritten</li>
            <li><span class="case-tick">✓</span> 51 cannibalization clusters consolidated with 301s</li>
            <li><span class="case-tick">✓</span> FAQPage + Speakable schema on high-traffic content</li>
            <li><span class="case-tick">✓</span> Featured-snippet optimization across core pages</li>
          </ul>
          <a href="/modules/content-seo/" class="case-approach-cta">Explore Content SEO <span class="arrow">→</span></a>
        </div>
        <div class="case-approach-card">
          <div class="case-approach-num">02</div>
          <h3 class="h-sm">Programmatic SEO</h3>
          <p>Scaled localized intent pages across 100+ countries and built a global installer directory — all managed across 8 language hubs with proper hreflang architecture.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> /best-solar-software/ pages for 100+ markets</li>
            <li><span class="case-tick">✓</span> /solar-installers/ directory by country and city</li>
            <li><span class="case-tick">✓</span> hreflang implementation across EN, ES, DE, FR, IT, PT, AR, TR</li>
            <li><span class="case-tick">✓</span> Tool-based link magnets: sun-angle and busbar-size calculators</li>
          </ul>
          <a href="/modules/programmatic-seo/" class="case-approach-cta">Explore Programmatic SEO <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- THE RESULTS -->
  <section class="case-results-section">
    <div class="case-results-head">
      <span class="label-pill">03 · The results</span>
      <h2 class="h-lg">Five months in. <span class="accent">A different funnel.</span></h2>
      <p class="lede">Numbers from Google Search Console, GA4, and the Solar Design Software CRM. No vanity stats.</p>
    </div>
    <div class="stats-row case-results-grid">
      <div class="stat-cell"><div class="stat-num">70<span class="accent">+</span></div><div class="stat-label">Qualified leads / month · from 5</div></div>
      <div class="stat-cell"><div class="stat-num">60</div><div class="stat-label">Daily clicks · from 10</div></div>
      <div class="stat-cell"><div class="stat-num">12<span class="accent">k</span></div><div class="stat-label">Daily impressions · from 1,157</div></div>
      <div class="stat-cell"><div class="stat-num">850<span class="accent">+</span></div><div class="stat-label">Pages driving clicks · from 120</div></div>
    </div>
    <div class="stats-row case-results-grid second">
      <div class="stat-cell"><div class="stat-num">12<span class="accent">+</span></div><div class="stat-label">Top-10 keywords · from 1</div></div>
      <div class="stat-cell"><div class="stat-num">20.6</div><div class="stat-label">Avg position · from 60–75</div></div>
      <div class="stat-cell"><div class="stat-num">4<span class="accent">/4</span></div><div class="stat-label">AI crawlers unblocked</div></div>
      <div class="stat-cell"><div class="stat-num">0.6<span class="accent">%</span></div><div class="stat-label">CTR · from 0.5%</div></div>
    </div>
  </section>

  <!-- GSC SCREENSHOTS -->
  <section class="case-screenshots-section">
    <div class="case-screenshots-head">
      <span class="label-pill">Behind the numbers</span>
      <h2 class="h-lg">Google Search Console. <span class="accent">The raw data.</span></h2>
      <p class="lede">Two screenshots from the actual Search Console account showing the before-and-after curve for impressions and clicks.</p>
    </div>
    <div class="case-screenshots-grid">
      <figure class="case-screenshot">
        <img src="/images/case-studies/gsc-impressions.webp" alt="Google Search Console impressions chart showing growth from 1,157 to 12,000 impressions per day" loading="lazy" />
        <figcaption>Impressions · from 1,157/day to 12,000/day average.</figcaption>
      </figure>
      <figure class="case-screenshot">
        <img src="/images/case-studies/gsc-clicks.webp" alt="Google Search Console clicks chart showing growth from 10 to 60 clicks per day" loading="lazy" />
        <figcaption>Clicks · from 10/day to 60/day average.</figcaption>
      </figure>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="case-pullquote-section">
    <div class="case-pullquote-wrap">
      <div class="case-pullquote-mark">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c.25 0 .25.5.25 1v1c0 1-1 2-2 2-.75 0-1 .25-1 1v2c0 1 0 1 1 1z"/></svg>
      </div>
      <blockquote class="case-pullquote">
        When we started, we had thousands of pages but almost zero organic visibility. theStacc didn't just tell us to publish more — they <span class="accent">stopped the bleeding</span>, fixed cannibalization, and rebuilt our highest-traffic pages so they actually converted.
      </blockquote>
      <div class="case-pullquote-attr">
        <div class="case-avatar green">S</div>
        <div>
          <div class="case-pullquote-name">Founder &amp; CEO</div>
          <div class="case-pullquote-role">Solar Design Software</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="case-timeline-section">
    <div class="case-timeline-head">
      <span class="label-pill">04 · Timeline</span>
      <h2 class="h-lg">From audit to compounding demos, <span class="accent">in 150 days.</span></h2>
    </div>
    <div class="case-timeline">
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 1</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">Onboarding · 22 minutes</h3>
          <p>Connected the CMS, Google Search Console, and GA4. Imported the 5,500-page inventory and trained brand voice on 50+ existing articles and reviews.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 14</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">Cannibalization map complete</h3>
          <p>Identified 51 query clusters where multiple pages competed for the same keyword. Prioritized the 18 clusters with the highest commercial intent.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 30</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">AI crawlers unblocked · llms.txt live</h3>
          <p>Removed GPTBot, ClaudeBot, PerplexityBot, and Google-Extended blocks from robots.txt. Shipped llms.txt and answer-first content formatting.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 60</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">Consolidation wave shipped</h3>
          <p>301 redirects, canonical tags, and updated internal links concentrated authority into single authoritative pages for each high-value query.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 90</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">280+ pages optimized for CTR</h3>
          <p>Rewrote titles, meta descriptions, and headers across reviews, comparisons, and programmatic pages. Average CTR started climbing within two weeks.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 150</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">70+ leads / month · 12+ top-10 keywords</h3>
          <p>Organic search became a consistent demo channel across India, the US, the UK, and Europe. The content engine kept publishing while the team focused on product.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TOOLS USED -->
  <section class="case-tools-section">
    <div class="case-tools-head">
      <span class="label-pill">05 · Tools used</span>
      <h2 class="h-lg">What's running in the background.</h2>
    </div>
    <div class="case-tools-grid">
      <a class="case-tools-card" href="/modules/content-seo/">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
        </div>
        <h3 class="case-tools-title">Content SEO module</h3>
        <p>Title and meta optimization, cannibalization cleanup, schema markup, and internal linking at scale.</p>
        <span class="case-tools-link">Explore <span class="arrow">→</span></span>
      </a>
      <a class="case-tools-card" href="/modules/programmatic-seo/">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="case-tools-title">Programmatic SEO module</h3>
        <p>Localized pages, directory builders, and multi-language hubs with hreflang and auto-publishing.</p>
        <span class="case-tools-link">Explore <span class="arrow">→</span></span>
      </a>
      <div class="case-tools-card static">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="case-tools-title">Integrations</h3>
        <p>CMS, Google Search Console, GA4, and Google Business Profile. Zero copy-paste between tools.</p>
        <span class="case-tools-link">8 integrations live</span>
      </div>
    </div>
  </section>

  <!-- WHAT'S NEXT -->
  <section class="case-next-section">
    <div class="case-next-wrap">
      <span class="label-pill">06 · What's next</span>
      <h2 class="h-lg">New link magnets. <span class="accent">New markets.</span></h2>
      <p class="lede">Solar Design Software is launching two new calculator tools as link magnets and expanding programmatic pages into three additional language hubs. The target is 150 qualified leads per month by Q1 and a top-10 presence for every core product comparison term.</p>
    </div>
  </section>

  <!-- OTHER CASE STUDIES -->
  <section class="cases-section" id="other-cases">
    <div class="cases-header">
      <div>
        <span class="label-pill">More wins</span>
        <h2 class="h-lg">Other case studies. <span class="accent">Real numbers.</span></h2>
      </div>
      <div class="cases-header-right"><a href="/case-studies/" class="cases-all-link">View all case studies <span class="arrow">→</span></a></div>
    </div>
    <div class="cases-carousel" id="casesCarousel">
      <div class="cases-track" id="casesTrack">
        <a class="case-slide" href="/case-studies/solar-epc-company/">
          <span class="case-tag">SOLAR EPC · GUJARAT, INDIA</span>
          <div class="case-header-row">
            <div class="case-avatar purple">N</div>
            <div class="case-info">
              <h4>Nirav Dhanani</h4>
              <div class="meta">DIRECTOR · SOLAR EPC COMPANY</div>
            </div>
          </div>
          <p class="case-quote">"We are now able to <span class="accent">generate content while we sleep.</span> Pretty cool."</p>
          <div class="case-stats">
            <div><div class="case-stat-num">+248<span class="accent">%</span></div><div class="case-stat-label">IMPRESSIONS</div></div>
            <div><div class="case-stat-num">+116<span class="accent">%</span></div><div class="case-stat-label">DAILY CLICKS</div></div>
            <div><div class="case-stat-num">120<span class="accent">+</span></div><div class="case-stat-label">PIECES PUBLISHED</div></div>
          </div>
          <span class="case-read-more">Read full study <span class="arrow">→</span></span>
        </a>
        <a class="case-slide" href="/case-studies/solar-engineering-services/">
          <span class="case-tag">SOLAR ENGINEERING · SURAT, GUJARAT, INDIA</span>
          <div class="case-header-row">
            <div class="case-avatar orange">S</div>
            <div class="case-info">
              <h4>Solar Engineering Services</h4>
              <div class="meta">DESIGN &amp; ENGINEERING FIRM</div>
            </div>
          </div>
          <p class="case-quote">"theStacc turned SEO into an <span class="accent">automated growth engine</span> for our business."</p>
          <div class="case-stats">
            <div><div class="case-stat-num">20<span class="accent">+</span></div><div class="case-stat-label">LEADS / WEEK</div></div>
            <div><div class="case-stat-num">340<span class="accent">+</span></div><div class="case-stat-label">PAGE-1 KEYWORDS</div></div>
            <div><div class="case-stat-num">85<span class="accent">%</span></div><div class="case-stat-label">SEO TIME SAVED</div></div>
          </div>
          <span class="case-read-more">Read full study <span class="arrow">→</span></span>
        </a>
      </div>
      <div class="cases-dots" id="casesDots"></div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor"/>
        </pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Run a B2B SaaS company?</span>
        <h2 class="final-headline">Your buyers are <span class="accent">searching today.</span><br/>Most of your pages aren't there.</h2>
        <p class="final-sub">70+ qualified leads a month. 850+ pages driving clicks. The same engine that runs for Solar Design Software runs for you. $1 trial. First fixes live in 24 hours.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>30-day money-back</span> · <span>No agency lock-in</span> · <span>Cancel anytime</span></div>
        <p class="final-ps"><strong>P.S.</strong> The pages you consolidate and optimize this month will compound for years. <span class="accent">The compounding starts the day you go live. Not the day you decide.</span></p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─────── CASE-STUDY HERO ─────── */
  .case-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: var(--brand-softer);
    color: var(--brand);
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 32px;
  }
  .case-hero-quote {
    font-size: clamp(34px, 4.8vw, 64px) !important;
    line-height: 1.1 !important;
    max-width: 980px;
    margin: 0 auto 40px;
    font-weight: 600 !important;
    letter-spacing: -0.025em !important;
  }
  .case-hero-attribution {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 36px;
  }
  .case-hero-attr-text { text-align: left; }
  .case-hero-name { font-size: 16px; font-weight: 600; color: var(--text-1); letter-spacing: -0.01em; }
  .case-hero-role { font-size: 13px; color: var(--text-3); margin-top: 2px; }

  /* ─────── NARRATIVE SECTIONS ─────── */
  .case-narrative-section { padding: 96px 32px; background: var(--bg); }
  .case-narrative-section.alt { background: var(--bg-soft); }
  .case-narrative-wrap { max-width: 1080px; margin: 0 auto; }
  .case-narrative-head { max-width: 720px; margin-bottom: 48px; }
  .case-narrative-head .label-pill { margin-bottom: 16px; }
  .case-narrative-head h2 { margin-bottom: 16px; }
  .case-narrative-head .lede { margin-top: 16px; }
  .case-narrative-body p {
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-2);
    max-width: 760px;
    margin-bottom: 20px;
  }
  .case-narrative-body p:last-child { margin-bottom: 0; }

  /* ─────── APPROACH GRID ─────── */
  .case-approach-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .case-approach-card {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 32px;
    display: flex;
    flex-direction: column;
  }
  .case-approach-num {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--brand);
    font-weight: 600;
    margin-bottom: 18px;
  }
  .case-approach-card h3 { margin-bottom: 12px; }
  .case-approach-card p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-2);
    margin-bottom: 20px;
  }
  .case-approach-list {
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .case-approach-list li {
    display: flex;
    align-items: flex-start;
