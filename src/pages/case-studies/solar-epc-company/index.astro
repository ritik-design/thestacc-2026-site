---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Solar EPC Company case study — theStacc',
  description: 'How a top-3 Gujarat solar EPC company grew daily impressions 248%, daily clicks 116%, and published 120+ SEO-optimized content pieces with theStacc.',
  canonical: 'https://thestacc.com/case-studies/solar-epc-company/',
  ogImage: '/og/case-solar-epc-company.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "theStacc",
        "url": "https://thestacc.com/",
        "logo": "https://thestacc.com/button.flex.svg"
      },
      {
        "@type": "Article",
        "headline": "Solar EPC Company: 248% impression growth and 120+ pieces published with theStacc",
        "description": "A top-3 Gujarat solar EPC company replaced manual content workflows with AI automation and grew from 2,500 to 8,700 daily impressions in four months.",
        "image": "https://thestacc.com/og/case-solar-epc-company.webp",
        "datePublished": "2026-06-28",
        "dateModified": "2026-06-28",
        "author": { "@type": "Organization", "name": "theStacc" },
        "publisher": {
          "@type": "Organization",
          "name": "theStacc",
          "logo": { "@type": "ImageObject", "url": "https://thestacc.com/button.flex.svg" }
        },
        "mainEntityOfPage": "https://thestacc.com/case-studies/solar-epc-company/",
        "about": {
          "@type": "Organization",
          "name": "Solar EPC Company",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Gujarat",
            "addressCountry": "IN"
          }
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "Case studies", "item": "https://thestacc.com/case-studies/" },
          { "@type": "ListItem", "position": 3, "name": "Solar EPC Company", "item": "https://thestacc.com/case-studies/solar-epc-company/" }
        ]
      }
    ]
  }
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <span class="case-eyebrow">SOLAR EPC · GUJARAT, INDIA</span>
    <h1 class="h-display case-hero-quote">
      "We are now able to <span class="accent">generate content while we sleep.</span> Pretty cool."
    </h1>
    <div class="case-hero-attribution">
      <div class="case-avatar purple">N</div>
      <div class="case-hero-attr-text">
        <div class="case-hero-name">Nirav Dhanani</div>
        <div class="case-hero-role">Director · Solar EPC Company</div>
      </div>
    </div>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
  </section>

  <!-- AT-A-GLANCE STAT BAR -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">+248<span class="accent">%</span></div><div class="stat-label">Impressions · 2,500 → 8,700 / day</div></div>
      <div class="stat-cell"><div class="stat-num">+116<span class="accent">%</span></div><div class="stat-label">Clicks · 180 → 389 / day</div></div>
      <div class="stat-cell"><div class="stat-num">6.5</div><div class="stat-label">Avg position · from 11.2</div></div>
      <div class="stat-cell"><div class="stat-num">120<span class="accent">+</span></div><div class="stat-label">Content pieces published</div></div>
    </div>
  </section>

  <!-- THE CHALLENGE -->
  <section class="case-narrative-section">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">01 · The challenge</span>
        <h2 class="h-lg">Top 3 in Gujarat. <span class="accent">Invisible online.</span></h2>
      </div>
      <div class="case-narrative-body">
        <p>Solar EPC Company had built a reputation as one of the top solar installers in Gujarat. On the ground, the team was winning. Online, they were losing leads to competitors with weaker track records.</p>
        <p>The publishing process was the bottleneck: one blog post every two weeks, 8+ hours per article, and engineers pulled away from site surveys to edit copy. High-intent terms like "solar panel cost in Gujarat" and "PM Surya Ghar subsidy eligibility" sent buyers elsewhere.</p>
        <p>The site had 34 indexed pages, zero schema markup, a 3.2-second average load time, and no presence in AI search engines. Growth had stalled — not because of demand, but because the content engine couldn't keep up.</p>
      </div>
    </div>
  </section>

  <!-- THE APPROACH -->
  <section class="case-narrative-section alt">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">02 · The approach</span>
        <h2 class="h-lg">AI content engine. <span class="accent">Local intent locked down.</span></h2>
        <p class="lede">We fixed the technical foundation, then turned the content workflow into a repeatable system that published 120+ pieces in four months.</p>
      </div>
      <div class="case-approach-grid">
        <div class="case-approach-card">
          <div class="case-approach-num">01</div>
          <h3 class="h-sm">Content SEO</h3>
          <p>Built a publishing engine around the 847 untapped solar keywords we identified — covering subsidies, installation guides, comparisons, and city-specific pages.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> 120+ SEO-optimized articles and location pages published</li>
            <li><span class="case-tick">✓</span> Topic clusters around solar installation, subsidies, and maintenance</li>
            <li><span class="case-tick">✓</span> Auto-publishing directly to the CMS with formatting and meta tags</li>
            <li><span class="case-tick">✓</span> Internal link architecture to distribute authority across key pages</li>
          </ul>
          <a href="/modules/content-seo/" class="case-approach-cta">Explore Content SEO <span class="arrow">→</span></a>
        </div>
        <div class="case-approach-card">
          <div class="case-approach-num">02</div>
          <h3 class="h-sm">Local SEO</h3>
          <p>Tuned every local signal so the company owned Gujarat and Rajasthan solar searches — from Google Business Profile to city-level landing pages and directory citations.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> Google Business Profile rebuilt with service-area coverage</li>
            <li><span class="case-tick">✓</span> City-specific landing pages for 47 location keywords</li>
            <li><span class="case-tick">✓</span> Citation cleanup and directory consistency across markets</li>
            <li><span class="case-tick">✓</span> Weekly Map Pack rank tracking for target queries</li>
          </ul>
          <a href="/modules/local-seo/" class="case-approach-cta">Explore Local SEO <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- THE RESULTS -->
  <section class="case-results-section">
    <div class="case-results-head">
      <span class="label-pill">03 · The results</span>
      <h2 class="h-lg">Four months in. <span class="accent">A self-reinforcing loop.</span></h2>
      <p class="lede">Numbers from Google Search Console, GA4, and the Solar EPC Company CRM. Organic only — Google Ads were paused in month 2 to isolate SEO impact.</p>
    </div>
    <div class="stats-row case-results-grid">
      <div class="stat-cell"><div class="stat-num">8.7<span class="accent">k</span></div><div class="stat-label">Daily impressions · from 2,500</div></div>
      <div class="stat-cell"><div class="stat-num">389</div><div class="stat-label">Daily clicks · from 180</div></div>
      <div class="stat-cell"><div class="stat-num">6.5</div><div class="stat-label">Avg position · from 11.2</div></div>
      <div class="stat-cell"><div class="stat-num">4.1<span class="accent">%</span></div><div class="stat-label">CTR · from 2.8%</div></div>
    </div>
    <div class="stats-row case-results-grid second">
      <div class="stat-cell"><div class="stat-num">120<span class="accent">+</span></div><div class="stat-label">Indexed pages · from 34</div></div>
      <div class="stat-cell"><div class="stat-num">588<span class="accent">k</span></div><div class="stat-label">Total impressions · 4-month period</div></div>
      <div class="stat-cell"><div class="stat-num">34<span class="accent">%</span></div><div class="stat-label">AI citation rate · from 0%</div></div>
      <div class="stat-cell"><div class="stat-num">100<span class="accent">%</span></div><div class="stat-label">Schema coverage · from 0%</div></div>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="case-pullquote-section">
    <div class="case-pullquote-wrap">
      <div class="case-pullquote-mark">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c.25 0 .25.5.25 1v1c0 1-1 2-2 2-.75 0-1 .25-1 1v2c0 1 0 1 1 1z"/></svg>
      </div>
      <blockquote class="case-pullquote">
        We are now able to <span class="accent">generate content while we sleep.</span> Pretty cool. The team is back on site surveys and client meetings, and our pipeline keeps growing.
      </blockquote>
      <div class="case-pullquote-attr">
        <div class="case-avatar purple">N</div>
        <div>
          <div class="case-pullquote-name">Nirav Dhanani</div>
          <div class="case-pullquote-role">Director · Solar EPC Company</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="case-timeline-section">
    <div class="case-timeline-head">
      <span class="label-pill">04 · Timeline</span>
      <h2 class="h-lg">From manual workflows to measurable growth, <span class="accent">in 120 days.</span></h2>
    </div>
    <div class="case-timeline">
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 1</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">Onboarding · 22 minutes</h3>
          <p>Connected the CMS, Google Search Console, GBP, and GA4. Brand voice trained on existing project case studies. Keyword map generated for 847 commercial-intent queries.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 14</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">Technical foundation fixed</h3>
          <p>Core Web Vitals improved, 14 broken links resolved, images optimized, and schema markup deployed across all key pages.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 30</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">Content engine live</h3>
          <p>First batch of location pages and subsidy guides published. Auto-publishing replaced the 8-hour manual workflow. Engineers back to project work.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 60</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">Authority build underway</h3>
          <p>Guest posts and educational solar content started earning backlinks. Topic clusters around installation, subsidies, and maintenance took shape.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 90</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">AI visibility unlocked</h3>
          <p>FAQ schema, answer-first formatting, and entity-rich content pushed AI citation rates from 0% to 34% for target Gujarat solar queries.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 120</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">248% impression growth · 120+ pages live</h3>
          <p>Daily impressions hit 8,700, daily clicks reached 389, and organic leads became a consistent source of new project inquiries.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TOOLS USED -->
  <section class="case-tools-section">
    <div class="case-tools-head">
      <span class="label-pill">05 · Tools used</span>
      <h2 class="h-lg">What's running in the background.</h2>
    </div>
    <div class="case-tools-grid">
      <a class="case-tools-card" href="/modules/content-seo/">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
        </div>
        <h3 class="case-tools-title">Content SEO module</h3>
        <p>AI keyword research, article generation, auto-publishing, and internal linking — all in one workflow.</p>
        <span class="case-tools-link">Explore <span class="arrow">→</span></span>
      </a>
      <a class="case-tools-card" href="/modules/local-seo/">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="case-tools-title">Local SEO module</h3>
        <p>GBP management, location pages, citation cleanup, and Map Pack tracking for regional service businesses.</p>
        <span class="case-tools-link">Explore <span class="arrow">→</span></span>
      </a>
      <div class="case-tools-card static">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="case-tools-title">Integrations</h3>
        <p>CMS, Google Search Console, Google Business Profile, GA4. Zero copy-paste between tools.</p>
        <span class="case-tools-link">6 integrations live</span>
      </div>
    </div>
  </section>

  <!-- WHAT'S NEXT -->
  <section class="case-next-section">
    <div class="case-next-wrap">
      <span class="label-pill">06 · What's next</span>
      <h2 class="h-lg">Rajasthan expansion. <span class="accent">Maintenance vertical.</span></h2>
      <p class="lede">Solar EPC Company is rolling out location pages for Rajasthan cities and launching a solar maintenance content cluster next quarter. The target is 15 qualified organic leads per month and a top-3 Map Pack ranking across all Gujarat solar EPC queries.</p>
    </div>
  </section>

  <!-- OTHER CASE STUDIES -->
  <section class="cases-section" id="other-cases">
    <div class="cases-header">
      <div>
        <span class="label-pill">More wins</span>
        <h2 class="h-lg">Other case studies. <span class="accent">Real numbers.</span></h2>
      </div>
      <div class="cases-header-right"><a href="/case-studies/" class="cases-all-link">View all case studies <span class="arrow">→</span></a></div>
    </div>
    <div class="cases-carousel" id="casesCarousel">
      <div class="cases-track" id="casesTrack">
        <a class="case-slide" href="/case-studies/vertical-saas-software/">
          <span class="case-tag">SAAS · GLOBAL (8 LANGUAGES)</span>
          <div class="case-header-row">
            <div class="case-avatar green">R</div>
            <div class="case-info">
              <h4>Founder &amp; CEO</h4>
              <div class="meta">SOLAR DESIGN SOFTWARE · VERTICAL SAAS</div>
            </div>
          </div>
          <p class="case-quote">"Thousands of pages, almost zero organic visibility. theStacc <span class="accent">stopped the bleeding</span> and rebuilt our highest-traffic pages."</p>
          <div class="case-stats">
            <div><div class="case-stat-num">70<span class="accent">+</span></div><div class="case-stat-label">LEADS / MO</div></div>
            <div><div class="case-stat-num">12<span class="accent">k</span></div><div class="case-stat-label">DAILY IMPR.</div></div>
            <div><div class="case-stat-num">850<span class="accent">+</span></div><div class="case-stat-label">PAGES CLICKING</div></div>
          </div>
          <span class="case-read-more">Read full study <span class="arrow">→</span></span>
        </a>
        <a class="case-slide" href="/case-studies/solar-engineering-services/">
          <span class="case-tag">SOLAR ENGINEERING · SURAT, GUJARAT, INDIA</span>
          <div class="case-header-row">
            <div class="case-avatar orange">S</div>
            <div class="case-info">
              <h4>Solar Engineering Services</h4>
              <div class="meta">DESIGN &amp; ENGINEERING FIRM</div>
            </div>
          </div>
          <p class="case-quote">"theStacc turned SEO into an <span class="accent">automated growth engine</span> for our business."</p>
          <div class="case-stats">
            <div><div class="case-stat-num">20<span class="accent">+</span></div><div class="case-stat-label">LEADS / WEEK</div></div>
            <div><div class="case-stat-num">340<span class="accent">+</span></div><div class="case-stat-label">PAGE-1 KEYWORDS</div></div>
            <div><div class="case-stat-num">85<span class="accent">%</span></div><div class="case-stat-label">SEO TIME SAVED</div></div>
          </div>
          <span class="case-read-more">Read full study <span class="arrow">→</span></span>
        </a>
      </div>
      <div class="cases-dots" id="casesDots"></div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-section dark">
    <svg class="dot-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotGrid" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor"/>
        </pattern>
        <radialGradient id="dotFade" cx="50%" cy="50%" r="60%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="dotMask"><rect width="100%" height="100%" fill="url(#dotFade)"/></mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotGrid)" mask="url(#dotMask)"/>
    </svg>
    <div class="final-wrap">
      <div class="final-content">
        <span class="final-label">Run a solar or local service business?</span>
        <h2 class="final-headline">Your buyers are <span class="accent">searching today.</span><br/>Your competitors are showing up.</h2>
        <p class="final-sub">248% impression growth. 120+ pages published. The same engine that runs for Solar EPC Company runs for you. $1 trial. First content live in 24 hours.</p>
        <a href="/checkout/" class="final-cta-btn">Start your $1 trial <span class="arrow">→</span></a>
        <div class="final-trust"><span>30-day money-back</span> · <span>No agency lock-in</span> · <span>Cancel anytime</span></div>
        <p class="final-ps"><strong>P.S.</strong> The content you publish this month will rank three years from now. <span class="accent">The compounding starts the day you go live. Not the day you decide.</span></p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─────── CASE-STUDY HERO ─────── */
  .case-eyebrow {
    display: inline-block;
    padding: 6px 14px;
    background: var(--brand-softer);
    color: var(--brand);
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 32px;
  }
  .case-hero-quote {
    font-size: clamp(34px, 4.8vw, 64px) !important;
    line-height: 1.1 !important;
    max-width: 980px;
    margin: 0 auto 40px;
    font-weight: 600 !important;
    letter-spacing: -0.025em !important;
  }
  .case-hero-attribution {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 36px;
  }
  .case-hero-attr-text { text-align: left; }
  .case-hero-name { font-size: 16px; font-weight: 600; color: var(--text-1); letter-spacing: -0.01em; }
  .case-hero-role { font-size: 13px; color: var(--text-3); margin-top: 2px; }

  /* ─────── NARRATIVE SECTIONS ─────── */
  .case-narrative-section { padding: 96px 32px; background: var(--bg); }
  .case-narrative-section.alt { background: var(--bg-soft); }
  .case-narrative-wrap { max-width: 1080px; margin: 0 auto; }
  .case-narrative-head { max-width: 720px; margin-bottom: 48px; }
  .case-narrative-head .label-pill { margin-bottom: 16px; }
  .case-narrative-head h2 { margin-bottom: 16px; }
  .case-narrative-head .lede { margin-top: 16px; }
  .case-narrative-body p {
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-2);
    max-width: 760px;
    margin-bottom: 20px;
  }
  .case-narrative-body p:last-child { margin-bottom: 0; }

  /* ─────── APPROACH GRID ─────── */
  .case-approach-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .case-approach-card {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 32px;
    display: flex;
    flex-direction: column;
  }
  .case-approach-num {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--brand);
    font-weight: 600;
    margin-bottom: 18px;
  }
  .case-approach-card h3 { margin-bottom: 12px; }
  .case-approach-card p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-2);
    margin-bottom: 20px;
  }
  .case-approach-list {
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .case-approach-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.5;
  }
  .case-tick {
    display: inline-grid;
    place-items: center;
    width: 18px;
    height: 18px;
    background: var(--brand-softer);
    color: var(--brand);
    font-weight: 700;
    font-size: 11px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .case-approach-cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: var(--brand);
  }
  .case-approach-cta .arrow { transition: transform 0.2s; }
  .case-approach-cta:hover .arrow { transform: translateX(3px); }

  /* ─────── RESULTS ─────── */
  .case-results-section { padding: 96px 32px; background: var(--bg); }
