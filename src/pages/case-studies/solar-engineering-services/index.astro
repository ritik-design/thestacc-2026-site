---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const seo = {
  title: 'Solar Engineering Services case study — theStacc',
  description: 'How a Surat-based solar design and engineering firm went from 0 to 20+ qualified leads per week and ranked 340+ keywords on page 1 — with theStacc.',
  canonical: 'https://thestacc.com/case-studies/solar-engineering-services/',
  ogImage: '/og/case-solar-engineering-services.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "theStacc",
        "url": "https://thestacc.com/",
        "logo": "https://thestacc.com/button.flex.svg"
      },
      {
        "@type": "Article",
        "headline": "Solar Engineering Services: from 0 to 20+ qualified leads per week with theStacc",
        "description": "A Surat-based solar design and engineering firm went from 12 ranked keywords to 340+ on page 1, generating 20+ qualified leads every week.",
        "image": "https://thestacc.com/og/case-solar-engineering-services.webp",
        "datePublished": "2026-06-28",
        "dateModified": "2026-06-28",
        "author": { "@type": "Organization", "name": "theStacc" },
        "publisher": {
          "@type": "Organization",
          "name": "theStacc",
          "logo": { "@type": "ImageObject", "url": "https://thestacc.com/button.flex.svg" }
        },
        "mainEntityOfPage": "https://thestacc.com/case-studies/solar-engineering-services/",
        "about": {
          "@type": "Organization",
          "name": "Solar Engineering Services",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Surat",
            "addressRegion": "Gujarat",
            "addressCountry": "IN"
          }
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "Case studies", "item": "https://thestacc.com/case-studies/" },
          { "@type": "ListItem", "position": 3, "name": "Solar Engineering Services", "item": "https://thestacc.com/case-studies/solar-engineering-services/" }
        ]
      }
    ]
  }
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <span class="case-eyebrow">SOLAR ENGINEERING · SURAT, GUJARAT, INDIA</span>
    <h1 class="h-display case-hero-quote">
      "theStacc turned SEO into an <span class="accent">automated growth engine</span> for our business."
    </h1>
    <div class="case-hero-attribution">
      <div class="case-avatar orange">S</div>
      <div class="case-hero-attr-text">
        <div class="case-hero-name">Solar Engineering Services</div>
        <div class="case-hero-role">Design &amp; engineering firm · Surat, Gujarat</div>
      </div>
    </div>
    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
  </section>

  <!-- AT-A-GLANCE STAT BAR -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">20<span class="accent">+</span></div><div class="stat-label">Qualified leads per week · from 0</div></div>
      <div class="stat-cell"><div class="stat-num">340<span class="accent">+</span></div><div class="stat-label">Page-1 keywords · from 12</div></div>
      <div class="stat-cell"><div class="stat-num">85<span class="accent">%</span></div><div class="stat-label">Less SEO time · 25h → 3h / week</div></div>
      <div class="stat-cell"><div class="stat-num">28<span class="accent">×</span></div><div class="stat-label">Ranked keyword growth</div></div>
    </div>
  </section>

  <!-- COMPANY SNAPSHOT + STARTING POINT -->
  <section class="case-narrative-section alt">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">At a glance</span>
        <h2 class="h-lg">Company snapshot <span class="accent">&amp; starting point</span></h2>
        <p class="lede">A mid-sized solar engineering firm in Surat with world-class technical delivery — and a website that could not keep up.</p>
      </div>
      <div class="snapshot-grid">
        <div class="snapshot-card">
          <div class="snapshot-label">Industry</div>
          <div class="snapshot-value">Solar Engineering &amp; Design</div>
        </div>
        <div class="snapshot-card">
          <div class="snapshot-label">Company size</div>
          <div class="snapshot-value">50+ engineers</div>
        </div>
        <div class="snapshot-card">
          <div class="snapshot-label">Location</div>
          <div class="snapshot-value">Surat, Gujarat, India</div>
        </div>
        <div class="snapshot-card">
          <div class="snapshot-label">Clients</div>
          <div class="snapshot-value">EPCs across India</div>
        </div>
        <div class="snapshot-card">
          <div class="snapshot-label">Campaign</div>
          <div class="snapshot-value">Jan 2025 – Apr 2025</div>
        </div>
        <div class="snapshot-card">
          <div class="snapshot-label">Primary module</div>
          <div class="snapshot-value">Blog SEO + Local SEO</div>
        </div>
        <div class="snapshot-card">
          <div class="snapshot-label">Publishing rate</div>
          <div class="snapshot-value">30+ blogs / month</div>
        </div>
        <div class="snapshot-card">
          <div class="snapshot-label">Starting page-1 keywords</div>
          <div class="snapshot-value">12</div>
        </div>
      </div>
      <div class="starting-stats">
        <div class="stat-cell"><div class="stat-num">0</div><div class="stat-label">Weekly leads</div></div>
        <div class="stat-cell"><div class="stat-num">12</div><div class="stat-label">Total blog posts</div></div>
        <div class="stat-cell"><div class="stat-num">25</div><div class="stat-label">SEO hours / week</div></div>
        <div class="stat-cell"><div class="stat-num">12</div><div class="stat-label">Page-1 keywords</div></div>
      </div>
    </div>
  </section>

  <!-- THE CHALLENGE -->
  <section class="case-narrative-section">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">01 · The challenge</span>
        <h2 class="h-lg">A great engineering team. <span class="accent">Zero inbound pipeline.</span></h2>
      </div>
      <div class="case-narrative-body">
        <p>Solar Engineering Services designs and engineers solar plants for EPC firms across India. The technical work was world-class. The website was not.</p>
        <p>Before theStacc, the team ranked for 12 keywords total and the contact form sat quiet for weeks. Every project came from referrals or cold outbound. The founder was spending 25 hours every week writing blog drafts, chasing a freelancer agency, and editing copy that never shipped on time.</p>
        <p>They needed three things at once: more keywords ranked, more qualified inbound leads, and most of those 25 hours back so the team could go back to engineering.</p>
      </div>
    </div>
  </section>

  <!-- THE AUTOMATION LAYER -->
  <section class="case-narrative-section alt">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">02 · What got automated</span>
        <h2 class="h-lg">The entire SEO workflow. <span class="accent">Running on autopilot.</span></h2>
        <p class="lede">theStacc replaced every manual step — from keyword discovery to published article — with a system that runs continuously.</p>
      </div>
      <div class="case-approach-grid">
        <div class="case-approach-card">
          <div class="case-approach-num">01</div>
          <h3 class="h-sm">Keyword research</h3>
          <p>Continuous discovery of high-intent solar engineering keywords, mapped by search volume, competition, and commercial intent. No more spreadsheets.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> 240+ commercial-intent queries mapped</li>
            <li><span class="case-tick">✓</span> Auto-surfaced long-tail opportunities</li>
            <li><span class="case-tick">✓</span> Competitor gap analysis every week</li>
          </ul>
        </div>
        <div class="case-approach-card">
          <div class="case-approach-num">02</div>
          <h3 class="h-sm">Content generation</h3>
          <p>AI writes SEO-optimized articles with proper structure, internal links, meta tags, and a brand voice trained on the firm's existing case studies.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> Brand voice trained on 12 case studies</li>
            <li><span class="case-tick">✓</span> Article + FAQPage schema on every post</li>
            <li><span class="case-tick">✓</span> 92+ internal SEO grade before publish</li>
          </ul>
        </div>
        <div class="case-approach-card">
          <div class="case-approach-num">03</div>
          <h3 class="h-sm">Auto-publishing</h3>
          <p>Articles publish directly to WordPress on a set schedule — formatted, optimized, and live without a single manual upload.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> 4 articles per week, every week</li>
            <li><span class="case-tick">✓</span> No missed deadlines or publishing bursts</li>
            <li><span class="case-tick">✓</span> CMS formatting handled automatically</li>
          </ul>
        </div>
        <div class="case-approach-card">
          <div class="case-approach-num">04</div>
          <h3 class="h-sm">Internal linking</h3>
          <p>The system builds intelligent links between related articles, creating topic clusters that strengthen domain authority and rankings.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> 80+ pages interlinked automatically</li>
            <li><span class="case-tick">✓</span> Pillar-cluster architecture built over time</li>
            <li><span class="case-tick">✓</span> Authority distributed to money pages</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- DISCOVERY / AUDIT -->
  <section class="case-narrative-section">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">03 · The SEO audit</span>
        <h2 class="h-lg">What the audit <span class="accent">uncovered</span></h2>
        <p class="lede">Before automation could work, we had to understand why the site was not generating leads — and what needed to change.</p>
      </div>
      <div class="audit-grid">
        <div class="audit-card">
          <div class="audit-num">0</div>
          <h3>Organic leads / week</h3>
          <p>Website traffic existed but converted poorly. No dedicated landing pages, no clear conversion paths, no lead magnets.</p>
        </div>
        <div class="audit-card">
          <div class="audit-num">12</div>
          <h3>Total blog posts</h3>
          <p>Published sporadically over 2 years. Most were outdated, thin, or targeting low-intent keywords with no search volume.</p>
        </div>
        <div class="audit-card">
          <div class="audit-num">0%</div>
          <h3>Publishing automation</h3>
          <p>Every step was manual — from keyword research in spreadsheets to uploading in WordPress. Zero workflow automation.</p>
        </div>
        <div class="audit-card">
          <div class="audit-num">4</div>
          <h3>Competitors outranking</h3>
          <p>Four direct competitors dominated high-intent solar engineering keywords. The firm was invisible for terms their buyers searched.</p>
        </div>
        <div class="audit-card">
          <div class="audit-num">3.8s</div>
          <h3>Average page load</h3>
          <p>Unoptimized images, no caching strategy, and bloated scripts hurt Core Web Vitals and rankings before content had a chance.</p>
        </div>
        <div class="audit-card">
          <div class="audit-num">0</div>
          <h3>Internal link structure</h3>
          <p>Blog posts existed in isolation. No topic clusters, no pillar pages, no strategic internal linking to distribute authority.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- THE PLAN -->
  <section class="case-narrative-section alt">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">04 · The plan</span>
        <h2 class="h-lg">4-phase growth <span class="accent">strategy</span></h2>
      </div>
      <div class="case-timeline">
        <div class="case-timeline-row">
          <div class="case-timeline-marker"><span>01</span></div>
          <div class="case-timeline-card">
            <h3 class="case-timeline-title">Foundation + audit</h3>
            <p>Fixed technical issues, implemented schema markup, optimized page speed, and built a conversion-focused landing page structure.</p>
          </div>
        </div>
        <div class="case-timeline-row">
          <div class="case-timeline-marker"><span>02</span></div>
          <div class="case-timeline-card">
            <h3 class="case-timeline-title">Content engine activation</h3>
            <p>Deployed automated keyword research and began publishing 30+ SEO-optimized articles per month targeting solar engineering intent.</p>
          </div>
        </div>
        <div class="case-timeline-row">
          <div class="case-timeline-marker"><span>03</span></div>
          <div class="case-timeline-card">
            <h3 class="case-timeline-title">Topic cluster build</h3>
            <p>Organized content into pillar-cluster structures around core services: residential design, commercial engineering, permitting, and utility-scale PV.</p>
          </div>
        </div>
        <div class="case-timeline-row">
          <div class="case-timeline-marker"><span>04</span></div>
          <div class="case-timeline-card">
            <h3 class="case-timeline-title">Conversion optimization</h3>
            <p>Added lead capture forms, service-specific CTAs, and consultation booking flows to convert rising traffic into qualified leads.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE APPROACH -->
  <section class="case-narrative-section">
    <div class="case-narrative-wrap">
      <div class="case-narrative-head">
        <span class="label-pill">05 · The approach</span>
        <h2 class="h-lg">Two modules. <span class="accent">One growth engine.</span></h2>
        <p class="lede">We mapped every commercial-intent keyword a solar EPC buyer types into Google — then handed Content SEO and Local SEO the keys.</p>
      </div>
      <div class="case-approach-grid">
        <div class="case-approach-card">
          <div class="case-approach-num">01</div>
          <h3 class="h-sm">Content SEO</h3>
          <p>3,000-word pillar articles on solar plant design, single-line diagrams, structural calculations, and grid-tie studies — the queries Solar Engineering Services' buyers actually search.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> 4 articles per week, auto-published to the live site</li>
            <li><span class="case-tick">✓</span> Brand-voice trained on 12 existing case studies</li>
            <li><span class="case-tick">✓</span> Internal linking auto-built across 80+ pages</li>
            <li><span class="case-tick">✓</span> Schema markup on every article — Article + FAQPage</li>
          </ul>
          <a href="/modules/content-seo/" class="case-approach-cta">Explore Content SEO <span class="arrow">→</span></a>
        </div>
        <div class="case-approach-card">
          <div class="case-approach-num">02</div>
          <h3 class="h-sm">Local SEO</h3>
          <p>The team serves clients across Gujarat, Maharashtra, and Rajasthan. We tuned the Google Business Profile, fixed citations across 38 directories, and started shipping weekly GBP posts.</p>
          <ul class="case-approach-list">
            <li><span class="case-tick">✓</span> GBP profile rebuilt with service-area coverage</li>
            <li><span class="case-tick">✓</span> 38 directory citations cleaned in 14 days</li>
            <li><span class="case-tick">✓</span> Auto-responses on every Google review within 1h</li>
            <li><span class="case-tick">✓</span> Map Pack rank tracking for 14 queries weekly</li>
          </ul>
          <a href="/modules/local-seo/" class="case-approach-cta">Explore Local SEO <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- THE RESULTS -->
  <section class="case-results-section">
    <div class="case-results-head">
      <span class="label-pill">06 · The results</span>
      <h2 class="h-lg">120 days in. <span class="accent">A different business.</span></h2>
      <p class="lede">Numbers from Google Search Console, GA4, and the Solar Engineering Services CRM. No vanity stats.</p>
    </div>
    <div class="stats-row case-results-grid">
      <div class="stat-cell"><div class="stat-num">20<span class="accent">+</span></div><div class="stat-label">Qualified leads / week · from 0</div></div>
      <div class="stat-cell"><div class="stat-num">340<span class="accent">+</span></div><div class="stat-label">Page-1 keywords · from 12</div></div>
      <div class="stat-cell"><div class="stat-num">85<span class="accent">%</span></div><div class="stat-label">SEO time saved · 25h → 3h weekly</div></div>
      <div class="stat-cell"><div class="stat-num">62<span class="accent">k</span></div><div class="stat-label">Impressions / month · from 1.4k</div></div>
    </div>
    <div class="stats-row case-results-grid second">
      <div class="stat-cell"><div class="stat-num">82</div><div class="stat-label">Articles live · in 120 days</div></div>
      <div class="stat-cell"><div class="stat-num">$3,200</div><div class="stat-label">Saved / month vs. old agency</div></div>
      <div class="stat-cell"><div class="stat-num">150<span class="accent">+</span></div><div class="stat-label">Indexed pages · from 18</div></div>
      <div class="stat-cell"><div class="stat-num">4.8<span class="accent">k</span></div><div class="stat-label">Organic visits / month · from 120</div></div>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="case-pullquote-section">
    <div class="case-pullquote-wrap">
      <div class="case-pullquote-mark">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c.25 0 .25.5.25 1v1c0 1-1 2-2 2-.75 0-1 .25-1 1v2c0 1 0 1 1 1z"/></svg>
      </div>
      <blockquote class="case-pullquote">
        theStacc turned SEO into an <span class="accent">automated growth engine</span> for our business. We used to spend 25 hours a week chasing drafts. Now we approve a few articles, our phone rings every day, and we get back to engineering.
      </blockquote>
      <div class="case-pullquote-attr">
        <div class="case-avatar orange">S</div>
        <div>
          <div class="case-pullquote-name">Solar Engineering Services</div>
          <div class="case-pullquote-role">Design &amp; engineering firm · Surat, Gujarat</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="case-timeline-section">
    <div class="case-timeline-head">
      <span class="label-pill">07 · Timeline</span>
      <h2 class="h-lg">From signup to compounding traffic, <span class="accent">in 120 days.</span></h2>
    </div>
    <div class="case-timeline">
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 1</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">Onboarding · 22 minutes</h3>
          <p>Connected WordPress, Google Search Console, and GBP. Brand voice trained on 12 existing case studies. Keyword map generated for 240 commercial-intent queries.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 7</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">First 4 articles live</h3>
          <p>Pillar pieces on rooftop solar plant design, ground-mount engineering, single-line diagrams, and structural load calculations. Each scored 92+ on internal SEO grade.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 30</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">First 3 leads from organic</h3>
          <p>An EPC firm in Pune submitted a contact form quoting a passage from the rooftop design article. Two more inbound leads followed that week. 38 directory citations cleaned.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 60</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">62 keywords ranked · GBP up to top 3</h3>
          <p>Map Pack ranking for "solar plant design consultant Surat" jumped from #14 to #2. Inbound calls started arriving from GBP, not just the form.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 90</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">12+ qualified leads a week</h3>
          <p>The pipeline got dense enough that the team paused outbound. Cancelled the old freelancer agency contract. Saved $3,200 a month from week one of the cancellation.</p>
        </div>
      </div>
      <div class="case-timeline-row">
        <div class="case-timeline-marker"><span>Day 120</span></div>
        <div class="case-timeline-card">
          <h3 class="case-timeline-title">340+ keywords · 20+ leads / week</h3>
          <p>Founder back to 3 hours a week on SEO — just approving the weekly content queue. The rest of the work runs on autopilot. Average article still ranks in 58 days.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TOOLS USED -->
  <section class="case-tools-section">
    <div class="case-tools-head">
      <span class="label-pill">08 · Tools used</span>
      <h2 class="h-lg">What's running in the background.</h2>
    </div>
    <div class="case-tools-grid">
      <a class="case-tools-card" href="/modules/content-seo/">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/></svg>
        </div>
        <h3 class="case-tools-title">Content SEO module</h3>
        <p>4 long-form articles every week, auto-published to WordPress, internal links auto-built.</p>
        <span class="case-tools-link">Explore <span class="arrow">→</span></span>
      </a>
      <a class="case-tools-card" href="/modules/local-seo/">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3 class="case-tools-title">Local SEO module</h3>
        <p>GBP automation, citation cleanup, weekly Map Pack rank tracking across 14 service-area queries.</p>
        <span class="case-tools-link">Explore <span class="arrow">→</span></span>
      </a>
      <div class="case-tools-card static">
        <div class="case-tools-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="case-tools-title">Integrations</h3>
        <p>WordPress, Google Search Console, Google Business Profile, GA4. Zero copy-paste between tools.</p>
        <span class="case-tools-link">8 integrations live</span>
      </div>
    </div>
  </section>

  <!-- WHAT'S NEXT -->
  <section class="case-next-section">
    <div class="case-next-wrap">
      <span class="label-pill">09 · What's next</span>
