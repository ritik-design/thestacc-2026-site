---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'White Label SEO — Resell SEO Under Your Brand | theStacc',
  description: 'White label SEO platform for agencies. Per-client brand voice, branded reports, custom domain dashboard. Charge $2,500/mo, spend $99. $1 trial.',
  canonical: 'https://thestacc.com/white-label-seo/',
  ogImage: '/og/white-label-seo.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "White Label SEO", "item": "https://thestacc.com/white-label-seo/" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is white label SEO?",
            "acceptedAnswer": { "@type": "Answer", "text": "White label SEO is when an agency resells an SEO platform under its own brand. theStacc writes, ranks, and publishes content for your clients — they see your logo, your domain, your reports. They never see theStacc." }
          },
          {
            "@type": "Question",
            "name": "How does white label SEO pricing work?",
            "acceptedAnswer": { "@type": "Answer", "text": "You pay theStacc $99 per client account per month. You bill your clients whatever you want — most agencies charge $1,500–$3,500 per client. The margin is yours." }
          },
          {
            "@type": "Question",
            "name": "Can I host the dashboard on my own domain?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. Point a subdomain like seo.youragency.com to theStacc. Clients log in at your domain, see your logo, and never know theStacc is in the stack." }
          },
          {
            "@type": "Question",
            "name": "Are the reports white labeled?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. Monthly PDF reports use your agency logo, your colors, and ship from your email domain. Clients see your brand end-to-end." }
          },
          {
            "@type": "Question",
            "name": "Does each client get their own brand voice?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. Brand voice is set per client account (tone, vocabulary, sample articles). Each client's content sounds like that client, not like AI." }
          },
          {
            "@type": "Question",
            "name": "Can I cancel a single client account?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. Each client account is billed and cancelled independently at $99/mo. Drop one, keep the rest." }
          },
          {
            "@type": "Question",
            "name": "How fast can I onboard a new client?",
            "acceptedAnswer": { "@type": "Answer", "text": "5 minutes. Add the client, set brand voice, connect their CMS. The first article ships within 24 hours." }
          },
          {
            "@type": "Question",
            "name": "Will Google penalize white label AI content?",
            "acceptedAnswer": { "@type": "Answer", "text": "No. Google rewards helpful content regardless of source. Every article passes the AI Humanizer + SME review + schema layer. 4M+ words shipped, zero penalties." }
          },
          {
            "@type": "Question",
            "name": "What if my client wants to leave?",
            "acceptedAnswer": { "@type": "Answer", "text": "Every article we publish stays on the client's CMS — they own it. You can also export the full archive from theStacc. No clawback." }
          },
          {
            "@type": "Question",
            "name": "Do you offer reseller pricing for 25+ clients?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes. Agencies running 25+ accounts get reseller pricing. Book a call at /contact/ to get a custom quote." }
          }
        ]
      }
    ]
  }
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section">
    <a href="/solutions/agencies/" class="hero-pill">
      <span class="pill-dot"></span>
      <span>Built for agencies running 10–60 clients</span>
      <span class="pill-arrow">→</span>
    </a>
    <h1 class="h-display">White label SEO that ships <span class="accent">under your brand.</span></h1>
    <p class="hero-sub">Resell <strong>SEO content, GBP automation, and monthly reporting</strong> under your agency's logo. Per-client brand voice. Your domain, your colors, your reports. Charge $2,500/mo. Spend $99. Keep the difference.</p>

    <div class="hero-ctas">
      <a href="/checkout/" class="btn btn-primary"><span>Start your $1 trial <span class="arrow">→</span></span></a>
      <a href="/demo/" class="btn btn-secondary">Book a 15-min demo</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item">
        <div class="hero-avatars"><div class="av">F</div><div class="av">N</div><div class="av">A</div><div class="av">C</div></div>
        <span><strong>22+</strong> agencies reselling theStacc</span>
      </div>
      <div class="hero-meta-item">
        <span class="hero-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span><strong>4.9</strong> · 89 reviews on G2</span>
      </div>
    </div>
  </section>

  <!-- TRUST -->
  <section class="trust-section">
    <div class="trust-head">
      <p class="trust-label">Powering white label SEO for 22 agencies</p>
      <div class="trust-rating">
        <span class="trust-stars">
          <svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg><svg><use href="#i-star"/></svg>
        </span>
        <span class="trust-rating-text"><strong>4.9</strong> from <strong>127 reviews</strong></span>
      </div>
    </div>
    <div class="trust-logos">
      <div class="trust-logo"><img src="/customer-logos/replydaddy.webp" alt="ReplyDaddy" loading="lazy"/><span>ReplyDaddy</span></div>
      <div class="trust-logo"><img src="/customer-logos/noobbooklm.webp" alt="NoobBookLM" loading="lazy"/><span>NoobBookLM</span></div>
      <div class="trust-logo"><img src="/customer-logos/chartmath.webp" alt="ChartMath" loading="lazy"/><span>ChartMath</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-designs.webp" alt="Heaven Designs" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/heaven-green-energy.webp" alt="Heaven Green Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/qbits.webp" alt="Qbits Energy" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/quickestimate.webp" alt="QuickEstimate" loading="lazy"/></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/intello.webp" alt="Intello" loading="lazy"/></div>
      <div class="trust-logo"><img src="/customer-logos/suryantra-energy.webp" alt="Suryantra Energy" loading="lazy"/><span>Suryantra Energy</span></div>
      <div class="trust-logo logo-only"><img src="/customer-logos/suncart.svg" alt="Suncart" loading="lazy"/></div>
    </div>
  </section>

  <!-- WHAT IS WHITE LABEL SEO (snippet target) -->
  <section class="solution-section">
    <div class="solution-grid">
      <div class="solution-left">
        <span class="label-pill">Definition</span>
        <h2 class="h-lg">What is <span class="accent hl-highlight">white label SEO?</span></h2>
      </div>
      <div class="solution-right">
        <strong>White label SEO is when an agency resells an SEO platform under its own brand.</strong> theStacc writes the content, manages the Google Business Profile, and ships the monthly reports — but your clients see your logo, your domain, and your reports. They never see theStacc in the loop. You charge $1,500–$3,500/mo per client. You pay theStacc $99. The margin is yours.
      </div>
    </div>
  </section>

  <!-- STATS ROW -->
  <section>
    <div class="stats-row">
      <div class="stat-cell"><div class="stat-num">$99</div><div class="stat-label">Your cost per client account</div></div>
      <div class="stat-cell"><div class="stat-num">$2,500</div><div class="stat-label">Avg agency bill rate / client</div></div>
      <div class="stat-cell"><div class="stat-num">96<span class="accent">%</span></div><div class="stat-label">Gross margin per account</div></div>
      <div class="stat-cell"><div class="stat-num">5<span class="accent">min</span></div><div class="stat-label">To onboard a new client</div></div>
    </div>
  </section>

  <!-- WHY MOST WHITE LABEL TOOLS FAIL -->
  <section class="problem-section">
    <div class="problem-header">
      <span class="label-pill">01 · The problem</span>
      <h2 class="h-lg">Most "white label SEO" tools are <span class="accent">just a rebranded dashboard.</span></h2>
      <p>The market is full of resellers selling you a logo upload and calling it white label. Here's what's actually missing — and what theStacc gives every agency.</p>
    </div>
    <div class="ba-grid">
      <div class="ba-col before">
        <div class="ba-head">
          <span class="ba-label">Other white-label platforms</span>
          <h3 class="ba-title">Rebrand only. You still ship the work.</h3>
          <p class="ba-sub">Where most reseller tools stop.</p>
        </div>
        <ul class="ba-list">
          <li><span class="ba-num">01</span><div><h4>Dashboard rebrand, nothing else</h4><p>Logo upload, that's the whole "white label." Content, posts, reviews — you still do them.</p></div></li>
          <li><span class="ba-num">02</span><div><h4>No content production</h4><p>You bring the writers. The platform is just rank tracking with your logo.</p></div></li>
          <li><span class="ba-num">03</span><div><h4>Reports require manual work</h4><p>Screenshots, Looker, PowerPoint. Designer eats 30 hours a month.</p></div></li>
          <li><span class="ba-num">04</span><div><h4>Per-seat pricing, not per-client</h4><p>You pay $500/seat. Margin gets eaten the moment you scale.</p></div></li>
          <li><span class="ba-num">05</span><div><h4>One brand voice across all clients</h4><p>Every article sounds the same. Clients notice. Cancellations spike.</p></div></li>
        </ul>
      </div>
      <div class="ba-divider"><span>→</span></div>
      <div class="ba-col after">
        <div class="ba-head">
          <span class="ba-label">White label SEO with theStacc</span>
          <h3 class="ba-title">End-to-end. We ship. You bill.</h3>
          <p class="ba-sub">Where you land in your first 30 days.</p>
        </div>
        <ul class="ba-list">
          <li><span class="ba-num">01</span><div><h4>End-to-end branded experience</h4><p>Custom domain, custom email, custom report PDF — clients never see theStacc anywhere.</p></div></li>
          <li><span class="ba-num">02</span><div><h4>30 articles ship per client / month</h4><p>SEO-scored, on-brand, published. Zero writers in your roster.</p></div></li>
          <li><span class="ba-num">03</span><div><h4>Auto-generated branded reports</h4><p>Monthly PDF lands in client inbox on the 1st — your logo, your colors.</p></div></li>
          <li><span class="ba-num">04</span><div><h4>Per-account pricing — $99 flat</h4><p>Scale to 60 clients without seat fees. Margin grows with you.</p></div></li>
          <li><span class="ba-num">05</span><div><h4>Per-client brand voice</h4><p>Each account has its own tone, vocabulary, and SME profile. Clients can't tell it's AI.</p></div></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- WHAT TO LOOK FOR -->
  <section class="benefits-section">
    <div class="benefits-header">
      <span class="label-pill">02 · What to look for</span>
      <h2 class="h-lg">5 criteria for picking a <span class="accent">white label SEO platform.</span></h2>
      <p class="lede">If any one of these is missing, the platform isn't white label — it's just a rebranded tool.</p>
    </div>
    <div class="benefits-grid">
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-trend"/></svg></div>
        <h3 class="h-sm">1. Custom domain dashboard.</h3>
        <p>Clients log in at <code>seo.youragency.com</code>, not <code>app.somesaas.com</code>. Non-negotiable.</p>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-dollar"/></svg></div>
        <h3 class="h-sm">2. Per-account pricing.</h3>
        <p>Flat fee per client, not per seat. You scale to 60 clients without paying for 60 seats.</p>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-clock"/></svg></div>
        <h3 class="h-sm">3. Per-client brand voice.</h3>
        <p>Each account has its own tone. Clients shouldn't notice the same engine writes for 40 of them.</p>
      </div>
      <div class="benefit-cell">
        <div class="benefit-icon-box"><svg><use href="#i-target"/></svg></div>
        <h3 class="h-sm">4. Auto-generated reports.</h3>
        <p>Branded PDF or web dashboard, on the 1st, every month. Without a designer touching it.</p>
      </div>
    </div>
  </section>

  <!-- HOW THESTACC WHITE LABELS -->
  <section class="howitworks-section">
    <div class="howitworks-header">
      <span class="label-pill">How theStacc white labels</span>
      <h2 class="h-lg">From rebrand to revenue, <span class="accent">in 3 steps.</span></h2>
      <p class="lede">No engineering. No long onboarding. Set it up once, run 60 clients.</p>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">01</span><span class="step-day">Day 1 · 10 minutes</span></div>
          <h3 class="h-md">Brand the platform <span class="accent">as yours.</span></h3>
          <p>Upload your logo, set your colors, point a subdomain to theStacc. Connect your email sender. Done — clients see your brand from login to report.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Custom subdomain (seo.youragency.com)</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Logo, brand colors, custom favicon</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Email reports ship from your domain</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-1">
            <div class="step-card-header"><span class="step-card-tag">BRAND SETUP · 8 MIN</span><span class="step-card-status">● Complete</span></div>
            <div class="step-card-row"><span class="step-card-key">Domain</span><span class="step-card-val">seo.northwind.agency</span></div>
            <div class="step-card-row"><span class="step-card-key">Logo</span><span class="step-card-val">northwind-mark.svg ✓</span></div>
            <div class="step-card-row"><span class="step-card-key">Colors</span><span class="step-card-val">#0a2540 · #f7a000</span></div>
            <div class="step-card-row"><span class="step-card-key">Email</span><span class="step-card-val">reports@northwind.agency ✓</span></div>
            <div class="step-card-row highlight"><span class="step-card-key">Status</span><span class="step-card-val"><strong>Live · clients see Northwind only</strong></span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid reverse">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">02</span><span class="step-day">Per client · 5 minutes</span></div>
          <h3 class="h-md">Add a client. Ship <span class="accent">within 24 hours.</span></h3>
          <p>One form per client: industry, location, brand voice, target keywords, CMS access. theStacc generates the keyword map and starts publishing the next day.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Per-client brand voice locked in</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>1-click CMS connect</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>First article shipped in 24h</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-2">
            <div class="step-card-header"><span class="step-card-tag">CLIENT FEED · LIVE</span><span class="step-card-status">● Auto</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 09:00</span><span class="step-feed-text">Client #14 added · Bayside Dental</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Mon 09:05</span><span class="step-feed-text">Brand voice trained · 4 sample articles</span></div>
            <div class="step-feed-item"><span class="step-feed-dot done"></span><span class="step-feed-time">Tue 06:14</span><span class="step-feed-text">First article live · "Dental implants Austin"</span></div>
            <div class="step-feed-item"><span class="step-feed-dot live"></span><span class="step-feed-time">Now</span><span class="step-feed-text">29 more queued for the month</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="step-block">
      <div class="step-grid">
        <div class="step-text">
          <div class="step-meta"><span class="step-num">03</span><span class="step-day">1st of every month</span></div>
          <h3 class="h-md">Branded reports <span class="accent">ship from your email.</span></h3>
          <p>Every client gets a PDF on the 1st: rankings, traffic, conversions, what shipped. Your logo on the cover, your domain on the footer. You log in once a month to check that the wins line up.</p>
          <ul>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Auto-sent on the 1st, every month</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>GA4 + GSC + GBP rolled into one PDF</li>
            <li><span class="icon"><svg><use href="#i-check"/></svg></span>Your brand on every page</li>
          </ul>
        </div>
        <div class="step-visual">
          <div class="step-card-3">
            <div class="step-card-header"><span class="step-card-tag">REPORT · NOV 2026</span><span class="step-card-status">● Sent</span></div>
            <div class="step-stat-big">
              <span class="step-stat-num">34/34</span>
              <span class="step-stat-label">Reports sent on Nov 1</span>
              <span class="step-stat-delta">100% on-time</span>
            </div>
            <div class="step-stat-row">
              <div><strong>34</strong> clients</div>
              <div><strong>$99</strong> cost each</div>
              <div><strong>$2.5k</strong> avg billed</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="cost-section">
    <div class="cost-header">
      <span class="label-pill">White label SEO compared</span>
      <h2 class="h-lg">theStacc vs. <span class="accent">every other reseller tool.</span></h2>
      <p>What you get for $99/client at theStacc vs. what other platforms charge.</p>
    </div>
    <div class="cost-table">
      <div class="cost-row head">
        <div class="cost-cell head-cell">Per client / month</div>
        <div class="cost-cell head-cell">Vendasta</div>
        <div class="cost-cell head-cell">SE Ranking</div>
        <div class="cost-cell head-cell brand">theStacc</div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Content production</div><div class="price" style="font-size:15px;font-weight:600;">30 articles / mo</div></div>
        <div class="cost-cell"><div class="price crossed">add-on</div><div class="per">+$1,200</div></div>
        <div class="cost-cell"><div class="price crossed">not incl.</div><div class="per">DIY</div></div>
        <div class="cost-cell brand"><div class="price brand">incl.</div><div class="per">in $99</div></div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">GBP automation</div><div class="price" style="font-size:15px;font-weight:600;">Posts + replies</div></div>
        <div class="cost-cell"><div class="price crossed">$249</div><div class="per">add-on</div></div>
        <div class="cost-cell"><div class="price crossed">$89</div><div class="per">add-on</div></div>
        <div class="cost-cell brand"><div class="price brand">incl.</div><div class="per">in $99</div></div>
      </div>
      <div class="cost-row">
        <div class="cost-cell label"><div class="vert">Branded reports</div><div class="price" style="font-size:15px;font-weight:600;">Monthly PDF</div></div>
        <div class="cost-cell"><div class="price crossed">$59</div><div class="per">per client</div></div>
        <div class="cost-cell"><div class="price crossed">$39</div><div class="per">per client</div></div>
        <div class="cost-cell brand"><div class="price brand">incl.</div><div class="per">in $99</div></div>
      </div>
      <div class="cost-savings">
        <div class="big">$99 in, $2,500 out — per client</div>
        <div class="lbl">Compare to $1,508 in / $2,500 out elsewhere</div>
      </div>
      <div class="cost-footnote">*Competitor pricing sourced from public sites in 2026. Production costs not included by competitors require external freelancer spend.</div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials-section dark">
    <div class="testimonials-wrap">
      <div class="testimonials-grid">
        <div class="testimonials-left">
          <span class="label-pill">03 · Real agencies</span>
          <h2 class="h-lg">Agencies that <span class="accent">scaled past 30 clients</span> on theStacc.</h2>
          <p>From boutique 6-client studios to 60-client white-label resellers — same engine, same $99/client cost.</p>
          <a href="/case-studies/" class="testimonials-cta">Read all case studies <span class="arrow">→</span></a>
        </div>
        <div class="testimonials-right">
          <div class="case-card">
            <div class="case-card-top">
              <div class="t-avatar purple">F</div>
              <div><div class="t-name">Finnian Graves · Founder</div><div class="t-role">NORTHWIND · SEO AGENCY</div></div>
              <span class="verified"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg> Verified · 6 months</span>
            </div>
            <p class="case-card-quote">"We scaled from 6 to 22 client accounts <span class="accent">without hiring a single writer.</span> Brand voice per client — clients can't tell their content is AI. Reports auto-ship on the 1st. I haven't opened Looker Studio in 4 months."</p>
            <div class="case-stats">
              <div class="case-stat"><div class="v">22</div><div class="l">Clients managed</div></div>
              <div class="case-stat"><div class="v brand">$99</div><div class="l">Cost / account</div></div>
              <div class="case-stat"><div class="v">$2.4k</div><div class="l">Avg client bill</div></div>
              <div class="case-stat"><div class="v brand">96%</div><div class="l">Gross margin</div></div>
            </div>
          </div>

          <div class="t-card">
            <div class="t-card-top">
              <div class="t-avatar cyan">A</div>
              <div><div class="t-name">Anders Loft</div><div class="t-role">DIRECTOR · MIDWAY MARKETING (34 CLIENTS)</div></div>
              <div class="t-quote-mark"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c.25 0 .25.5.25 1v1c0 1-1 2-2 2-.75 0-1 .25-1 1v2c0 1 0 1 1 1z"/></svg></div>
            </div>
            <p class="t-card-quote">Client reports take <span class="accent">zero hours from my team.</span> Branded PDF lands on the 1st. Clients renew without asking.</p>
          </div>

          <div class="t-card">
            <div class="t-card-top">
              <div class="t-avatar orange">M</div>
