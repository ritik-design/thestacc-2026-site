---
import BaseLayout from '../../layouts/BaseLayout.astro';

const seo = {
  title: 'Changelog — What we shipped this month | theStacc',
  description: 'Every feature, fix, and improvement we shipped to theStacc — in reverse chronological order. New features ship every Tuesday.',
  canonical: 'https://thestacc.com/changelog/',
  ogImage: '/og/changelog.webp',
  schemaData: {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://thestacc.com/" },
          { "@type": "ListItem", "position": 2, "name": "Changelog", "item": "https://thestacc.com/changelog/" }
        ]
      },
      {
        "@type": "ItemList",
        "name": "theStacc changelog",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "AI Humanizer v3", "url": "https://thestacc.com/changelog/#v3-4-0" },
          { "@type": "ListItem", "position": 2, "name": "Shopify connector", "url": "https://thestacc.com/changelog/#v3-3-0" },
          { "@type": "ListItem", "position": 3, "name": "Map Pack heat-map", "url": "https://thestacc.com/changelog/#v3-2-0" }
        ]
      }
    ]
  }
};

const entries = [
  {
    version: 'v3.4.0',
    id: 'v3-4-0',
    date: 'June 24, 2026',
    category: 'Feature',
    title: 'AI Humanizer v3 — every article passes Originality.ai with a 99% score.',
    summary: 'We retrained the humanizer model on 30,000 articles flagged by every major AI detector. The new model rewrites your draft so no detector can flag it. Auto-runs on every article.',
    details: [
      'Average detector score: 99% human (up from 91%)',
      'No extra step in your workflow — runs on every draft',
      'Bypasses Originality.ai, GPTZero, Copyleaks, Turnitin, ZeroGPT',
      'Adds 8 to 12 seconds to the publishing pipeline',
      'Free for every customer on every plan',
    ],
  },
  {
    version: 'v3.3.0',
    id: 'v3-3-0',
    date: 'June 17, 2026',
    category: 'Feature',
    title: 'Shopify connector — auto-publish to your storefront blog in one click.',
    summary: 'You can now connect a Shopify store and ship every article straight to your blog. No code. No webhook. Approval flow optional.',
    details: [
      'OAuth connection — no API keys to copy and paste',
      'Auto-tags, auto-categories, auto-author byline',
      'Publishes with featured image, SEO meta, and product cross-links',
      'Works with Shopify Plus and standard plans',
      'Optional approval queue before publish',
    ],
  },
  {
    version: 'v3.2.0',
    id: 'v3-2-0',
    date: 'June 10, 2026',
    category: 'Feature',
    title: 'Map Pack heat-map — see your rank in every grid square around your business.',
    summary: 'A 9×9 grid around your location shows your Google Maps rank for every keyword you track. Spot weak zones. Fix them with targeted GBP posts.',
    details: [
      'Default radius: 5 miles (configurable up to 25)',
      'Tracks 81 grid points per keyword',
      'Refreshes daily, history retained for 12 months',
      'Available on Local SEO and Bundle plans',
      'CSV export and PNG snapshot for client reports',
    ],
  },
  {
    version: 'v3.1.2',
    id: 'v3-1-2',
    date: 'June 6, 2026',
    category: 'Improvement',
    title: 'Brand voice training: 30 samples now enough (was 50).',
    summary: 'We improved the voice model so customers can start ranking with half the training data. Same accuracy.',
    details: [
      'Required samples dropped from 50 to 30',
      'Brand voice match score: 94% (vs 91% in v3.0)',
      'Faster onboarding — first article live in 24 hours',
      'Existing customers automatically benefit on next regeneration',
    ],
  },
  {
    version: 'v3.1.1',
    id: 'v3-1-1',
    date: 'May 30, 2026',
    category: 'Fix',
    title: 'Webflow CMS push — fixed broken alt text on image fields.',
    summary: 'Some Webflow collections were receiving empty alt text on hero images. Fixed at the API layer — no action needed on your end.',
    details: [
      'Affected Webflow customers between May 22 and May 29',
      'Auto-backfill ran on every affected article',
      'No SEO impact (alt text rewritten before Google recrawl)',
      'Apology email sent to 23 affected customers',
    ],
  },
  {
    version: 'v3.1.0',
    id: 'v3-1-0',
    date: 'May 23, 2026',
    category: 'Feature',
    title: 'Auto review responses — now in 12 languages.',
    summary: 'Reply to every Google review in the language the reviewer wrote in. English, Spanish, Hindi, French, German, Portuguese, Tagalog, Vietnamese, Mandarin, Arabic, Italian, Japanese.',
    details: [
      '12 languages auto-detected per review',
      'Tone matches your brand voice in every language',
      'Reply time still under 5 minutes',
      'Free for every Local SEO customer',
    ],
  },
  {
    version: 'v3.0.4',
    id: 'v3-0-4',
    date: 'May 17, 2026',
    category: 'Security',
    title: 'OAuth scope tightening — Google connection now read-only by default.',
    summary: 'We narrowed the scopes we request from Google. Read-only is now the default for GBP. Posting access is requested only when you turn auto-publish on.',
    details: [
      'Default scopes: read-only',
      'Write scopes requested only on auto-publish opt-in',
      'Existing customers re-prompted on next sign-in',
      'Audit trail of every scope change in the dashboard',
    ],
  },
  {
    version: 'v3.0.3',
    id: 'v3-0-3',
    date: 'May 9, 2026',
    category: 'Improvement',
    title: 'Faster dashboard — 2.3× speed-up on the article list page.',
    summary: 'We moved the article-list query to a materialised view. Customers with 500+ articles see the biggest jump.',
    details: [
      'Median load time: 480ms (down from 1,100ms)',
      'P95 load time: 920ms (down from 2,800ms)',
      'Pagination switched from offset to cursor',
      'No UI changes — just faster',
    ],
  },
  {
    version: 'v3.0.2',
    id: 'v3-0-2',
    date: 'May 3, 2026',
    category: 'Fix',
    title: 'Stripe webhook retry — duplicate charges prevented.',
    summary: 'A rare race condition could cause a duplicate charge on plan upgrades. Patched. Refunds issued automatically.',
    details: [
      'Affected 4 customers between April 28 and May 2',
      'All duplicate charges refunded within 24 hours',
      'Webhook handler now idempotent by event_id',
      'Postmortem published in our public engineering blog',
    ],
  },
  {
    version: 'v3.0.1',
    id: 'v3-0-1',
    date: 'April 25, 2026',
    category: 'Improvement',
    title: 'Better dashboard onboarding — 4 steps cut to 2.',
    summary: 'New customers reach their first published article in under 12 minutes. Average dropped from 24 to 11 minutes.',
    details: [
      'Connect site → connect Google → done',
      'Brand voice training moved to background job',
      'No more "wait for setup to finish" screen',
      'Conversion to first publish: 78% (up from 61%)',
    ],
  },
  {
    version: 'v3.0.0',
    id: 'v3-0-0',
    date: 'April 17, 2026',
    category: 'Feature',
    title: 'Bundle plan — Content + Local + Social for $167/mo.',
    summary: 'One subscription. Three modules. Saves $30/mo versus à la carte. Comes with priority support and a unified weekly report.',
    details: [
      'All 3 modules under one login',
      'Unified Friday revenue-attribution email',
      'Priority Slack channel for Bundle customers',
      '$30/mo discount vs. à la carte ($197)',
      'Free upgrade from existing plans — no contract reset',
    ],
  },
  {
    version: 'v2.9.4',
    id: 'v2-9-4',
    date: 'April 8, 2026',
    category: 'Feature',
    title: 'Citation builder — submit to 50 directories in one click.',
    summary: 'NAP-consistent submissions to Yelp, Bing Places, Apple Maps, Yellow Pages, Foursquare and 45 more. Monitor changes daily.',
    details: [
      '50 directories supported at launch',
      'NAP consistency monitored daily',
      'Auto-correct on profile drift',
      'Free for every Local SEO customer',
    ],
  },
];

const categoryColors = {
  Feature: 'feature',
  Improvement: 'improvement',
  Fix: 'fix',
  Security: 'security',
};
---
<BaseLayout seo={seo}>

  <!-- HERO -->
  <section class="hero-section" style="padding-bottom: 64px;">
    <span class="label-pill" style="margin-bottom: 24px;">Changelog · v3.4.0 latest</span>
    <h1 class="h-display">What we shipped <span class="accent">this month.</span></h1>
    <p class="hero-sub">New features ship every Tuesday. Bug fixes ship daily. Every change that affects you is logged below. <strong>No marketing rewrites. Just the work.</strong></p>
  </section>

  <!-- SUBSCRIBE STRIP -->
  <section style="padding: 24px 32px; background: var(--bg-soft); border-bottom: 1px solid var(--border);">
    <div class="subscribe-strip">
      <div class="subscribe-left">
        <strong>Get changelog updates in your inbox.</strong>
        <span>One email per release. Easy unsubscribe.</span>
      </div>
      <div class="subscribe-right">
        <a href="/changelog/rss.xml" class="subscribe-btn ghost">
          <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M3.429 4.286A.857.857 0 0 0 2.571 5.143v1.714c0 .474.384.857.858.857a9 9 0 0 1 9 9c0 .473.383.857.857.857h1.714a.857.857 0 0 0 .857-.857c0-7.571-6.143-13.714-13.428-13.428zM3.429 9.429a.857.857 0 0 0-.858.857v1.714c0 .474.384.857.858.857a3.857 3.857 0 0 1 3.857 3.857c0 .473.383.857.857.857h1.714a.857.857 0 0 0 .857-.857c0-4.262-3.452-7.714-7.285-7.285zM4.286 15.857a1.714 1.714 0 1 1 0 3.429 1.714 1.714 0 0 1 0-3.429z"/></svg>
          RSS feed
        </a>
        <a href="mailto:product@thestacc.com?subject=Subscribe%20to%20changelog" class="subscribe-btn">
          Subscribe by email <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section style="padding: 80px 32px;">
    <div style="max-width: 880px; margin: 0 auto;">

      <div class="timeline">
        {entries.map((e, idx) => (
          <div class="timeline-row" id={e.id}>
            <div class="timeline-meta">
              <div class="timeline-date">{e.date}</div>
              <div class="timeline-version">{e.version}</div>
              <span class={`timeline-badge ${categoryColors[e.category]}`}>{e.category}</span>
            </div>

            <div class="timeline-dot-col">
              <div class={`timeline-dot ${idx === 0 ? 'live' : ''}`}></div>
              {idx < entries.length - 1 && <div class="timeline-line"></div>}
            </div>

            <div class="timeline-body">
              <h2 class="timeline-title">{e.title}</h2>
              <p class="timeline-summary">{e.summary}</p>
              <details class="timeline-details">
                <summary>
                  <span class="details-open">Show details</span>
                  <span class="details-close">Hide details</span>
                </summary>
                <ul>
                  {e.details.map((d) => (<li>{d}</li>))}
                </ul>
              </details>
            </div>
          </div>
        ))}
      </div>

      <div class="timeline-foot">
        <p>Looking for older releases? See <a href="/changelog/archive/">the full archive →</a></p>
      </div>
    </div>
  </section>

  <!-- CROSS-LINK STRIP -->
  <section style="padding: 64px 32px; background: var(--bg-soft); border-top: 1px solid var(--border);">
    <div style="max-width: 1080px; margin: 0 auto;">
      <div style="text-align: center; max-width: 600px; margin: 0 auto 40px;">
        <span class="label-pill" style="margin-bottom: 16px;">Beyond the changelog</span>
        <h2 class="h-md">Read the <span class="accent">why</span> behind the work.</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
        <a href="/blog/" class="cross-card">
          <div class="cross-eyebrow">Blog</div>
          <div class="cross-title">Engineering and growth notes →</div>
        </a>
        <a href="/features/" class="cross-card">
          <div class="cross-eyebrow">Features</div>
          <div class="cross-title">Every shipped capability →</div>
        </a>
        <a href="/about/" class="cross-card">
          <div class="cross-eyebrow">Team</div>
          <div class="cross-title">Who builds the product →</div>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─────── SUBSCRIBE STRIP ─────── */
  .subscribe-strip {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .subscribe-left strong { color: var(--text-1); font-weight: 600; font-size: 15px; margin-right: 8px; }
  .subscribe-left span { color: var(--text-3); font-size: 14px; }
  .subscribe-right { display: flex; gap: 8px; align-items: center; }
  .subscribe-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 40px;
    padding: 0 16px;
    background: var(--text-1);
    color: white;
    border-radius: 100px !important;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s;
  }
  .subscribe-btn:hover { background: var(--brand); }
  .subscribe-btn .arrow { transition: transform 0.2s; }
  .subscribe-btn:hover .arrow { transform: translateX(3px); }
  .subscribe-btn.ghost {
    background: white;
    color: var(--text-1);
    box-shadow: inset 0 0 0 1px var(--border-strong);
  }
  .subscribe-btn.ghost:hover { box-shadow: inset 0 0 0 1px var(--text-1); background: white; color: var(--text-1); }

  /* ─────── TIMELINE ─────── */
  .timeline { display: flex; flex-direction: column; gap: 0; }
  .timeline-row {
    display: grid;
    grid-template-columns: 180px 40px 1fr;
    gap: 24px;
    align-items: stretch;
    padding: 28px 0;
    scroll-margin-top: 100px;
  }
  .timeline-row:first-child { padding-top: 0; }

  .timeline-meta { padding-top: 4px; }
  .timeline-date {
    font-size: 13px;
    color: var(--text-3);
    margin-bottom: 6px;
    font-family: 'Geist Mono', monospace;
    letter-spacing: 0.04em;
  }
  .timeline-version {
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-1);
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }
  .timeline-badge {
    display: inline-block;
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 100px !important;
    border: 1px solid;
  }
  .timeline-badge.feature {
    background: var(--brand-softer);
    border-color: var(--brand-soft);
    color: var(--brand);
  }
  .timeline-badge.improvement {
    background: #ecfdf5;
    border-color: #a7f3d0;
    color: #047857;
  }
  .timeline-badge.fix {
    background: #fffbeb;
    border-color: #fde68a;
    color: #b45309;
  }
  .timeline-badge.security {
    background: #fef2f2;
    border-color: #fecaca;
    color: #b91c1c;
  }

  .timeline-dot-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 8px;
  }
  .timeline-dot {
    width: 14px;
    height: 14px;
    border-radius: 50% !important;
    background: white;
    border: 2px solid var(--border-strong);
    flex-shrink: 0;
  }
  .timeline-dot.live {
    background: var(--brand);
    border-color: var(--brand);
    box-shadow: 0 0 0 4px var(--brand-soft);
  }
  .timeline-line {
    flex: 1;
    width: 2px;
    background: var(--border);
    margin: 6px 0 -16px;
  }

  .timeline-body {
    background: white;
    border: 1px solid var(--border);
    padding: 24px 28px;
    transition: all 0.2s cubic-bezier(.2,.8,.2,1);
  }
  .timeline-body:hover {
    border-color: var(--brand);
    box-shadow: 0 18px 36px -14px rgba(79,57,246,0.12);
  }
  .timeline-title {
    font-size: 19px;
    font-weight: 600;
    color: var(--text-1);
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin-bottom: 10px;
  }
  .timeline-summary {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-2);
    margin-bottom: 16px;
  }

  .timeline-details {
    border-top: 1px solid var(--border);
    padding-top: 14px;
  }
  .timeline-details summary {
    cursor: pointer;
    list-style: none;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    color: var(--brand);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .timeline-details summary::-webkit-details-marker { display: none; }
  .timeline-details summary::after {
    content: '→';
    transition: transform 0.2s;
    font-family: 'Geist', sans-serif;
  }
  .timeline-details[open] summary::after { transform: rotate(90deg); }
  .timeline-details .details-close { display: none; }
  .timeline-details[open] .details-open { display: none; }
  .timeline-details[open] .details-close { display: inline; }

  .timeline-details ul {
    list-style: none;
    padding: 14px 0 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .timeline-details li {
    position: relative;
    padding-left: 18px;
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-2);
  }
  .timeline-details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background: var(--brand);
  }

  .timeline-foot {
    margin-top: 32px;
    padding: 24px;
    text-align: center;
    font-size: 14px;
    color: var(--text-3);
  }
  .timeline-foot a { color: var(--brand); font-weight: 500; }

  /* ─────── CROSS-LINKS ─────── */
  .cross-card {
    background: white;
    border: 1px solid var(--border);
    padding: 24px;
    transition: all 0.2s cubic-bezier(.2,.8,.2,1);
  }
  .cross-card:hover {
    border-color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 36px -14px rgba(79,57,246,0.18);
  }
  .cross-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--brand);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .cross-title { font-size: 17px; font-weight: 600; color: var(--text-1); letter-spacing: -0.015em; }
  .cross-card:hover .cross-title { color: var(--brand); }

  /* ─────── RESPONSIVE ─────── */
  @media (max-width: 900px) {
    .timeline-row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .timeline-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .timeline-date, .timeline-version { margin-bottom: 0; }
    .timeline-dot-col { display: none; }
    .subscribe-strip { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 700px) {
    section[style*="grid-template-columns: repeat(3, 1fr)"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
